theorem proposition_3_2_compositum_and_F_bridge (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1) :
    вҲғ (M : Type) (_ : Field M) (_ : CharZero M) (_ : NumberField M)
      (_ : IsTotallyReal M) (_ : IsGalois в„ҡ M)
      (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois в„ҡ F)
      (_ : Algebra F M) (_ : IsScalarTower в„ҡ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank в„ҡ M = 3 ^ в„“ вҲ§
      Nonempty ((M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3)) вҲ§
      (NumberField.discr M).natAbs = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1)) вҲ§
      Module.finrank в„ҡ F = 3 вҲ§
      Nonempty ((F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3)) вҲ§
      Module.finrank F M = 3 ^ (в„“ - 1) вҲ§
      Odd (Module.finrank F M) вҲ§
      (NumberField.discr F).natAbs = (вҲҸ i, r i) ^ 2 вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) := by
  classical
  rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt _hв„“) with вҹЁn, rflвҹ©
  induction n with
  | zero =>
      rcases proposition_3_2_compositum_and_F_bridge_base r _hr_prime _hr_inj _hr_mod3 with вҹЁdвҹ©
      refine вҹЁd.M, d.field_M, d.charZero_M, d.numberField_M, d.totallyReal_M, d.galoisQM,
        d.F, d.field_F, d.charZero_F, d.numberField_F, d.totallyReal_F, d.galoisQF,
        d.algFM, d.tower, d.finiteDimensional, d.galoisFM, ?_вҹ©
      exact вҹЁd.finrankQM, d.absGalM, d.discrM_eq, d.finrankQF, d.absGalF, d.finrankFM,
        d.odd_finrankFM, d.discrF_eq, d.pow_rel, d.comm_relвҹ©
  | succ k ih =>
      let r0 : Fin (k + 1) вҶ’ в„• := fun i => r (Fin.castSucc i)
      let s : в„• := r (Fin.last (k + 1))
      have hr0_prime : вҲҖ i, (r0 i).Prime := by
        intro i
        exact _hr_prime (Fin.castSucc i)
      have hr0_inj : Function.Injective r0 := by
        intro i j hij
        apply Fin.castSucc_injective
        exact _hr_inj hij
      have hr0_mod3 : вҲҖ i, r0 i % 3 = 1 := by
        intro i
        exact _hr_mod3 (Fin.castSucc i)
      have hs_prime : s.Prime := by
        exact _hr_prime (Fin.last (k + 1))
      have hs_ne : вҲҖ i, r0 i вү  s := by
        intro i
        dsimp [r0, s]
        intro h
        exact Fin.castSucc_ne_last i (_hr_inj h)
      have hs_mod3 : s % 3 = 1 := by
        exact _hr_mod3 (Fin.last (k + 1))
      rcases ih (Nat.succ_pos k) r0 hr0_prime hr0_inj hr0_mod3 with
        вҹЁM, hMField, hMCharZero, hMNumberField, hMTotallyReal, hMGalois,
          F, hFField, hFCharZero, hFNumberField, hFTotallyReal, hFGalois,
          hAlg, hTower, hFiniteDim, hGaloisFM, hfinrankQM, habsGalM, hdiscrM,
          hfinrankQF, habsGalF, hfinrankFM, hodd_finrankFM, hdiscrF, hpow_rel, hcomm_relвҹ©
      let d0 : Proposition32BridgeData (k + 1)
        ((вҲҸ i, r0 i) ^ 2)
        ((вҲҸ i, r0 i) ^ (2 * 3 ^ k)) :=
        { M := M
          field_M := hMField
          charZero_M := hMCharZero
          numberField_M := hMNumberField
          totallyReal_M := hMTotallyReal
          galoisQM := hMGalois
          F := F
          field_F := hFField
          charZero_F := hFCharZero
          numberField_F := hFNumberField
          totallyReal_F := hFTotallyReal
          galoisQF := hFGalois
          algFM := hAlg
          tower := hTower
          finiteDimensional := hFiniteDim
          galoisFM := hGaloisFM
          finrankQM := hfinrankQM
          absGalM := habsGalM
          discrM_eq := hdiscrM
          finrankQF := hfinrankQF
          absGalF := habsGalF
          finrankFM := hfinrankFM
          odd_finrankFM := hodd_finrankFM
          discrF_eq := hdiscrF
          pow_rel := hpow_rel
          comm_rel := hcomm_rel }
      rcases proposition_3_2_compositum_and_F_bridge_step k r0 hr0_prime hr0_inj hr0_mod3 d0 s hs_prime hs_ne hs_mod3 with вҹЁdвҹ©
      have hprod : ((вҲҸ i, r0 i) * s) = вҲҸ i, r i := by
        simpa [r0, s] using (Fin.prod_univ_castSucc (f := r)).symm
      refine вҹЁd.M, d.field_M, d.charZero_M, d.numberField_M, d.totallyReal_M, d.galoisQM,
        d.F, d.field_F, d.charZero_F, d.numberField_F, d.totallyReal_F, d.galoisQF,
        d.algFM, d.tower, d.finiteDimensional, d.galoisFM, ?_вҹ©
      exact вҹЁd.finrankQM, d.absGalM, by simpa [hprod] using d.discrM_eq, d.finrankQF,
        d.absGalF, d.finrankFM, d.odd_finrankFM, by simpa [hprod] using d.discrF_eq,
        d.pow_rel, d.comm_relвҹ©

theorem proposition_3_2_compositum_and_F_local (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)

      exact h𝔓
    rw [coe_primesOverFinset (p := p) hp0 (B := 𝓞 𝒟.K)] at h𝔓set
    rcases hsplitK 𝔓 h𝔓set with ⟨h𝔓e, h𝔓f⟩
    rw [h𝔓e, h𝔓f]
  have hsum :
      ∑ 𝔓 ∈ primesOverFinset p (𝓞 𝒟.K),
        Ideal.ramificationIdx p 𝔓 * Ideal.inertiaDeg p 𝔓 = Module.finrank ℚ 𝒟.K := by
    exact Ideal.sum_ramification_inertia (S := 𝓞 𝒟.K) (K := ℚ) (L := 𝒟.K) (p := p) hp0

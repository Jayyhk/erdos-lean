theorem primeOverQ_has_abs_split (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
(Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))
(T : ProPTowerFromQuotient F p Q)
(q : в„•) (_hq : q.Prime)
(_hq_splits_F :
  (вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F),
      Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
      Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1) вҲ§
    ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F)).ncard =
      Module.finrank в„ҡ F)
(_h_killed :
  вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ),
    рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F) вҶ’
    Q.map (@splittingDetectorAt F _ _ p _ рқ”ӯ hp hne) = 1)
(j : в„•) {рқ”“ : Ideal (рқ“һ (T.L j))}
(hрқ”“ : рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ (T.L j))) :
Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
  Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 := by
  let p0 : Ideal в„Ө := Ideal.span {(q : в„Ө)}
  let рқ”ӯ : Ideal (рқ“һ F) := Ideal.comap (algebraMap (рқ“һ F) (рқ“һ (T.L j))) рқ”“
  letI : Fact q.Prime := вҹЁ_hqвҹ©
  letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
  have hqz : (q : в„Ө) вү  0 := by
    exact_mod_cast _hq.ne_zero
  have hp0_ne_bot : p0 вү  вҠҘ := by
    intro hp0_bot
    have hspan : Ideal.span {(q : в„Ө)} = вҠҘ := by
      simpa [p0] using hp0_bot
    exact hqz ((Ideal.span_singleton_eq_bot).mp hspan)
  have hрқ”“' : рқ”“ вҲҲ p0.primesOver (рқ“һ (T.L j)) := by
    simpa [p0] using hрқ”“
  have hP_prime : рқ”“.IsPrime := hрқ”“'.1
  have hP_lies_q : рқ”“.LiesOver p0 := hрқ”“'.2
  letI : рқ”“.IsPrime := hP_prime
  letI : рқ”“.LiesOver p0 := hP_lies_q
  have hрқ”ӯ_prime : рқ”ӯ.IsPrime := by
    dsimp [рқ”ӯ]
    infer_instance
  have hрқ”ӯ_lies_q : рқ”ӯ.LiesOver p0 := by
    dsimp [рқ”ӯ]
    infer_instance
  letI : рқ”ӯ.IsPrime := hрқ”ӯ_prime
  letI : рқ”ӯ.LiesOver p0 := hрқ”ӯ_lies_q
  have hрқ”ӯ_mem : рқ”ӯ вҲҲ p0.primesOver (рқ“һ F) := by
    exact вҹЁhрқ”ӯ_prime, hрқ”ӯ_lies_qвҹ©
  have hрқ”ӯ_ne_bot : рқ”ӯ вү  вҠҘ := Ideal.ne_bot_of_mem_primesOver hp0_ne_bot hрқ”ӯ_mem
  have hP_mem_rel : рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ (T.L j)) := by
    refine вҹЁhP_prime, ?_вҹ©
    dsimp [рқ”ӯ]
    infer_instance
  letI : рқ”“.LiesOver рқ”ӯ := hP_mem_rel.2
  have hram_rel : Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := by
    exact IsEverywhereUnramified.unramified_at_finite (T.unramified j) рқ”ӯ рқ”“ hрқ”ӯ_prime hрқ”ӯ_ne_bot hP_mem_rel
  have hkill : Q.map (@splittingDetectorAt F _ _ p _ рқ”ӯ hрқ”ӯ_prime hрқ”ӯ_ne_bot) = 1 := by
    exact _h_killed рқ”ӯ hрқ”ӯ_prime hрқ”ӯ_ne_bot (by simpa [p0] using hрқ”ӯ_mem)
  have hcompat : вҲҖ рқ”” вҲҲ рқ”ӯ.primesOver (рқ“һ (T.L j)), Ideal.inertiaDeg рқ”ӯ рқ”” = 1 := by
    exact (T.quotientMap_compat j рқ”ӯ hрқ”ӯ_prime hрқ”ӯ_ne_bot).mp (by rw [hkill, MonoidHom.map_one])
  have hinert_rel : Ideal.inertiaDeg рқ”ӯ рқ”“ = 1 := hcompat рқ”“ hP_mem_rel
  have hbase : Ideal.ramificationIdx p0 рқ”ӯ = 1 вҲ§ Ideal.inertiaDeg p0 рқ”ӯ = 1 := by
    exact (_hq_splits_F.1) рқ”ӯ (by simpa [p0] using hрқ”ӯ_mem)
  have hram_abs : Ideal.ramificationIdx p0 рқ”“ = 1 := by
    have hmapрқ”ӯ_ne_bot : Ideal.map (algebraMap (рқ“һ F) (рқ“һ (T.L j))) рқ”ӯ вү  вҠҘ :=
      Ideal.map_ne_bot_of_ne_bot hрқ”ӯ_ne_bot
    have hmapp0_ne_bot : Ideal.map (algebraMap в„Ө (рқ“һ (T.L j))) p0 вү  вҠҘ :=
      Ideal.map_ne_bot_of_ne_bot hp0_ne_bot
    have hmap_le : Ideal.map (algebraMap (рқ“һ F) (рқ“һ (T.L j))) рқ”ӯ вүӨ рқ”“ := by
      rw [Ideal.map_le_iff_le_comap, Ideal.over_def (A := рқ“һ F) (P := рқ”“) (p := рқ”ӯ)]
    rw [Ideal.ramificationIdx_algebra_tower (p := p0) (P := рқ”ӯ) (Q := рқ”“) hmapрқ”ӯ_ne_bot hmapp0_ne_bot hmap_le]
    rw [hbase.1, hram_rel]
  have hinert_abs : Ideal.inertiaDeg p0 рқ”“ = 1 := by
    letI : рқ”ӯ.IsMaximal := Ideal.isMaximal_of_mem_primesOver hрқ”ӯ_mem
    letI : рқ”“.IsMaximal := Ideal.isMaximal_of_mem_primesOver hрқ”“'
    rw [Ideal.inertiaDeg_algebra_tower p0 рқ”ӯ рқ”“]
    rw [hbase.2, hinert_rel]
  exact вҹЁby simpa [p0] using hram_abs, by simpa [p0] using hinert_absвҹ©

theorem splitCount_of_primewiseSplit (K : Type) [Field K] [NumberField K] (q : в„•) (_hq : q.Prime)
(h_split :
  вҲҖ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K),
    Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
    Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1) :
((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K)).ncard =
  Module.finrank в„ҡ K := by
  let p0 : Ideal в„Ө := Ideal.span {(q : в„Ө)}
  letI : Fact q.Prime := вҹЁ_hqвҹ©
  letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
  have hp0_ne_bot : p0 вү  вҠҘ := by
    simpa [p0, Ideal.span_singleton_eq_bot] using
      (show (q : в„Ө) вү  0 by exact_mod_cast _hq.ne_zero)
  have hsum :
      вҲ‘ P вҲҲ primesOverFinset p0 (рқ“һ K),
        Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P
        = (primesOverFinset p0 (рқ“һ K)).card := by
    calc
      вҲ‘ P вҲҲ primesOverFinset p0 (рқ“һ K),
          Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P
        = вҲ‘ _P вҲҲ primesOverFinset p0 (рқ“һ K), (1 : в„•) := by
            refine Finset.sum_congr rfl ?_
            intro P hP
            have hPset : P вҲҲ p0.primesOver (рқ“һ K) := by
              simpa only [mem_primesOverFinset_iff hp0_ne_bot (рқ“һ K)] using hP
            rcases h_split P hPset with вҹЁh1, h2вҹ©
            change (Ideal.span {(q : в„Ө)} : Ideal в„Ө).ramificationIdx P *
                (Ideal.span {(q : в„Ө)} : Ideal в„Ө).inertiaDeg P = 1
            simp only [h1, h2, one_mul]
      _ = (primesOverFinset p0 (рқ“һ K)).card := by
            rw [вҶҗ Finset.card_eq_sum_ones]
  calc
    ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K)).ncard
      = (primesOverFinset p0 (рқ“һ K)).card := by
          change (p0.primesOver (рқ“һ K)).ncard = (primesOverFinset p0 (рқ“һ K)).card
          rw [вҶҗ Set.ncard_coe_finset, coe_primesOverFinset hp0_ne_bot (рқ“һ K)]
    _ = вҲ‘ P вҲҲ primesOverFinset p0 (рқ“һ K),
          Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P := by
          exact hsum.symm
    _ = Module.finrank в„ҡ K := by
          exact Ideal.sum_ramification_inertia (S := рқ“һ K) (K := в„ҡ) (L := K) hp0_ne_bot

theorem cft_D3_killedFrobeniusSplits (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))

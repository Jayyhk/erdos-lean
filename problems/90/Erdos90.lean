theorem partialProd_consecutiveDifferences (G : Type) [Group G] (n : в„•) (g : Fin (n + 1) вҶ’ G) : Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))вҒ»В№ * g k.succ) = fun i : Fin (n + 1) => (g 0)вҒ»В№ * g i := by
  ext i
  have h := congrArg (fun h : Fin (n + 1) вҶ’ G => h i) (Fin.partialProd_left_inv g)
  simp only [Pi.smul_apply, smul_eq_mul] at h
  calc
    Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))вҒ»В№ * g k.succ) i =
        (g 0)вҒ»В№ * (g 0 * Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))вҒ»В№ * g k.succ) i) := by
          symm
          exact inv_mul_cancel_left (g 0) (Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))вҒ»В№ * g k.succ) i)
    _ = (g 0)вҒ»В№ * g i := by rw [h]

theorem homogObj_towerEval_leftMul (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : в„•) (x : HomogObjType p G n) (a : G) (g : Fin (n + 1) вҶ’ G) : towerEval p G (n + 1) x.1 (fun i : Fin (n + 1) => a * g i) = towerEval p G (n + 1) x.1 g := by
  let rep : в„• вҶ’ Action (TopModuleCat (ZMod p)) G
      | n => (ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj
          (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))
  have haux : вҲҖ n : в„•, вҲҖ y : HomogTower p G n, вҲҖ a : G, вҲҖ g : Fin n вҶ’ G,
      towerEval p G n ((((rep n).ПҒ a).hom) y) (fun i : Fin n => a * g i) = towerEval p G n y g := by
    intro n
    induction n with
    | zero =>
        intro y a g
        rfl
    | succ n ih =>
        intro y a g
        simp only [towerEval]
        have hhead : (towerAsC p G n ((((rep (n + 1)).ПҒ a).hom) y)) (a * g 0) =
            (((rep n).ПҒ a).hom) ((towerAsC p G n y) (g 0)) := by
          cases n with
          | zero =>
              change ((ContinuousCohomology.Iobj (rep 0)).ПҒ a).hom y (a * g 0) =
                  (((rep 0).ПҒ a).hom) ((towerAsC p G 0 y) (g 0))
              rw [ContinuousCohomology.Iobj_ПҒ_apply]
              simp only [mul_assoc, inv_mul_cancel_left]
              rfl
          | succ n =>
              change ((ContinuousCohomology.Iobj (rep (n + 1))).ПҒ a).hom y (a * g 0) =
                  (((rep (n + 1)).ПҒ a).hom) ((towerAsC p G (n + 1) y) (g 0))
              rw [ContinuousCohomology.Iobj_ПҒ_apply]
              simp only [mul_assoc, inv_mul_cancel_left]
              rfl
        rw [hhead]
        exact ih _ a (Fin.tail g)
  have hfixed : (((rep (n + 1)).ПҒ a).hom) x.1 = x.1 := x.2 a
  simpa [rep, hfixed] using haux (n + 1) x.1 a g

theorem selectedInhomogToHomog_homogToInhomog_aux (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) : (selectedInhomogToHomog_aux p G n).comp (selectedHomogToInhomog_aux p G n) = (LinearMap.id : HomogObjType p G n вҶ’вӮ—[ZMod p] HomogObjType p G n) := by

      (Polynomial.X ^ 2 + Polynomial.C (1 : NumberField.RingOfIntegers 𝒟.L)).map
          (algebraMap (NumberField.RingOfIntegers 𝒟.L) 𝒟.L) =
        Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
    simp only [Polynomial.map_add, Polynomial.map_pow, Polynomial.map_X, Polynomial.map_C,
      RingHom.map_one, Polynomial.map_one]
  apply (Polynomial.map_injective
    (f := algebraMap (NumberField.RingOfIntegers 𝒟.L) 𝒟.L)
    (hf := IsFractionRing.injective (NumberField.RingOfIntegers 𝒟.L) 𝒟.L))

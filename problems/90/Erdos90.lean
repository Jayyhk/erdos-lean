    refine hg.comp hden ?_
    intro z hz
    have hzre : 0 ≤ z.re := hz
    simpa [Complex.add_re] using add_le_add_left hzre 1
  have hnum : ContinuousOn (fun z : ℂ => g (1 + z) - c) {z : ℂ | 0 ≤ z.re} :=
    hcomp.sub continuousOn_const
  refine hnum.div hden ?_
  intro z hz
  have hzre : 0 ≤ z.re := hz
  have hz' : 1 ≤ (1 + z).re := by
    simpa [Complex.add_re] using add_le_add_left hzre 1
  intro h0
  have h0re : (1 + z).re = 0 := by
    simpa using congrArg Complex.re h0
  linarith

theorem eventually_mul_le_of_eventually_floor_pow_mul_le {f : ℕ → ℝ} {c : ℝ} :

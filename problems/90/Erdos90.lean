    вҹЁL, hFieldL, hCharZeroL, hNumberFieldL, hTRL, hGQL, hAlgLCyc, hfinQL, hdiscrL, habsGalLвҹ©
  letI : Field L := hFieldL
  letI : CharZero L := hCharZeroL
  letI : NumberField L := hNumberFieldL
  letI : IsTotallyReal L := hTRL
  letI : IsGalois в„ҡ L := hGQL
  let iM : d.M вҶ’вӮҗ[в„ҡ] AlgebraicClosure в„ҡ := IsAlgClosed.lift
  let iL : L вҶ’вӮҗ[в„ҡ] AlgebraicClosure в„ҡ := IsAlgClosed.lift

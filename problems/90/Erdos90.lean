      IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p)) вҶ’
      H.index = p вҶ’
      Module.finrank F (IntermediateField.fixedField H) = p вҲ§
        IsGalois F (IntermediateField.fixedField H) := by
  intro hNormal hOpen hHp
  letI : IsGalois F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let N : OpenNormalSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toOpenSubgroup := вҹЁH, hOpenвҹ©
      isNormal' := hNormal }
  have hfg : FiniteDimensional F (IntermediateField.fixedField H) вҲ§
      IsGalois F (IntermediateField.fixedField H) := by
    simpa [N] using
      (_root_.Erdos90.fixedField_openNormal_finiteGalois
        (k := F) (K := maximalUnramifiedProPF F p) N)
  rcases hfg with вҹЁhfd, hgalвҹ©
  letI : FiniteDimensional F (IntermediateField.fixedField H) := hfd
  letI : IsGalois F (IntermediateField.fixedField H) := hgal
  let Hc : ClosedSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toSubgroup := H
      isClosed' := Subgroup.isClosed_of_isOpen H hOpen }
  have hHcNormal : (Hc : Subgroup (MaxUnramifiedProPGaloisGroup F p)).Normal := by
    change H.Normal
    exact hNormal
  have hcard : Module.finrank F (IntermediateField.fixedField H) =
      Nat.card ((MaxUnramifiedProPGaloisGroup F p) в§ё H) := by
    let e : ((MaxUnramifiedProPGaloisGroup F p) в§ё H) вүғ*
        Gal(IntermediateField.fixedField H / F) :=
      @InfiniteGalois.normalAutEquivQuotient F (maximalUnramifiedProPF F p) _ _ _ _ Hc hHcNormal
    calc
      Module.finrank F (IntermediateField.fixedField H)
          = Nat.card (Gal(IntermediateField.fixedField H / F)) := by
              symm
              simpa using (IsGalois.card_aut_eq_finrank F (IntermediateField.fixedField H))
      _ = Nat.card ((MaxUnramifiedProPGaloisGroup F p) в§ё H) := by
              symm
              exact Nat.card_congr e.toEquiv
  refine вҹЁ?_, hgalвҹ©
  calc
    Module.finrank F (IntermediateField.fixedField H) =
        Nat.card ((MaxUnramifiedProPGaloisGroup F p) в§ё H) := hcard
    _ = p := by
      simpa [Subgroup.index_eq_card] using hHp

theorem finite_index_p_open_normal_subgroups :
    {H : Subgroup (MaxUnramifiedProPGaloisGroup F p) |
        H.Normal вҲ§ IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p)) вҲ§
          H.index = p}.Finite := by
  let G := MaxUnramifiedProPGaloisGroup F p
  let K := maximalUnramifiedProPF F p
  let S : Set (Subgroup G) :=
    {H | H.Normal вҲ§ IsOpen (H : Set G) вҲ§ H.index = p}
  let U : Set (IntermediateField F K) :=
    {L | Module.finrank F L = p вҲ§ IsGalois F L}
  have hU : U.Finite := by
    simpa [K, U] using finite_galois_degree_p_subextensions_of_maximal (F := F) (p := p)
  haveI : Finite U := hU.to_subtype
  haveI : IsGalois F K := by
    dsimp [K]
    exact MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let f : S вҶ’ U :=
    fun H => вҹЁIntermediateField.fixedField H.1, by
      simpa [G, K, S, U] using
        fixedField_of_index_p_open_normal (F := F) (p := p) H.1 H.2.1 H.2.2.1 H.2.2.2вҹ©
  have hf : Function.Injective f := by
    intro H1 H2 hEq
    apply Subtype.ext
    change H1.1 = H2.1
    have hff : IntermediateField.fixedField H1.1 = IntermediateField.fixedField H2.1 := by
      exact congrArg Subtype.val hEq
    let Hc1 : ClosedSubgroup G :=
      { toSubgroup := H1.1
        isClosed' := Subgroup.isClosed_of_isOpen H1.1 H1.2.2.1 }
    let Hc2 : ClosedSubgroup G :=
      { toSubgroup := H2.1
        isClosed' := Subgroup.isClosed_of_isOpen H2.1 H2.2.2.1 }
    have hfix1 : ((IntermediateField.fixedField H1.1).fixingSubgroup : Subgroup G) = H1.1 := by
      simpa [G, K, Hc1] using
        (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc1)
    have hfix2 : ((IntermediateField.fixedField H2.1).fixingSubgroup : Subgroup G) = H2.1 := by
      simpa [G, K, Hc2] using
        (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc2)
    have hmid : ((IntermediateField.fixedField H1.1).fixingSubgroup : Subgroup G) =
        ((IntermediateField.fixedField H2.1).fixingSubgroup : Subgroup G) := by
      rw [hff]
    exact hfix1.symm.trans (hmid.trans hfix2)
  haveI : Finite S := Finite.of_injective f hf
  simpa [G, S] using (Set.toFinite S)

end HermiteMinkowski

theorem IsPGroup.coatom_normal (p : в„•) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (K : Subgroup G) (hK : IsCoatom K) : K.Normal := by
  letI : Group.IsNilpotent G := hG.isNilpotent
  exact Subgroup.NormalizerCondition.normal_of_coatom K (normalizerCondition_of_isNilpotent (G := G)) hK

theorem IsPGroup.coatom_index_eq_p (p : в„•) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (K : Subgroup G) (hK : IsCoatom K) : K.index = p := by
  classical
  letI : K.Normal := IsPGroup.coatom_normal p hG K hK
  obtain вҹЁn, hnвҹ© := hG.index K
  have hne_top : K вү  вҠӨ := hK.1
  have hn_ne_zero : n вү  0 := by
    intro h0
    apply hne_top
    exact Subgroup.index_eq_one.mp (by rw [hn, h0, pow_zero])
  have hn_eq_one : n = 1 := by
    by_contra hn1
    have hp : Nat.Prime p := Fact.out
    have hp1 : 1 < p := hp.one_lt
    have hQp : IsPGroup p (G в§ё K) := hG.to_quotient K
    have hcardQ : Nat.card (G в§ё K) = p ^ n := by
      simpa [hn] using (Subgroup.index_eq_card (H := K)).symm
    have hp_pow_le_cardQ : p ^ 1 вүӨ Nat.card (G в§ё K) := by
      rw [hcardQ]
      exact pow_le_pow_right' (le_of_lt hp1) (by omega)
    obtain вҹЁM, hMcardвҹ© :=
      Sylow.exists_subgroup_card_pow_prime_of_le_card (G := G в§ё K) (p := p) (n := 1) hp hQp hp_pow_le_cardQ
    have hM_ne_bot : M вү  вҠҘ := by
      intro hbot
      have hcardbot : Nat.card (вҠҘ : Subgroup (G в§ё K)) = p := by
        simpa [hbot, pow_one] using hMcard
      have : p = 1 := by
        calc
          p = Nat.card (вҠҘ : Subgroup (G в§ё K)) := hcardbot.symm
          _ = 1 := Subgroup.card_bot (G := G в§ё K)
      exact (Nat.ne_of_gt hp1) this
    have hM_ne_top : M вү  вҠӨ := by
      intro htop
      have hcardtop : Nat.card M = Nat.card (G в§ё K) :=
        (Subgroup.card_eq_iff_eq_top (H := M)).2 htop
      rw [hcardQ, hMcard, pow_one] at hcardtop
      have hlt : p < p ^ n := by
        calc
          p = p ^ 1 := by rw [pow_one]
          _ < p ^ n := by
            exact pow_lt_pow_rightвӮҖ hp1 (by omega : 1 < n)
      exact (ne_of_lt hlt) hcardtop
    have hbot_lt_M : (вҠҘ : Subgroup (G в§ё K)) < M := bot_lt_iff_ne_bot.mpr hM_ne_bot
    have hpre1 : (вҠҘ : Subgroup (G в§ё K)).comap (QuotientGroup.mk' K) < M.comap (QuotientGroup.mk' K) :=
      (Subgroup.comap_lt_comap_of_surjective (f := QuotientGroup.mk' K)
        (K := (вҠҘ : Subgroup (G в§ё K))) (L := M) (hf := QuotientGroup.mk'_surjective (N := K))).2 hbot_lt_M
    have hK_lt_comap : K < M.comap (QuotientGroup.mk' K) := by
      simpa [MonoidHom.comap_bot, QuotientGroup.ker_mk'] using hpre1
    have hM_lt_top : M < вҠӨ := lt_top_iff_ne_top.mpr hM_ne_top
    have hpre2 : M.comap (QuotientGroup.mk' K) < (вҠӨ : Subgroup (G в§ё K)).comap (QuotientGroup.mk' K) :=
      (Subgroup.comap_lt_comap_of_surjective (f := QuotientGroup.mk' K)
        (K := M) (L := вҠӨ) (hf := QuotientGroup.mk'_surjective (N := K))).2 hM_lt_top
    have hcomap_lt_top : M.comap (QuotientGroup.mk' K) < вҠӨ := by
      simpa [Subgroup.comap_top] using hpre2
    have hEqTop : M.comap (QuotientGroup.mk' K) = вҠӨ := (hK.lt_iff).mp hK_lt_comap
    exact hcomap_lt_top.ne hEqTop
  rw [hn, hn_eq_one, pow_one]

theorem finite_group_exists_coatom_over {G : Type*} [Group G] [Finite G] (H : Subgroup G) (hH : H < вҠӨ) : вҲғ K : Subgroup G, IsCoatom K вҲ§ H вүӨ K := by
  classical
  letI : IsCoatomic (Subgroup G) := Finite.to_isCoatomic
  rcases eq_top_or_exists_le_coatom H with htop | вҹЁK, hK, hHKвҹ©
  В· exfalso
    exact hH.ne htop
  В· exact вҹЁK, hK, hHKвҹ©

theorem IsPGroup.proper_subgroup_contained_in_index_p (p : в„•) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (H : Subgroup G) (hH : H < вҠӨ) : вҲғ K : Subgroup G, K.Normal вҲ§ H вүӨ K вҲ§ K.index = p := by
  rcases finite_group_exists_coatom_over H hH with вҹЁK, hK, hHKвҹ©
  refine вҹЁK, IsPGroup.coatom_normal p hG K hK, hHK, IsPGroup.coatom_index_eq_p p hG K hKвҹ©

theorem exists_finset_not_subset_any_index_p_open_normal (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (hFin : {H : Subgroup G | H.Normal вҲ§ IsOpen (H : Set G) вҲ§ H.index = p}.Finite) :
    вҲғ S : Finset G,
      вҲҖ H : Subgroup G, H.Normal вҶ’ IsOpen (H : Set G) вҶ’ H.index = p вҶ’
        В¬ ((S : Set G) вҠҶ H) := by
  classical
  let I := {H : Subgroup G // H.Normal вҲ§ IsOpen (H : Set G) вҲ§ H.index = p}
  let _ : Fintype I := hFin.fintype
  let _ : вҲҖ i : I, Finite (G в§ё (i : Subgroup G)) := fun i =>
    Subgroup.quotient_finite_of_isOpen (i : Subgroup G) i.2.2.1
  let _ : вҲҖ i : I, Fintype (G в§ё (i : Subgroup G)) := fun i =>
    Fintype.ofFinite (G в§ё (i : Subgroup G))
  let Q := вҲҖ i : I, G в§ё (i : Subgroup G)
  let _ : Fintype Q := by
    infer_instance
  let ПҶ : G вҶ’ Q := fun g i => by
    letI : (i : Subgroup G).Normal := i.2.1
    exact QuotientGroup.mk' (i : Subgroup G) g
  let R : Set Q := Set.range ПҶ
  choose lift hlift using fun r : R => r.2
  let S : Finset G := Finset.univ.image lift
  refine вҹЁS, ?_вҹ©
  intro H hHn hHo hHp hsubset
  letI : H.Normal := hHn
  let i : I := вҹЁH, hHn, hHo, hHpвҹ©
  have hHne : H вү  вҠӨ := by
    intro htop
    have hp1 : p = 1 := by
      calc
        p = H.index := hHp.symm
        _ = 1 := by rw [htop, Subgroup.index_top]
    exact (Fact.out : p.Prime).ne_one hp1
  have hnontriv : Nontrivial (G в§ё H) := (QuotientGroup.nontrivial_iff).2 hHne
  letI : Nontrivial (G в§ё H) := hnontriv
  obtain вҹЁx, hxвҹ© := exists_ne (1 : G в§ё H)
  obtain вҹЁg, hgвҹ© := QuotientGroup.mk'_surjective H x
  let r : R := вҹЁПҶ g, вҹЁg, rflвҹ©вҹ©
  have hmemS : lift r вҲҲ S := by
    refine Finset.mem_image.mpr ?_
    exact вҹЁr, Finset.mem_univ _, rflвҹ©
  have hcoord : QuotientGroup.mk' H (lift r) = x := by
    have h := congrArg (fun q => q i) (hlift r)
    simpa [r, ПҶ, i] using h.trans hg
  have hnotmem : lift r вҲү H := by
    intro hmem
    have hone : QuotientGroup.mk' H (lift r) = 1 := by
      rw [вҶҗ MonoidHom.mem_ker, QuotientGroup.ker_mk']
      exact hmem
    exact hx (hcoord.symm.trans hone)
  exact hnotmem (hsubset hmemS)

theorem proper_closed_subgroup_le_proper_open_subgroup (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (H : Subgroup G) (hClosed : IsClosed (H : Set G)) (hProper : H < вҠӨ) :
    вҲғ U : Subgroup G, IsOpen (U : Set G) вҲ§ H вүӨ U вҲ§ U < вҠӨ := by
  classical
  let HC : ClosedSubgroup G := вҹЁH, hClosedвҹ©
  have hHne : H вү  вҠӨ := ne_of_lt hProper
  obtain вҹЁg, hgHвҹ© : вҲғ g : G, g вҲү H := by
    by_contra h
    apply hHne
    ext x
    constructor
    В· intro hx
      trivial
    В· intro hx
      by_contra hxH
      exact h вҹЁx, hxHвҹ©
  have hsInf : H = sInf {N : Subgroup G | IsOpen (N : Set G) вҲ§ H вүӨ N} := by
    simpa [HC] using ProfiniteGrp.closedSubgroup_eq_sInf_open HC
  have hgNotMemSInf : g вҲү sInf {N : Subgroup G | IsOpen (N : Set G) вҲ§ H вүӨ N} := by
    rwa [вҶҗ hsInf]
  by_contra hNoU
  apply hgNotMemSInf
  rw [Subgroup.mem_sInf]
  intro N hN
  by_contra hgN
  apply hNoU
  refine вҹЁN, hN.1, hN.2, ?_вҹ©
  refine lt_top_iff_ne_top.mpr ?_
  intro hNtop
  apply hgN
  simp [hNtop]

theorem topologicalClosure_eq_top_of_not_subset_any_index_p_open_normal (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (hP : вҲҖ (H : Subgroup G) [H.Normal], IsOpen (H : Set G) вҶ’ IsPGroup p (G в§ё H))
    (S : Finset G)
    (hS : вҲҖ H : Subgroup G, H.Normal вҶ’ IsOpen (H : Set G) вҶ’ H.index = p вҶ’
      В¬ ((S : Set G) вҠҶ H)) :
    (Subgroup.closure (S : Set G)).topologicalClosure = вҠӨ := by
  classical
  let C : Subgroup G := (Subgroup.closure (S : Set G)).topologicalClosure
  by_contra hCeq
  have hCproper : C < вҠӨ := by
    exact lt_of_le_of_ne le_top hCeq
  have hCclosed : IsClosed (C : Set G) := by
    simp [C]
  obtain вҹЁU, hUOpen, hCU, hUproperвҹ© :=
    proper_closed_subgroup_le_proper_open_subgroup G C hCclosed hCproper
  obtain вҹЁN, hNsubUвҹ© :=
    ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hUOpen
      (show (1 : G) вҲҲ (U : Set G) from U.one_mem)
  have hN_le_U : (N : Subgroup G) вүӨ U := by
    intro x hx
    exact hNsubU hx
  have hCsupN_le_U : C вҠ” (N : Subgroup G) вүӨ U := by
    exact sup_le hCU hN_le_U
  have hCsupN_proper : C вҠ” (N : Subgroup G) < вҠӨ :=
    lt_of_le_of_lt hCsupN_le_U hUproper
  let q : G вҶ’* G в§ё (N : Subgroup G) := QuotientGroup.mk' (N : Subgroup G)
  let J : Subgroup (G в§ё (N : Subgroup G)) := Subgroup.map q (C вҠ” (N : Subgroup G))
  have hJproper : J < вҠӨ := by
    refine lt_of_le_of_ne le_top ?_
    intro hJtop
    have hcomap : Subgroup.comap q J = C вҠ” (N : Subgroup G) := by
      simp [J, q, sup_comm]
    have : C вҠ” (N : Subgroup G) = вҠӨ := by
      rw [вҶҗ hcomap, hJtop, Subgroup.comap_top]
    exact hCsupN_proper.ne this
  have hNOpen : IsOpen ((N : Subgroup G) : Set G) := by
    simpa using (OpenSubgroup.isOpen (U := N.toOpenSubgroup))
  haveI : Finite (G в§ё (N : Subgroup G)) :=
    Subgroup.quotient_finite_of_isOpen (N : Subgroup G) hNOpen
  have hPquot : IsPGroup p (G в§ё (N : Subgroup G)) := by
    let _ : (N : Subgroup G).Normal := OpenNormalSubgroup.instNormal N
    exact hP (N : Subgroup G) hNOpen
  obtain вҹЁKq, hKqNormal, hJKq, hKqindexвҹ© :=
    IsPGroup.proper_subgroup_contained_in_index_p (p := p) hPquot J hJproper
  let K : Subgroup G := Subgroup.comap q Kq
  have hKNormal : K.Normal := by
    exact Subgroup.Normal.comap hKqNormal q
  have hKOpen : IsOpen (K : Set G) := by
    have hNleK : (N : Subgroup G) вүӨ K := by
      simpa [K, q] using QuotientGroup.le_comap_mk' (N := (N : Subgroup G)) Kq
    exact Subgroup.isOpen_mono hNleK hNOpen
  have hKindex : K.index = p := by
    change (Subgroup.comap q Kq).index = p
    rw [Subgroup.index_comap_of_surjective (H := Kq) (f := q)
      (QuotientGroup.mk'_surjective (N : Subgroup G))]
    exact hKqindex
  have hC_le_K : C вүӨ K := by
    have hcomap_le : Subgroup.comap q J вүӨ Subgroup.comap q Kq :=
      Subgroup.comap_mono hJKq
    have hCN_eq : Subgroup.comap q J = C вҠ” (N : Subgroup G) := by
      simp [J, q, sup_comm]
    have hsup_le_K : C вҠ” (N : Subgroup G) вүӨ K := by
      rw [вҶҗ hCN_eq]
      simpa [K] using hcomap_le
    exact le_trans le_sup_left hsup_le_K
  have hSsubsetK : (S : Set G) вҠҶ K := by
    intro x hx
    have hx1 : x вҲҲ Subgroup.closure (S : Set G) := Subgroup.subset_closure hx
    have hx2 : x вҲҲ C := by
      exact (show Subgroup.closure (S : Set G) вүӨ C by
        simpa [C] using Subgroup.le_topologicalClosure (Subgroup.closure (S : Set G))) hx1
    exact hC_le_K hx2
  have hcontra := hS K hKNormal hKOpen hKindex
  exact hcontra hSsubsetK

theorem proP_topologicallyFG_of_finite_index_p_subgroups (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (_hP : вҲҖ (H : Subgroup G) [H.Normal], IsOpen (H : Set G) вҶ’ IsPGroup p (G в§ё H))
    (_hFin : {H : Subgroup G | H.Normal вҲ§ IsOpen (H : Set G) вҲ§ H.index = p}.Finite) :
    вҲғ S : Finset G, (Subgroup.closure (S : Set G)).topologicalClosure = вҠӨ := by
  classical
  obtain вҹЁS, hSвҹ© := exists_finset_not_subset_any_index_p_open_normal (p := p) (G := G) _hFin
  refine вҹЁS, ?_вҹ©
  exact topologicalClosure_eq_top_of_not_subset_any_index_p_open_normal (p := p) (G := G) _hP S hS

section StructuralConjunct

variable (F : Type) [Field F] [NumberField F] (p : в„•) [Fact p.Prime]

theorem galois_sup_isPGroup_of_galois_pgroup
    (K L : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F K] [FiniteDimensional F L]
    [IsGalois F K] [IsGalois F L]
    (hK : IsPGroup p (K вүғвӮҗ[F] K))
    (hL : IsPGroup p (L вүғвӮҗ[F] L)) :
    IsPGroup p (вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F]
      вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F))) := by
  letI : Algebra вҶҘK вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_left).toRingHom)
  letI : IsScalarTower F вҶҘK вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_left)
  letI : Algebra вҶҘL вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_right).toRingHom)
  letI : IsScalarTower F вҶҘL вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_right)
  letI : Normal F вҶҘK := (isGalois_iff.mp (show IsGalois F вҶҘK from inferInstance)).2
  letI : Normal F вҶҘL := (isGalois_iff.mp (show IsGalois F вҶҘL from inferInstance)).2
  letI : FiniteDimensional F вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    IntermediateField.finiteDimensional_sup (E1 := K) (E2 := L)
  letI : Normal F вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) :=
    IntermediateField.normal_sup (E := K) (E' := L)
  letI : IsGalois F вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) := by
    rw [isGalois_iff]; exact вҹЁinferInstance, inferInstanceвҹ©
  intro Пғ
  obtain вҹЁa, haвҹ© := hK (AlgEquiv.restrictNormalHom (F := F)
    (KвӮҒ := вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F))) вҶҘK Пғ)
  obtain вҹЁb, hbвҹ© := hL (AlgEquiv.restrictNormalHom (F := F)
    (KвӮҒ := вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F))) вҶҘL Пғ)
  refine вҹЁmax a b, ?_вҹ©
  have hAlgK : вҲҖ x : вҶҘK, algebraMap вҶҘK вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) x
      = IntermediateField.inclusion le_sup_left x := fun _ => rfl
  have hAlgL : вҲҖ x : вҶҘL, algebraMap вҶҘL вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F)) x
      = IntermediateField.inclusion le_sup_right x := fun _ => rfl
  have hresK : (AlgEquiv.restrictNormalHom (F := F)
      (KвӮҒ := вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F))) вҶҘK (Пғ ^ p ^ max a b)) = 1 := by
    rw [map_pow]
    have : p ^ a вҲЈ p ^ max a b := pow_dvd_pow p (le_max_left _ _)
    obtain вҹЁc, hcвҹ© := this
    rw [hc, pow_mul, ha, one_pow]
  have hresL : (AlgEquiv.restrictNormalHom (F := F)
      (KвӮҒ := вҶҘ(K вҠ” L : IntermediateField F (AlgebraicClosure F))) вҶҘL (Пғ ^ p ^ max a b)) = 1 := by
    rw [map_pow]
    have : p ^ b вҲЈ p ^ max a b := pow_dvd_pow p (le_max_right _ _)
    obtain вҹЁc, hcвҹ© := this
    rw [hc, pow_mul, hb, one_pow]
  exact restrict_eq_one_of_eq_one_on_sup_left_right F K L (Пғ ^ p ^ max a b)
    hAlgK hAlgL hresK hresL

theorem finsetSup_isPGroup
    (s : Finset (maximalUnramifiedProPFIndex F p)) :
    IsPGroup p (вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F]
      вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F))) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      have hempty :
          (вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)),
              i.M : IntermediateField F (AlgebraicClosure F)) = вҠҘ := by
        simp
      let eEq : вҶҘ(вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)),
          i.M : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F]
          (вҠҘ : IntermediateField F (AlgebraicClosure F)) :=
        IntermediateField.equivOfEq hempty
      have hBot : IsPGroup p ((вҠҘ : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F]
          (вҠҘ : IntermediateField F (AlgebraicClosure F))) := by
        apply IsPGroup.of_card (n := 0)
        rw [pow_zero]
        have e : (вҠҘ : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F] F :=
          IntermediateField.botEquiv F (AlgebraicClosure F)
        haveI : Subsingleton ((вҠҘ : IntermediateField F (AlgebraicClosure F)) вүғвӮҗ[F]
            (вҠҘ : IntermediateField F (AlgebraicClosure F))) :=
          (AlgEquiv.autCongr e).toEquiv.subsingleton
        exact Nat.card_unique
      exact IsPGroup.of_equiv hBot (AlgEquiv.autCongr eEq).symm
  | @insert i s his ih =>
      let Ks : IntermediateField F (AlgebraicClosure F) := вЁҶ j вҲҲ s, j.M
      letI : вҲҖ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F j.M := fun j => j.hfd
      haveI : FiniteDimensional F вҶҘKs :=
        IntermediateField.finiteDimensional_iSup_of_finset'
          (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s)
          (by intro j _; exact j.hfd)
      letI : FiniteDimensional F i.M := i.hfd
      haveI : IsGalois F i.M := i.hg
      haveI : IsGalois F вҶҘKs := finsetSup_isGalois (F := F) (p := p) (s := s)
      have hIns : (i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) =
          вЁҶ j вҲҲ insert i s, j.M := by
        simpa [Ks] using
          (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M)).symm
      have hKsP : IsPGroup p (вҶҘKs вүғвӮҗ[F] вҶҘKs) := by
        simpa [Ks] using ih
      have hsup := galois_sup_isPGroup_of_galois_pgroup F p i.M Ks i.hpG hKsP
      exact IsPGroup.of_equiv hsup (AlgEquiv.autCongr (IntermediateField.equivOfEq hIns))

theorem galois_isPGroup_of_le_galois_pgroup
    (L M : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F L] [FiniteDimensional F M]
    [IsGalois F L] [IsGalois F M]
    (hLM : L вүӨ M)
    (hM : IsPGroup p (M вүғвӮҗ[F] M)) :
    IsPGroup p (L вүғвӮҗ[F] L) := by
  letI : Algebra вҶҘL вҶҘM := (IntermediateField.inclusion hLM).toAlgebra
  letI : IsScalarTower F вҶҘL вҶҘM := IsScalarTower.of_algHom (IntermediateField.inclusion hLM)
  letI : Normal F вҶҘL := (isGalois_iff.mp (show IsGalois F вҶҘL from inferInstance)).2
  exact hM.of_surjective (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘM) вҶҘL)
    (AlgEquiv.restrictNormalHom_surjective (F := F) (KвӮҒ := L) (E := M))

theorem isPGroup_quotient_of_open_normal
    (H : Subgroup (MaxUnramifiedProPGaloisGroup F p)) [hHN : H.Normal]
    (hHO : IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p))) :
    IsPGroup p (MaxUnramifiedProPGaloisGroup F p в§ё H) := by
  classical
  letI : IsGalois F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let N : OpenNormalSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toOpenSubgroup := вҹЁH, hHOвҹ©
      isNormal' := hHN }
  have hfg : FiniteDimensional F (IntermediateField.fixedField H) вҲ§
      IsGalois F (IntermediateField.fixedField H) := by
    simpa [N] using
      (_root_.Erdos90.fixedField_openNormal_finiteGalois
        (k := F) (K := maximalUnramifiedProPF F p) N)
  rcases hfg with вҹЁhfd, hgalвҹ©
  letI : FiniteDimensional F (IntermediateField.fixedField H) := hfd
  letI : IsGalois F (IntermediateField.fixedField H) := hgal
  let Hc : ClosedSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toSubgroup := H
      isClosed' := Subgroup.isClosed_of_isOpen H hHO }
  have hHcNormal : (Hc : Subgroup (MaxUnramifiedProPGaloisGroup F p)).Normal := by
    change H.Normal; exact hHN
  let L : IntermediateField F (maximalUnramifiedProPF F p) :=
    IntermediateField.fixedField H
  let LвӮҖ : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift L
  let eLift : L вүғвӮҗ[F] LвӮҖ := IntermediateField.liftAlgEquiv L
  letI : FiniteDimensional F LвӮҖ := eLift.toLinearEquiv.finiteDimensional
  letI : IsGalois F LвӮҖ := IsGalois.of_algEquiv eLift
  obtain вҹЁs, hsвҹ© :=
    finiteIntermediate_lift_le_finsetSup (F := F) (p := p) (L := L)
  let Ms : IntermediateField F (AlgebraicClosure F) := вЁҶ i вҲҲ s, i.M
  have hsub : LвӮҖ вүӨ Ms := by simpa [LвӮҖ, Ms] using hs
  letI : вҲҖ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F j.M := fun j => j.hfd
  letI : FiniteDimensional F вҶҘMs :=
    IntermediateField.finiteDimensional_iSup_of_finset'
      (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s)
      (by intro j _; exact j.hfd)
  haveI : IsGalois F вҶҘMs := finsetSup_isGalois (F := F) (p := p) (s := s)
  have hMsP : IsPGroup p (вҶҘMs вүғвӮҗ[F] вҶҘMs) :=
    finsetSup_isPGroup (F := F) (p := p) (s := s)
  have hLвӮҖP : IsPGroup p (вҶҘLвӮҖ вүғвӮҗ[F] вҶҘLвӮҖ) :=
    galois_isPGroup_of_le_galois_pgroup F p LвӮҖ Ms hsub hMsP
  have hLP : IsPGroup p (L вүғвӮҗ[F] L) :=
    IsPGroup.of_equiv hLвӮҖP (AlgEquiv.autCongr eLift).symm
  let eQ : ((MaxUnramifiedProPGaloisGroup F p) в§ё H) вүғ*
      Gal(IntermediateField.fixedField H / F) :=
    @InfiniteGalois.normalAutEquivQuotient F (maximalUnramifiedProPF F p) _ _ _ _ Hc hHcNormal
  exact IsPGroup.of_equiv hLP eQ.symm


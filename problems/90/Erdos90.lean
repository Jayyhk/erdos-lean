  have hnorm_ge_p : вҲҖ {P : Ideal (рқ“һ K)}, P вҲҲ s вҶ’ (p : в„қ) вүӨ Ideal.absNorm P := by
    intro P hP
    have hP' : P вҲҲ Ideal.primesOver pp (рқ“һ K) := (mem_primesOverFinset_iff (p := pp) (hpb := hpp0) (B := рқ“һ K)).1 hP
    let Q : Ideal.primesOver pp (рқ“һ K) := вҹЁP, hP'вҹ©
    letI : P.LiesOver pp := Q.2.2
    have hpow : Ideal.absNorm P = p ^ (pp.inertiaDeg P) := Ideal.absNorm_eq_pow_inertiaDeg' (P := P) hp
    have hpos : 0 < pp.inertiaDeg P := Ideal.inertiaDeg_pos (p := pp) (P := P)
    have hone : 1 вүӨ pp.inertiaDeg P := Nat.succ_le_of_lt hpos

          apply ContinuousMap.ext
          intro a
          apply ih
          intro g
          simpa using h (Fin.cons a g)
        cases m with
        | zero =>
            simpa [towerAsC] using h'
        | succ m =>
            simpa [towerAsC] using h'
  ext x
  apply Subtype.ext
  refine towerEval_ext (n + 1) _ _ ?_
  intro g
  rw [LinearMap.comp_apply, LinearMap.id_apply]
  rw [selectedInhomogToHomog_aux_apply]
  rw [selectedHomogToInhomog_aux_apply]
  have hprefix :

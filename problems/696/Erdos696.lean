      have hMdiv_eq : M / d = k_d * b * k_ab := by
        rw [hM_eq]; exact Nat.mul_div_cancel_left _ hd_pos_local
      rw [hMdiv_eq]
      exact ⟨k_d * k_ab, by ring⟩

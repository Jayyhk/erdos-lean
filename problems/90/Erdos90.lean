theorem homogToInhomog_inhomogToHomog (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) : (homogToInhomog p G n).comp (inhomogToHomog p G n) = (LinearMap.id : _root_.Erdos90.InhomogContsCochains.Cochain p G n вҶ’вӮ—[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n) := by

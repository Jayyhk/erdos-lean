theorem logRescalePartialSum_tendsto_of_tendsto_cumsum_div {f : в„• вҶ’ в„қ} {b : в„қ} : Filter.Tendsto (fun N : в„• => cumsum f N / (N : в„қ)) Filter.atTop (nhds b) вҶ’ Filter.Tendsto (fun x : в„қ => logRescalePartialSum f x) Filter.atTop (nhds b) := by

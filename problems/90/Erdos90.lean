theorem theorem_2_3_large_example (t : в„•) (q : Fin t вҶ’ в„•)
    (рқ’ҹ : в„• вҶ’ AdmissibleDatum)
    (sameT : вҲҖ j, (рқ’ҹ j).t = t)
    (sameQ : вҲҖ j (b : Fin t),

    (homogeneousCochains R H).obj X вҹ¶
      (homogeneousCochains R G).obj ((Action.res _ f).obj X) :=
  ((ComplexShape.embeddingUp'Add 1 1).restrictionFunctor (TopModuleCat R)).map
    ((NatTrans.mapHomologicalComplex (invariantsRes R f) _).app
        ((MultiInd.complex R H).asFunctor.obj X) вү«

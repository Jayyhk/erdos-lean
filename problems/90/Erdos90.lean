    hfinQF, hFgal, hfinFM, hoddFM, ?_, hpow3, habelвҹ©
  have hpow : (NumberField.discr F).natAbs ^ (3 ^ (в„“ - 1)) = ((вҲҸ i, r i) ^ 2) ^ (3 ^ (в„“ - 1)) := by
    calc
      (NumberField.discr F).natAbs ^ (3 ^ (в„“ - 1)) = (NumberField.discr M).natAbs := by
        simpa [hfinFM] using hrel.symm
      _ = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1)) := _hdisc

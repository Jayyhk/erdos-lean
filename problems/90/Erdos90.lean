      apply Subtype.ext
      exact hpow_abs Пғ'
    have hПғ := congrArg (IntermediateField.subgroupEquivAlgEquiv H) hПғ'
    simpa [Пғ'] using hПғ
  have hcomm_rel : вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ := by
    intro Пғ П„
    let Пғ' : H := (IntermediateField.subgroupEquivAlgEquiv H).symm Пғ
    let П„' : H := (IntermediateField.subgroupEquivAlgEquiv H).symm П„
    have hПғП„ : Пғ' * П„' = П„' * Пғ' := by
      apply Subtype.ext
      exact hcomm_abs Пғ' П„'
    have hПғП„' := congrArg (IntermediateField.subgroupEquivAlgEquiv H) hПғП„
    simpa [Пғ', П„'] using hПғП„'
  letI : Fact (Nat.Prime 3) := вҹЁby decideвҹ©
  have hcyc : Nonempty ((F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3)) := by
    refine вҹЁmulEquivOfPrimeCardEq (G := F вүғвӮҗ[в„ҡ] F) (G' := Multiplicative (ZMod 3)) hcardF ?_вҹ©
    simp
  refine вҹЁF, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, ?_вҹ©
  exact вҹЁhfinrankF, hcyc, hfinrankFM, hoddFM, hpow_rel, hcomm_relвҹ©


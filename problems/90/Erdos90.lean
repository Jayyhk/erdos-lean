    have h₁ : Module.finrank ℚ F = NumberField.InfinitePlace.nrRealPlaces F :=
      IsTotallyReal.finrank (K := F)
    rw [h_cubic] at h₁
    exact h₁.symm
  have hnr_cplx : NumberField.InfinitePlace.nrComplexPlaces F = 0 :=
    IsTotallyReal.nrComplexPlaces_eq_zero F
  have hδ : ¬ ∃ ζ : F, IsPrimitiveRoot ζ 3 :=
    no_primitive_cubeRoot_of_cubic F h_cubic
  have h3Odd : Odd (3 : ℕ) := by norm_num
  have h := (hSRR F 3 h3Odd).2
  simp only [hnr_real, hnr_cplx, if_neg hδ] at h

  exact h

lemma gsd_numeric_threshold (ℓ n : ℕ) (hℓ : 8 ≤ ℓ) (hn : ℓ - 1 ≤ n) :

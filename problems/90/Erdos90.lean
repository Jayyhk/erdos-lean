          Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
          Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1) вҲ§
        ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ (T.L j))).ncard =
          Module.finrank в„ҡ (T.L j) :=
  MaxUnramifiedProPGaloisGroup.killed_frobenius_splits_in_tower F p Q T q _hq _hq_splits_F _h_killed

theorem prop38_mkAdmissibleDatum (L : Type) [Field L] [CharZero L] [NumberField L] [IsTotallyReal L]
    (t : в„•) (_ht : 0 < t) (q : Fin t вҶ’ в„•)
    (_hq_prime : вҲҖ b, (q b).Prime)
    (_hq_inj : Function.Injective q)
    (_hq_mod4 : вҲҖ b, q b % 4 = 1)
    (_hq_splits : вҲҖ b,
      (вҲҖ рқ”ӯ вҲҲ (Ideal.span {((q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ L),
          Ideal.ramificationIdx (Ideal.span {((q b : в„Ө))} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
          Ideal.inertiaDeg (Ideal.span {((q b : в„Ө))} : Ideal в„Ө) рқ”ӯ = 1) вҲ§
        ((Ideal.span {((q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ L)).ncard =
          Module.finrank в„ҡ L) :
    вҲғ рқ’ҹ : AdmissibleDatum,
      Nonempty (рқ’ҹ.L вүғвӮҗ[в„ҡ] L) вҲ§
      вҲғ ht_eq : рқ’ҹ.t = t,
        вҲҖ b : Fin t, рқ’ҹ.q (Fin.cast ht_eq.symm b) = q b := by
  classical
  let K := CyclotomicField 4 L
  haveI : IsCyclotomicExtension ({4} : Set в„•) L K := by
    dsimp [K]
    exact CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := 4) (K := L)
  have hmem4 : 4 вҲҲ ({4} : Set в„•) := by simp
  obtain вҹЁiK, hiK_primвҹ© :=
    IsCyclotomicExtension.exists_isPrimitiveRoot L K hmem4 (by decide : (4 : в„•) вү  0)
  have hiK_sq : iK * iK = (-1 : K) := by
    have hsq_prim : IsPrimitiveRoot (iK ^ 2) 2 :=
      hiK_prim.pow_of_dvd (by decide : (2 : в„•) вү  0) (by decide : 2 вҲЈ 4)
    have hsq : iK ^ 2 = (-1 : K) := IsPrimitiveRoot.eq_neg_one_of_two_right hsq_prim
    simpa [pow_two] using hsq
  haveI : Algebra.IsIntegral L K := Algebra.IsIntegral.of_finite L K
  have hiK_int : IsIntegral L iK := Algebra.IsIntegral.isIntegral iK
  have hiK_not_range : iK вҲү (algebraMap L K).range := by
    rintro вҹЁa, haвҹ©
    have ha2 : a * a = (-1 : L) := by
      have h : (algebraMap L K) (a * a) = (algebraMap L K) (-1) := by
        rw [map_mul, ha, hiK_sq, map_neg, map_one]
      exact (algebraMap L K).injective h
    obtain вҹЁПҶвҹ© := (inferInstance : Nonempty (L вҶ’+* в„Ӯ))
    have hПҶ : NumberField.ComplexEmbedding.IsReal ПҶ :=
      NumberField.IsTotallyReal.complexEmbedding_isReal ПҶ
    let ПҲ : L вҶ’+* в„қ := hПҶ.embedding
    have hПҲ : ПҲ a * ПҲ a = -1 := by
      have h := congrArg ПҲ ha2
      simpa [map_mul, map_neg, map_one] using h
    have hnn : 0 вүӨ ПҲ a * ПҲ a := mul_self_nonneg _
    linarith
  have hdeg_ge2 : 2 вүӨ (minpoly L iK).natDegree := by
    exact (minpoly.two_le_natDegree_iff hiK_int).2 hiK_not_range
  have hroot : Polynomial.aeval iK (Polynomial.X ^ 2 + 1 : Polynomial L) = 0 := by
    simp [Polynomial.aeval_def, hiK_sq, pow_two]
  have hdiv : minpoly L iK вҲЈ (Polynomial.X ^ 2 + 1 : Polynomial L) :=
    minpoly.dvd L iK hroot
  have hdeg_poly : (Polynomial.X ^ 2 + (1 : Polynomial L)).natDegree = 2 := by
    simpa using (Polynomial.natDegree_X_pow_add_C (R := L) (n := 2) (r := (1 : L)))
  have hdeg_le2 : (minpoly L iK).natDegree вүӨ 2 := by
    have h := Polynomial.natDegree_le_of_dvd hdiv
      (Polynomial.X_pow_add_C_ne_zero (R := L) (n := 2) (by decide : 0 < (2 : в„•)) (1 : L))
    rw [hdeg_poly] at h
    exact h
  have hdeg_eq2 : (minpoly L iK).natDegree = 2 := by
    omega
  have hgen : IntermediateField.adjoin L ({iK} : Set K) = вҠӨ := by
    simpa using (IsCyclotomicExtension.adjoin_primitive_root_eq_top (A := L) (B := K) (n := 4) hiK_prim)
  have hfinrank : Module.finrank L K = 2 := by
    have h := (Field.primitive_element_iff_minpoly_natDegree_eq (F := L) (E := K) iK).1 hgen
    rw [вҶҗ h]
    exact hdeg_eq2

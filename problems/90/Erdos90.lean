  letI : Field (в„Ө в§ё p) := Ideal.Quotient.field p
  letI : Finite (в„Ө в§ё p) := Ideal.finiteQuotientOfFreeOfNeBot p hp_ne_bot
  letI : PerfectField (в„Ө в§ё p) := PerfectField.ofFinite
  letI : Field (рқ“һ M в§ё P) := Ideal.Quotient.field P
  letI : Algebra.IsIntegral (в„Ө в§ё p) (рқ“һ M в§ё P) :=
    Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P) (p := p)
  letI : Algebra.IsAlgebraic (в„Ө в§ё p) (рқ“һ M в§ё P) := by infer_instance
  letI : Algebra.IsSeparable (в„Ө в§ё p) (рқ“һ M в§ё P) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Field (рқ“һ M в§ё PвӮҖ) := Ideal.Quotient.field PвӮҖ
  letI : Algebra.IsIntegral (в„Ө в§ё p) (рқ“һ M в§ё PвӮҖ) :=
    Ideal.Quotient.algebra_isIntegral_of_liesOver (P := PвӮҖ) (p := p)
  letI : Algebra.IsAlgebraic (в„Ө в§ё p) (рқ“һ M в§ё PвӮҖ) := by infer_instance
  letI : Algebra.IsSeparable (в„Ө в§ё p) (рқ“һ M в§ё PвӮҖ) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hram0 : p.ramificationIdxIn (рқ“һ M) = 3 := by
    exact (Ideal.card_inertia_eq_ramificationIdxIn (G := (M вүғвӮҗ[в„ҡ] M)) p hp_ne_bot PвӮҖ).symm.trans hcardвӮҖ
  have hcardP : Nat.card (P.inertia (M вүғвӮҗ[в„ҡ] M)) = 3 := by
    exact (Ideal.card_inertia_eq_ramificationIdxIn (G := (M вүғвӮҗ[в„ҡ] M)) p hp_ne_bot P).trans hram0
  have hrel_inertia_bot : P.inertia H = вҠҘ := by
    rcases Subgroup.bot_or_exists_ne_one (P.inertia H) with hbot | вҹЁП„H, hП„Hmem, hП„Hneвҹ©
    В· exact hbot
    В· have hП„H_inertia : (П„H : M вүғвӮҗ[в„ҡ] M) вҲҲ P.inertia (M вүғвӮҗ[в„ҡ] M) := by
        rw [AddSubgroup.mem_inertia] at hП„Hmem вҠў
        intro x

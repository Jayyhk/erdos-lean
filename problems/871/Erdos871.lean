    have hsub_valid : ∀ i < k, a_base ≤ n := fun i hi => by have := hle i hi; omega
    let pairs : Finset (ℕ × ℕ) := Finset.image (fun i => (a_base - i, n - a_base + i)) (Finset.range k)
    have hpairs_valid : ∀ p ∈ pairs, p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧
                        p.1 ∈ seq.P k ∪ seq.R k ∧ p.2 ∈ seq.P k ∪ seq.R k := by
      intro p hp
      simp only [pairs, Finset.mem_image, Finset.mem_range] at hp
      obtain ⟨i, hi, rfl⟩ := hp
      refine ⟨hle i hi, by omega, Finset.mem_union_left _ (ha_in_Pk i hi),
              Finset.mem_union_right _ (hb_in_Rk i hi)⟩
    have hpairs_card : pairs.card = k := by
      simp only [pairs]
      rw [Finset.card_image_of_injective (Finset.range k)]
      · exact Finset.card_range k
      · intro i j hij; simp only [Prod.mk.injEq] at hij; omega
    have hcount : countReps (seq.P k ∪ seq.R k) n ≥ k := by
      unfold countReps
      have hsub : pairs ⊆ ((seq.P k ∪ seq.R k).product (seq.P k ∪ seq.R k)).filter
          (fun p => p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧ p.1 ∈ seq.P k ∪ seq.R k ∧ p.2 ∈ seq.P k ∪ seq.R k) := by
        intro p hp
        have hv := hpairs_valid p hp
        simp only [Finset.mem_filter]
        constructor
        · exact Finset.mem_product.mpr ⟨hv.2.2.1, hv.2.2.2⟩
        · exact hv
      calc k = pairs.card := hpairs_card.symm
        _ ≤ _ := Finset.card_le_card hsub
    have hge := countReps_mono hPR_in_union n
    omega
  push_neg at h_case2
  have hn_case5_lo : n ≥ seq.N k - k + 1 := by omega
  have hn_case5_hi : n ≤ seq.N k - 1 := hn_hi
  simp only [N] at hn_case5_lo hn_case5_hi
  let w := seq.N k - n
  have hw_lo : w ≥ 1 := by simp only [w, N]; omega
  have hw_hi : w ≤ k - 1 := by simp only [w, N]; omega
  have hnkm1_lower : seq.n (k-1) ≥ 3 * k^2 := by
    have hbound := seq.growth_bound (k-1) hkm1
    have hnkm2_poly : seq.n (k-2) ≥ 3 * (k-1)^2 + 6 * (k-1) + 1 := by
      simp only [Nat.sub_sub] at hbound; exact hbound
    have h8poly : 8 * (3 * (k-1)^2 + 6 * (k-1) + 1) ≥ 3 * k^2 := by
      let m := k - 1
      have hm_ge : m ≥ 2 := by simp only [m]; omega
      have hk_eq : k = m + 1 := by simp only [m]; omega
      have hlhs : 8 * (3 * (k-1)^2 + 6 * (k-1) + 1) = 24 * m^2 + 48 * m + 8 := by
        simp only [m]; ring
      have hrhs : 3 * k^2 = 3 * m^2 + 6 * m + 3 := by
        rw [hk_eq]; ring
      rw [hlhs, hrhs]
      have h : 21 * m^2 + 42 * m + 5 ≥ 0 := by omega
      omega
    calc seq.n (k-1) ≥ 8 * seq.n (k-2) := hgrowkm1
      _ ≥ 8 * (3 * (k-1)^2 + 6 * (k-1) + 1) := Nat.mul_le_mul_left 8 hnkm2_poly
      _ ≥ 3 * k^2 := h8poly
  have hQ_nonneg : seq.n k ≥ seq.n (k-1) + 3 * k * (k + 1) := by
    have hpoly : seq.n (k-1) ≥ 3 * k^2 := hnkm1_lower
    have h21_ge : 21 * k^2 ≥ 3 * k * (k + 1) := by
      have h3kk1 : 3 * k * (k + 1) = 3 * k^2 + 3 * k := by ring
      rw [h3kk1]
      have h18 : 18 * k^2 ≥ 3 * k := by nlinarith
      omega
    calc seq.n k ≥ 8 * seq.n (k-1) := hgrowk
      _ = seq.n (k-1) + 7 * seq.n (k-1) := by ring
      _ ≥ seq.n (k-1) + 7 * (3 * k^2) := by linarith
      _ = seq.n (k-1) + 21 * k^2 := by ring
      _ ≥ seq.n (k-1) + 3 * k * (k + 1) := by linarith
  have hQk_in_Bk : seq.Q k ⊆ seq.B_k k := fun x hx =>
    Finset.mem_union_left _ (Finset.mem_union_right _ hx)
  have hRk_in_Bk : seq.R k ⊆ seq.B_k k := fun x hx =>
    Finset.mem_union_right _ hx
  have hBk_in_union : seq.B_k k ⊆ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2) := fun x hx =>
    Finset.mem_union_left _ (Finset.mem_union_left _ hx)
  let qfun : ℕ → ℕ := fun u => seq.n k - seq.n (k-1) - 3 * k * u + 1
  let rfun : ℕ → ℕ := fun u => seq.n k + seq.n (k-1) + 3 * k * u - w
  have hq_sub_valid : ∀ u ≤ k + 1, seq.n k ≥ seq.n (k-1) + 3 * k * u := fun u hu =>
    calc seq.n k ≥ seq.n (k-1) + 3 * k * (k + 1) := hQ_nonneg
      _ ≥ seq.n (k-1) + 3 * k * u := by nlinarith
  have hq_in_Qk : ∀ u ∈ Finset.Icc 1 k, qfun u ∈ seq.Q k := by
    intro u hu
    simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hk1), Finset.mem_image]
    use u
    simp only [Finset.mem_Icc] at hu ⊢
    constructor
    · omega
    · -- qfun u = n_k - n_{k-1} - 3ku + 1, which is exactly the definition
      rfl
  have hr_sub_valid : ∀ u ∈ Finset.Icc 1 k, 3 * k * u ≥ w := by
    intro u hu
    simp only [Finset.mem_Icc] at hu
    have h3k : 3 * k ≥ k := by omega
    have huk : u ≥ 1 := hu.1
    have h1 : 3 * k * u ≥ 3 * k := by nlinarith
    have h2 : 3 * k > k - 1 := by omega
    omega
  have hr_lo : ∀ u ∈ Finset.Icc 1 k, rfun u ≥ seq.n k + 1 := by
    intro u hu
    have hsub := hr_sub_valid u hu
    simp only [rfun, Finset.mem_Icc] at *
    omega
  have hr_hi : ∀ u ∈ Finset.Icc 1 k, rfun u ≤ seq.n k + seq.N (k-1) := by
    intro u hu
    have hsub := hr_sub_valid u hu
    simp only [Finset.mem_Icc] at hu
    simp only [rfun, N]
    have h3k2 : 3 * k^2 ≤ seq.n (k-1) := hnkm1_lower
    have huk : 3 * k * u ≤ 3 * k * k := Nat.mul_le_mul_left _ hu.2
    have h3kk : 3 * k * k = 3 * k^2 := by ring
    omega
  have hr_not_excl : ∀ u ∈ Finset.Icc 1 k,
      rfun u ∉ Finset.image (fun v => seq.n k + seq.n (k-1) + 3 * k * v)
                            (Finset.Icc 1 (k + 1)) := by
    intro u hu
    have hsub := hr_sub_valid u hu
    simp only [Finset.mem_image, not_exists, not_and, Finset.mem_Icc]
    intro v ⟨hv_lo, hv_hi⟩
    simp only [rfun]
    simp only [Finset.mem_Icc] at hu
    intro heq
    by_cases huv : u = v
    · -- u = v: 3ku - w = 3ku, so w = 0, contradiction
      subst huv
      omega
    · rcases Nat.lt_trichotomy u v with hlt | heq' | hgt
      · -- u < v: 3ku < 3kv, so 3ku - w = 3kv is impossible (would need w < 0)
        have h3klt : 3 * k * u < 3 * k * v := by nlinarith
        omega
      · exact absurd heq' huv
      · -- u > v: u ≥ v + 1, so 3ku ≥ 3k(v+1) = 3kv + 3k
        have hge : u ≥ v + 1 := hgt
        have h3kge : 3 * k * u ≥ 3 * k * (v + 1) := Nat.mul_le_mul_left _ hge
        have hexp : 3 * k * (v + 1) = 3 * k * v + 3 * k := by ring
        have hw_eq : w = 3 * k * u - 3 * k * v := by omega
        have hw_ge_3k : w ≥ 3 * k := by
          rw [hw_eq]
          have h := h3kge
          rw [hexp] at h
          omega
        have h3k_gt : 3 * k > k - 1 := by omega
        omega
  have hr_in_Rk : ∀ u ∈ Finset.Icc 1 k, rfun u ∈ seq.R k := by
    intro u hu
    simp only [R, if_neg (Nat.one_le_iff_ne_zero.mp hk1), Finset.mem_sdiff, Finset.mem_Icc]
    constructor
    · exact ⟨hr_lo u hu, hr_hi u hu⟩
    · exact hr_not_excl u hu
  have hq_le_r : ∀ u ∈ Finset.Icc 1 k, qfun u ≤ rfun u := by
    intro u hu
    simp only [qfun, rfun, Finset.mem_Icc] at *
    have hqsub := hq_sub_valid u (by omega : u ≤ k + 1)
    have hrsub := hr_sub_valid u hu
    omega
  have hsum : ∀ u ∈ Finset.Icc 1 k, qfun u + rfun u = n := by
    intro u hu
    simp only [qfun, rfun, w, N, Finset.mem_Icc] at *
    have hqsub := hq_sub_valid u (by omega : u ≤ k + 1)
    have hrsub := hr_sub_valid u hu
    omega
  let pairs : Finset (ℕ × ℕ) := Finset.image (fun u => (qfun u, rfun u)) (Finset.Icc 1 k)
  have mul_cancel_lemma : ∀ A u v : ℕ, A > 0 → A * u = A * v → u = v := by
    intro A u v hA heq
    exact Nat.eq_of_mul_eq_mul_left hA heq
  have hcard : pairs.card = k := by
    simp only [pairs]
    have hinj : Set.InjOn (fun u => (qfun u, rfun u)) (Finset.Icc 1 k : Set ℕ) := by
      intro u hu v hv huv
      simp only [Finset.coe_Icc, Set.mem_Icc] at hu hv
      simp only [Prod.mk.injEq] at huv
      have hqeq := huv.1
      simp only [qfun] at hqeq
      have hsubu := hq_sub_valid u (by omega : u ≤ k + 1)
      have hsubv := hq_sub_valid v (by omega : v ≤ k + 1)
      have h3k_eq : 3 * k * u = 3 * k * v := by omega
      have h3k_pos : 3 * k > 0 := by omega
      exact mul_cancel_lemma (3 * k) u v h3k_pos h3k_eq
    rw [Finset.card_image_of_injOn hinj, Nat.card_Icc]
    omega
  have hpairs_valid : ∀ p ∈ pairs, p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧
      p.1 ∈ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2) ∧
      p.2 ∈ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2) := by
    intro p hp
    simp only [pairs, Finset.mem_image] at hp
    obtain ⟨u, hu, rfl⟩ := hp
    exact ⟨hq_le_r u hu, hsum u hu,
           hBk_in_union (hQk_in_Bk (hq_in_Qk u hu)),
           hBk_in_union (hRk_in_Bk (hr_in_Rk u hu))⟩
  unfold countReps
  have hsub : pairs ⊆ Finset.filter (fun p =>
      p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧
      p.1 ∈ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2) ∧
      p.2 ∈ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2))
      ((seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2)).product
       (seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2))) := by
    intro p hp
    simp only [Finset.mem_filter]
    have hv := hpairs_valid p hp
    constructor
    · exact Finset.mem_product.mpr ⟨hv.2.2.1, hv.2.2.2⟩
    · exact ⟨hv.1, hv.2.1, hv.2.2.1, hv.2.2.2⟩
  calc k = pairs.card := hcard.symm
    _ ≤ (Finset.filter _ _).card := Finset.card_le_card hsub
end NathansonSeq
/-!
# Lemma 4
-/
namespace NathansonSeq
/-- Lemma 4, part 1: N_k has no representations in B -/
theorem lemma4_part1 (seq : NathansonSeq) (k : ℕ) :
    ∀ a b, seq.inB a → seq.inB b → a + b ≠ seq.N k := by
  intro a b ha hb heq
  exact seq.lemma3_part1 k ⟨a, b, ha, hb, heq⟩
/-- Lemma 4, part 2: r_B(n) → ∞ for n ≠ N_k -/
theorem lemma4_part2 (seq : NathansonSeq) (t : ℕ) :
    ∃ M, ∀ n ≥ M, (∀ k, n ≠ seq.N k) →
      ∃ j ≥ 3, t ≤ countReps (seq.B_k j ∪ seq.B_k (j - 1) ∪ seq.B_k (j - 2)) n := by
  use seq.N (max 2 (t - 1)) + 1
  intro n hn hne
  have hbound : ∃ k, n < seq.N k := by
    obtain ⟨k, hk⟩ := seq.N_unbounded n
    exact ⟨k, hk⟩
  let j := Nat.find hbound
  have hj_spec : n < seq.N j := Nat.find_spec hbound
  have hj_min : ∀ i < j, ¬(n < seq.N i) := fun i hi => Nat.find_min hbound hi
  have hj_gt : j > max 2 (t - 1) := by
    by_contra hle
    push_neg at hle
    have hN_le : seq.N j ≤ seq.N (max 2 (t - 1)) := seq.N_mono_le hle
    omega
  have hj_ge3 : j ≥ 3 := by omega
  have hj_ge_t : j ≥ t := by
    rcases Nat.eq_zero_or_pos t with rfl | ht
    · omega
    · -- t ≥ 1, so max 2 (t-1) ≥ t - 1, thus j > t - 1, so j ≥ t
      have : max 2 (t - 1) ≥ t - 1 := le_max_right 2 (t - 1)
      omega
  have hN_jm1_le : seq.N (j - 1) ≤ n := by
    by_cases hj0 : j = 0
    · -- j = 0 contradicts j ≥ 3
      omega
    · have hlt : j - 1 < j := Nat.sub_lt (Nat.pos_of_ne_zero hj0) Nat.one_pos
      exact Nat.not_lt.mp (hj_min (j - 1) hlt)
  have hn_ne_jm1 : n ≠ seq.N (j - 1) := hne (j - 1)
  have hlo : seq.N (j - 1) + 1 ≤ n := by omega
  have hn_ne_j : n ≠ seq.N j := hne j
  have hhi : n ≤ seq.N j - 1 := by omega
  use j
  constructor
  · exact hj_ge3
  · have hreps := seq.lemma3_part2 j hj_ge3 n hlo hhi
    omega
end NathansonSeq
/-!
# Main Construction: Modified Nathanson set A with r_A(n) → ∞
The key modification from Nathanson's original construction is the "growing subset enumeration"
that allows t_k → ∞ while preserving the diagonalization argument.
## Strategy
We build A = B ∪ ⋃_k G_k where:
- B is the Nathanson base set with bad integers N_k ∉ 2B
- G_k = {N_k - f : f ∈ F_k} where F_k is the k-th gadget subset of B
- F_k has size t_k where t_k → ∞
The enumeration schedule organizes k-values into stages:
- Stage m processes all m-element subsets of {a_1, ..., a_{H_m}}
- For k in stage m, we have |F_k| = t_k = m
- Since each stage is finite, t_k → ∞
-/
section MainConstruction
variable (seq : NathansonSeq)
/-!
## Enumeration of B
We work with the set B as a predicate and enumerate it.
-/
/-- The set B as a set (not computable since inB is a Prop) -/
def NathansonSeq.BSet : Set ℕ := {x | seq.inB x}
/-- B is infinite: for any bound, there exist elements of B beyond that bound -/
lemma NathansonSeq.B_unbounded : ∀ M, ∃ x > M, seq.inB x := by
  intro M
  obtain ⟨k, hk⟩ := seq.N_unbounded M
  use seq.N k + 1
  constructor
  · omega
  · use k + 1
    constructor
    · omega
    · -- Show N_k + 1 ∈ B_{k+1} = P_{k+1} ∪ Q_{k+1} ∪ R_{k+1}
      simp only [NathansonSeq.B_k]
      apply Finset.mem_union_left
      apply Finset.mem_union_left
      simp only [NathansonSeq.P, if_neg (by omega : k + 1 ≠ 0), Finset.mem_Icc]
      simp only [Nat.add_sub_cancel]
      constructor
      · -- N_k + 1 ≥ N_k + 1
        rfl
      · -- N_k + 1 ≤ n_{k+1} - N_k
        have hgrow := seq.exponential_growth (k + 1) (by omega)
        simp only [Nat.add_sub_cancel] at hgrow
        simp only [NathansonSeq.N]
        have hn_pos := seq.n_pos k
        omega
/-- B is infinite as a set -/
lemma NathansonSeq.B_infinite : Set.Infinite {x | seq.inB x} := by
  apply Set.infinite_of_forall_exists_gt
  intro n
  obtain ⟨x, hx_gt, hx_B⟩ := seq.B_unbounded n
  exact ⟨x, hx_B, hx_gt⟩
/-!
## The Enumeration Schedule
We define:
- H : ℕ → ℕ - the horizon sequence
- K : ℕ → ℕ - cumulative count of k-values used up to stage m
- stage : ℕ → ℕ - which stage contains k
- t : ℕ → ℕ - the gadget size for index k
-/
/-- Cumulative count: K_m = sum of binomial(H_j, j) for j = 1 to m-1 -/
def cumulativeCount (H : ℕ → ℕ) : ℕ → ℕ
  | 0 => 0
  | 1 => 0
  | m + 1 => cumulativeCount H m + Nat.choose (H m) m
/-- Stage function: given horizons H, which stage contains index k
    This is a simplified version that just returns a placeholder -/
noncomputable def stageOf (H : ℕ → ℕ) (k : ℕ) : ℕ :=
  k  -- Simplified: actual implementation would track which stage k belongs to
/-- Gadget size: t_k = stage(k) -/
noncomputable def gadgetSize (H : ℕ → ℕ) (k : ℕ) : ℕ := stageOf H k
/-!
## Axiomatization of the Construction
Since the full construction involves:
1. Choosing an enumeration of B
2. Choosing horizons H_m appropriately
3. Defining the enumeration of m-subsets within each stage
We axiomatize the key properties needed for the proof.
-/
/-- A valid construction consists of:
- An enumeration a : ℕ → ℕ of B
- Horizons H : ℕ → ℕ with H_m → ∞
- Gadget subsets F : ℕ → Finset ℕ where F_k ⊆ {a_1, ..., a_{H_{stage(k)}}}
  with |F_k| = stage(k)
-/
structure GrowingConstruction where
  /-- The base Nathanson sequence -/
  seq : NathansonSeq
  /-- Enumeration of B (increasing) -/
  a : ℕ → ℕ
  /-- Horizons -/
  H : ℕ → ℕ
  /-- Gadget subsets -/
  F : ℕ → Finset ℕ
  /-- Stage assignment -/
  stage : ℕ → ℕ
  /-- a enumerates B: a_i ∈ B for all i ≥ 1 -/
  a_in_B : ∀ i ≥ 1, seq.inB (a i)
  /-- a is strictly increasing -/
  a_mono : ∀ i, a i < a (i + 1)
  /-- a covers B: every element of B is some a_i -/
  a_covers : ∀ x, seq.inB x → ∃ i ≥ 1, a i = x
  /-- Horizons are increasing -/
  H_mono : ∀ m, H m ≤ H (m + 1)
  /-- Horizons tend to infinity -/
  H_unbounded : ∀ M, ∃ m, H m > M
  /-- F_k has size t_k = stage(k) for k ≥ 1 -/
  F_card : ∀ k ≥ 1, (F k).card = stage k
  /-- F_k consists of elements from {a_1, ..., a_{H_{stage(k)}}} -/
  F_subset : ∀ k ≥ 1, ∀ x ∈ F k, ∃ i, 1 ≤ i ∧ i ≤ H (stage k) ∧ a i = x
  /-- Stage is at least 1 for k ≥ 1 -/
  stage_pos : ∀ k ≥ 1, stage k ≥ 1
  /-- Stage tends to infinity -/
  stage_unbounded : ∀ M, ∃ k₀, ∀ k ≥ k₀, stage k > M
  /-- Exhaustive enumeration: every m-element subset of {a_1, ..., a_{H_m}} appears as some F_k
      for k in stage m -/
  exhaustive : ∀ m ≥ 1, ∀ S : Finset ℕ,
    (∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ H m ∧ a i = x) → S.card = m →
    ∃ k, stage k = m ∧ F k = S
  /-- The horizons are chosen so that F_k elements are all < N_{k-1}.
      This ensures G_k elements are in the range (N_k - N_{k-1}, N_k).
      Note: This only needs to hold for k ≥ 2. For k = 1, the bound N_0 is too small
      (since B elements start at N_0 + 1), but k = 1 is never used in the main theorem
      because the threshold M = N_2 + 1 means we only consider N_k for k ≥ 3. -/
  F_lt_N_prev : ∀ k ≥ 2, ∀ x ∈ F k, x < seq.N (k - 1)
  /-- Stages enumerate k values in order: for each m, there is a minimum k₀ such that
      all k with stage(k) = m satisfy k ≥ k₀. This reflects that we process stages
      sequentially, so k values in later stages are larger. -/
  k_grows_with_stage : ∀ m ≥ 1, ∃ k₀, ∀ k, stage k = m → k ≥ k₀
  /-- The inverse bound: for each k, there is a maximum stage that can contain k.
      Specifically, stage(k) ≤ k for all k. This is because stage m uses
      at least 1 value of k per stage, so cumulative count ≤ m after stage m. -/
  stage_le_k : ∀ k ≥ 1, stage k ≤ k
  /-- Stage 0 is 0 (index 0 is not used in the construction) -/
  stage_zero : stage 0 = 0
  /-- H grows at least linearly: H_m ≥ 2m for all m ≥ 1.
      This is needed to ensure we have enough elements in {a_1,...,a_{H_m}}
      to form m-subsets that go beyond any fixed finite set. -/
  H_linear : ∀ m ≥ 1, H m ≥ 2 * m
namespace GrowingConstruction
variable (gc : GrowingConstruction)
/-- H is weakly monotone from any start -/
lemma H_mono_le {m n : ℕ} (h : m ≤ n) : gc.H m ≤ gc.H n := by
  induction n with
  | zero => simp [Nat.le_zero.mp h]
  | succ n ih =>
    rcases h.lt_or_eq with hlt | heq
    · have hle : m ≤ n := Nat.lt_succ_iff.mp hlt
      exact Nat.le_trans (ih hle) (gc.H_mono n)
    · subst heq; rfl
/-- a is strictly increasing for i ≥ 1 -/
lemma a_strict_mono_ge (i j : ℕ) (hi : i ≥ 1) (hj : j ≥ 1) (hij : i < j) :
    gc.a i < gc.a j := by
  induction j with
  | zero => omega
  | succ j ih =>
    rcases Nat.lt_succ_iff_lt_or_eq.mp hij with hlt | heq
    · have hj_ge_1 : j ≥ 1 := by omega
      calc gc.a i < gc.a j := ih hj_ge_1 hlt
        _ < gc.a (j + 1) := gc.a_mono j
    · subst heq
      exact gc.a_mono i
/-- a values are unbounded: for any M, there exists i ≥ 1 with a_i > M -/
lemma a_unbounded (M : ℕ) : ∃ i ≥ 1, gc.a i > M := by
  have h_mono : ∀ i ≥ 1, gc.a i ≥ gc.a 1 + (i - 1) := by
    intro i hi
    induction i with
    | zero => omega
    | succ i ih =>
      by_cases hi' : i = 0
      · subst hi'; simp
      · have hi_ge_1 : i ≥ 1 := Nat.one_le_iff_ne_zero.mpr hi'
        have h1 : gc.a (i + 1) > gc.a i := gc.a_mono i
        have h2 : gc.a i ≥ gc.a 1 + (i - 1) := ih hi_ge_1
        omega
  use M + 2
  constructor
  · omega
  · have h := h_mono (M + 2) (by omega)
    omega
/-- F_k elements are < N_k (follows from F_lt_N_prev for k ≥ 2) -/
lemma F_lt_N (k : ℕ) (hk : k ≥ 2) (x : ℕ) (hx : x ∈ gc.F k) : x < gc.seq.N k := by
  have h := gc.F_lt_N_prev k hk x hx
  calc x < gc.seq.N (k - 1) := h
    _ ≤ gc.seq.N k := gc.seq.N_mono_le (by omega)
/-- The gadget set G_k = {N_k - f : f ∈ F_k} -/
def G (k : ℕ) : Finset ℕ :=
  gc.F k |>.image (fun f => gc.seq.N k - f)
/-- G_k has the same cardinality as F_k (requires k ≥ 2 for the bound proof) -/
lemma G_card (k : ℕ) (hk : k ≥ 2) : (gc.G k).card = (gc.F k).card := by
  simp only [G]
  rw [Finset.card_image_of_injOn]
  intro f₁ hf₁ f₂ hf₂ heq
  have h1 : f₁ < gc.seq.N k := gc.F_lt_N k hk f₁ hf₁
  have h2 : f₂ < gc.seq.N k := gc.F_lt_N k hk f₂ hf₂
  have hle1 : f₁ ≤ gc.seq.N k := le_of_lt h1
  have hle2 : f₂ ≤ gc.seq.N k := le_of_lt h2
  have heq' : gc.seq.N k - f₁ = gc.seq.N k - f₂ := heq
  calc f₁ = gc.seq.N k - (gc.seq.N k - f₁) := (Nat.sub_sub_self hle1).symm
    _ = gc.seq.N k - (gc.seq.N k - f₂) := by rw [heq']
    _ = f₂ := Nat.sub_sub_self hle2
/-- G_k has size t_k (requires k ≥ 2) -/
lemma G_card_eq_stage (k : ℕ) (hk : k ≥ 2) : (gc.G k).card = gc.stage k := by
  have hk1 : k ≥ 1 := by omega
  rw [gc.G_card k hk, gc.F_card k hk1]
/-- Elements of G_k are of the form N_k - f for f ∈ F_k -/
lemma G_mem (k : ℕ) (g : ℕ) : g ∈ gc.G k ↔ ∃ f ∈ gc.F k, g = gc.seq.N k - f := by
  simp only [G, Finset.mem_image]
  constructor
  · intro ⟨f, hf, heq⟩
    exact ⟨f, hf, heq.symm⟩
  · intro ⟨f, hf, heq⟩
    exact ⟨f, hf, heq.symm⟩
/-- The set A = B ∪ ⋃_{k≥2} G_k
    Note: We start from k ≥ 2 because F_lt_N_prev only holds for k ≥ 2 (the bound N_0 is
    too small for k = 1 since B elements start at N_0 + 1). This doesn't affect the main
    theorem since the threshold M = N_2 + 1 means we only need to represent N_k for k ≥ 3. -/
def inA (x : ℕ) : Prop :=
  gc.seq.inB x ∨ ∃ k ≥ 2, x ∈ gc.G k
/-!
## Key Lemmas about G_k
-/
/-- G_k elements are in a specific range near N_k -/
lemma G_range (k : ℕ) (hk : k ≥ 2) (g : ℕ) (hg : g ∈ gc.G k) :
    gc.seq.N k - gc.seq.N (k - 1) < g ∧ g < gc.seq.N k := by
  rw [gc.G_mem] at hg
  obtain ⟨f, hf, rfl⟩ := hg
  have hf_lt_prev : f < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk f hf
  have hf_lt : f < gc.seq.N k := gc.F_lt_N k hk f hf
  have hf_in_B : gc.seq.inB f := by
    have hk1 : k ≥ 1 := by omega
    obtain ⟨i, hi_lo, hi_hi, hai⟩ := gc.F_subset k hk1 f hf
    rw [← hai]
    exact gc.a_in_B i hi_lo
  obtain ⟨j, hj, hfmem⟩ := hf_in_B
  have hf_ge : f ≥ gc.seq.N 0 + 1 := by
    have hbound := gc.seq.B_k_lower_bound j hj f hfmem
    have hmono := gc.seq.N_mono_from_zero (j - 1)
    omega
  constructor
  · -- g = N_k - f > N_k - N_{k-1} since f < N_{k-1}
    have hN_mono : gc.seq.N (k - 1) ≤ gc.seq.N k := gc.seq.N_mono_le (by omega)
    omega
  · -- g = N_k - f < N_k since f > 0
    have hf_pos : f > 0 := by
      simp only [NathansonSeq.N] at hf_ge
      have := gc.seq.n_pos 0
      omega
    omega
/-- Gadget sets from different k are disjoint -/
lemma G_disjoint (j k : ℕ) (hjk : j ≠ k) (hj : j ≥ 2) (hk : k ≥ 2) :
    Disjoint (gc.G j) (gc.G k) := by
  rw [Finset.disjoint_left]
  intro g hgj hgk
  wlog hjlt : j < k generalizing j k
  · push_neg at hjlt
    have hklt : k < j := Ne.lt_of_le hjk.symm hjlt
    exact this k j hjk.symm hk hj hgk hgj hklt
  have hgj_range := gc.G_range j hj g hgj
  have hgk_range := gc.G_range k hk g hgk
  have hN_mono : gc.seq.N j ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
  have hgj_upper : g < gc.seq.N j := hgj_range.2
  have hgk_lower : gc.seq.N k - gc.seq.N (k - 1) < g := hgk_range.1
  have hgap : gc.seq.N k - gc.seq.N (k - 1) > gc.seq.N (k - 1) := by
    simp only [NathansonSeq.N]
    have hgrow := gc.seq.exponential_growth k (by omega : k ≥ 1)
    have hn_pos := gc.seq.n_pos (k - 1)
    omega
  have hN_chain : gc.seq.N j ≤ gc.seq.N (k - 1) := hN_mono
  omega
/-- Gadget sets are disjoint from B -/
lemma G_disjoint_B (k : ℕ) (hk : k ≥ 2) : ∀ x ∈ gc.G k, ¬gc.seq.inB x := by
  intro g hg ⟨j, hj, hjmem⟩
  have hg_range := gc.G_range k hk g hg
  by_cases hjlt : j < k
  · -- Case j < k: B_j elements are ≤ n_{k-1} + N_{k-2}
    have hub := gc.seq.B_j_le_bound j k hjlt hj g hjmem
    have hgrow := gc.seq.exponential_growth k (by omega : k ≥ 1)
    have hN_prev := gc.seq.N_mono_le (by omega : k - 2 ≤ k - 1)
    simp only [NathansonSeq.N] at hN_prev hgrow hg_range hub
    by_cases hk2 : k ≥ 2
    · have hgrow_prev := gc.seq.exponential_growth (k - 1) (by omega : k - 1 ≥ 1)
      simp only [Nat.sub_sub] at hgrow_prev
      omega
    · -- k = 1 case
      have hk1 : k = 1 := by omega
      simp only [hk1] at hub hgrow hN_prev hg_range
      have hn0_pos := gc.seq.n_pos 0
      omega
  · by_cases hjgt : j > k
    · -- Case j > k: B_j elements are > N_k
      have hlb := gc.seq.B_j_gt_N_k j k hjgt hj g hjmem
      omega
    · -- Case j = k
      have hjk : j = k := by omega
      rw [hjk] at hjmem hj
      simp only [NathansonSeq.B_k] at hjmem
      rw [Finset.mem_union, Finset.mem_union] at hjmem
      rcases hjmem with (hP | hQ) | hR
      · -- g ∈ P_k: g ≤ n_k - N_{k-1}
        have hP_bound := gc.seq.P_subset k hj g hP
        simp only [NathansonSeq.N] at hP_bound hg_range
        omega
      · -- g ∈ Q_k: g < n_k
        have hQ_bound := gc.seq.Q_lt_n k hj g hQ
        simp only [NathansonSeq.N] at hg_range
        have hgrow := gc.seq.exponential_growth k hj
        omega
      · -- g ∈ R_k: g ≥ n_k + 1 and g ≤ n_k + N_{k-1}
        have hR_bound := gc.seq.R_subset k hj g hR
        simp only [NathansonSeq.N] at hR_bound hg_range
        have hgrow := gc.seq.exponential_growth k hj
        have hn_pos := gc.seq.n_pos (k - 1)
        omega
/-!
## Representation Count
-/
/-- For N_k, the only representations in A are f + (N_k - f) for f ∈ F_k -/
lemma N_representations (k : ℕ) (hk : k ≥ 2) :
    ∀ a b, gc.inA a → gc.inA b → a + b = gc.seq.N k →
      a ∈ gc.F k ∧ b ∈ gc.G k ∨ a ∈ gc.G k ∧ b ∈ gc.F k := by
  have hk1 : k ≥ 1 := by omega
  intro a b ha hb hab
  cases ha with
  | inl ha_B =>
    cases hb with
    | inl hb_B =>
      exfalso
      exact gc.seq.lemma3_part1 k ⟨a, b, ha_B, hb_B, hab⟩
    | inr hb_G =>
      obtain ⟨j, hj, hb_Gj⟩ := hb_G
      have hb_range := gc.G_range j hj b hb_Gj
      have hb_pos : b > 0 := by
        have := hb_range.1
        have hN_mono := gc.seq.N_mono_le (by omega : j - 1 ≤ j)
        omega
      have ha_lt : a < gc.seq.N k := by omega
      by_cases hjk : j = k
      · -- j = k case: show a ∈ F_k
        rw [gc.G_mem] at hb_Gj
        obtain ⟨f, hf, hbeq⟩ := hb_Gj
        have hf_lt : f < gc.seq.N j := gc.F_lt_N j hj f hf
        rw [hjk] at hbeq hf hf_lt
        have ha_eq : a = f := by omega
        left
        rw [ha_eq]
        constructor
        · exact hf
        · simp only [G, Finset.mem_image]
          exact ⟨f, hf, hbeq.symm⟩
      · -- j ≠ k case: derive contradiction
        exfalso
        rw [gc.G_mem] at hb_Gj
        obtain ⟨f, hf, hbeq⟩ := hb_Gj
        have hf_lt_prev : f < gc.seq.N (j - 1) := gc.F_lt_N_prev j hj f hf
        have hf_lt_j : f < gc.seq.N j := gc.F_lt_N j hj f hf
        by_cases hjlt : j < k
        · -- j < k: N_j ≤ N_{k-1}, so b < N_j ≤ N_{k-1}
          have hN_mono : gc.seq.N j ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
          have hb_upper : b < gc.seq.N j := hb_range.2
          have hb_eq : b = gc.seq.N j - f := hbeq
          have hb_lt_prev : b < gc.seq.N (k - 1) := by
            calc b < gc.seq.N j := hb_upper
              _ ≤ gc.seq.N (k - 1) := hN_mono
          have hNk_gt_prev : gc.seq.N k > gc.seq.N (k - 1) := gc.seq.N_strict_mono_lt (by omega : k - 1 < k)
          have ha_lower : a > gc.seq.N k - gc.seq.N (k - 1) := by omega
          have hgap : gc.seq.N k - gc.seq.N (k - 1) > gc.seq.N (k - 1) := by
            have hgrow := gc.seq.exponential_growth k hk1
            simp only [NathansonSeq.N] at hgrow ⊢
            have hn_pos := gc.seq.n_pos (k - 1)
            omega
          obtain ⟨i, hi, ha_Bi⟩ := ha_B
          by_cases hi_lt : i < k
          · have hub := gc.seq.B_j_le_bound i k hi_lt hi a ha_Bi
            have hgrow_k := gc.seq.exponential_growth k hk1
            by_cases hk2 : k ≥ 2
            · have hgrow2 := gc.seq.exponential_growth (k - 1) (by omega : k - 1 ≥ 1)
              simp only [Nat.sub_sub] at hgrow2
              simp only [NathansonSeq.N] at hub ha_lower hgap hNk_gt_prev
              have hn_k_gt : gc.seq.n k > gc.seq.n (k - 1) := by linarith
              have hgap_val : (2 * gc.seq.n k + 1) - (2 * gc.seq.n (k - 1) + 1) = 2 * gc.seq.n k - 2 * gc.seq.n (k - 1) := by omega
              rw [hgap_val] at ha_lower hgap
              have ha_lb : a > 14 * gc.seq.n (k - 1) := by linarith
              have ha_ub : a ≤ gc.seq.n (k - 1) + 2 * gc.seq.n (k - 2) + 1 := hub
              have hn_km1_pos := gc.seq.n_pos (k - 1)
              have h_nk2_bound : 2 * gc.seq.n (k - 2) ≤ gc.seq.n (k - 1) / 4 := by
                have := Nat.div_le_div_right hgrow2 (c := 4)
                simp only [Nat.mul_div_assoc, Nat.one_mul] at this
                calc 2 * gc.seq.n (k - 2) = (8 * gc.seq.n (k - 2)) / 4 := by omega
                  _ ≤ gc.seq.n (k - 1) / 4 := Nat.div_le_div_right hgrow2
              have ha_ub' : a ≤ gc.seq.n (k - 1) + gc.seq.n (k - 1) / 4 + 1 := by linarith
              have hcontra : 14 * gc.seq.n (k - 1) ≤ gc.seq.n (k - 1) + gc.seq.n (k - 1) / 4 + 1 := by linarith
              have := Nat.div_le_self (gc.seq.n (k - 1)) 4
              omega
            · have hk1 : k = 1 := by omega
              subst hk1
              omega
          · by_cases hi_eq : i = k
            · rw [hi_eq] at ha_Bi
              simp only [NathansonSeq.B_k] at ha_Bi
              rw [Finset.mem_union, Finset.mem_union] at ha_Bi
              rcases ha_Bi with (hP | hQ) | hR
              · have hP_bound := gc.seq.P_subset k hk1 a hP
                simp only [NathansonSeq.N] at hP_bound ha_lower hgap
                omega
              · have hQ_bound := gc.seq.Q_lt_n k hk1 a hQ
                simp only [NathansonSeq.N] at ha_lower hgap
                have hgrow3 := gc.seq.exponential_growth k hk1
                omega
              · have hR_bound := gc.seq.R_subset k hk1 a hR
                simp only [NathansonSeq.N] at hR_bound ha_lower hgap
                have hgrow3 := gc.seq.exponential_growth k hk1
                omega
            · have hi_gt : i > k := by omega
              have hlb := gc.seq.B_j_gt_N_k i k hi_gt hi a ha_Bi
              omega
        · -- j > k: N_j > N_k, so b could be very large
          have hj_gt : j > k := by omega
          have hN_mono : gc.seq.N k < gc.seq.N j := gc.seq.N_strict_mono_lt hj_gt
          have hb_lower : b > gc.seq.N j - gc.seq.N (j - 1) := hb_range.1
          have hgrow_j := gc.seq.exponential_growth j (by omega : j ≥ 1)
          simp only [NathansonSeq.N] at hgrow_j hN_mono hb_lower
          have hn_mono : gc.seq.n k ≤ gc.seq.n (j - 1) := gc.seq.n_mono_le (by omega : k ≤ j - 1)
          have hn_k_pos := gc.seq.n_pos k
          have hb_big : b > gc.seq.N k := by
            simp only [NathansonSeq.N]
            have hn_j_gt : gc.seq.n j > gc.seq.n (j - 1) := by linarith
            have hn_j_pos := gc.seq.n_pos j
            have hn_jm1_pos := gc.seq.n_pos (j - 1)
            calc b > 2 * gc.seq.n j + 1 - (2 * gc.seq.n (j - 1) + 1) := hb_lower
              _ = 2 * gc.seq.n j - 2 * gc.seq.n (j - 1) := by omega
              _ ≥ 2 * (8 * gc.seq.n (j - 1)) - 2 * gc.seq.n (j - 1) := by omega
              _ = 14 * gc.seq.n (j - 1) := by omega
              _ ≥ 14 * gc.seq.n k := by linarith
              _ > 2 * gc.seq.n k + 1 := by linarith
          omega
  | inr ha_G =>
    obtain ⟨j, hj, ha_Gj⟩ := ha_G
    cases hb with
    | inl hb_B =>
      have ha_range := gc.G_range j hj a ha_Gj
      have ha_pos : a > 0 := by
        have := ha_range.1
        have hN_mono := gc.seq.N_mono_le (by omega : j - 1 ≤ j)
        omega
      have hb_lt : b < gc.seq.N k := by omega
      by_cases hjk : j = k
      · -- j = k case: show b ∈ F_k
        rw [gc.G_mem] at ha_Gj
        obtain ⟨f, hf, haeq⟩ := ha_Gj
        rw [hjk] at haeq hf
        have hf_lt : f < gc.seq.N k := gc.F_lt_N k hk f hf
        have hb_eq : b = f := by omega
        right
        rw [hb_eq]
        constructor
        · simp only [G, Finset.mem_image]
          exact ⟨f, hf, haeq.symm⟩
        · exact hf
      · -- j ≠ k case: same analysis as before (symmetric)
        exfalso
        rw [gc.G_mem] at ha_Gj
        obtain ⟨f, hf, haeq⟩ := ha_Gj
        have hf_lt_prev : f < gc.seq.N (j - 1) := gc.F_lt_N_prev j hj f hf
        have hf_lt_j : f < gc.seq.N j := gc.F_lt_N j hj f hf
        by_cases hjlt : j < k
        · have hN_mono : gc.seq.N j ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
          have ha_upper : a < gc.seq.N j := ha_range.2
          have ha_lt_prev : a < gc.seq.N (k - 1) := by omega
          have hNk_gt_prev : gc.seq.N k > gc.seq.N (k - 1) := gc.seq.N_strict_mono_lt (by omega : k - 1 < k)
          have hb_lower : b > gc.seq.N k - gc.seq.N (k - 1) := by omega
          have hgap : gc.seq.N k - gc.seq.N (k - 1) > gc.seq.N (k - 1) := by
            simp only [NathansonSeq.N]
            have hgrow := gc.seq.exponential_growth k hk1
            have hn_pos := gc.seq.n_pos (k - 1)
            omega
          obtain ⟨i, hi, hb_Bi⟩ := hb_B
          by_cases hi_lt : i < k
          · have hub := gc.seq.B_j_le_bound i k hi_lt hi b hb_Bi
            have hgrow_k := gc.seq.exponential_growth k hk1
            by_cases hk2 : k ≥ 2
            · have hgrow2 := gc.seq.exponential_growth (k - 1) (by omega : k - 1 ≥ 1)
              simp only [NathansonSeq.N, Nat.sub_sub] at hub hb_lower hgap hgrow_k hgrow2 hNk_gt_prev
              have hn_k_gt : gc.seq.n k > gc.seq.n (k - 1) := by linarith
              have hgap_val : (2 * gc.seq.n k + 1) - (2 * gc.seq.n (k - 1) + 1) = 2 * gc.seq.n k - 2 * gc.seq.n (k - 1) := by omega
              rw [hgap_val] at hb_lower hgap
              have hb_lb : b > 14 * gc.seq.n (k - 1) := by linarith
              have hb_ub : b ≤ gc.seq.n (k - 1) + 2 * gc.seq.n (k - 2) + 1 := hub
              have h_nk2_bound : 2 * gc.seq.n (k - 2) ≤ gc.seq.n (k - 1) / 4 :=
                calc 2 * gc.seq.n (k - 2) = (8 * gc.seq.n (k - 2)) / 4 := by omega
                  _ ≤ gc.seq.n (k - 1) / 4 := Nat.div_le_div_right hgrow2
              have hb_ub' : b ≤ gc.seq.n (k - 1) + gc.seq.n (k - 1) / 4 + 1 := by linarith
              have := Nat.div_le_self (gc.seq.n (k - 1)) 4
              omega
            · have hk1 : k = 1 := by omega
              subst hk1
              omega
          · by_cases hi_eq : i = k
            · rw [hi_eq] at hb_Bi
              simp only [NathansonSeq.B_k] at hb_Bi
              rw [Finset.mem_union, Finset.mem_union] at hb_Bi
              simp only [NathansonSeq.N] at hb_lower hgap
              have hgrow := gc.seq.exponential_growth k hk1
              rcases hb_Bi with (hP | hQ) | hR
              · have hP_bound := gc.seq.P_subset k hk1 b hP
                simp only [NathansonSeq.N] at hP_bound
                omega
              · have hQ_bound := gc.seq.Q_lt_n k hk1 b hQ
                omega
              · have hR_bound := gc.seq.R_subset k hk1 b hR
                simp only [NathansonSeq.N] at hR_bound
                omega
            · have hi_gt : i > k := by omega
              have hlb := gc.seq.B_j_gt_N_k i k hi_gt hi b hb_Bi
              omega
        · have hj_gt : j > k := by omega
          have hN_mono : gc.seq.N k < gc.seq.N j := gc.seq.N_strict_mono_lt hj_gt
          have hgrow_j := gc.seq.exponential_growth j (by omega : j ≥ 1)
          simp only [NathansonSeq.N] at hgrow_j hN_mono ha_range
          have hn_mono : gc.seq.n k ≤ gc.seq.n (j - 1) := gc.seq.n_mono_le (by omega : k ≤ j - 1)
          have hn_k_pos := gc.seq.n_pos k
          have hn_j_gt : gc.seq.n j > gc.seq.n (j - 1) := by linarith
          have hn_j_pos := gc.seq.n_pos j
          have hn_jm1_pos := gc.seq.n_pos (j - 1)
          have ha_big : a > gc.seq.N k := by
            simp only [NathansonSeq.N]
            calc a > 2 * gc.seq.n j + 1 - (2 * gc.seq.n (j - 1) + 1) := ha_range.1
              _ = 2 * gc.seq.n j - 2 * gc.seq.n (j - 1) := by omega
              _ ≥ 2 * (8 * gc.seq.n (j - 1)) - 2 * gc.seq.n (j - 1) := by omega
              _ = 14 * gc.seq.n (j - 1) := by omega
              _ ≥ 14 * gc.seq.n k := by linarith
              _ > 2 * gc.seq.n k + 1 := by linarith
          omega
    | inr hb_G =>
      obtain ⟨j', hj', hb_Gj'⟩ := hb_G
      exfalso
      rw [gc.G_mem] at ha_Gj hb_Gj'
      obtain ⟨f, hf, ha_eq⟩ := ha_Gj
      obtain ⟨g, hg, hb_eq⟩ := hb_Gj'
      have hf_lt : f < gc.seq.N j := gc.F_lt_N j hj f hf
      have hg_lt : g < gc.seq.N j' := gc.F_lt_N j' hj' g hg
      have ha_range := gc.G_range j hj a (by simp only [G, Finset.mem_image]; exact ⟨f, hf, ha_eq.symm⟩)
      have hb_range := gc.G_range j' hj' b (by simp only [G, Finset.mem_image]; exact ⟨g, hg, hb_eq.symm⟩)
      by_cases hj_lt : j < k
      · by_cases hj'_lt : j' < k
        · -- Both j, j' < k: a + b < 2 * N_{k-1} < N_k
          have hN_mono_j : gc.seq.N j ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
          have hN_mono_j' : gc.seq.N j' ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
          have ha_ub : a < gc.seq.N (k - 1) := by omega
          have hb_ub : b < gc.seq.N (k - 1) := by omega
          have hab_ub : a + b < 2 * gc.seq.N (k - 1) := by omega
          have hNk_large : gc.seq.N k > 2 * gc.seq.N (k - 1) := by
            simp only [NathansonSeq.N]
            have hgrow := gc.seq.exponential_growth k hk1
            have hn_pos := gc.seq.n_pos (k - 1)
            omega
          omega
        · -- j < k, j' ≥ k. If j' > k: b > N_k (contradiction)
          have hj'_ge : j' ≥ k := by omega
          rcases hj'_ge.lt_or_eq with hj'_gt | hj'_eq
          · -- j' > k means j' ≥ k + 1
            have hj'_ge_k1 : j' ≥ k + 1 := hj'_gt
            have hN_prev_ge : gc.seq.N (j' - 1) ≥ gc.seq.N k := gc.seq.N_mono_le (by omega)
            have hgrow_j' := gc.seq.exponential_growth j' (by omega : j' ≥ 1)
            simp only [NathansonSeq.N] at hgrow_j' hN_prev_ge hb_range hab
            have hn_pos_k := gc.seq.n_pos k
            have hn_pos_j'_1 := gc.seq.n_pos (j' - 1)
            have ha_pos : a > 0 := by
              have := ha_range.1
              simp only [NathansonSeq.N] at this
              have hn_pos_j := gc.seq.n_pos j
              have hn_pos_j_1 : gc.seq.n (j - 1) ≥ 0 := Nat.zero_le _
              omega
            omega
          · -- j' = k: b ∈ G_k, j < k so a < N_j ≤ N_{k-1}
            subst hj'_eq
            have hN_mono : gc.seq.N j ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
            have ha_ub : a < gc.seq.N (k - 1) := by omega
            have hb_lb : b > gc.seq.N k - gc.seq.N (k - 1) := hb_range.1
            have hNk_gap : gc.seq.N k - gc.seq.N (k - 1) > gc.seq.N (k - 1) := by
              simp only [NathansonSeq.N]
              have hgrow := gc.seq.exponential_growth k hk1
              have hn_pos := gc.seq.n_pos (k - 1)
              omega
            have hg_in_B : gc.seq.inB g := by
              obtain ⟨i, hi_lo, hi_hi, hgi⟩ := gc.F_subset k hk1 g hg
              rw [← hgi]
              exact gc.a_in_B i hi_lo
            have ha_not_B := gc.G_disjoint_B j hj a (by simp only [G, Finset.mem_image]; exact ⟨f, hf, ha_eq.symm⟩)
            have hg_lt_prev : g < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk g hg
            have ha_eq_g : a = g := by omega
            rw [ha_eq_g] at ha_not_B
            exact ha_not_B hg_in_B
      · -- j ≥ k
        rcases (Nat.lt_or_eq_of_le (Nat.not_lt.mp hj_lt)).symm with hj_eq | hj_gt
        · -- j = k
          subst hj_eq
          by_cases hj'_lt : j' < k
          · -- j' < k, j = k: symmetric to case above
            have hN_mono : gc.seq.N j' ≤ gc.seq.N (k - 1) := gc.seq.N_mono_le (by omega)
            have hb_ub : b < gc.seq.N (k - 1) := by omega
            have ha_lb : a > gc.seq.N k - gc.seq.N (k - 1) := ha_range.1
            have hf_in_B : gc.seq.inB f := by
              obtain ⟨i, hi_lo, hi_hi, hfi⟩ := gc.F_subset k hk1 f hf
              rw [← hfi]
              exact gc.a_in_B i hi_lo
            have hb_not_B := gc.G_disjoint_B j' hj' b (by simp only [G, Finset.mem_image]; exact ⟨g, hg, hb_eq.symm⟩)
            have hf_lt_prev : f < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk f hf
            have hb_eq_f : b = f := by omega
            rw [hb_eq_f] at hb_not_B
            exact hb_not_B hf_in_B
          · -- j' ≥ k and j = k
            have hj'_ge : j' ≥ k := by omega
            rcases hj'_ge.lt_or_eq with hj'_gt | hj'_eq
            · -- j' > k: b > N_k (contradiction with hab)
              have hj'_ge_k1 : j' ≥ k + 1 := hj'_gt
              have hN_prev_ge : gc.seq.N (j' - 1) ≥ gc.seq.N k := gc.seq.N_mono_le (by omega)
              have hgrow_j' := gc.seq.exponential_growth j' (by omega : j' ≥ 1)
              simp only [NathansonSeq.N] at hgrow_j' hN_prev_ge hb_range hab
              have hn_pos_k := gc.seq.n_pos k
              have hn_pos_j'_1 := gc.seq.n_pos (j' - 1)
              have ha_pos : a > 0 := by
                have := ha_range.1
                simp only [NathansonSeq.N] at this
                have hn_pos := gc.seq.n_pos k
                have hn_pos_k_1 : gc.seq.n (k - 1) ≥ 0 := Nat.zero_le _
                omega
              omega
            · -- j = j' = k: a + b = 2*N_k - f - g = N_k, so f + g = N_k
              subst hj'_eq
              have hf_lt_prev : f < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk f hf
              have hg_lt_prev : g < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk g hg
              have hf_lt_k : f < gc.seq.N k := gc.F_lt_N k hk f hf
              have hg_lt_k : g < gc.seq.N k := gc.F_lt_N k hk g hg
              have ha_val : a = gc.seq.N k - f := ha_eq
              have hb_val : b = gc.seq.N k - g := hb_eq
              have hfg_sum : f + g = gc.seq.N k := by omega
              have hfg_ub : f + g < 2 * gc.seq.N (k - 1) := by omega
              have hNk_large : gc.seq.N k > 2 * gc.seq.N (k - 1) := by
                simp only [NathansonSeq.N]
                have hgrow := gc.seq.exponential_growth k hk1
                have hn_pos := gc.seq.n_pos (k - 1)
                omega
              omega
        · -- j > k: a > N_k (contradiction)
          have hj_ge_k1 : j ≥ k + 1 := hj_gt
          have hN_prev_ge : gc.seq.N (j - 1) ≥ gc.seq.N k := gc.seq.N_mono_le (by omega)
          have hgrow_j := gc.seq.exponential_growth j (by omega : j ≥ 1)
          simp only [NathansonSeq.N] at hgrow_j hN_prev_ge ha_range hab
          have hn_pos_k := gc.seq.n_pos k
          have hn_pos_j_1 := gc.seq.n_pos (j - 1)
          have hb_pos : b > 0 := by
            have := hb_range.1
            simp only [NathansonSeq.N] at this
            have hn_pos_j'_1 : gc.seq.n (j' - 1) ≥ 0 := Nat.zero_le _
            have hn_pos_j' := gc.seq.n_pos j'
            omega
          omega
/-- r_A(N_k) = t_k = stage(k) -/
theorem rep_count_Nk (k : ℕ) (hk : k ≥ 2) :
    ∃ pairs : Finset (ℕ × ℕ),
      pairs.card = gc.stage k ∧
      ∀ p ∈ pairs, gc.inA p.1 ∧ gc.inA p.2 ∧ p.1 + p.2 = gc.seq.N k ∧ p.1 ≤ p.2 := by
  have hk1 : k ≥ 1 := by omega
  use (gc.F k).image (fun f => (f, gc.seq.N k - f))
  constructor
  · -- Card = |F_k| = stage(k)
    rw [Finset.card_image_of_injective]
    · exact gc.F_card k hk1
    · intro f₁ f₂ heq
      simp only [Prod.mk.injEq] at heq
      exact heq.1
  · intro p hp
    simp only [Finset.mem_image] at hp
    obtain ⟨f, hf, rfl⟩ := hp
    have hf_lt : f < gc.seq.N k := gc.F_lt_N k hk f hf
    have hf_in_B : gc.seq.inB f := by
      obtain ⟨i, hi_lo, hi_hi, hai⟩ := gc.F_subset k hk1 f hf
      rw [← hai]
      exact gc.a_in_B i hi_lo
    refine ⟨Or.inl hf_in_B, ?_, ?_, ?_⟩
    · -- N_k - f ∈ A (it's in G_k)
      right
      use k, hk
      simp only [G, Finset.mem_image]
      exact ⟨f, hf, rfl⟩
    · -- f + (N_k - f) = N_k
      omega
    · -- f ≤ N_k - f (since f < N_k / 2 roughly)
      have hf_lt_prev : f < gc.seq.N (k - 1) := gc.F_lt_N_prev k hk f hf
      have hNk_large : gc.seq.N k > 2 * gc.seq.N (k - 1) := by
        simp only [NathansonSeq.N]
        have hgrow := gc.seq.exponential_growth k hk1
        have hn_pos := gc.seq.n_pos (k - 1)
        omega
      omega
/-- r_A(n) ≥ r_B(n) for all n ≠ N_k -/
lemma rep_count_other (n : ℕ) (hn : ∀ k, n ≠ gc.seq.N k) :
    ∀ a b, gc.seq.inB a → gc.seq.inB b → a + b = n →
      gc.inA a ∧ gc.inA b := by
  intro a b ha hb hab
  exact ⟨Or.inl ha, Or.inl hb⟩
/-- r_A(n) → ∞ as n → ∞ -/
theorem rep_count_unbounded : ∀ t, ∃ M, ∀ n ≥ M, ∃ k, gc.stage k ≥ t ∧
    (n = gc.seq.N k ∨ (∀ j, n ≠ gc.seq.N j)) := by
  intro t
  obtain ⟨k₀, hk₀⟩ := gc.stage_unbounded t
  use gc.seq.N k₀
  intro n hn
  by_cases hex : ∃ j, n = gc.seq.N j
  · obtain ⟨j, hj⟩ := hex
    use j
    constructor
    · -- Need stage j ≥ t
      have hj_ge : j ≥ k₀ := by
        by_contra h
        push_neg at h
        have hN_lt : gc.seq.N j < gc.seq.N k₀ := gc.seq.N_strict_mono_lt h
        omega
      have hstage := hk₀ j hj_ge
      omega
    · left
      exact hj
  · push_neg at hex
    use k₀
    constructor
    · have hstage := hk₀ k₀ (le_refl k₀)
      omega
    · right
      exact hex
/-!
## Non-decomposability
-/
/-- For any threshold N₀, there exists a stage m₀ such that for all m ≥ m₀,
    any k with stage(k) = m has N_k ≥ N₀.
    This follows from: stage(k) ≤ k (so k ≥ m when stage k = m), and N grows with k.
    We return m₀ ≥ 2 to ensure k ≥ 2 (needed since inA requires k ≥ 2). -/
lemma stage_ensures_large_N (N₀ : ℕ) :
    ∃ m₀ ≥ 2, ∀ m ≥ m₀, ∀ k, gc.stage k = m → gc.seq.N k ≥ N₀ := by
  obtain ⟨k₁, hk₁⟩ := gc.seq.N_eventually_large N₀
  use max 2 k₁
  constructor
  · exact le_max_left 2 k₁
  · intro m hm k hstage
    have hm_ge_2 : m ≥ 2 := Nat.le_trans (le_max_left 2 k₁) hm
    have hm_ge_1 : m ≥ 1 := by omega
    have hm_ge_k1 : m ≥ k₁ := Nat.le_trans (le_max_right 2 k₁) hm
    have hk_ge_1 : k ≥ 1 := by
      by_contra h
      push_neg at h
      interval_cases k
      · -- k = 0: stage 0 = 0 by stage_zero, but hstage says stage 0 = m ≥ 1
        rw [gc.stage_zero] at hstage
        omega
    have hstage_le_k : gc.stage k ≤ k := gc.stage_le_k k hk_ge_1
    have hk_ge_m : k ≥ m := by rw [← hstage]; exact hstage_le_k
    have hk_ge_k1 : k ≥ k₁ := Nat.le_trans hm_ge_k1 hk_ge_m
    exact hk₁ k hk_ge_k1
/-- If B' represents N_k, then some element of F_k is in B' -/
lemma Nk_rep_needs_Fk (k : ℕ) (hk : k ≥ 2) (B' : Set ℕ)
    (hB'_sub : ∀ x ∈ B', gc.inA x)
    (hrep : ∃ a ∈ B', ∃ b ∈ B', a + b = gc.seq.N k) :
    ∃ f ∈ gc.F k, f ∈ B' := by
  obtain ⟨a, ha_B', b, hb_B', hab⟩ := hrep
  have ha_A := hB'_sub a ha_B'
  have hb_A := hB'_sub b hb_B'
  have hrep_form := gc.N_representations k hk a b ha_A hb_A hab
  rcases hrep_form with ⟨ha_F, hb_G⟩ | ⟨ha_G, hb_F⟩
  · exact ⟨a, ha_F, ha_B'⟩
  · exact ⟨b, hb_F, hb_B'⟩
/-- Key claim: In any decomposition A = B' ⊔ C' with B' an asymptotic basis,
    B' ∩ B is infinite -/
lemma intersection_infinite (B' C' : Set ℕ)
    (hpart : ∀ x, gc.inA x ↔ x ∈ B' ∨ x ∈ C')
    (hdisj : Disjoint B' C')
    (hB'_basis : ∀ᶠ n in Filter.atTop, ∃ a ∈ B', ∃ b ∈ B', a + b = n) :
    Set.Infinite (B' ∩ {x | gc.seq.inB x}) := by
  by_contra hfin
  rw [Set.not_infinite] at hfin
  have hB'_sub : ∀ x ∈ B', gc.inA x := fun x hx => (hpart x).mpr (Or.inl hx)
  rw [Filter.Eventually, Filter.mem_atTop_sets] at hB'_basis
  obtain ⟨N₀, hN₀⟩ := hB'_basis
  have hB_inf : Set.Infinite {x | gc.seq.inB x} := gc.seq.B_infinite
  have hB_partition : ∀ x, gc.seq.inB x → (x ∈ B' ↔ x ∉ C') := by
    intro x hx
    have hxA : gc.inA x := Or.inl hx
    rw [hpart] at hxA
    have hdisj' := Set.disjoint_iff.mp hdisj
    constructor
    · intro hxB'; exact fun hxC' => hdisj' ⟨hxB', hxC'⟩
    · intro hxnC'
      rcases hxA with hxB' | hxC'
      · exact hxB'
      · exact absurd hxC' hxnC'
  have hC'B_inf : Set.Infinite (C' ∩ {x | gc.seq.inB x}) := by
    have hB_eq : {x | gc.seq.inB x} = (B' ∩ {x | gc.seq.inB x}) ∪ (C' ∩ {x | gc.seq.inB x}) := by
      ext x
      simp only [Set.mem_setOf_eq, Set.mem_union, Set.mem_inter_iff]
      constructor
      · intro hx
        have hxA : gc.inA x := Or.inl hx
        rw [hpart] at hxA
        rcases hxA with hxB' | hxC'
        · left; exact ⟨hxB', hx⟩
        · right; exact ⟨hxC', hx⟩
      · intro h
        rcases h with ⟨_, hx⟩ | ⟨_, hx⟩ <;> exact hx
    rw [hB_eq] at hB_inf
    simp only [Set.infinite_union] at hB_inf
    rcases hB_inf with hinf' | hinf''
    · exact absurd hinf' (Set.not_infinite.mpr hfin)
    · exact hinf''
  obtain ⟨m₀, hm₀_ge_2, hm₀_large⟩ := gc.stage_ensures_large_N N₀
  have hm₀_ge_1 : m₀ ≥ 1 := by omega
  have hB'B_bounded : ∃ J, ∀ i, i > J → gc.a i ∉ B' := by
    by_contra h
    push_neg at h
    have hinf' : Set.Infinite (B' ∩ {x | gc.seq.inB x}) := by
      apply Set.infinite_of_forall_exists_gt
      intro n
      obtain ⟨i₀, hi₀_ge, hi₀_gt⟩ := gc.a_unbounded n
      obtain ⟨i, hi_gt, ha_i_B'⟩ := h (max i₀ 0)
      have hi_ge_1 : i ≥ 1 := by omega
      have ha_i_B : gc.seq.inB (gc.a i) := gc.a_in_B i hi_ge_1
      use gc.a i
      refine ⟨⟨ha_i_B', ha_i_B⟩, ?_⟩
      have ha_i_gt : gc.a i > gc.a i₀ := gc.a_strict_mono_ge i₀ i hi₀_ge hi_ge_1 (by omega)
      omega
    exact absurd hinf' (Set.not_infinite.mpr hfin)
  obtain ⟨J, hJ⟩ := hB'B_bounded
  have hH_linear : ∀ m ≥ 1, gc.H m ≥ 2 * m := gc.H_linear
  let m := max m₀ (J + 1)
  have hm_ge_m0 : m ≥ m₀ := le_max_left m₀ (J + 1)
  have hm_ge_J1 : m ≥ J + 1 := le_max_right m₀ (J + 1)
  have hm_ge_1 : m ≥ 1 := Nat.le_trans hm₀_ge_1 hm_ge_m0
  have hHm_ge_Jm : gc.H m ≥ J + m + 1 := by
    have h := hH_linear m hm_ge_1
    calc gc.H m ≥ 2 * m := h
      _ = m + m := by ring
      _ ≥ m + (J + 1) := by omega
      _ = J + m + 1 := by ring
  have hm_ge_1 : m ≥ 1 := Nat.le_trans hm₀_ge_1 hm_ge_m0
  let S : Finset ℕ := (Finset.Icc (J + 1) (J + m)).image gc.a
  have hS_card : S.card = m := by
    simp only [S]
    rw [Finset.card_image_of_injOn]
    · -- card of Icc (J+1) (J+m) = (J+m) + 1 - (J+1) = m
      rw [Nat.card_Icc]
      omega
    · -- a is injective on Icc (J+1) (J+m)
      intro i₁ hi₁ i₂ hi₂ heq
      have hi₁_bounds : J + 1 ≤ i₁ ∧ i₁ ≤ J + m := Finset.mem_Icc.mp hi₁
      have hi₂_bounds : J + 1 ≤ i₂ ∧ i₂ ≤ J + m := Finset.mem_Icc.mp hi₂
      have hi₁_ge_1 : i₁ ≥ 1 := by omega
      have hi₂_ge_1 : i₂ ≥ 1 := by omega
      by_contra hne
      rcases Nat.lt_trichotomy i₁ i₂ with hlt | heq' | hgt
      · have := gc.a_strict_mono_ge i₁ i₂ hi₁_ge_1 hi₂_ge_1 hlt
        omega
      · exact hne heq'
      · have := gc.a_strict_mono_ge i₂ i₁ hi₂_ge_1 hi₁_ge_1 hgt
        omega
  have hS_subset : ∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ gc.H m ∧ gc.a i = x := by
    intro x hx
    simp only [S, Finset.mem_image, Finset.mem_Icc] at hx
    obtain ⟨i, ⟨hi_lo, hi_hi⟩, rfl⟩ := hx
    use i
    refine ⟨by omega, ?_, rfl⟩
    omega
  have hm_ge_1' : m ≥ 1 := hm_ge_1
  obtain ⟨k, hstage_k, hF_k⟩ := gc.exhaustive m hm_ge_1' S hS_subset hS_card
  have hNk_large : gc.seq.N k ≥ N₀ := hm₀_large m hm_ge_m0 k hstage_k
  have hB'_rep_Nk : ∃ a ∈ B', ∃ b ∈ B', a + b = gc.seq.N k := hN₀ (gc.seq.N k) hNk_large
  have hk_ge_1 : k ≥ 1 := by
    by_contra h
    push_neg at h
    interval_cases k
    · rw [gc.stage_zero] at hstage_k
      omega
  have hk_ge_m : k ≥ m := by
    have := gc.stage_le_k k hk_ge_1
    rw [hstage_k] at this; exact this
  have hk_ge_2 : k ≥ 2 := by omega
  obtain ⟨f, hf_Fk, hf_B'⟩ := gc.Nk_rep_needs_Fk k hk_ge_2 B' hB'_sub hB'_rep_Nk
  rw [hF_k] at hf_Fk
  simp only [S, Finset.mem_image, Finset.mem_Icc] at hf_Fk
  obtain ⟨i, ⟨hi_lo, hi_hi⟩, hf_eq⟩ := hf_Fk
  have hi_gt_J : i > J := by omega
  have ha_i_not_B' : gc.a i ∉ B' := hJ i hi_gt_J
  rw [hf_eq] at ha_i_not_B'
  exact ha_i_not_B' hf_B'
/-- Main non-decomposability theorem -/
theorem non_decomposable :
    ¬∃ (B' C' : Set ℕ),
      (∀ x, gc.inA x ↔ x ∈ B' ∨ x ∈ C') ∧
      Disjoint B' C' ∧
      (∀ᶠ n in Filter.atTop, ∃ a ∈ B', ∃ b ∈ B', a + b = n) ∧
      (∀ᶠ n in Filter.atTop, ∃ a ∈ C', ∃ b ∈ C', a + b = n) := by
  intro ⟨B', C', hpart, hdisj, hB'_basis, hC'_basis⟩
  have hB'B_inf := gc.intersection_infinite B' C' hpart hdisj hB'_basis
  rw [Filter.Eventually, Filter.mem_atTop_sets] at hC'_basis
  obtain ⟨N₀, hN₀⟩ := hC'_basis
  obtain ⟨m₀, hm₀_ge_2, hm₀_large⟩ := gc.stage_ensures_large_N N₀
  have hm₀_ge_1 : m₀ ≥ 1 := by omega
  have hB'_sub : ∀ x ∈ B', gc.inA x := fun x hx => (hpart x).mpr (Or.inl hx)
  have hexists : ∃ m ≥ m₀, ∃ S : Finset ℕ, S.card = m ∧
      (∀ x ∈ S, x ∈ B' ∧ gc.seq.inB x) ∧
      (∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ gc.H m ∧ gc.a i = x) := by
    by_cases hC'B_fin : Set.Finite (C' ∩ {x | gc.seq.inB x})
    case pos =>
      have hC'B_bounded : ∃ J, ∀ i, i > J → gc.a i ∉ C' := by
        by_contra h
        push_neg at h
        have hinf : Set.Infinite (C' ∩ {x | gc.seq.inB x}) := by
          apply Set.infinite_of_forall_exists_gt
          intro n
          obtain ⟨i₀, hi₀_ge, ha_i₀_gt⟩ := gc.a_unbounded n
          obtain ⟨i, hi_gt, ha_i_C'⟩ := h (max i₀ 0)
          have hi_ge_1 : i ≥ 1 := by omega
          have ha_i_B : gc.seq.inB (gc.a i) := gc.a_in_B i hi_ge_1
          use gc.a i
          refine ⟨⟨ha_i_C', ha_i_B⟩, ?_⟩
          have ha_i_gt' : gc.a i > gc.a i₀ := gc.a_strict_mono_ge i₀ i hi₀_ge hi_ge_1 (by omega)
          omega
        exact absurd hinf (Set.not_infinite.mpr hC'B_fin)
      obtain ⟨J, hJ⟩ := hC'B_bounded
      have hH_linear := gc.H_linear
      let m := max m₀ (J + 1)
      use m
      constructor
      · exact le_max_left m₀ (J + 1)
      let S : Finset ℕ := (Finset.Icc (J + 1) (J + m)).image gc.a
      use S
      have hm_ge_1 : m ≥ 1 := Nat.le_trans hm₀_ge_1 (le_max_left m₀ (J + 1))
      have hm_ge_J1 : m ≥ J + 1 := le_max_right m₀ (J + 1)
      have hHm_ge : gc.H m ≥ J + m + 1 := by
        have h := hH_linear m hm_ge_1
        calc gc.H m ≥ 2 * m := h
          _ = m + m := by ring
          _ ≥ m + (J + 1) := by omega
          _ = J + m + 1 := by ring
      constructor
      · -- S.card = m
        simp only [S]
        rw [Finset.card_image_of_injOn]
        · rw [Nat.card_Icc]; omega
        · intro i₁ hi₁ i₂ hi₂ heq
          simp only [Finset.coe_Icc, Set.mem_Icc] at hi₁ hi₂
          have hi₁_ge_1 : i₁ ≥ 1 := by omega
          have hi₂_ge_1 : i₂ ≥ 1 := by omega
          by_contra hne
          rcases Nat.lt_trichotomy i₁ i₂ with hlt | heq' | hgt
          · have := gc.a_strict_mono_ge i₁ i₂ hi₁_ge_1 hi₂_ge_1 hlt; omega
          · exact hne heq'
          · have := gc.a_strict_mono_ge i₂ i₁ hi₂_ge_1 hi₁_ge_1 hgt; omega
      constructor
      · -- ∀ x ∈ S, x ∈ B' ∧ gc.seq.inB x
        intro x hx
        simp only [S, Finset.mem_image, Finset.mem_Icc] at hx
        obtain ⟨i, ⟨hi_lo, hi_hi⟩, rfl⟩ := hx
        have hi_gt_J : i > J := by omega
        have hi_ge_1 : i ≥ 1 := by omega
        have ha_i_B := gc.a_in_B i hi_ge_1
        have ha_i_not_C' := hJ i hi_gt_J
        have ha_i_A : gc.inA (gc.a i) := Or.inl ha_i_B
        have ha_i_in_union := (hpart (gc.a i)).mp ha_i_A
        rcases ha_i_in_union with ha_i_B' | ha_i_C'
        · exact ⟨ha_i_B', ha_i_B⟩
        · exact absurd ha_i_C' ha_i_not_C'
      · -- ∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ gc.H m ∧ gc.a i = x
        intro x hx
        simp only [S, Finset.mem_image, Finset.mem_Icc] at hx
        obtain ⟨i, ⟨hi_lo, hi_hi⟩, rfl⟩ := hx
        use i
        refine ⟨by omega, ?_, rfl⟩
        omega
    case neg =>
      have hI_inf : Set.Infinite {i : ℕ | i ≥ 1 ∧ gc.a i ∈ B'} := by
        apply Set.infinite_of_not_bddAbove
        intro ⟨M, hM⟩
        have hfin : Set.Finite (B' ∩ {x | gc.seq.inB x}) := by
          apply Set.Finite.subset (Set.finite_Icc 0 (gc.a (M + 1)))
          intro x ⟨hxB', hxB⟩
          simp only [Set.mem_Icc]
          obtain ⟨i, hi_ge, hai⟩ := gc.a_covers x hxB
          constructor
          · omega
          · have hi_in : i ∈ {i : ℕ | i ≥ 1 ∧ gc.a i ∈ B'} := by
              simp only [Set.mem_setOf_eq]
              exact ⟨hi_ge, hai ▸ hxB'⟩
            have hi_le_M := hM hi_in
            rw [← hai]
            by_cases hi_eq_M1 : i = M + 1
            · omega  -- i ≤ M so can't equal M+1
            · have hi_lt : i < M + 1 := by omega
              have hM1_ge_1 : M + 1 ≥ 1 := by omega
              exact Nat.le_of_lt (gc.a_strict_mono_ge i (M + 1) hi_ge hM1_ge_1 hi_lt)
        exact hB'B_inf hfin
      have hIJ_partition : ∀ i ≥ 1, (gc.a i ∈ B' ∧ gc.a i ∉ C') ∨ (gc.a i ∉ B' ∧ gc.a i ∈ C') := by
        intro i hi
        have ha_i_B := gc.a_in_B i hi
        have ha_i_A : gc.inA (gc.a i) := Or.inl ha_i_B
        have ha_i_in_union := (hpart (gc.a i)).mp ha_i_A
        rcases ha_i_in_union with ha_i_B' | ha_i_C'
        · left
          constructor
          · exact ha_i_B'
          · intro ha_i_C'_
            exact Set.disjoint_iff.mp hdisj ⟨ha_i_B', ha_i_C'_⟩
        · right
          constructor
          · intro ha_i_B'_
            exact Set.disjoint_iff.mp hdisj ⟨ha_i_B'_, ha_i_C'⟩
          · exact ha_i_C'
      classical
      have hcount_partition : ∀ n ≥ 1,
          (Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 n)).card +
          (Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 n)).card = n := by
        intro n hn
        have h1 : (Finset.Icc 1 n).card = n := Nat.card_Icc 1 n
        have h2 : Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 n) ∪
                  Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 n) =
                  Finset.Icc 1 n := by
          ext i
          simp only [Finset.mem_union, Finset.mem_filter, Finset.mem_Icc]
          constructor
          · intro h; rcases h with ⟨⟨hi_lo, hi_hi⟩, _⟩ | ⟨⟨hi_lo, hi_hi⟩, _⟩ <;> exact ⟨hi_lo, hi_hi⟩
          · intro ⟨hi_lo, hi_hi⟩
            have hi_ge : i ≥ 1 := hi_lo
            rcases hIJ_partition i hi_ge with ⟨hB', _⟩ | ⟨_, hC'⟩
            · left; exact ⟨⟨hi_lo, hi_hi⟩, hB'⟩
            · right; exact ⟨⟨hi_lo, hi_hi⟩, hC'⟩
        have h3 : Disjoint (Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 n))
                          (Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 n)) := by
          rw [Finset.disjoint_iff_ne]
          intro i hi j hj heq
          simp only [Finset.mem_filter, Finset.mem_Icc] at hi hj
          rw [← heq] at hj
          have ⟨⟨hi_lo, _⟩, hi_B'⟩ := hi
          have ⟨_, hj_C'⟩ := hj
          rcases hIJ_partition i hi_lo with ⟨_, hi_not_C'⟩ | ⟨hi_not_B', _⟩
          · exact hi_not_C' hj_C'
          · exact hi_not_B' hi_B'
        rw [← Finset.card_union_of_disjoint h3, h2, h1]
      have hH_m₀_ge : gc.H m₀ ≥ 2 * m₀ := gc.H_linear m₀ hm₀_ge_1
      have hH_m₀_ge_1 : gc.H m₀ ≥ 1 := by omega
      have hpigeonhole : (Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 (gc.H m₀))).card ≥ m₀ ∨
                         (Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 (gc.H m₀))).card ≥ m₀ := by
        by_contra h
        push_neg at h
        have ⟨hI_lt, hJ_lt⟩ := h
        have hsum := hcount_partition (gc.H m₀) hH_m₀_ge_1
        omega
      rcases hpigeonhole with hI_case | hJ_case
      · use m₀
        constructor
        · exact le_refl m₀
        let goodIndices := Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 (gc.H m₀))
        have hgood_card : goodIndices.card ≥ m₀ := hI_case
        obtain ⟨S_indices, hS_sub, hS_card⟩ := Finset.exists_subset_card_eq hgood_card
        let S := S_indices.image gc.a
        use S
        constructor
        · -- S.card = m₀
          rw [Finset.card_image_of_injOn]
          · exact hS_card
          · intro i₁ hi₁ i₂ hi₂ heq
            have hi₁' := hS_sub hi₁
            have hi₂' := hS_sub hi₂
            simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi₁' hi₂'
            have hi₁_ge_1 : i₁ ≥ 1 := hi₁'.1.1
            have hi₂_ge_1 : i₂ ≥ 1 := hi₂'.1.1
            by_contra hne
            rcases Nat.lt_trichotomy i₁ i₂ with hlt | heq' | hgt
            · have := gc.a_strict_mono_ge i₁ i₂ hi₁_ge_1 hi₂_ge_1 hlt; omega
            · exact hne heq'
            · have := gc.a_strict_mono_ge i₂ i₁ hi₂_ge_1 hi₁_ge_1 hgt; omega
        constructor
        · -- ∀ x ∈ S, x ∈ B' ∧ gc.seq.inB x
          intro x hx
          simp only [S, Finset.mem_image] at hx
          obtain ⟨i, hi_mem, rfl⟩ := hx
          have hi' := hS_sub hi_mem
          simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi'
          have ⟨⟨hi_lo, _⟩, ha_i_B'⟩ := hi'
          exact ⟨ha_i_B', gc.a_in_B i hi_lo⟩
        · -- ∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ gc.H m₀ ∧ gc.a i = x
          intro x hx
          simp only [S, Finset.mem_image] at hx
          obtain ⟨i, hi_mem, rfl⟩ := hx
          have hi' := hS_sub hi_mem
          simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi'
          use i
          exact ⟨hi'.1.1, hi'.1.2, rfl⟩
      · -- Get threshold for B'
        rw [Filter.Eventually, Filter.mem_atTop_sets] at hB'_basis
        obtain ⟨N₀', hN₀'⟩ := hB'_basis
        obtain ⟨m₀', hm₀'_ge_2, hm₀'_large⟩ := gc.stage_ensures_large_N N₀'
        have hm₀'_ge_1 : m₀' ≥ 1 := by omega
        let m₁ := max m₀ m₀'
        have hm₁_ge_m₀ : m₁ ≥ m₀ := le_max_left m₀ m₀'
        have hm₁_ge_m₀' : m₁ ≥ m₀' := le_max_right m₀ m₀'
        have hm₁_ge_1 : m₁ ≥ 1 := Nat.le_trans hm₀_ge_1 hm₁_ge_m₀
        have hH_m₁_ge : gc.H m₁ ≥ 2 * m₁ := gc.H_linear m₁ hm₁_ge_1
        have hH_m₁_ge_1 : gc.H m₁ ≥ 1 := by omega
        have hpigeonhole' : (Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 (gc.H m₁))).card ≥ m₁ ∨
                            (Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 (gc.H m₁))).card ≥ m₁ := by
          by_contra h
          push_neg at h
          have ⟨hI_lt, hJ_lt⟩ := h
          have hsum := hcount_partition (gc.H m₁) hH_m₁_ge_1
          omega
        rcases hpigeonhole' with hI_case' | hJ_case'
        · use m₁
          constructor
          · exact hm₁_ge_m₀
          let goodIndices := Finset.filter (fun i => gc.a i ∈ B') (Finset.Icc 1 (gc.H m₁))
          have hgood_card : goodIndices.card ≥ m₁ := hI_case'
          obtain ⟨S_indices, hS_sub, hS_card⟩ := Finset.exists_subset_card_eq hgood_card
          let S := S_indices.image gc.a
          use S
          constructor
          · rw [Finset.card_image_of_injOn]
            · exact hS_card
            · intro i₁ hi₁ i₂ hi₂ heq
              have hi₁' := hS_sub hi₁
              have hi₂' := hS_sub hi₂
              simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi₁' hi₂'
              have hi₁_ge_1 : i₁ ≥ 1 := hi₁'.1.1
              have hi₂_ge_1 : i₂ ≥ 1 := hi₂'.1.1
              by_contra hne
              rcases Nat.lt_trichotomy i₁ i₂ with hlt | heq' | hgt
              · have := gc.a_strict_mono_ge i₁ i₂ hi₁_ge_1 hi₂_ge_1 hlt; omega
              · exact hne heq'
              · have := gc.a_strict_mono_ge i₂ i₁ hi₂_ge_1 hi₁_ge_1 hgt; omega
          constructor
          · intro x hx
            simp only [S, Finset.mem_image] at hx
            obtain ⟨i, hi_mem, rfl⟩ := hx
            have hi' := hS_sub hi_mem
            simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi'
            have ⟨⟨hi_lo, _⟩, ha_i_B'⟩ := hi'
            exact ⟨ha_i_B', gc.a_in_B i hi_lo⟩
          · intro x hx
            simp only [S, Finset.mem_image] at hx
            obtain ⟨i, hi_mem, rfl⟩ := hx
            have hi' := hS_sub hi_mem
            simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices] at hi'
            use i
            exact ⟨hi'.1.1, hi'.1.2, rfl⟩
        · -- There are ≥ m₁ elements of C' in {a_1, ..., a_{H_{m₁}}}
          exfalso
          let goodIndices' := Finset.filter (fun i => gc.a i ∈ C') (Finset.Icc 1 (gc.H m₁))
          have hgood_card' : goodIndices'.card ≥ m₁ := hJ_case'
          obtain ⟨S_indices', hS_sub', hS_card'⟩ := Finset.exists_subset_card_eq hgood_card'
          let S' := S_indices'.image gc.a
          have hS'_card : S'.card = m₁ := by
            rw [Finset.card_image_of_injOn]
            · exact hS_card'
            · intro i₁ hi₁ i₂ hi₂ heq
              have hi₁' := hS_sub' hi₁
              have hi₂' := hS_sub' hi₂
              simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices'] at hi₁' hi₂'
              have hi₁_ge_1 : i₁ ≥ 1 := hi₁'.1.1
              have hi₂_ge_1 : i₂ ≥ 1 := hi₂'.1.1
              by_contra hne
              rcases Nat.lt_trichotomy i₁ i₂ with hlt | heq' | hgt
              · have := gc.a_strict_mono_ge i₁ i₂ hi₁_ge_1 hi₂_ge_1 hlt; omega
              · exact hne heq'
              · have := gc.a_strict_mono_ge i₂ i₁ hi₂_ge_1 hi₁_ge_1 hgt; omega
          have hS'_in_C' : ∀ x ∈ S', x ∈ C' ∧ gc.seq.inB x := by
            intro x hx
            simp only [S', Finset.mem_image] at hx
            obtain ⟨i, hi_mem, rfl⟩ := hx
            have hi' := hS_sub' hi_mem
            simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices'] at hi'
            have ⟨⟨hi_lo, _⟩, ha_i_C'⟩ := hi'
            exact ⟨ha_i_C', gc.a_in_B i hi_lo⟩
          have hS'_in_enum : ∀ x ∈ S', ∃ i, 1 ≤ i ∧ i ≤ gc.H m₁ ∧ gc.a i = x := by
            intro x hx
            simp only [S', Finset.mem_image] at hx
            obtain ⟨i, hi_mem, rfl⟩ := hx
            have hi' := hS_sub' hi_mem
            simp only [Finset.mem_filter, Finset.mem_Icc, goodIndices'] at hi'
            use i
            exact ⟨hi'.1.1, hi'.1.2, rfl⟩
          obtain ⟨k, hstage_k, hF_k⟩ := gc.exhaustive m₁ hm₁_ge_1 S' hS'_in_enum hS'_card
          have hNk_large' : gc.seq.N k ≥ N₀' := hm₀'_large m₁ hm₁_ge_m₀' k hstage_k
          have hB'_rep_Nk : ∃ a ∈ B', ∃ b ∈ B', a + b = gc.seq.N k := hN₀' (gc.seq.N k) hNk_large'
          have hk_ge_1 : k ≥ 1 := by
            by_contra h; push_neg at h; interval_cases k
            rw [gc.stage_zero] at hstage_k; omega
          have hk_ge_m₁ : k ≥ m₁ := by
            have := gc.stage_le_k k hk_ge_1
            rw [hstage_k] at this; exact this
          have hm₁_ge_2 : m₁ ≥ 2 := by
            have : m₁ ≥ m₀ := le_max_left m₀ m₀'
            omega
          have hk_ge_2 : k ≥ 2 := by omega
          have hF_k_in_C' : ∀ x ∈ gc.F k, x ∈ C' := by
            rw [hF_k]
            intro x hx
            exact (hS'_in_C' x hx).1
          have hF_k_disjoint_B' : ∀ x ∈ gc.F k, x ∉ B' := by
            intro x hx hxB'
            have hxC' := hF_k_in_C' x hx
            exact Set.disjoint_iff.mp hdisj ⟨hxB', hxC'⟩
          obtain ⟨b, hb_B', b', hb'_B', hbb'⟩ := hB'_rep_Nk
          have hb_A : gc.inA b := (hpart b).mpr (Or.inl hb_B')
          have hb'_A : gc.inA b' := (hpart b').mpr (Or.inl hb'_B')
          have hrep_form := gc.N_representations k hk_ge_2 b b' hb_A hb'_A hbb'
          rcases hrep_form with ⟨hb_Fk, _⟩ | ⟨_, hb'_Fk⟩
          · exact hF_k_disjoint_B' b hb_Fk hb_B'
          · exact hF_k_disjoint_B' b' hb'_Fk hb'_B'
  obtain ⟨m, hm_ge, S, hS_card, hS_in_B', hS_in_enum⟩ := hexists
  have hm_ge_1 : m ≥ 1 := Nat.le_trans hm₀_ge_1 hm_ge
  obtain ⟨k, hstage_k, hF_k⟩ := gc.exhaustive m hm_ge_1 S hS_in_enum hS_card
  have hNk_large : gc.seq.N k ≥ N₀ := hm₀_large m hm_ge k hstage_k
  have hC'_rep_Nk : ∃ a ∈ C', ∃ b ∈ C', a + b = gc.seq.N k := hN₀ (gc.seq.N k) hNk_large
  have hk_ge_1 : k ≥ 1 := by
    by_contra h; push_neg at h; interval_cases k
    rw [gc.stage_zero] at hstage_k; omega
  have hk_ge_m : k ≥ m := by
    have := gc.stage_le_k k hk_ge_1
    rw [hstage_k] at this; exact this
  have hm_ge_2 : m ≥ 2 := by
    have : m ≥ m₀ := hm_ge
    omega
  have hk_ge_2 : k ≥ 2 := by omega
  obtain ⟨c, hc_C', d, hd_C', hcd⟩ := hC'_rep_Nk
  have hc_A : gc.inA c := (hpart c).mpr (Or.inr hc_C')
  have hd_A : gc.inA d := (hpart d).mpr (Or.inr hd_C')
  have hrep_form := gc.N_representations k hk_ge_2 c d hc_A hd_A hcd
  have hF_k_in_B' : ∀ x ∈ gc.F k, x ∈ B' := by
    rw [hF_k]
    intro x hx
    exact (hS_in_B' x hx).1
  have hF_k_disjoint_C' : ∀ x ∈ gc.F k, x ∉ C' := by
    intro x hx hxC'
    have hxB' := hF_k_in_B' x hx
    exact Set.disjoint_iff.mp hdisj ⟨hxB', hxC'⟩
  rcases hrep_form with ⟨hc_Fk, hd_Gk⟩ | ⟨hc_Gk, hd_Fk⟩
  · -- c ∈ F_k, but c ∈ C' and F_k ∩ C' = ∅
    exact hF_k_disjoint_C' c hc_Fk hc_C'
  · -- d ∈ F_k, but d ∈ C' and F_k ∩ C' = ∅
    exact hF_k_disjoint_C' d hd_Fk hd_C'
end GrowingConstruction
/-!
## Main Theorem: Answer to Erdős Problem 871
The main theorem `erdos871_negative` is proved in `Nathanson/Construction.lean`
using a concrete GrowingConstruction (see `erdos_871`).
-/
end MainConstruction
/-
Construction of a concrete GrowingConstruction instance.
This file provides building blocks toward removing the axiom GrowingConstruction_exists.
-/
open NathansonSeq GrowingConstruction
set_option maxHeartbeats 2000000
/-!
## Step 1: Construct a concrete NathansonSeq
We use n_0 = 100, n_k = 8^k * 100.
-/
/-- The concrete sequence: n_k = 100 * 8^k -/
def concreteN (k : ℕ) : ℕ := 100 * 8^k
lemma concreteN_pos : ∀ k, 0 < concreteN k := by
  intro k
  simp only [concreteN]
  positivity
lemma concreteN_mono : ∀ k, concreteN k ≤ concreteN (k + 1) := by
  intro k
  simp only [concreteN]
  have h : 8^k ≤ 8^(k+1) := Nat.pow_le_pow_right (by norm_num) (Nat.le_succ k)
  nlinarith
lemma concreteN_growth_bound : ∀ k ≥ 1, concreteN (k - 1) ≥ 3 * k^2 + 6 * k + 1 := by
  intro k hk
  simp only [concreteN]
  have h8_bound : ∀ m, 8^m ≥ m + 1 := by
    intro m
    induction m with
    | zero => norm_num
    | succ m ih =>
      calc 8^(m+1) = 8 * 8^m := by ring
        _ ≥ 8 * (m + 1) := Nat.mul_le_mul_left 8 ih
        _ ≥ m + 2 := by omega
  have hk_bound : 8^(k - 1) ≥ k := by
    have h := h8_bound (k - 1)
    have hkm1 : k - 1 + 1 = k := Nat.sub_add_cancel hk
    omega
  by_cases hk5 : k ≤ 5
  · -- Small cases: verify directly by case enumeration
    interval_cases k <;> decide
  · -- Large cases: use that 8^5 = 32768 and polynomial is small
    push_neg at hk5
    have h8_large : 8^(k - 1) ≥ 8^5 := Nat.pow_le_pow_right (by norm_num) (by omega : 5 ≤ k - 1)
    have h8_5 : (8:ℕ)^5 = 32768 := by decide
    have hlarge : 100 * 8^(k - 1) ≥ 100 * 32768 := by omega
    by_cases hk100 : k ≤ 100
    · -- For k ≤ 100: 3k² + 6k + 1 ≤ 3*10000 + 600 + 1 = 30601 < 3276800
      have hpoly : 3 * k^2 + 6 * k + 1 ≤ 30601 := by nlinarith
      have hconst : (100:ℕ) * 32768 = 3276800 := by norm_num
      omega
    · -- For k > 100: use inductive bound that 8^m ≥ m² for m ≥ 1
      push_neg at hk100
      have h8_sq : ∀ m ≥ 1, 8^m ≥ m^2 := by
        intro m hm
        induction m with
        | zero => omega
        | succ n ih =>
          by_cases hn : n = 0
          · simp [hn]
          · have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn
            have ih' := ih hn_pos
            calc 8^(n+1) = 8 * 8^n := by ring
              _ ≥ 8 * n^2 := Nat.mul_le_mul_left 8 ih'
              _ ≥ (n + 1)^2 := by nlinarith [sq_nonneg n]
      have hk_sq : 8^(k - 1) ≥ (k - 1)^2 := by
        apply h8_sq
        omega
      have hkm1 : k - 1 ≥ 100 := by omega
      have hkm1_vs_k : 2 * (k - 1) ≥ k := by omega
      have hkm1_sq_vs_k : 4 * (k - 1)^2 ≥ k^2 := by nlinarith [sq_nonneg k, sq_nonneg (k - 1)]
      have h25 : 100 * (k - 1)^2 ≥ 25 * k^2 := by nlinarith
      have hpoly : 25 * k^2 ≥ 3 * k^2 + 6 * k + 1 := by nlinarith [sq_nonneg k]
      calc 100 * 8^(k - 1) ≥ 100 * (k - 1)^2 := Nat.mul_le_mul_left 100 hk_sq
        _ ≥ 25 * k^2 := h25
        _ ≥ 3 * k^2 + 6 * k + 1 := hpoly
lemma concreteN_exponential_growth : ∀ k ≥ 1, concreteN k ≥ 8 * concreteN (k - 1) := by
  intro k hk
  simp only [concreteN]
  have h : 8^k = 8 * 8^(k - 1) := by
    conv_lhs => rw [← Nat.sub_add_cancel hk]
    ring
  linarith [Nat.one_le_pow (k - 1) 8 (by norm_num)]
/-- The concrete Nathanson sequence -/
def concreteSeq : NathansonSeq where
  n := concreteN
  n_pos := concreteN_pos
  n_mono := concreteN_mono
  growth_bound := concreteN_growth_bound
  exponential_growth := concreteN_exponential_growth
/-!
## Step 2: Simple horizon function
We use H_m = 2m for all m ≥ 1.
-/
/-- Simple horizon function: H_m = 2m -/
def simpleH (m : ℕ) : ℕ := 2 * m
lemma simpleH_mono : ∀ m, simpleH m ≤ simpleH (m + 1) := by
  intro m
  simp only [simpleH]
  omega
lemma simpleH_unbounded : ∀ M, ∃ m, simpleH m > M := by
  intro M
  use M + 1
  simp only [simpleH]
  omega
lemma simpleH_linear : ∀ m ≥ 1, simpleH m ≥ 2 * m := fun _ _ => le_refl _
/-!
## Step 3: Enumerate B in increasing order
B is infinite (proven as NathansonSeq.B_infinite), so we can enumerate it as a_1 < a_2 < ...
We use Nat.find to define a_i inductively as the smallest element of B greater than a_{i-1}.
-/
/-- Predicate: x is in B for the concrete sequence -/
def inB_concrete (x : ℕ) : Prop := concreteSeq.inB x
/-- There exist elements of B greater than any bound -/
lemma B_unbounded_concrete : ∀ M, ∃ x > M, inB_concrete x := concreteSeq.B_unbounded
/-- Given a bound, there exists a smallest element of B above the bound -/
lemma B_has_next (M : ℕ) : ∃ x, x > M ∧ inB_concrete x := by
  obtain ⟨x, hx_gt, hx_in⟩ := B_unbounded_concrete M
  exact ⟨x, hx_gt, hx_in⟩
/-- The predicate "x > M and x ∈ B" is decidable for any given x (classically) -/
noncomputable instance (M x : ℕ) : Decidable (x > M ∧ inB_concrete x) := Classical.propDecidable _
/-- Next element of B after M: the smallest x > M with x ∈ B -/
noncomputable def nextInB (M : ℕ) : ℕ :=
  Nat.find (B_has_next M)
lemma nextInB_gt (M : ℕ) : nextInB M > M := (Nat.find_spec (B_has_next M)).1
lemma nextInB_in_B (M : ℕ) : inB_concrete (nextInB M) := (Nat.find_spec (B_has_next M)).2
lemma nextInB_minimal (M x : ℕ) (hx_gt : x > M) (hx_in : inB_concrete x) : nextInB M ≤ x :=
  Nat.find_min' (B_has_next M) ⟨hx_gt, hx_in⟩
/-- Enumeration of B: a(0) = 0 (placeholder), a(i+1) = smallest element of B > a(i) -/
noncomputable def enumerateB : ℕ → ℕ
  | 0 => 0  -- placeholder, not used
  | n + 1 => nextInB (enumerateB n)
lemma enumerateB_zero : enumerateB 0 = 0 := rfl
lemma enumerateB_succ (n : ℕ) : enumerateB (n + 1) = nextInB (enumerateB n) := rfl
lemma enumerateB_mono (n : ℕ) : enumerateB n < enumerateB (n + 1) := by
  rw [enumerateB_succ]
  exact nextInB_gt (enumerateB n)
lemma enumerateB_in_B (n : ℕ) (hn : n ≥ 1) : inB_concrete (enumerateB n) := by
  cases n with
  | zero => omega
  | succ n => exact nextInB_in_B (enumerateB n)
/-- Enumeration covers B: every element of B is enumerated -/
lemma enumerateB_covers (x : ℕ) (hx : inB_concrete x) : ∃ n ≥ 1, enumerateB n = x := by
  by_contra h
  push_neg at h
  have hmono : ∀ n, enumerateB n < enumerateB (n + 1) := enumerateB_mono
  have hinj : Function.Injective enumerateB := by
    intro m n heq
    rcases lt_trichotomy m n with hlt | rfl | hgt
    · -- Use strictMono_nat_of_lt_succ to get strict monotonicity
      have hstrictMono : StrictMono enumerateB := strictMono_nat_of_lt_succ hmono
      have h' : enumerateB m < enumerateB n := hstrictMono hlt
      omega
    · rfl
    · have hstrictMono : StrictMono enumerateB := strictMono_nat_of_lt_succ hmono
      have h' : enumerateB n < enumerateB m := hstrictMono hgt
      omega
  have hunbounded : ∃ n, enumerateB n > x := by
    have hge : ∀ n, enumerateB n ≥ n := by
      intro n
      induction n with
      | zero => simp
      | succ n ih =>
        have h := hmono n
        omega
    use x + 1
    have h := hge (x + 1)
    omega
  let k := Nat.find hunbounded
  have hk_spec : enumerateB k > x := Nat.find_spec hunbounded
  have hk_min : ∀ n < k, ¬(enumerateB n > x) := fun n hn => Nat.find_min hunbounded hn
  have hk_le : ∀ n < k, enumerateB n ≤ x := fun n hn => Nat.not_lt.mp (hk_min n hn)
  have hk_ge_1 : k ≥ 1 := by
    by_contra hk0
    push_neg at hk0
    have hk_eq_0 : k = 0 := by omega
    rw [hk_eq_0] at hk_spec
    simp [enumerateB] at hk_spec
  have hkm1_le : enumerateB (k - 1) ≤ x := by
    have hkm1_lt : k - 1 < k := Nat.sub_lt hk_ge_1 Nat.one_pos
    exact hk_le (k - 1) hkm1_lt
  have hk_eq : enumerateB k = nextInB (enumerateB (k - 1)) := by
    conv_lhs => rw [← Nat.sub_add_cancel hk_ge_1]
    rfl
  have hx_gt : x > enumerateB (k - 1) := by
    by_contra hle
    push_neg at hle
    have heq : x = enumerateB (k - 1) := Nat.le_antisymm hle hkm1_le
    by_cases hkm1_ge : k - 1 ≥ 1
    · exact h (k - 1) hkm1_ge heq.symm
    · -- k - 1 = 0, so k = 1, and enumerateB 0 = 0 = x
      have hkm1_eq_0 : k - 1 = 0 := by omega
      have hk_eq_1 : k = 1 := by omega
      rw [hkm1_eq_0] at heq
      simp [enumerateB] at heq
      rw [heq] at hx
      simp only [inB_concrete, NathansonSeq.inB] at hx
      obtain ⟨k', hk'_ge, hx_in⟩ := hx
      simp only [NathansonSeq.B_k, Finset.mem_union] at hx_in
      rcases hx_in with (hP | hQ) | hR
      · -- 0 ∈ P_k'
        simp only [NathansonSeq.P] at hP
        split_ifs at hP with hk'0
        · exact Finset.notMem_empty 0 hP
        · simp only [Finset.mem_Icc] at hP
          have hN_pos : concreteSeq.N (k' - 1) ≥ 1 := by
            simp only [NathansonSeq.N, concreteSeq, concreteN]
            omega
          omega
      · -- 0 ∈ Q_k'
        simp only [NathansonSeq.Q] at hQ
        split_ifs at hQ with hk'0
        · exact Finset.notMem_empty 0 hQ
        · simp only [Finset.mem_image, Finset.mem_Icc] at hQ
          obtain ⟨u, ⟨hu_lo, hu_hi⟩, heq'⟩ := hQ
          have hexp := concreteSeq.exponential_growth k' hk'_ge
          have hgrowth := concreteSeq.growth_bound k' hk'_ge
          have hn_pos := concreteSeq.n_pos (k' - 1)
          have hn_pos' := concreteSeq.n_pos k'
          omega
      · -- 0 ∈ R_k'
        simp only [NathansonSeq.R] at hR
        split_ifs at hR with hk'0
        · exact Finset.notMem_empty 0 hR
        · simp only [Finset.mem_sdiff, Finset.mem_Icc] at hR
          have hn_pos := concreteSeq.n_pos k'
          omega
  have hmin : nextInB (enumerateB (k - 1)) ≤ x := nextInB_minimal _ x hx_gt hx
  rw [← hk_eq] at hmin
  omega
/-!
## Step 4: Stage assignment and gadget sets
For each m ≥ 1, we enumerate all m-subsets of {a_1, ..., a_{H_m}}.
Stage m processes C(H_m, m) values of k.
K_m = sum_{j=1}^{m-1} C(H_j, j) is the cumulative count before stage m.
For K_{m-1} < k ≤ K_m, stage(k) = m and F_k is the (k - K_{m-1})-th m-subset.
-/
/-- Cumulative count before stage m: K_m = sum_{j=1}^{m-1} C(H_j, j) -/
def K (m : ℕ) : ℕ := cumulativeCount simpleH m
lemma K_zero : K 0 = 0 := rfl
lemma K_one : K 1 = 0 := rfl
lemma K_succ (m : ℕ) (hm : m ≥ 1) : K (m + 1) = K m + Nat.choose (simpleH m) m := by
  cases m with
  | zero => omega
  | succ n =>
    simp only [K]
    rfl
/-- K grows monotonically -/
lemma K_mono (m : ℕ) : K m ≤ K (m + 1) := by
  cases m with
  | zero => simp [K, cumulativeCount]
  | succ n =>
    simp only [K, cumulativeCount]
    omega
/-- K is monotone with respect to ≤ -/
lemma K_mono_le {a b : ℕ} (hab : a ≤ b) : K a ≤ K b := by
  induction hab with
  | refl => rfl
  | @step n _ ih => exact le_trans ih (K_mono n)
/-- Stage assignment: find the unique m with K_m < k ≤ K_{m+1} -/
noncomputable def stageAssign (k : ℕ) : ℕ :=
  if hk : k = 0 then 0
  else Nat.find (exists_stage k (Nat.one_le_iff_ne_zero.mpr hk))
where
  /-- There exists a stage containing k, for k ≥ 1 -/
  exists_stage (k : ℕ) (hk_pos : k ≥ 1) : ∃ m, K m < k ∧ k ≤ K (m + 1) := by
    have hK_grows : ∀ m, K m ≤ K (m + 1) := K_mono
    have hK_strict : ∀ m ≥ 1, K (m + 1) ≥ K m + 2 := by
      intro m hm
      rw [K_succ _ hm]
      simp only [simpleH]
      have hchoose : Nat.choose (2 * m) m ≥ 2 := by
        cases m with
        | zero => omega
        | succ m =>
          have h : Nat.choose (2 * (m + 1)) (m + 1) ≥ 2 := by
            calc Nat.choose (2 * (m + 1)) (m + 1)
              = Nat.choose (2 * m + 2) (m + 1) := by ring_nf
              _ ≥ 2 := by
                cases m with
                | zero => decide
                | succ m' =>
                  have h_central : Nat.choose (2 * (m' + 1) + 2) (m' + 1 + 1)
                      = Nat.choose (2 * (m' + 2)) (m' + 2) := by ring_nf
                  rw [h_central]
                  have hpos : m' + 2 > 0 := by omega
                  exact Nat.two_le_centralBinom (m' + 2) hpos
          exact h
      omega
    have hK_unbounded : ∀ M, ∃ m, K m > M := by
      intro M
      use M + 2
      have h : K (M + 2) ≥ 2 * (M + 1) := by
        induction M with
        | zero =>
          simp only [K, cumulativeCount, simpleH]
          decide
        | succ M ih =>
          have hstrict := hK_strict (M + 2) (by omega)
          calc K (M + 2 + 1) ≥ K (M + 2) + 2 := hstrict
            _ ≥ 2 * (M + 1) + 2 := by omega
            _ = 2 * (M + 2) := by ring
      omega
    have hexists : ∃ m, K (m + 1) ≥ k := by
      obtain ⟨m, hm⟩ := hK_unbounded k
      by_cases hm0 : m = 0
      · rw [hm0, K_zero] at hm; omega
      · have hm_ge : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm0
        use m - 1
        calc K ((m - 1) + 1) = K m := by rw [Nat.sub_add_cancel hm_ge]
          _ ≥ k + 1 := hm
          _ ≥ k := by omega
    let m := Nat.find hexists
    have hm_spec : K (m + 1) ≥ k := Nat.find_spec hexists
    use m
    constructor
    · by_contra hle
      push_neg at hle
      by_cases hm0 : m = 0
      · have hK1_eq : K 1 = 0 := K_one
        rw [hm0] at hm_spec
        rw [hK1_eq] at hm_spec
        omega
      · have hm_ge_1 : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm0
        have hprev : K ((m - 1) + 1) ≥ k := by
          simp only [Nat.sub_add_cancel hm_ge_1]
          exact hle
        have hmin := Nat.find_min hexists (Nat.sub_lt hm_ge_1 Nat.one_pos)
        exact hmin hprev
    · exact hm_spec
lemma stageAssign_zero : stageAssign 0 = 0 := by simp [stageAssign]
/-- For k ≥ 1, the stage is at least 1 -/
lemma stageAssign_pos (k : ℕ) (hk : k ≥ 1) : stageAssign k ≥ 1 := by
  simp only [stageAssign, dif_neg (Nat.one_le_iff_ne_zero.mp hk)]
  have h := Nat.find_spec (stageAssign.exists_stage k hk)
  by_contra hlt
  push_neg at hlt
  have hm_eq_0 : Nat.find (stageAssign.exists_stage k hk) = 0 := by omega
  rw [hm_eq_0] at h
  have hK0 : K 0 = 0 := K_zero
  have hK1 : K 1 = 0 := K_one
  rw [hK0, hK1] at h
  omega
/-- The stage of k is unbounded: for any M, there exists k₀ such that for all k ≥ k₀, stage k > M -/
lemma stageAssign_unbounded : ∀ M, ∃ k₀, ∀ k ≥ k₀, stageAssign k > M := by
  intro M
  use K (M + 1) + 1
  intro k hk
  simp only [stageAssign]
  split_ifs with hk0
  · omega
  · -- stageAssign k = Nat.find (exists_stage k)
    have hk_pos : k ≥ 1 := Nat.one_le_iff_ne_zero.mpr hk0
    have h := Nat.find_spec (stageAssign.exists_stage k hk_pos)
    let m := Nat.find (stageAssign.exists_stage k hk_pos)
    by_contra hle
    push_neg at hle
    have hKM : K (M + 1) < k := by omega
    have hKm1 : k ≤ K (m + 1) := h.2
    have hmono : ∀ a b, a ≤ b → K a ≤ K b := by
      intro a b hab
      induction b with
      | zero => simp [Nat.le_zero.mp hab]
      | succ b ih =>
        rcases Nat.lt_succ_iff_lt_or_eq.mp (Nat.lt_succ_of_le hab) with hlt | rfl
        · calc K a ≤ K b := ih (Nat.lt_succ_iff.mp hlt)
            _ ≤ K (b + 1) := K_mono b
        · rfl
    have h' : m + 1 ≤ M + 1 := by omega
    have hKmono : K (m + 1) ≤ K (M + 1) := hmono (m + 1) (M + 1) h'
    omega
/-!
## Step 5: Subset enumeration
We enumerate all m-subsets of [1, n] in colexicographic order.
The i-th m-subset (0-indexed) is computed using the combinatorial number system.
-/
/-- The i-th m-subset of [1, n] in colexicographic order.
    Returns a Finset of natural numbers (values, not indices).
    If i ≥ C(n, m), returns an arbitrary subset. -/
noncomputable def nthSubsetOfIcc (n m i : ℕ) : Finset ℕ :=
  if hm0 : m = 0 then ∅
  else if hn0 : n = 0 then ∅
  else if hmn : m > n then ∅
  else
    let without_n := Nat.choose (n - 1) m
    if i < without_n then
      nthSubsetOfIcc (n - 1) m i
    else
      insert n (nthSubsetOfIcc (n - 1) (m - 1) (i - without_n))
termination_by (n, m)
/-- Helper: elements of nthSubsetOfIcc are bounded by n. -/
lemma nthSubsetOfIcc_le (n m i : ℕ) : ∀ x ∈ nthSubsetOfIcc n m i, x ≤ n := by
  intro x hx
  unfold nthSubsetOfIcc at hx
  dsimp only at hx  -- reduce the let binding
  split_ifs at hx with hm0 hn0 hmn hi
  · exact absurd hx (Finset.notMem_empty x)
  · exact absurd hx (Finset.notMem_empty x)
  · exact absurd hx (Finset.notMem_empty x)
  · -- i < C(n-1, m), recurse on (n-1, m)
    have hle := nthSubsetOfIcc_le (n - 1) m i x hx
    have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
    omega
  · -- i ≥ C(n-1, m), use insert n (nthSubsetOfIcc (n-1) (m-1) _)
    simp only [Finset.mem_insert] at hx
    rcases hx with rfl | hx
    · -- x = n, so x ≤ n
      rfl
    · have hle := nthSubsetOfIcc_le (n - 1) (m - 1) (i - Nat.choose (n - 1) m) x hx
      have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
      omega
termination_by (n, m)
/-- Helper: elements of nthSubsetOfIcc are at least 1 (when n ≥ 1) -/
lemma nthSubsetOfIcc_ge_one (n m i : ℕ) (hn : n ≥ 1) : ∀ x ∈ nthSubsetOfIcc n m i, x ≥ 1 := by
  intro x hx
  unfold nthSubsetOfIcc at hx
  dsimp only at hx
  split_ifs at hx with hm0 hn0 hmn hi
  · exact absurd hx (Finset.notMem_empty x)
  · omega  -- hn0 : n = 0 contradicts hn : n ≥ 1
  · exact absurd hx (Finset.notMem_empty x)
  · -- i < C(n-1, m), recurse on (n-1, m)
    by_cases hn1 : n - 1 = 0
    · -- n = 1, so n - 1 = 0, and nthSubsetOfIcc 0 m i = ∅
      simp only [hn1] at hx
      unfold nthSubsetOfIcc at hx
      simp only [↓reduceIte] at hx
      split_ifs at hx with hm0'
      all_goals exact absurd hx (Finset.notMem_empty x)
    · have hn1_ge : n - 1 ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn1
      exact nthSubsetOfIcc_ge_one (n - 1) m i hn1_ge x hx
  · -- i ≥ C(n-1, m), use insert n (nthSubsetOfIcc (n-1) (m-1) _)
    simp only [Finset.mem_insert] at hx
    rcases hx with rfl | hx
    · exact hn
    · by_cases hn1 : n - 1 = 0
      · simp only [hn1] at hx
        unfold nthSubsetOfIcc at hx
        simp only [↓reduceIte] at hx
        split_ifs at hx with hm1
        all_goals exact absurd hx (Finset.notMem_empty x)
      · have hn1_ge : n - 1 ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn1
        exact nthSubsetOfIcc_ge_one (n - 1) (m - 1) _ hn1_ge x hx
termination_by (n, m)
/-- Key: n is not in nthSubsetOfIcc (n-1) _ _ -/
lemma nthSubsetOfIcc_not_mem_n (n m i : ℕ) : n ∉ nthSubsetOfIcc (n - 1) m i := by
  by_cases hn0 : n = 0
  · subst hn0; simp [nthSubsetOfIcc]
  · intro hmem
    have hle := nthSubsetOfIcc_le (n - 1) m i n hmem
    have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
    omega
/-- Main property: nthSubsetOfIcc produces m-element subsets of [1, n] -/
lemma nthSubsetOfIcc_card (n m i : ℕ) (hi : i < Nat.choose n m) :
    (nthSubsetOfIcc n m i).card = m := by
  unfold nthSubsetOfIcc
  dsimp only  -- reduce the let binding
  split_ifs with hm0 hn0 hmn hilt
  · -- m = 0
    simp [hm0]
  · -- n = 0, m ≠ 0
    subst hn0
    by_cases hm' : m = 0
    · subst hm'; simp only [Nat.choose_zero_right, Nat.lt_one_iff] at hi; omega
    · simp only [Nat.choose_eq_zero_of_lt (Nat.pos_of_ne_zero hm'), not_lt_zero'] at hi
  · -- m > n
    simp only [Nat.choose_eq_zero_of_lt hmn, not_lt_zero'] at hi
  · -- i < C(n-1, m)
    have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
    exact nthSubsetOfIcc_card (n - 1) m i hilt
  · -- i ≥ C(n-1, m)
    push_neg at hilt
    have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
    have hm_pos : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm0
    have hchoose : Nat.choose n m = Nat.choose (n - 1) m + Nat.choose (n - 1) (m - 1) := by
      have hn' : n = (n - 1) + 1 := by omega
      have hm' : m = (m - 1) + 1 := by omega
      conv_lhs => rw [hn', hm']
      rw [Nat.choose_succ_succ']
      have hm_eq : (m - 1) + 1 = m := by omega
      rw [hm_eq, Nat.add_comm]
    have hi' : i - Nat.choose (n - 1) m < Nat.choose (n - 1) (m - 1) := by omega
    have hn_not_mem : n ∉ nthSubsetOfIcc (n - 1) (m - 1) (i - Nat.choose (n - 1) m) :=
      nthSubsetOfIcc_not_mem_n n (m - 1) (i - Nat.choose (n - 1) m)
    rw [Finset.card_insert_of_notMem hn_not_mem]
    rw [nthSubsetOfIcc_card (n - 1) (m - 1) (i - Nat.choose (n - 1) m) hi']
    omega
termination_by (n, m)
lemma nthSubsetOfIcc_subset (n m i : ℕ) (hi : i < Nat.choose n m) :
    ∀ x ∈ nthSubsetOfIcc n m i, 1 ≤ x ∧ x ≤ n := by
  intro x hx
  constructor
  · by_cases hn : n = 0
    · subst hn
      by_cases hm : m = 0
      · -- n = 0, m = 0: nthSubsetOfIcc 0 0 i = ∅ for all i, contradiction
        subst hm
        simp only [Nat.choose_zero_right, Nat.lt_one_iff] at hi
        subst hi
        unfold nthSubsetOfIcc at hx
        simp at hx
      · simp only [Nat.choose_eq_zero_of_lt (Nat.pos_of_ne_zero hm), not_lt_zero'] at hi
    · exact nthSubsetOfIcc_ge_one n m i (Nat.one_le_iff_ne_zero.mpr hn) x hx
  · exact nthSubsetOfIcc_le n m i x hx
/-- Exhaustiveness: every m-subset of [1, n] appears as some nthSubsetOfIcc -/
lemma nthSubsetOfIcc_exhaustive (n m : ℕ) (S : Finset ℕ)
    (hS_card : S.card = m) (hS_subset : ∀ x ∈ S, 1 ≤ x ∧ x ≤ n) :
    ∃ i < Nat.choose n m, nthSubsetOfIcc n m i = S := by
  by_cases hm0 : m = 0
  · -- m = 0, S = ∅
    subst hm0
    simp only [Finset.card_eq_zero] at hS_card
    subst hS_card
    use 0
    simp [Nat.choose_zero_right, nthSubsetOfIcc]
  · by_cases hn0 : n = 0
    · -- n = 0, m ≠ 0, impossible since S ⊆ [1, 0] = ∅ but |S| = m ≥ 1
      subst hn0
      have hS_empty : S = ∅ := by
        ext x
        simp only [Finset.notMem_empty, iff_false]
        intro hx
        have ⟨_, hle⟩ := hS_subset x hx
        omega
      rw [hS_empty] at hS_card
      simp at hS_card
      omega
    · by_cases hmn : m > n
      · -- m > n, impossible since S ⊆ [1, n] has at most n elements but |S| = m > n
        have hcard_bound : S.card ≤ n := by
          have hS_sub : S ⊆ Finset.Icc 1 n := by
            intro x hx
            simp only [Finset.mem_Icc]
            exact hS_subset x hx
          calc S.card ≤ (Finset.Icc 1 n).card := Finset.card_le_card hS_sub
            _ = n := by simp [Nat.card_Icc]
        omega
      · push_neg at hmn
        have hn_pos : n ≥ 1 := Nat.one_le_iff_ne_zero.mpr hn0
        have hm_pos : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm0
        by_cases hn_in : n ∈ S
        · -- n ∈ S: S = S' ∪ {n} where S' is an (m-1)-subset of [1, n-1]
          let S' := S.erase n
          have hS'_card : S'.card = m - 1 := by
            simp only [S', Finset.card_erase_of_mem hn_in, hS_card]
          have hS'_subset : ∀ x ∈ S', 1 ≤ x ∧ x ≤ n - 1 := by
            intro x hx
            simp only [S', Finset.mem_erase] at hx
            have ⟨hne, hx'⟩ := hx
            have ⟨hge, hle⟩ := hS_subset x hx'
            constructor
            · exact hge
            · omega
          have hn1 : n - 1 < n := Nat.sub_lt hn_pos Nat.one_pos
          have hm1 : m - 1 < m := Nat.sub_lt hm_pos Nat.one_pos
          obtain ⟨j, hj, heq⟩ := nthSubsetOfIcc_exhaustive (n - 1) (m - 1) S' hS'_card hS'_subset
          use Nat.choose (n - 1) m + j
          constructor
          · -- C(n-1, m) + j < C(n, m)
            have hchoose : Nat.choose n m = Nat.choose (n - 1) m + Nat.choose (n - 1) (m - 1) := by
              have hn' : n = (n - 1) + 1 := by omega
              have hm' : m = (m - 1) + 1 := by omega
              conv_lhs => rw [hn', hm']
              rw [Nat.choose_succ_succ']
              have hm_eq : (m - 1) + 1 = m := by omega
              rw [hm_eq, Nat.add_comm]
            omega
          · -- nthSubsetOfIcc n m (C(n-1,m) + j) = S
            unfold nthSubsetOfIcc
            have hge : ¬ (Nat.choose (n - 1) m + j < Nat.choose (n - 1) m) := by omega
            simp only [hm0, hn0, not_lt.mpr hmn, hge, ↓dite_false, Nat.add_sub_cancel_left]
            rw [heq]
            simp only [S']
            exact Finset.insert_erase hn_in
        · -- n ∉ S: S is an m-subset of [1, n-1]
          have hS_subset' : ∀ x ∈ S, 1 ≤ x ∧ x ≤ n - 1 := by
            intro x hx
            have ⟨hge, hle⟩ := hS_subset x hx
            constructor
            · exact hge
            · have hne : x ≠ n := fun h => hn_in (h ▸ hx)
              omega
          have hn1 : n - 1 < n := Nat.sub_lt hn_pos Nat.one_pos
          obtain ⟨j, hj, heq⟩ := nthSubsetOfIcc_exhaustive (n - 1) m S hS_card hS_subset'
          use j
          constructor
          · -- j < C(n-1, m) ≤ C(n, m)
            have hle : Nat.choose (n - 1) m ≤ Nat.choose n m := by
              conv_rhs => rw [← Nat.sub_add_cancel hn_pos]
              exact Nat.choose_le_choose m (Nat.le_succ _)
            omega
          · -- nthSubsetOfIcc n m j = S
            unfold nthSubsetOfIcc
            simp only [hm0, hn0, not_lt.mpr hmn, hj, ↓dite_false]
            exact heq
termination_by (n, m)
/-!
## Step 6: Define F_k
For k in stage m, F_k is the ((k - K_m) - 1)-th m-subset of {a_1, ..., a_{H_m}},
translated via the enumeration a.
-/
/-- Index within the current stage: how many k's before this one in the same stage -/
noncomputable def indexInStage (k : ℕ) : ℕ :=
  if k = 0 then 0
  else k - K (stageAssign k) - 1
/-- F_k: the gadget set for index k.
    For k ≥ 1, F_k is an m-subset of {a_1, ..., a_{H_m}} where m = stage(k). -/
noncomputable def F (k : ℕ) : Finset ℕ :=
  if hk : k = 0 then ∅
  else
    let m := stageAssign k
    let Hm := simpleH m
    let idx := indexInStage k
    let indices := nthSubsetOfIcc Hm m idx
    indices.image enumerateB
/-!
## Step 7: Key lemma - F_k constraint
The critical constraint F_lt_N_prev requires that all elements of F_k are < N_{k-1}.
This means: for all i ≤ H_{stage(k)}, a_i < N_{k-1}.
For this to work, we need the horizons to not grow too fast relative to N.
With H_m = 2m and N_k = 2 * 100 * 8^k + 1, this should be satisfied for large k.
-/
/-- Elements of B_1 start at N_0 + 1 = 201 -/
lemma B1_lower_bound : ∀ x, concreteSeq.inB x → x ≥ concreteSeq.N 0 + 1 := by
  intro x ⟨j, hj, hx_in⟩
  simp only [NathansonSeq.B_k, Finset.mem_union] at hx_in
  rcases hx_in with (hP | hQ) | hR
  · -- x ∈ P_j
    simp only [NathansonSeq.P] at hP
    split_ifs at hP with hj0
    · omega
    · simp only [Finset.mem_Icc] at hP
      have hN_mono : concreteSeq.N 0 ≤ concreteSeq.N (j - 1) := concreteSeq.N_mono_le (by omega)
      omega
  · -- x ∈ Q_j
    simp only [NathansonSeq.Q] at hQ
    split_ifs at hQ with hj0
    · omega
    · simp only [Finset.mem_image, Finset.mem_Icc] at hQ
      obtain ⟨u, ⟨hu_lo, hu_hi⟩, heq⟩ := hQ
      have hexp := concreteSeq.exponential_growth j hj
      have hn_pos := concreteSeq.n_pos (j - 1)
      have hn_pos' := concreteSeq.n_pos j
      have hN0 : concreteSeq.N 0 = 2 * 100 + 1 := by
        simp only [NathansonSeq.N, concreteSeq, concreteN]
        ring
      have hn_eq : concreteSeq.n = concreteN := rfl
      simp only [hn_eq] at heq
      by_cases hj1 : j = 1
      · subst hj1
        simp only [concreteSeq, concreteN] at hexp hn_pos hn_pos' heq
        simp only [NathansonSeq.N, concreteSeq, concreteN] at hN0 ⊢
        simp only [pow_one, pow_zero] at heq
        omega
      · -- j ≥ 2
        have hj_ge_2 : j ≥ 2 := by omega
        have hgrowth := concreteSeq.growth_bound j hj
        simp only [concreteSeq, concreteN] at hexp hn_pos hn_pos' hgrowth heq
        simp only [NathansonSeq.N, concreteSeq, concreteN] at hN0 ⊢
        have hn_jm1_bound : 100 * 8^(j - 1) ≥ 800 := by
          have h : (8 : ℕ)^(j - 1) ≥ 8^1 := Nat.pow_le_pow_right (by norm_num : 1 ≤ 8) (by omega : 1 ≤ j - 1)
          simp only [pow_one] at h
          nlinarith
        have hn_j_eq : 100 * 8^j = 8 * (100 * 8^(j - 1)) := by
          have hj_pos : j ≥ 1 := by omega
          have hpow : 8^j = 8 * 8^(j - 1) := by
            conv_lhs => rw [← Nat.sub_add_cancel hj_pos]
            ring
          nlinarith
        have hdiff : 100 * 8^j - 100 * 8^(j - 1) = 7 * (100 * 8^(j - 1)) := by omega
        have hkey : 100 * 8^j - 100 * 8^(j - 1) ≥ 5600 := by
          rw [hdiff]
          nlinarith
        have hu_bound : 3 * j * u ≤ 3 * j * (j + 1) := by nlinarith
        by_cases hj2 : j = 2
        · -- j = 2 case: direct computation
          subst hj2
          have h82 : (8 : ℕ)^2 = 64 := by decide
          have h81 : (8 : ℕ)^1 = 8 := by decide
          have h80 : (8 : ℕ)^0 = 1 := by decide
          simp only [concreteN, h82, h81, h80] at heq hu_lo hu_hi
          omega
        · -- j ≥ 3 case
          have hj_ge_3 : j ≥ 3 := by omega
          by_cases hj_bound : j ≤ 120
          · -- For j ∈ [3, 120], 700*64 = 44800 > 3*120*121 = 43560
            have h8pow : (8 : ℕ)^(j - 1) ≥ 64 := by
              have : (8 : ℕ)^(j - 1) ≥ 8^2 := Nat.pow_le_pow_right (by norm_num) (by omega)
              simp only [pow_two] at this; exact this
            have hdiff_large : 100 * 8^j - 100 * 8^(j - 1) ≥ 44800 := by rw [hdiff]; nlinarith
            have hpoly_bound : 3 * j * (j + 1) ≤ 43560 := by nlinarith
            omega
          · -- For j > 120, use 8^{j-1} ≥ 8^120 which is astronomically large
            have h8_dom : ∀ n ≥ 3, 700 * (8 : ℕ)^n > 3 * (n + 1) * (n + 2) + 201 := by
              intro n hn
              induction n with
              | zero => omega
              | succ m ih =>
                by_cases hm2 : m ≤ 2
                · interval_cases m <;> decide
                · have hm3 : m ≥ 3 := by omega
                  have ih' := ih hm3
                  have hgrow_lhs : 700 * (8 : ℕ)^(m + 1) = 8 * (700 * 8^m) := by ring
                  have hgrow_rhs : 3 * (m + 2) * (m + 3) + 201 = 3 * (m + 1) * (m + 2) + 201 + 6 * (m + 2) := by ring
                  calc 700 * (8 : ℕ)^(m + 1) = 8 * (700 * 8^m) := hgrow_lhs
                    _ > 8 * (3 * (m + 1) * (m + 2) + 201) := by nlinarith
                    _ = 8 * (3 * (m + 1) * (m + 2)) + 8 * 201 := by ring
                    _ > 3 * (m + 2) * (m + 3) + 201 := by nlinarith
            have hdom := h8_dom (j - 1) (by omega : j - 1 ≥ 3)
            have heq_idx : j - 1 + 1 = j := by omega
            have heq_idx2 : j - 1 + 2 = j + 1 := by omega
            simp only [heq_idx, heq_idx2] at hdom
            have hdiff_eq : 100 * 8^j - 100 * 8^(j - 1) = 7 * 100 * 8^(j - 1) := by
              rw [hdiff]; ring
            omega
  · -- x ∈ R_j
    simp only [NathansonSeq.R] at hR
    split_ifs at hR with hj0
    · omega
    · simp only [Finset.mem_sdiff, Finset.mem_Icc] at hR
      have hn_pos := concreteSeq.n_pos j
      have hN0 : concreteSeq.N 0 = 201 := by simp [NathansonSeq.N, concreteSeq, concreteN]
      simp only [NathansonSeq.N, concreteSeq, concreteN] at hn_pos hN0 ⊢
      have hR_lb : x ≥ concreteN j + 1 := hR.1.1
      have hn1 : concreteN 1 = 800 := by simp [concreteN]
      have hn1_le : concreteN 1 ≤ concreteN j := by
        have hmono : Monotone concreteN := monotone_nat_of_le_succ concreteN_mono
        exact hmono hj
      omega
/-- a_1 is the smallest element of B, hence a_1 ≥ N_0 + 1 = 201 -/
lemma enumerateB_1_lower_bound : enumerateB 1 ≥ concreteSeq.N 0 + 1 := by
  have h := enumerateB_in_B 1 (by omega)
  exact B1_lower_bound (enumerateB 1) h
/-- a_i ≥ a_1 + (i - 1) ≥ 201 + (i - 1) for i ≥ 1 -/
lemma enumerateB_lower_bound (i : ℕ) (hi : i ≥ 1) : enumerateB i ≥ 201 + (i - 1) := by
  have h1 : enumerateB 1 ≥ 201 := by
    have hN0 : concreteSeq.N 0 = 201 := by simp [NathansonSeq.N, concreteSeq, concreteN]
    have h := enumerateB_1_lower_bound
    omega
  have hmono : ∀ n, enumerateB n < enumerateB (n + 1) := enumerateB_mono
  have hge : enumerateB i ≥ enumerateB 1 + (i - 1) := by
    induction i with
    | zero => omega
    | succ i ih =>
      by_cases hi' : i = 0
      · subst hi'; simp
      · have hi_ge : i ≥ 1 := Nat.one_le_iff_ne_zero.mpr hi'
        have h' := ih hi_ge
        have hmono' := hmono i
        omega
  omega
/-- P_1 for the concrete sequence: integers from 202 to 599 -/
lemma P1_concrete : concreteSeq.P 1 = Finset.Icc 202 599 := by
  simp only [NathansonSeq.P, if_neg (Nat.one_ne_zero)]
  simp only [NathansonSeq.N, concreteSeq, concreteN]
  rfl
/-- P_1 has 398 elements -/
lemma P1_card : (concreteSeq.P 1).card = 398 := by
  rw [P1_concrete]
  norm_num
/-- P_k cardinality formula: |P_k| = 400 * 8^{k-1} - 2 for k ≥ 1 -/
lemma P_card_formula (k : ℕ) (hk : k ≥ 1) : (concreteSeq.P k).card = 400 * 8^(k-1) - 2 := by
  cases k with
  | zero => omega
  | succ k' =>
    simp only [NathansonSeq.P, if_neg (Nat.succ_ne_zero k')]
    simp only [NathansonSeq.N, concreteSeq, concreteN]
    simp only [Nat.add_sub_cancel]
    rw [Nat.card_Icc]
    have h1 : 100 * 8 ^ (k' + 1) = 800 * 8 ^ k' := by ring
    have h2 : 2 * (100 * 8 ^ k') + 1 = 200 * 8 ^ k' + 1 := by ring
    simp only [h1, h2]
    have h8k_pos : 8 ^ k' ≥ 1 := Nat.one_le_pow k' 8 (by omega)
    omega
/-- P_k cardinality is at least 400 * 8^{k-1} - 2 -/
lemma P_card_lower (k : ℕ) (hk : k ≥ 1) : (concreteSeq.P k).card ≥ 400 * 8^(k-1) - 2 := by
  rw [P_card_formula k hk]
/-- Central binomial coefficient C(2n,n) < 4^n for n ≥ 1 -/
lemma central_binom_lt_four_pow (n : ℕ) (hn : n ≥ 1) : Nat.choose (2 * n) n < 4^n := by
  have h4 : 4^n = 2^(2*n) := by
    have : (4 : ℕ) = 2^2 := by norm_num
    rw [this, ← pow_mul]
  rw [h4]
  have hsum : (Finset.range (2*n + 1)).sum (fun k => Nat.choose (2*n) k) = 2^(2*n) := by
    exact Nat.sum_range_choose (2*n)
  have hC0 : Nat.choose (2*n) 0 = 1 := Nat.choose_zero_right (2*n)
  have hC1 : Nat.choose (2*n) 1 = 2*n := Nat.choose_one_right (2*n)
  by_cases hn1 : n = 1
  · subst hn1
    decide
  · have h1_ne : 1 ≠ n := by omega
    have hsum_ge : (Finset.range (2*n + 1)).sum (fun k => Nat.choose (2*n) k)
                 ≥ Nat.choose (2*n) 0 + Nat.choose (2*n) 1 + Nat.choose (2*n) n := by
      have hsub : ({0, 1, n} : Finset ℕ) ⊆ Finset.range (2*n + 1) := by
        intro x hx
        simp only [Finset.mem_insert, Finset.mem_singleton] at hx
        simp only [Finset.mem_range]
        rcases hx with rfl | rfl | rfl <;> omega
      calc (Finset.range (2*n + 1)).sum (fun k => Nat.choose (2*n) k)
        ≥ ({0, 1, n} : Finset ℕ).sum (fun k => Nat.choose (2*n) k) := Finset.sum_le_sum_of_subset hsub
        _ = Nat.choose (2*n) 0 + Nat.choose (2*n) 1 + Nat.choose (2*n) n := by
          rw [Finset.sum_insert (by simp; omega : 0 ∉ ({1, n} : Finset ℕ))]
          rw [Finset.sum_insert (by simp; omega : 1 ∉ ({n} : Finset ℕ))]
          rw [Finset.sum_singleton]
          ring
    rw [hsum, hC0, hC1] at hsum_ge
    omega
/-- Key dominance: |P_k| > C(2k, k) for all k ≥ 1 -/
lemma P_card_dominates_central (k : ℕ) (hk : k ≥ 1) :
    (concreteSeq.P k).card > Nat.choose (2 * k) k := by
  rw [P_card_formula k hk]
  cases k with
  | zero => omega
  | succ k' =>
    simp only [Nat.add_sub_cancel]
    have h8_vs_4 : ∀ n, 400 * 8^n ≥ 4^(n+1) + 3 := by
      intro n
      induction n with
      | zero => decide
      | succ m ih =>
        calc 400 * 8^(m+1) = 8 * (400 * 8^m) := by ring
          _ ≥ 8 * (4^(m+1) + 3) := Nat.mul_le_mul_left 8 ih
          _ = 8 * 4^(m+1) + 24 := by ring
          _ = 2 * 4^(m+2) + 24 := by ring
          _ ≥ 4^(m+2) + 3 := by nlinarith [Nat.one_le_pow (m+2) 4 (by omega)]
    have hcentral_bound : Nat.choose (2 * (k' + 1)) (k' + 1) < 4^(k' + 1) := by
      exact central_binom_lt_four_pow (k' + 1) (by omega)
    have h1 := h8_vs_4 k'
    omega
/-- Sum of |P_1|...|P_m| exceeds K(m+1) for all m ≥ 1 -/
lemma P_sum_dominates_K (m : ℕ) (hm : m ≥ 1) :
    (Finset.range m).sum (fun k => (concreteSeq.P (k+1)).card) > K (m + 1) := by
  induction m with
  | zero => omega
  | succ m' ih =>
    by_cases hm' : m' = 0
    · -- Base case: m = 1
      subst hm'
      simp only [Finset.range_one, Finset.sum_singleton, Nat.zero_add]
      have hP1 : (concreteSeq.P 1).card = 398 := P1_card
      rw [hP1]
      decide
    · -- Inductive case: m' ≥ 1
      have hm'_pos : m' ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm'
      have ih' := ih hm'_pos
      simp only [Finset.range_add_one, Finset.sum_insert (Finset.notMem_range_self)]
      have hK_succ : K (m' + 2) = K (m' + 1) + Nat.choose (2 * (m' + 1)) (m' + 1) := by
        rw [K_succ (m' + 1) (by omega)]
        simp only [simpleH]
      rw [hK_succ]
      have hdom := P_card_dominates_central (m' + 1) (by omega)
      omega
/-- Every integer from 202 to 599 is in B -/
lemma range_202_599_in_B (x : ℕ) (hx : 202 ≤ x ∧ x ≤ 599) : concreteSeq.inB x := by
  use 1
  constructor
  · omega
  · simp only [NathansonSeq.B_k, Finset.mem_union]
    left; left
    rw [P1_concrete]
    simp only [Finset.mem_Icc]
    exact hx
/-- For i ≤ 398, enumerateB i = 201 + i (the first 398 B elements are consecutive from 202) -/
lemma enumerateB_early (i : ℕ) (hi : 1 ≤ i ∧ i ≤ 398) : enumerateB i = 201 + i := by
  induction i using Nat.strong_induction_on with
  | _ i ih =>
    rcases i with _ | i
    · omega  -- i = 0 contradicts hi.1
    · rcases i with _ | i
      · -- i = 1: enumerateB 1 = 202
        simp only [enumerateB, Nat.add_eq, Nat.add_zero]
        have h202_in : inB_concrete 202 := range_202_599_in_B 202 ⟨le_refl _, by omega⟩
        have h202_min : ∀ x, x > 0 → inB_concrete x → 202 ≤ x := by
          intro x _ hx_in
          exact B1_lower_bound x hx_in
        have hnext : nextInB 0 = 202 := by
          have hspec := Nat.find_spec (B_has_next 0)
          have hmin := nextInB_minimal 0 202 (by omega) h202_in
          have hge := B1_lower_bound (nextInB 0) (nextInB_in_B 0)
          have hgt := nextInB_gt 0
          have hN0 : concreteSeq.N 0 = 201 := by simp [NathansonSeq.N, concreteSeq, concreteN]
          omega
        rw [hnext]
      · -- i ≥ 2: inductive step
        have hi_lt : i + 1 < i + 1 + 1 := by omega
        have hi_bounds : 1 ≤ i + 1 ∧ i + 1 ≤ 398 := by omega
        have ih_prev := ih (i + 1) hi_lt hi_bounds
        have heq : enumerateB (i + 1 + 1) = nextInB (enumerateB (i + 1)) := rfl
        rw [heq, ih_prev]
        have hnext_val : 201 + (i + 1) + 1 = 201 + (i + 1 + 1) := by omega
        have h_in : inB_concrete (201 + (i + 1) + 1) := by
          apply range_202_599_in_B
          constructor <;> omega
        have hmin : ∀ x, x > 201 + (i + 1) → inB_concrete x → 201 + (i + 1) + 1 ≤ x := by
          intro x hx_gt hx_in
          omega
        have hnext : nextInB (201 + (i + 1)) = 201 + (i + 1) + 1 := by
          have hspec := Nat.find_spec (B_has_next (201 + (i + 1)))
          have hmin' := nextInB_minimal (201 + (i + 1)) (201 + (i + 1) + 1) (by omega) h_in
          have hgt := nextInB_gt (201 + (i + 1))
          have hge := hmin (nextInB (201 + (i + 1))) hgt (nextInB_in_B (201 + (i + 1)))
          omega
        rw [hnext, hnext_val]
/-- Upper bound on enumerateB for small i: enumerateB i ≤ 201 + i for i ≤ 398 -/
lemma enumerateB_upper_bound_small (i : ℕ) (hi : 1 ≤ i ∧ i ≤ 398) : enumerateB i ≤ 201 + i := by
  rw [enumerateB_early i hi]
/-- Central binomial coefficient lower bound: C(2m, m) ≥ 2^m for m ≥ 1 -/
lemma central_binom_ge_pow2 (m : ℕ) (hm : m ≥ 1) : Nat.choose (2 * m) m ≥ 2^m := by
  induction m with
  | zero => omega
  | succ m ih =>
    by_cases hm0 : m = 0
    · subst hm0; decide
    · have hm_ge : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm0
      have ih' := ih hm_ge
      have hkey : Nat.choose (2 * (m + 1)) (m + 1) ≥ 2 * Nat.choose (2 * m) m := by
        have hpascal : Nat.choose (2 * (m + 1)) (m + 1) =
            Nat.choose (2 * m + 1) (m + 1) + Nat.choose (2 * m + 1) m := by
          rw [show 2 * (m + 1) = (2 * m + 1) + 1 from by ring]
          rw [Nat.choose_succ_succ]
          simp only [Nat.succ_eq_add_one, add_comm]
        have h1 : Nat.choose (2 * m + 1) m ≥ Nat.choose (2 * m) m := by
          exact Nat.choose_le_choose m (by omega : 2 * m ≤ 2 * m + 1)
        have h2 : Nat.choose (2 * m + 1) (m + 1) ≥ Nat.choose (2 * m) m := by
          have hpascal2 : Nat.choose (2 * m + 1) (m + 1) =
              Nat.choose (2 * m) (m + 1) + Nat.choose (2 * m) m := by
            rw [Nat.choose_succ_succ]
            simp only [Nat.succ_eq_add_one, add_comm]
          omega
        omega
      calc Nat.choose (2 * (m + 1)) (m + 1) ≥ 2 * Nat.choose (2 * m) m := hkey
        _ ≥ 2 * 2^m := by omega
        _ = 2^(m + 1) := by ring
/-- K(m+1) ≥ 2^m for m ≥ 1 -/
lemma K_exp_lower (m : ℕ) (hm : m ≥ 1) : K (m + 1) ≥ 2^m := by
  have hK : K (m + 1) = K m + Nat.choose (simpleH m) m := K_succ m hm
  simp only [simpleH] at hK
  have hbinom := central_binom_ge_pow2 m hm
  omega
/-- Logarithmic bound: stageAssign k ≤ Nat.log 2 k + 2 for k ≥ 1 -/
lemma stageAssign_log_bound (k : ℕ) (hk : k ≥ 1) : stageAssign k ≤ Nat.log 2 k + 2 := by
  by_cases hstage_small : stageAssign k ≤ 2
  · have hlog : Nat.log 2 k ≥ 0 := Nat.zero_le _
    omega
  · push_neg at hstage_small
    have hstage_ge_3 : stageAssign k ≥ 3 := hstage_small
    have hstage_pos := stageAssign_pos k hk

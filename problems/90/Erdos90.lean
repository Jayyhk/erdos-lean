  have hpowcommJ2 :
      (вҲҖ Пғ : J2 вүғвӮҗ[в„ҡ] J2, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : J2 вүғвӮҗ[в„ҡ] J2, Пғ * П„ = П„ * Пғ) :=
    fun_zmod3_equiv_pow_three_and_comm 1 (J2 вүғвӮҗ[в„ҡ] J2) (galJ2.trans eZ3)
  rcases hpowcommJ2 with вҹЁhpowJ2, hcommJ2вҹ©
  have hpowM0 : вҲҖ П„ : M0 вүғвӮҗ[в„ҡ] M0, П„ ^ 3 = 1 := by
    intro П„
    apply hpair_injective
    refine Prod.ext ?_ ?_
    В· calc
        ПҒ1 (П„ ^ 3) = (ПҒ1 П„) ^ 3 := by rw [MonoidHom.map_pow]
        _ = 1 := hpowJ1 _
        _ = ПҒ1 1 := by simp [ПҒ1]
    В· calc
        ПҒ2 (П„ ^ 3) = (ПҒ2 П„) ^ 3 := by rw [MonoidHom.map_pow]
        _ = 1 := hpowJ2 _
        _ = ПҒ2 1 := by simp [ПҒ2]
  have hcommM0 : вҲҖ П„ П… : M0 вүғвӮҗ[в„ҡ] M0, П„ * П… = П… * П„ := by
    intro П„ П…

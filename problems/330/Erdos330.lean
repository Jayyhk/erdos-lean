    (hhi_private : hi ≤ params.serviceR - a)
    (hlo_sum : st.X + params.N + params.L < a + lo)
    (hhi_sum : a + hi < params.protectedEndpoint)
    (hlen : params.protectedEndpoint + 4 * params.Mplus ≤ 4 * (hi - lo)) :

    simpa [invFunToFun, zker, TopModuleCat.kerО№] using h
  have h_invFun :
      вҲҖ (f : BKContsHomSubmodule p G N) (x y : вҶҘN),
        bk_cycles1_cochain p G N (invFunToFun f) x y =
          (f.1) вҹЁ(x : G)вҒ»В№ * y, by

    simpa [ПҮh] using h1ToHom_continuous p G N hN ПҮ.1
  have hrcont : Continuous fun g : G => (Additive.ofMul (r g) : Additive вҶҘN) := by
    simpa [r] using (continuousQuotientSectionRemainder G N hN).continuous

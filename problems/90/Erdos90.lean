  have hSubEq :
      (K1.toSubfield вҠ” K2.toSubfield : Subfield (AlgebraicClosure в„ҡ)) =
        ((K1 вҠ” K2 : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)).toSubfield) := by
    simp [IntermediateField.sup_toSubfield]
  have hM0_subfield2 :
      IsTotallyReal вҶҘ(((K1 вҠ” K2 : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)).toSubfield) :

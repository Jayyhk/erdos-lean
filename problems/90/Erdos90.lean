  letI : IsGalois в„ҡ вҶҘJ2 := IsGalois.of_algEquiv eJ2
  have hNJ1 : Normal в„ҡ вҶҘJ1 := Normal.of_algEquiv eJ1
  have hNJ2 : Normal в„ҡ вҶҘJ2 := Normal.of_algEquiv eJ2

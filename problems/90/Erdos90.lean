  let e : B ≃ₗ[ZMod p] _root_.Erdos90.InhomogClassAPI.Cocycles p G n :=
    LinearEquiv.ofEq _ _ hker
  have hmap :
      ((_root_.Erdos90.InhomogClassAPI.Coboundaries p G n).comap B.subtype).map
        (e : B →ₗ[ZMod p] _root_.Erdos90.InhomogClassAPI.Cocycles p G n) =
      _root_.Erdos90.InhomogClassAPI.coboundariesInCocycles p G n := by
    ext x
    constructor
    · intro hx
      rcases hx with ⟨y, hy, rfl⟩
      simpa [e, _root_.Erdos90.InhomogClassAPI.coboundariesInCocycles] using hy
    · intro hx
      refine ⟨e.symm x, ?_, ?_⟩
      · simpa [e, _root_.Erdos90.InhomogClassAPI.coboundariesInCocycles] using hx
      · exact e.apply_symm_apply x
  let hrange :
      (LinearMap.range (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatToCycles)).map
        (e : B →ₗ[ZMod p] _root_.Erdos90.InhomogClassAPI.Cocycles p G n) =
      _root_.Erdos90.InhomogClassAPI.coboundariesInCocycles p G n := by

theorem cochainsMapTrivial_inhomogToHomog (p : ℕ) [Fact p.Prime]
    (G H : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H]
    (f : G →* H) (hf : Continuous f) (n : ℕ)
    (φ : _root_.Erdos90.InhomogContsCochains.Cochain p H n) :
    (((ContinuousCohomology.cochainsMapTrivial (ZMod p) f hf
        (TopModuleCat.of (ZMod p) (ZMod p))).f n).hom)
      (inhomogToHomog p H n φ) =
    inhomogToHomog p G n (inhomogCochainPullback p G H f hf n φ) := by
  have hmap :
      ∀ m (x : HomogTower p H m) (g : Fin m → G),
        towerEval p G m
            ((ContinuousCohomology.multiIndMap (ZMod p) f hf m
              (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))).hom.hom x) g =
          towerEval p H m x (fun i => f (g i)) := by
    intro m
    induction m with
    | zero =>
        intro x g
        rfl
    | succ m ih =>
        let rep :=
          (ContinuousCohomology.MultiInd.functor (ZMod p) H m).obj
            (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))
        intro x g
        have hhead :
            (towerAsC p G m
                (((ContinuousCohomology.I (ZMod p) G).map
                    (ContinuousCohomology.multiIndMap (ZMod p) f hf m
                      (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p))))).hom.hom
                  (((ContinuousCohomology.iobjMap (ZMod p) f hf rep).hom.hom x))))
                (g 0) =
              ((ContinuousCohomology.multiIndMap (ZMod p) f hf m
                  (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))).hom.hom
                ((towerAsC p H m x) (f (g 0)))) := by
          cases m <;> rfl
        have hhead' :
            (towerAsC p G m
                (((ContinuousCohomology.multiIndMap (ZMod p) f hf (m + 1)
                    (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))).hom.hom x)))
                (g 0) =
              ((ContinuousCohomology.multiIndMap (ZMod p) f hf m
                  (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))).hom.hom
                ((towerAsC p H m x) (f (g 0)))) := by
          simpa [rep, ContinuousCohomology.multiIndMap] using hhead
        rw [towerEval, towerEval, hhead']
        simpa using ih ((towerAsC p H m x) (f (g 0))) (Fin.tail g)
  apply Subtype.ext
  have towerAsC_inj :
      ∀ (m : ℕ) {x y : HomogTower p G (m + 1)},
        towerAsC p G m x = towerAsC p G m y → x = y := by
    intro m x y hh
    cases m <;> exact hh
  have rec_ext :
      ∀ (m : ℕ) (u v : HomogTower p G m),
        (∀ g : Fin m → G, towerEval p G m u g = towerEval p G m v g) → u = v := by
    intro m
    induction m with
    | zero =>
        intro u v hh
        simpa [towerEval] using hh Fin.elim0
    | succ m ih =>
        intro u v hh
        apply towerAsC_inj m
        apply DFunLike.ext
        intro b
        apply ih
        intro g
        simpa [towerEval] using hh (Fin.cons b g)
  apply rec_ext (n + 1) _ _
  intro g
  change towerEval p G (n + 1)
      ((ContinuousCohomology.multiIndMap (ZMod p) f hf (n + 1)
        (Action.trivial H (TopModuleCat.of (ZMod p) (ZMod p)))).hom.hom
        ((inhomogToHomog p H n φ).1)) g =
    towerEval p G (n + 1) ((inhomogToHomog p G n (inhomogCochainPullback p G H f hf n φ)).1) g
  rw [hmap (n + 1) ((inhomogToHomog p H n φ).1) g]
  exact (inhomogToHomog_natural p G H f hf n φ g).symm


theorem burnside_image_generates (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (Q : Type) [AddCommGroup Q] [TopologicalSpace Q] [DiscreteTopology Q]
    (φ : G →* Multiplicative Q)
    (_hφ_surj : Function.Surjective φ)
    (_hφ_cont : Continuous φ)
    (S : Finset G)
    (hS : (Subgroup.closure (S : Set G)).topologicalClosure = ⊤) :
    Subgroup.closure (φ '' (S : Set G)) = (⊤ : Subgroup (Multiplicative Q)) := by
  have htop : ((Subgroup.closure (S : Set G)).map φ).topologicalClosure =
      (⊤ : Subgroup (Multiplicative Q)) := by
    simpa using
      (DenseRange.topologicalClosure_map_subgroup _hφ_cont _hφ_surj.denseRange hS :
        ((Subgroup.closure (S : Set G)).map φ).topologicalClosure =
          (⊤ : Subgroup (Multiplicative Q)))
  rw [MonoidHom.map_closure] at htop
  have hself : (Subgroup.closure (φ '' (S : Set G))).topologicalClosure =
      Subgroup.closure (φ '' (S : Set G)) := by
    apply le_antisymm
    · exact Subgroup.topologicalClosure_minimal _ le_rfl (isClosed_discrete _)
    · exact Subgroup.le_topologicalClosure _
  simpa [hself] using htop

theorem burnside_span_top_of_group_generators (p : ℕ)
    (Q : Type) [AddCommGroup Q] [Module (ZMod p) Q]
    (T : Finset Q)
    (hT : Subgroup.closure (Multiplicative.ofAdd '' (T : Set Q)) =
      (⊤ : Subgroup (Multiplicative Q))) :
    Submodule.span (ZMod p) (T : Set Q) = ⊤ := by
  let A : AddSubgroup Q := AddSubgroup.closure (T : Set Q)
  have hA : A = ⊤ := by
    have hT' := congrArg Subgroup.toAddSubgroup' hT
    simpa [A, Subgroup.toAddSubgroup'_closure] using hT'
  let U : Submodule (ZMod p) Q := Submodule.span (ZMod p) (T : Set Q)
  have hTU : (T : Set Q) ⊆ U.toAddSubgroup := by
    intro x hx
    exact Submodule.subset_span hx
  have hAleU : A ≤ U.toAddSubgroup := by
    exact (AddSubgroup.closure_le (K := U.toAddSubgroup)).2 hTU
  have hUtop_add : U.toAddSubgroup = ⊤ := by
    apply top_unique
    rw [← hA]
    exact hAleU
  exact Submodule.toAddSubgroup_injective hUtop_add

theorem burnside_finrank_le_of_generating_finset (p : ℕ) [Fact (Nat.Prime p)]
    (Q : Type) [AddCommGroup Q] [Module (ZMod p) Q]
    (T : Finset Q)
    (hT : Subgroup.closure (Multiplicative.ofAdd '' (T : Set Q)) =
      (⊤ : Subgroup (Multiplicative Q))) :
    Module.finrank (ZMod p) Q ≤ T.card := by

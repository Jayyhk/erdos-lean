  intro hExt hОҙ z hz
  rcases hExt with вҹЁG, hGcont, hGint, hGeqвҹ©
  let U : в„қ вҶ’ в„Ӯ := fun x => (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x))
  have hU_integrable : MeasureTheory.IntegrableOn U (Set.Ioi (0 : в„қ)) := by
    simpa [U] using hGint z hz
  have hpreim : (fun x : в„қ => x + Оҙ) вҒ»В№' Set.Ioi Оҙ = Set.Ioi (0 : в„қ) := by
    ext x
    constructor
    В· intro hx
      have hx' : Оҙ < x + Оҙ := by
        simpa [Set.mem_preimage, Set.mem_Ioi] using hx
      show 0 < x
      linarith
    В· intro hx
      have hx' : 0 < x := by simpa [Set.mem_Ioi] using hx
      have : Оҙ < x + Оҙ := by simpa using add_lt_add_right hx' Оҙ
      simpa [Set.mem_preimage, Set.mem_Ioi] using this
  have hU_shift :
      (вҲ« x in Set.Ioi (0 : в„қ), U (x + Оҙ)) = вҲ« y in Set.Ioi Оҙ, U y := by
    simpa [hpreim] using
      (MeasureTheory.MeasurePreserving.setIntegral_preimage_emb
        (MeasureTheory.measurePreserving_add_right (MeasureTheory.volume : MeasureTheory.Measure в„қ) Оҙ)
        (MeasurableEquiv.addRight Оҙ).measurableEmbedding

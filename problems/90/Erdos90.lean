theorem proposition_3_2_compositum_and_F_bridge_step (k : ℕ) (r : Fin (k + 1) → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (d : Proposition32BridgeData (k + 1)
      ((∏ i, r i) ^ 2)
      ((∏ i, r i) ^ (2 * 3 ^ k)))
    (s : ℕ) (hs_prime : s.Prime) (hs_ne : ∀ i, r i ≠ s) (hs_mod3 : s % 3 = 1) :
    Nonempty (Proposition32BridgeData (k + 2)
      (((∏ i, r i) * s) ^ 2)
      (((∏ i, r i) * s) ^ (2 * 3 ^ (k + 1)))) := by
  classical
  letI : Field d.M := d.field_M
  letI : CharZero d.M := d.charZero_M
  letI : NumberField d.M := d.numberField_M
  letI : IsTotallyReal d.M := d.totallyReal_M
  letI : IsGalois ℚ d.M := d.galoisQM
  rcases cyclic_cubic_field_of_prime_mod3 s hs_prime hs_mod3 with
    ⟨L, hFieldL, hCharZeroL, hNumberFieldL, hTRL, hGQL, hAlgLCyc, hfinQL, hdiscrL, habsGalL⟩
  letI : Field L := hFieldL
  letI : CharZero L := hCharZeroL
  letI : NumberField L := hNumberFieldL
  letI : IsTotallyReal L := hTRL
  letI : IsGalois ℚ L := hGQL
  let iM : d.M →ₐ[ℚ] AlgebraicClosure ℚ := IsAlgClosed.lift
  let iL : L →ₐ[ℚ] AlgebraicClosure ℚ := IsAlgClosed.lift
  let K1 : IntermediateField ℚ (AlgebraicClosure ℚ) := iM.fieldRange
  let K2 : IntermediateField ℚ (AlgebraicClosure ℚ) := iL.fieldRange
  let eM : d.M ≃ₐ[ℚ] K1 :=
    IntermediateField.topEquiv.symm.trans
      ((IntermediateField.equivMap (⊤ : IntermediateField ℚ d.M) iM).trans
        (IntermediateField.equivOfEq (by simpa [K1] using (AlgHom.fieldRange_eq_map iM).symm)))
  let eL : L ≃ₐ[ℚ] K2 :=
    IntermediateField.topEquiv.symm.trans
      ((IntermediateField.equivMap (⊤ : IntermediateField ℚ L) iL).trans
        (IntermediateField.equivOfEq (by simpa [K2] using (AlgHom.fieldRange_eq_map iL).symm)))
  letI : FiniteDimensional ℚ K1 :=
    FiniteDimensional.of_injective eM.symm.toLinearMap eM.symm.injective
  letI : FiniteDimensional ℚ K2 :=
    FiniteDimensional.of_injective eL.symm.toLinearMap eL.symm.injective
  letI : NumberField K1 := NumberField.of_module_finite ℚ K1
  letI : NumberField K2 := NumberField.of_module_finite ℚ K2
  letI : IsTotallyReal K1 := IsTotallyReal.ofRingEquiv eM.toRingEquiv
  letI : IsTotallyReal K2 := IsTotallyReal.ofRingEquiv eL.toRingEquiv
  letI : IsGalois ℚ K1 := IsGalois.of_algEquiv eM
  letI : IsGalois ℚ K2 := IsGalois.of_algEquiv eL
  have hK1_subfield_tot : IsTotallyReal (K1.toSubfield : Subfield (AlgebraicClosure ℚ)) := by
    simpa using (show IsTotallyReal K1 from inferInstance)
  have hK2_subfield_tot : IsTotallyReal (K2.toSubfield : Subfield (AlgebraicClosure ℚ)) := by
    simpa using (show IsTotallyReal K2 from inferInstance)
  have hM0_subfield_tot :
      IsTotallyReal (K1.toSubfield ⊔ K2.toSubfield : Subfield (AlgebraicClosure ℚ)) := by
    letI : Algebra.IsAlgebraic ℚ (AlgebraicClosure ℚ) := AlgebraicClosure.isAlgebraic (k := ℚ)
    letI : IsTotallyReal (K1.toSubfield : Subfield (AlgebraicClosure ℚ)) := hK1_subfield_tot
    letI : IsTotallyReal (K2.toSubfield : Subfield (AlgebraicClosure ℚ)) := hK2_subfield_tot
    exact NumberField.isTotallyReal_sup
      (K := AlgebraicClosure ℚ) (E := K1.toSubfield) (F := K2.toSubfield)
  have hSubEq :
      (K1.toSubfield ⊔ K2.toSubfield : Subfield (AlgebraicClosure ℚ)) =
        ((K1 ⊔ K2 : IntermediateField ℚ (AlgebraicClosure ℚ)).toSubfield) := by
    simp [IntermediateField.sup_toSubfield]
  have hM0_subfield2 :
      IsTotallyReal ↥(((K1 ⊔ K2 : IntermediateField ℚ (AlgebraicClosure ℚ)).toSubfield) :
        Subfield (AlgebraicClosure ℚ)) := by
    exact cast
      (by
        simpa using
          congrArg
            (fun U : Subfield (AlgebraicClosure ℚ) => IsTotallyReal ↥U) hSubEq)
      hM0_subfield_tot
  have hN1 : Normal ℚ ↥K1 := by infer_instance
  have hN2 : Normal ℚ ↥K2 := by infer_instance
  let M0 : IntermediateField ℚ (AlgebraicClosure ℚ) := K1 ⊔ K2
  letI : FiniteDimensional ℚ M0 := by infer_instance
  letI : NumberField M0 := NumberField.of_module_finite ℚ M0
  letI : IsTotallyReal M0 := by
    simpa [M0] using hM0_subfield2
  letI : Normal ℚ ↥M0 := by
    let h' : Normal ℚ ↥(K1 ⊔ K2 : IntermediateField ℚ (AlgebraicClosure ℚ)) :=
      @IntermediateField.normal_sup ℚ (AlgebraicClosure ℚ) _ _ _ K1 K2 hN1 hN2
    simpa [M0] using h'
  letI : Algebra.IsSeparable ℚ ↥M0 := by infer_instance
  letI : IsGalois ℚ ↥M0 := {}
  let J1 : IntermediateField ℚ M0 :=
    IntermediateField.restrict (show K1 ≤ M0 by dsimp [M0]; exact le_sup_left)
  let J2 : IntermediateField ℚ M0 :=
    IntermediateField.restrict (show K2 ≤ M0 by dsimp [M0]; exact le_sup_right)
  have eJ1 : K1 ≃ₐ[ℚ] J1 :=
    IntermediateField.restrict_algEquiv (show K1 ≤ M0 by dsimp [M0]; exact le_sup_left)
  have eJ2 : K2 ≃ₐ[ℚ] J2 :=
    IntermediateField.restrict_algEquiv (show K2 ≤ M0 by dsimp [M0]; exact le_sup_right)
  letI : IsGalois ℚ ↥J1 := IsGalois.of_algEquiv eJ1
  letI : IsGalois ℚ ↥J2 := IsGalois.of_algEquiv eJ2
  have hNJ1 : Normal ℚ ↥J1 := Normal.of_algEquiv eJ1
  have hNJ2 : Normal ℚ ↥J2 := Normal.of_algEquiv eJ2
  have hJsup : J1 ⊔ J2 = ⊤ := by
    apply (IntermediateField.lift_injective M0)
    calc
      IntermediateField.lift (F := M0) (J1 ⊔ J2)
          = IntermediateField.lift (F := M0) J1 ⊔ IntermediateField.lift (F := M0) J2 := by
            simpa using (IntermediateField.lift_sup (F := ℚ) (E := AlgebraicClosure ℚ) M0 J1 J2)
      _ = K1 ⊔ K2 := by
        rw [IntermediateField.lift_restrict, IntermediateField.lift_restrict]
      _ = IntermediateField.lift (F := M0) (⊤ : IntermediateField ℚ M0) := by
        exact (IntermediateField.lift_top (F := ℚ) (E := AlgebraicClosure ℚ) M0).symm
  let ρ1 : (M0 ≃ₐ[ℚ] M0) →* (J1 ≃ₐ[ℚ] J1) :=
    @AlgEquiv.restrictNormalHom ℚ _ M0 _ _ J1 _ _ _ _ hNJ1
  let ρ2 : (M0 ≃ₐ[ℚ] M0) →* (J2 ≃ₐ[ℚ] J2) :=
    @AlgEquiv.restrictNormalHom ℚ _ M0 _ _ J2 _ _ _ _ hNJ2
  have hpair_injective :
      Function.Injective (fun τ : M0 ≃ₐ[ℚ] M0 => (ρ1 τ, ρ2 τ)) := by
    simpa [ρ1, ρ2] using
      (@restrictNormalHom_pair_injective_of_sup_eq_top ℚ M0 _ _ _ J1 J2 hNJ1 hNJ2 hJsup)
  obtain ⟨galJ1⟩ :=
    nonempty_mulEquiv_transport_autCongr ℚ d.M J1
      (Multiplicative (Fin (k + 1) → ZMod 3)) (eM.trans eJ1) d.absGalM
  obtain ⟨galJ2⟩ :=
    nonempty_mulEquiv_transport_autCongr ℚ L J2
      (Multiplicative (ZMod 3)) (eL.trans eJ2) habsGalL
  have hfinQJ1 : Module.finrank ℚ J1 = 3 ^ (k + 1) := by
    rw [← (eM.trans eJ1).toLinearEquiv.finrank_eq]
    exact d.finrankQM
  have hfinQJ2 : Module.finrank ℚ J2 = 3 := by
    rw [← (eL.trans eJ2).toLinearEquiv.finrank_eq]
    exact hfinQL
  have hdiscrJ1 : (NumberField.discr J1).natAbs = (∏ i, r i) ^ (2 * 3 ^ k) := by
    have hEq : NumberField.discr d.M = NumberField.discr J1 :=
      NumberField.discr_eq_discr_of_algEquiv (K := d.M) (L := J1) (eM.trans eJ1)
    calc
      (NumberField.discr J1).natAbs = (NumberField.discr d.M).natAbs := by
        simpa using congrArg Int.natAbs hEq.symm
      _ = (∏ i, r i) ^ (2 * 3 ^ k) := d.discrM_eq
  have hdiscrJ2 : (NumberField.discr J2).natAbs = s ^ 2 := by
    have hEq : NumberField.discr L = NumberField.discr J2 :=
      NumberField.discr_eq_discr_of_algEquiv (K := L) (L := J2) (eL.trans eJ2)
    calc
      (NumberField.discr J2).natAbs = (NumberField.discr L).natAbs := by
        simpa using congrArg Int.natAbs hEq.symm
      _ = s ^ 2 := hdiscrL
  have hcopJ_nat : Nat.Coprime (NumberField.discr J1).natAbs (NumberField.discr J2).natAbs := by
    have hcop_prod : Nat.Coprime (∏ i, r i) s := by
      rw [Nat.coprime_fintype_prod_left_iff]
      intro i
      exact (Nat.coprime_primes (_hr_prime i) hs_prime).2 (hs_ne i)
    have hpos : 0 < 2 * 3 ^ k := by positivity
    have hcop_pow_left : Nat.Coprime ((∏ i, r i) ^ (2 * 3 ^ k)) s :=
      (Nat.coprime_pow_left_iff hpos _ _).2 hcop_prod
    have hcop_pow : Nat.Coprime ((∏ i, r i) ^ (2 * 3 ^ k)) (s ^ 2) :=
      (Nat.coprime_pow_right_iff (by decide : 0 < 2) _ _).2 hcop_pow_left
    simpa [hdiscrJ1, hdiscrJ2] using hcop_pow
  have hcopJ : IsCoprime (NumberField.discr J1) (NumberField.discr J2) :=
    (Int.isCoprime_iff_nat_coprime).2 hcopJ_nat
  have hJ1lin : J1.LinearDisjoint J2 :=
    NumberField.linearDisjoint_of_isGalois_isCoprime_discr (L := M0) J1 J2 hcopJ
  have hfinSup :
      Module.finrank ℚ (J1 ⊔ J2 : IntermediateField ℚ M0) =
        Module.finrank ℚ J1 * Module.finrank ℚ J2 :=
    IntermediateField.LinearDisjoint.finrank_sup hJ1lin
  have hfinM0_mul : Module.finrank ℚ M0 = Module.finrank ℚ J1 * Module.finrank ℚ J2 := by
    calc
      Module.finrank ℚ M0 = Module.finrank ℚ (⊤ : IntermediateField ℚ M0) := by simp
      _ = Module.finrank ℚ (J1 ⊔ J2 : IntermediateField ℚ M0) := by rw [← hJsup]
      _ = Module.finrank ℚ J1 * Module.finrank ℚ J2 := hfinSup
  have hfinM0 : Module.finrank ℚ M0 = 3 ^ (k + 2) := by
    calc
      Module.finrank ℚ M0 = Module.finrank ℚ J1 * Module.finrank ℚ J2 := hfinM0_mul
      _ = 3 ^ (k + 1) * 3 := by rw [hfinQJ1, hfinQJ2]
      _ = 3 ^ (k + 2) := by
        simp [pow_succ, Nat.mul_assoc, Nat.mul_comm, Nat.mul_left_comm]
  have hpowcommJ1 :
      (∀ σ : J1 ≃ₐ[ℚ] J1, σ ^ 3 = 1) ∧
      (∀ σ τ : J1 ≃ₐ[ℚ] J1, σ * τ = τ * σ) :=
    fun_zmod3_equiv_pow_three_and_comm (k + 1) (J1 ≃ₐ[ℚ] J1) galJ1
  rcases hpowcommJ1 with ⟨hpowJ1, hcommJ1⟩
  let eZ3 : Multiplicative (ZMod 3) ≃* Multiplicative (Fin 1 → ZMod 3) :=
    ((MulEquiv.funMultiplicative (ι := Fin 1) (G := ZMod 3)).trans
      (MulEquiv.funUnique (α := Fin 1) (M := Multiplicative (ZMod 3)))).symm
  have hpowcommJ2 :
      (∀ σ : J2 ≃ₐ[ℚ] J2, σ ^ 3 = 1) ∧
      (∀ σ τ : J2 ≃ₐ[ℚ] J2, σ * τ = τ * σ) :=
    fun_zmod3_equiv_pow_three_and_comm 1 (J2 ≃ₐ[ℚ] J2) (galJ2.trans eZ3)
  rcases hpowcommJ2 with ⟨hpowJ2, hcommJ2⟩
  have hpowM0 : ∀ τ : M0 ≃ₐ[ℚ] M0, τ ^ 3 = 1 := by
    intro τ
    apply hpair_injective
    refine Prod.ext ?_ ?_
    · calc
        ρ1 (τ ^ 3) = (ρ1 τ) ^ 3 := by rw [MonoidHom.map_pow]
        _ = 1 := hpowJ1 _
        _ = ρ1 1 := by simp [ρ1]
    · calc
        ρ2 (τ ^ 3) = (ρ2 τ) ^ 3 := by rw [MonoidHom.map_pow]
        _ = 1 := hpowJ2 _
        _ = ρ2 1 := by simp [ρ2]
  have hcommM0 : ∀ τ υ : M0 ≃ₐ[ℚ] M0, τ * υ = υ * τ := by
    intro τ υ
    apply hpair_injective
    refine Prod.ext ?_ ?_
    · calc
        ρ1 (τ * υ) = ρ1 τ * ρ1 υ := by rw [MonoidHom.map_mul]
        _ = ρ1 υ * ρ1 τ := hcommJ1 _ _
        _ = ρ1 (υ * τ) := by rw [MonoidHom.map_mul]
    · calc
        ρ2 (τ * υ) = ρ2 τ * ρ2 υ := by rw [MonoidHom.map_mul]
        _ = ρ2 υ * ρ2 τ := hcommJ2 _ _
        _ = ρ2 (υ * τ) := by rw [MonoidHom.map_mul]
  have hcardM0 : Nat.card (M0 ≃ₐ[ℚ] M0) = 3 ^ (k + 2) := by
    rw [IsGalois.card_aut_eq_finrank (F := ℚ) (E := M0), hfinM0]
  have hAbsGalM0 : Nonempty ((M0 ≃ₐ[ℚ] M0) ≃* Multiplicative (Fin (k + 2) → ZMod 3)) :=
    elementary_abelian_three_mulEquiv (k + 2) (M0 ≃ₐ[ℚ] M0) hpowM0 hcommM0 hcardM0
  have hcopDiff :=
    NumberField.isCoprime_differentIdeal_of_isCoprime_discr (L := M0) hcopJ
  have hdiscrM0_mul :=
    @NumberField.natAbs_discr_eq_natAbs_discr_pow_mul_natAbs_discr_pow M0 _ _ J1 J2 hJ1lin hJsup hcopDiff
  have hdiscrM0 :
      (NumberField.discr M0).natAbs = ((∏ i, r i) * s) ^ (2 * 3 ^ (k + 1)) := by
    rw [hdiscrM0_mul]
    rw [hdiscrJ1, hdiscrJ2, hfinQJ1, hfinQJ2]
    rw [← pow_mul, ← pow_mul]
    simp [pow_succ, Nat.mul_assoc, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_pow]
  let r' : Fin (k + 2) → ℕ := Fin.snoc r s
  have hr'_prime : ∀ i, (r' i).Prime := by
    rw [Fin.forall_iff_castSucc]
    constructor
    · simpa [r', Fin.snoc_last] using hs_prime
    · intro i
      simpa [r', Fin.snoc_castSucc] using _hr_prime i
  have hr'_inj : Function.Injective r' := by
    rw [Fin.snoc_injective_iff]
    constructor
    · exact _hr_inj
    · intro hs
      rcases hs with ⟨i, hi⟩
      exact hs_ne i hi
  have hr'_mod3 : ∀ i, r' i % 3 = 1 := by
    rw [Fin.forall_iff_castSucc]
    constructor
    · simpa [r', Fin.snoc_last] using hs_mod3
    · intro i
      simpa [r', Fin.snoc_castSucc] using _hr_mod3 i
  have hprod_r' : ∏ i, r' i = (∏ i, r i) * s := by
    simp [r']
  have hdiscrM0' :
      (NumberField.discr M0).natAbs = (∏ i, r' i) ^ (2 * 3 ^ ((k + 2) - 1)) := by
    calc
      (NumberField.discr M0).natAbs = ((∏ i, r i) * s) ^ (2 * 3 ^ (k + 1)) := hdiscrM0
      _ = (∏ i, r' i) ^ (2 * 3 ^ ((k + 2) - 1)) := by
        rw [hprod_r']
        simp
  rcases diagonal_cubic_subfield_exists_with_discr (ℓ := k + 2)
      (Nat.succ_pos _) r' hr'_prime hr'_inj hr'_mod3 M0 hAbsGalM0 hfinM0 hdiscrM0' with
    ⟨F, hFieldF, hCharZeroF, hNumberFieldF, hTotRealF, hGaloisQF, hAlgFM0, hTowerFM0,
      hFiniteDimFM0, hGaloisFM0, hfinQF, hAbsGalF, hfinFM, hOddFM, hdiscrF, hpowFM,
      hcommFM⟩
  have hGaloisQM0 : IsGalois ℚ M0 := inferInstance
  exact ⟨{
    M := M0
    field_M := inferInstance
    charZero_M := inferInstance
    numberField_M := inferInstance
    totallyReal_M := inferInstance
    galoisQM := hGaloisQM0
    F := F
    field_F := hFieldF
    charZero_F := hCharZeroF
    numberField_F := hNumberFieldF
    totallyReal_F := hTotRealF
    galoisQF := hGaloisQF
    algFM := hAlgFM0
    tower := hTowerFM0
    finiteDimensional := hFiniteDimFM0
    galoisFM := hGaloisFM0
    finrankQM := hfinM0
    absGalM := hAbsGalM0
    discrM_eq := hdiscrM0
    finrankQF := hfinQF
    absGalF := hAbsGalF
    finrankFM := hfinFM
    odd_finrankFM := hOddFM
    discrF_eq := by simpa [hprod_r'] using hdiscrF
    pow_rel := hpowFM
    comm_rel := hcommFM
  }⟩

theorem proposition_3_2_compositum_and_F_bridge (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1) :
    ∃ (M : Type) (_ : Field M) (_ : CharZero M) (_ : NumberField M)
      (_ : IsTotallyReal M) (_ : IsGalois ℚ M)
      (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ M = 3 ^ ℓ ∧
      Nonempty ((M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3)) ∧
      (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1)) ∧
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      (NumberField.discr F).natAbs = (∏ i, r i) ^ 2 ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  classical
  rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt _hℓ) with ⟨n, rfl⟩
  induction n with
  | zero =>
      rcases proposition_3_2_compositum_and_F_bridge_base r _hr_prime _hr_inj _hr_mod3 with ⟨d⟩
      refine ⟨d.M, d.field_M, d.charZero_M, d.numberField_M, d.totallyReal_M, d.galoisQM,
        d.F, d.field_F, d.charZero_F, d.numberField_F, d.totallyReal_F, d.galoisQF,
        d.algFM, d.tower, d.finiteDimensional, d.galoisFM, ?_⟩
      exact ⟨d.finrankQM, d.absGalM, d.discrM_eq, d.finrankQF, d.absGalF, d.finrankFM,
        d.odd_finrankFM, d.discrF_eq, d.pow_rel, d.comm_rel⟩
  | succ k ih =>
      let r0 : Fin (k + 1) → ℕ := fun i => r (Fin.castSucc i)
      let s : ℕ := r (Fin.last (k + 1))
      have hr0_prime : ∀ i, (r0 i).Prime := by
        intro i
        exact _hr_prime (Fin.castSucc i)
      have hr0_inj : Function.Injective r0 := by
        intro i j hij
        apply Fin.castSucc_injective
        exact _hr_inj hij
      have hr0_mod3 : ∀ i, r0 i % 3 = 1 := by
        intro i
        exact _hr_mod3 (Fin.castSucc i)
      have hs_prime : s.Prime := by
        exact _hr_prime (Fin.last (k + 1))
      have hs_ne : ∀ i, r0 i ≠ s := by
        intro i
        dsimp [r0, s]
        intro h
        exact Fin.castSucc_ne_last i (_hr_inj h)
      have hs_mod3 : s % 3 = 1 := by
        exact _hr_mod3 (Fin.last (k + 1))
      rcases ih (Nat.succ_pos k) r0 hr0_prime hr0_inj hr0_mod3 with
        ⟨M, hMField, hMCharZero, hMNumberField, hMTotallyReal, hMGalois,
          F, hFField, hFCharZero, hFNumberField, hFTotallyReal, hFGalois,
          hAlg, hTower, hFiniteDim, hGaloisFM, hfinrankQM, habsGalM, hdiscrM,
          hfinrankQF, habsGalF, hfinrankFM, hodd_finrankFM, hdiscrF, hpow_rel, hcomm_rel⟩
      let d0 : Proposition32BridgeData (k + 1)
        ((∏ i, r0 i) ^ 2)
        ((∏ i, r0 i) ^ (2 * 3 ^ k)) :=
        { M := M
          field_M := hMField
          charZero_M := hMCharZero
          numberField_M := hMNumberField
          totallyReal_M := hMTotallyReal
          galoisQM := hMGalois
          F := F
          field_F := hFField
          charZero_F := hFCharZero
          numberField_F := hFNumberField
          totallyReal_F := hFTotallyReal
          galoisQF := hFGalois
          algFM := hAlg
          tower := hTower
          finiteDimensional := hFiniteDim
          galoisFM := hGaloisFM
          finrankQM := hfinrankQM
          absGalM := habsGalM
          discrM_eq := hdiscrM
          finrankQF := hfinrankQF
          absGalF := habsGalF
          finrankFM := hfinrankFM
          odd_finrankFM := hodd_finrankFM
          discrF_eq := hdiscrF
          pow_rel := hpow_rel
          comm_rel := hcomm_rel }
      rcases proposition_3_2_compositum_and_F_bridge_step k r0 hr0_prime hr0_inj hr0_mod3 d0 s hs_prime hs_ne hs_mod3 with ⟨d⟩
      have hprod : ((∏ i, r0 i) * s) = ∏ i, r i := by
        simpa [r0, s] using (Fin.prod_univ_castSucc (f := r)).symm
      refine ⟨d.M, d.field_M, d.charZero_M, d.numberField_M, d.totallyReal_M, d.galoisQM,
        d.F, d.field_F, d.charZero_F, d.numberField_F, d.totallyReal_F, d.galoisQF,
        d.algFM, d.tower, d.finiteDimensional, d.galoisFM, ?_⟩
      exact ⟨d.finrankQM, d.absGalM, by simpa [hprod] using d.discrM_eq, d.finrankQF,
        d.absGalF, d.finrankFM, d.odd_finrankFM, by simpa [hprod] using d.discrF_eq,
        d.pow_rel, d.comm_rel⟩

theorem proposition_3_2_compositum_and_F_local (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1) :
    ∃ (M : Type) (_ : Field M) (_ : CharZero M) (_ : NumberField M)

      exists_h1NormalInvariantClass_of_continuousConjInvariantHom
        p G N hN χh hχinv with
    ⟨χ, hχ⟩
  refine ⟨χ, ?_⟩
  apply quotientCocycle_class_eq_transgression_of_sectionCochain_formula p G N hN ω χ u
  intro x y
  rw [hχ]
  exact hω x y

theorem inflation_ker_le_transgression_range_H2 (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    LinearMap.ker (inflation p G N 2).hom.toLinearMap ≤
      LinearMap.range (transgression p G N hN) := by
  intro x hx
  simp only [LinearMap.mem_ker] at hx
  rcases continuousH2_exists_normalized_cocycle p G N hN x with ⟨ω, hωx, h1, h2⟩
  have hωG : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G (QPull p G N ω) := by
    intro g h k
    simpa [QPull] using ω.2 ((QuotientGroup.mk' N) g) ((QuotientGroup.mk' N) h) ((QuotientGroup.mk' N) k)
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  have hnat := cohomologyIso_natural_map_ofIsCocycle2 p G (G ⧸ N)
    (QuotientGroup.mk' N) QuotientGroup.continuous_mk ω.1 ω.2 hωG
  have hnat' :
      (inflation p G N 2).hom.toLinearMap (QClass p G N hN ω) =
        (_root_.Erdos90.InhomogHomogIso.cohomologyIso p G 2)
          (_root_.Erdos90.InhomogClassAPI.classMap p G 2
            (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (QPull p G N ω) hωG)) := by
    simpa [inflation, QClass, QPull] using hnat
  have hpullzero :
      (_root_.Erdos90.InhomogHomogIso.cohomologyIso p G 2)
        (_root_.Erdos90.InhomogClassAPI.classMap p G 2
          (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (QPull p G N ω) hωG)) = 0 := by
    rw [← hnat', hωx]
    exact hx
  have hclasszero :
      _root_.Erdos90.InhomogClassAPI.classMap p G 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (QPull p G N ω) hωG) = 0 := by
    apply (_root_.Erdos90.InhomogHomogIso.cohomologyIso p G 2).injective
    simpa using hpullzero
  have hmem :
      (((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (QPull p G N ω) hωG :
        _root_.Erdos90.InhomogClassAPI.Cocycles p G 2) :
        _root_.Erdos90.InhomogContsCochains.Cochain p G 2) ∈
        _root_.Erdos90.InhomogClassAPI.Coboundaries p G 2) := by
    exact (_root_.Erdos90.InhomogClassAPI.classMap_eq_zero_iff p G 2
      (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (QPull p G N ω) hωG)).mp hclasszero
  have hinfl : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p G (QPull p G N ω) := by
    have hmem' :
        _root_.Erdos90.InhomogClassAPI.ofProd p G (QPull p G N ω) ∈
          LinearMap.range (_root_.Erdos90.InhomogContsCochains.d p G 1) := by
      simpa [_root_.Erdos90.InhomogClassAPI.Coboundaries] using hmem
    rw [LinearMap.mem_range] at hmem'
    rcases hmem' with ⟨b, hb⟩
    let b0 : C(G, ZMod p) :=
      b.comp ⟨fun g : G => ![g], by continuity⟩
    refine ⟨b0, ?_⟩
    intro g h
    have hbh' : ((_root_.Erdos90.InhomogContsCochains.d p G 1) b) ![g, h] = (QPull p G N ω) (g, h) := by
      simpa [QPull, _root_.Erdos90.InhomogClassAPI.ofProd] using
        congrArg (fun f : _root_.Erdos90.InhomogContsCochains.Cochain p G 2 => f ![g, h]) hb
    have hc0 : Fin.contractNth (0 : Fin 2) (· * ·) ![g, h] = ![g * h] := by
      ext i
      fin_cases i
      simpa using (Fin.contractNth_apply_of_eq (j := (0 : Fin 2)) (op := (· * ·))
        (g := ![g, h]) (k := 0) rfl)
    have hc1 : Fin.contractNth (1 : Fin 2) (· * ·) ![g, h] = ![g] := by
      ext i
      fin_cases i
      simpa using (Fin.contractNth_apply_of_lt (j := (1 : Fin 2)) (op := (· * ·))
        (g := ![g, h]) (k := 0) (by decide))
    have hd_eval : ((_root_.Erdos90.InhomogContsCochains.d p G 1) b) ![g, h] =
        b0 h - b0 (g * h) + b0 g := by
      change b (fun i => ![g, h] i.succ) +
          ∑ j : Fin 2, (-1 : ZMod p) ^ ((j : ℕ) + 1) • b (Fin.contractNth j (· * ·) ![g, h]) =
        b0 h - b0 (g * h) + b0 g

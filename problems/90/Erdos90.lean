theorem lemma_2_4_integral_shift_count (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) (u : рқ’ҹ.K) (hОӣu : рқ’ҹ.ОҰ u вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V)) : вҲ« a in lemma_2_4_FD рқ’ҹ, (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ) вҲӮMeasureTheory.volume = MeasureTheory.volume.real { a : рқ’ҹ.V | a вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R } := by

      exact absurd this ( by norm_cast; linarith );
    rw [ Fintype.not_linearIndependent_iff ] at h_linear_dep;
    obtain ⟨ g, hg₁, i, hi ⟩ := h_linear_dep; specialize h_contra ( Finset.univ.filter fun j => g j = 1 ) ; simp_all +decide [ Finset.sum_filter ] ;

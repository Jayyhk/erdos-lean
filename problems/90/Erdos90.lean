theorem superquotient_map_has_continuous_section {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] (V : OpenNormalSubgroup G) :
    ∃ s : ContinuousMap (G ⧸ (N ⊔ V.toSubgroup)) (G ⧸ V.toSubgroup),
      ∀ y : G ⧸ (N ⊔ V.toSubgroup),
        QuotientGroup.map V.toSubgroup (N ⊔ V.toSubgroup) (MonoidHom.id G)
          (show V.toSubgroup ≤ N ⊔ V.toSubgroup from le_sup_right) (s y) = y := by
  classical
  let q : G ⧸ V.toSubgroup →* G ⧸ (N ⊔ V.toSubgroup) :=
    QuotientGroup.map V.toSubgroup (N ⊔ V.toSubgroup) (MonoidHom.id G)
      (show V.toSubgroup ≤ N ⊔ V.toSubgroup from le_sup_right)
  have hopen : IsOpen (((N ⊔ V.toSubgroup : Subgroup G) : Set G)) := by
    exact Subgroup.isOpen_mono (H₁ := V.toSubgroup) (H₂ := N ⊔ V.toSubgroup)
      le_sup_right V.isOpen
  letI : DiscreteTopology (G ⧸ (N ⊔ V.toSubgroup)) :=
    QuotientGroup.discreteTopology (N := N ⊔ V.toSubgroup) hopen
  have hq : Function.Surjective q := by
    intro y
    refine QuotientGroup.induction_on y ?_
    intro g
    refine ⟨QuotientGroup.mk g, ?_⟩
    rfl
  let s0 : G ⧸ (N ⊔ V.toSubgroup) → G ⧸ V.toSubgroup := Function.surjInv hq
  refine ⟨⟨s0, continuous_of_discreteTopology⟩, ?_⟩
  intro y
  exact Function.surjInv_eq hq y

theorem quotient_fiber_lift_exists {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] {V W : OpenNormalSubgroup G} (hVW : V ≤ W)
    (x : G ⧸ N) (b : G ⧸ W.toSubgroup)
    (hb : QuotientGroup.map W.toSubgroup (N ⊔ W.toSubgroup) (MonoidHom.id G)
      (show W.toSubgroup ≤ N ⊔ W.toSubgroup from le_sup_right) b =
      QuotientGroup.map N (N ⊔ W.toSubgroup) (MonoidHom.id G)
        (show N ≤ N ⊔ W.toSubgroup from le_sup_left) x) :
    ∃ a : G ⧸ V.toSubgroup,
      QuotientGroup.map V.toSubgroup W.toSubgroup (MonoidHom.id G)
          (show V.toSubgroup ≤ W.toSubgroup from hVW) a = b ∧
        QuotientGroup.map V.toSubgroup (N ⊔ V.toSubgroup) (MonoidHom.id G)
          (show V.toSubgroup ≤ N ⊔ V.toSubgroup from le_sup_right) a =
        QuotientGroup.map N (N ⊔ V.toSubgroup) (MonoidHom.id G)
          (show N ≤ N ⊔ V.toSubgroup from le_sup_left) x := by
  classical
  revert b hb
  refine Quotient.inductionOn x ?_
  intro g b hb
  revert hb
  refine Quotient.inductionOn b ?_
  intro h hb
  have h_eq : QuotientGroup.mk' (N ⊔ W.toSubgroup) h = QuotientGroup.mk' (N ⊔ W.toSubgroup) g := by
    simpa [QuotientGroup.map_mk'] using hb
  have hz : ∃ z ∈ N ⊔ W.toSubgroup, g * z = h := by
    exact (QuotientGroup.mk'_eq_mk' (N := N ⊔ W.toSubgroup)).1 h_eq.symm
  rcases hz with ⟨z, hzmem, hz_eq⟩
  rcases (Subgroup.mem_sup_of_normal_left.mp hzmem) with ⟨n, hnN, w, hwW, hnw⟩
  refine ⟨QuotientGroup.mk' V.toSubgroup (g * n), ?_⟩
  constructor
  · rw [QuotientGroup.map_mk']
    apply (QuotientGroup.mk'_eq_mk' (N := W.toSubgroup)).2
    refine ⟨w, hwW, ?_⟩
    calc
      (g * n) * w = g * (n * w) := by simp [mul_assoc]
      _ = g * z := by rw [hnw]
      _ = h := hz_eq
  · simp only [QuotientGroup.map_mk']
    apply (QuotientGroup.mk'_eq_mk' (N := N ⊔ V.toSubgroup)).2
    refine ⟨n⁻¹, ?_, ?_⟩
    · exact (show N ≤ N ⊔ V.toSubgroup from le_sup_left)
        (show n⁻¹ ∈ N from N.inv_mem hnN)
    · simp [mul_assoc]

theorem quotient_eq_of_all_open_superquotients_eq {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) {g : G} {x : G ⧸ N}
    (h : ∀ V : OpenNormalSubgroup G,
      QuotientGroup.map N (N ⊔ V.toSubgroup) (MonoidHom.id G)
        (show N ≤ N ⊔ V.toSubgroup from le_sup_left) x
      = QuotientGroup.mk' (N ⊔ V.toSubgroup) g) :
    QuotientGroup.mk' N g = x := by
  rcases QuotientGroup.mk'_surjective N x with ⟨a, rfl⟩
  have hN_eq : N = sInf {M : Subgroup G | IsOpen (M : Set G) ∧ N ≤ M} := by
    simpa using
      (ProfiniteGrp.closedSubgroup_eq_sInf_open (G := G) (⟨N, hN⟩ : ClosedSubgroup G))
  have hdiff : a⁻¹ * g ∈ N := by
    rw [hN_eq]
    rw [Subgroup.mem_sInf]
    intro M hM
    obtain ⟨V, hVsub⟩ :=
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hM.1 M.one_mem
    have hVle : V.toSubgroup ≤ M := by
      intro y hy
      exact hVsub hy
    have hNV : N ⊔ V.toSubgroup ≤ M := sup_le hM.2 hVle
    have hVeq := h V
    rw [QuotientGroup.map_mk', MonoidHom.id_apply, QuotientGroup.mk'_apply,
      QuotientGroup.eq] at hVeq
    exact hNV hVeq
  exact (QuotientGroup.eq).2 (by simpa using N.inv_mem hdiff)

theorem compatible_pointwise_lift {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] {W0 : OpenNormalSubgroup G}
    (y : G ⧸ (N ⊔ W0.toSubgroup))
    (b : ∀ U : OpenNormalSubgroup G, W0 ≤ U → G ⧸ U.toSubgroup)
    (hb_compat : ∀ {U1 U2 : OpenNormalSubgroup G}
      (h01 : W0 ≤ U1) (h02 : W0 ≤ U2) (h12 : U1 ≤ U2),
      QuotientGroup.map U1.toSubgroup U2.toSubgroup (MonoidHom.id G)
        (show U1.toSubgroup ≤ U2.toSubgroup from h12) (b U1 h01) = b U2 h02)
    (hb_fiber : ∀ U (h0U : W0 ≤ U),
      QuotientGroup.map U.toSubgroup (N ⊔ U.toSubgroup) (MonoidHom.id G)
        (show U.toSubgroup ≤ N ⊔ U.toSubgroup from le_sup_right) (b U h0U) =
      QuotientGroup.map (N ⊔ W0.toSubgroup) (N ⊔ U.toSubgroup) (MonoidHom.id G)
        (show N ⊔ W0.toSubgroup ≤ N ⊔ U.toSubgroup from
          sup_le_sup_left (show W0.toSubgroup ≤ U.toSubgroup from h0U) N) y) :
    ∃ a : G ⧸ W0.toSubgroup,
      QuotientGroup.map W0.toSubgroup (N ⊔ W0.toSubgroup) (MonoidHom.id G)
        (show W0.toSubgroup ≤ N ⊔ W0.toSubgroup from le_sup_right) a = y ∧
      ∀ U (h0U : W0 ≤ U),
        QuotientGroup.map W0.toSubgroup U.toSubgroup (MonoidHom.id G)
          (show W0.toSubgroup ≤ U.toSubgroup from h0U) a = b U h0U := by
  refine ⟨b W0 le_rfl, ?_, ?_⟩
  · simpa using hb_fiber W0 le_rfl
  · intro U h0U
    simpa using hb_compat (U1 := W0) (U2 := U) le_rfl h0U h0U

theorem open_normal_quotient_surj_hom_has_section
    {G H : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H]
    (N : Subgroup H) [N.Normal] (hN : IsOpen (N : Set H))
    (f : G →ₜ* H) (hf : Function.Surjective f) :
    ∃ s : ContinuousMap (H ⧸ N) (G ⧸ N.comap f.toMonoidHom),
      ∀ y : H ⧸ N,
        QuotientGroup.map (N.comap f.toMonoidHom) N f.toMonoidHom (le_rfl) (s y) = y := by
  classical
  letI : DiscreteTopology (H ⧸ N) := QuotientGroup.discreteTopology (N := N) hN

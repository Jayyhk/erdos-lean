    simpa [H, T, π, Finset.coe_image] using htop
  have hcomm_le : commutator G ≤ N := by
    intro x hx
    have hx' : x ∈ Subgroup.closure ((Set.range (fun g : G => g ^ p)) ∪ (commutator G : Set G)) :=
      Subgroup.subset_closure (Or.inr hx)
    have hx'' : x ∈
        (Subgroup.closure ((Set.range (fun g : G => g ^ p)) ∪ (commutator G : Set G))).topologicalClosure :=
      Subgroup.le_topologicalClosure _ hx'
    simpa [N, _root_.Erdos90.closedFrattini] using hx''
  letI : IsMulCommutative (G ⧸ N) :=
    ⟨(Subgroup.Normal.quotient_commutative_iff_commutator_le (N := N)).2 hcomm_le⟩
  letI : CommGroup (G ⧸ N) := CommGroup.ofIsMulCommutative
  have hpow_mem : ∀ g : G, g ^ p ∈ N := by
    intro g
    have hg' : g ^ p ∈ Subgroup.closure ((Set.range (fun x : G => x ^ p)) ∪ (commutator G : Set G)) :=

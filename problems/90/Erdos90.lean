  have hmeasLp : MeasurableSet Lp := by
    simpa [Lp, overlapSymmetricLensRight] using hmeasL.inter hmeas_pos
  have hmeasLm : MeasurableSet Lm := by
    simpa [Lm] using hmeasL.inter hmeas_neg

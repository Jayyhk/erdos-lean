  have hgt_two : (2 : в„Ө) < |NumberField.discr F0| := NumberField.abs_discr_gt_two (K := F0) hdeg_gt_one
  have habs_one : |NumberField.discr F0| = (1 : в„Ө) := by
    have hcast : (((NumberField.discr F0).natAbs : в„•) : в„Ө) = 1 := by
      exact_mod_cast hdiscrF0_one

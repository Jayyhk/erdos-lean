    charZero_F := hCharZeroF
    numberField_F := hNumberFieldF
    totallyReal_F := hTotRealF
    galoisQF := hGaloisQF
    algFM := hAlgFM0
    tower := hTowerFM0
    finiteDimensional := hFiniteDimFM0
    galoisFM := hGaloisFM0
    finrankQM := hfinM0
    absGalM := hAbsGalM0
    discrM_eq := hdiscrM0
    finrankQF := hfinQF
    absGalF := hAbsGalF
    finrankFM := hfinFM
    odd_finrankFM := hOddFM

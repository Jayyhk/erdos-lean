      letI : Finite (в„Ө в§ё p) := Finite.of_fintype (в„Ө в§ё p)
      letI : Finite ((рқ“һ M) в§ё Q.1) := Ideal.finiteQuotientOfFreeOfNeBot Q.1 hQne
      letI : Module.Finite (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) := Module.Finite.of_finite
      letI : PerfectField (в„Ө в§ё p) := PerfectField.ofFinite
      letI : Algebra.IsAlgebraic (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) :=

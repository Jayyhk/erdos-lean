                simpa using N.mul_mem (N.inv_mem x.2) y.2вҹ© := rfl
          _ = c вҖў bk_cycles1_cochain p G N (invFunToFun f) x y := by
                rw [h_invFun f x y]
          _ = bk_cycles1_cochain p G N (c вҖў invFunToFun f) x y := by
                unfold bk_cycles1_cochain

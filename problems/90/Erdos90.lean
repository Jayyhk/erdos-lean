  [isQuadratic_LK : Algebra.IsQuadraticExtension L K]

  [algebra_ℚK : Algebra ℚ K]
  [isScalarTower_ℚLK : IsScalarTower ℚ L K]

  i_K : K
  i_K_sq : i_K * i_K = -1
  t : ℕ
  t_pos : 0 < t
  q : Fin t → ℕ
  q_prime : ∀ b, Nat.Prime (q b)
  q_inj : Function.Injective q
  q_mod4 : ∀ b, q b % 4 = 1

  q_splits_in_L : ∀ b,
    (∀ 𝔭 ∈ (Ideal.span {(q b : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
        Ideal.ramificationIdx (Ideal.span {(q b : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q b : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
      ((Ideal.span {(q b : ℤ)} : Ideal ℤ).primesOver (𝓞 L)).ncard =
        Module.finrank ℚ L

attribute [instance] AdmissibleDatum.field_L AdmissibleDatum.charZero_L
  AdmissibleDatum.numberField_L AdmissibleDatum.totally_real_L
  AdmissibleDatum.field_K AdmissibleDatum.charZero_K
  AdmissibleDatum.numberField_K AdmissibleDatum.algebra_LK
  AdmissibleDatum.isQuadratic_LK
  AdmissibleDatum.algebra_ℚK AdmissibleDatum.isScalarTower_ℚLK

noncomputable def adm_σ (𝒟 : AdmissibleDatum)
    (i : Fin (Module.finrank ℚ 𝒟.L)) : 𝒟.K →+* ℂ :=
  let e : Fin (Module.finrank ℚ 𝒟.L) ≃ NumberField.InfinitePlace 𝒟.L :=
    Fintype.equivFinOfCardEq
      (by
        classical
        have hfr := (NumberField.IsTotallyReal.finrank (K := 𝒟.L)).symm

        have hreal : ∀ w : NumberField.InfinitePlace 𝒟.L,
            NumberField.InfinitePlace.IsReal w :=
          fun w => NumberField.IsTotallyReal.isReal w
        have hcard : Fintype.card (NumberField.InfinitePlace 𝒟.L) =
            NumberField.InfinitePlace.nrRealPlaces 𝒟.L :=
          Fintype.card_congr
            (Equiv.subtypeUnivEquiv hreal).symm
        rw [hcard, ← hfr]) |>.symm
  let φ_L : 𝒟.L →+* ℂ := (e i).embedding

  letI : Algebra 𝒟.L ℂ := φ_L.toAlgebra
  (IsAlgClosed.lift (R := 𝒟.L) (S := 𝒟.K) (M := ℂ)).toRingHom

namespace AdmissibleDatum

variable (𝒟 : AdmissibleDatum)

noncomputable def f : ℕ := Module.finrank ℚ 𝒟.L

theorem f_pos : 0 < 𝒟.f := Module.finrank_pos


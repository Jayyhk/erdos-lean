    (sameT : ∀ j, (𝒟 j).t = t)
    (sameQ : ∀ j (b : Fin t),
      (𝒟 j).q (Fin.cast (sameT j).symm b) = q b)
    (H : ℝ) (hH : 0 < H)
    (hClass : ∀ j, (NumberField.classNumber (𝒟 j).K : ℝ) ≤ H ^ (𝒟 j).f)
    (R : ℝ) (hR : 1 / 2 < R)
    (hρ0_pos : 0 < (𝒟 0).ρ R)
    (hρ0 : -(theorem_2_3_gamma t H / 2) < Real.log ((𝒟 0).ρ R))

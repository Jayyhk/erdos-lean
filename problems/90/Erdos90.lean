    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hcontract1 (g h k : G в§ё N) :
      Fin.contractNth 1 (fun x y : G в§ё N => x * y) ![g, h, k] = ![g, h * k] := by
    ext i
    fin_cases i
    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hcontract2 (g h k : G в§ё N) :
      Fin.contractNth 2 (fun x y : G в§ё N => x * y) ![g, h, k] = ![g, h] := by
    ext i
    fin_cases i
    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hpow : ((-1 : ZMod p) ^ 3) = -1 := by
    norm_num
  have hz' (g h k : G в§ё N) :

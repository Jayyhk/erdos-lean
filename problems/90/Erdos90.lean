  have htwo_mul_pow_le : (2 : ℝ) * (n : ℝ) ^ (1 + δ) ≤ (n : ℝ) ^ (1 + 2 * δ) := by
    exact theorem_2_3_absorb_factor_two (n : ℝ) A δ hn_pos_real hδpos hA hA_le_n
  refine ⟨n, hnpos, hA_le_n, ?_⟩
  have htwo_mul_pow_le_nu : (2 : ℝ) * (n : ℝ) ^ (1 + δ) ≤ (2 : ℝ) * (νn n : ℝ) :=
    le_trans htwo_mul_pow_le hν_ge_pow
  linarith

theorem theorem_2_3 (t : ℕ) (_ht_pos : 0 < t) (q : Fin t → ℕ)
    (𝒟 : ℕ → AdmissibleDatum)
    (sameT : ∀ j, (𝒟 j).t = t)
    (_sameQ : ∀ j (b : Fin t),
        (𝒟 j).q (Fin.cast (sameT j).symm b) = q b)
    (H : ℝ) (hH : 0 < H)
    (_hClass : ∀ j, (NumberField.classNumber (𝒟 j).K : ℝ) ≤ H ^ (𝒟 j).f)
    (_degsUnbounded : ∀ N, ∃ j, N ≤ (𝒟 j).f)
    (_hγ : 0 < (t : ℝ) * Real.log 2 - Real.log H) :
    ∃ δ > (0 : ℝ),
      {n : ℕ | 0 < n ∧ (νn n : ℝ) ≥ (n : ℝ) ^ (1 + δ)}.Infinite := by
  let γ : ℝ := theorem_2_3_gamma t H
  have hγ : 0 < γ := by
    simpa [γ, theorem_2_3_gamma] using _hγ
  rcases theorem_2_3_choose_radius (𝒟 0) γ hγ with ⟨R, hR, hρ0_pos, hρ0⟩
  let D : ℝ := theorem_2_3_denConst t q
  have hD_eq : ((𝒟 0).denom : ℝ) = D := by
    simpa [D] using theorem_2_3_denom_eq t q 𝒟 sameT _sameQ 0
  have hD_pos : 0 < D := by
    have h : 0 < ((𝒟 0).denom : ℝ) := by
      exact_mod_cast (𝒟 0).denom_pos
    simpa [hD_eq] using h
  have hD_one : 1 ≤ D := by
    have h : (1 : ℝ) ≤ ((𝒟 0).denom : ℝ) := by
      exact_mod_cast (Nat.succ_le_of_lt (𝒟 0).denom_pos)
    simpa [hD_eq] using h
  have h4R : 2 < 4 * R := by
    nlinarith [hR]
  have h4R_nonneg : 0 ≤ 4 * R := by
    nlinarith [hR]
  have hmul : 4 * R ≤ 4 * R * D := by
    have := mul_le_mul_of_nonneg_left hD_one h4R_nonneg
    simpa [mul_assoc] using this
  have h4RD_gt_two : 2 < 4 * R * D := by
    exact lt_of_lt_of_le h4R hmul
  have h4RD_gt_one : 1 < 4 * R * D := by
    have : (1 : ℝ) < 2 := by norm_num
    exact lt_trans this h4RD_gt_two
  have hlog_pos : 0 < Real.log (4 * R * D) := by
    exact Real.log_pos h4RD_gt_one
  let δ : ℝ := γ / (8 * Real.log (4 * R * D))
  have hδpos : 0 < δ := by
    have hden : 0 < 8 * Real.log (4 * R * D) := by
      nlinarith [hlog_pos]
    have : 0 < γ / (8 * Real.log (4 * R * D)) := by
      exact div_pos hγ hden
    simpa [δ] using this
  refine ⟨δ, hδpos, ?_⟩
  refine Set.infinite_of_forall_exists_gt ?_
  intro M
  let A : ℝ := max ((M + 1 : ℕ) : ℝ) ((2 : ℝ) ^ (1 / δ))
  have hA : (2 : ℝ) ^ (1 / δ) ≤ A := by
    exact le_max_right _ _
  have hγhalf : 0 < γ / 2 := by
    nlinarith [hγ]
  have h_tendsto1 : Filter.Tendsto (fun N : ℕ => (γ / 2) * (N : ℝ)) Filter.atTop Filter.atTop := by
    exact Filter.Tendsto.const_mul_atTop hγhalf tendsto_natCast_atTop_atTop
  have h_tendsto2 : Filter.Tendsto (fun N : ℕ => Real.exp ((γ / 2) * (N : ℝ))) Filter.atTop Filter.atTop := by
    exact (Real.tendsto_exp_comp_atTop).2 h_tendsto1
  have hAevent : ∀ᶠ N : ℕ in Filter.atTop, A ≤ Real.exp ((γ / 2) * (N : ℝ)) := by
    exact h_tendsto2.eventually_ge_atTop A
  rcases Filter.eventually_atTop.1 hAevent with ⟨N₀, hN₀⟩
  rcases _degsUnbounded N₀ with ⟨j, hj⟩
  have hlarge' : A ≤ Real.exp ((γ / 2) * ((𝒟 j).f : ℝ)) := by
    exact hN₀ _ hj
  have hlarge : A ≤ Real.exp ((theorem_2_3_gamma t H / 2) * (𝒟 j).f) := by
    simpa [γ] using hlarge'
  rcases theorem_2_3_large_example t q 𝒟 sameT _sameQ H hH _hClass R hR hρ0_pos (by simpa [γ] using hρ0) δ hδpos (by simp [δ, γ, D]) A hA j hlarge with ⟨n, hn_pos, hAn, hν⟩
  refine ⟨n, ?_, ?_⟩
  · exact ⟨hn_pos, hν⟩
  · have hM1 : ((M + 1 : ℕ) : ℝ) ≤ (n : ℝ) := by
      exact le_trans (le_max_left _ _) hAn
    have hM1' : M + 1 ≤ n := by
      exact_mod_cast hM1
    omega


      exact @Algebra.IsAlgebraic.isSeparable_of_perfectField
        (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) _ _ (show Algebra (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) from inferInstance) inferInstance inferInstance
    letI : Algebra.IsSeparable (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) := hsepQ
    have hcardQ : Nat.card (Q.1.inertia (M вүғвӮҗ[в„ҡ] M)) = p.ramificationIdxIn (рқ“һ M) := by
      simpa using (Ideal.card_inertia_eq_ramificationIdxIn (G := M вүғвӮҗ[в„ҡ] M) p hpne Q.1)
    have hdiv_card : Nat.card (Q.1.inertia (M вүғвӮҗ[в„ҡ] M)) вҲЈ Nat.card (M вүғвӮҗ[в„ҡ] M) :=
      Subgroup.card_subgroup_dvd_card (Q.1.inertia (M вүғвӮҗ[в„ҡ] M))
    have hdiv_e : p.ramificationIdxIn (рқ“һ M) вҲЈ 3 ^ в„“ := by

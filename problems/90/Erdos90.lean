theorem finite_unramified_galois_degree_p_subextensions :
    {L : IntermediateField F (AlgebraicClosure F) |
        Module.finrank F L = p ∧
        ∃ _ : NumberField L, ∃ _ : IsGalois F L, IsEverywhereUnramified F L}.Finite := by
  let B : ℕ := (NumberField.discr F).natAbs ^ p

    have h : (algebraMap рқ’ҹ.L рқ’ҹ.K) (a * a) = (algebraMap рқ’ҹ.L рқ’ҹ.K) (-1) := by
      rw [map_mul, ha, рқ’ҹ.i_K_sq, map_neg, map_one]
    exact FaithfulSMul.algebraMap_injective рқ’ҹ.L рқ’ҹ.K h

  obtain вҹЁПҶвҹ© := (inferInstance : Nonempty (рқ’ҹ.L вҶ’+* в„Ӯ))
  have hПҶ : ComplexEmbedding.IsReal ПҶ :=
    NumberField.IsTotallyReal.complexEmbedding_isReal ПҶ
  let ПҲ : рқ’ҹ.L вҶ’+* в„қ := hПҶ.embedding
  have hПҲ : (ПҲ a) * (ПҲ a) = -1 := by
    have h := congrArg ПҲ ha2
    simpa [map_mul, map_neg, map_one] using h

  have hnn : 0 вүӨ ПҲ a * ПҲ a := mul_self_nonneg _
  linarith

theorem adjoin_i_K_eq_top :
    Algebra.adjoin рқ’ҹ.L ({рқ’ҹ.i_K} : Set рқ’ҹ.K) = вҠӨ := by

  have hprime : (Module.finrank рқ’ҹ.L рқ’ҹ.K).Prime := by
    rw [Algebra.IsQuadraticExtension.finrank_eq_two]
    exact Nat.prime_two
  have hsimple : IsSimpleOrder (Subalgebra рқ’ҹ.L рқ’ҹ.K) :=
    Subalgebra.isSimpleOrder_of_finrank_prime рқ’ҹ.L рқ’ҹ.K hprime
  rcases hsimple.eq_bot_or_eq_top (Algebra.adjoin рқ’ҹ.L ({рқ’ҹ.i_K} : Set рқ’ҹ.K))
    with hbot | htop
  В· exfalso
    apply рқ’ҹ.i_K_notMem_range
    have hmem : рқ’ҹ.i_K вҲҲ (вҠҘ : Subalgebra рқ’ҹ.L рқ’ҹ.K) := by
      rw [вҶҗ hbot]
      exact Algebra.self_mem_adjoin_singleton рқ’ҹ.L рқ’ҹ.i_K
    exact Algebra.mem_bot.mp hmem
  В· exact htop

theorem c_i_K : рқ’ҹ.c рқ’ҹ.i_K = -рқ’ҹ.i_K := by

  have h_sq : рқ’ҹ.c рқ’ҹ.i_K * рқ’ҹ.c рқ’ҹ.i_K = -1 := by
    have h1 : рқ’ҹ.c (рқ’ҹ.i_K * рқ’ҹ.i_K) = рқ’ҹ.c (-1) := by rw [рқ’ҹ.i_K_sq]
    rw [map_mul, map_neg, map_one] at h1
    exact h1

  have hprod : (рқ’ҹ.c рқ’ҹ.i_K - рқ’ҹ.i_K) * (рқ’ҹ.c рқ’ҹ.i_K + рқ’ҹ.i_K) = 0 := by
    have : (рқ’ҹ.c рқ’ҹ.i_K - рқ’ҹ.i_K) * (рқ’ҹ.c рқ’ҹ.i_K + рқ’ҹ.i_K)
        = рқ’ҹ.c рқ’ҹ.i_K * рқ’ҹ.c рқ’ҹ.i_K - рқ’ҹ.i_K * рқ’ҹ.i_K := by ring
    rw [this, h_sq, рқ’ҹ.i_K_sq, sub_self]

  rcases mul_eq_zero.mp hprod with h | h
  В·

    exfalso
    apply рқ’ҹ.c_ne_one
    have hfix : рқ’ҹ.c рқ’ҹ.i_K = рқ’ҹ.i_K := sub_eq_zero.mp h

    have hext : (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
      refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
      intro y hy
      simp [Set.mem_singleton_iff.mp hy, hfix]

    ext x
    have hx := AlgHom.congr_fun hext x
    simpa using hx
  В· exact eq_neg_of_add_eq_zero_left h

theorem c_sq_eq_id (рқ’ҹ : AdmissibleDatum) (x : рқ’ҹ.K) : рқ’ҹ.c (рқ’ҹ.c x) = x := by

  have hext : (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K).comp (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K)
      = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
    refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
    intro y hy
    have hy_eq : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
    subst hy_eq
    simp [рқ’ҹ.c_i_K, map_neg]
  have := AlgHom.congr_fun hext x
  simpa using this

noncomputable def relNorm (u : рқ’ҹ.K) : рқ’ҹ.K := u * рқ’ҹ.c u

end AdmissibleDatum

theorem complex_embedding_conjugation_compat
    (рқ’ҹ : AdmissibleDatum) (Пғ : рқ’ҹ.K вҶ’+* в„Ӯ) (x : рқ’ҹ.K) :
    Пғ (рқ’ҹ.c x) = star (Пғ x) := by
  let ПҲ : рқ’ҹ.L вҶ’+* в„Ӯ := Пғ.comp (algebraMap рқ’ҹ.L рқ’ҹ.K)
  have hПҲ_real : ComplexEmbedding.IsReal ПҲ :=
    NumberField.IsTotallyReal.complexEmbedding_isReal ПҲ
  letI : Algebra рқ’ҹ.L в„Ӯ := ПҲ.toAlgebra
  let ПғcA : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] в„Ӯ :=
    { Пғ.comp (рқ’ҹ.c : рқ’ҹ.K вҶ’+* рқ’ҹ.K) with
      commutes' := fun r => by
        change Пғ ((рқ’ҹ.c : рқ’ҹ.K вҶ’+* рқ’ҹ.K) (algebraMap рқ’ҹ.L рқ’ҹ.K r)) = ПҲ r
        rw [show (рқ’ҹ.c : рқ’ҹ.K вҶ’+* рқ’ҹ.K) (algebraMap рқ’ҹ.L рқ’ҹ.K r)
              = algebraMap рқ’ҹ.L рқ’ҹ.K r from AlgEquiv.commutes _ _]
        rfl }
  let ПғstarA : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] в„Ӯ :=
    { (starRingEnd в„Ӯ).comp Пғ with
      commutes' := fun r => by
        change star (ПҲ r) = ПҲ r
        exact RingHom.congr_fun hПҲ_real r }
  suffices h : ПғcA = ПғstarA by
    have := AlgHom.congr_fun h x
    change Пғ (рқ’ҹ.c x) = star (Пғ x)
    exact this
  refine AlgHom.ext_of_adjoin_eq_top рқ’ҹ.adjoin_i_K_eq_top ?_
  intro y hy
  rw [Set.mem_singleton_iff] at hy
  subst hy
  change Пғ (рқ’ҹ.c рқ’ҹ.i_K) = star (Пғ рқ’ҹ.i_K)
  rw [рқ’ҹ.c_i_K, map_neg]
  have hsq : Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K = -1 := by
    have := congrArg Пғ рқ’ҹ.i_K_sq
    rw [map_mul, map_neg, map_one] at this
    exact this
  have hre : (Пғ рқ’ҹ.i_K).re = 0 := by
    have hreal : (Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K).im = 0 := by rw [hsq]; simp
    have hreal' : (Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K).re = -1 := by rw [hsq]; simp
    have him_eq : (Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K).im = 2 * (Пғ рқ’ҹ.i_K).re * (Пғ рқ’ҹ.i_K).im := by
      simp [Complex.mul_im]; ring
    rw [him_eq] at hreal
    have h2 : (Пғ рқ’ҹ.i_K).re * (Пғ рқ’ҹ.i_K).im = 0 := by linarith
    rcases mul_eq_zero.mp h2 with hre0 | him0
    В· exact hre0
    В· exfalso
      have hreal_re : (Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K).re =
          (Пғ рқ’ҹ.i_K).re * (Пғ рқ’ҹ.i_K).re - (Пғ рқ’ҹ.i_K).im * (Пғ рқ’ҹ.i_K).im := by
        simp [Complex.mul_re]
      rw [hreal_re, him0] at hreal'
      have : (Пғ рқ’ҹ.i_K).re * (Пғ рқ’ҹ.i_K).re = -1 := by linarith
      have hnn : 0 вүӨ (Пғ рқ’ҹ.i_K).re * (Пғ рқ’ҹ.i_K).re := mul_self_nonneg _
      linarith
  apply Complex.ext
  В· simp [hre]
  В· simp

namespace AdmissibleDatum
variable (рқ’ҹ : AdmissibleDatum)

theorem relNorm_mem_L (рқ’ҹ : AdmissibleDatum) (u : рқ’ҹ.K) :
    рқ’ҹ.relNorm u вҲҲ (algebraMap рқ’ҹ.L рқ’ҹ.K).range := by

  have hc_sq : вҲҖ x : рқ’ҹ.K, рқ’ҹ.c (рқ’ҹ.c x) = x := by
    have hext : (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K).comp (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K)
        = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
      refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
      intro y hy
      have hy_eq : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
      subst hy_eq
      simp [рқ’ҹ.c_i_K, map_neg]
    intro x
    have hx := AlgHom.congr_fun hext x
    simpa using hx

  have hfix_c : рқ’ҹ.c (рқ’ҹ.relNorm u) = рқ’ҹ.relNorm u := by
    unfold AdmissibleDatum.relNorm
    rw [map_mul, hc_sq u, mul_comm]

  have hfix : вҲҖ Пғ : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K, Пғ (рқ’ҹ.relNorm u) = рқ’ҹ.relNorm u := by
    intro Пғ
    have hПғ_sq : Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K = -1 := by
      have h1 : Пғ (рқ’ҹ.i_K * рқ’ҹ.i_K) = Пғ (-1) := by rw [рқ’ҹ.i_K_sq]
      rw [map_mul, map_neg, map_one] at h1; exact h1
    have hprod : (Пғ рқ’ҹ.i_K - рқ’ҹ.i_K) * (Пғ рқ’ҹ.i_K + рқ’ҹ.i_K) = 0 := by
      have : (Пғ рқ’ҹ.i_K - рқ’ҹ.i_K) * (Пғ рқ’ҹ.i_K + рқ’ҹ.i_K) =
          Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K - рқ’ҹ.i_K * рқ’ҹ.i_K := by ring
      rw [this, hПғ_sq, рқ’ҹ.i_K_sq, sub_self]
    have hПғ_cases : Пғ рқ’ҹ.i_K = рқ’ҹ.i_K вҲЁ Пғ рқ’ҹ.i_K = -рқ’ҹ.i_K := by
      rcases mul_eq_zero.mp hprod with h | h
      В· exact Or.inl (sub_eq_zero.mp h)
      В· exact Or.inr (eq_neg_of_add_eq_zero_left h)

    have hПғ_eq : Пғ = 1 вҲЁ Пғ = рқ’ҹ.c := by
      rcases hПғ_cases with hid | hc
      В· left
        have hext : (Пғ : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
          refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
          intro y hy
          have : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
          subst this; simpa using hid
        ext x
        have := AlgHom.congr_fun hext x
        simpa using this
      В· right
        have hext : (Пғ : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) = (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) := by
          refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
          intro y hy
          have hy_eq : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
          subst hy_eq
          change Пғ рқ’ҹ.i_K = рқ’ҹ.c рқ’ҹ.i_K
          rw [hc, рқ’ҹ.c_i_K]
        ext x
        have := AlgHom.congr_fun hext x
        simpa using this
    rcases hПғ_eq with h1 | hc
    В· rw [h1]; rfl
    В· rw [hc]; exact hfix_c

  rw [RingHom.mem_range]
  obtain вҹЁa, haвҹ© := (IsGalois.mem_range_algebraMap_iff_fixed
    (F := рқ’ҹ.L) (E := рқ’ҹ.K) (рқ’ҹ.relNorm u)).mpr hfix
  exact вҹЁa, haвҹ©

abbrev V : Type := Fin рқ’ҹ.f вҶ’ в„Ӯ

noncomputable def ОҰ : рқ’ҹ.K вҶ’ рқ’ҹ.V := fun x i => adm_Пғ рқ’ҹ i x

theorem ОҰ_injective (рқ’ҹ : AdmissibleDatum) : Function.Injective рқ’ҹ.ОҰ := by
  intro x y hxy
  have h0 := congrFun hxy вҹЁ0, рқ’ҹ.f_posвҹ©
  exact (adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ©).injective h0

noncomputable def adm_real_embedding (рқ’ҹ : AdmissibleDatum)
    (i : Fin рқ’ҹ.f) : рқ’ҹ.L вҶ’+* в„Ӯ :=
  let e : Fin (Module.finrank в„ҡ рқ’ҹ.L) вүғ NumberField.InfinitePlace рқ’ҹ.L :=
    Fintype.equivFinOfCardEq
      (by
        classical
        have hfr := (NumberField.IsTotallyReal.finrank (K := рқ’ҹ.L)).symm
        have hreal : вҲҖ w : NumberField.InfinitePlace рқ’ҹ.L,
            NumberField.InfinitePlace.IsReal w :=
          fun w => NumberField.IsTotallyReal.isReal w
        have hcard : Fintype.card (NumberField.InfinitePlace рқ’ҹ.L) =
            NumberField.InfinitePlace.nrRealPlaces рқ’ҹ.L :=
          Fintype.card_congr
            (Equiv.subtypeUnivEquiv hreal).symm
        rw [hcard, вҶҗ hfr]) |>.symm
  (e i).embedding

theorem adm_real_embedding_injective (рқ’ҹ : AdmissibleDatum) : Function.Injective (adm_real_embedding рқ’ҹ) := by
  intro i j h
  let e : Fin (Module.finrank в„ҡ рқ’ҹ.L) вүғ NumberField.InfinitePlace рқ’ҹ.L :=
    Fintype.equivFinOfCardEq
      (by
        classical
        have hfr := (NumberField.IsTotallyReal.finrank (K := рқ’ҹ.L)).symm
        have hreal : вҲҖ w : NumberField.InfinitePlace рқ’ҹ.L,
            NumberField.InfinitePlace.IsReal w :=
          fun w => NumberField.IsTotallyReal.isReal w
        have hcard : Fintype.card (NumberField.InfinitePlace рқ’ҹ.L) =
            NumberField.InfinitePlace.nrRealPlaces рқ’ҹ.L :=
          Fintype.card_congr
            (Equiv.subtypeUnivEquiv hreal).symm
        rw [hcard, вҶҗ hfr]) |>.symm
  change (e i).embedding = (e j).embedding at h
  exact e.injective (NumberField.InfinitePlace.embedding_inj.mp h)

theorem adm_Пғ_comp_algebraMap (рқ’ҹ : AdmissibleDatum) (i : Fin рқ’ҹ.f) : (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) = adm_real_embedding рқ’ҹ i := by
  classical
  simpa [adm_Пғ, adm_real_embedding, NumberField.ComplexEmbedding.lift] using
    (NumberField.ComplexEmbedding.lift_comp_algebraMap (K := рқ’ҹ.K) (k := рқ’ҹ.L)
      (ПҶ := adm_real_embedding рқ’ҹ i))

theorem adm_Пғ_restrict_distinct (рқ’ҹ : AdmissibleDatum) :
    вҲҖ i j : Fin рқ’ҹ.f, i вү  j вҶ’
      (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) вү 
      (adm_Пғ рқ’ҹ j).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) := by
  intro i j hij hEq
  rw [adm_Пғ_comp_algebraMap (рқ’ҹ := рқ’ҹ) i, adm_Пғ_comp_algebraMap (рқ’ҹ := рқ’ҹ) j] at hEq
  exact hij ((adm_real_embedding_injective рқ’ҹ) hEq)

noncomputable def Оӣ : Submodule в„Ө рқ’ҹ.V where
  carrier := { z | вҲғ u : рқ’ҹ.K,
      (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) x) вҲ§
      рқ’ҹ.ОҰ u = z }
  zero_mem' := by
    refine вҹЁ0, вҹЁ0, ?_вҹ©, ?_вҹ©
    В· simp
    В· funext i; simp [AdmissibleDatum.ОҰ]
  add_mem' := by
    rintro zвӮҒ zвӮӮ вҹЁuвӮҒ, вҹЁxвӮҒ, hxвӮҒвҹ©, hzвӮҒвҹ© вҹЁuвӮӮ, вҹЁxвӮӮ, hxвӮӮвҹ©, hzвӮӮвҹ©
    refine вҹЁuвӮҒ + uвӮӮ, вҹЁxвӮҒ + xвӮӮ, ?_вҹ©, ?_вҹ©
    В· push_cast
      rw [mul_add, hxвӮҒ, hxвӮӮ]
    В· funext i
      simp [AdmissibleDatum.ОҰ, вҶҗ hzвӮҒ, вҶҗ hzвӮӮ, map_add]
  smul_mem' := by
    rintro c z вҹЁu, вҹЁx, hxвҹ©, hzвҹ©
    refine вҹЁ(c : рқ’ҹ.K) * u, вҹЁc вҖў x, ?_вҹ©, ?_вҹ©
    В·
      have h_alg : (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) (c вҖў x) = (c : рқ’ҹ.K) * algebraMap _ _ x := by
        rw [zsmul_eq_mul, map_mul]; simp
      rw [h_alg, вҶҗ hx]; ring
    В·
      funext i
      have hОҰ : рқ’ҹ.ОҰ ((c : рқ’ҹ.K) * u) i = (c : в„Ӯ) * рқ’ҹ.ОҰ u i := by
        simp [AdmissibleDatum.ОҰ, map_mul, map_intCast]
      rw [hОҰ, вҶҗ hz]
      simp [zsmul_eq_mul]

noncomputable def LambdaIntegral (рқ’ҹ : AdmissibleDatum) : Submodule в„Ө рқ’ҹ.V where
  carrier := { z | вҲғ x : рқ“һ рқ’ҹ.K, рқ’ҹ.ОҰ (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) = z }
  zero_mem' := by
    refine вҹЁ0, ?_вҹ©
    funext i
    simp [AdmissibleDatum.ОҰ]
  add_mem' := by
    rintro zвӮҒ zвӮӮ вҹЁxвӮҒ, rflвҹ© вҹЁxвӮӮ, rflвҹ©
    refine вҹЁxвӮҒ + xвӮӮ, ?_вҹ©
    funext i
    simp [AdmissibleDatum.ОҰ, map_add]
  smul_mem' := by
    rintro c z вҹЁx, rflвҹ©
    refine вҹЁc вҖў x, ?_вҹ©
    funext i
    simp [AdmissibleDatum.ОҰ, zsmul_eq_mul, map_mul, map_intCast]

theorem LambdaIntegral_discreteTopology (рқ’ҹ : AdmissibleDatum) : DiscreteTopology рқ’ҹ.LambdaIntegral := by
  classical
  have hall_nonreal : вҲҖ ПҶ : рқ’ҹ.K вҶ’+* в„Ӯ, В¬ NumberField.ComplexEmbedding.IsReal ПҶ := by
    intro ПҶ hreal
    let ПҲ : рқ’ҹ.K вҶ’+* в„қ := hreal.embedding
    have hПҲ : ПҲ рқ’ҹ.i_K * ПҲ рқ’ҹ.i_K = -1 := by
      have h := congrArg ПҲ рқ’ҹ.i_K_sq
      simpa [map_mul, map_neg, map_one] using h
    have hnn : 0 вүӨ ПҲ рқ’ҹ.i_K * ПҲ рқ’ҹ.i_K := mul_self_nonneg _
    linarith
  have hno_real : IsEmpty {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsReal} := by
    refine вҹЁ?_вҹ©
    intro w
    exact hall_nonreal w.1.embedding ((NumberField.InfinitePlace.isReal_iff).mp w.2)
  have hcard_complex : Fintype.card {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} = рқ’ҹ.f := by
    letI : IsEmpty {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsReal} := hno_real
    letI : Algebra в„ҡ рқ’ҹ.K := DivisionRing.toRatAlgebra
    have hnrreal : NumberField.InfinitePlace.nrRealPlaces рқ’ҹ.K = 0 := by
      simp [NumberField.InfinitePlace.nrRealPlaces]
    have hfinrank : Module.finrank в„ҡ рқ’ҹ.K = 2 * рқ’ҹ.f := by
      calc
        Module.finrank в„ҡ рқ’ҹ.K = Module.finrank в„ҡ рқ’ҹ.L * Module.finrank рқ’ҹ.L рқ’ҹ.K := by
          symm
          exact Module.finrank_mul_finrank в„ҡ рқ’ҹ.L рқ’ҹ.K
        _ = рқ’ҹ.f * 2 := by rw [AdmissibleDatum.f, Algebra.IsQuadraticExtension.finrank_eq_two рқ’ҹ.L рқ’ҹ.K]
        _ = 2 * рқ’ҹ.f := by ring
    have hsig := NumberField.InfinitePlace.card_add_two_mul_card_eq_rank (K := рқ’ҹ.K)
    have hsig0 : 2 * Fintype.card {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} = Module.finrank в„ҡ рқ’ҹ.K := by
      simpa [hnrreal, NumberField.InfinitePlace.nrComplexPlaces] using hsig
    rw [hfinrank] at hsig0
    omega
  let ПғToPlace : Fin рқ’ҹ.f вҶ’ {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} :=
    fun i => NumberField.InfinitePlace.mkComplex вҹЁadm_Пғ рқ’ҹ i, hall_nonreal (adm_Пғ рқ’ҹ i)вҹ©
  have hПғinj : Function.Injective ПғToPlace := by
    intro i j hij
    by_contra hne
    have hij' : (ПғToPlace i : NumberField.InfinitePlace рқ’ҹ.K) = ПғToPlace j := congrArg Subtype.val hij
    simp only [ПғToPlace, NumberField.InfinitePlace.mkComplex_coe] at hij'
    rw [NumberField.InfinitePlace.mk_eq_iff] at hij'
    have hrext :
        (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) =
          (adm_Пғ рқ’ҹ j).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) := by
      rcases hij' with h | h
      В· exact congrArg (fun ПҶ => ПҶ.comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) h
      В· have hreal_restrict : NumberField.ComplexEmbedding.IsReal ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) :=
          NumberField.IsTotallyReal.complexEmbedding_isReal _
        have hconj_restrict :
            NumberField.ComplexEmbedding.conjugate ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) =
              (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) :=
          (NumberField.ComplexEmbedding.isReal_iff).mp hreal_restrict
        have hconjcomp :
            NumberField.ComplexEmbedding.conjugate ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) =
              (adm_Пғ рқ’ҹ j).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) := by
          calc
            NumberField.ComplexEmbedding.conjugate ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) =
                (NumberField.ComplexEmbedding.conjugate (adm_Пғ рқ’ҹ i)).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) := by
                  symm
                  exact NumberField.ComplexEmbedding.conjugate_comp (adm_Пғ рқ’ҹ i) (algebraMap рқ’ҹ.L рқ’ҹ.K)
            _ = (adm_Пғ рқ’ҹ j).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) := by rw [h]
        exact hconj_restrict.symm.trans hconjcomp
    exact (рқ’ҹ.adm_Пғ_restrict_distinct i j hne) hrext
  let eПғ : Fin рқ’ҹ.f вүғ {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} :=
    Equiv.ofBijective ПғToPlace ((Fintype.bijective_iff_injective_and_card ПғToPlace).2 вҹЁhПғinj, by simpa using hcard_complex.symmвҹ©)
  let coordEquiv : {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} вҶ’ в„Ӯ вүғL[в„қ] в„Ӯ := fun w =>
    if h : w.1.embedding = adm_Пғ рқ’ҹ (eПғ.symm w) then ContinuousLinearEquiv.refl в„қ в„Ӯ else Complex.conjCLE
  let complexReindex : рқ’ҹ.V вүғL[в„қ] ({w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} вҶ’ в„Ӯ) :=
    (ContinuousLinearEquiv.piCongrLeft в„қ (fun _ : {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} => в„Ӯ) eПғ).trans
      (ContinuousLinearEquiv.piCongrRight coordEquiv)
  letI : IsEmpty {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsReal} := hno_real
  let reindexComplex : рқ’ҹ.V вүғL[в„қ] NumberField.mixedEmbedding.mixedSpace рқ’ҹ.K :=
    complexReindex.trans
      (ContinuousLinearEquiv.uniqueProd в„қ ({w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} вҶ’ в„Ӯ)
        ({w : NumberField.InfinitePlace рқ’ҹ.K // w.IsReal} вҶ’ в„қ)).symm
  have hreindex_apply (x : рқ’ҹ.K) : reindexComplex (рқ’ҹ.ОҰ x) = NumberField.mixedEmbedding рқ’ҹ.K x := by
    ext w
    В· cases hno_real.false w
    В· simp [reindexComplex, complexReindex]
      have hpi := Equiv.piCongrLeft_apply (P := fun _ : {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} => в„Ӯ) eПғ (рқ’ҹ.ОҰ x) w
      have hpi' :
          ((ContinuousLinearEquiv.piCongrLeft в„қ (fun _ : {w : NumberField.InfinitePlace рқ’ҹ.K // w.IsComplex} => в„Ӯ) eПғ)
            (рқ’ҹ.ОҰ x) w) = (рқ’ҹ.ОҰ x) (eПғ.symm w) := by
        simpa [ContinuousLinearEquiv.piCongrLeft] using hpi
      rw [hpi']
      have hwplace_sub : ПғToPlace (eПғ.symm w) = w := by
        exact eПғ.apply_symm_apply w
      have hwplace :
          (NumberField.InfinitePlace.mkComplex вҹЁadm_Пғ рқ’ҹ (eПғ.symm w), hall_nonreal (adm_Пғ рқ’ҹ (eПғ.symm w))вҹ© :
            NumberField.InfinitePlace рқ’ҹ.K) = w.1 := by
        exact congrArg Subtype.val hwplace_sub
      have hwemb : adm_Пғ рқ’ҹ (eПғ.symm w) = w.1.embedding вҲЁ
          NumberField.ComplexEmbedding.conjugate (adm_Пғ рқ’ҹ (eПғ.symm w)) = w.1.embedding := by
        have hwplace' : NumberField.InfinitePlace.mk (adm_Пғ рқ’ҹ (eПғ.symm w)) = NumberField.InfinitePlace.mk w.1.embedding := by
          simpa [ПғToPlace, NumberField.InfinitePlace.mkComplex_coe, NumberField.InfinitePlace.mk_embedding] using hwplace
        simpa using (NumberField.InfinitePlace.mk_eq_iff.mp hwplace')
      rcases hwemb with h | h
      В· simp [coordEquiv, h, AdmissibleDatum.ОҰ]
      В· have hne : В¬ w.1.embedding = adm_Пғ рқ’ҹ (eПғ.symm w) := by
          intro hw
          have hreal : NumberField.ComplexEmbedding.IsReal (adm_Пғ рқ’ҹ (eПғ.symm w)) := by
            rw [NumberField.ComplexEmbedding.isReal_iff]
            exact h.trans hw
          exact hall_nonreal (adm_Пғ рқ’ҹ (eПғ.symm w)) hreal
        have hx : NumberField.ComplexEmbedding.conjugate (adm_Пғ рқ’ҹ (eПғ.symm w)) x = w.1.embedding x := by
          exact RingHom.congr_fun h x
        simpa [coordEquiv, hne, AdmissibleDatum.ОҰ, NumberField.ComplexEmbedding.conjugate, Complex.conjCLE_apply] using hx
  have hLambda :
      рқ’ҹ.LambdaIntegral =
        ZLattice.comap в„қ (NumberField.mixedEmbedding.integerLattice рқ’ҹ.K) reindexComplex.toLinearMap := by
    ext z
    constructor
    В· rintro вҹЁx, rflвҹ©
      change reindexComplex (рқ’ҹ.ОҰ (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x)) вҲҲ NumberField.mixedEmbedding.integerLattice рқ’ҹ.K
      rw [hreindex_apply]
      change NumberField.mixedEmbedding рқ’ҹ.K (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) вҲҲ
        LinearMap.range (((NumberField.mixedEmbedding рқ’ҹ.K).comp (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K)).toIntAlgHom.toLinearMap)
      exact вҹЁx, rflвҹ©
    В· intro hz
      change reindexComplex z вҲҲ NumberField.mixedEmbedding.integerLattice рқ’ҹ.K at hz
      change reindexComplex z вҲҲ
        LinearMap.range (((NumberField.mixedEmbedding рқ’ҹ.K).comp (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K)).toIntAlgHom.toLinearMap) at hz
      rcases hz with вҹЁx, hxвҹ©
      refine вҹЁx, ?_вҹ©
      apply reindexComplex.injective
      rw [hreindex_apply]
      simpa using hx
  rw [hLambda]
  infer_instance

theorem Lambda_eq_comap_LambdaIntegral (рқ’ҹ : AdmissibleDatum) :
    рқ’ҹ.Оӣ =
      ZLattice.comap в„қ рқ’ҹ.LambdaIntegral
        (((рқ’ҹ.Q : в„қ) ^ 2) вҖў (1 : рқ’ҹ.V вҶ’вӮ—[в„қ] рқ’ҹ.V)) := by
  ext z
  constructor
  В· intro hz
    change ((((рқ’ҹ.Q : в„қ) ^ 2) вҖў (1 : рқ’ҹ.V вҶ’вӮ—[в„қ] рқ’ҹ.V)) z вҲҲ рқ’ҹ.LambdaIntegral)
    change ((рқ’ҹ.Q : в„қ) ^ 2) вҖў z вҲҲ рқ’ҹ.LambdaIntegral
    rcases hz with вҹЁu, вҹЁx, hxвҹ©, rflвҹ©
    refine вҹЁx, ?_вҹ©
    funext i
    have hxi : (adm_Пғ рқ’ҹ i) (((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u) = (adm_Пғ рқ’ҹ i) (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) :=
      congrArg (adm_Пғ рқ’ҹ i) hx
    simpa [AdmissibleDatum.ОҰ, Pi.smul_apply, smul_eq_mul, map_mul, map_natCast] using hxi.symm
  В· intro hz
    change ((((рқ’ҹ.Q : в„қ) ^ 2) вҖў (1 : рқ’ҹ.V вҶ’вӮ—[в„қ] рқ’ҹ.V)) z вҲҲ рқ’ҹ.LambdaIntegral) at hz
    change ((рқ’ҹ.Q : в„қ) ^ 2) вҖў z вҲҲ рқ’ҹ.LambdaIntegral at hz
    rcases hz with вҹЁx, hxвҹ©
    let u : рқ’ҹ.K := ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№ * algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x
    have hQK_ne : ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) вү  0 := by
      exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt рқ’ҹ.Q_pos))
    have hu : ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x := by
      simp [u, hQK_ne, mul_assoc]
    have huОҰ : ((рқ’ҹ.Q : в„қ) ^ 2) вҖў рқ’ҹ.ОҰ u = рқ’ҹ.ОҰ (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) := by
      funext i
      have hxi : (adm_Пғ рқ’ҹ i) (((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u) = (adm_Пғ рқ’ҹ i) (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) :=
        congrArg (adm_Пғ рқ’ҹ i) hu
      simpa [AdmissibleDatum.ОҰ, Pi.smul_apply, smul_eq_mul, map_mul, map_natCast] using hxi
    have hQ2_ne : ((рқ’ҹ.Q : в„қ) ^ 2) вү  0 := by
      exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt рқ’ҹ.Q_pos))
    have huz : рқ’ҹ.ОҰ u = z := by
      apply (MulAction.injectiveвӮҖ hQ2_ne)
      calc
        ((рқ’ҹ.Q : в„қ) ^ 2) вҖў рқ’ҹ.ОҰ u = рқ’ҹ.ОҰ (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) := huОҰ
        _ = ((рқ’ҹ.Q : в„қ) ^ 2) вҖў z := hx
    exact вҹЁu, вҹЁx, huвҹ©, huzвҹ©

theorem Оӣ_discreteTopology (рқ’ҹ : AdmissibleDatum) :
    DiscreteTopology рқ’ҹ.Оӣ := by
  letI : DiscreteTopology рқ’ҹ.LambdaIntegral := LambdaIntegral_discreteTopology рқ’ҹ
  rw [Lambda_eq_comap_LambdaIntegral рқ’ҹ]
  let eQ : рқ’ҹ.V вҶ’вӮ—[в„қ] рқ’ҹ.V := (((рқ’ҹ.Q : в„қ) ^ 2) вҖў (1 : рқ’ҹ.V вҶ’вӮ—[в„қ] рқ’ҹ.V))
  simpa [eQ] using
    (ZLattice.comap_discreteTopology (K := в„қ) (L := рқ’ҹ.LambdaIntegral)
      (e := eQ)
      (LinearMap.continuous_of_finiteDimensional eQ)
      (by
        have hQ0 : (рқ’ҹ.Q : в„қ) вү  0 := by
          exact_mod_cast (Nat.ne_of_gt рқ’ҹ.Q_pos)
        have hQ : ((рқ’ҹ.Q : в„қ) ^ 2) вү  0 := by
          exact pow_ne_zero 2 hQ0
        simpa [eQ] using
          (LinearEquiv.smulOfNeZero (K := в„қ) (M := рқ’ҹ.V) (((рқ’ҹ.Q : в„қ) ^ 2)) hQ).injective))

theorem L_integralBasis_embedding_linearIndependent: LinearIndependent в„Ӯ (fun j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L) => fun i : Fin рқ’ҹ.f => ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) (NumberField.integralBasis рқ’ҹ.L j)) := by
  classical
  let П„ : Fin рқ’ҹ.f вҶ’ рқ’ҹ.L вҶ’+* в„Ӯ := fun i => (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)
  have hП„inj : Function.Injective П„ := by
    intro i j hij
    by_contra hne
    exact (adm_Пғ_restrict_distinct рқ’ҹ i j hne) hij
  have hП„bij : Function.Bijective П„ := by
    rw [Fintype.bijective_iff_injective_and_card]
    refine вҹЁhП„inj, ?_вҹ©
    rw [Fintype.card_fin, f, NumberField.Embeddings.card]
  let eП„ : Fin рқ’ҹ.f вүғ (рқ’ҹ.L вҶ’+* в„Ӯ) := Equiv.ofBijective П„ hП„bij
  have hbasis' :
      LinearIndependent в„Ӯ
        (fun j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L) =>
          NumberField.canonicalEmbedding рқ’ҹ.L (NumberField.integralBasis рқ’ҹ.L j)) := by
    convert (NumberField.canonicalEmbedding.latticeBasis рқ’ҹ.L).linearIndependent using 1
    ext j Пғ
    rw [NumberField.canonicalEmbedding.latticeBasis_apply, NumberField.canonicalEmbedding.apply_at]
  have hbasis :
      LinearIndependent в„Ӯ
        (fun j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L) =>
          fun Пғ : рқ’ҹ.L вҶ’+* в„Ӯ => Пғ (NumberField.integralBasis рқ’ҹ.L j)) := by
    simpa [NumberField.canonicalEmbedding.apply_at] using hbasis'
  have hmap :
      LinearIndependent в„Ӯ
        (fun j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L) =>
          (LinearEquiv.funCongrLeft в„Ӯ в„Ӯ eП„)
            (fun Пғ : рқ’ҹ.L вҶ’+* в„Ӯ => Пғ (NumberField.integralBasis рқ’ҹ.L j))) := by
    exact hbasis.map'
      (LinearEquiv.funCongrLeft в„Ӯ в„Ӯ eП„).toLinearMap
      (LinearMap.ker_eq_bot.mpr (LinearEquiv.injective _))
  simpa [П„, eП„, LinearEquiv.funCongrLeft_apply, LinearMap.funLeft_apply] using hmap

theorem adm_Пғ_iK_eq_I_or_neg_I: вҲҖ i : Fin рқ’ҹ.f, adm_Пғ рқ’ҹ i рқ’ҹ.i_K = Complex.I вҲЁ adm_Пғ рқ’ҹ i рқ’ҹ.i_K = -Complex.I := by
  intro i
  let z : в„Ӯ := adm_Пғ рқ’ҹ i рқ’ҹ.i_K
  have hconj : -z = star z := by
    dsimp [z]
    simpa [рқ’ҹ.c_i_K, map_neg] using
      (complex_embedding_conjugation_compat рқ’ҹ (adm_Пғ рқ’ҹ i) рқ’ҹ.i_K)
  have hsq : z * z = (-1 : в„Ӯ) := by
    dsimp [z]
    simpa using congrArg (adm_Пғ рқ’ҹ i) рқ’ҹ.i_K_sq
  have hre_eq : -z.re = z.re := by
    simpa using congrArg Complex.re hconj
  have hre0 : z.re = 0 := by
    linarith
  have hmulre : z.re * z.re - z.im * z.im = (-1 : в„қ) := by
    have h := congrArg Complex.re hsq
    simpa [Complex.mul_re] using h
  have himsq' : z.im * z.im = (1 : в„қ) := by
    nlinarith [hmulre, hre0]
  have himsq : z.im ^ 2 = (1 : в„қ) := by
    simpa [pow_two] using himsq'
  have hz_cases : z = Complex.I вҲЁ z = -Complex.I := by
    rcases sq_eq_one_iff.mp himsq with him1 | him1
    В· left
      apply Complex.ext <;> simp [hre0, him1]
    В· right
      apply Complex.ext <;> simp [hre0, him1]
  simpa [z] using hz_cases

theorem scaled_L_integralBasis_left_linearIndependent: LinearIndependent в„қ (fun j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L) => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))) := by
  let О№ := Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L)
  let b : О№ вҶ’ рқ’ҹ.V := fun j => fun i =>
    ((adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)) (NumberField.integralBasis рқ’ҹ.L j)
  let cR : в„қ := (((рқ’ҹ.Q : в„қ) ^ 2)вҒ»В№)
  have hb : LinearIndependent в„Ӯ b := by
    simpa [b, AdmissibleDatum.V] using L_integralBasis_embedding_linearIndependent (рқ’ҹ := рқ’ҹ)
  have hbR : LinearIndependent в„қ b :=
    LinearIndependent.restrict_scalars' (R := в„қ) hb
  have hQ : (рқ’ҹ.Q : в„қ) вү  0 := by
    exact_mod_cast (ne_of_gt рқ’ҹ.Q_pos)
  have hcR : cR вү  0 := by
    dsimp [cR]
    exact inv_ne_zero (pow_ne_zero 2 hQ)
  have hfamily :
      (fun j : О№ => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))) =
      (((fun _ : О№ => Units.mk0 cR hcR) вҖў b : О№ вҶ’ рқ’ҹ.V)) := by
    funext j
    ext i
    simp [b, cR, AdmissibleDatum.ОҰ, Complex.real_smul, mul_assoc]
  rw [hfamily]
  exact LinearIndependent.units_smul hbR (fun _ : О№ => Units.mk0 cR hcR)

theorem scaled_L_integralBasis_pair_linearIndependent: LinearIndependent в„қ (fun ij : Sum (Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L)) (Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L)) => Sum.elim (fun j => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))) (fun j => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)))) ij) := by
  classical
  let О№ := Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L)
  let v : О№ вҶ’ Fin рқ’ҹ.f вҶ’ в„Ӯ := fun j =>
    рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))
  let w : О№ вҶ’ Fin рқ’ҹ.f вҶ’ в„Ӯ := fun j =>
    рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)))
  change LinearIndependent в„қ (Sum.elim v w)
  have hv : LinearIndependent в„қ v := by
    simpa [v] using scaled_L_integralBasis_left_linearIndependent (рқ’ҹ := рқ’ҹ)
  let r : О№ вҶ’ Fin рқ’ҹ.f вҶ’ в„қ := fun j i => (v j i).re
  have hvim : вҲҖ j i, (v j i).im = 0 := by
    intro j i
    dsimp [v, AdmissibleDatum.ОҰ]
    let ПҶ : рқ’ҹ.L вҶ’+* в„Ӯ := (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)
    have hПҶ : NumberField.ComplexEmbedding.IsReal ПҶ := by
      exact NumberField.IsTotallyReal.complexEmbedding_isReal ПҶ
    let y : рқ’ҹ.L := ((рқ’ҹ.Q : рқ’ҹ.L) ^ 2)вҒ»В№ * NumberField.integralBasis рқ’ҹ.L j
    have hy : (adm_Пғ рқ’ҹ i) ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)) = ПҶ y := by
      simp [ПҶ, y, map_mul, mul_assoc]
    rw [hy]
    rw [вҶҗ NumberField.ComplexEmbedding.IsReal.coe_embedding_apply (hПҶ := hПҶ) y]
    simpa using Complex.ofReal_im (hПҶ.embedding y)
  have hvofReal : вҲҖ j i, v j i = (r j i : в„Ӯ) := by
    intro j i
    apply Complex.ext
    В· simp [r]
    В· simpa [r] using hvim j i
  let ofRealPi : (Fin рқ’ҹ.f вҶ’ в„қ) вҶ’вӮ—[в„қ] (Fin рқ’ҹ.f вҶ’ в„Ӯ) :=
    LinearMap.pi fun i => (Complex.ofRealLI.toLinearMap).comp (LinearMap.proj i)
  have hofReal_r : ofRealPi вҲҳ r = v := by
    funext j
    ext i
    simpa [ofRealPi] using (hvofReal j i).symm
  have hr : LinearIndependent в„қ r := by
    apply LinearIndependent.of_comp ofRealPi
    rw [hofReal_r]
    exact hv
  have hwcoord : вҲҖ j i, w j i = adm_Пғ рқ’ҹ i рқ’ҹ.i_K * v j i := by
    intro j i
    dsimp [w, v, AdmissibleDatum.ОҰ]
    simp [map_mul, mul_assoc, mul_left_comm, mul_comm]
  have hrew : вҲҖ j i, (w j i).re = 0 := by
    intro j i
    rcases adm_Пғ_iK_eq_I_or_neg_I (рқ’ҹ := рқ’ҹ) i with hI | hI
    В· rw [hwcoord j i, hI, hvofReal j i]
      simp
    В· rw [hwcoord j i, hI, hvofReal j i]
      simp
  let Оө : Fin рқ’ҹ.f вҶ’ в„қ := fun i => if adm_Пғ рқ’ҹ i рқ’ҹ.i_K = Complex.I then 1 else -1
  have hОөnz : вҲҖ i, Оө i вү  0 := by
    intro i
    by_cases hI : adm_Пғ рқ’ҹ i рқ’ҹ.i_K = Complex.I
    В· simp [Оө, hI]
    В· simp [Оө, hI]
  have himw : вҲҖ j i, (w j i).im = Оө i * r j i := by
    intro j i
    rcases adm_Пғ_iK_eq_I_or_neg_I (рқ’ҹ := рқ’ҹ) i with hI | hI
    В· rw [hwcoord j i, hI, hvofReal j i]
      simp [Оө, hI, r]
    В· have hne : В¬ adm_Пғ рқ’ҹ i рқ’ҹ.i_K = Complex.I := by
        intro h
        rw [h] at hI
        have him : (Complex.I : в„Ӯ).im = (-Complex.I).im := congrArg Complex.im hI
        norm_num at him
      rw [hwcoord j i, hI, hvofReal j i]
      simp [Оө, hne, r]
  let diag : (Fin рқ’ҹ.f вҶ’ в„қ) вҶ’вӮ—[в„қ] (Fin рқ’ҹ.f вҶ’ в„қ) :=
    { toFun := fun x i => Оө i * x i
      map_add' := by
        intro x y
        ext i
        simp [mul_add]
      map_smul' := by
        intro a x
        ext i
        simp [mul_assoc, mul_left_comm, mul_comm] }
  have hdiag_ker : LinearMap.ker diag = вҠҘ := by
    rw [LinearMap.ker_eq_bot']
    intro x hx
    ext i
    have hxi : Оө i * x i = 0 := by
      have := congrFun hx i
      simpa [diag] using this
    rcases mul_eq_zero.mp hxi with hОө | hx0
    В· exact (hОөnz i hОө).elim
    В· exact hx0
  let twisted : О№ вҶ’ Fin рқ’ҹ.f вҶ’ в„қ := fun j i => Оө i * r j i
  have htwisted : LinearIndependent в„қ twisted := by
    have hdiag : LinearIndependent в„қ (diag вҲҳ r) := by
      exact LinearIndependent.map' hr diag hdiag_ker
    simpa [diag, twisted] using hdiag
  let imPi : (Fin рқ’ҹ.f вҶ’ в„Ӯ) вҶ’вӮ—[в„қ] (Fin рқ’ҹ.f вҶ’ в„қ) :=
    LinearMap.pi fun i => (Complex.imCLM.toLinearMap).comp (LinearMap.proj i)
  have himPi_w : imPi вҲҳ w = twisted := by
    funext j
    ext i
    simp [imPi, twisted, himw]
  have hw : LinearIndependent в„қ w := by
    apply LinearIndependent.of_comp imPi
    rw [himPi_w]
    exact htwisted
  have hdisj : Disjoint (Submodule.span в„қ (Set.range v)) (Submodule.span в„қ (Set.range w)) := by
    rw [Submodule.disjoint_def]
    intro x hxv hxw
    rw [Submodule.mem_span_range_iff_exists_fun] at hxv
    rw [Submodule.mem_span_range_iff_exists_fun] at hxw
    rcases hxv with вҹЁa, haвҹ©
    rcases hxw with вҹЁb, hbвҹ©
    have hab : вҲ‘ j, a j вҖў v j = вҲ‘ j, b j вҖў w j := ha.trans hb.symm
    have hre : вҲ‘ j, a j вҖў r j = 0 := by
      ext i
      have hi := congrArg Complex.re (congrFun hab i)
      simpa [r, hrew, Complex.re_sum, Complex.real_smul] using hi
    have ha0 : вҲҖ j, a j = 0 := (Fintype.linearIndependent_iff.mp hr) a hre
    have hx0 : x = 0 := by
      rw [вҶҗ ha]
      ext i
      simp [ha0]
    exact hx0
  exact LinearIndependent.sum_type hv hw hdisj

theorem Оӣ_contains_scaled_L_integralBasis_pair: вҲҖ j : Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L), рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)) вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) вҲ§ рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))) вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
  intro j
  have hQ : ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) вү  0 := by
    exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt рқ’ҹ.Q_pos))
  have hxInt : IsIntegral в„Ө (algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)) := by
    simpa [NumberField.integralBasis_apply] using
      (NumberField.RingOfIntegers.isIntegral_coe
        (NumberField.RingOfIntegers.mapRingHom (algebraMap рқ’ҹ.L рқ’ҹ.K)
          (NumberField.RingOfIntegers.basis рқ’ҹ.L j)))
  have hi : IsIntegral в„Ө рқ’ҹ.i_K := by
    refine вҹЁ(Polynomial.X ^ 2 + Polynomial.C (1 : в„Ө) : Polynomial в„Ө), ?_, ?_вҹ©
    В· simpa using (Polynomial.monic_X_pow_add_C (a := (1 : в„Ө)) (n := 2) (by decide))
    В· rw [Polynomial.evalвӮӮ_add, Polynomial.evalвӮӮ_X_pow, Polynomial.evalвӮӮ_C]
      simp [pow_two, рқ’ҹ.i_K_sq]
  constructor
  В· unfold AdmissibleDatum.Оӣ
    change
      вҲғ u : рқ’ҹ.K,
        (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) вҲ§
          рқ’ҹ.ОҰ u =
            рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) *
              algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))
    let x : рқ“һ рқ’ҹ.K := вҹЁalgebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j), hxIntвҹ©
    refine вҹЁ(((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j), ?_вҹ©
    constructor
    В· refine вҹЁx, ?_вҹ©
      dsimp [x]
      rw [вҶҗ mul_assoc, mul_inv_cancelвӮҖ hQ, one_mul]
    В· rfl
  В· unfold AdmissibleDatum.Оӣ
    change
      вҲғ u : рқ’ҹ.K,
        (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K x) вҲ§
          рқ’ҹ.ОҰ u =
            рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) *
              (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)))
    have hixInt : IsIntegral в„Ө
        (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)) :=
      hi.mul hxInt
    let x : рқ“һ рқ’ҹ.K :=
      вҹЁрқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j), hixIntвҹ©
    refine вҹЁ(((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) *
        (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)), ?_вҹ©
    constructor
    В· refine вҹЁx, ?_вҹ©
      dsimp [x]
      rw [вҶҗ mul_assoc, mul_inv_cancelвӮҖ hQ, one_mul]
    В· rfl

theorem Оӣ_spans_top (рқ’ҹ : AdmissibleDatum) :
    Submodule.span в„қ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) = вҠӨ := by
  let О№ := Module.Free.ChooseBasisIndex в„Ө (рқ“һ рқ’ҹ.L)
  let b : Sum О№ О№ вҶ’ рқ’ҹ.V :=
    fun ij =>
      Sum.elim
        (fun j => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j)))
        (fun j => рқ’ҹ.ОҰ ((((рқ’ҹ.Q : рқ’ҹ.K) ^ 2)вҒ»В№) * (рқ’ҹ.i_K * algebraMap рқ’ҹ.L рқ’ҹ.K (NumberField.integralBasis рқ’ҹ.L j))))
        ij
  have hb_mem : вҲҖ k : Sum О№ О№, b k вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
    intro k
    cases k with
    | inl j =>
        exact (Оӣ_contains_scaled_L_integralBasis_pair рқ’ҹ j).1
    | inr j =>
        exact (Оӣ_contains_scaled_L_integralBasis_pair рқ’ҹ j).2
  have hspan_le : Submodule.span в„қ (Set.range b) вүӨ Submodule.span в„қ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
    refine Submodule.span_le.mpr ?_
    rintro _ вҹЁk, rflвҹ©
    exact Submodule.subset_span (hb_mem k)
  have hlin : LinearIndependent в„қ b := by
    simpa only [b] using scaled_L_integralBasis_pair_linearIndependent (рқ’ҹ := рқ’ҹ)
  have hcardI : Fintype.card О№ = рқ’ҹ.f := by
    calc
      Fintype.card О№ = Module.finrank в„Ө (рқ“һ рқ’ҹ.L) := by
        simpa only [О№] using (Module.finrank_eq_card_basis (NumberField.RingOfIntegers.basis рқ’ҹ.L)).symm
      _ = Module.finrank в„ҡ рқ’ҹ.L := NumberField.RingOfIntegers.rank (K := рқ’ҹ.L)
      _ = рқ’ҹ.f := by rfl
  have hfinrankC : Module.finrank в„қ в„Ӯ = 2 := by
    simpa only using (Module.finrank_eq_card_basis Complex.basisOneI)
  have hfinrankV : Module.finrank в„қ рқ’ҹ.V = 2 * рқ’ҹ.f := by
    calc
      Module.finrank в„қ рқ’ҹ.V = вҲ‘ _ : Fin рқ’ҹ.f, Module.finrank в„қ в„Ӯ := by
        simpa only [AdmissibleDatum.V] using
          (Module.finrank_pi_fintype (R := в„қ) (M := fun _ : Fin рқ’ҹ.f => в„Ӯ))
      _ = вҲ‘ _ : Fin рқ’ҹ.f, 2 := by simp only [hfinrankC]
      _ = 2 * рқ’ҹ.f := by
        simp only [Finset.sum_const_nat, Finset.card_univ, Fintype.card_fin]
        omega
  have hcard : Fintype.card (Sum О№ О№) = Module.finrank в„қ рқ’ҹ.V := by
    calc
      Fintype.card (Sum О№ О№) = Fintype.card О№ + Fintype.card О№ := by
        simp only [Fintype.card_sum]
      _ = рқ’ҹ.f + рқ’ҹ.f := by simp only [hcardI]
      _ = 2 * рқ’ҹ.f := by omega
      _ = Module.finrank в„қ рқ’ҹ.V := by rw [hfinrankV]
  have hspan_top : Submodule.span в„қ (Set.range b) = вҠӨ := by
    exact LinearIndependent.span_eq_top_of_card_eq_finrank' hlin hcard
  exact top_unique <| by
    simpa only [hspan_top] using hspan_le

noncomputable def supNorm (z : рқ’ҹ.V) : в„қ :=
  Finset.univ.sup' вҹЁвҹЁ0, рқ’ҹ.f_posвҹ©, Finset.mem_univ _вҹ©
    (fun r : Fin рқ’ҹ.f => вҖ–z rвҖ–)

noncomputable def closedPolydisc (R : в„қ) : Set рқ’ҹ.V :=
  { z | рқ’ҹ.supNorm z вүӨ R }

noncomputable def X (a : рқ’ҹ.V) (R : в„қ) : Set рқ’ҹ.V :=
  (Set.range (fun (l : рқ’ҹ.Оӣ) => a + (l : рқ’ҹ.V))) вҲ© рқ’ҹ.closedPolydisc R

end AdmissibleDatum

theorem supNorm_eq_norm (рқ’ҹ : AdmissibleDatum) (z : рқ’ҹ.V) : рқ’ҹ.supNorm z = вҖ–zвҖ– := by
  unfold AdmissibleDatum.supNorm
  apply le_antisymm
  В· exact (Finset.sup'_le_iff (H := вҹЁвҹЁ0, рқ’ҹ.f_posвҹ©, Finset.mem_univ _вҹ©)
      (f := fun r : Fin рқ’ҹ.f => вҖ–z rвҖ–)).2 (fun b hb => by
        simpa using norm_le_pi_norm z b)
  В· apply (pi_norm_le_iff_of_nonneg ?_).2
    В· intro i
      exact Finset.le_sup' (f := fun r : Fin рқ’ҹ.f => вҖ–z rвҖ–) (Finset.mem_univ i)
    В· exact le_trans (norm_nonneg (z вҹЁ0, рқ’ҹ.f_posвҹ©))
        (Finset.le_sup' (f := fun r : Fin рқ’ҹ.f => вҖ–z rвҖ–) (Finset.mem_univ _))

instance Оӣ_discreteTopology_inst (рқ’ҹ : AdmissibleDatum) :
    DiscreteTopology рқ’ҹ.Оӣ :=
  рқ’ҹ.Оӣ_discreteTopology

instance Оӣ_IsZLattice (рқ’ҹ : AdmissibleDatum) :
    IsZLattice в„қ рқ’ҹ.Оӣ where
  span_top := рқ’ҹ.Оӣ_spans_top

theorem X_finite (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) :
    (рқ’ҹ.X a R).Finite := by
  classical
  let s : Set рқ’ҹ.V := Set.range (fun l : рқ’ҹ.Оӣ => a + (l : рқ’ҹ.V))
  have hs_discrete : IsDiscrete s := by
    letI : DiscreteTopology рқ’ҹ.Оӣ := рқ’ҹ.Оӣ_discreteTopology
    let П„ : рқ’ҹ.V вҶ’ рқ’ҹ.V := fun z => a + z
    have hП„ : Topology.IsEmbedding П„ := by
      refine Topology.IsEmbedding.of_leftInverse
        (f := fun z : рқ’ҹ.V => z - a) (g := П„) ?_ ?_ ?_
      В· intro z
        simp [П„, sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
      В· simpa using (continuous_id.sub continuous_const)
      В· simpa [П„] using (continuous_const.add continuous_id)
    have hs_emb : Topology.IsEmbedding (fun l : рқ’ҹ.Оӣ => a + (l : рқ’ҹ.V)) := by
      simpa [П„, Function.comp] using hП„.comp Topology.IsEmbedding.subtypeVal
    simpa [s] using (IsEmbedding.isDiscrete_range hs_emb)
  have hs_closed : IsClosed s := by
    let H : Subgroup (Multiplicative рқ’ҹ.V) := рқ’ҹ.Оӣ.toAddSubgroup.toSubgroup
    letI : DiscreteTopology H := by
      simpa [H] using (рқ’ҹ.Оӣ_discreteTopology)
    have hОӣclosed : IsClosed ((рқ’ҹ.Оӣ : Set рқ’ҹ.V)) := by
      simpa [H] using (Subgroup.isClosed_of_discrete (H := H))
    have hs_eq : s = (fun z : рқ’ҹ.V => z - a) вҒ»В№' (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
      ext z
      constructor
      В· rintro вҹЁl, rflвҹ©
        simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
      В· intro hz
        refine вҹЁвҹЁz - a, hzвҹ©, ?_вҹ©
        simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
    rw [hs_eq]
    exact hОӣclosed.preimage (continuous_id.sub continuous_const)
  have hbounded : Bornology.IsBounded (рқ’ҹ.closedPolydisc R) := by
    have hsubset : рқ’ҹ.closedPolydisc R вҠҶ Metric.closedBall (0 : рқ’ҹ.V) (max R 0) := by
      intro z hz
      have hz' : рқ’ҹ.supNorm z вүӨ max R 0 := le_trans hz (le_max_left R 0)
      letI : Nonempty (Fin рқ’ҹ.f) := вҹЁвҹЁ0, рқ’ҹ.f_posвҹ©вҹ©
      have hcoord : вҲҖ i : Fin рқ’ҹ.f, вҖ–z iвҖ– вүӨ max R 0 := by
        intro i
        exact le_trans
          (Finset.le_sup' (s := Finset.univ) (f := fun r : Fin рқ’ҹ.f => вҖ–z rвҖ–)
            (h := Finset.mem_univ i))
          hz'
      have hnorm : вҖ–zвҖ– вүӨ max R 0 :=
        (pi_norm_le_iff_of_nonempty (f := z) (r := max R 0)).2 hcoord
      simpa [Metric.mem_closedBall, dist_eq_norm] using hnorm
    exact (Metric.isBounded_closedBall : Bornology.IsBounded (Metric.closedBall (0 : рқ’ҹ.V) (max R 0))).subset hsubset
  have hfin := Metric.finite_isBounded_inter_isClosed hs_discrete hbounded hs_closed
  simpa [AdmissibleDatum.X, s, Set.inter_comm] using hfin

namespace AdmissibleDatum
variable (рқ’ҹ : AdmissibleDatum)

noncomputable def X_finset (a : рқ’ҹ.V) (R : в„қ) : Finset рқ’ҹ.V :=
  (X_finite рқ’ҹ a R).toFinset

noncomputable def N_count (a : рқ’ҹ.V) (R : в„қ) : в„• := (рқ’ҹ.X_finset a R).card

noncomputable def E_count (a : рқ’ҹ.V) (R : в„қ) (U : Finset рқ’ҹ.K) : в„• :=
  вҲ‘ u вҲҲ U, ((рқ’ҹ.X_finset a R).filter
    (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card

noncomputable def b (_рқ’ҹ : AdmissibleDatum) (R : в„қ) : в„қ := Real.pi * R ^ 2

noncomputable def ПҖ1 (z : рқ’ҹ.V) : в„Ӯ := z вҹЁ0, рқ’ҹ.f_posвҹ©

noncomputable def P_set (a : рқ’ҹ.V) (R : в„қ) : Finset Point :=
  (рқ’ҹ.X_finset a R).image (fun z : рқ’ҹ.V =>
    (EuclideanSpace.equiv (Fin 2) в„қ).symm ![(рқ’ҹ.ПҖ1 z).re, (рқ’ҹ.ПҖ1 z).im])

end AdmissibleDatum

namespace AdmissibleDatum
variable (рқ’ҹ : AdmissibleDatum)

noncomputable def ПҒ (R : в„қ) : в„қ := overlapArea R / рқ’ҹ.b R

def IsNormOneIntegral (u : рқ’ҹ.K) : Prop :=
  (рқ’ҹ.relNorm u = 1) вҲ§
  (вҲҖ Пғ : рқ’ҹ.K вҶ’+* в„Ӯ, вҖ–Пғ uвҖ– = 1) вҲ§

  (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) x)

end AdmissibleDatum

abbrev proposition_2_2_choice_type (рқ’ҹ : AdmissibleDatum) : Type := (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Bool

theorem proposition_2_2_choice_type_natCard (рқ’ҹ : AdmissibleDatum) : Nat.card (proposition_2_2_choice_type рқ’ҹ) = 2 ^ (рқ’ҹ.t * рқ’ҹ.f) := by
  classical
  unfold proposition_2_2_choice_type
  rw [Nat.card_fun, Nat.card_prod, Nat.card_fin, Nat.card_fin, Nat.card_eq_fintype_card, Fintype.card_bool]

theorem proposition_2_2_classGroup_natCard (рқ’ҹ : AdmissibleDatum) : Nat.card (ClassGroup (рқ“һ рқ’ҹ.K)) = NumberField.classNumber рқ’ҹ.K := by
  simp [NumberField.classNumber]

theorem proposition_2_2_conductor_coprime_p (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) (p : Ideal (рқ“һ рқ’ҹ.L))
    (hp0 : p вү  вҠҘ) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)))
    (Оё : рқ“һ рқ’ҹ.K)
    (hОё : ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K))
    (hmin : minpoly (рқ“һ рқ’ҹ.L) Оё = Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L)) :
    (conductor (рқ“һ рқ’ҹ.L) Оё).comap (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҠ” p = вҠӨ := by
  let I : Ideal (рқ“һ рқ’ҹ.L) := (conductor (рқ“һ рқ’ҹ.L) Оё).comap (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
  let pZ : Ideal в„Ө := Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)
  have hgen : Algebra.adjoin рқ’ҹ.L ({((Оё : рқ’ҹ.K))} : Set рқ’ҹ.K) = вҠӨ := by
    simpa [hОё] using рқ’ҹ.adjoin_i_K_eq_top
  have htwoОё : (2 : рқ“һ рқ’ҹ.K) * Оё вҲҲ conductor (рқ“һ рқ’ҹ.L) Оё := by
    have hdiff :=
        conductor_mul_differentIdeal (A := рқ“һ рқ’ҹ.L) (B := рқ“һ рқ’ҹ.K)
          (K := рқ’ҹ.L) (L := рқ’ҹ.K) (x := Оё) hgen
    have hmem :
        Polynomial.aeval Оё (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) Оё)) вҲҲ
          (conductor (рқ“һ рқ’ҹ.L) Оё) * differentIdeal (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) := by
      rw [hdiff]
      exact Ideal.subset_span (by simp)
    have hmem' :
        Polynomial.aeval Оё (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) Оё)) вҲҲ
          conductor (рқ“һ рқ’ҹ.L) Оё := by
      exact Ideal.mul_le_right hmem
    have hEval :
        Polynomial.aeval Оё (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) Оё)) =
          (2 : рқ“һ рқ’ҹ.K) * Оё := by
      rw [hmin]
      simp [two_mul, add_mul]
    rw [hEval] at hmem'
    exact hmem'
  have hОёsqK : ((Оё : рқ’ҹ.K) * (Оё : рқ’ҹ.K)) = (-1 : рқ’ҹ.K) := by
    rw [hОё]
    simpa using рқ’ҹ.i_K_sq
  have hОёinv : Оё * (-Оё) = (1 : рқ“һ рқ’ҹ.K) := by
    apply Subtype.coe_injective
    change ((Оё : рқ’ҹ.K) * (-Оё : рқ’ҹ.K)) = 1
    rw [mul_neg, hОёsqK]
    simp
  have hОёunit : IsUnit Оё :=
    (isUnit_iff_exists_inv).2 вҹЁ-Оё, hОёinvвҹ©
  have htwo : (2 : рқ“һ рқ’ҹ.K) вҲҲ conductor (рқ“һ рқ’ҹ.L) Оё :=
    (Ideal.mul_unit_mem_iff_mem (I := conductor (рқ“һ рқ’ҹ.L) Оё)
      (x := (2 : рқ“һ рқ’ҹ.K)) (y := Оё) hОёunit).1 htwoОё
  have htwoI : (2 : рқ“һ рқ’ҹ.L) вҲҲ I := by
    rw [show I = _ by rfl, Ideal.mem_comap]
    have h2map : (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) (2 : рқ“һ рқ’ҹ.L)) = (2 : рқ“һ рқ’ҹ.K) := by
      simpa using (map_natCast (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) 2)
    simpa [h2map] using htwo
  have hnot2p : (2 : рқ“һ рқ’ҹ.L) вҲү p := by
    intro h2p
    letI : p.LiesOver pZ := hp_lies
    have h2Z : (2 : в„Ө) вҲҲ pZ := by
      exact (Ideal.mem_of_liesOver (P := p) (p := pZ) (x := (2 : в„Ө))).2 (by simpa using h2p)
    rw [show pZ = Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө) by rfl] at h2Z
    rw [Ideal.mem_span_singleton] at h2Z
    have hq2 : рқ’ҹ.q b вҲЈ 2 := by
      simpa using (Int.natCast_dvd (n := (2 : в„Ө)) (m := рқ’ҹ.q b)).1 h2Z
    have hqeq : рқ’ҹ.q b = 2 :=
      (Nat.prime_dvd_prime_iff_eq (рқ’ҹ.q_prime b) Nat.prime_two).1 hq2
    have hmod : (2 : в„•) % 4 = 1 := by
      simpa [hqeq] using рқ’ҹ.q_mod4 b
    norm_num at hmod
  have hp_max : p.IsMaximal := hp_prime.isMaximal hp0
  change I вҠ” p = вҠӨ
  have hOne : (1 : рқ“һ рқ’ҹ.L) вҲҲ I вҠ” p := by
    exact (Ideal.isMaximal_iff.mp hp_max).2 (I вҠ” p) (2 : рқ“һ рқ’ҹ.L) le_sup_right hnot2p
      (Ideal.mem_sup_left htwoI)
  apply top_unique
  intro x hx
  exact Ideal.mem_of_one_mem hOne x

noncomputable def proposition_2_2_conjIdeal (рқ’ҹ : AdmissibleDatum) (I : Ideal (рқ“һ рқ’ҹ.K)) : Ideal (рқ“һ рқ’ҹ.K) := I.map (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K))

theorem proposition_2_2_conjIdeal_involutive (рқ’ҹ : AdmissibleDatum) (I : Ideal (рқ“һ рқ’ҹ.K)) :
    proposition_2_2_conjIdeal рқ’ҹ (proposition_2_2_conjIdeal рқ’ҹ I) = I := by
  let e : рқ“һ рқ’ҹ.K вүғ+* рқ“һ рқ’ҹ.K := NumberField.RingOfIntegers.mapRingEquiv (рқ’ҹ.c : рқ’ҹ.K вүғ+* рқ’ҹ.K)
  have he : e.symm = e := by
    ext x
    change рқ’ҹ.c.symm (x : рқ’ҹ.K) = рқ’ҹ.c (x : рқ’ҹ.K)
    apply рқ’ҹ.c.injective
    have h1 : рқ’ҹ.c (рқ’ҹ.c.symm (x : рқ’ҹ.K)) = (x : рқ’ҹ.K) := by
      simp
    have h2 : рқ’ҹ.c (рқ’ҹ.c (x : рқ’ҹ.K)) = (x : рқ’ҹ.K) := by
      simpa using рқ’ҹ.c_sq_eq_id (x : рқ’ҹ.K)
    exact h1.trans h2.symm
  simpa [proposition_2_2_conjIdeal, e, he] using (Ideal.map_of_equiv (I := I) e)

theorem proposition_2_2_conj_aeval_X_sub_C (рқ’ҹ : AdmissibleDatum) (Оё : рқ“һ рқ’ҹ.K)
    (hОё : ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K)) (a : рқ“һ рқ’ҹ.L) :
    (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K))
      (((Polynomial.X - Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)) =
    -(((Polynomial.X + Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)) := by
  rw [вҶҗ Polynomial.aeval_algHom_apply
    (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)) Оё
    (Polynomial.X - Polynomial.C a)]
  have hmapОё :
      (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)) Оё = -Оё := by
    ext
    change рқ’ҹ.c (Оё : рқ’ҹ.K) = -(Оё : рқ’ҹ.K)
    rw [hОё, рқ’ҹ.c_i_K]
  rw [hmapОё]
  simp [Polynomial.aeval_X, Polynomial.aeval_C]
  ring

theorem proposition_2_2_conjIdeal_span_X_sub_C_eq_span_X_add_C (рқ’ҹ : AdmissibleDatum) (Оё : рқ“һ рқ’ҹ.K)
    (hОё : ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K)) (p : Ideal (рқ“һ рқ’ҹ.L)) (a : рқ“һ рқ’ҹ.L) :
    proposition_2_2_conjIdeal рқ’ҹ
      (Ideal.span
        (p.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҲӘ
          {((Polynomial.X - Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)})) =
    Ideal.span
      (p.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҲӘ
        {((Polynomial.X + Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)}) := by
  unfold proposition_2_2_conjIdeal
  let Оұ : рқ“һ рқ’ҹ.L вҶ’+* рқ“һ рқ’ҹ.K := algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)
  let Пғ : рқ“һ рқ’ҹ.K вүғвӮҗ[рқ“һ рқ’ҹ.L] рқ“һ рқ’ҹ.K :=
    NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
  let x : рқ“һ рқ’ҹ.K := ((Polynomial.X - Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)
  let y : рқ“һ рқ’ҹ.K := ((Polynomial.X + Polynomial.C a : Polynomial (рқ“һ рқ’ҹ.L)).aeval Оё)
  change (Ideal.span (p.map Оұ вҲӘ ({x} : Set (рқ“һ рқ’ҹ.K)))).map Пғ =
      Ideal.span (p.map Оұ вҲӘ ({y} : Set (рқ“һ рқ’ҹ.K)))
  rw [Ideal.span_union, Ideal.map_sup, Ideal.span_union]
  have hbase : Ideal.map (Пғ : рқ“һ рқ’ҹ.K вҶ’+* рқ“һ рқ’ҹ.K)
      (Ideal.span ((p.map Оұ : Ideal (рқ“һ рқ’ҹ.K)) : Set (рқ“һ рқ’ҹ.K))) = p.map Оұ := by
    rw [Ideal.span_eq, Ideal.map_map]
    congr
    ext b
    simp [Function.comp, Оұ, Пғ, AlgEquiv.commutes]
  have hsingle : Ideal.map (Пғ : рқ“һ рқ’ҹ.K вҶ’+* рқ“һ рқ’ҹ.K) (Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K))) =
      Ideal.span ({y} : Set (рқ“һ рқ’ҹ.K)) := by
    rw [Ideal.map_span, Set.image_singleton]
    change Ideal.span ({Пғ x} : Set (рқ“һ рқ’ҹ.K)) = Ideal.span ({y} : Set (рқ“һ рқ’ҹ.K))
    rw [show Пғ x = -y by
      simpa [x, y, Пғ] using proposition_2_2_conj_aeval_X_sub_C рқ’ҹ Оё hОё a]
    simp
  change Ideal.map (Пғ : рқ“һ рқ’ҹ.K вҶ’+* рқ“һ рқ’ҹ.K)
      (Ideal.span ((p.map Оұ : Ideal (рқ“һ рқ’ҹ.K)) : Set (рқ“һ рқ’ҹ.K))) вҠ”
      Ideal.map (Пғ : рқ“һ рқ’ҹ.K вҶ’+* рқ“һ рқ’ҹ.K) (Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K))) =
    Ideal.span ((p.map Оұ : Ideal (рқ“һ рқ’ҹ.K)) : Set (рқ“һ рқ’ҹ.K)) вҠ” Ideal.span ({y} : Set (рқ“һ рқ’ҹ.K))
  rw [hbase, hsingle, Ideal.span_eq]

theorem proposition_2_2_fiber_principal_generator_injective (рқ’ҹ : AdmissibleDatum)
    (I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K))
    (hI_nonzero : вҲҖ Оө, I Оө вү  вҠҘ)
    (hI_cross : вҲҖ {Оө О· : proposition_2_2_choice_type рқ’ҹ},
      I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) =
        I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) вҶ’ Оө = О·)
    (C : ClassGroup (рқ“һ рқ’ҹ.K))
    (ОөвӮҖ : proposition_2_2_choice_type рқ’ҹ)
    (xgen : {Оө : proposition_2_2_choice_type рқ’ҹ //
          ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C} вҶ’ рқ“һ рқ’ҹ.K)
    (hxgen_nonzero : вҲҖ Оө, xgen Оө вү  0)
    (hxgen_ideal : вҲҖ Оө,
      I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) =
        Ideal.span ({xgen Оө} : Set (рқ“һ рқ’ҹ.K))) :
    Function.Injective (fun Оө => ((xgen Оө : рқ’ҹ.K) / рқ’ҹ.c (xgen Оө : рқ’ҹ.K))) := by
  intro Оө О· hratio
  apply Subtype.ext
  apply hI_cross
  let xОө : рқ“һ рқ’ҹ.K := xgen Оө
  let xО· : рқ“һ рқ’ҹ.K := xgen О·
  let Пғ : (рқ“һ рқ’ҹ.K) вүғвӮҗ[рқ“һ рқ’ҹ.L] (рқ“һ рқ’ҹ.K) :=
    NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
  have hxОө : (xОө : рқ’ҹ.K) вү  0 := by
    exact_mod_cast hxgen_nonzero Оө
  have hxО· : (xО· : рқ’ҹ.K) вү  0 := by
    exact_mod_cast hxgen_nonzero О·
  have hcОө : рқ’ҹ.c (xОө : рқ’ҹ.K) вү  0 := by
    intro h
    apply hxОө
    exact рқ’ҹ.c.injective (by simpa using h)
  have hcО· : рқ’ҹ.c (xО· : рқ’ҹ.K) вү  0 := by
    intro h
    apply hxО·
    exact рқ’ҹ.c.injective (by simpa using h)
  have hxy : (xОө : рқ’ҹ.K) * рқ’ҹ.c (xО· : рқ’ҹ.K) = (xО· : рқ’ҹ.K) * рқ’ҹ.c (xОө : рқ’ҹ.K) := by
    exact (div_eq_div_iff hcОө hcО·).mp hratio
  have hПғПғ' :
      Ideal.map (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K))
        (Ideal.map (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)) (I ОөвӮҖ)) = I ОөвӮҖ := by
    simpa [proposition_2_2_conjIdeal] using proposition_2_2_conjIdeal_involutive рқ’ҹ (I ОөвӮҖ)
  have hconjО· :
      proposition_2_2_conjIdeal рқ’ҹ (I О·.1) * I ОөвӮҖ =
        Ideal.span ({Пғ xО·} : Set (рқ“һ рқ’ҹ.K)) := by
    have h' := congrArg (proposition_2_2_conjIdeal рқ’ҹ) (hxgen_ideal О·)
    simp [proposition_2_2_conjIdeal, Пғ, Ideal.map_mul, Ideal.map_span, Set.image_singleton] at h'
    rw [hПғПғ'] at h'
    simpa [Пғ, proposition_2_2_conjIdeal] using h'
  have hconjОө :
      proposition_2_2_conjIdeal рқ’ҹ (I Оө.1) * I ОөвӮҖ =
        Ideal.span ({Пғ xОө} : Set (рқ“һ рқ’ҹ.K)) := by
    have h' := congrArg (proposition_2_2_conjIdeal рқ’ҹ) (hxgen_ideal Оө)
    simp [proposition_2_2_conjIdeal, Пғ, Ideal.map_mul, Ideal.map_span, Set.image_singleton] at h'
    rw [hПғПғ'] at h'
    simpa [Пғ, proposition_2_2_conjIdeal] using h'
  have hxy_int : xОө * Пғ xО· = xО· * Пғ xОө := by
    apply NumberField.RingOfIntegers.coe_injective
    change (xОө : рқ’ҹ.K) * (Пғ xО· : рқ’ҹ.K) = (xО· : рқ’ҹ.K) * (Пғ xОө : рқ’ҹ.K)
    simpa [Пғ] using hxy
  have hprod :
      (I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I О·.1)) *
          (proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ) =
        (I О·.1 * proposition_2_2_conjIdeal рқ’ҹ (I Оө.1)) *
          (proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ) := by
    calc
      (I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I О·.1)) *
          (proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ)
          = (I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)) *
              (proposition_2_2_conjIdeal рқ’ҹ (I О·.1) * I ОөвӮҖ) := by
              simp [mul_assoc, mul_left_comm, mul_comm]
      _ = Ideal.span ({xОө} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({Пғ xО·} : Set (рқ“һ рқ’ҹ.K)) := by
            rw [hxgen_ideal Оө, hconjО·]
      _ = Ideal.span ({xО·} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({Пғ xОө} : Set (рқ“һ рқ’ҹ.K)) := by
            calc
              Ideal.span ({xОө} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({Пғ xО·} : Set (рқ“һ рқ’ҹ.K))
                  = Ideal.span ({xОө * Пғ xО·} : Set (рқ“һ рқ’ҹ.K)) := by
                      rw [Ideal.span_singleton_mul_span_singleton]
              _ = Ideal.span ({xО· * Пғ xОө} : Set (рқ“һ рқ’ҹ.K)) := by
                    rw [hxy_int]
              _ = Ideal.span ({xО·} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({Пғ xОө} : Set (рқ“һ рқ’ҹ.K)) := by
                    rw [Ideal.span_singleton_mul_span_singleton]
      _ = (I О·.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)) *
            (proposition_2_2_conjIdeal рқ’ҹ (I Оө.1) * I ОөвӮҖ) := by
            rw [hxgen_ideal О·, hconjОө]
      _ = (I О·.1 * proposition_2_2_conjIdeal рқ’ҹ (I Оө.1)) *
            (proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ) := by
            simp [mul_assoc, mul_left_comm, mul_comm]
  have hconj_nonzero : proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) вү  вҠҘ := by
    intro hbot
    apply hI_nonzero ОөвӮҖ
    exact (Ideal.map_eq_bot_iff_of_injective
      (I := I ОөвӮҖ)
      (f := NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K))
      (NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)).injective).1
      (by simpa [proposition_2_2_conjIdeal] using hbot)
  have hcommon_nonzero : proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ вү  вҠҘ := by
    exact mul_ne_zero hconj_nonzero (hI_nonzero ОөвӮҖ)
  exact mul_right_cancelвӮҖ (show proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) * I ОөвӮҖ вү  0 by simpa using hcommon_nonzero) hprod

theorem proposition_2_2_large_class_fiber (рқ’ҹ : AdmissibleDatum) (H : в„қ) (hH : 0 < H)
    (hClass : (NumberField.classNumber рқ’ҹ.K : в„қ) вүӨ H ^ рқ’ҹ.f)
    (I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K))
    (hI_nonzero : вҲҖ Оө, I Оө вү  вҠҘ) :
    вҲғ (C : ClassGroup (рқ“һ рқ’ҹ.K)) (ОөвӮҖ : proposition_2_2_choice_type рқ’ҹ),
      ClassGroup.mk0 вҹЁI ОөвӮҖ, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ОөвӮҖ)вҹ© = C вҲ§
      (((Nat.card {Оө : proposition_2_2_choice_type рқ’ҹ //
          ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C} : в„•) : в„қ)
        вүҘ Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f)) := by
  classical
  let g : proposition_2_2_choice_type рқ’ҹ вҶ’ ClassGroup (рқ“һ рқ’ҹ.K) :=
    fun Оө => ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ©
  have hcard_dom :
      ((Fintype.card (proposition_2_2_choice_type рқ’ҹ) : в„•) : в„қ) = (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) := by
    rw [Fintype.card_eq_nat_card, proposition_2_2_choice_type_natCard, Nat.cast_pow]
    norm_num
  have hcard_codom :
      ((Fintype.card (ClassGroup (рқ“һ рқ’ҹ.K)) : в„•) : в„қ) = (NumberField.classNumber рқ’ҹ.K : в„қ) := by
    rw [Fintype.card_eq_nat_card, proposition_2_2_classGroup_natCard]
  have hclass_pos : (0 : в„қ) < NumberField.classNumber рқ’ҹ.K := by
    exact_mod_cast (NumberField.classNumber_pos (K := рқ’ҹ.K))
  have hclass_ne : (NumberField.classNumber рқ’ҹ.K : в„қ) вү  0 := by
    exact ne_of_gt hclass_pos
  have hb :
      Fintype.card (ClassGroup (рқ“һ рқ’ҹ.K)) вҖў ((2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / NumberField.classNumber рқ’ҹ.K) вүӨ
        (Fintype.card (proposition_2_2_choice_type рқ’ҹ) : в„қ) := by
    rw [nsmul_eq_mul, hcard_codom, hcard_dom]
    simpa [hclass_ne] using (le_of_eq (mul_div_cancelвӮҖ ((2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f)) hclass_ne))
  obtain вҹЁC, hCвҹ© :=
    Fintype.exists_le_card_fiber_of_nsmul_le_card g
      (b := (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / NumberField.classNumber рқ’ҹ.K) hb
  have hC_nat :
      (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / NumberField.classNumber рқ’ҹ.K вүӨ
        (((Nat.card {Оө : proposition_2_2_choice_type рқ’ҹ // g Оө = C} : в„•) : в„қ)) := by
    simpa [Nat.card_eq_fintype_card, Fintype.card_subtype, g] using hC
  have hquot_pos : 0 < (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / NumberField.classNumber рқ’ҹ.K := by
    have hpow_pos : 0 < (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) := by positivity
    exact div_pos hpow_pos hclass_pos
  have hfiber_pos : 0 < Nat.card {Оө : proposition_2_2_choice_type рқ’ҹ // g Оө = C} := by
    exact Nat.cast_pos.mp (lt_of_lt_of_le hquot_pos hC_nat)
  obtain вҹЁОөвӮҖвҹ© := Finite.card_pos_iff.mp hfiber_pos
  refine вҹЁC, ОөвӮҖ.1, ОөвӮҖ.2, ?_вҹ©
  have hExpEq :
      Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f) = ((2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f)) / H ^ рқ’ҹ.f := by
    calc
      Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f)
          = (Real.exp (рқ’ҹ.t * Real.log 2 - Real.log H)) ^ (рқ’ҹ.f : в„қ) := by
              rw [Real.exp_mul]
      _ = (Real.exp (рқ’ҹ.t * Real.log 2) / Real.exp (Real.log H)) ^ (рқ’ҹ.f : в„қ) := by
              rw [Real.exp_sub]
      _ = (((2 : в„қ) ^ рқ’ҹ.t) / H) ^ (рқ’ҹ.f : в„қ) := by
              rw [show Real.exp ((рқ’ҹ.t : в„қ) * Real.log 2) = (2 : в„қ) ^ рқ’ҹ.t by
                    rw [mul_comm, Real.exp_mul, Real.exp_log (by positivity), Real.rpow_natCast],
                  Real.exp_log hH]
      _ = (((2 : в„қ) ^ рқ’ҹ.t) ^ рқ’ҹ.f) / H ^ рқ’ҹ.f := by
              rw [Real.div_rpow (by positivity) hH.le, Real.rpow_natCast, Real.rpow_natCast]
      _ = (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / H ^ рқ’ҹ.f := by rw [вҶҗ pow_mul]
  have hexp_le_quot : Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f) вүӨ
      (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) / NumberField.classNumber рқ’ҹ.K := by
    rw [hExpEq]
    have hpow_nonneg : (0 : в„қ) вүӨ (2 : в„қ) ^ (рқ’ҹ.t * рқ’ҹ.f) := by positivity
    exact div_le_div_of_nonneg_left hpow_nonneg hclass_pos hClass
  exact le_trans hexp_le_quot hC_nat


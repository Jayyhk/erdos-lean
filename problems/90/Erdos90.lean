    (∃ b : ℝ, 0 < b ∧ ∃ n₀ : ℕ, ∀ n : ℕ, n₀ ≤ n →
      b * (⌊c ^ n⌋₊ : ℝ) ≤ ∑ k ∈ Finset.range ⌊c ^ n⌋₊, f k) →
    ∃ d : ℝ, 0 < d ∧ ∃ X₀ : ℕ, ∀ X : ℕ, X₀ ≤ X →
      d * X ≤ ∑ k ∈ Finset.range X, f k := by

    exact hfield_map_eq

theorem isArithFrobAt_restrictNormal (F M N : Type) [Field F] [Field M] [Field N]
    [NumberField F] [NumberField M] [NumberField N]
    [Algebra F M] [Algebra F N] [Algebra M N] [IsScalarTower F M N]
    [FiniteDimensional F M] [FiniteDimensional F N] [Normal F M] [IsGalois F N]
    (𝔭 : Ideal (𝓞 F))
    (𝔔 : Ideal (𝓞 N)) (h𝔔 : 𝔔 ∈ 𝔭.primesOver (𝓞 N))
    (τ : N ≃ₐ[F] N)
    (hτ : AlgHom.IsArithFrobAt (R := 𝓞 F)
      ((NumberField.RingOfIntegers.mapAlgEquiv τ).toAlgHom) 𝔔) :
    AlgHom.IsArithFrobAt (R := 𝓞 F)
      ((NumberField.RingOfIntegers.mapAlgEquiv (((AlgEquiv.restrictNormalHom (F := F) (K₁ := N) M) τ))).toAlgHom)
      (Ideal.comap (algebraMap (𝓞 M) (𝓞 N)) 𝔔) := by
  intro x
  have hcomm :
      algebraMap (𝓞 M) (𝓞 N)
          (((NumberField.RingOfIntegers.mapAlgEquiv
            (((AlgEquiv.restrictNormalHom (F := F) (K₁ := N) M) τ))).toAlgHom) x)
        =
      ((NumberField.RingOfIntegers.mapAlgEquiv τ).toAlgHom) (algebraMap (𝓞 M) (𝓞 N) x) := by
    apply NumberField.RingOfIntegers.ext
    change
      algebraMap M N ((((AlgEquiv.restrictNormalHom (F := F) (K₁ := N) M) τ) : M ≃ₐ[F] M) (x : M)) =
        τ (algebraMap M N (x : M))
    exact AlgEquiv.restrictNormal_commutes (χ := τ) (E := M) (x := (x : M))
  rw [Ideal.mem_comap]
  rw [map_sub, map_pow, hcomm]
  simpa only [Ideal.under_def, Ideal.under_under] using hτ (algebraMap (𝓞 M) (𝓞 N) x)

theorem local_unramified_descends_in_tower (F K L : Type) [Field F] [Field K] [Field L]
    [NumberField F] [NumberField K] [NumberField L]
    [Algebra F K] [Algebra F L] [Algebra K L] [IsScalarTower F K L]
    [FiniteDimensional F K] [FiniteDimensional F L]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥)
    (hL_unr : ∀ 𝔔 ∈ 𝔭.primesOver (𝓞 L), Ideal.ramificationIdx 𝔭 𝔔 = 1) :
    ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 K), Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
  intro 𝔓 h𝔓
  let 𝔓' : Ideal.primesOver 𝔭 (𝓞 K) := ⟨𝔓, h𝔓⟩
  haveI : 𝔓.IsPrime := Ideal.primesOver.isPrime 𝔭 𝔓'
  haveI : 𝔓.LiesOver 𝔭 := Ideal.primesOver.liesOver 𝔭 𝔓'
  obtain ⟨𝔔'⟩ := Ideal.nonempty_primesOver (R := 𝓞 K) (S := 𝓞 L) 𝔓
  haveI : (𝔔' : Ideal (𝓞 L)).IsPrime := Ideal.primesOver.isPrime 𝔓 𝔔'
  haveI : (𝔔' : Ideal (𝓞 L)).LiesOver 𝔓 := Ideal.primesOver.liesOver 𝔓 𝔔'
  haveI : (𝔔' : Ideal (𝓞 L)).LiesOver 𝔭 := Ideal.LiesOver.trans (𝔔' : Ideal (𝓞 L)) 𝔓 𝔭
  have h𝔔_over_p : (𝔔' : Ideal (𝓞 L)) ∈ 𝔭.primesOver (𝓞 L) :=
    (Ideal.primesOver.mk 𝔭 (𝔔' : Ideal (𝓞 L))).property
  have hQne : (𝔔' : Ideal (𝓞 L)) ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hne h𝔔_over_p
  have hQunr : Algebra.IsUnramifiedAt (𝓞 F) (𝔔' : Ideal (𝓞 L)) := by
    exact
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
          (R := 𝓞 F) (S := 𝓞 L) (p := (𝔔' : Ideal (𝓞 L))) hQne).2
        (by
          simpa [Ideal.over_def (A := 𝓞 F) (P := (𝔔' : Ideal (𝓞 L))) (p := 𝔭)] using
            hL_unr (𝔔' : Ideal (𝓞 L)) h𝔔_over_p)
  have hPunr : Algebra.IsUnramifiedAt (𝓞 F) 𝔓 := by
    letI : Algebra.IsUnramifiedAt (𝓞 F) (𝔔' : Ideal (𝓞 L)) := hQunr
    exact Algebra.IsUnramifiedAt.of_liesOver (R := 𝓞 F) (p := 𝔓) (P := (𝔔' : Ideal (𝓞 L)))
  have hPne : 𝔓 ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hne h𝔓
  exact
    by
      simpa [Ideal.over_def (A := 𝓞 F) (P := 𝔓) (p := 𝔭)] using
        (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
            (R := 𝓞 F) (S := 𝓞 K) (p := 𝔓) hPne).1 hPunr

noncomputable def maximalUnramifiedFiniteStage
    (F : Type) [Field F] [NumberField F]
    (p : ℕ) [Fact (Nat.Prime p)]
    (s : Finset (maximalUnramifiedProPFIndex F p)) :
    IntermediateField F (AlgebraicClosure F) :=
  ⨆ i ∈ s, i.M

theorem maximalUnramified_restrictNormalHom_surjective (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (M : IntermediateField F (maximalUnramifiedProPF F p)) [Normal F M] :
    Function.Surjective ((AlgEquiv.restrictNormalHom (F := F)
      (K₁ := maximalUnramifiedProPF F p) M) :
      MaxUnramifiedProPGaloisGroup F p →* (M ≃ₐ[F] M)) := by
  haveI : Normal F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.normal_maximalUnramifiedProPF F p
  simpa [MaxUnramifiedProPGaloisGroup] using
    (AlgEquiv.restrictNormalHom_surjective (F := F)
      (K₁ := M) (E := maximalUnramifiedProPF F p))

theorem normal_numberField_intermediate_fg {F K : Type*} [Field F] [Field K] [Algebra F K]
    (M : IntermediateField F K) [FiniteDimensional F M] [Normal F M] [NumberField M] :
    M.FG := by
  letI : Algebra.FiniteType F M := Module.Finite.finiteType M
  letI : Algebra.EssFiniteType F M := Algebra.EssFiniteType.of_finiteType F M
  exact (IntermediateField.essFiniteType_iff (F := F) (E := K) (K := M)).1 inferInstance

theorem restrictNormal_mem_inertia_comap (F : Type) [Field F] [NumberField F]
    (E K : IntermediateField F (AlgebraicClosure F))
    [NumberField ↥E] [NumberField ↥K]
    [Algebra ↥K ↥E] [IsScalarTower F ↥K ↥E]
    [Normal F ↥K]
    (𝔖 : Ideal (𝓞 ↥E))
    {σ : ↥E ≃ₐ[F] ↥E} :
    σ ∈ 𝔖.inertia (↥E ≃ₐ[F] ↥E) →
      (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) ∈
        (Ideal.comap
          (NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F ↥K ↥E))
          𝔖).inertia (↥K ≃ₐ[F] ↥K) := by
  intro hσ
  rw [AddSubgroup.mem_inertia] at hσ ⊢
  intro x
  let f : 𝓞 ↥K →ₐ[𝓞 F] 𝓞 ↥E :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F ↥K ↥E)
  change ((AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) • x - x : 𝓞 ↥K) ∈ Ideal.comap f 𝔖
  rw [Ideal.mem_comap]
  rw [show f (((AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) • x - x : 𝓞 ↥K)) =
      f ((AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) • x) - f x by
    simp]
  have hcomm :
      f ((AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) • x) = σ • f x := by
    apply NumberField.RingOfIntegers.ext
    change algebraMap ↥K ↥E (((AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥E) ↥K σ) x : ↥K)) =
      σ (algebraMap ↥K ↥E (x : ↥K))
    simpa only [f] using
      (AlgEquiv.restrictNormal_commutes (χ := σ) (E := ↥K) (x := (x : ↥K)))
  have hσx := hσ (f x)
  simpa [hcomm] using hσx

theorem restrict_eq_one_of_eq_one_on_sup_left_right (F : Type) [Field F] [NumberField F]
    (K L : IntermediateField F (AlgebraicClosure F))
    [Normal F ↥K] [Normal F ↥L] [Normal F ↥(K ⊔ L)]
    [Algebra ↥K ↥(K ⊔ L)] [Algebra ↥L ↥(K ⊔ L)]
    [IsScalarTower F ↥K ↥(K ⊔ L)] [IsScalarTower F ↥L ↥(K ⊔ L)]
    (σ : ↥(K ⊔ L) ≃ₐ[F] ↥(K ⊔ L))
    (hAlgK : ∀ x : ↥K,
      algebraMap ↥K ↥(K ⊔ L) x = IntermediateField.inclusion le_sup_left x)
    (hAlgL : ∀ x : ↥L,
      algebraMap ↥L ↥(K ⊔ L) x = IntermediateField.inclusion le_sup_right x)
    (hK : (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥K σ) = 1)
    (hL : (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥L σ) = 1) :
    σ = 1 := by
  have hKx : ∀ x : ↥K, (σ.restrictNormal ↥K) x = x := by
    intro x
    have hx := congrArg (fun e : ↥K ≃ₐ[F] ↥K => e x) hK
    simpa using hx
  have hLx : ∀ x : ↥L, (σ.restrictNormal ↥L) x = x := by
    intro x
    have hx := congrArg (fun e : ↥L ≃ₐ[F] ↥L => e x) hL
    simpa using hx
  have hfixK : ∀ x : ↥K, σ (algebraMap ↥K ↥(K ⊔ L) x) = algebraMap ↥K ↥(K ⊔ L) x := by
    intro x
    have hcomm := AlgEquiv.restrictNormal_commutes (χ := σ) (E := ↥K) (x := x)
    rw [hKx x] at hcomm
    simpa using hcomm.symm
  have hfixL : ∀ x : ↥L, σ (algebraMap ↥L ↥(K ⊔ L) x) = algebraMap ↥L ↥(K ⊔ L) x := by
    intro x
    have hcomm := AlgEquiv.restrictNormal_commutes (χ := σ) (E := ↥L) (x := x)
    rw [hLx x] at hcomm
    simpa using hcomm.symm
  have hS :
      (K ⊔ L : IntermediateField F (AlgebraicClosure F)) =
        IntermediateField.adjoin F ((K : Set (AlgebraicClosure F)) ∪ L) := by
    simpa using (IntermediateField.sup_def K L)
  have hσ_alg : (σ : ↥(K ⊔ L) →ₐ[F] ↥(K ⊔ L)) = 1 := by
    refine IntermediateField.algHom_ext_of_eq_adjoin (F := F) (S := K ⊔ L) hS ?_
    intro x hx
    rcases hx with hx | hx
    · let xE : ↥(K ⊔ L) :=
        ⟨x,
          hS.ge
            (IntermediateField.subset_adjoin F ((K : Set (AlgebraicClosure F)) ∪ L)
              (Or.inl hx))⟩
      let e : ↥K := ⟨x, hx⟩
      have hxE : xE = algebraMap ↥K ↥(K ⊔ L) e := by
        ext
        rw [hAlgK e]
        simp [xE, e]
      calc
        σ xE = σ (algebraMap ↥K ↥(K ⊔ L) e) := by rw [hxE]
        _ = algebraMap ↥K ↥(K ⊔ L) e := hfixK _
        _ = (1 : ↥(K ⊔ L) →ₐ[F] ↥(K ⊔ L)) xE := by rw [hxE]; rfl
    · let xE : ↥(K ⊔ L) :=
        ⟨x,
          hS.ge
            (IntermediateField.subset_adjoin F ((K : Set (AlgebraicClosure F)) ∪ L)
              (Or.inr hx))⟩
      let e : ↥L := ⟨x, hx⟩
      have hxE : xE = algebraMap ↥L ↥(K ⊔ L) e := by
        ext
        rw [hAlgL e]
        simp [xE, e]
      calc
        σ xE = σ (algebraMap ↥L ↥(K ⊔ L) e) := by rw [hxE]
        _ = algebraMap ↥L ↥(K ⊔ L) e := hfixL _
        _ = (1 : ↥(K ⊔ L) →ₐ[F] ↥(K ⊔ L)) xE := by rw [hxE]; rfl
  ext x
  simpa using congrArg (fun f : ↥(K ⊔ L) →ₐ[F] ↥(K ⊔ L) => f x) hσ_alg

theorem two_field_sup_locally_unramified (F : Type) [Field F] [NumberField F]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥)
    (K L : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F ↥K] [FiniteDimensional F ↥L] [FiniteDimensional F ↥(K ⊔ L)]
    [IsGalois F ↥K] [IsGalois F ↥L] [IsGalois F ↥(K ⊔ L)]
    [NumberField ↥K] [NumberField ↥L] [NumberField ↥(K ⊔ L)]
    (hK : ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 ↥K), Ideal.ramificationIdx 𝔭 𝔓 = 1)
    (hL : ∀ 𝔔 ∈ 𝔭.primesOver (𝓞 ↥L), Ideal.ramificationIdx 𝔭 𝔔 = 1) :
    ∀ 𝔖 ∈ 𝔭.primesOver (𝓞 ↥(K ⊔ L)), Ideal.ramificationIdx 𝔭 𝔖 = 1 := by
  intro 𝔖 h𝔖
  letI : Algebra ↥K ↥(K ⊔ L) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_left).toRingHom)
  letI : IsScalarTower F ↥K ↥(K ⊔ L) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_left)
  letI : Algebra ↥L ↥(K ⊔ L) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_right).toRingHom)
  letI : IsScalarTower F ↥L ↥(K ⊔ L) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_right)
  letI : Normal F ↥K :=
    (isGalois_iff.mp (show IsGalois F ↥K from inferInstance)).2
  letI : Normal F ↥L :=
    (isGalois_iff.mp (show IsGalois F ↥L from inferInstance)).2
  letI : Normal F ↥(K ⊔ L) :=
    (isGalois_iff.mp (show IsGalois F ↥(K ⊔ L) from inferInstance)).2
  let fK : (𝓞 ↥K) →ₐ[𝓞 F] (𝓞 ↥(K ⊔ L)) :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F ↥K ↥(K ⊔ L))
  let fL : (𝓞 ↥L) →ₐ[𝓞 F] (𝓞 ↥(K ⊔ L)) :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F ↥L ↥(K ⊔ L))
  let 𝔓 : Ideal (𝓞 ↥K) := Ideal.comap fK 𝔖
  let 𝔔 : Ideal (𝓞 ↥L) := Ideal.comap fL 𝔖
  have hSprime : 𝔖.IsPrime := h𝔖.1
  have hSlies : 𝔖.LiesOver 𝔭 := h𝔖.2
  have hPprime : 𝔓.IsPrime := by
    dsimp [𝔓]
    letI : 𝔖.IsPrime := hSprime
    simpa using (Ideal.comap_isPrime fK.toRingHom 𝔖)
  have hQprime : 𝔔.IsPrime := by
    dsimp [𝔔]
    letI : 𝔖.IsPrime := hSprime
    simpa using (Ideal.comap_isPrime fL.toRingHom 𝔖)
  have hPlies : 𝔓.LiesOver 𝔭 := by
    dsimp [𝔓]
    letI : 𝔖.LiesOver 𝔭 := hSlies
    simpa using (Ideal.comap_liesOver 𝔖 𝔭 fK)
  have hQlies : 𝔔.LiesOver 𝔭 := by
    dsimp [𝔔]
    letI : 𝔖.LiesOver 𝔭 := hSlies
    simpa using (Ideal.comap_liesOver 𝔖 𝔭 fL)
  have hPmem : 𝔓 ∈ 𝔭.primesOver (𝓞 ↥K) := ⟨hPprime, hPlies⟩
  have hQmem : 𝔔 ∈ 𝔭.primesOver (𝓞 ↥L) := ⟨hQprime, hQlies⟩
  letI : 𝔭.IsMaximal := hp.isMaximal hne
  letI : 𝔓.IsMaximal := hPprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔓)
  letI : 𝔔.IsMaximal := hQprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔔)
  letI : 𝔖.IsMaximal := hSprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔖)
  letI : Field ((𝓞 F) ⧸ 𝔭) := Ideal.Quotient.field 𝔭
  letI : Field ((𝓞 ↥K) ⧸ 𝔓) := Ideal.Quotient.field 𝔓
  letI : Field ((𝓞 ↥L) ⧸ 𝔔) := Ideal.Quotient.field 𝔔
  letI : Field ((𝓞 ↥(K ⊔ L)) ⧸ 𝔖) := Ideal.Quotient.field 𝔖
  let p0 : Ideal ℤ := Ideal.under ℤ 𝔭
  have habsNorm_p_ne_zero : Ideal.absNorm 𝔭 ≠ 0 := by
    intro h0
    exact hne ((Ideal.absNorm_eq_zero_iff (I := 𝔭)).mp h0)
  have hp0ne : p0 ≠ ⊥ := by
    letI : 𝔭.LiesOver p0 := by
      dsimp [p0]
      simpa using (Ideal.over_under (A := ℤ) 𝔭)
    intro hp0bot
    have hmem0 : (((Ideal.absNorm 𝔭 : ℕ) : ℤ)) ∈ p0 := by
      exact (Ideal.mem_of_liesOver (P := 𝔭) (p := p0) (((Ideal.absNorm 𝔭 : ℕ) : ℤ))).2
        (by simpa using (Ideal.absNorm_mem 𝔭))
    have hz0 : (((Ideal.absNorm 𝔭 : ℕ) : ℤ)) = 0 := by
      simpa [hp0bot] using hmem0
    exact habsNorm_p_ne_zero (by exact_mod_cast hz0)
  have hp0abs_ne_zero : Ideal.absNorm p0 ≠ 0 := by
    intro h0
    exact hp0ne ((Ideal.absNorm_eq_zero_iff (I := p0)).mp h0)
  have hp0eq : Ideal.span ({(Ideal.absNorm p0 : ℤ)} : Set ℤ) = p0 := by
    simp [p0]
  let e : ℤ ⧸ p0 ≃+* ZMod (Ideal.absNorm p0) :=
    (Ideal.quotEquivOfEq hp0eq.symm).trans (Int.quotientSpanNatEquivZMod (Ideal.absNorm p0))
  letI : NeZero (Ideal.absNorm p0) := ⟨hp0abs_ne_zero⟩
  letI : Fintype (ZMod (Ideal.absNorm p0)) := ZMod.fintype (Ideal.absNorm p0)
  have hfinZ : Finite (ℤ ⧸ p0) := Finite.of_equiv _ e.symm.toEquiv
  letI : Finite (ℤ ⧸ p0) := hfinZ
  have hmf : Module.Finite (ℤ ⧸ p0) ((𝓞 F) ⧸ 𝔭) := by
    letI : 𝔭.LiesOver p0 := by
      dsimp [p0]
      simpa using (Ideal.over_under (A := ℤ) 𝔭)
    exact module_finite_of_liesOver (P := 𝔭) (p := p0)
  letI : Module.Finite (ℤ ⧸ p0) ((𝓞 F) ⧸ 𝔭) := hmf
  letI : Finite ((𝓞 F) ⧸ 𝔭) := Module.finite_of_finite (R := ℤ ⧸ p0)
  letI : PerfectField ((𝓞 F) ⧸ 𝔭) := PerfectField.ofFinite
  letI : Algebra.IsAlgebraic ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥K) ⧸ 𝔓) := by infer_instance
  letI : Algebra.IsSeparable ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥K) ⧸ 𝔓) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Algebra.IsAlgebraic ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥L) ⧸ 𝔔) := by infer_instance
  letI : Algebra.IsSeparable ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥L) ⧸ 𝔔) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Algebra.IsAlgebraic ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥(K ⊔ L)) ⧸ 𝔖) := by infer_instance
  letI : Algebra.IsSeparable ((𝓞 F) ⧸ 𝔭) ((𝓞 ↥(K ⊔ L)) ⧸ 𝔖) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hramK : Ideal.ramificationIdx 𝔭 𝔓 = 1 := hK 𝔓 hPmem
  have hramL : Ideal.ramificationIdx 𝔭 𝔔 = 1 := hL 𝔔 hQmem
  have hcardK : Nat.card (𝔓.inertia (↥K ≃ₐ[F] ↥K)) = 1 := by
    letI : 𝔓.LiesOver 𝔭 := hPlies
    letI : 𝔓.IsPrime := hPprime
    rw [Ideal.card_inertia_eq_ramificationIdxIn (G := ↥K ≃ₐ[F] ↥K) 𝔭 hne 𝔓,
      Ideal.ramificationIdxIn_eq_ramificationIdx (G := ↥K ≃ₐ[F] ↥K) (p := 𝔭) (P := 𝔓)]
    exact hramK
  have hcardL : Nat.card (𝔔.inertia (↥L ≃ₐ[F] ↥L)) = 1 := by
    letI : 𝔔.LiesOver 𝔭 := hQlies
    letI : 𝔔.IsPrime := hQprime
    rw [Ideal.card_inertia_eq_ramificationIdxIn (G := ↥L ≃ₐ[F] ↥L) 𝔭 hne 𝔔,
      Ideal.ramificationIdxIn_eq_ramificationIdx (G := ↥L ≃ₐ[F] ↥L) (p := 𝔭) (P := 𝔔)]
    exact hramL
  have hInertiaK_bot : 𝔓.inertia (↥K ≃ₐ[F] ↥K) = ⊥ :=
    (Subgroup.card_eq_one).mp hcardK
  have hInertiaL_bot : 𝔔.inertia (↥L ≃ₐ[F] ↥L) = ⊥ :=
    (Subgroup.card_eq_one).mp hcardL
  have hSinertia_bot : 𝔖.inertia (↥(K ⊔ L) ≃ₐ[F] ↥(K ⊔ L)) = ⊥ := by
    refine Subgroup.ext ?_
    intro σ
    constructor
    · intro hσ
      have hresK_mem :
          (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥K σ) ∈
            𝔓.inertia (↥K ≃ₐ[F] ↥K) := by
        simpa [fK, 𝔓] using
          (restrictNormal_mem_inertia_comap F (K ⊔ L) K 𝔖 (σ := σ) hσ)
      have hresL_mem :
          (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥L σ) ∈
            𝔔.inertia (↥L ≃ₐ[F] ↥L) := by
        simpa [fL, 𝔔] using
          (restrictNormal_mem_inertia_comap F (K ⊔ L) L 𝔖 (σ := σ) hσ)
      have hresK : (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥K σ) = 1 := by
        rw [hInertiaK_bot] at hresK_mem
        simpa [Subgroup.mem_bot] using hresK_mem
      have hresL : (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥(K ⊔ L)) ↥L σ) = 1 := by
        rw [hInertiaL_bot] at hresL_mem
        simpa [Subgroup.mem_bot] using hresL_mem
      have hAlgK : ∀ x : ↥K,
          algebraMap ↥K ↥(K ⊔ L) x = IntermediateField.inclusion le_sup_left x := by
        intro x
        rfl
      have hAlgL : ∀ x : ↥L,
          algebraMap ↥L ↥(K ⊔ L) x = IntermediateField.inclusion le_sup_right x := by
        intro x
        rfl
      have hσ1 : σ = 1 :=
        restrict_eq_one_of_eq_one_on_sup_left_right F K L σ hAlgK hAlgL hresK hresL
      simpa [Subgroup.mem_bot] using hσ1
    · intro hσ
      have hσ1 : σ = 1 := by
        simpa [Subgroup.mem_bot] using hσ
      rw [hσ1]
      exact (𝔖.inertia (↥(K ⊔ L) ≃ₐ[F] ↥(K ⊔ L))).one_mem
  have hramIn : Ideal.ramificationIdxIn 𝔭 (𝓞 ↥(K ⊔ L)) = 1 := by
    letI : 𝔖.LiesOver 𝔭 := hSlies
    rw [← Ideal.card_inertia_eq_ramificationIdxIn
      (G := ↥(K ⊔ L) ≃ₐ[F] ↥(K ⊔ L)) 𝔭 hne 𝔖, hSinertia_bot, Subgroup.card_bot]
  letI : 𝔖.LiesOver 𝔭 := hSlies
  letI : 𝔖.IsPrime := hSprime
  rw [← Ideal.ramificationIdxIn_eq_ramificationIdx
    (G := ↥(K ⊔ L) ≃ₐ[F] ↥(K ⊔ L)) (p := 𝔭) (P := 𝔖)]
  exact hramIn

theorem maximalUnramifiedFiniteStage_locally_unramified (F : Type) [Field F] [NumberField F]
    (p : ℕ) [Fact (Nat.Prime p)]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥)
    (s : Finset (maximalUnramifiedProPFIndex F p))
    [NumberField (maximalUnramifiedFiniteStage F p s)] :
    ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 (maximalUnramifiedFiniteStage F p s)),
      Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      intro 𝔓 h𝔓
      simp [maximalUnramifiedFiniteStage, iSup_false] at h𝔓 ⊢
      have hPrime : 𝔓.IsPrime := h𝔓.1
      have hOver : 𝔓.LiesOver 𝔭 := h𝔓.2
      have hempty : maximalUnramifiedFiniteStage F p (∅ : Finset (maximalUnramifiedProPFIndex F p)) =
          (⊥ : IntermediateField F (AlgebraicClosure F)) := by
        simp [maximalUnramifiedFiniteStage, iSup_false]
      let eStage : ↥(maximalUnramifiedFiniteStage F p (∅ : Finset (maximalUnramifiedProPFIndex F p))) ≃ₐ[F] F :=
        (IntermediateField.equivOfEq (F := F) (E := AlgebraicClosure F) hempty).trans
          (IntermediateField.botEquiv F (AlgebraicClosure F))
      let e : (𝓞 ↥(maximalUnramifiedFiniteStage F p (∅ : Finset (maximalUnramifiedProPFIndex F p)))) ≃ₐ[𝓞 F] (𝓞 F) :=
        NumberField.RingOfIntegers.mapAlgEquiv eStage
      let Q : Ideal (𝓞 F) := Ideal.map e 𝔓
      have hQOver : Q.LiesOver 𝔭 := by
        dsimp [Q]
        infer_instance
      have hQeq : Q = 𝔭 := by
        simpa [Q] using (Ideal.over_def (P := Q) (p := 𝔭)).symm
      have hramQ : Ideal.ramificationIdx 𝔭 Q = 1 := by
        simpa [hQeq] using
          (Ideal.ramificationIdx_map_self_eq_one (R := 𝓞 F) (S := 𝓞 F)
            (h₁ := by simpa using hp.ne_top)
            (h₂ := by simpa using hne))
      have hmap : Ideal.ramificationIdx 𝔭 Q = Ideal.ramificationIdx 𝔭 𝔓 := by
        simpa [Q] using
          (Ideal.ramificationIdx_map_eq (R := 𝓞 F) (S := 𝓞 ↥(maximalUnramifiedFiniteStage F p ∅))
            (S₁ := 𝓞 F) (p := 𝔭) (P := 𝔓) e)
      exact hmap.symm.trans hramQ
  | @insert i s hi ih =>
      let S := maximalUnramifiedFiniteStage F p s
      letI : FiniteDimensional F ↥i.M := i.hfd
      letI : IsGalois F ↥i.M := i.hg
      letI : NumberField ↥i.M := i.hnf
      letI : ∀ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F ↥(j.M) := fun j => j.hfd
      letI : FiniteDimensional F ↥S := by
        simpa [S, maximalUnramifiedFiniteStage] using
          (IntermediateField.finiteDimensional_iSup_of_finset
            (K := F) (L := AlgebraicClosure F)
            (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s))
      letI : NumberField ↥S := NumberField.of_module_finite F S
      have hS_eq : S = ⨆ j : {j // j ∈ s}, j.1.M := by
        dsimp [S, maximalUnramifiedFiniteStage]
        rw [← Finset.iSup_coe (s := s) (f := fun j : maximalUnramifiedProPFIndex F p => j.M)]
        symm
        exact iSup_subtype
      have hS_normal' : Normal F ↥(⨆ j : {j // j ∈ s}, j.1.M) := by
        letI : ∀ j : {j // j ∈ s}, Normal F ↥(j.1.M) := fun j => j.1.hg.to_normal
        exact IntermediateField.normal_iSup (F := F) (t := fun j : {j // j ∈ s} => j.1.M)
      have hS_normal : Normal F ↥S := by
        rw [hS_eq]
        exact hS_normal'
      letI : IsGalois F ↥S := by
        rw [isGalois_iff]
        exact ⟨inferInstance, hS_normal⟩
      have hstage : maximalUnramifiedFiniteStage F p (insert i s) = i.M ⊔ S := by
        simpa [S, maximalUnramifiedFiniteStage] using
          (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M))
      letI : FiniteDimensional F ↥(i.M ⊔ S) := IntermediateField.finiteDimensional_sup (K := F) (E1 := i.M) (E2 := S)
      have hsup_normal : Normal F ↥(i.M ⊔ S) := IntermediateField.normal_sup (E := i.M) (E' := S)
      letI : IsGalois F ↥(i.M ⊔ S) := by
        rw [isGalois_iff]
        exact ⟨inferInstance, hsup_normal⟩
      letI : NumberField ↥(i.M ⊔ S) := NumberField.of_module_finite F ↥(i.M ⊔ S)
      rw [hstage]
      simpa [S] using
        two_field_sup_locally_unramified F 𝔭 hp hne i.M S
          (fun 𝔔 h𝔔 => i.hunr.unramified_at_finite 𝔭 𝔔 hp hne h𝔔)
          (fun 𝔔 h𝔔 => ih 𝔔 h𝔔)

theorem finite_galois_subextension_of_maximalUnramified_locally_unramified (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥)
    (M : IntermediateField F (maximalUnramifiedProPF F p))
    [FiniteDimensional F M] [Normal F M] [NumberField M] :
    ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 M), Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
  classical
  intro 𝔓 h𝔓
  let E : IntermediateField F (AlgebraicClosure F) := maximalUnramifiedProPF F p
  let M' : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift M
  have hM_fg0 : M.FG := normal_numberField_intermediate_fg M
  have hM_fg : M'.FG := by
    rcases hM_fg0 with ⟨s0, hs0⟩
    refine ⟨s0.image (fun x : maximalUnramifiedProPF F p => (x : AlgebraicClosure F)), ?_⟩
    have hs0' : IntermediateField.lift (IntermediateField.adjoin F (↑s0 : Set (maximalUnramifiedProPF F p))) = M' := by
      simpa [M'] using congrArg (fun S : IntermediateField F (maximalUnramifiedProPF F p) => IntermediateField.lift S) hs0
    simpa [IntermediateField.lift, IntermediateField.adjoin_map, Finset.coe_image] using hs0'
  let t : maximalUnramifiedProPFIndex F p → IntermediateField F (AlgebraicClosure F) := fun i => i.M
  have hEq : maximalUnramifiedProPF F p = ⨆ i : maximalUnramifiedProPFIndex F p, t i := by
    simpa [t] using MaxUnramifiedProPGaloisGroup.maximalUnramifiedProPF_eq_iSup_index (F := F) (p := p)
  have hMle0 : M' ≤ maximalUnramifiedProPF F p := by
    simpa [M', E] using (show IntermediateField.lift M ≤ maximalUnramifiedProPF F p from IntermediateField.lift_le M)
  have hMle1 : M' ≤ ⨆ i : maximalUnramifiedProPFIndex F p, t i := by
    simpa [hEq] using hMle0
  obtain ⟨s, hs⟩ := fg_intermediateField_le_iSup_finset (M := M') hM_fg (t := t) hMle1
  let S : IntermediateField F (AlgebraicClosure F) := maximalUnramifiedFiniteStage F p s
  have hMleS : M' ≤ S := by
    simpa [S, maximalUnramifiedFiniteStage, t] using hs
  letI : ∀ i : maximalUnramifiedProPFIndex F p, FiniteDimensional F (t i) := fun i => i.hfd
  letI : FiniteDimensional F S := by
    simpa [S, maximalUnramifiedFiniteStage, t] using
      (IntermediateField.finiteDimensional_iSup_of_finset (K := F) (L := AlgebraicClosure F) (t := t) (s := s))
  letI : NumberField S := NumberField.of_module_finite F S
  have hS_unr : ∀ 𝔔 ∈ 𝔭.primesOver (𝓞 S), Ideal.ramificationIdx 𝔭 𝔔 = 1 :=
    maximalUnramifiedFiniteStage_locally_unramified F p 𝔭 hp hne s
  let f : M →ₐ[F] S :=
    (IntermediateField.inclusion hMleS).comp (IntermediateField.liftAlgEquiv M).toAlgHom
  let instMS : Algebra M S := f.toRingHom.toAlgebra
  let instTower : @IsScalarTower F M S _ instMS.toSMul _ := IsScalarTower.of_algHom f
  exact @local_unramified_descends_in_tower F M S _ _ _ _ _ _ _ _ instMS instTower _ _ 𝔭 hp hne hS_unr 𝔓 h𝔓

theorem exists_splittingDetectorAt (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (𝔭 : Ideal (𝓞 F)) (_hp : 𝔭.IsPrime) (_hne : 𝔭 ≠ ⊥) :
    ∃ σ : MaxUnramifiedProPGaloisGroup F p, IsSplittingDetectorAt F p 𝔭 σ := by
  classical
  letI : 𝔭.IsPrime := _hp
  let K := maximalUnramifiedProPF F p
  let A : SplittingDetectorTestField F p → Set (MaxUnramifiedProPGaloisGroup F p) := fun i => by
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M ≃ₐ[F] i.M) := i.hpG
    exact {σ | ((AlgEquiv.restrictNormalHom (F := F) (K₁ := K) i.M) σ : i.M ≃ₐ[F] i.M) = 1 ↔
      ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 i.M), Ideal.inertiaDeg 𝔭 𝔓 = 1}
  have hclosed : ∀ i, IsClosed (A i) := by
    intro i
    dsimp [A]
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M ≃ₐ[F] i.M) := i.hpG
    let res : MaxUnramifiedProPGaloisGroup F p → (i.M ≃ₐ[F] i.M) :=
      AlgEquiv.restrictNormalHom (F := F) (K₁ := K) i.M
    have hres : Continuous res := by
      simpa [res, K] using
        (InfiniteGalois.restrictNormalHom_continuous (k := F) (K := K) i.M)
    letI : DiscreteTopology (i.M ≃ₐ[F] i.M) :=
      krullTopology_discreteTopology_of_finiteDimensional F i.M
    by_cases hsplit : ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 i.M), Ideal.inertiaDeg 𝔭 𝔓 = 1
    · let S : Set (i.M ≃ₐ[F] i.M) := {(1 : i.M ≃ₐ[F] i.M)}
      have hS : IsClosed S := isClosed_discrete S
      have hA : {σ : MaxUnramifiedProPGaloisGroup F p |
          (res σ = 1 ↔ ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 i.M), Ideal.inertiaDeg 𝔭 𝔓 = 1)} = res ⁻¹' S := by
        ext σ
        constructor
        · intro h
          exact h.mpr hsplit
        · intro hσ
          constructor
          · intro _
            exact hsplit
          · intro _
            exact hσ
      rw [hA]
      exact IsClosed.preimage hres hS
    · let S : Set (i.M ≃ₐ[F] i.M) := ({(1 : i.M ≃ₐ[F] i.M)} : Set (i.M ≃ₐ[F] i.M))ᶜ
      have hS : IsClosed S := isClosed_discrete S
      have hA : {σ : MaxUnramifiedProPGaloisGroup F p |
          (res σ = 1 ↔ ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 i.M), Ideal.inertiaDeg 𝔭 𝔓 = 1)} = res ⁻¹' S := by
        ext σ
        constructor
        · intro h hσ
          exact hsplit (h.mp hσ)
        · intro hσ
          constructor
          · intro hEq
            exact False.elim (hσ hEq)
          · intro hsplit'
            exact False.elim (hsplit hsplit')
      rw [hA]
      exact IsClosed.preimage hres hS
  have hFIP : ∀ s : Finset (SplittingDetectorTestField F p), (⋂ i ∈ s, A i).Nonempty := by
    intro s
    let ιs : Type := {i : SplittingDetectorTestField F p // i ∈ (↑s : Set (SplittingDetectorTestField F p))}
    let N : IntermediateField F K := ⨆ i : ιs, i.1.M
    have hle : ∀ {i : SplittingDetectorTestField F p}, i ∈ s → i.M ≤ N := by
      intro i hi
      exact le_iSup (fun j : ιs => j.1.M) ⟨i, by simpa using hi⟩
    letI : Finite ιs := by infer_instance
    letI : ∀ i : ιs, FiniteDimensional F i.1.M := fun i => i.1.hfd
    letI : FiniteDimensional F N := by
      simpa [N] using
        (IntermediateField.finiteDimensional_iSup_of_finite
          (K := F) (L := K) (t := fun i : ιs => i.1.M))
    letI : ∀ i : ιs, Normal F i.1.M := fun i => i.1.hnorm
    letI : Normal F N := by
      simpa [N] using
        (IntermediateField.normal_iSup (F := F) (K := K) (t := fun i : ιs => i.1.M))
    letI : IsGalois F N := by
      rw [isGalois_iff]
      exact ⟨inferInstance, inferInstance⟩
    letI : NumberField N := NumberField.of_module_finite F N
    letI : 𝔭.IsMaximal := Ideal.IsPrime.isMaximal _hp _hne
    have hQnonempty : Nonempty (𝔭.primesOver (𝓞 N)) := by
      simpa using (Ideal.nonempty_primesOver (R := 𝓞 F) (S := 𝓞 N) 𝔭)
    let Qs : 𝔭.primesOver (𝓞 N) := Classical.choice hQnonempty
    let 𝔔 : Ideal (𝓞 N) := Qs.1
    have h𝔔 : 𝔔 ∈ 𝔭.primesOver (𝓞 N) := Qs.2
    letI : 𝔔.IsPrime := Qs.2.1
    letI : 𝔔.LiesOver 𝔭 := Qs.2.2
    letI : 𝔔.IsMaximal := by
      change Qs.1.IsMaximal
      exact Ideal.primesOver.isMaximal Qs
    have hQne : 𝔔 ≠ ⊥ := by
      exact Ring.ne_bot_of_isMaximal_of_not_isField inferInstance (NumberField.RingOfIntegers.not_isField N)
    haveI : Module.Finite ℤ (𝓞 N) := by infer_instance
    letI : Finite (𝓞 N ⧸ 𝔔) := Ideal.finiteQuotientOfFreeOfNeBot 𝔔 hQne
    have hramN :=
      finite_galois_subextension_of_maximalUnramified_locally_unramified
        F p 𝔭 _hp _hne N
    have hramQ : Ideal.ramificationIdx 𝔭 𝔔 = 1 := hramN 𝔔 h𝔔
    let τ : N ≃ₐ[F] N := arithFrobAt (R := 𝓞 F) (G := N ≃ₐ[F] N) 𝔔
    have hτ : AlgHom.IsArithFrobAt (R := 𝓞 F)
        ((NumberField.RingOfIntegers.mapAlgEquiv τ).toAlgHom) 𝔔 := by
      change IsArithFrobAt (R := 𝓞 F) τ 𝔔
      simpa [τ] using (IsArithFrobAt.arithFrobAt (R := 𝓞 F) (G := N ≃ₐ[F] N) (Q := 𝔔))
    have hsurj := maximalUnramified_restrictNormalHom_surjective (F := F) (p := p) N
    obtain ⟨σ, hσN⟩ := hsurj τ
    refine ⟨σ, ?_⟩
    simp only [Set.mem_iInter]
    intro i hi
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M ≃ₐ[F] i.M) := i.hpG
    letI : IsGalois F i.M := by
      rw [isGalois_iff]
      exact ⟨inferInstance, inferInstance⟩
    let f_incl : i.M →ₐ[F] N := IntermediateField.inclusion (hle hi)
    let instMN : Algebra i.M N := f_incl.toRingHom.toAlgebra
    letI : Algebra i.M N := instMN
    letI : SMul i.M N := instMN.toSMul
    letI : IsScalarTower F i.M N := IsScalarTower.of_algHom f_incl
    let f : (𝓞 i.M) →ₐ[𝓞 F] (𝓞 N) := NumberField.RingOfIntegers.mapAlgHom f_incl
    let 𝔓0 : Ideal (𝓞 i.M) := Ideal.comap f 𝔔
    have h𝔓0 : 𝔓0 ∈ 𝔭.primesOver (𝓞 i.M) := by
      letI : 𝔓0.IsPrime := Ideal.comap_isPrime f.toRingHom 𝔔
      letI : 𝔓0.LiesOver 𝔭 := Ideal.comap_liesOver (Q := 𝔔) (p := 𝔭) f
      exact (Ideal.primesOver.mk (p := 𝔭) 𝔓0).2
    have hrami :=
      finite_galois_subextension_of_maximalUnramified_locally_unramified
        F p 𝔭 _hp _hne i.M
    have hram𝔓0 : Ideal.ramificationIdx 𝔭 𝔓0 = 1 := hrami 𝔓0 h𝔓0
    have hτi : AlgHom.IsArithFrobAt (R := 𝓞 F)
        ((NumberField.RingOfIntegers.mapAlgEquiv
          (((AlgEquiv.restrictNormalHom (F := F) (K₁ := N) i.M) τ))).toAlgHom) 𝔓0 := by
      simpa [𝔓0, f] using (isArithFrobAt_restrictNormal F i.M N 𝔭 𝔔 h𝔔 τ hτ)
    let valN : N →ₐ[i.M] K :=
      { toRingHom := (IntermediateField.val N).toRingHom
        commutes' := by
          intro x
          rfl }
    letI : IsScalarTower i.M N K := IsScalarTower.of_algHom valN
    have hresσ :
        (AlgEquiv.restrictNormalHom (F := F) (K₁ := K) i.M) σ =
          (AlgEquiv.restrictNormalHom (F := F) (K₁ := N) i.M) τ := by
      rw [IsScalarTower.AlgEquiv.restrictNormalHom_comp_apply (F := F) (K₁ := i.M) (K₂ := N) (f := σ)]
      rw [hσN]
    have hiff0 :
        ((AlgEquiv.restrictNormalHom (F := F) (K₁ := N) i.M) τ : i.M ≃ₐ[F] i.M) = 1 ↔
          Ideal.inertiaDeg 𝔭 𝔓0 = 1 := by
      exact finite_isArithFrobAt_eq_one_iff_inertiaDeg_eq_one F i.M 𝔭 _hp _hne 𝔓0 h𝔓0 hram𝔓0 _ hτi
    have hsplit0 : Ideal.inertiaDeg 𝔭 𝔓0 = 1 ↔
        ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 i.M), Ideal.inertiaDeg 𝔭 𝔓 = 1 := by
      constructor
      · intro hdeg 𝔓 h𝔓
        rcases h𝔓 with ⟨h𝔓_prime, h𝔓_lies⟩
        letI : 𝔓.IsPrime := h𝔓_prime
        letI : 𝔓.LiesOver 𝔭 := h𝔓_lies
        letI : Finite (i.M ≃ₐ[F] i.M) := by infer_instance
        have hEq : Ideal.inertiaDeg 𝔭 𝔓0 = Ideal.inertiaDeg 𝔭 𝔓 := by
          simpa using (Ideal.inertiaDeg_eq_of_isGaloisGroup (p := 𝔭) (P := 𝔓0) (Q := 𝔓) (G := i.M ≃ₐ[F] i.M))
        exact hEq.symm ▸ hdeg
      · intro hsplit
        exact hsplit 𝔓0 h𝔓0
    dsimp [A]
    rw [hresσ]
    exact hiff0.trans hsplit0
  rcases CompactSpace.iInter_nonempty hclosed hFIP with ⟨σ, hσ⟩
  refine ⟨σ, ?_⟩
  intro M _instFD _instNorm _instNF _instP
  let i : SplittingDetectorTestField F p :=
    { M := M, hfd := _instFD, hnorm := _instNorm, hnf := _instNF, hpG := _instP }
  have hσ' : ∀ j, σ ∈ A j := by
    simpa [Set.mem_iInter] using hσ
  simpa [A, K, i] using hσ' i

noncomputable def splittingDetectorAt
    (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥) :
    MaxUnramifiedProPGaloisGroup F p :=
  (exists_splittingDetectorAt F p 𝔭 hp hne).choose

theorem splittingDetectorAt_spec
    (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥) :
    IsSplittingDetectorAt F p 𝔭 (splittingDetectorAt F p 𝔭 hp hne) :=
  (exists_splittingDetectorAt F p 𝔭 hp hne).choose_spec


  · intro b₁ b₂ hq
    apply Fin.ext
    exact Nat.nth_injective hP' hq
  · intro b
    exact (Nat.nth_mem_of_infinite hP' b.1).1
  · intro b
    exact (Nat.nth_mem_of_infinite hP' b.1).2

theorem finiteGaloisIntermediateField_contains_two_subfields (K₁ K₂ : IntermediateField ℚ (AlgebraicClosure ℚ))
    [FiniteDimensional ℚ K₁] [FiniteDimensional ℚ K₂] :

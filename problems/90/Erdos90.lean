def overlapSymmetricLens (R : ℝ) : Set ℂ :=
  Metric.ball (-((1 : ℂ) / 2)) R ∩ Metric.ball (((1 : ℂ) / 2)) R

theorem overlapArea_eq_volume_rotate (R : ℝ) (z : ℂ) (hz : ‖z‖ = 1) :
  (MeasureTheory.volume
    (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R)).toReal =
  (MeasureTheory.volume (overlapSymmetricLens R)).toReal := by
  let a : Circle := ⟨star z, by
    simpa [Submonoid.unitSphere] using hz⟩
  let e : ℂ ≃ₗᵢ[ℝ] ℂ := rotation a
  have hzmul : star z * z = (1 : ℂ) := by
    simpa [Complex.star_def, hz] using Complex.conj_mul' z
  have hzmul' : (starRingEnd ℂ) z * z = (1 : ℂ) := by
    simpa using hzmul
  have hpos : e (z / 2) = ((1 : ℂ) / 2) := by
    change (a : ℂ) * (z / 2) = ((1 : ℂ) / 2)
    dsimp [a]
    rw [div_eq_mul_inv, ← mul_assoc, hzmul', one_mul, div_eq_mul_inv, one_mul]
  have hneg : e (-(z / 2)) = -((1 : ℂ) / 2) := by
    simpa using congrArg Neg.neg hpos
  have hmp : MeasureTheory.MeasurePreserving e := by
    simpa [e] using (LinearIsometryEquiv.measurePreserving e)
  have hnegHalf : -(z / 2) - z / 2 = -z := by
    ring
  have hpreRot :
      e ⁻¹' overlapSymmetricLens R = Metric.ball (-(z / 2)) R ∩ Metric.ball (z / 2) R := by
    rw [overlapSymmetricLens, ← hneg, ← hpos, Set.preimage_inter,
      Isometry.preimage_ball e.isometry (-(z / 2)) R,
      Isometry.preimage_ball e.isometry (z / 2) R]
  have hmeasLens : MeasurableSet (overlapSymmetricLens R) := by
    rw [overlapSymmetricLens]
    exact (Metric.isOpen_ball.measurableSet).inter Metric.isOpen_ball.measurableSet
  have hvol1 :
      MeasureTheory.volume (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) =
        MeasureTheory.volume (Metric.ball (z / 2) R ∩ Metric.ball (-(z / 2)) R) := by
    simpa [hnegHalf] using
      (MeasureTheory.measure_preimage_add (MeasureTheory.volume : MeasureTheory.Measure ℂ)
        (z / 2) (Metric.ball (z / 2) R ∩ Metric.ball (-(z / 2)) R))
  have hvol2 :
      MeasureTheory.volume (Metric.ball (z / 2) R ∩ Metric.ball (-(z / 2)) R) =
        MeasureTheory.volume (overlapSymmetricLens R) := by
    simpa [hpreRot, Set.inter_comm] using hmp.measure_preimage hmeasLens.nullMeasurableSet
  have hvol :
      MeasureTheory.volume (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) =
        MeasureTheory.volume (overlapSymmetricLens R) := by
    exact hvol1.trans hvol2
  simpa using congrArg ENNReal.toReal hvol


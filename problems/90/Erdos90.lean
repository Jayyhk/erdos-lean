theorem conjInvariantHom_eval_injective_normalClosure (A : Type*) (G : Type*) [CommGroup A] [Group G] (n : в„•) (gens : Fin n вҶ’ G) :
    let N : Subgroup G := Subgroup.normalClosure (Set.range gens)
    let eval : {ПҶ : N вҶ’* A // вҲҖ g : G, ПҶ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = ПҶ} вҶ’ Fin n вҶ’ A := fun ПҶ i => ПҶ.1 вҹЁgens i, Subgroup.subset_normalClosure вҹЁi, rflвҹ©вҹ©
    Function.Injective eval := by
  classical
  dsimp
  intro ПҶ ПҲ h
  rcases ПҶ with вҹЁПҶ, hПҶвҹ©
  rcases ПҲ with вҹЁПҲ, hПҲвҹ©
  have hgen_eq (i : Fin n) :
      ПҶ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© =
        ПҲ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© := by
    exact congrFun h i
  apply Subtype.ext
  ext x
  have hx : x.1 вҲҲ Subgroup.closure (Group.conjugatesOfSet (Set.range gens)) := by
    simp [Subgroup.normalClosure, x.2]
  have hEq :
      вҲҖ g (hg : g вҲҲ Subgroup.closure (Group.conjugatesOfSet (Set.range gens))),
        вҲҖ hgN : g вҲҲ Subgroup.normalClosure (Set.range gens),
          ПҶ вҹЁg, hgNвҹ© = ПҲ вҹЁg, hgNвҹ© := by
    intro g hg
    refine Subgroup.closure_induction
      (k := Group.conjugatesOfSet (Set.range gens))
      (p := fun g _ =>
        вҲҖ hgN : g вҲҲ Subgroup.normalClosure (Set.range gens),
          ПҶ вҹЁg, hgNвҹ© = ПҲ вҹЁg, hgNвҹ©) ?_ ?_ ?_ ?_ hg
    В· intro y hy hyN
      rcases (Group.mem_conjugatesOfSet_iff.mp hy) with вҹЁa, ha, hconjвҹ©
      rcases ha with вҹЁi, rflвҹ©
      rcases (isConj_iff.mp hconj) with вҹЁc, rflвҹ©
      have hconjElt :
          ((MulAut.conjNormal (H := Subgroup.normalClosure (Set.range gens)) c)
            вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ©) =
            вҹЁc * gens i * cвҒ»В№, hyNвҹ© := by
        apply Subtype.ext
        simp [MulAut.conjNormal_apply]
      have hПҶc :=
        congrArg
          (fun f =>
            f вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ©)
          (hПҶ c)
      have hПҲc :=
        congrArg
          (fun f =>
            f вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ©)
          (hПҲ c)
      have hПҶc' :
          ПҶ вҹЁc * gens i * cвҒ»В№, hyNвҹ© =
            ПҶ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© := by
        simpa [MonoidHom.comp_apply, hconjElt] using hПҶc
      have hПҲc' :
          ПҲ вҹЁc * gens i * cвҒ»В№, hyNвҹ© =
            ПҲ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© := by
        simpa [MonoidHom.comp_apply, hconjElt] using hПҲc
      calc
        ПҶ вҹЁc * gens i * cвҒ»В№, hyNвҹ© = ПҶ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© := hПҶc'
        _ = ПҲ вҹЁgens i, Subgroup.subset_normalClosure (s := Set.range gens) вҹЁi, rflвҹ©вҹ© := hgen_eq i
        _ = ПҲ вҹЁc * gens i * cвҒ»В№, hyNвҹ© := hПҲc'.symm
    В· intro h1N
      have hone : (вҹЁ1, h1Nвҹ© : Subgroup.normalClosure (Set.range gens)) = 1 := by
        apply Subtype.ext
        rfl
      calc
        ПҶ вҹЁ1, h1Nвҹ© = ПҶ 1 := by rw [hone]
        _ = 1 := ПҶ.map_one
        _ = ПҲ 1 := by symm; exact ПҲ.map_one
        _ = ПҲ вҹЁ1, h1Nвҹ© := by rw [hone]
    В· intro a b ha hb hPa hPb habN
      have haN : a вҲҲ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using ha
      have hbN : b вҲҲ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using hb
      have hmul :
          (вҹЁa * b, habNвҹ© : Subgroup.normalClosure (Set.range gens)) =
            вҹЁa, haNвҹ© * вҹЁb, hbNвҹ© := by
        apply Subtype.ext
        rfl
      calc
        ПҶ вҹЁa * b, habNвҹ© = ПҶ (вҹЁa, haNвҹ© * вҹЁb, hbNвҹ©) := by rw [hmul]
        _ = ПҶ вҹЁa, haNвҹ© * ПҶ вҹЁb, hbNвҹ© := by
          simpa using MonoidHom.map_mul ПҶ вҹЁa, haNвҹ© вҹЁb, hbNвҹ©
        _ = ПҲ вҹЁa, haNвҹ© * ПҲ вҹЁb, hbNвҹ© := by rw [hPa haN, hPb hbN]
        _ = ПҲ (вҹЁa, haNвҹ© * вҹЁb, hbNвҹ©) := by
          symm
          simpa using MonoidHom.map_mul ПҲ вҹЁa, haNвҹ© вҹЁb, hbNвҹ©
        _ = ПҲ вҹЁa * b, habNвҹ© := by rw [hmul]
    В· intro a ha hPa haInvN
      have haN : a вҲҲ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using ha
      have hinv :
          (вҹЁaвҒ»В№, haInvNвҹ© : Subgroup.normalClosure (Set.range gens)) =
            (вҹЁa, haNвҹ©)вҒ»В№ := by
        apply Subtype.ext
        rfl
      calc
        ПҶ вҹЁaвҒ»В№, haInvNвҹ© = ПҶ ((вҹЁa, haNвҹ© : Subgroup.normalClosure (Set.range gens))вҒ»В№) := by
          rw [hinv]
        _ = (ПҶ вҹЁa, haNвҹ©)вҒ»В№ := by
          simp
        _ = (ПҲ вҹЁa, haNвҹ©)вҒ»В№ := by rw [hPa haN]
        _ = ПҲ ((вҹЁa, haNвҹ© : Subgroup.normalClosure (Set.range gens))вҒ»В№) := by
          symm
          simp
        _ = ПҲ вҹЁaвҒ»В№, haInvNвҹ© := by rw [hinv]
  exact hEq x.1 hx x.2

theorem finrank_middle_le_left_add_right_of_exact (k : Type*) [Field k] {VвӮҒ VвӮӮ VвӮғ : Type*} [AddCommGroup VвӮҒ] [Module k VвӮҒ] [FiniteDimensional k VвӮҒ] [AddCommGroup VвӮӮ] [Module k VвӮӮ] [FiniteDimensional k VвӮӮ] [AddCommGroup VвӮғ] [Module k VвӮғ] [FiniteDimensional k VвӮғ] (f : VвӮҒ вҶ’вӮ—[k] VвӮӮ) (g : VвӮӮ вҶ’вӮ—[k] VвӮғ) (hfg : Function.Exact f g) : Module.finrank k VвӮӮ вүӨ Module.finrank k VвӮҒ + Module.finrank k VвӮғ := by
  classical
  rw [вҶҗ LinearMap.finrank_range_add_finrank_ker g]
  rw [Function.Exact.linearMap_ker_eq hfg]
  have hf : Module.finrank k вҶҘ(LinearMap.range f) вүӨ Module.finrank k VвӮҒ := LinearMap.finrank_range_le f
  have hg : Module.finrank k вҶҘ(LinearMap.range g) вүӨ Module.finrank k VвӮғ := Submodule.finrank_le _
  omega

noncomputable def quotientGroupExtension (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    GroupExtension N G (G в§ё N) where
  inl := N.subtype
  rightHom := QuotientGroup.mk' N
  inl_injective := by
    intro a b h
    exact Subtype.ext h
  range_inl_eq_ker_rightHom := by
    rw [Subgroup.range_subtype, QuotientGroup.ker_mk']
  rightHom_surjective := QuotientGroup.mk'_surjective N

theorem quotientGroupExtension_conjAct_eq_conjNormal (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (g : G) : (quotientGroupExtension G N).conjAct g = MulAut.conjNormal (H := N) g := by
  ext n
  simpa [quotientGroupExtension, MulAut.conjNormal_apply] using
    ((quotientGroupExtension G N).inl_conjAct_comm (e := g) (n := n))

noncomputable abbrev quotientGroupSection (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    (quotientGroupExtension G N).Section :=
  GroupExtension.surjInvRightHom (quotientGroupExtension G N)

noncomputable def quotientSectionDefect (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    (G в§ё N) Г— (G в§ё N) вҶ’ N := fun xy =>
  let S := quotientGroupExtension G N
  let Пғ := quotientGroupSection G N
  Classical.choose <|
    (show вҲғ n : N, S.inl n = Пғ xy.1 * Пғ xy.2 * (Пғ (xy.1 * xy.2))вҒ»В№ from by
      simpa [MonoidHom.mem_range] using
        (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
          (S := S) (Пғ := Пғ) (gвӮҒ := xy.1) (gвӮӮ := xy.2)))

theorem quotientSectionDefect_spec (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (x y : G в§ё N) : вҶ‘(quotientSectionDefect G N (x, y)) = quotientGroupSection G N x * quotientGroupSection G N y * (quotientGroupSection G N (x * y))вҒ»В№ := by
  classical
  unfold quotientSectionDefect
  simpa [quotientGroupSection, quotientGroupExtension] using
    (Classical.choose_spec
      (show вҲғ n : N,
          (quotientGroupExtension G N).inl n =
            quotientGroupSection G N x * quotientGroupSection G N y *
              (quotientGroupSection G N (x * y))вҒ»В№ from by
        simpa [MonoidHom.mem_range, quotientGroupSection, quotientGroupExtension] using
          (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
            (S := quotientGroupExtension G N)
            (Пғ := quotientGroupSection G N) (gвӮҒ := x) (gвӮӮ := y))))

noncomputable def quotientSectionRemainder (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    G вҶ’ N := fun g =>
  вҹЁg * (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№, by
    apply (QuotientGroup.eq_one_iff (N := N)
      (x := g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№)).mp
    change (QuotientGroup.mk' N) (g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№) = 1
    have hПғ :
        (QuotientGroup.mk' N : G вҶ’* G в§ё N) (quotientGroupSection G N ((QuotientGroup.mk' N) g)) =
          (QuotientGroup.mk' N) g := by
      simpa [quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section (S := quotientGroupExtension G N)
          (Пғ := quotientGroupSection G N) ((QuotientGroup.mk' N) g))
    rw [map_mul, map_inv, hПғ]
    simpвҹ©

theorem quotientSectionRemainder_mul (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (g h : G) : quotientSectionRemainder G N (g * h) = quotientSectionRemainder G N g * (MulAut.conjNormal (H := N) (quotientGroupSection G N ((QuotientGroup.mk' N) g)) (quotientSectionRemainder G N h)) * quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h)) := by
  classical
  apply Subtype.ext
  change
    ((g * h) * (quotientGroupSection G N ((QuotientGroup.mk' N) (g * h)))вҒ»В№ : G) =
      ((g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№) *
          вҶ‘(MulAut.conjNormal (H := N) (quotientGroupSection G N ((QuotientGroup.mk' N) g))
            (quotientSectionRemainder G N h)) *
          вҶ‘(quotientSectionDefect G N
            ((QuotientGroup.mk' N) g, (QuotientGroup.mk' N) h)) : G)
  rw [MulAut.conjNormal_apply]
  rw [quotientSectionDefect_spec]
  change
    (g * h) * (quotientGroupSection G N ((QuotientGroup.mk' N) (g * h)))вҒ»В№ =
      (g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№) *
        (quotientGroupSection G N ((QuotientGroup.mk' N) g) *
          (h * (quotientGroupSection G N ((QuotientGroup.mk' N) h))вҒ»В№) *
          (quotientGroupSection G N ((QuotientGroup.mk' N) g))вҒ»В№) *
        (quotientGroupSection G N ((QuotientGroup.mk' N) g) *
          quotientGroupSection G N ((QuotientGroup.mk' N) h) *
          (quotientGroupSection G N ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h))вҒ»В№)
  rw [map_mul]
  group

noncomputable def quotientTransgressionFactor (A : Type*) (G : Type*) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A) : (G в§ё N) Г— (G в§ё N) вҶ’ A :=
  fun xy => ПҮ (quotientSectionDefect G N xy)

noncomputable def inflatedQuotientTransgressionFactor (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A) : G Г— G вҶ’ A :=
  fun gh =>
    quotientTransgressionFactor A G N ПҮ
      (((QuotientGroup.mk' N) gh.1), ((QuotientGroup.mk' N) gh.2))

noncomputable abbrev restrictHomKerEquivQuotientHom (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] : (MonoidHom.restrictHom N A).ker вүғ* (G в§ё N вҶ’* A) := MonoidHom.restrictHomKerEquiv A N

def restrictToConjInvariantHom (A : Type*) (G : Type*) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    (G вҶ’* A) вҶ’ ConjInvariantHom A G N := fun ПҲ =>
  вҹЁПҲ.comp N.subtype, by
    intro g
    ext n
    change ПҲ (g * n.1 * gвҒ»В№) = ПҲ n.1
    simp [MulAut.conjNormal_apply, map_mul, map_inv, mul_assoc, mul_left_comm, mul_comm]вҹ©

noncomputable abbrev trivialCoeffRep (k G : Type) [CommRing k] [Group G] : Rep k G := Rep.trivial k G k

noncomputable abbrev H1TrivialIso (k G : Type) [CommRing k] [Group G] : groupCohomology.H1 (trivialCoeffRep k G) вү… ModuleCat.of k (Additive G вҶ’+ k) := groupCohomology.H1IsoOfIsTrivial (trivialCoeffRep k G)

theorem inflation_restriction_H1_exact (k G : Type) [CommRing k] [Group G] (N : Subgroup G) [N.Normal] : (groupCohomology.H1InfRes (trivialCoeffRep k G) N).Exact := by
  simpa [trivialCoeffRep] using groupCohomology.H1InfRes_exact (A := trivialCoeffRep k G) (S := N)

theorem inflation_restriction_H1_exact_zmod (p : в„•) (G : Type) [Group G] (N : Subgroup G) [N.Normal] : (groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).Exact := by
  simpa using inflation_restriction_H1_exact (k := ZMod p) (G := G) N

theorem inflation_restriction_H1_injective_zmod (p : в„•) (G : Type) [Group G] (N : Subgroup G) [N.Normal] : Function.Injective ((groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).f) := by
  simpa using (ModuleCat.mono_iff_injective ((groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).f)).1 (by infer_instance)

@[reducible] def trivialMulDistribMulAction (G A : Type*) [Monoid G] [CommGroup A] :
    MulDistribMulAction G A where
  smul := fun _ a => a
  one_smul := by
    intro a
    rfl
  mul_smul := by
    intro g h a
    rfl
  smul_mul := by
    intro g a b
    rfl
  smul_one := by
    intro g
    rfl

theorem exists_lift_of_transgressionFactor_isMulCoboundary (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A) (hПҮ : вҲҖ g : G, ПҮ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = ПҮ) : (letI := trivialMulDistribMulAction (G в§ё N) A; groupCohomology.IsMulCoboundaryвӮӮ (quotientTransgressionFactor A G N ПҮ)) вҶ’ вҲғ ПҲ : G вҶ’* A, ПҲ.comp N.subtype = ПҮ := by
  intro hcb
  classical
  letI := trivialMulDistribMulAction (G в§ё N) A
  rcases hcb with вҹЁb, hbвҹ©
  have hb1 : b 1 = ПҮ (quotientSectionDefect G N (1, 1)) := by
    simpa [quotientTransgressionFactor, div_eq_mul_inv] using hb 1 1
  have hb_mul : вҲҖ x y : G в§ё N,
      ПҮ (quotientSectionDefect G N (x, y)) * b (x * y) = b x * b y := by
    intro x y
    have hxy := congrArg (fun a : A => a * b (x * y)) (hb x y)
    simpa [quotientTransgressionFactor, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hxy.symm
  have hdef11 : вҶ‘(quotientSectionDefect G N (1, 1)) = quotientGroupSection G N 1 := by
    simpa using quotientSectionDefect_spec G N (1 : G в§ё N) 1
  have h_ext_aux : вҲҖ n : N, ПҮ (quotientSectionRemainder G N (n : G)) * b 1 = ПҮ n := by
    intro n
    have hqn : (QuotientGroup.mk' N) (n : G) = 1 := by
      exact (QuotientGroup.eq_one_iff (N := N) (x := (n : G))).mpr n.property
    have hmul : quotientSectionRemainder G N (n : G) * quotientSectionDefect G N (1, 1) = n := by
      apply Subtype.ext
      change (((n : G) * (quotientGroupSection G N ((QuotientGroup.mk' N) (n : G)))вҒ»В№) *
          quotientSectionDefect G N (1, 1) : G) = (n : G)
      rw [hqn, hdef11]
      simp [mul_assoc]
    calc
      ПҮ (quotientSectionRemainder G N (n : G)) * b 1
          = ПҮ (quotientSectionRemainder G N (n : G)) * ПҮ (quotientSectionDefect G N (1, 1)) := by
              rw [hb1]
      _ = ПҮ (quotientSectionRemainder G N (n : G) * quotientSectionDefect G N (1, 1)) := by
            rw [вҶҗ ПҮ.map_mul]
      _ = ПҮ n := by rw [hmul]
  let ПҲ : G вҶ’* A :=
    { toFun := fun g => ПҮ (quotientSectionRemainder G N g) * b ((QuotientGroup.mk' N) g)
      map_one' := by
        simpa using h_ext_aux (1 : N)
      map_mul' := by
        intro g h
        have hconj :
            ПҮ
                (MulAut.conjNormal (H := N)
                  (quotientGroupSection G N ((QuotientGroup.mk' N) g))
                  (quotientSectionRemainder G N h)) =
              ПҮ (quotientSectionRemainder G N h) := by
          have hcomp := congrArg (fun f : N вҶ’* A => f (quotientSectionRemainder G N h))
            (hПҮ (quotientGroupSection G N ((QuotientGroup.mk' N) g)))
          simpa using hcomp
        have hrПҮ :
            ПҮ (quotientSectionRemainder G N (g * h)) =
              ПҮ (quotientSectionRemainder G N g) * ПҮ (quotientSectionRemainder G N h) *
                ПҮ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) := by
          rw [quotientSectionRemainder_mul, ПҮ.map_mul, ПҮ.map_mul, hconj]
        have hbxy :
            ПҮ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) *
                b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h) =
              b ((QuotientGroup.mk' N) g) * b ((QuotientGroup.mk' N) h) :=
          hb_mul ((QuotientGroup.mk' N) g) ((QuotientGroup.mk' N) h)
        rw [map_mul]
        calc
          ПҮ (quotientSectionRemainder G N (g * h)) * b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h)
              = (ПҮ (quotientSectionRemainder G N g) * ПҮ (quotientSectionRemainder G N h) *
                  ПҮ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h)))) *
                  b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h) := by
                  rw [hrПҮ]
          _ = ПҮ (quotientSectionRemainder G N g) * ПҮ (quotientSectionRemainder G N h) *
                (ПҮ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) *
                  b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h)) := by
                simp [mul_assoc, mul_left_comm, mul_comm]
          _ = ПҮ (quotientSectionRemainder G N g) * ПҮ (quotientSectionRemainder G N h) *
                (b ((QuotientGroup.mk' N) g) * b ((QuotientGroup.mk' N) h)) := by
                rw [hbxy]
          _ = (ПҮ (quotientSectionRemainder G N g) * b ((QuotientGroup.mk' N) g)) *
                (ПҮ (quotientSectionRemainder G N h) * b ((QuotientGroup.mk' N) h)) := by
                simp [mul_assoc, mul_left_comm, mul_comm] }
  refine вҹЁПҲ, ?_вҹ©
  ext n
  change ПҮ (quotientSectionRemainder G N вҶ‘n) * b ((QuotientGroup.mk' N) вҶ‘n) = ПҮ n
  have hqn : (QuotientGroup.mk' N) (вҶ‘n) = 1 := by
    exact (QuotientGroup.eq_one_iff (N := N) (x := (n : G))).mpr n.property
  rw [hqn]
  exact h_ext_aux n

theorem inflatedQuotientTransgressionFactor_isMulCoboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A) (hПҮ : вҲҖ g : G, ПҮ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = ПҮ) : letI := trivialMulDistribMulAction G A; groupCohomology.IsMulCoboundaryвӮӮ (inflatedQuotientTransgressionFactor A G N ПҮ) := by
  letI := trivialMulDistribMulAction G A
  refine вҹЁfun g => (ПҮ (quotientSectionRemainder G N g))вҒ»В№, ?_вҹ©
  intro g h
  dsimp [inflatedQuotientTransgressionFactor, quotientTransgressionFactor]
  change (ПҮ (quotientSectionRemainder G N h))вҒ»В№ / (ПҮ (quotientSectionRemainder G N (g * h)))вҒ»В№ * (ПҮ (quotientSectionRemainder G N g))вҒ»В№ = _
  have hmul := quotientSectionRemainder_mul G N g h
  have hmulПҮ := by
    simpa [map_mul, mul_assoc] using congrArg ПҮ hmul
  have hПҮconj :
      ПҮ (MulAut.conjNormal (H := N)
          (quotientGroupSection G N ((g : G в§ё N)))
          (quotientSectionRemainder G N h)) =
        ПҮ (quotientSectionRemainder G N h) := by
    simpa using congrArg
      (fun f : N вҶ’* A => f (quotientSectionRemainder G N h))
      (hПҮ (quotientGroupSection G N ((g : G в§ё N))))
  rw [hmulПҮ, hПҮconj]
  simp [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm]

noncomputable abbrev quotientTrivialMulRep (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] : Rep в„Ө (G в§ё N) := by
  letI := trivialMulDistribMulAction (G в§ё N) A
  exact Rep.of (Representation.ofMulDistribMulAction (M := G в§ё N) (G := A))

theorem exists_conjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (f : groupCohomology.cocyclesвӮӮ (quotientTrivialMulRep A G N))
    (hf1 : вҲҖ q : G в§ё N, f (1, q) = 0)
    (hf2 : вҲҖ q : G в§ё N, f (q, 1) = 0)
    (hinfl : letI := trivialMulDistribMulAction G A;
      groupCohomology.IsMulCoboundaryвӮӮ
        (fun gh : G Г— G =>
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2)))) :
    вҲғ ПҮ : ConjInvariantHom A G N, вҲғ u : G в§ё N вҶ’ A,
      вҲҖ x y : G в§ё N,
        Additive.toMul (show Additive A from f (x, y)) =
          u y / u (x * y) * u x * quotientTransgressionFactor A G N ПҮ.1 (x, y) := by
  classical
  letI := trivialMulDistribMulAction G A
  rcases hinfl with вҹЁb, hbвҹ©
  have hb' :
      вҲҖ g h : G,
        b h / b (g * h) * b g =
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) g, (QuotientGroup.mk' N) h)) := by
    intro g h
    simpa using hb g h
  have hnq : вҲҖ n : N, QuotientGroup.mk' N (n : G) = 1 := by
    intro n
    simp
  have hf1mul : вҲҖ q : G в§ё N, Additive.toMul (show Additive A from f (1, q)) = (1 : A) := by
    intro q
    simp [hf1 q]
  have hf2mul : вҲҖ q : G в§ё N, Additive.toMul (show Additive A from f (q, 1)) = (1 : A) := by
    intro q
    simp [hf2 q]
  have hb_one : b 1 = 1 := by
    have h := hb' (1 : G) 1
    simpa using h.trans (hf1mul (1 : G в§ё N))
  have hb_leftN : вҲҖ n : N, вҲҖ g : G, b ((n : G) * g) = b n * b g := by
    intro n g
    have h : b g / b ((n : G) * g) * b n = 1 := by
      have h0 := hb' (n : G) g
      rw [hnq n] at h0
      exact h0.trans (hf1mul ((QuotientGroup.mk' N) g))
    have h' := congrArg (fun z : A => z * b ((n : G) * g)) h
    simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using h'.symm
  have hb_rightN : вҲҖ g : G, вҲҖ n : N, b (g * n) = b g * b n := by
    intro g n
    have h : b n / b (g * (n : G)) * b g = 1 := by
      have h0 := hb' g (n : G)
      rw [hnq n] at h0
      exact h0.trans (hf2mul ((QuotientGroup.mk' N) g))
    have h' := congrArg (fun z : A => z * b (g * (n : G))) h
    simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using h'.symm
  have hb_mulN : вҲҖ n1 n2 : N, b ((n1 : G) * n2) = b n1 * b n2 := by
    intro n1 n2
    simpa using hb_leftN n1 (n2 : G)
  let ПҮ0 : N вҶ’* A :=
    { toFun := fun n => (b n)вҒ»В№
      map_one' := by
        change (b (1 : G))вҒ»В№ = 1
        simp [hb_one]
      map_mul' := by
        intro n1 n2
        change (b ((n1 : G) * n2))вҒ»В№ = (b n1)вҒ»В№ * (b n2)вҒ»В№
        rw [hb_mulN n1 n2]
        simp [mul_comm] }
  let Пғ := quotientGroupSection G N
  let u : G в§ё N вҶ’ A := fun q => b (Пғ q)
  refine вҹЁвҹЁПҮ0, ?_вҹ©, u, ?_вҹ©
  В· intro g
    ext n
    change (b ((MulAut.conjNormal (H := N) g) n))вҒ»В№ = (b n)вҒ»В№
    have hleft : b (g * (n : G)) = b ((MulAut.conjNormal (H := N) g) n) * b g := by
      simpa [MulAut.conjNormal_apply, mul_assoc] using
        (hb_leftN ((MulAut.conjNormal (H := N) g) n) g)
    have hright : b (g * (n : G)) = b g * b n := by
      simpa using hb_rightN g n
    have hcomp : b ((MulAut.conjNormal (H := N) g) n) * b g = b n * b g := by
      exact hleft.symm.trans (by simpa [mul_comm] using hright)
    have hEq' := congrArg (fun z : A => z * (b g)вҒ»В№) hcomp
    have hEq : b ((MulAut.conjNormal (H := N) g) n) = b n := by
      simpa [mul_assoc, mul_left_comm, mul_comm] using hEq'
    simpa using congrArg Inv.inv hEq
  В· intro x y
    have hsecx : QuotientGroup.mk' N (Пғ x) = x := by
      simpa [Пғ, quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section
          (S := quotientGroupExtension G N) (Пғ := quotientGroupSection G N) x)
    have hsecy : QuotientGroup.mk' N (Пғ y) = y := by
      simpa [Пғ, quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section
          (S := quotientGroupExtension G N) (Пғ := quotientGroupSection G N) y)
    have hmain : u y / b (Пғ x * Пғ y) * u x =
        Additive.toMul (show Additive A from f (x, y)) := by
      simpa [u, Пғ, hsecx, hsecy] using hb' (Пғ x) (Пғ y)
    have hdefmul : Пғ x * Пғ y = (quotientSectionDefect G N (x, y) : G) * Пғ (x * y) := by
      have h := congrArg (fun z : G => z * Пғ (x * y)) (quotientSectionDefect_spec G N x y)
      simpa [Пғ, mul_assoc] using h.symm
    have hbdef : b (Пғ x * Пғ y) = b (quotientSectionDefect G N (x, y)) * u (x * y) := by
      rw [hdefmul]
      simpa [u, Пғ] using hb_leftN (quotientSectionDefect G N (x, y)) (Пғ (x * y))
    calc
      Additive.toMul (show Additive A from f (x, y))
          = u y / b (Пғ x * Пғ y) * u x := by
            simpa using hmain.symm
      _ = u y / (b (quotientSectionDefect G N (x, y)) * u (x * y)) * u x := by
            rw [hbdef]
      _ = u y / u (x * y) * u x * quotientTransgressionFactor A G N ПҮ0 (x, y) := by
            simp [u, Пғ, ПҮ0, quotientTransgressionFactor, div_eq_mul_inv,
              mul_assoc, mul_left_comm, mul_comm]

theorem quotientH2_exists_normalized_cocycle (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (x : groupCohomology.H2 (quotientTrivialMulRep A G N)) :
    вҲғ f : groupCohomology.cocyclesвӮӮ (quotientTrivialMulRep A G N),
      groupCohomology.H2ПҖ (quotientTrivialMulRep A G N) f = x вҲ§
        (вҲҖ q : G в§ё N, f (1, q) = 0) вҲ§
        (вҲҖ q : G в§ё N, f (q, 1) = 0) := by
  classical
  letI := trivialMulDistribMulAction (G в§ё N) A
  change groupCohomology.H2 (Rep.ofMulDistribMulAction (G в§ё N) A) at x
  change
    вҲғ f : groupCohomology.cocyclesвӮӮ (Rep.ofMulDistribMulAction (G в§ё N) A),
      groupCohomology.H2ПҖ (Rep.ofMulDistribMulAction (G в§ё N) A) f = x вҲ§
        (вҲҖ q : G в§ё N, f (1, q) = 0) вҲ§
        (вҲҖ q : G в§ё N, f (q, 1) = 0)
  refine groupCohomology.H2_induction_on x ?_
  intro z
  let c : A := Additive.toMul (z (1, 1))
  have hcob : groupCohomology.IsMulCoboundaryвӮӮ (fun _ : (G в§ё N) Г— (G в§ё N) => cвҒ»В№) := by
    refine вҹЁfun _ : G в§ё N => cвҒ»В№, ?_вҹ©
    intro g h
    change cвҒ»В№ / cвҒ»В№ * cвҒ»В№ = cвҒ»В№
    simp
  let b : groupCohomology.coboundariesвӮӮ (Rep.ofMulDistribMulAction (G в§ё N) A) :=
    groupCohomology.coboundariesOfIsMulCoboundaryвӮӮ hcob
  let f : groupCohomology.cocyclesвӮӮ (Rep.ofMulDistribMulAction (G в§ё N) A) :=
    z + groupCohomology.coboundariesToCocyclesвӮӮ _ b
  refine вҹЁf, ?_, ?_, ?_вҹ©
  В· rw [groupCohomology.H2ПҖ_eq_iff]
    have hdiff : вҮ‘f - вҮ‘z = вҮ‘b := by
      ext p
      change z p + b p - z p = b p
      abel
    rw [hdiff]
    exact b.2
  В· intro q
    have hz : z (1, q) = z (1, 1) := groupCohomology.cocyclesвӮӮ_map_one_fst z q
    have hb : b (1, q) = - z (1, 1) := by
      rfl
    change z (1, q) + b (1, q) = 0
    rw [hz, hb]
    abel
  В· intro q
    have hz : z (q, 1) = z (1, 1) := by
      simpa [Rep.ofMulDistribMulAction_ПҒ_apply_apply, c] using
        groupCohomology.cocyclesвӮӮ_map_one_snd z q
    have hb : b (q, 1) = - z (1, 1) := by
      rfl
    change z (q, 1) + b (q, 1) = 0
    rw [hz, hb]
    abel

noncomputable def quotientTransgressionCocycle (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A)
    (hПҮ : вҲҖ g : G, ПҮ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = ПҮ) :
    groupCohomology.cocyclesвӮӮ (quotientTrivialMulRep A G N) := by
  letI := trivialMulDistribMulAction (G в§ё N) A
  have hf : groupCohomology.IsMulCocycleвӮӮ (quotientTransgressionFactor A G N ПҮ) := by
    classical
    intro x y z
    change
      ПҮ (quotientSectionDefect G N (x * y, z)) * ПҮ (quotientSectionDefect G N (x, y)) =
        ПҮ (quotientSectionDefect G N (y, z)) * ПҮ (quotientSectionDefect G N (x, y * z))
    let S := quotientGroupExtension G N
    let Пғ := quotientGroupSection G N
    let c : (G в§ё N) Г— (G в§ё N) вҶ’ N := quotientSectionDefect G N
    have hmul (a b : G в§ё N) : Пғ a * Пғ b = вҶ‘(c (a, b)) * Пғ (a * b) := by
      calc
        Пғ a * Пғ b = (Пғ a * Пғ b * (Пғ (a * b))вҒ»В№) * Пғ (a * b) := by
          simp [mul_assoc]
        _ = вҶ‘(c (a, b)) * Пғ (a * b) := by
          congr 1
          unfold c quotientSectionDefect
          simpa [quotientGroupSection, quotientGroupExtension] using
            (Classical.choose_spec
              (show вҲғ n : N,
                  (quotientGroupExtension G N).inl n =
                    quotientGroupSection G N a * quotientGroupSection G N b *
                      (quotientGroupSection G N (a * b))вҒ»В№ from by
                simpa [MonoidHom.mem_range, quotientGroupSection, quotientGroupExtension] using
                  (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
                    (S := quotientGroupExtension G N)
                    (Пғ := quotientGroupSection G N) (gвӮҒ := a) (gвӮӮ := b)))).symm
    have hleft : Пғ x * Пғ y * Пғ z = (((c (x, y) * c (x * y, z) : N) : G) * Пғ (x * (y * z))) := by
      calc
        Пғ x * Пғ y * Пғ z = (Пғ x * Пғ y) * Пғ z := by
          simp [mul_assoc]
        _ = (вҶ‘(c (x, y)) * Пғ (x * y)) * Пғ z := by
          rw [hmul x y]
        _ = вҶ‘(c (x, y)) * (Пғ (x * y) * Пғ z) := by
          simp [mul_assoc]
        _ = вҶ‘(c (x, y)) * (вҶ‘(c (x * y, z)) * Пғ ((x * y) * z)) := by
          rw [hmul (x * y) z]
        _ = (((c (x, y) * c (x * y, z) : N) : G) * Пғ ((x * y) * z)) := by
          simp [mul_assoc]
        _ = (((c (x, y) * c (x * y, z) : N) : G) * Пғ (x * (y * z))) := by
          rw [mul_assoc]
    have hright : Пғ x * Пғ y * Пғ z =
        (((((S.conjAct (Пғ x)) (c (y, z))) * c (x, y * z) : N) : G) * Пғ (x * (y * z))) := by
      calc
        Пғ x * Пғ y * Пғ z = Пғ x * (Пғ y * Пғ z) := by
          simp [mul_assoc]
        _ = Пғ x * (вҶ‘(c (y, z)) * Пғ (y * z)) := by
          rw [hmul y z]
        _ = (Пғ x * вҶ‘(c (y, z)) * (Пғ x)вҒ»В№) * (Пғ x * Пғ (y * z)) := by
          simp [mul_assoc]
        _ = (вҶ‘((S.conjAct (Пғ x)) (c (y, z))) * (Пғ x * Пғ (y * z))) := by
          congr 1
          simpa [S] using (GroupExtension.inl_conjAct_comm (S := S) (e := Пғ x) (n := c (y, z))).symm
        _ = вҶ‘((S.conjAct (Пғ x)) (c (y, z))) * (вҶ‘(c (x, y * z)) * Пғ (x * (y * z))) := by
          rw [hmul x (y * z)]
        _ = (((((S.conjAct (Пғ x)) (c (y, z))) * c (x, y * z) : N) : G) * Пғ (x * (y * z))) := by
          simp [mul_assoc]
    have hEqG : (((c (x, y) * c (x * y, z) : N) : G)) =
        (((((S.conjAct (Пғ x)) (c (y, z))) * c (x, y * z) : N) : G)) := by
      have htmp :
          (((c (x, y) * c (x * y, z) : N) : G) * Пғ (x * (y * z))) =
            (((((S.conjAct (Пғ x)) (c (y, z))) * c (x, y * z) : N) : G) * Пғ (x * (y * z))) := by
        calc
          (((c (x, y) * c (x * y, z) : N) : G) * Пғ (x * (y * z))) = Пғ x * Пғ y * Пғ z := by
            simpa using hleft.symm
          _ = (((((S.conjAct (Пғ x)) (c (y, z))) * c (x, y * z) : N) : G) * Пғ (x * (y * z))) := by
            simpa using hright
      have htmp' := congrArg (fun g : G => g * (Пғ (x * (y * z)))вҒ»В№) htmp
      simpa [mul_assoc] using htmp'
    have hEqN : c (x, y) * c (x * y, z) = (S.conjAct (Пғ x)) (c (y, z)) * c (x, y * z) := by
      exact Subtype.ext hEqG
    have hПҮeq : ПҮ (c (x, y)) * ПҮ (c (x * y, z)) =
        ПҮ ((S.conjAct (Пғ x)) (c (y, z))) * ПҮ (c (x, y * z)) := by
      simpa using congrArg ПҮ hEqN
    have hПҮconj : ПҮ ((S.conjAct (Пғ x)) (c (y, z))) = ПҮ (c (y, z)) := by
      have hconjEq : S.conjAct (Пғ x) = MulAut.conjNormal (H := N) (Пғ x) := by
        ext n
        simpa [S, quotientGroupExtension, MulAut.conjNormal_apply] using
          ((quotientGroupExtension G N).inl_conjAct_comm (e := Пғ x) (n := n))
      have hПҮПғ : ПҮ.comp ((S.conjAct (Пғ x)).toMonoidHom) = ПҮ := by
        rw [hconjEq]
        exact hПҮ (Пғ x)
      simpa using DFunLike.congr_fun hПҮПғ (c (y, z))
    have hfinal : ПҮ (c (x, y)) * ПҮ (c (x * y, z)) = ПҮ (c (y, z)) * ПҮ (c (x, y * z)) := by
      calc
        ПҮ (c (x, y)) * ПҮ (c (x * y, z)) = ПҮ ((S.conjAct (Пғ x)) (c (y, z))) * ПҮ (c (x, y * z)) := hПҮeq
        _ = ПҮ (c (y, z)) * ПҮ (c (x, y * z)) := by rw [hПҮconj]
    simpa [c, mul_comm] using hfinal
  simpa [quotientTrivialMulRep, Rep.ofMulDistribMulAction] using
    (groupCohomology.cocyclesOfIsMulCocycleвӮӮ hf)

noncomputable abbrev quotientTransgressionClass (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A)
    (hПҮ : вҲҖ g : G, ПҮ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = ПҮ) :
    groupCohomology.H2 (quotientTrivialMulRep A G N) :=
  groupCohomology.H2ПҖ (quotientTrivialMulRep A G N)
    (quotientTransgressionCocycle A G N ПҮ hПҮ)

noncomputable def quotientTransgressionMap (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    ConjInvariantHom A G N вҶ’ groupCohomology.H2 (quotientTrivialMulRep A G N) := fun ПҮ =>
  quotientTransgressionClass A G N ПҮ.1 ПҮ.2

theorem normalized_quotientCocycle_class_eq_transgressionMap_of_inflated_coboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (f : groupCohomology.cocyclesвӮӮ (quotientTrivialMulRep A G N))
    (hf1 : вҲҖ q : G в§ё N, f (1, q) = 0)
    (hf2 : вҲҖ q : G в§ё N, f (q, 1) = 0)
    (hinfl : letI := trivialMulDistribMulAction G A;
      groupCohomology.IsMulCoboundaryвӮӮ
        (fun gh : G Г— G =>
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2)))) :
    вҲғ ПҮ : ConjInvariantHom A G N,
      groupCohomology.H2ПҖ (quotientTrivialMulRep A G N) f = quotientTransgressionMap A G N ПҮ := by
  rcases
      exists_conjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary
        A G N f hf1 hf2 hinfl with вҹЁПҮ, u, huвҹ©
  refine вҹЁПҮ, ?_вҹ©
  rw [quotientTransgressionMap, quotientTransgressionClass]
  apply
    (groupCohomology.H2ПҖ_eq_iff (A := quotientTrivialMulRep A G N) f
      (quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2)).2
  letI := trivialMulDistribMulAction (G в§ё N) A
  change
    (Additive.ofMul вҲҳ fun xy : (G в§ё N) Г— (G в§ё N) =>
      Additive.toMul
        (show Additive A from
          f xy - quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2 xy)) вҲҲ
      groupCohomology.coboundariesвӮӮ (Rep.ofMulDistribMulAction (G в§ё N) A)
  refine
    (groupCohomology.coboundariesOfIsMulCoboundaryвӮӮ
      (f := fun xy : (G в§ё N) Г— (G в§ё N) =>
        Additive.toMul
          (show Additive A from
            f xy - quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2 xy)) ?_).property
  refine вҹЁu, ?_вҹ©
  intro x y
  have htrans :
      Additive.toMul
          (show Additive A from
            quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2 (x, y)) =
        quotientTransgressionFactor A G N ПҮ.1 (x, y) := by
    unfold quotientTransgressionCocycle
    rfl
  calc
    u y / u (x * y) * u x =
        (u y / u (x * y) * u x * quotientTransgressionFactor A G N ПҮ.1 (x, y)) /
          quotientTransgressionFactor A G N ПҮ.1 (x, y) := by
      simp [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm]
    _ =
        Additive.toMul (show Additive A from f (x, y)) /
          quotientTransgressionFactor A G N ПҮ.1 (x, y) := by
      rw [hu x y]
    _ =
        Additive.toMul (show Additive A from f (x, y)) /
          Additive.toMul
            (show Additive A from
              quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2 (x, y)) := by
      rw [htrans]
    _ =
        Additive.toMul
          (show Additive A from
            f (x, y) - quotientTransgressionCocycle A G N ПҮ.1 ПҮ.2 (x, y)) := by
      rfl

theorem transgressionFactor_isMulCoboundary_of_exists_lift (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (ПҮ : N вҶ’* A) : (вҲғ ПҲ : G вҶ’* A, ПҲ.comp N.subtype = ПҮ) вҶ’ letI := trivialMulDistribMulAction (G в§ё N) A; groupCohomology.IsMulCoboundaryвӮӮ (quotientTransgressionFactor A G N ПҮ) := by
  intro hПҮ
  classical
  letI := trivialMulDistribMulAction (G в§ё N) A
  rcases hПҮ with вҹЁПҲ, hПҲвҹ©
  refine вҹЁfun q => ПҲ (quotientGroupSection G N q), ?_вҹ©
  intro x y

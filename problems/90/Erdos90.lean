theorem closedFrattini_isOpen (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : _root_.Erdos90.IsFinitelyGeneratedProPGroup p G) :
    IsOpen (_root_.Erdos90.closedFrattini p G : Set G) := by
  classical
  let H : Subgroup G := _root_.Erdos90.closedFrattini p G
  have hfin : Finite (G ⧸ H) := closedFrattini_quotient_finite G p hG
  letI : Finite (G ⧸ H) := hfin
  letI : H.FiniteIndex := Subgroup.finiteIndex_of_finite_quotient (H := H)
  have hclosed : IsClosed (H : Set G) := by
    dsimp [H, _root_.Erdos90.closedFrattini]
    exact Subgroup.isClosed_topologicalClosure _
  exact Subgroup.isOpen_of_isClosed_of_finiteIndex H hclosed

theorem exists_injective_fin_away_of_infinite_pred (P : ℕ → Prop) (hP : {n : ℕ | P n}.Infinite) (t : ℕ) (badPrimes : Finset ℕ) :

  haveI : T2Space (G ⧸ N) := inferInstance
  have hHclosed : IsClosed (H : Set (G ⧸ N)) := (Set.toFinite (H : Set (G ⧸ N))).isClosed
  have hH_eq_top : H = ⊤ := by
    apply top_unique
    rw [← hH_top]
    exact Subgroup.topologicalClosure_minimal H le_rfl hHclosed

# Definitions for Lemmas 3 and 4
-/
/-- A valid Nathanson sequence satisfies n_{k-1} ≥ 3k² + 6k + 1 and n_k ≥ 8n_{k-1} -/
structure NathansonSeq where
  n : ℕ → ℕ
  n_pos : ∀ k, 0 < n k
  n_mono : ∀ k, n k ≤ n (k + 1)
  growth_bound : ∀ k ≥ 1, n (k - 1) ≥ 3 * k^2 + 6 * k + 1
  exponential_growth : ∀ k ≥ 1, n k ≥ 8 * n (k - 1)
namespace NathansonSeq
variable (seq : NathansonSeq)
/-- N_k = 2n_k + 1 -/
def N (k : ℕ) : ℕ := 2 * seq.n k + 1
/-- P_k for k ≥ 1 (empty for k = 0) -/
def P (k : ℕ) : Finset ℕ :=
  if k = 0 then ∅
  else Finset.Icc (seq.N (k - 1) + 1) (seq.n k - seq.N (k - 1))
/-- Q_k for k ≥ 1 (empty for k = 0) -/
def Q (k : ℕ) : Finset ℕ :=
  if k = 0 then ∅
  else Finset.image (fun u => seq.n k - seq.n (k - 1) - 3 * k * u + 1)
                    (Finset.Icc 1 (k + 1))
/-- R_k for k ≥ 1 (empty for k = 0) -/
def R (k : ℕ) : Finset ℕ :=
  if k = 0 then ∅
  else (Finset.Icc (seq.n k + 1) (seq.n k + seq.N (k - 1))) \
       Finset.image (fun u => seq.n k + seq.n (k - 1) + 3 * k * u)
                    (Finset.Icc 1 (k + 1))
/-- B_k = P_k ∪ Q_k ∪ R_k -/
def B_k (k : ℕ) : Finset ℕ := seq.P k ∪ seq.Q k ∪ seq.R k
/-- S_k = [n_k + 1, n_k + n_{k-1} + k + 1], a subset of R_k used in Lemma 3 proof -/
def S (k : ℕ) : Finset ℕ :=
  if k = 0 then ∅
  else Finset.Icc (seq.n k + 1) (seq.n k + seq.n (k - 1) + k + 1)
/-- T_k = [n_k + n_{k-1} + 3k(k+1) + 1, n_k + N_{k-1}], a subset of R_k used in Lemma 3 proof -/
def T (k : ℕ) : Finset ℕ :=
  if k = 0 then ∅
  else Finset.Icc (seq.n k + seq.n (k - 1) + 3 * k * (k + 1) + 1) (seq.n k + seq.N (k - 1))
/-- The full set B as a predicate -/
def inB (x : ℕ) : Prop := ∃ k ≥ 1, x ∈ seq.B_k k
/-- Count representations of n in a finset S -/
def countReps (S : Finset ℕ) (n : ℕ) : ℕ :=
  Finset.card (Finset.filter (fun p : ℕ × ℕ =>
    p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧ p.1 ∈ S ∧ p.2 ∈ S)
    (Finset.product S S))
/-- countReps equals countRepsGen -/
lemma countReps_eq_countRepsGen (S : Finset ℕ) (n : ℕ) :
    countReps S n = countRepsGen S n := rfl
/-- countReps is monotone with respect to set inclusion -/
lemma countReps_mono {S T : Finset ℕ} (h : S ⊆ T) (n : ℕ) :
    countReps S n ≤ countReps T n := by
  unfold countReps
  apply Finset.card_le_card
  intro p hp
  simp only [Finset.mem_filter] at hp ⊢
  have hprod : p ∈ Finset.product T T := Finset.product_subset_product h h hp.1
  exact ⟨hprod, hp.2.1, hp.2.2.1, h hp.2.2.2.1, h hp.2.2.2.2⟩

theorem crtProductPstar_selected_eq {ι : Type*} [Fintype ι]
    (M p0 : ℕ) [NeZero M] (p : ι → ℕ)
    (φ : ZMod M ≃+ ProductSpace p0 p) (a : ZMod M)
    (α : ZMod p0) (β e : ∀ i : ι, ZMod (p i)) (h : ZMod p0)
    (ha1 : (φ a).1 = α)
    {r : ZMod M} (hr : r ∈ crtProductPstarFinset M p0 p φ a β e h) :

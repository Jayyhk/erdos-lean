  Algebra.IsQuadraticExtension.isGalois 𝒟.L 𝒟.K

private theorem nontrivial_aut_exists :
    ∃ σ : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K, σ ≠ 1 := by
  have hcard : Nat.card (𝒟.K ≃ₐ[𝒟.L] 𝒟.K) = 2 := by
    rw [IsGalois.card_aut_eq_finrank,
      Algebra.IsQuadraticExtension.finrank_eq_two]
  by_contra h
  push Not at h
  have hsub : Subsingleton (𝒟.K ≃ₐ[𝒟.L] 𝒟.K) :=
    ⟨fun a b => by rw [h a, h b]⟩
  have hone : Nat.card (𝒟.K ≃ₐ[𝒟.L] 𝒟.K) = 1 :=
    Nat.card_eq_one_iff_unique.mpr ⟨hsub, ⟨1⟩⟩
  omega

noncomputable def c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K :=
  (nontrivial_aut_exists 𝒟).choose

theorem c_ne_one : 𝒟.c ≠ 1 :=
  (nontrivial_aut_exists 𝒟).choose_spec

theorem i_K_notMem_range :
    𝒟.i_K ∉ (algebraMap 𝒟.L 𝒟.K).range := by
  rintro ⟨a, ha⟩

  have ha2 : a * a = -1 := by
    have h : (algebraMap 𝒟.L 𝒟.K) (a * a) = (algebraMap 𝒟.L 𝒟.K) (-1) := by
      rw [map_mul, ha, 𝒟.i_K_sq, map_neg, map_one]
    exact FaithfulSMul.algebraMap_injective 𝒟.L 𝒟.K h

  obtain ⟨φ⟩ := (inferInstance : Nonempty (𝒟.L →+* ℂ))
  have hφ : ComplexEmbedding.IsReal φ :=
    NumberField.IsTotallyReal.complexEmbedding_isReal φ
  let ψ : 𝒟.L →+* ℝ := hφ.embedding
  have hψ : (ψ a) * (ψ a) = -1 := by
    have h := congrArg ψ ha2
    simpa [map_mul, map_neg, map_one] using h

  have hnn : 0 ≤ ψ a * ψ a := mul_self_nonneg _
  linarith

theorem adjoin_i_K_eq_top :
    Algebra.adjoin 𝒟.L ({𝒟.i_K} : Set 𝒟.K) = ⊤ := by

  have hprime : (Module.finrank 𝒟.L 𝒟.K).Prime := by
    rw [Algebra.IsQuadraticExtension.finrank_eq_two]
    exact Nat.prime_two
  have hsimple : IsSimpleOrder (Subalgebra 𝒟.L 𝒟.K) :=
    Subalgebra.isSimpleOrder_of_finrank_prime 𝒟.L 𝒟.K hprime
  rcases hsimple.eq_bot_or_eq_top (Algebra.adjoin 𝒟.L ({𝒟.i_K} : Set 𝒟.K))
    with hbot | htop
  · exfalso
    apply 𝒟.i_K_notMem_range
    have hmem : 𝒟.i_K ∈ (⊥ : Subalgebra 𝒟.L 𝒟.K) := by
      rw [← hbot]
      exact Algebra.self_mem_adjoin_singleton 𝒟.L 𝒟.i_K
    exact Algebra.mem_bot.mp hmem
  · exact htop

theorem c_i_K : 𝒟.c 𝒟.i_K = -𝒟.i_K := by

  have h_sq : 𝒟.c 𝒟.i_K * 𝒟.c 𝒟.i_K = -1 := by
    have h1 : 𝒟.c (𝒟.i_K * 𝒟.i_K) = 𝒟.c (-1) := by rw [𝒟.i_K_sq]
    rw [map_mul, map_neg, map_one] at h1
    exact h1

  have hprod : (𝒟.c 𝒟.i_K - 𝒟.i_K) * (𝒟.c 𝒟.i_K + 𝒟.i_K) = 0 := by
    have : (𝒟.c 𝒟.i_K - 𝒟.i_K) * (𝒟.c 𝒟.i_K + 𝒟.i_K)
        = 𝒟.c 𝒟.i_K * 𝒟.c 𝒟.i_K - 𝒟.i_K * 𝒟.i_K := by ring
    rw [this, h_sq, 𝒟.i_K_sq, sub_self]

  rcases mul_eq_zero.mp hprod with h | h
  ·

    exfalso
    apply 𝒟.c_ne_one
    have hfix : 𝒟.c 𝒟.i_K = 𝒟.i_K := sub_eq_zero.mp h

    have hext : (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K) = AlgHom.id 𝒟.L 𝒟.K := by
      refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
      intro y hy
      simp [Set.mem_singleton_iff.mp hy, hfix]

    ext x
    have hx := AlgHom.congr_fun hext x
    simpa using hx
  · exact eq_neg_of_add_eq_zero_left h

theorem c_sq_eq_id (𝒟 : AdmissibleDatum) (x : 𝒟.K) : 𝒟.c (𝒟.c x) = x := by

  have hext : (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K).comp (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K)
      = AlgHom.id 𝒟.L 𝒟.K := by
    refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
    intro y hy
    have hy_eq : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
    subst hy_eq
    simp [𝒟.c_i_K, map_neg]
  have := AlgHom.congr_fun hext x
  simpa using this

noncomputable def relNorm (u : 𝒟.K) : 𝒟.K := u * 𝒟.c u

end AdmissibleDatum

theorem complex_embedding_conjugation_compat
    (𝒟 : AdmissibleDatum) (σ : 𝒟.K →+* ℂ) (x : 𝒟.K) :
    σ (𝒟.c x) = star (σ x) := by
  let ψ : 𝒟.L →+* ℂ := σ.comp (algebraMap 𝒟.L 𝒟.K)
  have hψ_real : ComplexEmbedding.IsReal ψ :=
    NumberField.IsTotallyReal.complexEmbedding_isReal ψ
  letI : Algebra 𝒟.L ℂ := ψ.toAlgebra
  let σcA : 𝒟.K →ₐ[𝒟.L] ℂ :=
    { σ.comp (𝒟.c : 𝒟.K →+* 𝒟.K) with
      commutes' := fun r => by
        change σ ((𝒟.c : 𝒟.K →+* 𝒟.K) (algebraMap 𝒟.L 𝒟.K r)) = ψ r
        rw [show (𝒟.c : 𝒟.K →+* 𝒟.K) (algebraMap 𝒟.L 𝒟.K r)
              = algebraMap 𝒟.L 𝒟.K r from AlgEquiv.commutes _ _]
        rfl }
  let σstarA : 𝒟.K →ₐ[𝒟.L] ℂ :=
    { (starRingEnd ℂ).comp σ with
      commutes' := fun r => by
        change star (ψ r) = ψ r
        exact RingHom.congr_fun hψ_real r }
  suffices h : σcA = σstarA by
    have := AlgHom.congr_fun h x
    change σ (𝒟.c x) = star (σ x)
    exact this
  refine AlgHom.ext_of_adjoin_eq_top 𝒟.adjoin_i_K_eq_top ?_
  intro y hy
  rw [Set.mem_singleton_iff] at hy
  subst hy
  change σ (𝒟.c 𝒟.i_K) = star (σ 𝒟.i_K)
  rw [𝒟.c_i_K, map_neg]
  have hsq : σ 𝒟.i_K * σ 𝒟.i_K = -1 := by
    have := congrArg σ 𝒟.i_K_sq
    rw [map_mul, map_neg, map_one] at this
    exact this
  have hre : (σ 𝒟.i_K).re = 0 := by
    have hreal : (σ 𝒟.i_K * σ 𝒟.i_K).im = 0 := by rw [hsq]; simp
    have hreal' : (σ 𝒟.i_K * σ 𝒟.i_K).re = -1 := by rw [hsq]; simp
    have him_eq : (σ 𝒟.i_K * σ 𝒟.i_K).im = 2 * (σ 𝒟.i_K).re * (σ 𝒟.i_K).im := by
      simp [Complex.mul_im]; ring
    rw [him_eq] at hreal
    have h2 : (σ 𝒟.i_K).re * (σ 𝒟.i_K).im = 0 := by linarith
    rcases mul_eq_zero.mp h2 with hre0 | him0
    · exact hre0
    · exfalso
      have hreal_re : (σ 𝒟.i_K * σ 𝒟.i_K).re =
          (σ 𝒟.i_K).re * (σ 𝒟.i_K).re - (σ 𝒟.i_K).im * (σ 𝒟.i_K).im := by
        simp [Complex.mul_re]
      rw [hreal_re, him0] at hreal'
      have : (σ 𝒟.i_K).re * (σ 𝒟.i_K).re = -1 := by linarith
      have hnn : 0 ≤ (σ 𝒟.i_K).re * (σ 𝒟.i_K).re := mul_self_nonneg _
      linarith
  apply Complex.ext
  · simp [hre]
  · simp

namespace AdmissibleDatum
variable (𝒟 : AdmissibleDatum)

theorem relNorm_mem_L (𝒟 : AdmissibleDatum) (u : 𝒟.K) :
    𝒟.relNorm u ∈ (algebraMap 𝒟.L 𝒟.K).range := by

  have hc_sq : ∀ x : 𝒟.K, 𝒟.c (𝒟.c x) = x := by
    have hext : (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K).comp (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K)
        = AlgHom.id 𝒟.L 𝒟.K := by
      refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
      intro y hy
      have hy_eq : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
      subst hy_eq
      simp [𝒟.c_i_K, map_neg]
    intro x
    have hx := AlgHom.congr_fun hext x
    simpa using hx

  have hfix_c : 𝒟.c (𝒟.relNorm u) = 𝒟.relNorm u := by
    unfold AdmissibleDatum.relNorm
    rw [map_mul, hc_sq u, mul_comm]

  have hfix : ∀ σ : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K, σ (𝒟.relNorm u) = 𝒟.relNorm u := by
    intro σ
    have hσ_sq : σ 𝒟.i_K * σ 𝒟.i_K = -1 := by
      have h1 : σ (𝒟.i_K * 𝒟.i_K) = σ (-1) := by rw [𝒟.i_K_sq]
      rw [map_mul, map_neg, map_one] at h1; exact h1
    have hprod : (σ 𝒟.i_K - 𝒟.i_K) * (σ 𝒟.i_K + 𝒟.i_K) = 0 := by
      have : (σ 𝒟.i_K - 𝒟.i_K) * (σ 𝒟.i_K + 𝒟.i_K) =
          σ 𝒟.i_K * σ 𝒟.i_K - 𝒟.i_K * 𝒟.i_K := by ring
      rw [this, hσ_sq, 𝒟.i_K_sq, sub_self]
    have hσ_cases : σ 𝒟.i_K = 𝒟.i_K ∨ σ 𝒟.i_K = -𝒟.i_K := by
      rcases mul_eq_zero.mp hprod with h | h
      · exact Or.inl (sub_eq_zero.mp h)
      · exact Or.inr (eq_neg_of_add_eq_zero_left h)

    have hσ_eq : σ = 1 ∨ σ = 𝒟.c := by
      rcases hσ_cases with hid | hc
      · left
        have hext : (σ : 𝒟.K →ₐ[𝒟.L] 𝒟.K) = AlgHom.id 𝒟.L 𝒟.K := by
          refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
          intro y hy
          have : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
          subst this; simpa using hid
        ext x
        have := AlgHom.congr_fun hext x
        simpa using this
      · right
        have hext : (σ : 𝒟.K →ₐ[𝒟.L] 𝒟.K) = (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K) := by
          refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
          intro y hy
          have hy_eq : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
          subst hy_eq
          change σ 𝒟.i_K = 𝒟.c 𝒟.i_K
          rw [hc, 𝒟.c_i_K]
        ext x
        have := AlgHom.congr_fun hext x
        simpa using this
    rcases hσ_eq with h1 | hc
    · rw [h1]; rfl
    · rw [hc]; exact hfix_c

  rw [RingHom.mem_range]
  obtain ⟨a, ha⟩ := (IsGalois.mem_range_algebraMap_iff_fixed
    (F := 𝒟.L) (E := 𝒟.K) (𝒟.relNorm u)).mpr hfix
  exact ⟨a, ha⟩

abbrev V : Type := Fin 𝒟.f → ℂ

noncomputable def Φ : 𝒟.K → 𝒟.V := fun x i => adm_σ 𝒟 i x

theorem Φ_injective (𝒟 : AdmissibleDatum) : Function.Injective 𝒟.Φ := by
  intro x y hxy
  have h0 := congrFun hxy ⟨0, 𝒟.f_pos⟩
  exact (adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩).injective h0

noncomputable def adm_real_embedding (𝒟 : AdmissibleDatum)
    (i : Fin 𝒟.f) : 𝒟.L →+* ℂ :=
  let e : Fin (Module.finrank ℚ 𝒟.L) ≃ NumberField.InfinitePlace 𝒟.L :=
    Fintype.equivFinOfCardEq
      (by
        classical
        have hfr := (NumberField.IsTotallyReal.finrank (K := 𝒟.L)).symm
        have hreal : ∀ w : NumberField.InfinitePlace 𝒟.L,
            NumberField.InfinitePlace.IsReal w :=
          fun w => NumberField.IsTotallyReal.isReal w
        have hcard : Fintype.card (NumberField.InfinitePlace 𝒟.L) =
            NumberField.InfinitePlace.nrRealPlaces 𝒟.L :=
          Fintype.card_congr
            (Equiv.subtypeUnivEquiv hreal).symm
        rw [hcard, ← hfr]) |>.symm
  (e i).embedding

theorem adm_real_embedding_injective (𝒟 : AdmissibleDatum) : Function.Injective (adm_real_embedding 𝒟) := by
  intro i j h
  let e : Fin (Module.finrank ℚ 𝒟.L) ≃ NumberField.InfinitePlace 𝒟.L :=
    Fintype.equivFinOfCardEq
      (by
        classical
        have hfr := (NumberField.IsTotallyReal.finrank (K := 𝒟.L)).symm
        have hreal : ∀ w : NumberField.InfinitePlace 𝒟.L,
            NumberField.InfinitePlace.IsReal w :=
          fun w => NumberField.IsTotallyReal.isReal w
        have hcard : Fintype.card (NumberField.InfinitePlace 𝒟.L) =
            NumberField.InfinitePlace.nrRealPlaces 𝒟.L :=
          Fintype.card_congr
            (Equiv.subtypeUnivEquiv hreal).symm
        rw [hcard, ← hfr]) |>.symm
  change (e i).embedding = (e j).embedding at h
  exact e.injective (NumberField.InfinitePlace.embedding_inj.mp h)

theorem adm_σ_comp_algebraMap (𝒟 : AdmissibleDatum) (i : Fin 𝒟.f) : (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K) = adm_real_embedding 𝒟 i := by
  classical
  simpa [adm_σ, adm_real_embedding, NumberField.ComplexEmbedding.lift] using
    (NumberField.ComplexEmbedding.lift_comp_algebraMap (K := 𝒟.K) (k := 𝒟.L)
      (φ := adm_real_embedding 𝒟 i))

theorem adm_σ_restrict_distinct (𝒟 : AdmissibleDatum) :
    ∀ i j : Fin 𝒟.f, i ≠ j →
      (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K) ≠
      (adm_σ 𝒟 j).comp (algebraMap 𝒟.L 𝒟.K) := by
  intro i j hij hEq
  rw [adm_σ_comp_algebraMap (𝒟 := 𝒟) i, adm_σ_comp_algebraMap (𝒟 := 𝒟) j] at hEq
  exact hij ((adm_real_embedding_injective 𝒟) hEq)

noncomputable def Λ : Submodule ℤ 𝒟.V where
  carrier := { z | ∃ u : 𝒟.K,
      (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = (algebraMap (𝓞 𝒟.K) 𝒟.K) x) ∧
      𝒟.Φ u = z }
  zero_mem' := by
    refine ⟨0, ⟨0, ?_⟩, ?_⟩
    · simp
    · funext i; simp [AdmissibleDatum.Φ]
  add_mem' := by
    rintro z₁ z₂ ⟨u₁, ⟨x₁, hx₁⟩, hz₁⟩ ⟨u₂, ⟨x₂, hx₂⟩, hz₂⟩
    refine ⟨u₁ + u₂, ⟨x₁ + x₂, ?_⟩, ?_⟩
    · push_cast
      rw [mul_add, hx₁, hx₂]
    · funext i
      simp [AdmissibleDatum.Φ, ← hz₁, ← hz₂, map_add]
  smul_mem' := by
    rintro c z ⟨u, ⟨x, hx⟩, hz⟩
    refine ⟨(c : 𝒟.K) * u, ⟨c • x, ?_⟩, ?_⟩
    ·
      have h_alg : (algebraMap (𝓞 𝒟.K) 𝒟.K) (c • x) = (c : 𝒟.K) * algebraMap _ _ x := by
        rw [zsmul_eq_mul, map_mul]; simp
      rw [h_alg, ← hx]; ring
    ·
      funext i
      have hΦ : 𝒟.Φ ((c : 𝒟.K) * u) i = (c : ℂ) * 𝒟.Φ u i := by
        simp [AdmissibleDatum.Φ, map_mul, map_intCast]
      rw [hΦ, ← hz]
      simp [zsmul_eq_mul]

noncomputable def LambdaIntegral (𝒟 : AdmissibleDatum) : Submodule ℤ 𝒟.V where
  carrier := { z | ∃ x : 𝓞 𝒟.K, 𝒟.Φ (algebraMap (𝓞 𝒟.K) 𝒟.K x) = z }
  zero_mem' := by
    refine ⟨0, ?_⟩
    funext i
    simp [AdmissibleDatum.Φ]
  add_mem' := by
    rintro z₁ z₂ ⟨x₁, rfl⟩ ⟨x₂, rfl⟩
    refine ⟨x₁ + x₂, ?_⟩
    funext i
    simp [AdmissibleDatum.Φ, map_add]
  smul_mem' := by
    rintro c z ⟨x, rfl⟩
    refine ⟨c • x, ?_⟩
    funext i
    simp [AdmissibleDatum.Φ, zsmul_eq_mul, map_mul, map_intCast]

theorem LambdaIntegral_discreteTopology (𝒟 : AdmissibleDatum) : DiscreteTopology 𝒟.LambdaIntegral := by
  classical
  have hall_nonreal : ∀ φ : 𝒟.K →+* ℂ, ¬ NumberField.ComplexEmbedding.IsReal φ := by
    intro φ hreal
    let ψ : 𝒟.K →+* ℝ := hreal.embedding
    have hψ : ψ 𝒟.i_K * ψ 𝒟.i_K = -1 := by
      have h := congrArg ψ 𝒟.i_K_sq
      simpa [map_mul, map_neg, map_one] using h
    have hnn : 0 ≤ ψ 𝒟.i_K * ψ 𝒟.i_K := mul_self_nonneg _
    linarith
  have hno_real : IsEmpty {w : NumberField.InfinitePlace 𝒟.K // w.IsReal} := by
    refine ⟨?_⟩
    intro w
    exact hall_nonreal w.1.embedding ((NumberField.InfinitePlace.isReal_iff).mp w.2)
  have hcard_complex : Fintype.card {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} = 𝒟.f := by
    letI : IsEmpty {w : NumberField.InfinitePlace 𝒟.K // w.IsReal} := hno_real
    letI : Algebra ℚ 𝒟.K := DivisionRing.toRatAlgebra
    have hnrreal : NumberField.InfinitePlace.nrRealPlaces 𝒟.K = 0 := by
      simp [NumberField.InfinitePlace.nrRealPlaces]
    have hfinrank : Module.finrank ℚ 𝒟.K = 2 * 𝒟.f := by
      calc
        Module.finrank ℚ 𝒟.K = Module.finrank ℚ 𝒟.L * Module.finrank 𝒟.L 𝒟.K := by
          symm
          exact Module.finrank_mul_finrank ℚ 𝒟.L 𝒟.K
        _ = 𝒟.f * 2 := by rw [AdmissibleDatum.f, Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K]
        _ = 2 * 𝒟.f := by ring
    have hsig := NumberField.InfinitePlace.card_add_two_mul_card_eq_rank (K := 𝒟.K)
    have hsig0 : 2 * Fintype.card {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} = Module.finrank ℚ 𝒟.K := by
      simpa [hnrreal, NumberField.InfinitePlace.nrComplexPlaces] using hsig
    rw [hfinrank] at hsig0
    omega
  let σToPlace : Fin 𝒟.f → {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} :=
    fun i => NumberField.InfinitePlace.mkComplex ⟨adm_σ 𝒟 i, hall_nonreal (adm_σ 𝒟 i)⟩
  have hσinj : Function.Injective σToPlace := by
    intro i j hij
    by_contra hne
    have hij' : (σToPlace i : NumberField.InfinitePlace 𝒟.K) = σToPlace j := congrArg Subtype.val hij
    simp only [σToPlace, NumberField.InfinitePlace.mkComplex_coe] at hij'
    rw [NumberField.InfinitePlace.mk_eq_iff] at hij'
    have hrext :
        (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K) =
          (adm_σ 𝒟 j).comp (algebraMap 𝒟.L 𝒟.K) := by
      rcases hij' with h | h
      · exact congrArg (fun φ => φ.comp (algebraMap 𝒟.L 𝒟.K)) h
      · have hreal_restrict : NumberField.ComplexEmbedding.IsReal ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) :=
          NumberField.IsTotallyReal.complexEmbedding_isReal _
        have hconj_restrict :
            NumberField.ComplexEmbedding.conjugate ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) =
              (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K) :=
          (NumberField.ComplexEmbedding.isReal_iff).mp hreal_restrict
        have hconjcomp :
            NumberField.ComplexEmbedding.conjugate ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) =
              (adm_σ 𝒟 j).comp (algebraMap 𝒟.L 𝒟.K) := by
          calc
            NumberField.ComplexEmbedding.conjugate ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) =
                (NumberField.ComplexEmbedding.conjugate (adm_σ 𝒟 i)).comp (algebraMap 𝒟.L 𝒟.K) := by
                  symm
                  exact NumberField.ComplexEmbedding.conjugate_comp (adm_σ 𝒟 i) (algebraMap 𝒟.L 𝒟.K)
            _ = (adm_σ 𝒟 j).comp (algebraMap 𝒟.L 𝒟.K) := by rw [h]
        exact hconj_restrict.symm.trans hconjcomp
    exact (𝒟.adm_σ_restrict_distinct i j hne) hrext
  let eσ : Fin 𝒟.f ≃ {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} :=
    Equiv.ofBijective σToPlace ((Fintype.bijective_iff_injective_and_card σToPlace).2 ⟨hσinj, by simpa using hcard_complex.symm⟩)
  let coordEquiv : {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} → ℂ ≃L[ℝ] ℂ := fun w =>
    if h : w.1.embedding = adm_σ 𝒟 (eσ.symm w) then ContinuousLinearEquiv.refl ℝ ℂ else Complex.conjCLE
  let complexReindex : 𝒟.V ≃L[ℝ] ({w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} → ℂ) :=
    (ContinuousLinearEquiv.piCongrLeft ℝ (fun _ : {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} => ℂ) eσ).trans
      (ContinuousLinearEquiv.piCongrRight coordEquiv)
  letI : IsEmpty {w : NumberField.InfinitePlace 𝒟.K // w.IsReal} := hno_real
  let reindexComplex : 𝒟.V ≃L[ℝ] NumberField.mixedEmbedding.mixedSpace 𝒟.K :=
    complexReindex.trans
      (ContinuousLinearEquiv.uniqueProd ℝ ({w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} → ℂ)
        ({w : NumberField.InfinitePlace 𝒟.K // w.IsReal} → ℝ)).symm
  have hreindex_apply (x : 𝒟.K) : reindexComplex (𝒟.Φ x) = NumberField.mixedEmbedding 𝒟.K x := by
    ext w
    · cases hno_real.false w
    · simp [reindexComplex, complexReindex]
      have hpi := Equiv.piCongrLeft_apply (P := fun _ : {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} => ℂ) eσ (𝒟.Φ x) w
      have hpi' :
          ((ContinuousLinearEquiv.piCongrLeft ℝ (fun _ : {w : NumberField.InfinitePlace 𝒟.K // w.IsComplex} => ℂ) eσ)
            (𝒟.Φ x) w) = (𝒟.Φ x) (eσ.symm w) := by
        simpa [ContinuousLinearEquiv.piCongrLeft] using hpi
      rw [hpi']
      have hwplace_sub : σToPlace (eσ.symm w) = w := by
        exact eσ.apply_symm_apply w
      have hwplace :
          (NumberField.InfinitePlace.mkComplex ⟨adm_σ 𝒟 (eσ.symm w), hall_nonreal (adm_σ 𝒟 (eσ.symm w))⟩ :
            NumberField.InfinitePlace 𝒟.K) = w.1 := by
        exact congrArg Subtype.val hwplace_sub
      have hwemb : adm_σ 𝒟 (eσ.symm w) = w.1.embedding ∨
          NumberField.ComplexEmbedding.conjugate (adm_σ 𝒟 (eσ.symm w)) = w.1.embedding := by
        have hwplace' : NumberField.InfinitePlace.mk (adm_σ 𝒟 (eσ.symm w)) = NumberField.InfinitePlace.mk w.1.embedding := by
          simpa [σToPlace, NumberField.InfinitePlace.mkComplex_coe, NumberField.InfinitePlace.mk_embedding] using hwplace
        simpa using (NumberField.InfinitePlace.mk_eq_iff.mp hwplace')
      rcases hwemb with h | h
      · simp [coordEquiv, h, AdmissibleDatum.Φ]
      · have hne : ¬ w.1.embedding = adm_σ 𝒟 (eσ.symm w) := by
          intro hw
          have hreal : NumberField.ComplexEmbedding.IsReal (adm_σ 𝒟 (eσ.symm w)) := by
            rw [NumberField.ComplexEmbedding.isReal_iff]
            exact h.trans hw
          exact hall_nonreal (adm_σ 𝒟 (eσ.symm w)) hreal
        have hx : NumberField.ComplexEmbedding.conjugate (adm_σ 𝒟 (eσ.symm w)) x = w.1.embedding x := by
          exact RingHom.congr_fun h x
        simpa [coordEquiv, hne, AdmissibleDatum.Φ, NumberField.ComplexEmbedding.conjugate, Complex.conjCLE_apply] using hx
  have hLambda :
      𝒟.LambdaIntegral =
        ZLattice.comap ℝ (NumberField.mixedEmbedding.integerLattice 𝒟.K) reindexComplex.toLinearMap := by
    ext z
    constructor
    · rintro ⟨x, rfl⟩
      change reindexComplex (𝒟.Φ (algebraMap (𝓞 𝒟.K) 𝒟.K x)) ∈ NumberField.mixedEmbedding.integerLattice 𝒟.K
      rw [hreindex_apply]
      change NumberField.mixedEmbedding 𝒟.K (algebraMap (𝓞 𝒟.K) 𝒟.K x) ∈
        LinearMap.range (((NumberField.mixedEmbedding 𝒟.K).comp (algebraMap (𝓞 𝒟.K) 𝒟.K)).toIntAlgHom.toLinearMap)
      exact ⟨x, rfl⟩
    · intro hz
      change reindexComplex z ∈ NumberField.mixedEmbedding.integerLattice 𝒟.K at hz
      change reindexComplex z ∈
        LinearMap.range (((NumberField.mixedEmbedding 𝒟.K).comp (algebraMap (𝓞 𝒟.K) 𝒟.K)).toIntAlgHom.toLinearMap) at hz
      rcases hz with ⟨x, hx⟩
      refine ⟨x, ?_⟩
      apply reindexComplex.injective
      rw [hreindex_apply]
      simpa using hx
  rw [hLambda]
  infer_instance

theorem Lambda_eq_comap_LambdaIntegral (𝒟 : AdmissibleDatum) :
    𝒟.Λ =
      ZLattice.comap ℝ 𝒟.LambdaIntegral
        (((𝒟.Q : ℝ) ^ 2) • (1 : 𝒟.V →ₗ[ℝ] 𝒟.V)) := by
  ext z
  constructor
  · intro hz
    change ((((𝒟.Q : ℝ) ^ 2) • (1 : 𝒟.V →ₗ[ℝ] 𝒟.V)) z ∈ 𝒟.LambdaIntegral)
    change ((𝒟.Q : ℝ) ^ 2) • z ∈ 𝒟.LambdaIntegral
    rcases hz with ⟨u, ⟨x, hx⟩, rfl⟩
    refine ⟨x, ?_⟩
    funext i
    have hxi : (adm_σ 𝒟 i) (((𝒟.Q : 𝒟.K) ^ 2) * u) = (adm_σ 𝒟 i) (algebraMap (𝓞 𝒟.K) 𝒟.K x) :=
      congrArg (adm_σ 𝒟 i) hx
    simpa [AdmissibleDatum.Φ, Pi.smul_apply, smul_eq_mul, map_mul, map_natCast] using hxi.symm
  · intro hz
    change ((((𝒟.Q : ℝ) ^ 2) • (1 : 𝒟.V →ₗ[ℝ] 𝒟.V)) z ∈ 𝒟.LambdaIntegral) at hz
    change ((𝒟.Q : ℝ) ^ 2) • z ∈ 𝒟.LambdaIntegral at hz
    rcases hz with ⟨x, hx⟩
    let u : 𝒟.K := ((𝒟.Q : 𝒟.K) ^ 2)⁻¹ * algebraMap (𝓞 𝒟.K) 𝒟.K x
    have hQK_ne : ((𝒟.Q : 𝒟.K) ^ 2) ≠ 0 := by
      exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt 𝒟.Q_pos))
    have hu : ((𝒟.Q : 𝒟.K) ^ 2) * u = algebraMap (𝓞 𝒟.K) 𝒟.K x := by
      simp [u, hQK_ne, mul_assoc]
    have huΦ : ((𝒟.Q : ℝ) ^ 2) • 𝒟.Φ u = 𝒟.Φ (algebraMap (𝓞 𝒟.K) 𝒟.K x) := by
      funext i
      have hxi : (adm_σ 𝒟 i) (((𝒟.Q : 𝒟.K) ^ 2) * u) = (adm_σ 𝒟 i) (algebraMap (𝓞 𝒟.K) 𝒟.K x) :=
        congrArg (adm_σ 𝒟 i) hu
      simpa [AdmissibleDatum.Φ, Pi.smul_apply, smul_eq_mul, map_mul, map_natCast] using hxi
    have hQ2_ne : ((𝒟.Q : ℝ) ^ 2) ≠ 0 := by
      exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt 𝒟.Q_pos))
    have huz : 𝒟.Φ u = z := by
      apply (MulAction.injective₀ hQ2_ne)
      calc
        ((𝒟.Q : ℝ) ^ 2) • 𝒟.Φ u = 𝒟.Φ (algebraMap (𝓞 𝒟.K) 𝒟.K x) := huΦ
        _ = ((𝒟.Q : ℝ) ^ 2) • z := hx
    exact ⟨u, ⟨x, hu⟩, huz⟩

theorem Λ_discreteTopology (𝒟 : AdmissibleDatum) :
    DiscreteTopology 𝒟.Λ := by
  letI : DiscreteTopology 𝒟.LambdaIntegral := LambdaIntegral_discreteTopology 𝒟
  rw [Lambda_eq_comap_LambdaIntegral 𝒟]
  let eQ : 𝒟.V →ₗ[ℝ] 𝒟.V := (((𝒟.Q : ℝ) ^ 2) • (1 : 𝒟.V →ₗ[ℝ] 𝒟.V))
  simpa [eQ] using
    (ZLattice.comap_discreteTopology (K := ℝ) (L := 𝒟.LambdaIntegral)
      (e := eQ)
      (LinearMap.continuous_of_finiteDimensional eQ)
      (by
        have hQ0 : (𝒟.Q : ℝ) ≠ 0 := by
          exact_mod_cast (Nat.ne_of_gt 𝒟.Q_pos)
        have hQ : ((𝒟.Q : ℝ) ^ 2) ≠ 0 := by
          exact pow_ne_zero 2 hQ0
        simpa [eQ] using
          (LinearEquiv.smulOfNeZero (K := ℝ) (M := 𝒟.V) (((𝒟.Q : ℝ) ^ 2)) hQ).injective))

theorem L_integralBasis_embedding_linearIndependent: LinearIndependent ℂ (fun j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L) => fun i : Fin 𝒟.f => ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) (NumberField.integralBasis 𝒟.L j)) := by
  classical
  let τ : Fin 𝒟.f → 𝒟.L →+* ℂ := fun i => (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)
  have hτinj : Function.Injective τ := by
    intro i j hij
    by_contra hne
    exact (adm_σ_restrict_distinct 𝒟 i j hne) hij
  have hτbij : Function.Bijective τ := by
    rw [Fintype.bijective_iff_injective_and_card]
    refine ⟨hτinj, ?_⟩
    rw [Fintype.card_fin, f, NumberField.Embeddings.card]
  let eτ : Fin 𝒟.f ≃ (𝒟.L →+* ℂ) := Equiv.ofBijective τ hτbij
  have hbasis' :
      LinearIndependent ℂ
        (fun j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L) =>
          NumberField.canonicalEmbedding 𝒟.L (NumberField.integralBasis 𝒟.L j)) := by
    convert (NumberField.canonicalEmbedding.latticeBasis 𝒟.L).linearIndependent using 1
    ext j σ
    rw [NumberField.canonicalEmbedding.latticeBasis_apply, NumberField.canonicalEmbedding.apply_at]
  have hbasis :
      LinearIndependent ℂ
        (fun j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L) =>
          fun σ : 𝒟.L →+* ℂ => σ (NumberField.integralBasis 𝒟.L j)) := by
    simpa [NumberField.canonicalEmbedding.apply_at] using hbasis'
  have hmap :
      LinearIndependent ℂ
        (fun j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L) =>
          (LinearEquiv.funCongrLeft ℂ ℂ eτ)
            (fun σ : 𝒟.L →+* ℂ => σ (NumberField.integralBasis 𝒟.L j))) := by
    exact hbasis.map'
      (LinearEquiv.funCongrLeft ℂ ℂ eτ).toLinearMap
      (LinearMap.ker_eq_bot.mpr (LinearEquiv.injective _))
  simpa [τ, eτ, LinearEquiv.funCongrLeft_apply, LinearMap.funLeft_apply] using hmap

theorem adm_σ_iK_eq_I_or_neg_I: ∀ i : Fin 𝒟.f, adm_σ 𝒟 i 𝒟.i_K = Complex.I ∨ adm_σ 𝒟 i 𝒟.i_K = -Complex.I := by
  intro i
  let z : ℂ := adm_σ 𝒟 i 𝒟.i_K
  have hconj : -z = star z := by
    dsimp [z]
    simpa [𝒟.c_i_K, map_neg] using
      (complex_embedding_conjugation_compat 𝒟 (adm_σ 𝒟 i) 𝒟.i_K)
  have hsq : z * z = (-1 : ℂ) := by
    dsimp [z]
    simpa using congrArg (adm_σ 𝒟 i) 𝒟.i_K_sq
  have hre_eq : -z.re = z.re := by
    simpa using congrArg Complex.re hconj
  have hre0 : z.re = 0 := by
    linarith
  have hmulre : z.re * z.re - z.im * z.im = (-1 : ℝ) := by
    have h := congrArg Complex.re hsq
    simpa [Complex.mul_re] using h
  have himsq' : z.im * z.im = (1 : ℝ) := by
    nlinarith [hmulre, hre0]
  have himsq : z.im ^ 2 = (1 : ℝ) := by
    simpa [pow_two] using himsq'
  have hz_cases : z = Complex.I ∨ z = -Complex.I := by
    rcases sq_eq_one_iff.mp himsq with him1 | him1
    · left
      apply Complex.ext <;> simp [hre0, him1]
    · right
      apply Complex.ext <;> simp [hre0, him1]
  simpa [z] using hz_cases

theorem scaled_L_integralBasis_left_linearIndependent: LinearIndependent ℝ (fun j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L) => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))) := by
  let ι := Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L)
  let b : ι → 𝒟.V := fun j => fun i =>
    ((adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)) (NumberField.integralBasis 𝒟.L j)
  let cR : ℝ := (((𝒟.Q : ℝ) ^ 2)⁻¹)
  have hb : LinearIndependent ℂ b := by
    simpa [b, AdmissibleDatum.V] using L_integralBasis_embedding_linearIndependent (𝒟 := 𝒟)
  have hbR : LinearIndependent ℝ b :=
    LinearIndependent.restrict_scalars' (R := ℝ) hb
  have hQ : (𝒟.Q : ℝ) ≠ 0 := by
    exact_mod_cast (ne_of_gt 𝒟.Q_pos)
  have hcR : cR ≠ 0 := by
    dsimp [cR]
    exact inv_ne_zero (pow_ne_zero 2 hQ)
  have hfamily :
      (fun j : ι => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))) =
      (((fun _ : ι => Units.mk0 cR hcR) • b : ι → 𝒟.V)) := by
    funext j
    ext i
    simp [b, cR, AdmissibleDatum.Φ, Complex.real_smul, mul_assoc]
  rw [hfamily]
  exact LinearIndependent.units_smul hbR (fun _ : ι => Units.mk0 cR hcR)

theorem scaled_L_integralBasis_pair_linearIndependent: LinearIndependent ℝ (fun ij : Sum (Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L)) (Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L)) => Sum.elim (fun j => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))) (fun j => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)))) ij) := by
  classical
  let ι := Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L)
  let v : ι → Fin 𝒟.f → ℂ := fun j =>
    𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))
  let w : ι → Fin 𝒟.f → ℂ := fun j =>
    𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)))
  change LinearIndependent ℝ (Sum.elim v w)
  have hv : LinearIndependent ℝ v := by
    simpa [v] using scaled_L_integralBasis_left_linearIndependent (𝒟 := 𝒟)
  let r : ι → Fin 𝒟.f → ℝ := fun j i => (v j i).re
  have hvim : ∀ j i, (v j i).im = 0 := by
    intro j i
    dsimp [v, AdmissibleDatum.Φ]
    let φ : 𝒟.L →+* ℂ := (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)
    have hφ : NumberField.ComplexEmbedding.IsReal φ := by
      exact NumberField.IsTotallyReal.complexEmbedding_isReal φ
    let y : 𝒟.L := ((𝒟.Q : 𝒟.L) ^ 2)⁻¹ * NumberField.integralBasis 𝒟.L j
    have hy : (adm_σ 𝒟 i) ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)) = φ y := by
      simp [φ, y, map_mul, mul_assoc]
    rw [hy]
    rw [← NumberField.ComplexEmbedding.IsReal.coe_embedding_apply (hφ := hφ) y]
    simpa using Complex.ofReal_im (hφ.embedding y)
  have hvofReal : ∀ j i, v j i = (r j i : ℂ) := by
    intro j i
    apply Complex.ext
    · simp [r]
    · simpa [r] using hvim j i
  let ofRealPi : (Fin 𝒟.f → ℝ) →ₗ[ℝ] (Fin 𝒟.f → ℂ) :=
    LinearMap.pi fun i => (Complex.ofRealLI.toLinearMap).comp (LinearMap.proj i)
  have hofReal_r : ofRealPi ∘ r = v := by
    funext j
    ext i
    simpa [ofRealPi] using (hvofReal j i).symm
  have hr : LinearIndependent ℝ r := by
    apply LinearIndependent.of_comp ofRealPi
    rw [hofReal_r]
    exact hv
  have hwcoord : ∀ j i, w j i = adm_σ 𝒟 i 𝒟.i_K * v j i := by
    intro j i
    dsimp [w, v, AdmissibleDatum.Φ]
    simp [map_mul, mul_assoc, mul_left_comm, mul_comm]
  have hrew : ∀ j i, (w j i).re = 0 := by
    intro j i
    rcases adm_σ_iK_eq_I_or_neg_I (𝒟 := 𝒟) i with hI | hI
    · rw [hwcoord j i, hI, hvofReal j i]
      simp
    · rw [hwcoord j i, hI, hvofReal j i]
      simp
  let ε : Fin 𝒟.f → ℝ := fun i => if adm_σ 𝒟 i 𝒟.i_K = Complex.I then 1 else -1
  have hεnz : ∀ i, ε i ≠ 0 := by
    intro i
    by_cases hI : adm_σ 𝒟 i 𝒟.i_K = Complex.I
    · simp [ε, hI]
    · simp [ε, hI]
  have himw : ∀ j i, (w j i).im = ε i * r j i := by
    intro j i
    rcases adm_σ_iK_eq_I_or_neg_I (𝒟 := 𝒟) i with hI | hI
    · rw [hwcoord j i, hI, hvofReal j i]
      simp [ε, hI, r]
    · have hne : ¬ adm_σ 𝒟 i 𝒟.i_K = Complex.I := by
        intro h
        rw [h] at hI
        have him : (Complex.I : ℂ).im = (-Complex.I).im := congrArg Complex.im hI
        norm_num at him
      rw [hwcoord j i, hI, hvofReal j i]
      simp [ε, hne, r]
  let diag : (Fin 𝒟.f → ℝ) →ₗ[ℝ] (Fin 𝒟.f → ℝ) :=
    { toFun := fun x i => ε i * x i
      map_add' := by
        intro x y
        ext i
        simp [mul_add]
      map_smul' := by
        intro a x
        ext i
        simp [mul_assoc, mul_left_comm, mul_comm] }
  have hdiag_ker : LinearMap.ker diag = ⊥ := by
    rw [LinearMap.ker_eq_bot']
    intro x hx
    ext i
    have hxi : ε i * x i = 0 := by
      have := congrFun hx i
      simpa [diag] using this
    rcases mul_eq_zero.mp hxi with hε | hx0
    · exact (hεnz i hε).elim
    · exact hx0
  let twisted : ι → Fin 𝒟.f → ℝ := fun j i => ε i * r j i
  have htwisted : LinearIndependent ℝ twisted := by
    have hdiag : LinearIndependent ℝ (diag ∘ r) := by
      exact LinearIndependent.map' hr diag hdiag_ker
    simpa [diag, twisted] using hdiag
  let imPi : (Fin 𝒟.f → ℂ) →ₗ[ℝ] (Fin 𝒟.f → ℝ) :=
    LinearMap.pi fun i => (Complex.imCLM.toLinearMap).comp (LinearMap.proj i)
  have himPi_w : imPi ∘ w = twisted := by
    funext j
    ext i
    simp [imPi, twisted, himw]
  have hw : LinearIndependent ℝ w := by
    apply LinearIndependent.of_comp imPi
    rw [himPi_w]
    exact htwisted
  have hdisj : Disjoint (Submodule.span ℝ (Set.range v)) (Submodule.span ℝ (Set.range w)) := by
    rw [Submodule.disjoint_def]
    intro x hxv hxw
    rw [Submodule.mem_span_range_iff_exists_fun] at hxv
    rw [Submodule.mem_span_range_iff_exists_fun] at hxw
    rcases hxv with ⟨a, ha⟩
    rcases hxw with ⟨b, hb⟩
    have hab : ∑ j, a j • v j = ∑ j, b j • w j := ha.trans hb.symm
    have hre : ∑ j, a j • r j = 0 := by
      ext i
      have hi := congrArg Complex.re (congrFun hab i)
      simpa [r, hrew, Complex.re_sum, Complex.real_smul] using hi
    have ha0 : ∀ j, a j = 0 := (Fintype.linearIndependent_iff.mp hr) a hre
    have hx0 : x = 0 := by
      rw [← ha]
      ext i
      simp [ha0]
    exact hx0
  exact LinearIndependent.sum_type hv hw hdisj

theorem Λ_contains_scaled_L_integralBasis_pair: ∀ j : Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L), 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)) ∈ (𝒟.Λ : Set 𝒟.V) ∧ 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))) ∈ (𝒟.Λ : Set 𝒟.V) := by
  intro j
  have hQ : ((𝒟.Q : 𝒟.K) ^ 2) ≠ 0 := by
    exact pow_ne_zero 2 (by exact_mod_cast (Nat.ne_of_gt 𝒟.Q_pos))
  have hxInt : IsIntegral ℤ (algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)) := by
    simpa [NumberField.integralBasis_apply] using
      (NumberField.RingOfIntegers.isIntegral_coe
        (NumberField.RingOfIntegers.mapRingHom (algebraMap 𝒟.L 𝒟.K)
          (NumberField.RingOfIntegers.basis 𝒟.L j)))
  have hi : IsIntegral ℤ 𝒟.i_K := by
    refine ⟨(Polynomial.X ^ 2 + Polynomial.C (1 : ℤ) : Polynomial ℤ), ?_, ?_⟩
    · simpa using (Polynomial.monic_X_pow_add_C (a := (1 : ℤ)) (n := 2) (by decide))
    · rw [Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
      simp [pow_two, 𝒟.i_K_sq]
  constructor
  · unfold AdmissibleDatum.Λ
    change
      ∃ u : 𝒟.K,
        (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = algebraMap (𝓞 𝒟.K) 𝒟.K x) ∧
          𝒟.Φ u =
            𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) *
              algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))
    let x : 𝓞 𝒟.K := ⟨algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j), hxInt⟩
    refine ⟨(((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j), ?_⟩
    constructor
    · refine ⟨x, ?_⟩
      dsimp [x]
      rw [← mul_assoc, mul_inv_cancel₀ hQ, one_mul]
    · rfl
  · unfold AdmissibleDatum.Λ
    change
      ∃ u : 𝒟.K,
        (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = algebraMap (𝓞 𝒟.K) 𝒟.K x) ∧
          𝒟.Φ u =
            𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) *
              (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)))
    have hixInt : IsIntegral ℤ
        (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)) :=
      hi.mul hxInt
    let x : 𝓞 𝒟.K :=
      ⟨𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j), hixInt⟩
    refine ⟨(((𝒟.Q : 𝒟.K) ^ 2)⁻¹) *
        (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)), ?_⟩
    constructor
    · refine ⟨x, ?_⟩
      dsimp [x]
      rw [← mul_assoc, mul_inv_cancel₀ hQ, one_mul]
    · rfl

theorem Λ_spans_top (𝒟 : AdmissibleDatum) :
    Submodule.span ℝ (𝒟.Λ : Set 𝒟.V) = ⊤ := by
  let ι := Module.Free.ChooseBasisIndex ℤ (𝓞 𝒟.L)
  let b : Sum ι ι → 𝒟.V :=
    fun ij =>
      Sum.elim
        (fun j => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j)))
        (fun j => 𝒟.Φ ((((𝒟.Q : 𝒟.K) ^ 2)⁻¹) * (𝒟.i_K * algebraMap 𝒟.L 𝒟.K (NumberField.integralBasis 𝒟.L j))))
        ij
  have hb_mem : ∀ k : Sum ι ι, b k ∈ (𝒟.Λ : Set 𝒟.V) := by
    intro k
    cases k with
    | inl j =>
        exact (Λ_contains_scaled_L_integralBasis_pair 𝒟 j).1
    | inr j =>
        exact (Λ_contains_scaled_L_integralBasis_pair 𝒟 j).2
  have hspan_le : Submodule.span ℝ (Set.range b) ≤ Submodule.span ℝ (𝒟.Λ : Set 𝒟.V) := by
    refine Submodule.span_le.mpr ?_
    rintro _ ⟨k, rfl⟩
    exact Submodule.subset_span (hb_mem k)
  have hlin : LinearIndependent ℝ b := by
    simpa only [b] using scaled_L_integralBasis_pair_linearIndependent (𝒟 := 𝒟)
  have hcardI : Fintype.card ι = 𝒟.f := by
    calc
      Fintype.card ι = Module.finrank ℤ (𝓞 𝒟.L) := by
        simpa only [ι] using (Module.finrank_eq_card_basis (NumberField.RingOfIntegers.basis 𝒟.L)).symm
      _ = Module.finrank ℚ 𝒟.L := NumberField.RingOfIntegers.rank (K := 𝒟.L)
      _ = 𝒟.f := by rfl
  have hfinrankC : Module.finrank ℝ ℂ = 2 := by
    simpa only using (Module.finrank_eq_card_basis Complex.basisOneI)
  have hfinrankV : Module.finrank ℝ 𝒟.V = 2 * 𝒟.f := by
    calc
      Module.finrank ℝ 𝒟.V = ∑ _ : Fin 𝒟.f, Module.finrank ℝ ℂ := by
        simpa only [AdmissibleDatum.V] using
          (Module.finrank_pi_fintype (R := ℝ) (M := fun _ : Fin 𝒟.f => ℂ))
      _ = ∑ _ : Fin 𝒟.f, 2 := by simp only [hfinrankC]
      _ = 2 * 𝒟.f := by
        simp only [Finset.sum_const_nat, Finset.card_univ, Fintype.card_fin]
        omega
  have hcard : Fintype.card (Sum ι ι) = Module.finrank ℝ 𝒟.V := by
    calc
      Fintype.card (Sum ι ι) = Fintype.card ι + Fintype.card ι := by
        simp only [Fintype.card_sum]
      _ = 𝒟.f + 𝒟.f := by simp only [hcardI]
      _ = 2 * 𝒟.f := by omega
      _ = Module.finrank ℝ 𝒟.V := by rw [hfinrankV]
  have hspan_top : Submodule.span ℝ (Set.range b) = ⊤ := by
    exact LinearIndependent.span_eq_top_of_card_eq_finrank' hlin hcard
  exact top_unique <| by
    simpa only [hspan_top] using hspan_le

noncomputable def supNorm (z : 𝒟.V) : ℝ :=
  Finset.univ.sup' ⟨⟨0, 𝒟.f_pos⟩, Finset.mem_univ _⟩
    (fun r : Fin 𝒟.f => ‖z r‖)

noncomputable def closedPolydisc (R : ℝ) : Set 𝒟.V :=
  { z | 𝒟.supNorm z ≤ R }

noncomputable def X (a : 𝒟.V) (R : ℝ) : Set 𝒟.V :=
  (Set.range (fun (l : 𝒟.Λ) => a + (l : 𝒟.V))) ∩ 𝒟.closedPolydisc R

end AdmissibleDatum

theorem supNorm_eq_norm (𝒟 : AdmissibleDatum) (z : 𝒟.V) : 𝒟.supNorm z = ‖z‖ := by
  unfold AdmissibleDatum.supNorm
  apply le_antisymm
  · exact (Finset.sup'_le_iff (H := ⟨⟨0, 𝒟.f_pos⟩, Finset.mem_univ _⟩)
      (f := fun r : Fin 𝒟.f => ‖z r‖)).2 (fun b hb => by
        simpa using norm_le_pi_norm z b)
  · apply (pi_norm_le_iff_of_nonneg ?_).2
    · intro i
      exact Finset.le_sup' (f := fun r : Fin 𝒟.f => ‖z r‖) (Finset.mem_univ i)
    · exact le_trans (norm_nonneg (z ⟨0, 𝒟.f_pos⟩))
        (Finset.le_sup' (f := fun r : Fin 𝒟.f => ‖z r‖) (Finset.mem_univ _))

instance Λ_discreteTopology_inst (𝒟 : AdmissibleDatum) :
    DiscreteTopology 𝒟.Λ :=
  𝒟.Λ_discreteTopology

instance Λ_IsZLattice (𝒟 : AdmissibleDatum) :
    IsZLattice ℝ 𝒟.Λ where
  span_top := 𝒟.Λ_spans_top

theorem X_finite (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) :
    (𝒟.X a R).Finite := by
  classical
  let s : Set 𝒟.V := Set.range (fun l : 𝒟.Λ => a + (l : 𝒟.V))
  have hs_discrete : IsDiscrete s := by
    letI : DiscreteTopology 𝒟.Λ := 𝒟.Λ_discreteTopology
    let τ : 𝒟.V → 𝒟.V := fun z => a + z
    have hτ : Topology.IsEmbedding τ := by
      refine Topology.IsEmbedding.of_leftInverse
        (f := fun z : 𝒟.V => z - a) (g := τ) ?_ ?_ ?_
      · intro z
        simp [τ, sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
      · simpa using (continuous_id.sub continuous_const)
      · simpa [τ] using (continuous_const.add continuous_id)
    have hs_emb : Topology.IsEmbedding (fun l : 𝒟.Λ => a + (l : 𝒟.V)) := by
      simpa [τ, Function.comp] using hτ.comp Topology.IsEmbedding.subtypeVal
    simpa [s] using (IsEmbedding.isDiscrete_range hs_emb)
  have hs_closed : IsClosed s := by
    let H : Subgroup (Multiplicative 𝒟.V) := 𝒟.Λ.toAddSubgroup.toSubgroup
    letI : DiscreteTopology H := by
      simpa [H] using (𝒟.Λ_discreteTopology)
    have hΛclosed : IsClosed ((𝒟.Λ : Set 𝒟.V)) := by
      simpa [H] using (Subgroup.isClosed_of_discrete (H := H))
    have hs_eq : s = (fun z : 𝒟.V => z - a) ⁻¹' (𝒟.Λ : Set 𝒟.V) := by
      ext z
      constructor
      · rintro ⟨l, rfl⟩
        simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
      · intro hz
        refine ⟨⟨z - a, hz⟩, ?_⟩
        simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
    rw [hs_eq]
    exact hΛclosed.preimage (continuous_id.sub continuous_const)
  have hbounded : Bornology.IsBounded (𝒟.closedPolydisc R) := by
    have hsubset : 𝒟.closedPolydisc R ⊆ Metric.closedBall (0 : 𝒟.V) (max R 0) := by
      intro z hz
      have hz' : 𝒟.supNorm z ≤ max R 0 := le_trans hz (le_max_left R 0)
      letI : Nonempty (Fin 𝒟.f) := ⟨⟨0, 𝒟.f_pos⟩⟩
      have hcoord : ∀ i : Fin 𝒟.f, ‖z i‖ ≤ max R 0 := by
        intro i
        exact le_trans
          (Finset.le_sup' (s := Finset.univ) (f := fun r : Fin 𝒟.f => ‖z r‖)
            (h := Finset.mem_univ i))
          hz'
      have hnorm : ‖z‖ ≤ max R 0 :=
        (pi_norm_le_iff_of_nonempty (f := z) (r := max R 0)).2 hcoord
      simpa [Metric.mem_closedBall, dist_eq_norm] using hnorm
    exact (Metric.isBounded_closedBall : Bornology.IsBounded (Metric.closedBall (0 : 𝒟.V) (max R 0))).subset hsubset
  have hfin := Metric.finite_isBounded_inter_isClosed hs_discrete hbounded hs_closed
  simpa [AdmissibleDatum.X, s, Set.inter_comm] using hfin

namespace AdmissibleDatum
variable (𝒟 : AdmissibleDatum)

noncomputable def X_finset (a : 𝒟.V) (R : ℝ) : Finset 𝒟.V :=
  (X_finite 𝒟 a R).toFinset

noncomputable def N_count (a : 𝒟.V) (R : ℝ) : ℕ := (𝒟.X_finset a R).card

noncomputable def E_count (a : 𝒟.V) (R : ℝ) (U : Finset 𝒟.K) : ℕ :=
  ∑ u ∈ U, ((𝒟.X_finset a R).filter
    (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card

noncomputable def b (_𝒟 : AdmissibleDatum) (R : ℝ) : ℝ := Real.pi * R ^ 2

noncomputable def π1 (z : 𝒟.V) : ℂ := z ⟨0, 𝒟.f_pos⟩

noncomputable def P_set (a : 𝒟.V) (R : ℝ) : Finset Point :=
  (𝒟.X_finset a R).image (fun z : 𝒟.V =>
    (EuclideanSpace.equiv (Fin 2) ℝ).symm ![(𝒟.π1 z).re, (𝒟.π1 z).im])

end AdmissibleDatum

namespace AdmissibleDatum
variable (𝒟 : AdmissibleDatum)

noncomputable def ρ (R : ℝ) : ℝ := overlapArea R / 𝒟.b R

def IsNormOneIntegral (u : 𝒟.K) : Prop :=
  (𝒟.relNorm u = 1) ∧
  (∀ σ : 𝒟.K →+* ℂ, ‖σ u‖ = 1) ∧

  (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = (algebraMap (𝓞 𝒟.K) 𝒟.K) x)

end AdmissibleDatum

abbrev proposition_2_2_choice_type (𝒟 : AdmissibleDatum) : Type := (Fin 𝒟.t × Fin 𝒟.f) → Bool

theorem proposition_2_2_choice_type_natCard (𝒟 : AdmissibleDatum) : Nat.card (proposition_2_2_choice_type 𝒟) = 2 ^ (𝒟.t * 𝒟.f) := by
  classical
  unfold proposition_2_2_choice_type
  rw [Nat.card_fun, Nat.card_prod, Nat.card_fin, Nat.card_fin, Nat.card_eq_fintype_card, Fintype.card_bool]

theorem proposition_2_2_classGroup_natCard (𝒟 : AdmissibleDatum) : Nat.card (ClassGroup (𝓞 𝒟.K)) = NumberField.classNumber 𝒟.K := by
  simp [NumberField.classNumber]

theorem proposition_2_2_conductor_coprime_p (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) (p : Ideal (𝓞 𝒟.L))
    (hp0 : p ≠ ⊥) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)))
    (θ : 𝓞 𝒟.K)
    (hθ : ((θ : 𝒟.K) = 𝒟.i_K))
    (hmin : minpoly (𝓞 𝒟.L) θ = Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L)) :
    (conductor (𝓞 𝒟.L) θ).comap (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ⊔ p = ⊤ := by
  let I : Ideal (𝓞 𝒟.L) := (conductor (𝓞 𝒟.L) θ).comap (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
  let pZ : Ideal ℤ := Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)
  have hgen : Algebra.adjoin 𝒟.L ({((θ : 𝒟.K))} : Set 𝒟.K) = ⊤ := by
    simpa [hθ] using 𝒟.adjoin_i_K_eq_top
  have htwoθ : (2 : 𝓞 𝒟.K) * θ ∈ conductor (𝓞 𝒟.L) θ := by
    have hdiff :=
        conductor_mul_differentIdeal (A := 𝓞 𝒟.L) (B := 𝓞 𝒟.K)
          (K := 𝒟.L) (L := 𝒟.K) (x := θ) hgen
    have hmem :
        Polynomial.aeval θ (Polynomial.derivative (minpoly (𝓞 𝒟.L) θ)) ∈
          (conductor (𝓞 𝒟.L) θ) * differentIdeal (𝓞 𝒟.L) (𝓞 𝒟.K) := by
      rw [hdiff]
      exact Ideal.subset_span (by simp)
    have hmem' :
        Polynomial.aeval θ (Polynomial.derivative (minpoly (𝓞 𝒟.L) θ)) ∈
          conductor (𝓞 𝒟.L) θ := by
      exact Ideal.mul_le_right hmem
    have hEval :
        Polynomial.aeval θ (Polynomial.derivative (minpoly (𝓞 𝒟.L) θ)) =
          (2 : 𝓞 𝒟.K) * θ := by
      rw [hmin]
      simp [two_mul, add_mul]
    rw [hEval] at hmem'
    exact hmem'
  have hθsqK : ((θ : 𝒟.K) * (θ : 𝒟.K)) = (-1 : 𝒟.K) := by
    rw [hθ]
    simpa using 𝒟.i_K_sq
  have hθinv : θ * (-θ) = (1 : 𝓞 𝒟.K) := by
    apply Subtype.coe_injective
    change ((θ : 𝒟.K) * (-θ : 𝒟.K)) = 1
    rw [mul_neg, hθsqK]
    simp
  have hθunit : IsUnit θ :=
    (isUnit_iff_exists_inv).2 ⟨-θ, hθinv⟩
  have htwo : (2 : 𝓞 𝒟.K) ∈ conductor (𝓞 𝒟.L) θ :=
    (Ideal.mul_unit_mem_iff_mem (I := conductor (𝓞 𝒟.L) θ)
      (x := (2 : 𝓞 𝒟.K)) (y := θ) hθunit).1 htwoθ
  have htwoI : (2 : 𝓞 𝒟.L) ∈ I := by
    rw [show I = _ by rfl, Ideal.mem_comap]
    have h2map : (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K) (2 : 𝓞 𝒟.L)) = (2 : 𝓞 𝒟.K) := by
      simpa using (map_natCast (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 2)
    simpa [h2map] using htwo
  have hnot2p : (2 : 𝓞 𝒟.L) ∉ p := by
    intro h2p
    letI : p.LiesOver pZ := hp_lies
    have h2Z : (2 : ℤ) ∈ pZ := by
      exact (Ideal.mem_of_liesOver (P := p) (p := pZ) (x := (2 : ℤ))).2 (by simpa using h2p)
    rw [show pZ = Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ) by rfl] at h2Z
    rw [Ideal.mem_span_singleton] at h2Z
    have hq2 : 𝒟.q b ∣ 2 := by
      simpa using (Int.natCast_dvd (n := (2 : ℤ)) (m := 𝒟.q b)).1 h2Z
    have hqeq : 𝒟.q b = 2 :=
      (Nat.prime_dvd_prime_iff_eq (𝒟.q_prime b) Nat.prime_two).1 hq2
    have hmod : (2 : ℕ) % 4 = 1 := by
      simpa [hqeq] using 𝒟.q_mod4 b
    norm_num at hmod
  have hp_max : p.IsMaximal := hp_prime.isMaximal hp0
  change I ⊔ p = ⊤
  have hOne : (1 : 𝓞 𝒟.L) ∈ I ⊔ p := by
    exact (Ideal.isMaximal_iff.mp hp_max).2 (I ⊔ p) (2 : 𝓞 𝒟.L) le_sup_right hnot2p
      (Ideal.mem_sup_left htwoI)
  apply top_unique
  intro x hx
  exact Ideal.mem_of_one_mem hOne x

noncomputable def proposition_2_2_conjIdeal (𝒟 : AdmissibleDatum) (I : Ideal (𝓞 𝒟.K)) : Ideal (𝓞 𝒟.K) := I.map (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K))

theorem proposition_2_2_conjIdeal_involutive (𝒟 : AdmissibleDatum) (I : Ideal (𝓞 𝒟.K)) :
    proposition_2_2_conjIdeal 𝒟 (proposition_2_2_conjIdeal 𝒟 I) = I := by
  let e : 𝓞 𝒟.K ≃+* 𝓞 𝒟.K := NumberField.RingOfIntegers.mapRingEquiv (𝒟.c : 𝒟.K ≃+* 𝒟.K)
  have he : e.symm = e := by
    ext x
    change 𝒟.c.symm (x : 𝒟.K) = 𝒟.c (x : 𝒟.K)
    apply 𝒟.c.injective
    have h1 : 𝒟.c (𝒟.c.symm (x : 𝒟.K)) = (x : 𝒟.K) := by
      simp
    have h2 : 𝒟.c (𝒟.c (x : 𝒟.K)) = (x : 𝒟.K) := by
      simpa using 𝒟.c_sq_eq_id (x : 𝒟.K)
    exact h1.trans h2.symm
  simpa [proposition_2_2_conjIdeal, e, he] using (Ideal.map_of_equiv (I := I) e)

theorem proposition_2_2_conj_aeval_X_sub_C (𝒟 : AdmissibleDatum) (θ : 𝓞 𝒟.K)
    (hθ : ((θ : 𝒟.K) = 𝒟.i_K)) (a : 𝓞 𝒟.L) :
    (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K))
      (((Polynomial.X - Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)) =
    -(((Polynomial.X + Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)) := by
  rw [← Polynomial.aeval_algHom_apply
    (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)) θ
    (Polynomial.X - Polynomial.C a)]
  have hmapθ :
      (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)) θ = -θ := by
    ext
    change 𝒟.c (θ : 𝒟.K) = -(θ : 𝒟.K)
    rw [hθ, 𝒟.c_i_K]
  rw [hmapθ]
  simp [Polynomial.aeval_X, Polynomial.aeval_C]
  ring

theorem proposition_2_2_conjIdeal_span_X_sub_C_eq_span_X_add_C (𝒟 : AdmissibleDatum) (θ : 𝓞 𝒟.K)
    (hθ : ((θ : 𝒟.K) = 𝒟.i_K)) (p : Ideal (𝓞 𝒟.L)) (a : 𝓞 𝒟.L) :
    proposition_2_2_conjIdeal 𝒟
      (Ideal.span
        (p.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ∪
          {((Polynomial.X - Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)})) =
    Ideal.span
      (p.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ∪
        {((Polynomial.X + Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)}) := by
  unfold proposition_2_2_conjIdeal
  let α : 𝓞 𝒟.L →+* 𝓞 𝒟.K := algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)
  let σ : 𝓞 𝒟.K ≃ₐ[𝓞 𝒟.L] 𝓞 𝒟.K :=
    NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
  let x : 𝓞 𝒟.K := ((Polynomial.X - Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)
  let y : 𝓞 𝒟.K := ((Polynomial.X + Polynomial.C a : Polynomial (𝓞 𝒟.L)).aeval θ)
  change (Ideal.span (p.map α ∪ ({x} : Set (𝓞 𝒟.K)))).map σ =
      Ideal.span (p.map α ∪ ({y} : Set (𝓞 𝒟.K)))
  rw [Ideal.span_union, Ideal.map_sup, Ideal.span_union]
  have hbase : Ideal.map (σ : 𝓞 𝒟.K →+* 𝓞 𝒟.K)
      (Ideal.span ((p.map α : Ideal (𝓞 𝒟.K)) : Set (𝓞 𝒟.K))) = p.map α := by
    rw [Ideal.span_eq, Ideal.map_map]
    congr
    ext b
    simp [Function.comp, α, σ, AlgEquiv.commutes]
  have hsingle : Ideal.map (σ : 𝓞 𝒟.K →+* 𝓞 𝒟.K) (Ideal.span ({x} : Set (𝓞 𝒟.K))) =
      Ideal.span ({y} : Set (𝓞 𝒟.K)) := by
    rw [Ideal.map_span, Set.image_singleton]
    change Ideal.span ({σ x} : Set (𝓞 𝒟.K)) = Ideal.span ({y} : Set (𝓞 𝒟.K))
    rw [show σ x = -y by
      simpa [x, y, σ] using proposition_2_2_conj_aeval_X_sub_C 𝒟 θ hθ a]
    simp
  change Ideal.map (σ : 𝓞 𝒟.K →+* 𝓞 𝒟.K)
      (Ideal.span ((p.map α : Ideal (𝓞 𝒟.K)) : Set (𝓞 𝒟.K))) ⊔
      Ideal.map (σ : 𝓞 𝒟.K →+* 𝓞 𝒟.K) (Ideal.span ({x} : Set (𝓞 𝒟.K))) =
    Ideal.span ((p.map α : Ideal (𝓞 𝒟.K)) : Set (𝓞 𝒟.K)) ⊔ Ideal.span ({y} : Set (𝓞 𝒟.K))
  rw [hbase, hsingle, Ideal.span_eq]

theorem proposition_2_2_fiber_principal_generator_injective (𝒟 : AdmissibleDatum)
    (I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K))
    (hI_nonzero : ∀ ε, I ε ≠ ⊥)
    (hI_cross : ∀ {ε η : proposition_2_2_choice_type 𝒟},
      I ε * proposition_2_2_conjIdeal 𝒟 (I η) =
        I η * proposition_2_2_conjIdeal 𝒟 (I ε) → ε = η)
    (C : ClassGroup (𝓞 𝒟.K))
    (ε₀ : proposition_2_2_choice_type 𝒟)
    (xgen : {ε : proposition_2_2_choice_type 𝒟 //
          ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C} → 𝓞 𝒟.K)
    (hxgen_nonzero : ∀ ε, xgen ε ≠ 0)
    (hxgen_ideal : ∀ ε,
      I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀) =
        Ideal.span ({xgen ε} : Set (𝓞 𝒟.K))) :
    Function.Injective (fun ε => ((xgen ε : 𝒟.K) / 𝒟.c (xgen ε : 𝒟.K))) := by
  intro ε η hratio
  apply Subtype.ext
  apply hI_cross
  let xε : 𝓞 𝒟.K := xgen ε
  let xη : 𝓞 𝒟.K := xgen η
  let σ : (𝓞 𝒟.K) ≃ₐ[𝓞 𝒟.L] (𝓞 𝒟.K) :=
    NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
  have hxε : (xε : 𝒟.K) ≠ 0 := by
    exact_mod_cast hxgen_nonzero ε
  have hxη : (xη : 𝒟.K) ≠ 0 := by
    exact_mod_cast hxgen_nonzero η
  have hcε : 𝒟.c (xε : 𝒟.K) ≠ 0 := by
    intro h
    apply hxε
    exact 𝒟.c.injective (by simpa using h)
  have hcη : 𝒟.c (xη : 𝒟.K) ≠ 0 := by
    intro h
    apply hxη
    exact 𝒟.c.injective (by simpa using h)
  have hxy : (xε : 𝒟.K) * 𝒟.c (xη : 𝒟.K) = (xη : 𝒟.K) * 𝒟.c (xε : 𝒟.K) := by
    exact (div_eq_div_iff hcε hcη).mp hratio
  have hσσ' :
      Ideal.map (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K))
        (Ideal.map (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)) (I ε₀)) = I ε₀ := by
    simpa [proposition_2_2_conjIdeal] using proposition_2_2_conjIdeal_involutive 𝒟 (I ε₀)
  have hconjη :
      proposition_2_2_conjIdeal 𝒟 (I η.1) * I ε₀ =
        Ideal.span ({σ xη} : Set (𝓞 𝒟.K)) := by
    have h' := congrArg (proposition_2_2_conjIdeal 𝒟) (hxgen_ideal η)
    simp [proposition_2_2_conjIdeal, σ, Ideal.map_mul, Ideal.map_span, Set.image_singleton] at h'
    rw [hσσ'] at h'
    simpa [σ, proposition_2_2_conjIdeal] using h'
  have hconjε :
      proposition_2_2_conjIdeal 𝒟 (I ε.1) * I ε₀ =
        Ideal.span ({σ xε} : Set (𝓞 𝒟.K)) := by
    have h' := congrArg (proposition_2_2_conjIdeal 𝒟) (hxgen_ideal ε)
    simp [proposition_2_2_conjIdeal, σ, Ideal.map_mul, Ideal.map_span, Set.image_singleton] at h'
    rw [hσσ'] at h'
    simpa [σ, proposition_2_2_conjIdeal] using h'
  have hxy_int : xε * σ xη = xη * σ xε := by
    apply NumberField.RingOfIntegers.coe_injective
    change (xε : 𝒟.K) * (σ xη : 𝒟.K) = (xη : 𝒟.K) * (σ xε : 𝒟.K)
    simpa [σ] using hxy
  have hprod :
      (I ε.1 * proposition_2_2_conjIdeal 𝒟 (I η.1)) *
          (proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀) =
        (I η.1 * proposition_2_2_conjIdeal 𝒟 (I ε.1)) *
          (proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀) := by
    calc
      (I ε.1 * proposition_2_2_conjIdeal 𝒟 (I η.1)) *
          (proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀)
          = (I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀)) *
              (proposition_2_2_conjIdeal 𝒟 (I η.1) * I ε₀) := by
              simp [mul_assoc, mul_left_comm, mul_comm]
      _ = Ideal.span ({xε} : Set (𝓞 𝒟.K)) * Ideal.span ({σ xη} : Set (𝓞 𝒟.K)) := by
            rw [hxgen_ideal ε, hconjη]
      _ = Ideal.span ({xη} : Set (𝓞 𝒟.K)) * Ideal.span ({σ xε} : Set (𝓞 𝒟.K)) := by
            calc
              Ideal.span ({xε} : Set (𝓞 𝒟.K)) * Ideal.span ({σ xη} : Set (𝓞 𝒟.K))
                  = Ideal.span ({xε * σ xη} : Set (𝓞 𝒟.K)) := by
                      rw [Ideal.span_singleton_mul_span_singleton]
              _ = Ideal.span ({xη * σ xε} : Set (𝓞 𝒟.K)) := by
                    rw [hxy_int]
              _ = Ideal.span ({xη} : Set (𝓞 𝒟.K)) * Ideal.span ({σ xε} : Set (𝓞 𝒟.K)) := by
                    rw [Ideal.span_singleton_mul_span_singleton]
      _ = (I η.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀)) *
            (proposition_2_2_conjIdeal 𝒟 (I ε.1) * I ε₀) := by
            rw [hxgen_ideal η, hconjε]
      _ = (I η.1 * proposition_2_2_conjIdeal 𝒟 (I ε.1)) *
            (proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀) := by
            simp [mul_assoc, mul_left_comm, mul_comm]
  have hconj_nonzero : proposition_2_2_conjIdeal 𝒟 (I ε₀) ≠ ⊥ := by
    intro hbot
    apply hI_nonzero ε₀
    exact (Ideal.map_eq_bot_iff_of_injective
      (I := I ε₀)
      (f := NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K))
      (NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)).injective).1
      (by simpa [proposition_2_2_conjIdeal] using hbot)
  have hcommon_nonzero : proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀ ≠ ⊥ := by
    exact mul_ne_zero hconj_nonzero (hI_nonzero ε₀)
  exact mul_right_cancel₀ (show proposition_2_2_conjIdeal 𝒟 (I ε₀) * I ε₀ ≠ 0 by simpa using hcommon_nonzero) hprod

theorem proposition_2_2_large_class_fiber (𝒟 : AdmissibleDatum) (H : ℝ) (hH : 0 < H)
    (hClass : (NumberField.classNumber 𝒟.K : ℝ) ≤ H ^ 𝒟.f)
    (I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K))
    (hI_nonzero : ∀ ε, I ε ≠ ⊥) :
    ∃ (C : ClassGroup (𝓞 𝒟.K)) (ε₀ : proposition_2_2_choice_type 𝒟),
      ClassGroup.mk0 ⟨I ε₀, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε₀)⟩ = C ∧
      (((Nat.card {ε : proposition_2_2_choice_type 𝒟 //
          ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C} : ℕ) : ℝ)
        ≥ Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f)) := by
  classical
  let g : proposition_2_2_choice_type 𝒟 → ClassGroup (𝓞 𝒟.K) :=
    fun ε => ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩
  have hcard_dom :
      ((Fintype.card (proposition_2_2_choice_type 𝒟) : ℕ) : ℝ) = (2 : ℝ) ^ (𝒟.t * 𝒟.f) := by
    rw [Fintype.card_eq_nat_card, proposition_2_2_choice_type_natCard, Nat.cast_pow]
    norm_num
  have hcard_codom :
      ((Fintype.card (ClassGroup (𝓞 𝒟.K)) : ℕ) : ℝ) = (NumberField.classNumber 𝒟.K : ℝ) := by
    rw [Fintype.card_eq_nat_card, proposition_2_2_classGroup_natCard]
  have hclass_pos : (0 : ℝ) < NumberField.classNumber 𝒟.K := by
    exact_mod_cast (NumberField.classNumber_pos (K := 𝒟.K))
  have hclass_ne : (NumberField.classNumber 𝒟.K : ℝ) ≠ 0 := by
    exact ne_of_gt hclass_pos
  have hb :
      Fintype.card (ClassGroup (𝓞 𝒟.K)) • ((2 : ℝ) ^ (𝒟.t * 𝒟.f) / NumberField.classNumber 𝒟.K) ≤
        (Fintype.card (proposition_2_2_choice_type 𝒟) : ℝ) := by
    rw [nsmul_eq_mul, hcard_codom, hcard_dom]
    simpa [hclass_ne] using (le_of_eq (mul_div_cancel₀ ((2 : ℝ) ^ (𝒟.t * 𝒟.f)) hclass_ne))
  obtain ⟨C, hC⟩ :=
    Fintype.exists_le_card_fiber_of_nsmul_le_card g
      (b := (2 : ℝ) ^ (𝒟.t * 𝒟.f) / NumberField.classNumber 𝒟.K) hb
  have hC_nat :
      (2 : ℝ) ^ (𝒟.t * 𝒟.f) / NumberField.classNumber 𝒟.K ≤
        (((Nat.card {ε : proposition_2_2_choice_type 𝒟 // g ε = C} : ℕ) : ℝ)) := by
    simpa [Nat.card_eq_fintype_card, Fintype.card_subtype, g] using hC
  have hquot_pos : 0 < (2 : ℝ) ^ (𝒟.t * 𝒟.f) / NumberField.classNumber 𝒟.K := by
    have hpow_pos : 0 < (2 : ℝ) ^ (𝒟.t * 𝒟.f) := by positivity
    exact div_pos hpow_pos hclass_pos
  have hfiber_pos : 0 < Nat.card {ε : proposition_2_2_choice_type 𝒟 // g ε = C} := by
    exact Nat.cast_pos.mp (lt_of_lt_of_le hquot_pos hC_nat)
  obtain ⟨ε₀⟩ := Finite.card_pos_iff.mp hfiber_pos
  refine ⟨C, ε₀.1, ε₀.2, ?_⟩
  have hExpEq :
      Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f) = ((2 : ℝ) ^ (𝒟.t * 𝒟.f)) / H ^ 𝒟.f := by
    calc
      Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f)
          = (Real.exp (𝒟.t * Real.log 2 - Real.log H)) ^ (𝒟.f : ℝ) := by
              rw [Real.exp_mul]
      _ = (Real.exp (𝒟.t * Real.log 2) / Real.exp (Real.log H)) ^ (𝒟.f : ℝ) := by
              rw [Real.exp_sub]
      _ = (((2 : ℝ) ^ 𝒟.t) / H) ^ (𝒟.f : ℝ) := by
              rw [show Real.exp ((𝒟.t : ℝ) * Real.log 2) = (2 : ℝ) ^ 𝒟.t by
                    rw [mul_comm, Real.exp_mul, Real.exp_log (by positivity), Real.rpow_natCast],
                  Real.exp_log hH]
      _ = (((2 : ℝ) ^ 𝒟.t) ^ 𝒟.f) / H ^ 𝒟.f := by
              rw [Real.div_rpow (by positivity) hH.le, Real.rpow_natCast, Real.rpow_natCast]
      _ = (2 : ℝ) ^ (𝒟.t * 𝒟.f) / H ^ 𝒟.f := by rw [← pow_mul]
  have hexp_le_quot : Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f) ≤
      (2 : ℝ) ^ (𝒟.t * 𝒟.f) / NumberField.classNumber 𝒟.K := by
    rw [hExpEq]
    have hpow_nonneg : (0 : ℝ) ≤ (2 : ℝ) ^ (𝒟.t * 𝒟.f) := by positivity
    exact div_le_div_of_nonneg_left hpow_nonneg hclass_pos hClass
  exact le_trans hexp_le_quot hC_nat

open scoped BigOperators in
theorem proposition_2_2_prime_family_L (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) :
    ∃ p : Fin 𝒟.f → Ideal (𝓞 𝒟.L),
      (∀ i, p i ≠ ⊥) ∧
      (∀ i, (p i).IsPrime) ∧
      (∀ {i j}, i ≠ j → p i ≠ p j) ∧
      (∀ i,
        (p i).LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) ∧
        Ideal.ramificationIdx (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) (p i) = 1 ∧
        Ideal.inertiaDeg (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) (p i) = 1) ∧
      ((∏ i : Fin 𝒟.f, p i) = Ideal.span ({(𝒟.q b : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L))) := by
  classical
  let qid : Ideal ℤ := Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)
  let s : Finset (Ideal (𝓞 𝒟.L)) := primesOverFinset qid (𝓞 𝒟.L)
  have hqid0 : qid ≠ ⊥ := by
    dsimp [qid]
    simp [Nat.Prime.ne_zero (𝒟.q_prime b)]
  have hqid_prime : qid.IsPrime := by
    dsimp [qid]
    rw [Ideal.span_singleton_prime]
    · exact (Nat.prime_iff_prime_int).mp (𝒟.q_prime b)
    · exact_mod_cast (Nat.Prime.ne_zero (𝒟.q_prime b))
  letI : qid.IsMaximal := Ideal.IsPrime.isMaximal hqid_prime hqid0
  have hs_card : s.card = 𝒟.f := by
    have hs_ncard : (s : Set (Ideal (𝓞 𝒟.L))).ncard = 𝒟.f := by
      calc
        (s : Set (Ideal (𝓞 𝒟.L))).ncard = (qid.primesOver (𝓞 𝒟.L)).ncard := by
          simpa [s] using congrArg Set.ncard (coe_primesOverFinset (p := qid) (B := 𝓞 𝒟.L) hqid0)
        _ = Module.finrank ℚ 𝒟.L := (𝒟.q_splits_in_L b).2
        _ = 𝒟.f := by rfl
    simpa using hs_ncard
  let e : Fin 𝒟.f ≃ s := (Finset.equivFinOfCardEq (s := s) hs_card).symm
  refine ⟨fun i => ((e i : s) : Ideal (𝓞 𝒟.L)), ?_⟩
  constructor
  · intro i
    simpa [s] using (Ideal.Factors.ne_bot qid (e i))
  constructor
  · intro i
    simpa [s] using (Ideal.Factors.isPrime qid (e i))
  constructor
  · intro i j hij hpij
    apply hij
    apply e.injective
    exact Subtype.ext hpij
  constructor
  · intro i
    have hmem_s : (((e i : s) : Ideal (𝓞 𝒟.L))) ∈ s := (e i).property
    have hmem : (((e i : s) : Ideal (𝓞 𝒟.L))) ∈ qid.primesOver (𝓞 𝒟.L) := by
      exact (mem_primesOverFinset_iff (p := qid) (B := 𝓞 𝒟.L) hqid0).mp (by simp [s])
    have hsplit : Ideal.ramificationIdx qid (((e i : s) : Ideal (𝓞 𝒟.L))) = 1 ∧
        Ideal.inertiaDeg qid (((e i : s) : Ideal (𝓞 𝒟.L))) = 1 := by
      simpa [qid] using (𝒟.q_splits_in_L b).1 (((e i : s) : Ideal (𝓞 𝒟.L))) hmem
    exact ⟨hmem.2, hsplit.1, hsplit.2⟩
  · let I : Ideal (𝓞 𝒟.L) := Ideal.map (algebraMap ℤ (𝓞 𝒟.L)) qid
    have hI0 : I ≠ ⊥ := by
      dsimp [I]
      exact Ideal.map_ne_bot_of_ne_bot hqid0
    have hcount1 : ∀ P ∈ s, Multiset.count P (UniqueFactorizationMonoid.factors I) = 1 := by
      intro P hP
      have hmem : P ∈ qid.primesOver (𝓞 𝒟.L) := by
        exact (mem_primesOverFinset_iff (p := qid) (B := 𝓞 𝒟.L) hqid0).mp (by simpa [s] using hP)
      have hP0 : P ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hqid0 hmem
      have hPprime : P.IsPrime := hmem.1
      have hram : Ideal.ramificationIdx qid P = 1 := by
        simpa [qid] using ((𝒟.q_splits_in_L b).1 P hmem).1
      rw [Ideal.IsDedekindDomain.ramificationIdx_eq_factors_count (by simpa [I] using hI0) hPprime hP0] at hram
      simpa [I] using hram
    have hprod_enum :
        (∏ i : Fin 𝒟.f, (((e i : s) : Ideal (𝓞 𝒟.L)))) = ∏ x : s, ((x : Ideal (𝓞 𝒟.L))) := by
      exact Fintype.prod_equiv e (fun i => (((e i : s) : Ideal (𝓞 𝒟.L))))
        (fun x => ((x : Ideal (𝓞 𝒟.L)))) (fun _ => rfl)
    have hprod_subtype : (∏ x : s, ((x : Ideal (𝓞 𝒟.L)))) = ∏ P ∈ s, P := by
      simpa [Finset.univ_eq_attach] using
        (Finset.prod_attach s (fun P : Ideal (𝓞 𝒟.L) => P))
    have hprod_s : ∏ P ∈ s, P = I := by
      calc
        ∏ P ∈ s, P = ∏ P ∈ s, P ^ Multiset.count P (UniqueFactorizationMonoid.factors I) := by
          apply Finset.prod_congr rfl
          intro P hP
          rw [hcount1 P hP, pow_one]
        _ = (UniqueFactorizationMonoid.factors I).prod := by
          symm
          simpa [s, I, primesOverFinset] using
            (Finset.prod_multiset_count (s := UniqueFactorizationMonoid.factors I))
        _ = I := by
          rw [UniqueFactorizationMonoid.factors_eq_normalizedFactors, prod_normalizedFactors_eq_self hI0]
    calc
      (∏ i : Fin 𝒟.f, (((e i : s) : Ideal (𝓞 𝒟.L)))) = ∏ x : s, ((x : Ideal (𝓞 𝒟.L))) := hprod_enum
      _ = ∏ P ∈ s, P := hprod_subtype
      _ = I := hprod_s
      _ = Ideal.span ({(𝒟.q b : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L)) := by
        dsimp [I, qid]
        simpa using (Ideal.map_span (algebraMap ℤ (𝓞 𝒟.L)) ({(𝒟.q b : ℤ)} : Set ℤ))

noncomputable def proposition_2_2_qIdeal (𝒟 : AdmissibleDatum) : Ideal (𝓞 𝒟.K) := Ideal.span ({(𝒟.Q : 𝓞 𝒟.K)} : Set (𝓞 𝒟.K))

theorem proposition_2_2_fiber_principal_generator_normOne (𝒟 : AdmissibleDatum)
    (I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K))
    (hI_nonzero : ∀ ε, I ε ≠ ⊥)
    (hI_mul_conj : ∀ ε, I ε * proposition_2_2_conjIdeal 𝒟 (I ε) = proposition_2_2_qIdeal 𝒟)
    (C : ClassGroup (𝓞 𝒟.K))
    (ε₀ : proposition_2_2_choice_type 𝒟)
    (ε : {ε : proposition_2_2_choice_type 𝒟 //
          ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C})
    (x : 𝓞 𝒟.K) (hx0 : x ≠ 0)
    (hx : I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀) =
      Ideal.span ({x} : Set (𝓞 𝒟.K))) :
    𝒟.IsNormOneIntegral ((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)) := by
  classical
  let u : 𝒟.K := (x : 𝒟.K) / 𝒟.c (x : 𝒟.K)
  have hxK0 : (x : 𝒟.K) ≠ 0 := by
    exact_mod_cast hx0
  have hcx0 : 𝒟.c (x : 𝒟.K) ≠ 0 := by
    intro h
    apply hxK0
    rw [← 𝒟.c_sq_eq_id (x : 𝒟.K), h, map_zero]
  refine ⟨?_, ?_, ?_⟩
  · calc
      𝒟.relNorm u
          = (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)) *
              (𝒟.c (x : 𝒟.K) / 𝒟.c (𝒟.c (x : 𝒟.K)))) := by
                simp [u, AdmissibleDatum.relNorm, map_div₀]
      _ = (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)) * ((𝒟.c (x : 𝒟.K)) / (x : 𝒟.K))) := by
            rw [𝒟.c_sq_eq_id]
      _ = 1 := by
            field_simp [hxK0, hcx0]
  · intro σ
    have hσx0 : σ (x : 𝒟.K) ≠ 0 := by
      intro h
      apply hxK0
      apply σ.injective
      simpa using h
    change ‖σ (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)))‖ = 1
    rw [map_div₀, complex_embedding_conjugation_compat]
    rw [norm_div, norm_star, div_self (norm_ne_zero_iff.mpr hσx0)]
  · let e : (𝓞 𝒟.K) ≃ₐ[𝓞 𝒟.L] (𝓞 𝒟.K) :=
        NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
    have he2₀ : Ideal.map e (Ideal.map e (I ε₀)) = I ε₀ := by
      simpa [proposition_2_2_conjIdeal, e] using
        (proposition_2_2_conjIdeal_involutive 𝒟 (I ε₀))
    have hx_map' : Ideal.map e (I ε.1) * Ideal.map e (proposition_2_2_conjIdeal 𝒟 (I ε₀)) = Ideal.span ({e x} : Set (𝓞 𝒟.K)) := by
      have hx_map := congrArg (fun J : Ideal (𝓞 𝒟.K) => Ideal.map e J) hx
      simpa [Ideal.map_mul, Ideal.map_span, Set.image_singleton] using hx_map
    have hx_conj : proposition_2_2_conjIdeal 𝒟 (I ε.1) * I ε₀ = Ideal.span ({e x} : Set (𝓞 𝒟.K)) := by
      rw [proposition_2_2_conjIdeal, he2₀] at hx_map'
      exact hx_map'
    have hspan_mul :
        Ideal.span ({x} : Set (𝓞 𝒟.K)) * Ideal.span ({e x} : Set (𝓞 𝒟.K)) =
          proposition_2_2_qIdeal 𝒟 * proposition_2_2_qIdeal 𝒟 := by
      calc
        Ideal.span ({x} : Set (𝓞 𝒟.K)) * Ideal.span ({e x} : Set (𝓞 𝒟.K))
            = (I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀)) *
                (proposition_2_2_conjIdeal 𝒟 (I ε.1) * I ε₀) := by
                  rw [← hx, ← hx_conj]
        _ = (I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε.1)) *
              (I ε₀ * proposition_2_2_conjIdeal 𝒟 (I ε₀)) := by
              simp [mul_assoc, mul_left_comm, mul_comm]
        _ = proposition_2_2_qIdeal 𝒟 * proposition_2_2_qIdeal 𝒟 := by
              rw [hI_mul_conj ε.1, hI_mul_conj ε₀]
    have hsingle :
        Ideal.span ({x * e x} : Set (𝓞 𝒟.K)) =
          Ideal.span ({(𝒟.Q : 𝓞 𝒟.K) * (𝒟.Q : 𝓞 𝒟.K)} : Set (𝓞 𝒟.K)) := by
      simpa [proposition_2_2_qIdeal, Ideal.span_singleton_mul_span_singleton] using hspan_mul
    have hmem : ((𝒟.Q : 𝓞 𝒟.K) * (𝒟.Q : 𝓞 𝒟.K)) ∈ Ideal.span ({x * e x} : Set (𝓞 𝒟.K)) := by
      rw [hsingle]
      exact Ideal.subset_span (by simp)
    have hdiv : x * e x ∣ (𝒟.Q : 𝓞 𝒟.K) * (𝒟.Q : 𝓞 𝒟.K) := by
      rwa [Ideal.mem_span_singleton] at hmem
    rcases hdiv with ⟨a, ha⟩
    refine ⟨a * x * x, ?_⟩
    have he_apply : ((e x : 𝓞 𝒟.K) : 𝒟.K) = 𝒟.c (x : 𝒟.K) := by
      rfl
    have haK : ((𝒟.Q : 𝒟.K) * (𝒟.Q : 𝒟.K)) = (((x : 𝒟.K) * 𝒟.c (x : 𝒟.K)) * (a : 𝒟.K)) := by
      have ha' := congrArg (fun z : 𝓞 𝒟.K => (z : 𝒟.K)) ha
      simpa [he_apply, mul_assoc] using ha'
    have hcancel : (𝒟.c (x : 𝒟.K)) * ((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)) = (x : 𝒟.K) := by
      field_simp [hcx0]
    change ((𝒟.Q : 𝒟.K) ^ 2) * (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K))) = (((a * x * x : 𝓞 𝒟.K) : 𝒟.K))
    calc
      ((𝒟.Q : 𝒟.K) ^ 2) * (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)))
          = (((𝒟.Q : 𝒟.K) * (𝒟.Q : 𝒟.K)) * (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)))) := by
              simp [pow_two]
      _ = ((((x : 𝒟.K) * 𝒟.c (x : 𝒟.K)) * (a : 𝒟.K)) * (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K)))) := by
            rw [haK]
      _ = (((a : 𝒟.K) * (x : 𝒟.K)) * ((𝒟.c (x : 𝒟.K)) * (((x : 𝒟.K) / 𝒟.c (x : 𝒟.K))))) := by
            ring
      _ = (((a : 𝒟.K) * (x : 𝒟.K)) * (x : 𝒟.K)) := by
            rw [hcancel]
      _ = (((a * x * x : 𝓞 𝒟.K) : 𝒟.K)) := by
            simp [mul_assoc]

theorem proposition_2_2_fiber_injective_normOneMap (𝒟 : AdmissibleDatum)
    (I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K))
    (hI_nonzero : ∀ ε, I ε ≠ ⊥)
    (hI_mul_conj : ∀ ε, I ε * proposition_2_2_conjIdeal 𝒟 (I ε) = proposition_2_2_qIdeal 𝒟)
    (hI_cross : ∀ {ε η : proposition_2_2_choice_type 𝒟},
      I ε * proposition_2_2_conjIdeal 𝒟 (I η) =
        I η * proposition_2_2_conjIdeal 𝒟 (I ε) → ε = η)
    (C : ClassGroup (𝓞 𝒟.K))
    (ε₀ : proposition_2_2_choice_type 𝒟)
    (hε₀ : ClassGroup.mk0 ⟨I ε₀, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε₀)⟩ = C) :
    ∃ u : {ε : proposition_2_2_choice_type 𝒟 //
          ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C} → 𝒟.K,
      Function.Injective u ∧ ∀ ε, 𝒟.IsNormOneIntegral (u ε) := by
  classical
  let cInt : (𝓞 𝒟.K) ≃ₐ[𝓞 𝒟.L] (𝓞 𝒟.K) :=
    NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
  let conjI0 : Ideal (𝓞 𝒟.K) := proposition_2_2_conjIdeal 𝒟 (I ε₀)
  have hconjI0_nonzero : conjI0 ≠ ⊥ := by
    dsimp [conjI0, proposition_2_2_conjIdeal]
    rw [Ideal.map_eq_bot_iff_of_injective]
    · exact hI_nonzero ε₀
    · exact cInt.injective
  have hI0_inv :
      ClassGroup.mk0 ⟨I ε₀, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε₀)⟩ =
        (ClassGroup.mk0 ⟨conjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzero⟩)⁻¹ := by
    rw [ClassGroup.mk0_eq_mk0_inv_iff]
    refine ⟨(𝒟.Q : 𝓞 𝒟.K), ?_, ?_⟩
    · exact_mod_cast (Nat.ne_of_gt 𝒟.Q_pos)
    · simpa [conjI0, proposition_2_2_qIdeal] using hI_mul_conj ε₀
  let F := {ε : proposition_2_2_choice_type 𝒟 //
    ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C}
  have hprincipal : ∀ ε : F,
      ∃ x : 𝓞 𝒟.K, x ≠ 0 ∧ I ε.1 * conjI0 = Ideal.span ({x} : Set (𝓞 𝒟.K)) := by
    intro ε
    have hclass :
        ClassGroup.mk0 ⟨I ε.1, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε.1)⟩ =
          (ClassGroup.mk0 ⟨conjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzero⟩)⁻¹ := by
      calc
        ClassGroup.mk0 ⟨I ε.1, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε.1)⟩ = C := ε.2
        _ = ClassGroup.mk0 ⟨I ε₀, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε₀)⟩ := hε₀.symm
        _ = (ClassGroup.mk0 ⟨conjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzero⟩)⁻¹ := hI0_inv
    rw [ClassGroup.mk0_eq_mk0_inv_iff] at hclass
    simpa [conjI0] using hclass
  let xgen : F → 𝓞 𝒟.K := fun ε => Classical.choose (hprincipal ε)
  have hxgen_nonzero : ∀ ε : F, xgen ε ≠ 0 := by
    intro ε
    exact (Classical.choose_spec (hprincipal ε)).1
  have hxgen_ideal : ∀ ε : F,
      I ε.1 * proposition_2_2_conjIdeal 𝒟 (I ε₀) =
        Ideal.span ({xgen ε} : Set (𝓞 𝒟.K)) := by
    intro ε
    exact (Classical.choose_spec (hprincipal ε)).2
  let u : F → 𝒟.K := fun ε => (xgen ε : 𝒟.K) / 𝒟.c (xgen ε : 𝒟.K)
  refine ⟨u, ?_, ?_⟩
  · simpa [u] using
      proposition_2_2_fiber_principal_generator_injective 𝒟 I hI_nonzero @hI_cross C ε₀ xgen hxgen_nonzero hxgen_ideal
  · intro ε
    simpa [u] using
      proposition_2_2_fiber_principal_generator_normOne 𝒟 I hI_nonzero hI_mul_conj C ε₀ ε (xgen ε)
        (hxgen_nonzero ε) (hxgen_ideal ε)

theorem proposition_2_2_class_fiber_to_finset (𝒟 : AdmissibleDatum)
    (I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K))
    (hI_nonzero : ∀ ε, I ε ≠ ⊥)
    (hI_mul_conj : ∀ ε, I ε * proposition_2_2_conjIdeal 𝒟 (I ε) = proposition_2_2_qIdeal 𝒟)
    (hI_cross : ∀ {ε η : proposition_2_2_choice_type 𝒟},
      I ε * proposition_2_2_conjIdeal 𝒟 (I η) =
        I η * proposition_2_2_conjIdeal 𝒟 (I ε) → ε = η)
    (C : ClassGroup (𝓞 𝒟.K))
    (ε₀ : proposition_2_2_choice_type 𝒟)
    (hε₀ : ClassGroup.mk0 ⟨I ε₀, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε₀)⟩ = C) :
    ∃ U : Finset 𝒟.K,
      U.card =
        Nat.card {ε : proposition_2_2_choice_type 𝒟 //
          ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C} ∧
      (∀ u ∈ U, 𝒟.IsNormOneIntegral u) := by
  classical
  let fiber : Type := {ε : proposition_2_2_choice_type 𝒟 //
    ClassGroup.mk0 ⟨I ε, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ε)⟩ = C}
  let _ : Fintype fiber := Fintype.ofFinite fiber
  obtain ⟨u, huinj, hnorm⟩ := proposition_2_2_fiber_injective_normOneMap 𝒟 I hI_nonzero hI_mul_conj hI_cross C ε₀ hε₀
  refine ⟨Finset.univ.image u, ?_, ?_⟩
  · simpa [fiber] using (Finset.card_image_of_injective (s := (Finset.univ : Finset fiber)) huinj)
  · intro v hv
    rcases Finset.mem_image.mp hv with ⟨ε, -, rfl⟩
    exact hnorm ε

open UniqueFactorizationMonoid in
theorem proposition_2_2_quadratic_split_normalizedFactors (κ : Type*) [Field κ] [DecidableEq κ] (r : κ) (hr : r ^ 2 = (-1 : κ)) :
    UniqueFactorizationMonoid.normalizedFactors
      ((Polynomial.X ^ 2 + Polynomial.C (1 : κ) : Polynomial κ)) =
      ({(Polynomial.X - Polynomial.C r : Polynomial κ)} : Multiset (Polynomial κ)) +
      ({(Polynomial.X + Polynomial.C r : Polynomial κ)} : Multiset (Polynomial κ)) := by
  let q₁ : Polynomial κ := Polynomial.X - Polynomial.C r
  let q₂ : Polynomial κ := Polynomial.X + Polynomial.C r
  have hfac : (Polynomial.X ^ 2 + Polynomial.C (1 : κ) : Polynomial κ) = q₁ * q₂ := by
    calc
      (Polynomial.X ^ 2 + Polynomial.C (1 : κ) : Polynomial κ)
          = Polynomial.X ^ 2 - Polynomial.C (r ^ 2) := by
              rw [hr]
              simp [sub_eq_add_neg]
      _ = Polynomial.X ^ 2 - (Polynomial.C r) ^ 2 := by
            rw [Polynomial.C_pow]
      _ = q₁ * q₂ := by
            simp [q₁, q₂, pow_two]
            ring
  have hq₁irr : Irreducible q₁ := by
    simpa [q₁] using Polynomial.irreducible_X_sub_C r
  have hq₂irr : Irreducible q₂ := by
    simpa [q₂, sub_eq_add_neg, Polynomial.C_neg, add_comm, add_left_comm, add_assoc] using
      (Polynomial.irreducible_X_sub_C (-r))
  have hq₁0 : q₁ ≠ 0 := hq₁irr.ne_zero
  have hq₂0 : q₂ ≠ 0 := hq₂irr.ne_zero
  calc
    UniqueFactorizationMonoid.normalizedFactors
        ((Polynomial.X ^ 2 + Polynomial.C (1 : κ) : Polynomial κ))
        = UniqueFactorizationMonoid.normalizedFactors (q₁ * q₂) := by rw [hfac]
    _ = UniqueFactorizationMonoid.normalizedFactors q₁ +
        UniqueFactorizationMonoid.normalizedFactors q₂ := by
          rw [UniqueFactorizationMonoid.normalizedFactors_mul hq₁0 hq₂0]
    _ = ({normalize q₁} : Multiset (Polynomial κ)) + ({normalize q₂} : Multiset (Polynomial κ)) := by
          rw [UniqueFactorizationMonoid.normalizedFactors_irreducible hq₁irr,
            UniqueFactorizationMonoid.normalizedFactors_irreducible hq₂irr]
    _ = ({q₁} : Multiset (Polynomial κ)) + ({q₂} : Multiset (Polynomial κ)) := by
          congr 1
          · rw [Polynomial.Monic.normalize_eq_self (Polynomial.monic_X_sub_C r)]
          · rw [Polynomial.Monic.normalize_eq_self (Polynomial.monic_X_add_C r)]
    _ = ({(Polynomial.X - Polynomial.C r : Polynomial κ)} : Multiset (Polynomial κ)) +
        ({(Polynomial.X + Polynomial.C r : Polynomial κ)} : Multiset (Polynomial κ)) := by
          simp [q₁, q₂]

theorem proposition_2_2_split_prime_over_L_residue_root (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) (p : Ideal (𝓞 𝒟.L))
    (hp0 : p ≠ ⊥) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)))
    (hp_inertia : Ideal.inertiaDeg (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) p = 1) :
    ∃ r : (𝓞 𝒟.L ⧸ p), r ^ 2 = (-1 : (𝓞 𝒟.L ⧸ p)) ∧ (-r : (𝓞 𝒟.L ⧸ p)) ≠ r := by
  classical
  letI : p.IsMaximal := hp_prime.isMaximal hp0
  letI : Field (𝓞 𝒟.L ⧸ p) := Ideal.Quotient.field p
  letI : Finite (𝓞 𝒟.L ⧸ p) := by
    infer_instance
  letI : Fintype (𝓞 𝒟.L ⧸ p) := Fintype.ofFinite (𝓞 𝒟.L ⧸ p)
  letI : p.LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) := hp_lies
  letI : Fact (Nat.Prime (𝒟.q b)) := ⟨𝒟.q_prime b⟩
  have hcard_nat : Nat.card (𝓞 𝒟.L ⧸ p) = 𝒟.q b := by
    calc
      Nat.card (𝓞 𝒟.L ⧸ p) = Submodule.cardQuot p := by
        symm
        exact Submodule.cardQuot_apply p
      _ = Ideal.absNorm p := by
        symm
        exact Ideal.absNorm_apply p
      _ = 𝒟.q b ^ Ideal.inertiaDeg (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) p := by
        simpa using
          (Ideal.absNorm_eq_pow_inertiaDeg' (P := p) (p := 𝒟.q b) (hp := 𝒟.q_prime b))
      _ = 𝒟.q b ^ 1 := by rw [hp_inertia]
      _ = 𝒟.q b := by simp only [pow_one]
  have hcard : Fintype.card (𝓞 𝒟.L ⧸ p) = 𝒟.q b := by
    rw [Fintype.card_eq_nat_card]
    exact hcard_nat
  let e : ZMod (𝒟.q b) ≃+* (𝓞 𝒟.L ⧸ p) :=
    ZMod.ringEquivOfPrime (R := (𝓞 𝒟.L ⧸ p)) (𝒟.q_prime b) hcard
  have hmod4_ne3 : 𝒟.q b % 4 ≠ 3 := by
    have hmod4 : 𝒟.q b % 4 = 1 := 𝒟.q_mod4 b
    omega
  have hsq : ∃ z : ZMod (𝒟.q b), z ^ 2 = (-1 : ZMod (𝒟.q b)) := by
    have hsq' : IsSquare (-1 : ZMod (𝒟.q b)) :=
      (ZMod.exists_sq_eq_neg_one_iff).2 hmod4_ne3
    rw [isSquare_iff_exists_sq] at hsq'
    rcases hsq' with ⟨z, hz⟩
    exact ⟨z, by simpa [eq_comm] using hz⟩
  rcases hsq with ⟨z, hz⟩
  have hz0 : z ≠ 0 := by
    intro hz0
    have hneg1_ne_zero : (-1 : ZMod (𝒟.q b)) ≠ 0 := by
      exact neg_ne_zero.mpr one_ne_zero
    apply hneg1_ne_zero
    calc
      (-1 : ZMod (𝒟.q b)) = z ^ 2 := by simpa using hz.symm
      _ = 0 := by simp [hz0]
  have hodd : Odd (𝒟.q b) := by
    rw [Nat.odd_iff]
    exact Nat.odd_of_mod_four_eq_one (𝒟.q_mod4 b)
  have hz_ne_neg : z ≠ (-z : ZMod (𝒟.q b)) :=
    ZMod.ne_neg_self hodd hz0
  refine ⟨e z, ?_, ?_⟩
  · calc
      (e z) ^ 2 = e (z ^ 2) := by
        simp
      _ = e (-1) := by rw [hz]
      _ = (-1 : (𝓞 𝒟.L ⧸ p)) := by
        simp
  · intro h
    have h' : (-z : ZMod (𝒟.q b)) = z := by
      apply e.injective
      simpa using h
    exact hz_ne_neg h'.symm

theorem proposition_2_2_theta_minpoly (𝒟 : AdmissibleDatum) :
    ∃ θ : 𝓞 𝒟.K,
      ((θ : 𝒟.K) = 𝒟.i_K) ∧
      minpoly (𝓞 𝒟.L) θ = Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L) := by
  classical
  let hiL : IsIntegral (𝓞 𝒟.L) 𝒟.i_K := by
    refine ⟨Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L), ?_, ?_⟩
    · simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : 𝓞 𝒟.L)) (n := 2) (by decide))
    · rw [Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
      simp [pow_two, 𝒟.i_K_sq]
  let θ : 𝓞 𝒟.K := IsIntegralClosure.mk' (𝓞 𝒟.K) 𝒟.i_K hiL
  have hθ : ((θ : 𝒟.K) = 𝒟.i_K) := by
    simp [θ]
  have hiField : IsIntegral 𝒟.L 𝒟.i_K := by
    refine ⟨Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L), ?_, ?_⟩
    · simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : 𝒟.L)) (n := 2) (by decide))
    · rw [Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
      simp [pow_two, 𝒟.i_K_sq]
  have htwo : 2 ≤ (minpoly 𝒟.L 𝒟.i_K).natDegree :=
    (minpoly.two_le_natDegree_iff hiField).2 𝒟.i_K_notMem_range
  have hdeg :
      (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)).degree ≤
        (minpoly 𝒟.L 𝒟.i_K).degree := by
    have hdeg' : (2 : WithBot ℕ) ≤ (minpoly 𝒟.L 𝒟.i_K).degree := by
      rw [Polynomial.degree_eq_natDegree (minpoly.ne_zero hiField)]
      exact_mod_cast htwo
    rw [Polynomial.degree_X_pow_add_C (R := 𝒟.L) (n := 2) (by decide : 0 < 2) (1 : 𝒟.L)]
    exact hdeg'
  have hmin_field : Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) = minpoly 𝒟.L 𝒟.i_K := by
    apply minpoly.unique_of_degree_le_degree_minpoly (A := 𝒟.L) (x := 𝒟.i_K)
    · simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : 𝒟.L)) (n := 2) (by decide))
    · change Polynomial.eval₂ (algebraMap 𝒟.L 𝒟.K) 𝒟.i_K
          (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)) = 0
      rw [Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
      simp [pow_two, 𝒟.i_K_sq]
    · exact hdeg
  have hθ_integral : IsIntegral (𝓞 𝒟.L) θ :=
    IsIntegralClosure.isIntegral (R := 𝓞 𝒟.L) (A := 𝓞 𝒟.K) (B := 𝒟.K) θ
  have hfrac :
      minpoly 𝒟.L ((θ : 𝒟.K)) =
        (minpoly (𝓞 𝒟.L) θ).map (algebraMap (𝓞 𝒟.L) 𝒟.L) := by
    simpa using
      (minpoly.isIntegrallyClosed_eq_field_fractions
        (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) (K := 𝒟.L) (L := 𝒟.K) (s := θ)
        hθ_integral)
  refine ⟨θ, hθ, ?_⟩
  have hmap' :
      (minpoly (𝓞 𝒟.L) θ).map (algebraMap (𝓞 𝒟.L) 𝒟.L) =
        Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
    calc
      (minpoly (𝓞 𝒟.L) θ).map (algebraMap (𝓞 𝒟.L) 𝒟.L)
          = minpoly 𝒟.L ((θ : 𝒟.K)) := by
              symm
              exact hfrac
      _ = minpoly 𝒟.L 𝒟.i_K := by rw [hθ]
      _ = Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := hmin_field.symm
  have himg :
      (Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L)).map (algebraMap (𝓞 𝒟.L) 𝒟.L) =
        Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
    rw [Polynomial.map_add, Polynomial.map_pow, Polynomial.map_X, Polynomial.map_C]
    rw [map_one]
  have hmap :
      (minpoly (𝓞 𝒟.L) θ).map (algebraMap (𝓞 𝒟.L) 𝒟.L) =
        (Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L)).map (algebraMap (𝓞 𝒟.L) 𝒟.L) :=
    hmap'.trans himg.symm
  exact
    (Polynomial.map_injective (algebraMap (𝓞 𝒟.L) 𝒟.L)
      (FaithfulSMul.algebraMap_injective (𝓞 𝒟.L) 𝒟.L)) hmap

theorem proposition_2_2_split_prime_over_L_kd_setup (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) (p : Ideal (𝓞 𝒟.L))
    (hp0 : p ≠ ⊥) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ))) :
    ∃ θ : 𝓞 𝒟.K,
      ((θ : 𝒟.K) = 𝒟.i_K) ∧
      minpoly (𝓞 𝒟.L) θ = Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L) ∧
      (conductor (𝓞 𝒟.L) θ).comap (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ⊔ p = ⊤ := by
  obtain ⟨θ, hθ, hmin⟩ := proposition_2_2_theta_minpoly 𝒟
  refine ⟨θ, hθ, hmin, ?_⟩
  exact proposition_2_2_conductor_coprime_p 𝒟 b p hp0 hp_prime hp_lies θ hθ hmin

open UniqueFactorizationMonoid in
theorem proposition_2_2_split_prime_over_L (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) (p : Ideal (𝓞 𝒟.L))
    (hp0 : p ≠ ⊥) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)))
    (hp_inertia : Ideal.inertiaDeg (Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ)) p = 1) :
    ∃ P : Ideal (𝓞 𝒟.K),
      P ≠ ⊥ ∧ P.IsPrime ∧ P.LiesOver p ∧
      (proposition_2_2_conjIdeal 𝒟 P).LiesOver p ∧
      P ≠ proposition_2_2_conjIdeal 𝒟 P ∧
      P * proposition_2_2_conjIdeal 𝒟 P =
        p.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) := by
  classical
  have hp_max : p.IsMaximal := hp_prime.isMaximal hp0
  letI : p.IsMaximal := hp_max
  letI : Field (𝓞 𝒟.L ⧸ p) := Ideal.Quotient.field p
  letI : DecidableEq (𝓞 𝒟.L ⧸ p) := Classical.decEq _
  obtain ⟨θ, hθi, hmin, hcond⟩ :=
    proposition_2_2_split_prime_over_L_kd_setup 𝒟 b p hp0 hp_prime hp_lies
  have hθint : IsIntegral (𝓞 𝒟.L) θ := by
    exact
      (Algebra.isIntegral_def.mp
        (NumberField.RingOfIntegers.extension_algebra_isIntegral (K := 𝒟.L) (L := 𝒟.K))) θ
  obtain ⟨r, hr, hr_ne⟩ :=
    proposition_2_2_split_prime_over_L_residue_root 𝒟 b p hp0 hp_prime hp_lies hp_inertia
  obtain ⟨a, ha⟩ := (Ideal.Quotient.mk_surjective (I := p)) r
  let Q₁ : Polynomial (𝓞 𝒟.L) := Polynomial.X - Polynomial.C a
  let Q₂ : Polynomial (𝓞 𝒟.L) := Polynomial.X + Polynomial.C a
  have hQ₁map : Q₁.map (Ideal.Quotient.mk p) = Polynomial.X - Polynomial.C r := by
    dsimp [Q₁]
    simp [ha]
  have hQ₂map : Q₂.map (Ideal.Quotient.mk p) = Polynomial.X + Polynomial.C r := by
    dsimp [Q₂]
    simp [ha]
  have hminmap : (minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p) =
      (Polynomial.X ^ 2 + Polynomial.C (1 : 𝓞 𝒟.L ⧸ p)) := by
    rw [hmin]
    simp
  have hnormFactors_fbar :
      UniqueFactorizationMonoid.normalizedFactors
        ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p)) =
        ({(Polynomial.X - Polynomial.C r : Polynomial (𝓞 𝒟.L ⧸ p))} :
            Multiset (Polynomial (𝓞 𝒟.L ⧸ p))) +
        ({(Polynomial.X + Polynomial.C r : Polynomial (𝓞 𝒟.L ⧸ p))} :
            Multiset (Polynomial (𝓞 𝒟.L ⧸ p))) := by
    rw [hminmap]
    exact proposition_2_2_quadratic_split_normalizedFactors (κ := (𝓞 𝒟.L ⧸ p)) r hr
  have hQ₁fac : Q₁.map (Ideal.Quotient.mk p) ∈
      UniqueFactorizationMonoid.normalizedFactors ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p)) := by
    rw [hnormFactors_fbar, hQ₁map]
    simp
  have hQ₂fac : Q₂.map (Ideal.Quotient.mk p) ∈
      UniqueFactorizationMonoid.normalizedFactors ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p)) := by
    rw [hnormFactors_fbar, hQ₂map]
    simp
  let α : 𝓞 𝒟.L →+* 𝓞 𝒟.K := algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)
  let kd := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk hp_max hp0 hcond hθint
  let P₁ : Ideal (𝓞 𝒟.K) :=
    (kd.symm ⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩ :
        {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α)})
  let P₂ : Ideal (𝓞 𝒟.K) :=
    (kd.symm ⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩ :
        {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α)})
  have hP₁_mem : P₁ ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α) := by
    dsimp [P₁]
    exact (kd.symm ⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩).property
  have hP₂_mem : P₂ ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α) := by
    dsimp [P₂]
    exact (kd.symm ⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩).property
  have hP₁_over : P₁ ∈ p.primesOver (𝓞 𝒟.K) := by
    rw [Ideal.mem_primesOver_iff_mem_normalizedFactors (A := 𝓞 𝒟.K) hp0]
    simpa [α] using hP₁_mem
  have hP₂_over : P₂ ∈ p.primesOver (𝓞 𝒟.K) := by
    rw [Ideal.mem_primesOver_iff_mem_normalizedFactors (A := 𝓞 𝒟.K) hp0]
    simpa [α] using hP₂_mem
  have hP₁0 : P₁ ≠ ⊥ := by
    exact Ideal.ne_bot_of_mem_primesOver (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) hp0 hP₁_over
  have hP₂0 : P₂ ≠ ⊥ := by
    exact Ideal.ne_bot_of_mem_primesOver (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) hp0 hP₂_over
  have hP₁_prime : P₁.IsPrime := hP₁_over.1
  have hP₂_prime : P₂.IsPrime := hP₂_over.1
  have hP₁_lies : P₁.LiesOver p := hP₁_over.2
  have hP₂_lies : P₂.LiesOver p := hP₂_over.2
  have hP₁_span : P₁ = Ideal.span (p.map α ∪ {Q₁.aeval θ}) := by
    simpa [P₁, α, kd] using
      KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
        hp_max hQ₁fac hp0 hcond hθint
  have hP₂_span : P₂ = Ideal.span (p.map α ∪ {Q₂.aeval θ}) := by
    simpa [P₂, α, kd] using
      KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
        hp_max hQ₂fac hp0 hcond hθint
  have hconjP : proposition_2_2_conjIdeal 𝒟 P₁ = P₂ := by
    rw [hP₁_span, hP₂_span]
    exact proposition_2_2_conjIdeal_span_X_sub_C_eq_span_X_add_C 𝒟 θ hθi p a
  have hP₁_sub : (⟨P₁, hP₁_mem⟩ : {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α)}) =
      kd.symm ⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩ := by
    apply Subtype.ext
    rfl
  have hP₂_sub : (⟨P₂, hP₂_mem⟩ : {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α)}) =
      kd.symm ⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩ := by
    apply Subtype.ext
    rfl
  have hkd1 : kd ⟨P₁, hP₁_mem⟩ = ⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩ := by
    rw [hP₁_sub]
    exact Equiv.apply_symm_apply kd _
  have hkd2 : kd ⟨P₂, hP₂_mem⟩ = ⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩ := by
    rw [hP₂_sub]
    exact Equiv.apply_symm_apply kd _
  have hPneq : P₁ ≠ P₂ := by
    intro hEq
    have hsubEq : (⟨P₁, hP₁_mem⟩ : {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (p.map α)}) =
        ⟨P₂, hP₂_mem⟩ := by
      apply Subtype.ext
      exact hEq
    have hpolySub :
        ((⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩ :
          {f : Polynomial (𝓞 𝒟.L ⧸ p) |
            f ∈ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p))}) =
        (⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩ :
          {f : Polynomial (𝓞 𝒟.L ⧸ p) |
            f ∈ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p))})) := by
      calc
        (⟨Q₁.map (Ideal.Quotient.mk p), hQ₁fac⟩ :
          {f : Polynomial (𝓞 𝒟.L ⧸ p) |
            f ∈ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p))}) = kd ⟨P₁, hP₁_mem⟩ := by
          symm
          exact hkd1
        _ = kd ⟨P₂, hP₂_mem⟩ := by
          rw [hsubEq]
        _ = (⟨Q₂.map (Ideal.Quotient.mk p), hQ₂fac⟩ :
          {f : Polynomial (𝓞 𝒟.L ⧸ p) |
            f ∈ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (𝓞 𝒟.L) θ).map (Ideal.Quotient.mk p))}) := by
          exact hkd2
    have hpolyEq : Q₁.map (Ideal.Quotient.mk p) = Q₂.map (Ideal.Quotient.mk p) := by
      exact congrArg Subtype.val hpolySub
    have hxeq : (Polynomial.X - Polynomial.C r : Polynomial (𝓞 𝒟.L ⧸ p)) = Polynomial.X + Polynomial.C r := by
      calc
        (Polynomial.X - Polynomial.C r : Polynomial (𝓞 𝒟.L ⧸ p)) = Q₁.map (Ideal.Quotient.mk p) := by
          symm
          exact hQ₁map
        _ = Q₂.map (Ideal.Quotient.mk p) := hpolyEq
        _ = Polynomial.X + Polynomial.C r := hQ₂map
    have hneg_eq : (-r : 𝓞 𝒟.L ⧸ p) = r := by
      have hcoeff := congrArg (fun f : Polynomial (𝓞 𝒟.L ⧸ p) => f.coeff 0) hxeq
      simpa [sub_eq_add_neg] using hcoeff
    exact hr_ne hneg_eq
  have hpmap0 : p.map α ≠ ⊥ := by
    simpa [α] using (Ideal.map_ne_bot_of_ne_bot (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) hp0)
  have hcard :
      (UniqueFactorizationMonoid.normalizedFactors (p.map α)).card = 2 := by
    rw [KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) (x := θ) (I := p) hp_max hp0 hcond hθint]
    simp [hnormFactors_fbar]
  obtain ⟨J₁, J₂, hnf⟩ := (Multiset.card_eq_two).mp hcard
  have hmem1 : P₁ = J₁ ∨ P₁ = J₂ := by
    simpa [hnf] using hP₁_mem
  have hmem2 : P₂ = J₁ ∨ P₂ = J₂ := by
    simpa [hnf] using hP₂_mem
  have hnormFactors_map :
      UniqueFactorizationMonoid.normalizedFactors (p.map α) =
        ({P₁} : Multiset (Ideal (𝓞 𝒟.K))) +
        ({P₂} : Multiset (Ideal (𝓞 𝒟.K))) := by
    rcases hmem1 with h1 | h1 <;> rcases hmem2 with h2 | h2
    · exfalso
      exact hPneq (by simp [h1, h2])
    · simp [h1, h2, hnf]
    · simp [h1, h2, Multiset.add_comm, hnf]
    · exfalso
      exact hPneq (by simp [h1, h2])
  have hprod : P₁ * P₂ = p.map α := by
    calc
      P₁ * P₂ =
          (({P₁} : Multiset (Ideal (𝓞 𝒟.K))) +
            ({P₂} : Multiset (Ideal (𝓞 𝒟.K)))).prod := by
        simp
      _ = (UniqueFactorizationMonoid.normalizedFactors (p.map α)).prod := by
        rw [hnormFactors_map]
      _ = p.map α := prod_normalizedFactors_eq_self hpmap0
  refine ⟨P₁, hP₁0, hP₁_prime, hP₁_lies, ?_, ?_, ?_⟩
  · simpa [hconjP] using hP₂_lies
  · simpa [hconjP] using hPneq
  · simpa [hconjP] using hprod

open scoped BigOperators in
theorem proposition_2_2_prime_family (𝒟 : AdmissibleDatum) :
    ∃ P : (Fin 𝒟.t × Fin 𝒟.f) → Ideal (𝓞 𝒟.K),
      (∀ j, P j ≠ ⊥) ∧
      (∀ j, (P j).IsPrime) ∧
      (∀ {j k}, j ≠ k → P j ≠ P k) ∧
      (∀ j k, P j ≠ proposition_2_2_conjIdeal 𝒟 (P k)) ∧
      ((∏ j : Fin 𝒟.t × Fin 𝒟.f, P j * proposition_2_2_conjIdeal 𝒟 (P j)) = proposition_2_2_qIdeal 𝒟) := by
  classical
  choose p hp_ne hp_prime hp_dist hp_fact hp_prod using proposition_2_2_prime_family_L 𝒟
  have hsplit :
      ∀ j : Fin 𝒟.t × Fin 𝒟.f,
        ∃ P : Ideal (𝓞 𝒟.K),
          P ≠ ⊥ ∧
          P.IsPrime ∧
          P.LiesOver (p j.1 j.2) ∧
          (proposition_2_2_conjIdeal 𝒟 P).LiesOver (p j.1 j.2) ∧
          P ≠ proposition_2_2_conjIdeal 𝒟 P ∧
          P * proposition_2_2_conjIdeal 𝒟 P =
            (p j.1 j.2).map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) := by
    intro j
    refine proposition_2_2_split_prime_over_L 𝒟 j.1 (p j.1 j.2) (hp_ne j.1 j.2) (hp_prime j.1 j.2) ?_ ?_
    · exact (hp_fact j.1 j.2).1
    · exact (hp_fact j.1 j.2).2.2
  choose P hP_ne hP_prime hP_lies hP_conj_lies hP_ne_conj hP_mul using hsplit
  have hp_under_Z :
      ∀ b i,
        Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ) = (p b i).under ℤ := by
    intro b i
    haveI := (hp_fact b i).1
    exact Ideal.over_def (A := ℤ) (P := p b i)
      (p := Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ))
  have p_eq_imp_eq :
      ∀ {j k : Fin 𝒟.t × Fin 𝒟.f}, p j.1 j.2 = p k.1 k.2 → j = k := by
    rintro ⟨b, i⟩ ⟨b', i'⟩ hp_eq
    have hspan :
        Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ) = Ideal.span ({(𝒟.q b' : ℤ)} : Set ℤ) := by
      calc
        Ideal.span ({(𝒟.q b : ℤ)} : Set ℤ) = (p b i).under ℤ := hp_under_Z b i
        _ = (p b' i').under ℤ := by simp [hp_eq]
        _ = Ideal.span ({(𝒟.q b' : ℤ)} : Set ℤ) := (hp_under_Z b' i').symm
    have hassoc : Associated (𝒟.q b : ℤ) (𝒟.q b' : ℤ) :=
      (Ideal.span_singleton_eq_span_singleton).1 hspan
    have hq : 𝒟.q b = 𝒟.q b' := by
      have hnatAbs : ((𝒟.q b : ℤ).natAbs) = ((𝒟.q b' : ℤ).natAbs) :=
        (Int.associated_iff_natAbs).1 hassoc
      simpa using hnatAbs
    have hb : b = b' := 𝒟.q_inj hq
    subst hb
    by_cases hi : i = i'
    · subst hi
      rfl
    · exfalso
      exact (hp_dist b hi) hp_eq
  refine ⟨P, hP_ne, hP_prime, ?_, ?_, ?_⟩
  · intro j k hjk hEq
    apply hjk
    apply p_eq_imp_eq
    calc
      p j.1 j.2 = (P j).under (𝓞 𝒟.L) := by
        haveI := hP_lies j
        exact Ideal.over_def (A := 𝓞 𝒟.L) (P := P j) (p := p j.1 j.2)
      _ = (P k).under (𝓞 𝒟.L) := by simp [hEq]
      _ = p k.1 k.2 := by
        haveI := hP_lies k
        exact (Ideal.over_def (A := 𝓞 𝒟.L) (P := P k) (p := p k.1 k.2)).symm
  · intro j k hEq
    have hp_eq : p j.1 j.2 = p k.1 k.2 := by
      calc
        p j.1 j.2 = (P j).under (𝓞 𝒟.L) := by
          haveI := hP_lies j
          exact Ideal.over_def (A := 𝓞 𝒟.L) (P := P j) (p := p j.1 j.2)
        _ = (proposition_2_2_conjIdeal 𝒟 (P k)).under (𝓞 𝒟.L) := by simp [hEq]
        _ = p k.1 k.2 := by
          haveI := hP_conj_lies k
          exact (Ideal.over_def (A := 𝓞 𝒟.L)
            (P := proposition_2_2_conjIdeal 𝒟 (P k)) (p := p k.1 k.2)).symm
    have hjk : j = k := p_eq_imp_eq hp_eq
    cases hjk
    exact hP_ne_conj j hEq
  · calc
      ∏ j : Fin 𝒟.t × Fin 𝒟.f, P j * proposition_2_2_conjIdeal 𝒟 (P j)
          = ∏ j : Fin 𝒟.t × Fin 𝒟.f,
              Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) (p j.1 j.2) := by
            refine Finset.prod_congr rfl ?_
            intro j hj
            exact hP_mul j
      _ = ∏ b : Fin 𝒟.t, ∏ i : Fin 𝒟.f,
            Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) (p b i) := by
            simpa using
              (Fintype.prod_prod_type' (f := fun b i =>
                Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) (p b i)))
      _ = ∏ b : Fin 𝒟.t,
            Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) (∏ i : Fin 𝒟.f, p b i) := by
            refine Finset.prod_congr rfl ?_
            intro b hb
            exact (map_prod (Ideal.mapHom (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))
              (fun i : Fin 𝒟.f => p b i) Finset.univ).symm
      _ = ∏ b : Fin 𝒟.t,
            Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
              (Ideal.span ({(𝒟.q b : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L))) := by
            refine Finset.prod_congr rfl ?_
            intro b hb
            rw [hp_prod b]
      _ = Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
            (∏ b : Fin 𝒟.t, Ideal.span ({(𝒟.q b : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L))) := by
            symm
            exact (map_prod (Ideal.mapHom (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))
              (fun b : Fin 𝒟.t => Ideal.span ({(𝒟.q b : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L)))
              Finset.univ)
      _ = Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
            (Ideal.span ({(∏ b : Fin 𝒟.t, (𝒟.q b : 𝓞 𝒟.L))} : Set (𝓞 𝒟.L))) := by
            congr 1
            simpa using
              (Ideal.prod_span_singleton (s := Finset.univ) (I := fun b : Fin 𝒟.t => (𝒟.q b : 𝓞 𝒟.L)))
      _ = Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
            (Ideal.span ({(𝒟.Q : 𝓞 𝒟.L)} : Set (𝓞 𝒟.L))) := by
            simp [AdmissibleDatum.Q]
      _ = proposition_2_2_qIdeal 𝒟 := by
            rw [Ideal.map_span]
            simp [proposition_2_2_qIdeal]

open scoped BigOperators in
theorem proposition_2_2_ideal_family_exists (𝒟 : AdmissibleDatum) :
    ∃ I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K),
      (∀ ε, I ε ≠ ⊥) ∧
      (∀ ε, I ε * proposition_2_2_conjIdeal 𝒟 (I ε) = proposition_2_2_qIdeal 𝒟) ∧
      (∀ {ε η : proposition_2_2_choice_type 𝒟},
        I ε * proposition_2_2_conjIdeal 𝒟 (I η) =
          I η * proposition_2_2_conjIdeal 𝒟 (I ε) → ε = η) := by
  classical
  let e := NumberField.RingOfIntegers.mapAlgEquiv (𝒟.c : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
  have hconj_conj : ∀ I : Ideal (𝓞 𝒟.K), proposition_2_2_conjIdeal 𝒟 (proposition_2_2_conjIdeal 𝒟 I) = I := by
    intro I
    unfold proposition_2_2_conjIdeal
    change Ideal.map (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) (Ideal.map (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) I) = I
    rw [show Ideal.map (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) (Ideal.map (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) I)
          = Ideal.map ((e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)).comp (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K))) I by
          simpa using (Ideal.map_map (I := I) (f := (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K))) (g := (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K))))]
    have hcomp : (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)).comp (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) = RingHom.id _ := by
      ext x
      change (𝒟.c (𝒟.c (x : 𝒟.K))) = (x : 𝒟.K)
      simpa using 𝒟.c_sq_eq_id (x : 𝒟.K)
    simp [hcomp]
  obtain ⟨P, hPnz, hPprime, hPneq, hPneqConj, hPprod⟩ := proposition_2_2_prime_family 𝒟
  let C : (Fin 𝒟.t × Fin 𝒟.f) → Ideal (𝓞 𝒟.K) := fun j => proposition_2_2_conjIdeal 𝒟 (P j)
  have hCnz : ∀ j, C j ≠ ⊥ := by
    intro j h
    exact hPnz j ((Ideal.map_eq_bot_iff_of_injective (show Function.Injective (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K)) from e.injective)).1 (by simpa [C, proposition_2_2_conjIdeal] using h))
  have hCprime : ∀ j, (C j).IsPrime := by
    intro j
    dsimp [C, proposition_2_2_conjIdeal]
    let _ : (P j).IsPrime := hPprime j
    simpa using Ideal.map_isPrime_of_equiv e (I := P j)
  let F : proposition_2_2_choice_type 𝒟 → (Fin 𝒟.t × Fin 𝒟.f) → Ideal (𝓞 𝒟.K) :=
    fun ε j => if ε j then P j else C j
  let G : proposition_2_2_choice_type 𝒟 → (Fin 𝒟.t × Fin 𝒟.f) → Ideal (𝓞 𝒟.K) :=
    fun ε j => if ε j then C j else P j
  let I : proposition_2_2_choice_type 𝒟 → Ideal (𝓞 𝒟.K) :=
    fun ε => ∏ j : Fin 𝒟.t × Fin 𝒟.f, F ε j
  have hconj_prod' (ε : proposition_2_2_choice_type 𝒟) (s : Finset (Fin 𝒟.t × Fin 𝒟.f)) :
      proposition_2_2_conjIdeal 𝒟 (∏ j ∈ s, F ε j) = ∏ j ∈ s, G ε j := by
    induction s using Finset.induction_on with
    | empty =>
        simpa [proposition_2_2_conjIdeal] using (Ideal.map_top (f := (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K))))
    | @insert a s ha hs =>
        rw [Finset.prod_insert ha, Finset.prod_insert ha]
        rw [show proposition_2_2_conjIdeal 𝒟 (F ε a * ∏ j ∈ s, F ε j) = proposition_2_2_conjIdeal 𝒟 (F ε a) * proposition_2_2_conjIdeal 𝒟 (∏ j ∈ s, F ε j) by
          simpa [proposition_2_2_conjIdeal] using (Ideal.map_mul (f := (e : (𝓞 𝒟.K) →+* (𝓞 𝒟.K))) (F ε a) (∏ j ∈ s, F ε j))]
        rw [hs]
        by_cases hεa : ε a
        · simp [F, G, C, hεa]
        · simp [F, G, C, hεa, hconj_conj]
  have hconjI (ε : proposition_2_2_choice_type 𝒟) : proposition_2_2_conjIdeal 𝒟 (I ε) = ∏ j : Fin 𝒟.t × Fin 𝒟.f, G ε j := by
    simpa [I] using hconj_prod' ε Finset.univ
  have hPmax : ∀ j, (P j).IsMaximal := by
    intro j
    exact Ideal.IsPrime.isMaximal (hPprime j) (hPnz j)
  have hCmax : ∀ j, (C j).IsMaximal := by
    intro j
    exact Ideal.IsPrime.isMaximal (hCprime j) (hCnz j)
  have hnot_le_Pj (j : Fin 𝒟.t × Fin 𝒟.f) {J : Ideal (𝓞 𝒟.K)} (hJmax : J.IsMaximal) (hne : J ≠ P j) :
      ¬ J ≤ P j := by
    intro hle
    have hsup : J ⊔ P j = ⊤ := Ideal.IsMaximal.coprime_of_ne hJmax (hPmax j) hne
    have hsup' : J ⊔ P j = P j := sup_eq_right.mpr hle
    exact (Ideal.IsMaximal.ne_top (hPmax j)) (hsup'.symm.trans hsup)
  have hprod_not_le (j : Fin 𝒟.t × Fin 𝒟.f) (H : (Fin 𝒟.t × Fin 𝒟.f) → Ideal (𝓞 𝒟.K))
      (hHprime : ∀ k, (H k).IsPrime) (hHnz : ∀ k, H k ≠ ⊥) (hHne : ∀ k, H k ≠ P j) :
      ¬ (∏ k : Fin 𝒟.t × Fin 𝒟.f, H k) ≤ P j := by
    intro hle
    rw [show (∏ k : Fin 𝒟.t × Fin 𝒟.f, H k) = ∏ k ∈ Finset.univ, H k by rfl] at hle
    rw [Ideal.IsPrime.prod_le (hp := hPprime j)] at hle
    rcases hle with ⟨k, hk, hkle⟩
    exact hnot_le_Pj j (Ideal.IsPrime.isMaximal (hHprime k) (hHnz k)) (hHne k) hkle
  have hneq_true_false (ε η : proposition_2_2_choice_type 𝒟) (j : Fin 𝒟.t × Fin 𝒟.f)
      (hε : ε j = true) (hη : ¬ η j = true) :
      I ε * proposition_2_2_conjIdeal 𝒟 (I η) ≠ I η * proposition_2_2_conjIdeal 𝒟 (I ε) := by
    intro hEq
    have hIε_le : I ε ≤ P j := by
      dsimp [I]
      rw [show (∏ k : Fin 𝒟.t × Fin 𝒟.f, F ε k) = ∏ k ∈ Finset.univ, F ε k by rfl]
      rw [Ideal.IsPrime.prod_le (hp := hPprime j)]
      refine ⟨j, by simp, by simp [F, hε]⟩
    have hleft_le : I ε * proposition_2_2_conjIdeal 𝒟 (I η) ≤ P j := le_trans Ideal.mul_le_right hIε_le
    have hright_le : I η * proposition_2_2_conjIdeal 𝒟 (I ε) ≤ P j := by simpa [hEq] using hleft_le
    rw [hconjI ε] at hright_le
    dsimp [I] at hright_le
    rw [Ideal.IsPrime.mul_le (hp := hPprime j)] at hright_le
    rcases hright_le with hηle | hεle
    · have hFηprime : ∀ k, (F η k).IsPrime := by
        intro k
        by_cases hk : η k
        · simp [F, hk, hPprime k]
        · simp [F, hk, hCprime k]
      have hFηnz : ∀ k, F η k ≠ ⊥ := by
        intro k
        by_cases hk : η k
        · simp [F, hk, hPnz k]
        · simp [F, hk, hCnz k]
      have hFηne : ∀ k, F η k ≠ P j := by
        intro k
        by_cases hk : η k
        · by_cases hkj : k = j
          · subst hkj
            simp [hη] at hk
          · simpa [F, hk] using hPneq (j := k) (k := j) hkj
        · simpa [F, hk, C] using (hPneqConj j k).symm
      exact (hprod_not_le j (F η) hFηprime hFηnz hFηne) hηle
    · have hGεprime : ∀ k, (G ε k).IsPrime := by
        intro k
        by_cases hk : ε k
        · simp [G, hk, hCprime k]
        · simp [G, hk, hPprime k]
      have hGεnz : ∀ k, G ε k ≠ ⊥ := by
        intro k
        by_cases hk : ε k
        · simp [G, hk, hCnz k]
        · simp [G, hk, hPnz k]
      have hGεne : ∀ k, G ε k ≠ P j := by
        intro k
        by_cases hk : ε k
        · simpa [G, hk, C] using (hPneqConj j k).symm
        · by_cases hkj : k = j
          · subst hkj
            simp [hε] at hk
          · simpa [G, hk] using hPneq (j := k) (k := j) hkj
      exact (hprod_not_le j (G ε) hGεprime hGεnz hGεne) hεle
  refine ⟨I, ?_, ?_, ?_⟩
  · intro ε
    dsimp [I]
    simpa using (Finset.prod_ne_zero_iff (s := Finset.univ) (f := F ε)).2 (by
      intro j hj
      by_cases hε : ε j
      · simp [F, hε, hPnz j]
      · simp [F, hε, hCnz j])
  · intro ε
    rw [hconjI ε]
    dsimp [I]
    rw [← Finset.prod_mul_distrib]
    refine Eq.trans ?_ hPprod
    refine Finset.prod_congr rfl ?_
    intro j hj
    by_cases hε : ε j
    · simp [F, G, C, hε]
    · simp [F, G, C, hε, hconj_conj, mul_comm]
  · intro ε η hEq
    ext j
    by_cases hε : ε j <;> by_cases hη : η j <;> simp [hε, hη]
    · exact False.elim (hneq_true_false ε η j hε hη hEq)
    · exact False.elim (hneq_true_false η ε j hη hε hEq.symm)

theorem proposition_2_2 (𝒟 : AdmissibleDatum) (H : ℝ) (hH : 0 < H)
    (hClass : (NumberField.classNumber 𝒟.K : ℝ) ≤ H ^ 𝒟.f) :
    ∃ U : Finset 𝒟.K,
      (U.card : ℝ) ≥ Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f) ∧
      (∀ u ∈ U, 𝒟.IsNormOneIntegral u) := by
  rcases proposition_2_2_ideal_family_exists 𝒟 with ⟨I, hI_nonzero, hI_mul_conj, hI_cross⟩
  rcases proposition_2_2_large_class_fiber 𝒟 H hH hClass I hI_nonzero with ⟨C, ε₀, hε₀, hfiber⟩
  rcases proposition_2_2_class_fiber_to_finset 𝒟 I hI_nonzero hI_mul_conj (fun {ε η} h => hI_cross h) C ε₀ hε₀ with ⟨U, hUcard, hUnorm⟩
  refine ⟨U, ?_, hUnorm⟩
  rw [hUcard]
  exact hfiber

theorem lemma_2_4_E_count_eq_zero_of_N_count_eq_zero (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) (U : Finset 𝒟.K) : 𝒟.N_count a R = 0 → 𝒟.E_count a R U = 0 := by
  intro hN
  unfold AdmissibleDatum.N_count at hN
  rw [Finset.card_eq_zero] at hN
  unfold AdmissibleDatum.E_count
  simp [hN]

theorem lemma_2_4_E_count_term_le_N_count (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) (u : 𝒟.K) : ((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card ≤ 𝒟.N_count a R := by
  simpa [AdmissibleDatum.N_count] using
    (Finset.card_filter_le (s := 𝒟.X_finset a R)
      (p := fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R))

noncomputable def lemma_2_4_FD (𝒟 : AdmissibleDatum) : Set 𝒟.V :=
  ZSpan.fundamentalDomain ((Module.Free.chooseBasis ℤ 𝒟.Λ).ofZLatticeBasis ℝ)

theorem lemma_2_4_N_count_eq_lattice_encard (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) : ({l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R}.encard) = 𝒟.N_count a R := by
  classical
  let S : Set 𝒟.Λ := {l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R}
  let f : 𝒟.Λ → 𝒟.V := fun l => a + (l : 𝒟.V)
  have hbij : Set.BijOn f S (𝒟.X a R) := by
    refine ⟨?_, ?_, ?_⟩
    · intro l hl
      exact ⟨⟨l, rfl⟩, hl⟩
    · intro l₁ hl₁ l₂ hl₂ h
      exact Subtype.ext (add_left_cancel h)
    · intro z hz
      rcases hz.1 with ⟨l, rfl⟩
      exact ⟨l, hz.2, rfl⟩
  have hSX : S.encard = (𝒟.X a R).encard := by
    refine Set.encard_congr ?_
    exact Equiv.ofBijective (hbij.mapsTo.restrict f S (𝒟.X a R)) hbij.bijective
  calc
    ({l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R}.encard) = S.encard := by rfl
    _ = (𝒟.X a R).encard := hSX
    _ = 𝒟.N_count a R := by
      simpa [AdmissibleDatum.X_finset, AdmissibleDatum.N_count] using
        (X_finite 𝒟 a R).encard_eq_coe_toFinset_card

theorem lemma_2_4_ball_overlap_volume (R : ℝ) (z : ℂ) (hz : ‖z‖ = 1) :
    MeasureTheory.volume.real (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) = overlapArea R :=

  overlapArea_eq_volume R z hz

theorem lemma_2_4_closedBall_overlap_volume (R : ℝ) (z : ℂ) (hz : ‖z‖ = 1) : MeasureTheory.volume.real (Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R) = overlapArea R := by
  have hsub :
      Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R ⊆
        Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R := by
    intro w hw
    exact ⟨Metric.ball_subset_closedBall hw.1, Metric.ball_subset_closedBall hw.2⟩
  have hdiff_sub :
      (Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R) \
          (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) ⊆
        Metric.sphere (0 : ℂ) R ∪ Metric.sphere (-z) R := by
    intro w hw
    rcases hw with ⟨hwA, hwB⟩
    rcases hwA with ⟨hw0, hwz⟩
    by_cases h0 : w ∈ Metric.ball (0 : ℂ) R
    · have hz' : w ∉ Metric.ball (-z) R := by
        intro hzB
        exact hwB ⟨h0, hzB⟩
      right
      have hle : dist w (-z) ≤ R := by
        simpa [Metric.mem_closedBall] using hwz
      have hge : R ≤ dist w (-z) := by
        simpa [Metric.mem_ball, not_lt] using hz'
      have hEq : dist w (-z) = R := le_antisymm hle hge
      rw [Metric.mem_sphere]
      exact hEq
    · left
      have hle : dist w (0 : ℂ) ≤ R := by
        simpa [Metric.mem_closedBall] using hw0
      have hge : R ≤ dist w (0 : ℂ) := by
        simpa [Metric.mem_ball, not_lt] using h0
      have hEq : dist w (0 : ℂ) = R := le_antisymm hle hge
      rw [Metric.mem_sphere]
      exact hEq
  have hcircles :
      MeasureTheory.volume (Metric.sphere (0 : ℂ) R ∪ Metric.sphere (-z) R) = 0 := by
    exact MeasureTheory.measure_union_null
      (MeasureTheory.Measure.addHaar_sphere (μ := MeasureTheory.volume) (x := (0 : ℂ)) (r := R))
      (MeasureTheory.Measure.addHaar_sphere (μ := MeasureTheory.volume) (x := (-z)) (r := R))
  have hdiff :
      MeasureTheory.volume
          ((Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R) \
            (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R)) = 0 :=
    MeasureTheory.measure_mono_null hdiff_sub hcircles
  have hmeas :
      MeasureTheory.volume (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) =
        MeasureTheory.volume (Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R) :=
    MeasureTheory.measure_eq_measure_of_null_diff hsub hdiff
  have hreal :
      MeasureTheory.volume.real (Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-z) R) =
        MeasureTheory.volume.real (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) := by
    rw [MeasureTheory.measureReal_def, MeasureTheory.measureReal_def, hmeas]
  have hopen :
      MeasureTheory.volume.real (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R) = overlapArea R := by
    exact lemma_2_4_ball_overlap_volume R z hz
  exact hreal.trans hopen

noncomputable def lemma_2_4_gap (𝒟 : AdmissibleDatum) (H R : ℝ) (U : Finset 𝒟.K) (a : 𝒟.V) : ℝ :=
  (𝒟.E_count a R U : ℝ) -
    Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f / 2) * 𝒟.N_count a R

theorem lemma_2_4_isAddFundamentalDomain (𝒟 : AdmissibleDatum) : MeasureTheory.IsAddFundamentalDomain (↥𝒟.Λ) (lemma_2_4_FD 𝒟) MeasureTheory.volume := by
  simpa [lemma_2_4_FD] using
    (ZLattice.isAddFundamentalDomain (L := 𝒟.Λ)
      (b := Module.Free.chooseBasis ℤ 𝒟.Λ) MeasureTheory.volume)

theorem lemma_2_4_exists_gap_positive (𝒟 : AdmissibleDatum) (H R : ℝ) (U : Finset 𝒟.K) (havg : 0 < ⨍ a in lemma_2_4_FD 𝒟, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume) : ∃ a ∈ lemma_2_4_FD 𝒟, 0 < lemma_2_4_gap 𝒟 H R U a := by
  classical
  let F := lemma_2_4_FD 𝒟
  by_contra h
  push Not at h
  have hF_meas : MeasurableSet F := by
    simpa [F, lemma_2_4_FD] using
      (ZSpan.fundamentalDomain_measurableSet
        (b := (Module.Free.chooseBasis ℤ 𝒟.Λ).ofZLatticeBasis ℝ))
  have hμreal_eq : ZLattice.covolume 𝒟.Λ MeasureTheory.volume = MeasureTheory.volume.real F := by
    simpa [F] using
      (ZLattice.covolume_eq_measure_fundamentalDomain (L := 𝒟.Λ)
        (μ := MeasureTheory.volume) (F := F) (lemma_2_4_isAddFundamentalDomain 𝒟))
  have hμreal_pos : 0 < MeasureTheory.volume.real F := by
    have hcovol : 0 < ZLattice.covolume 𝒟.Λ MeasureTheory.volume :=
      ZLattice.covolume_pos (L := 𝒟.Λ) (μ := MeasureTheory.volume)
    rwa [hμreal_eq] at hcovol
  have hInt_nonpos :
      ∫ a in F, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume ≤ 0 := by
    exact MeasureTheory.setIntegral_nonpos hF_meas h
  have hAvg_nonpos :
      (⨍ a in F, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume) ≤ 0 := by
    rw [MeasureTheory.setAverage_eq (μ := MeasureTheory.volume)]
    have hinv_nonneg : 0 ≤ (MeasureTheory.volume.real F)⁻¹ := by
      positivity
    have hmul :
        (MeasureTheory.volume.real F)⁻¹ *
            (∫ a in F, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume) ≤ 0 :=
      mul_nonpos_of_nonneg_of_nonpos hinv_nonneg hInt_nonpos
    simpa [smul_eq_mul] using hmul
  linarith

theorem lemma_2_4_measurableConstVAdd (𝒟 : AdmissibleDatum) : MeasurableConstVAdd (↥𝒟.Λ) 𝒟.V := by
  refine ⟨?_⟩
  intro l
  change Measurable ((l : 𝒟.V) + · : 𝒟.V → 𝒟.V)
  simpa [vadd_eq_add] using (measurable_const_add (c := (l : 𝒟.V)))

theorem lemma_2_4_shift_count_eq_lattice_encard (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) (u : 𝒟.K) (hΛu : 𝒟.Φ u ∈ (𝒟.Λ : Set 𝒟.V)) : ({l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R ∧ a + (l : 𝒟.V) + 𝒟.Φ u ∈ 𝒟.closedPolydisc R}.encard) = ((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card := by
  classical
  let lu : 𝒟.Λ := ⟨𝒟.Φ u, hΛu⟩
  let S : Set 𝒟.Λ :=
    {l | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R ∧
        a + (l : 𝒟.V) + 𝒟.Φ u ∈ 𝒟.closedPolydisc R}
  let T : Set 𝒟.V :=
    {x | x ∈ 𝒟.X a R ∧ x + 𝒟.Φ u ∈ 𝒟.X a R}
  let F : Finset 𝒟.V :=
    (𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)
  let f : 𝒟.Λ → 𝒟.V := fun l => a + (l : 𝒟.V)
  have hbij : Set.BijOn f S T := by
    refine ⟨?_, ?_, ?_⟩
    · intro l hl
      refine ⟨?_, ?_⟩
      · exact ⟨⟨l, rfl⟩, hl.1⟩
      · refine ⟨?_, hl.2⟩
        refine ⟨l + lu, ?_⟩
        simp [f, lu, add_assoc]
    · intro l₁ hl₁ l₂ hl₂ hEq
      apply Subtype.ext
      exact add_left_cancel hEq
    · intro x hx
      rcases hx.1 with ⟨⟨l, rfl⟩, hlB⟩
      refine ⟨l, ?_, rfl⟩
      exact ⟨hlB, hx.2.2⟩
  have hencard : S.encard = T.encard := by
    exact Set.encard_congr (Set.BijOn.equiv f hbij)
  have hT : T = (F : Set 𝒟.V) := by
    ext x
    simp [T, F, AdmissibleDatum.X_finset]
  calc
    ({l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R ∧ a + (l : 𝒟.V) + 𝒟.Φ u ∈ 𝒟.closedPolydisc R}.encard)
        = S.encard := by rfl
    _ = T.encard := hencard
    _ = (F : Set 𝒟.V).encard := by rw [hT]
    _ = F.card := Set.encard_coe_eq_coe_finsetCard F
    _ = ((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card := by rfl

theorem lemma_2_4_vaddInvariantVolume (𝒟 : AdmissibleDatum) : MeasureTheory.VAddInvariantMeasure (↥𝒟.Λ) 𝒟.V MeasureTheory.volume := by
  refine ⟨?_⟩
  intro c s hs
  change MeasureTheory.volume (((fun x : 𝒟.V => (c : 𝒟.V) + x) ⁻¹' s) ) = MeasureTheory.volume s
  simp [vadd_eq_add]


          exact dvd_mul_of_dvd_left (dvd_refl _) _
        have hLdvdn : Ideal.absNorm L вҲЈ n := by
          apply hLcop.dvd_of_dvd_mul_left
          rw [вҶҗ hnorm_mul]
          exact dvd_mul_of_dvd_right (dvd_refl _) _
        have hJle : Ideal.absNorm J вүӨ m := Nat.le_of_dvd (Nat.pos_of_ne_zero hm0) hJdvdm
        have hLle : Ideal.absNorm L вүӨ n := Nat.le_of_dvd (Nat.pos_of_ne_zero hn0) hLdvdn
        have hJL : Ideal.absNorm J = m вҲ§ Ideal.absNorm L = n :=
          (mul_eq_mul_iff_eq_and_eq_of_pos' hJle hLle (Nat.pos_of_ne_zero hm0) (Nat.pos_of_ne_zero hL0)).mp hnorm_mul
        exact вҹЁвҹЁJ, hJL.1вҹ©, вҹЁL, hJL.2вҹ©вҹ©
      let G : ({J : Ideal (рқ“һ K) // Ideal.absNorm J = m} Г— {L : Ideal (рқ“һ K) // Ideal.absNorm L = n}) вҶ’
          {I : Ideal (рқ“һ K) // Ideal.absNorm I = m * n} := fun JL => by
        exact вҹЁJL.1.1 * JL.2.1, by rw [map_mul, JL.1.2, JL.2.2]вҹ©
      have hFG : Function.LeftInverse G F := by
        intro I
        let I0 : Ideal (рқ“һ K) := I.1
        let J : Ideal (рқ“һ K) := I0 вҠ” M
        let L : Ideal (рқ“һ K) := I0 вҠ” N
        have hMNtop : M вҠ” N = вҠӨ := hMNcop.sup_eq
        have hsup : J вҠ” L = вҠӨ := by
          calc
            J вҠ” L = I0 вҠ” (M вҠ” N) := by
              simp [J, L, sup_assoc, sup_left_comm, sup_comm]
            _ = вҠӨ := by simp [hMNtop]
        have hmnem : ((m * n : в„•) : рқ“һ K) вҲҲ I0 := by
          have hmem : вҶ‘(Ideal.absNorm I0) вҲҲ I0 := Ideal.absNorm_mem I0
          rw [I.2] at hmem
          simpa [Nat.cast_mul] using hmem
        have hmulle : M * N вүӨ I0 := by
          rw [Ideal.span_singleton_mul_span_singleton]
          exact (Ideal.span_singleton_le_iff_mem I0).2 (by simpa [Nat.cast_mul] using hmnem)
        have hmul_le : J * L вүӨ I0 := by
          change (I0 вҠ” M) * (I0 вҠ” N) вүӨ I0
          rw [Ideal.mul_sup, Ideal.sup_mul, Ideal.sup_mul]
          refine sup_le ?_ ?_
          В· refine sup_le ?_ ?_
            В· exact Ideal.mul_le_left
            В· exact Ideal.mul_le_left
          В· refine sup_le ?_ ?_
            В· exact Ideal.mul_le_right
            В· exact hmulle
        have hIle : I0 вүӨ J * L := by
          calc
            I0 = I0 * вҠӨ := by rw [Ideal.mul_top]
            _ = I0 * (J вҠ” L) := by rw [hsup]
            _ = I0 * J вҠ” I0 * L := by rw [Ideal.mul_sup]
            _ вүӨ J * L := by
              refine sup_le ?_ ?_
              В· have h1 : I0 * J вүӨ L * J := Ideal.mul_mono_left (K := J) (show I0 вүӨ L by exact le_sup_left)
                simpa [Ideal.mul_comm] using h1
              В· have h2 : I0 * L вүӨ J * L := Ideal.mul_mono_left (K := L) (show I0 вүӨ J by exact le_sup_left)
                simpa using h2
        have hmul : J * L = I0 := le_antisymm hmul_le hIle
        apply Subtype.ext
        simpa [F, G, I0, J, L]
      have hGF : Function.RightInverse G F := by
        intro JL
        rcases JL with вҹЁвҹЁJ0, hJ0nвҹ©, вҹЁL0, hL0nвҹ©вҹ©
        have hm_mem_J0 : (m : рқ“һ K) вҲҲ J0 := by
          have hmem : вҶ‘(Ideal.absNorm J0) вҲҲ J0 := Ideal.absNorm_mem J0
          rw [hJ0n] at hmem
          simpa using hmem
        have hn_mem_L0 : (n : рқ“һ K) вҲҲ L0 := by
          have hmem : вҶ‘(Ideal.absNorm L0) вҲҲ L0 := Ideal.absNorm_mem L0
          rw [hL0n] at hmem
          simpa using hmem
        have hsupnorm : Ideal.absNorm (J0 вҠ” L0) = 1 := by
          have hdivm : Ideal.absNorm (J0 вҠ” L0) вҲЈ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 вүӨ J0 вҠ” L0 by exact le_sup_left)
          have hdivn : Ideal.absNorm (J0 вҠ” L0) вҲЈ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 вүӨ J0 вҠ” L0 by exact le_sup_right)
          have hdiv1 : Ideal.absNorm (J0 вҠ” L0) вҲЈ 1 := by
            rw [вҶҗ hcop.gcd_eq_one]
            exact Nat.dvd_gcd hdivm hdivn

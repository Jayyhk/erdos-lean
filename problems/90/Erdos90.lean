theorem intPolynomial_exists_prime_dvd_eval_outside (f : Polynomial в„Ө) (hf : f.natDegree вү  0) (badPrimes : Finset в„•) :
    вҲғ q : в„•, q.Prime вҲ§ q вҲү badPrimes вҲ§ вҲғ n : в„Ө, (q : в„Ө) вҲЈ Polynomial.eval n f := by
  classical
  have hspecial : вҲҖ {f : Polynomial в„Ө}, f.natDegree вү  0 вҶ’ f.eval 0 вү  0 вҶ’
      вҲҖ badPrimes : Finset в„•,
        вҲғ q : в„•, q.Prime вҲ§ q вҲү badPrimes вҲ§ вҲғ n : в„Ө, (q : в„Ө) вҲЈ Polynomial.eval n f := by
    intro g hg h0 badPrimes
    let a : в„Ө := Polynomial.eval 0 g
    let M : в„Ө := вҲҸ p вҲҲ badPrimes.filter Nat.Prime, (p : в„Ө)
    have ha : a вү  0 := h0
    have hM : M вү  0 := by
      classical
      dsimp [M]
      refine Finset.prod_ne_zero_iff.mpr ?_
      intro p hp
      exact_mod_cast (Finset.mem_filter.mp hp).2.ne_zero
    have hdivX_ne : g.divX вү  0 := by
      intro hzero
      apply hg

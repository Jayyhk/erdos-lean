  calc
    (p.primesOver (𝓞 𝒟.K)).ncard = ((primesOverFinset p (𝓞 𝒟.K) : Finset (Ideal (𝓞 𝒟.K))) : Set (Ideal (𝓞 𝒟.K))).ncard := by
      rw [← coe_primesOverFinset (p := p) hp0 (B := 𝓞 𝒟.K)]
    _ = (primesOverFinset p (𝓞 𝒟.K)).card := Set.ncard_coe_finset _
    _ = Module.finrank ℚ 𝒟.K := hcard_finset

theorem rootDiscr_eq_of_everywhereUnramified (F L : Type) [Field F] [Field L] [NumberField F] [NumberField L]
    [Algebra F L] (_hunr : IsEverywhereUnramified F L) :
    NumberField.rootDiscr L = NumberField.rootDiscr F := by
  have hdisc_nat := IsEverywhereUnramified.discr_eq _hunr
  have hdisc : ((|NumberField.discr L| : ℤ) : ℝ) = (((|NumberField.discr F| : ℤ) : ℝ) ^ Module.finrank F L) := by
    calc
      ((|NumberField.discr L| : ℤ) : ℝ) = ((NumberField.discr L).natAbs : ℝ) := by
        rw [Nat.cast_natAbs]
      _ = (((NumberField.discr F).natAbs : ℝ) ^ Module.finrank F L) := by
        exact_mod_cast hdisc_nat
      _ = (((|NumberField.discr F| : ℤ) : ℝ) ^ Module.finrank F L) := by
        rw [Nat.cast_natAbs]
  rw [NumberField.rootDiscr_def, NumberField.rootDiscr_def, hdisc]
  rw [← Real.rpow_natCast_mul (by positivity : 0 ≤ ((|NumberField.discr F| : ℤ) : ℝ))]
  congr 1
  have hmul : (Module.finrank ℚ F : ℝ) * Module.finrank F L = Module.finrank ℚ L := by
    exact_mod_cast Module.finrank_mul_finrank ℚ F L
  have hF : (Module.finrank ℚ F : ℝ) ≠ 0 := by
    exact Nat.cast_ne_zero.mpr (ne_of_gt (Module.finrank_pos : 0 < Module.finrank ℚ F))
  have hFL : (Module.finrank F L : ℝ) ≠ 0 := by
    exact Nat.cast_ne_zero.mpr (ne_of_gt (Module.finrank_pos : 0 < Module.finrank F L))
  calc
    (Module.finrank F L : ℝ) * (Module.finrank ℚ L : ℝ)⁻¹ = (Module.finrank F L : ℝ) / Module.finrank ℚ L := by
      rw [div_eq_mul_inv]
    _ = (Module.finrank F L : ℝ) / ((Module.finrank ℚ F : ℝ) * Module.finrank F L) := by
      rw [← hmul]
    _ = (Module.finrank ℚ F : ℝ)⁻¹ := by
      field_simp [hF, hFL]

theorem totallyReal_of_odd_p_unramified (F L : Type) [Field F] [Field L] [NumberField F] [NumberField L]
    [IsTotallyReal F] [Algebra F L] [IsGalois F L]
    (p : ℕ) (_hp : p.Prime) (_hp_odd : p ≠ 2)
    (_hunr : IsEverywhereUnramified F L)
    (_hPGroup : IsPGroup p (L ≃ₐ[F] L)) :
    IsTotallyReal L := by
  refine ⟨?_⟩
  intro w
  let v : NumberField.InfinitePlace F := w.comap (algebraMap F L)
  have hv : v.IsReal := IsTotallyReal.isReal v
  exact IsEverywhereUnramified.real_lifts_real _hunr v hv w rfl


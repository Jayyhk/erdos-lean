      continuousOn_id.mul hGshift
    simpa [W, wiener_boundary_function] using hmul.add continuousOn_const
  have hWeq : Set.EqOn W
      (fun s : в„Ӯ => LSeries (fun n => (f n : в„Ӯ)) s - Complex.ofReal b / (s - 1))
      {s : в„Ӯ | 1 < s.re} := by
    exact wiener_boundary_function_eqOn hGint hGeq hnonneg hsumm
  have hcum : Filter.Tendsto (fun N : в„• => cumsum f N / (N : в„қ)) Filter.atTop (nhds b) := by
    exact wiener_ikehara hnonneg hf hWcont hWeq
  exact logRescalePartialSum_tendsto_of_tendsto_cumsum_div hcum

theorem liminf_logRescalePartialSum_pos_of_boundary_extension {f : в„• вҶ’ в„қ} {b : в„қ} :
    (hb : 0 < b) вҶ’
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hF : HasBoundaryLaplaceExtension f b) вҶ’
    вҲғ c : в„қ, 0 < c вҲ§ вҲғ xвӮҖ : в„қ, вҲҖ x : в„қ, xвӮҖ вүӨ x вҶ’ c вүӨ logRescalePartialSum f x := by
  intro hb hnonneg hF

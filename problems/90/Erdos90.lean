theorem towerEval_prefixProd_cons (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (x : HomogObjType p G (n + 1)) (a : G) (g : Fin n → G) : towerEval p G (n + 2) x.1 (prefixProdTuple G (n + 1) (Fin.cons a g)) = towerEval p G (n + 1) ((towerAsC p G (n + 1) x.1) a⁻¹) (prefixProdTuple G n g) := by

          · have hnot : ¬ X < ⌊c ^ (N' + n₀ + 1)⌋₊ := by
              exact hminN N' (Nat.lt_succ_self N')
            omega
          · simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hupperN
    rcases hchoose with ⟨n, hnge, hlower, hupper⟩
    have hpow_nonneg : 0 ≤ c ^ n := pow_nonneg (le_of_lt hc0) n

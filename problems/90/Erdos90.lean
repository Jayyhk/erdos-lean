open NumberField

theorem cubic_subfield_prime_ramification_data (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField ℚ (CyclotomicField r ℚ))
    [IsGalois ℚ L] [IsTotallyReal L]
    (hcubic : Module.finrank ℚ L = 3) :
    ∃ P : Ideal (𝓞 L),
      P ∈ (Ideal.span {(r : ℤ)} : Ideal ℤ).primesOver (𝓞 L) ∧
      ((Ideal.span {(r : ℤ)} : Ideal ℤ).primesOver (𝓞 L)).ncard = 1 ∧
      Ideal.ramificationIdx (Ideal.span {(r : ℤ)} : Ideal ℤ) P = 3 ∧
      Ideal.inertiaDeg (Ideal.span {(r : ℤ)} : Ideal ℤ) P = 1 ∧
      (∀ q : ℕ, q.Prime → q ≠ r →
        ∀ Q ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) Q = 1) := by
  letI : Fact r.Prime := ⟨hr⟩
  let p : Ideal ℤ := Ideal.span {(r : ℤ)}
  let E := CyclotomicField r ℚ
  letI : IsCyclotomicExtension {r} ℚ E :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := r) (K := ℚ)
  haveI : IsGalois ℚ E := IsCyclotomicExtension.isGalois {r} ℚ E
  have hp0 : p ≠ ⊥ := by
    simp [p, hr.ne_zero]
  have hEcard : (p.primesOver (𝓞 E)).ncard = 1 := by
    simpa [p, E] using (IsCyclotomicExtension.Rat.ncard_primesOver_of_prime (p := r)
      (K := E))
  have hEinertia : p.inertiaDegIn (𝓞 E) = 1 := by
    simpa [p, E] using (IsCyclotomicExtension.Rat.inertiaDegIn_eq_of_prime (p := r)
      (K := E))
  obtain ⟨⟨P, hPprime, hPover⟩⟩ := (show Nonempty (p.primesOver (𝓞 L)) from Ideal.nonempty_primesOver p)
  letI : P.IsMaximal := hPprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hp0 P)
  have hcount := Ideal.ncard_primesOver_mul_ncard_primesOver (P := P) (p := p) (G := Gal(L/ℚ))
    (C := 𝓞 E) (GAC := Gal(E/ℚ)) (GBC := Gal(E/L)) hp0
  have hLcard : (p.primesOver (𝓞 L)).ncard = 1 := by
    rw [hEcard] at hcount
    exact Nat.eq_one_of_mul_eq_one_right hcount
  have hcardL : Nat.card Gal(L/ℚ) = 3 := by
    rw [IsGalois.card_aut_eq_finrank (F := ℚ) (E := L), hcubic]
  have hfund := Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn (p := p)
    (B := 𝓞 L) hp0 Gal(L/ℚ)
  have hprod : p.ramificationIdxIn (𝓞 L) * p.inertiaDegIn (𝓞 L) = 3 := by
    rw [hLcard, one_mul, hcardL] at hfund
    exact hfund
  have hmulIn := Ideal.inertiaDegIn_mul_inertiaDegIn (p := p) (P := P) (G := Gal(L/ℚ))
    (C := 𝓞 E) (GAC := Gal(E/ℚ)) (GBC := Gal(E/L))
  have hInertiaL : p.inertiaDegIn (𝓞 L) = 1 := by
    rw [hEinertia] at hmulIn
    exact Nat.eq_one_of_mul_eq_one_right hmulIn
  have hRamL : p.ramificationIdxIn (𝓞 L) = 3 := by
    rw [hInertiaL, mul_one] at hprod
    exact hprod
  have hP_ram : Ideal.ramificationIdx p P = 3 := by
    rw [← Ideal.ramificationIdxIn_eq_ramificationIdx (p := p) (P := P) Gal(L/ℚ), hRamL]
  have hP_inertia : Ideal.inertiaDeg p P = 1 := by
    rw [← Ideal.inertiaDegIn_eq_inertiaDeg (p := p) (P := P) Gal(L/ℚ), hInertiaL]
  refine ⟨P, ?_, hLcard, hP_ram, hP_inertia, ?_⟩
  · exact ⟨hPprime, hPover⟩
  · intro q hq hqr Q hQ
    let pq : Ideal ℤ := Ideal.span {(q : ℤ)}
    have hpq0 : pq ≠ ⊥ := by
      simp [pq, hq.ne_zero]
    have hqnr : ¬ q ∣ r := by
      intro hdiv
      exact hqr ((Nat.prime_dvd_prime_iff_eq hq hr).mp hdiv)
    have hQprime : Q.IsPrime := hQ.1
    have hQover : Q.LiesOver pq := hQ.2
    letI : Q.IsPrime := hQprime
    letI : Q.IsMaximal := hQprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hpq0 Q)
    obtain ⟨⟨Q', hQ'prime, hQ'overQ⟩⟩ :=
      (show Nonempty (Q.primesOver (𝓞 E)) from Ideal.nonempty_primesOver Q)
    have hQ'overpq : Q'.LiesOver pq := Ideal.LiesOver.trans (𝔓 := Q') (P := Q) (p := pq)
    letI : Q'.IsPrime := hQ'prime
    letI : Q'.LiesOver pq := hQ'overpq
    have hQ'ram : Ideal.ramificationIdx pq Q' = 1 := by
      letI : Fact q.Prime := ⟨hq⟩
      simpa [pq, E] using
        (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_not_dvd (p := q) (m := r)
          (K := E) (P := Q') hqnr)
    have hmapQ : Ideal.map (algebraMap (𝓞 L) (𝓞 E)) Q ≠ ⊥ := by
      exact Ideal.map_ne_bot_of_ne_bot (Ideal.ne_bot_of_liesOver_of_ne_bot hpq0 Q)
    have hmappq : Ideal.map (algebraMap ℤ (𝓞 E)) pq ≠ ⊥ := by
      exact Ideal.map_ne_bot_of_ne_bot hpq0
    have hle : Ideal.map (algebraMap (𝓞 L) (𝓞 E)) Q ≤ Q' := by
      exact Q'.over_def Q ▸ Ideal.map_comap_le
    have htower := Ideal.ramificationIdx_algebra_tower (p := pq) (P := Q) (Q := Q') hmapQ hmappq hle
    rw [hQ'ram] at htower
    exact Nat.eq_one_of_mul_eq_one_right htower.symm

theorem cyclotomicField_prime_discr_natAbs (r : ℕ) (hr : r.Prime) (hodd : r ≠ 2) :
    (NumberField.discr (CyclotomicField r ℚ)).natAbs = r ^ (r - 2) := by
  classical
  letI : Fact r.Prime := ⟨hr⟩
  letI : NeZero (r : ℚ) := ⟨by
    exact_mod_cast hr.ne_zero⟩
  letI : IsCyclotomicExtension {r} ℚ (CyclotomicField r ℚ) :=
    CyclotomicField.isCyclotomicExtension (n := r) (K := ℚ)
  rw [IsCyclotomicExtension.Rat.discr_prime (p := r) (K := CyclotomicField r ℚ)]
  rw [Int.natAbs_mul, Int.natAbs_pow, Int.natAbs_neg, Int.natAbs_one, one_pow, one_mul]
  simp

theorem differentIdeal_cubic_subfield_eq_prime_sq (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField ℚ (CyclotomicField r ℚ))
    [IsGalois ℚ L] [IsTotallyReal L]
    (hcubic : Module.finrank ℚ L = 3) :
    ∃ P : Ideal (𝓞 L),
      P ∈ (Ideal.span {(r : ℤ)} : Ideal ℤ).primesOver (𝓞 L) ∧
      differentIdeal ℤ (𝓞 L) = P ^ 2 := by
  classical
  let p : Ideal ℤ := Ideal.span {(r : ℤ)}
  letI : Fact r.Prime := ⟨hr⟩
  letI : NeZero r := ⟨hr.ne_zero⟩
  letI : NeZero (r : ℚ) := ⟨by exact_mod_cast hr.ne_zero⟩
  letI : IsCyclotomicExtension {r} ℚ (CyclotomicField r ℚ) :=
    CyclotomicField.isCyclotomicExtension (n := r) (K := ℚ)
  have hr0 : (r : ℤ) ≠ 0 := by
    exact_mod_cast hr.ne_zero
  have hp0 : p ≠ ⊥ := by
    simpa [p, Ideal.span_singleton_eq_bot] using hr0
  letI : p.IsMaximal := by
    simpa [p] using (Int.ideal_span_isMaximal_of_prime r)
  rcases cubic_subfield_prime_ramification_data r hr hr3 L hcubic with
    ⟨P, hPover, hunique, hram, hinert, hunram⟩
  letI : P.LiesOver p := hPover.2
  have hPmax : P.IsMaximal := Ideal.isMaximal_of_mem_primesOver (p := p) hPover
  have hPprime : P.IsPrime := Ideal.IsMaximal.isPrime hPmax
  have hPne : P ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hp0 hPover
  letI : P.IsPrime := hPprime
  have hP2div : P ^ 2 ∣ differentIdeal ℤ (𝓞 L) := by
    have hP3 : P ^ 3 ∣ Ideal.map (algebraMap ℤ (𝓞 L)) p := by
      rw [Ideal.dvd_iff_le]
      simpa [p, hram] using
        (show Ideal.map (algebraMap ℤ (𝓞 L)) p ≤ P ^ (Ideal.ramificationIdx p P) from
          Ideal.le_pow_ramificationIdx)
    simpa [p] using (pow_sub_one_dvd_differentIdeal ℤ P 3 hp0 hP3)
  have hsetP : p.primesOver (𝓞 L) = {P} := by
    rcases Set.ncard_eq_one.mp hunique with ⟨P0, hP0⟩
    have hPP0 : P = P0 := by
      simpa [hP0] using hPover
    have hP0P : P0 = P := hPP0.symm
    simpa [hP0P] using hP0
  have hsetP' : (Ideal.span {(r : ℤ)} : Ideal ℤ).primesOver (𝓞 L) = {P} := by
    simpa [p] using hsetP
  have hDne : differentIdeal ℤ (𝓞 L) ≠ ⊥ := differentIdeal_ne_bot (A := ℤ) (B := 𝓞 L)
  have hfactor_eq_P : ∀ {M : Ideal (𝓞 L)}, M ∈ UniqueFactorizationMonoid.normalizedFactors (differentIdeal ℤ (𝓞 L)) → M = P := by
    intro M hM
    have hMprime : M.IsPrime := (Ideal.mem_normalizedFactors_iff (I := differentIdeal ℤ (𝓞 L)) hDne).mp hM |>.1
    have hDleM : differentIdeal ℤ (𝓞 L) ≤ M :=
      (Ideal.mem_normalizedFactors_iff (I := differentIdeal ℤ (𝓞 L)) hDne).mp hM |>.2
    letI : M.IsPrime := hMprime
    have hMne : M ≠ ⊥ := by
      intro hMb
      have hDbot : differentIdeal ℤ (𝓞 L) ≤ ⊥ := by
        simpa [hMb] using hDleM
      exact hDne (le_bot_iff.mp hDbot)
    letI : NeZero M := ⟨hMne⟩
    let q : ℕ := Ideal.absNorm (Ideal.under ℤ M)
    have hqprime : q.Prime := by
      simpa [q] using (Nat.absNorm_under_prime M)
    have hunder : Ideal.under ℤ M = Ideal.span {(q : ℤ)} := by
      simp [q]
    have hMliesq : M.LiesOver (Ideal.span {(q : ℤ)} : Ideal ℤ) := by
      simpa [hunder] using (Ideal.over_under (A := ℤ) (P := M))
    have hMmemq : M ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L) := ⟨hMprime, hMliesq⟩
    by_cases hqr : q = r
    · have hMmemr : M ∈ (Ideal.span {(r : ℤ)} : Ideal ℤ).primesOver (𝓞 L) := by
        simpa [hqr] using hMmemq
      rw [hsetP'] at hMmemr
      simpa using hMmemr
    · exfalso
      have hram1 : Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) M = 1 :=
        hunram q hqprime hqr M hMmemq
      have hram1' : Ideal.ramificationIdx (Ideal.under ℤ M) M = 1 := by
        simpa [hunder] using hram1
      have hMunram : Algebra.IsUnramifiedAt ℤ M := by
        exact (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := ℤ) (S := 𝓞 L) (p := M) hMne).2 hram1'
      have hMvd : M ∣ differentIdeal ℤ (𝓞 L) := by
        exact Ideal.dvd_iff_le.mpr hDleM
      exact ((dvd_differentIdeal_iff (A := ℤ) (B := 𝓞 L) (P := M)).1 hMvd) hMunram
  rcases UniqueFactorizationMonoid.exists_associated_prime_pow_of_unique_normalized_factor
      (p := P) (r := differentIdeal ℤ (𝓞 L))
      (h := by
        intro m hm
        exact hfactor_eq_P hm) hDne with ⟨n, hnassoc⟩
  have hDpow : differentIdeal ℤ (𝓞 L) = P ^ n := by
    simpa [eq_comm] using (associated_iff_eq.mp hnassoc)
  have htwo_le_n : 2 ≤ n := by
    rw [hDpow] at hP2div
    exact (pow_dvd_pow_iff hPne (by
      rw [Ideal.isUnit_iff]
      exact hPmax.ne_top)).mp hP2div
  have hPinert : Ideal.inertiaDeg p P = 1 := by
    simpa [p] using hinert
  have hAbsNormP0 := Ideal.absNorm_eq_pow_inertiaDeg' P hr
  have hAbsNormP : Ideal.absNorm P = r := by
    rw [hPinert, pow_one] at hAbsNormP0
    exact hAbsNormP0
  obtain ⟨⟨Q, hQprime, hQoverP⟩⟩ := Ideal.nonempty_primesOver (S := 𝓞 (CyclotomicField r ℚ)) P
  letI : Q.IsPrime := hQprime
  letI : Q.LiesOver P := hQoverP
  letI : Q.LiesOver p := Ideal.LiesOver.trans Q P p
  let m : ℕ := (r - 1) / 3
  have hQe_total : Ideal.ramificationIdx p Q = r - 1 := by
    simpa [p] using
      (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_prime (p := r) (K := CyclotomicField r ℚ)
        (P := Q))
  have hQf_total : Ideal.inertiaDeg p Q = 1 := by
    simpa [p] using
      (IsCyclotomicExtension.Rat.inertiaDeg_eq_of_prime (p := r) (K := CyclotomicField r ℚ)
        (P := Q))
  have hPmap_ne : Ideal.map (algebraMap (𝓞 L) (𝓞 (CyclotomicField r ℚ))) P ≠ ⊥ := by
    exact (Ideal.map_eq_bot_iff_of_injective
      (FaithfulSMul.algebraMap_injective (𝓞 L) (𝓞 (CyclotomicField r ℚ)))).not.mpr hPne
  have hpmapE_ne : Ideal.map (algebraMap ℤ (𝓞 (CyclotomicField r ℚ))) p ≠ ⊥ := by
    exact (Ideal.map_eq_bot_iff_of_injective
      (FaithfulSMul.algebraMap_injective ℤ (𝓞 (CyclotomicField r ℚ)))).not.mpr hp0
  have hmapPQ : Ideal.map (algebraMap (𝓞 L) (𝓞 (CyclotomicField r ℚ))) P ≤ Q := by
    exact Ideal.map_le_iff_le_comap.mpr Ideal.LiesOver.over.le
  have hQe_tower :=
    Ideal.ramificationIdx_algebra_tower (p := p) (P := P) (Q := Q) hPmap_ne hpmapE_ne hmapPQ
  have hQe_rel : Ideal.ramificationIdx P Q = m := by
    dsimp [m]
    rw [hQe_total, hram] at hQe_tower
    omega
  have hQf_tower := Ideal.inertiaDeg_algebra_tower p P Q
  have hQf_rel : Ideal.inertiaDeg P Q = 1 := by
    rw [hQf_total, hinert] at hQf_tower
    omega
  have hAbsNormQ0 := Ideal.absNorm_eq_pow_inertiaDeg_of_liesOver Q P hPprime hPne
  have hAbsNormQ : Ideal.absNorm Q = r := by
    rw [hAbsNormP, hQf_rel, pow_one] at hAbsNormQ0
    exact hAbsNormQ0
  let Drel : Ideal (𝓞 (CyclotomicField r ℚ)) := differentIdeal (𝓞 L) (𝓞 (CyclotomicField r ℚ))
  have hQpow : Q ^ m ∣ Ideal.map (algebraMap (𝓞 L) (𝓞 (CyclotomicField r ℚ))) P := by
    rw [Ideal.dvd_iff_le]
    simpa [hQe_rel] using
      (show Ideal.map (algebraMap (𝓞 L) (𝓞 (CyclotomicField r ℚ))) P ≤ Q ^ (Ideal.ramificationIdx P Q) from
        Ideal.le_pow_ramificationIdx)
  have hQdivDrel : Q ^ (m - 1) ∣ Drel := by
    simpa [Drel, m] using
      (pow_sub_one_dvd_differentIdeal (A := 𝓞 L) (B := 𝓞 (CyclotomicField r ℚ)) (p := P) Q
        m hPne hQpow)
  have hDrel_norm_dvd : r ^ (m - 1) ∣ Ideal.absNorm Drel := by
    have h := map_dvd Ideal.absNorm hQdivDrel
    simpa [Drel, hAbsNormQ] using h
  have hdiscrL_natAbs : (NumberField.discr L).natAbs = r ^ n := by
    rw [← NumberField.absNorm_differentIdeal (K := L) (𝒪 := 𝓞 L), hDpow]
    simp [hAbsNormP]
  have hirr : Irreducible (Polynomial.cyclotomic r ℚ) :=
    Polynomial.cyclotomic.irreducible_rat (Nat.pos_of_ne_zero hr.ne_zero)
  have hfinrankE : Module.finrank ℚ (CyclotomicField r ℚ) = r - 1 := by
    simpa [Nat.totient_prime hr] using
      (IsCyclotomicExtension.finrank (n := r) (K := ℚ) (L := CyclotomicField r ℚ) hirr)
  have hfinrankLE : Module.finrank L (CyclotomicField r ℚ) = m := by
    dsimp [m]
    have hmul := Module.finrank_mul_finrank (F := ℚ) (K := L) (A := CyclotomicField r ℚ)
    rw [hcubic, hfinrankE] at hmul
    omega
  have hodd : r ≠ 2 := by
    intro hr2
    rw [hr2] at hr3
    norm_num at hr3
  have hdiscE : (NumberField.discr (CyclotomicField r ℚ)).natAbs = r ^ (r - 2) :=
    cyclotomicField_prime_discr_natAbs r hr hodd
  have htower_rhs : Ideal.absNorm Drel * (r ^ n) ^ m = r ^ (r - 2) := by
    have htower0 :=
      NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        (K := L) (𝒪 := 𝓞 L) (CyclotomicField r ℚ) (𝓞 (CyclotomicField r ℚ))
    rw [hdiscE, hdiscrL_natAbs, hfinrankLE] at htower0
    simpa [Drel] using htower0.symm
  have hdiv_total : r ^ ((m - 1) + n * m) ∣ r ^ (r - 2) := by
    have hmuldiv : r ^ (m - 1) * (r ^ n) ^ m ∣ Ideal.absNorm Drel * (r ^ n) ^ m := by
      exact mul_dvd_mul hDrel_norm_dvd (dvd_rfl)
    rw [htower_rhs] at hmuldiv
    simpa [pow_mul, pow_add, mul_comm, mul_left_comm, mul_assoc] using hmuldiv
  have hr_nonunit : ¬ IsUnit r := by
    rw [Nat.isUnit_iff]
    exact hr.ne_one
  have hupper : (m - 1) + n * m ≤ r - 2 := by
    exact (pow_dvd_pow_iff hr.ne_zero hr_nonunit).mp hdiv_total
  have hr_div : r = 3 * m + 1 := by
    dsimp [m]
    omega
  have hm_ne_zero : m ≠ 0 := by
    intro hm0
    rw [hm0] at hr_div
    exact hr.ne_one hr_div
  have hm_pos : 0 < m := Nat.pos_of_ne_zero hm_ne_zero
  have hupper' : (m - 1) + n * m ≤ 3 * m - 1 := by
    rw [hr_div] at hupper
    simpa using hupper
  have hnm_le : n * m ≤ 2 * m := by
    omega
  have hn_le_two : n ≤ 2 := by
    exact le_of_mul_le_mul_right hnm_le hm_pos
  have hn_eq : n = 2 := le_antisymm hn_le_two htwo_le_n
  refine ⟨P, ?_, ?_⟩
  · exact hPover
  · simpa [hn_eq] using hDpow

theorem discr_cubic_subfield_of_prime_cyclotomic (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField ℚ (CyclotomicField r ℚ))
    [IsGalois ℚ L] [IsTotallyReal L]
    (hcubic : Module.finrank ℚ L = 3) :
    (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let p : Ideal ℤ := Ideal.span {(r : ℤ)}
  obtain ⟨P, hPmem, hcount, hram, hfin, h_unram⟩ :=
    cubic_subfield_prime_ramification_data r hr hr3 L hcubic
  obtain ⟨P', hP'mem, hdiff⟩ :=
    differentIdeal_cubic_subfield_eq_prime_sq r hr hr3 L hcubic
  have hcount' : (p.primesOver (𝓞 L)).ncard = 1 := by
    simpa [p] using hcount
  have hPmem' : P ∈ p.primesOver (𝓞 L) := by
    simpa [p] using hPmem
  have hP'mem' : P' ∈ p.primesOver (𝓞 L) := by
    simpa [p] using hP'mem
  obtain ⟨Q, hQsingle⟩ := Set.ncard_eq_one.mp hcount'
  have hP_eq_Q : P = Q := by
    rw [hQsingle] at hPmem'
    simpa using hPmem'
  have hP'_eq_Q : P' = Q := by
    rw [hQsingle] at hP'mem'
    simpa using hP'mem'
  have hP'eqP : P' = P := hP'_eq_Q.trans hP_eq_Q.symm
  set_option maxHeartbeats 800000 in
  have hnormP : Ideal.absNorm P = r := by
    let PP : p.primesOver (𝓞 L) := ⟨P, hPmem'⟩
    letI : P.LiesOver p := by
      simpa using (Ideal.primesOver.liesOver p PP)
    rw [Ideal.absNorm_eq_pow_inertiaDeg' P hr, hfin, pow_one]
  calc
    (NumberField.discr L).natAbs = Ideal.absNorm (differentIdeal ℤ (𝓞 L)) := by
      rw [← NumberField.absNorm_differentIdeal (K := L) (𝒪 := 𝓞 L)]
    _ = Ideal.absNorm (P' ^ 2) := by rw [hdiff]
    _ = Ideal.absNorm P' ^ 2 := map_pow Ideal.absNorm P' 2
    _ = Ideal.absNorm P ^ 2 := by rw [hP'eqP]
    _ = r ^ 2 := by rw [hnormP]

theorem cyclic_cubic_subfield_exists (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1) :
    ∃ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois ℚ L)
      (_ : Algebra L (CyclotomicField r ℚ)),
      Module.finrank ℚ L = 3 ∧
      (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let E := CyclotomicField r ℚ
  letI : Fact r.Prime := ⟨hr⟩
  have hne : r ≠ 0 := hr.ne_zero
  letI : NeZero (r : ℚ) := ⟨Nat.cast_ne_zero.mpr hne⟩
  letI : IsCyclotomicExtension ({r} : Set ℕ) ℚ E := CyclotomicField.isCyclotomicExtension (n := r) (K := ℚ)
  letI : IsAbelianGalois ℚ E := IsCyclotomicExtension.isAbelianGalois (S := ({r} : Set ℕ)) (K := ℚ) (L := E)
  letI : IsGalois ℚ E := IsCyclotomicExtension.isGalois (S := ({r} : Set ℕ)) (K := ℚ) (L := E)
  have hirr : Irreducible (Polynomial.cyclotomic r ℚ) :=
    Polynomial.cyclotomic.irreducible_rat hr.pos
  let e : (E ≃ₐ[ℚ] E) ≃* (ZMod r)ˣ := by
    simpa [E] using (galCyclotomicEquivUnitsZMod (n := r) (K := ℚ) (L := E) hirr)
  let H' : Subgroup ((ZMod r)ˣ) := (powMonoidHom 3).range
  let H : Subgroup (E ≃ₐ[ℚ] E) := H'.map e.symm.toMonoidHom
  let L : IntermediateField ℚ E := IntermediateField.fixedField H
  have hindexH' : H'.index = 3 := by
    have hidx : H'.index = Nat.gcd (Nat.card ((ZMod r)ˣ)) 3 := by
      simpa [H'] using (IsCyclic.index_powMonoidHom_range (G := (ZMod r)ˣ) 3)
    have hcard : Nat.card ((ZMod r)ˣ) = r - 1 := by
      rw [Nat.card_eq_fintype_card, ZMod.card_units r]
    have h3dvd : 3 ∣ r - 1 := by
      omega
    have hgcd : Nat.gcd (Nat.card ((ZMod r)ˣ)) 3 = 3 := by
      rw [hcard, Nat.gcd_eq_right_iff_dvd]
      exact h3dvd
    rw [hidx, hgcd]
  have hindexH : H.index = 3 := by
    have hm : (H'.map e.symm.toMonoidHom).index = H'.index := by
      simp
    rw [show H = H'.map e.symm.toMonoidHom by rfl, hm, hindexH']
  have hfix : L.fixingSubgroup = H := by
    simpa [L] using (IntermediateField.fixingSubgroup_fixedField (F := ℚ) (E := E) H)
  have hfinrankL : Module.finrank ℚ L = 3 := by
    rw [IntermediateField.finrank_eq_fixingSubgroup_index (k := ℚ) (K := E) L, hfix, hindexH]
  have hgalL : IsGalois ℚ L := by
    letI : H.Normal := Subgroup.normal_of_comm H
    exact IsGalois.of_fixedField_normal_subgroup (K := ℚ) (L := E) H
  have htrL : IsTotallyReal L := by
    letI : IsUnramifiedAtInfinitePlaces ℚ L := by
      apply IsUnramifiedAtInfinitePlaces_of_odd_finrank (k := ℚ) (K := L)
      simpa [hfinrankL] using (show Odd (3 : ℕ) by decide)
    refine ⟨fun w => ?_⟩
    have hwunr : w.IsUnramified ℚ := NumberField.InfinitePlace.isUnramified (k := ℚ) w
    have hwq : w.comap (algebraMap ℚ L) = Rat.infinitePlace := Subsingleton.elim _ _
    have hbaseReal : (w.comap (algebraMap ℚ L)).IsReal := by
      simpa [hwq] using (Rat.isReal_infinitePlace : Rat.infinitePlace.IsReal)
    exact (NumberField.InfinitePlace.isUnramified_iff (k := ℚ) (w := w)).mp hwunr |>.resolve_right
      ((NumberField.InfinitePlace.not_isComplex_iff_isReal).2 hbaseReal)
  letI : IsGalois ℚ L := hgalL
  letI : IsTotallyReal L := htrL
  refine ⟨L, inferInstance, inferInstance, inferInstance, htrL, hgalL, inferInstance, ?_⟩
  exact ⟨hfinrankL, discr_cubic_subfield_of_prime_cyclotomic r hr hr3 L hfinrankL⟩

theorem elementaryAbelian_mulEquiv (G : Type) [Group G] [Finite G]
    (p k : ℕ) [Fact (Nat.Prime p)]
    (_hcard : Nat.card G = p ^ k)
    (_hexp : ∀ g : G, g ^ p = 1)
    (_habel : ∀ g h : G, g * h = h * g) :
    Nonempty (G ≃* Multiplicative (Fin k → ZMod p)) := by
  classical
  letI : CommGroup G :=
    { ‹Group G› with
      mul_comm := _habel }
  have hsmul_zero : ∀ a : Additive G, p • a = 0 := by
    intro a
    simpa using congrArg Additive.ofMul (_hexp a.toMul)
  haveI : Module (ZMod p) (Additive G) := AddCommGroup.zmodModule hsmul_zero
  haveI : Finite (Additive G) := inferInstance
  haveI : Module.Finite (ZMod p) (Additive G) :=
    Module.Finite.of_finite (R := ZMod p) (M := Additive G)
  haveI : Module.Free (ZMod p) (Additive G) :=
    Module.Free.of_divisionRing (K := ZMod p) (V := Additive G)
  have hpow : p ^ Module.finrank (ZMod p) (Additive G) = Nat.card (Additive G) := by
    simpa using (FiniteField.pow_finrank_eq_natCard p (Additive G))
  have hpow' : p ^ Module.finrank (ZMod p) (Additive G) = p ^ k := by
    calc
      p ^ Module.finrank (ZMod p) (Additive G) = Nat.card (Additive G) := hpow
      _ = Nat.card G := Nat.card_congr Additive.toMul
      _ = p ^ k := _hcard
  have hfinrank : Module.finrank (ZMod p) (Additive G) = k := by
    exact Nat.pow_right_injective (a := p) (Fact.out : Nat.Prime p).two_le hpow'
  let b : Module.Basis (Fin k) (ZMod p) (Additive G) :=
    Module.finBasisOfFinrankEq (R := ZMod p) (M := Additive G) (n := k) hfinrank
  refine ⟨AddEquiv.toMultiplicativeRight
    (show Additive G ≃+ (Fin k → ZMod p) from b.equivFun.toAddEquiv)⟩

theorem minpoly_iK_eq_X_sq_add_one (𝒟 : AdmissibleDatum) :
    minpoly 𝒟.L 𝒟.i_K = (Polynomial.X ^ 2 + 1 : Polynomial 𝒟.L) := by
  let p : Polynomial 𝒟.L := Polynomial.X ^ 2 + 1
  have hp_monic : p.Monic := by
    dsimp [p]
    simpa using (Polynomial.monic_X_pow_add_C (a := (1 : 𝒟.L)) (n := 2) (by decide))
  have hp_aeval : Polynomial.aeval 𝒟.i_K p = 0 := by
    dsimp [p]
    simp [pow_two, 𝒟.i_K_sq]
  have hi : IsIntegral 𝒟.L 𝒟.i_K := ⟨p, hp_monic, hp_aeval⟩
  let pb : PowerBasis 𝒟.L 𝒟.K := PowerBasis.ofAdjoinEqTop hi 𝒟.adjoin_i_K_eq_top
  have hdim : pb.dim = 2 := by
    rw [← PowerBasis.finrank pb]
    exact Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K
  have hdeg : (minpoly 𝒟.L 𝒟.i_K).natDegree = 2 := by
    rw [← PowerBasis.ofAdjoinEqTop_dim hi 𝒟.adjoin_i_K_eq_top]
    simpa [pb] using hdim
  have hnat_p : p.natDegree = 2 := by
    dsimp [p]
    simpa using (Polynomial.natDegree_X_pow_add_C (n := 2) (r := (1 : 𝒟.L)))
  have hpdeg : p.degree = 2 := by
    simpa using
      (Polynomial.MonicDegreeEq.degree (Polynomial.MonicDegreeEq.mk p hp_monic hnat_p))
  have hmdeg : (minpoly 𝒟.L 𝒟.i_K).degree = 2 := by
    simpa using
      (Polynomial.MonicDegreeEq.degree
        (Polynomial.MonicDegreeEq.mk (minpoly 𝒟.L 𝒟.i_K) (minpoly.monic hi) hdeg))
  have hp_le : p.degree ≤ (minpoly 𝒟.L 𝒟.i_K).degree := by
    rw [hpdeg, hmdeg]
  have hEq : p = minpoly 𝒟.L 𝒟.i_K := by
    exact minpoly.unique_of_degree_le_degree_minpoly (A := 𝒟.L) (x := 𝒟.i_K) hp_monic hp_aeval hp_le
  simpa [p] using hEq.symm

theorem minpoly_iO_map_eq_X_sq_add_one (𝒟 : AdmissibleDatum) :
    (minpoly (𝓞 𝒟.L) (admissibleDatum_iO 𝒟)).map
      (algebraMap (𝓞 𝒟.L) 𝒟.L) = (Polynomial.X ^ 2 + 1 : Polynomial 𝒟.L) := by
  let iO := admissibleDatum_iO 𝒟
  have hIntExt : Algebra.IsIntegral (𝓞 𝒟.L) (𝓞 𝒟.K) :=
    NumberField.RingOfIntegers.extension_algebra_isIntegral (K := 𝒟.L) (L := 𝒟.K)
  have hiOint : IsIntegral (𝓞 𝒟.L) iO :=
    (Algebra.isIntegral_def.mp hIntExt) iO
  rw [← minpoly.isIntegrallyClosed_eq_field_fractions (K := 𝒟.L) (L := 𝒟.K) hiOint]
  simp [iO, admissibleDatum_iO, minpoly_iK_eq_X_sq_add_one 𝒟]

theorem q_mod4_exists_sq_eq_neg_one (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) :
    ∃ a : ZMod (𝒟.q b), a ^ 2 = (-1 : ZMod (𝒟.q b)) := by
  letI : Fact (Nat.Prime (𝒟.q b)) := ⟨𝒟.q_prime b⟩
  have hsquare : IsSquare (-1 : ZMod (𝒟.q b)) := by
    rw [ZMod.exists_sq_eq_neg_one_iff]
    have hmod : 𝒟.q b % 4 ≠ 3 := by
      rw [𝒟.q_mod4 b]
      decide
    exact hmod
  rcases hsquare with ⟨a, ha⟩
  refine ⟨a, ?_⟩
  simpa [sq] using ha.symm

theorem exists_sq_eq_neg_one_residueField_of_prime_over_q (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t)
    (𝔮 : Ideal (𝓞 𝒟.L)) (h𝔮p : 𝔮.IsPrime) (h𝔮ne : 𝔮 ≠ ⊥)
    (h𝔮over : 𝔮 ∈ (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.L)) :
    ∃ a : 𝓞 𝒟.L ⧸ 𝔮, a ^ 2 = (-1 : 𝓞 𝒟.L ⧸ 𝔮) := by
  classical
  let p : Ideal ℤ := Ideal.span {((𝒟.q b : ℤ))}
  have hpPrime : p.IsPrime := by
    rw [show p = Ideal.span {((𝒟.q b : ℤ))} by rfl]
    exact (Ideal.span_singleton_prime (show ((𝒟.q b : ℤ)) ≠ 0 by exact_mod_cast (𝒟.q_prime b).ne_zero)).2
      ((Nat.prime_iff_prime_int).mp (𝒟.q_prime b))
  have hp0 : p ≠ ⊥ := by
    rw [show p = Ideal.span {((𝒟.q b : ℤ))} by rfl, ne_eq, Ideal.span_singleton_eq_bot]
    exact_mod_cast (𝒟.q_prime b).ne_zero
  letI : p.IsMaximal := hpPrime.isMaximal hp0
  let Q : p.primesOver (𝓞 𝒟.L) := ⟨𝔮, h𝔮over⟩
  letI : 𝔮.LiesOver p := by
    simpa using (Ideal.primesOver.liesOver (p := p) Q)
  letI : 𝔮.IsMaximal := Ideal.isMaximal_of_mem_primesOver h𝔮over
  have hinertia : Ideal.inertiaDeg p 𝔮 = 1 := by
    simpa [p] using ((𝒟.q_splits_in_L b).1 𝔮 h𝔮over).2
  have hcard_nat : Nat.card (𝓞 𝒟.L ⧸ 𝔮) = 𝒟.q b := by
    calc
      Nat.card (𝓞 𝒟.L ⧸ 𝔮) = 𝔮.cardQuot := by
        symm
        exact Submodule.cardQuot_apply 𝔮
      _ = Ideal.absNorm 𝔮 := by
        symm
        exact Ideal.absNorm_apply 𝔮
      _ = (𝒟.q b) ^ (Ideal.inertiaDeg p 𝔮) := by
        exact Ideal.absNorm_eq_pow_inertiaDeg' 𝔮 (𝒟.q_prime b)
      _ = 𝒟.q b := by rw [hinertia, pow_one]
  letI : Finite (𝓞 𝒟.L ⧸ 𝔮) := Nat.finite_of_card_ne_zero (by
    rw [hcard_nat]
    exact (𝒟.q_prime b).ne_zero)
  letI : Fintype (𝓞 𝒟.L ⧸ 𝔮) := Fintype.ofFinite (𝓞 𝒟.L ⧸ 𝔮)
  have hcard : Fintype.card (𝓞 𝒟.L ⧸ 𝔮) = 𝒟.q b := by
    rw [Fintype.card_eq_nat_card, hcard_nat]
  let e : ZMod (𝒟.q b) ≃+* (𝓞 𝒟.L ⧸ 𝔮) :=
    ZMod.ringEquivOfPrime (R := 𝓞 𝒟.L ⧸ 𝔮) (𝒟.q_prime b) hcard
  rcases q_mod4_exists_sq_eq_neg_one 𝒟 b with ⟨a, ha⟩
  refine ⟨e a, ?_⟩
  simpa [map_pow, map_neg, map_one] using congrArg e ha

theorem q_two_not_mem_prime_over_q (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t)
    (𝔮 : Ideal (𝓞 𝒟.L)) (h𝔮p : 𝔮.IsPrime) (h𝔮ne : 𝔮 ≠ ⊥)
    (h𝔮over : 𝔮 ∈ (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.L)) :
    (2 : 𝓞 𝒟.L) ∉ 𝔮 := by
  let p : Ideal ℤ := Ideal.span {((𝒟.q b : ℤ))}
  intro h2
  have h_lies' : 𝔮.LiesOver (Ideal.span {((𝒟.q b : ℤ))}) := by
    exact h𝔮over.2
  letI : 𝔮.LiesOver p := by
    simpa [p] using h_lies'
  have h2int : (2 : ℤ) ∈ p := by
    exact (Ideal.mem_of_liesOver 𝔮 p 2).2 (by simpa using h2)
  have h2int' : (2 : ℤ) ∈ Ideal.span {((𝒟.q b : ℤ))} := by
    simpa [p] using h2int
  have hdivz : ((𝒟.q b : ℤ)) ∣ (2 : ℤ) := by
    exact Ideal.mem_span_singleton.mp h2int'
  have hdivn : 𝒟.q b ∣ 2 := by
    exact Int.ofNat_dvd_natCast.mp hdivz
  have hqeq : 𝒟.q b = 2 := by
    exact (Nat.prime_dvd_prime_iff_eq (𝒟.q_prime b) Nat.prime_two).mp hdivn
  have hmod : (2 : ℕ) % 4 = 1 := by
    simpa [hqeq] using 𝒟.q_mod4 b
  norm_num at hmod

theorem conductor_iO_sup_prime_over_q_eq_top (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t)
    (𝔮 : Ideal (𝓞 𝒟.L)) (h𝔮p : 𝔮.IsPrime) (h𝔮ne : 𝔮 ≠ ⊥)
    (h𝔮over : 𝔮 ∈ (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.L)) :
    (conductor (𝓞 𝒟.L) (admissibleDatum_iO 𝒟)).comap
      (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ⊔ 𝔮 = ⊤ := by
  let iO := admissibleDatum_iO 𝒟
  have hcoe_iO : (algebraMap (𝓞 𝒟.K) 𝒟.K) iO = 𝒟.i_K := by
    rfl
  have hmap2 : (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) (2 : 𝓞 𝒟.L) = (2 : 𝓞 𝒟.K) := by
    simpa using map_natCast (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 2
  have hmul :
      conductor (𝓞 𝒟.L) iO * differentIdeal (𝓞 𝒟.L) (𝓞 𝒟.K)
        = Ideal.span
            {(Polynomial.aeval iO (Polynomial.derivative (minpoly (𝓞 𝒟.L) iO)))} := by
    simpa [iO] using
      (conductor_mul_differentIdeal (A := 𝓞 𝒟.L) (K := 𝒟.L) (L := 𝒟.K) (x := iO)
        (by simpa [iO] using 𝒟.adjoin_i_K_eq_top))
  have hiO_sq : iO * iO = (-1 : 𝓞 𝒟.K) := by
    ext
    simp [iO, admissibleDatum_iO, 𝒟.i_K_sq]
  have hiO_unit : IsUnit iO := by
    refine ⟨⟨iO, -iO, ?_, ?_⟩, rfl⟩
    · calc
        iO * (-iO) = -(iO * iO) := by ring
        _ = -(-1 : 𝓞 𝒟.K) := by rw [hiO_sq]
        _ = 1 := by ring
    · calc
        (-iO) * iO = -(iO * iO) := by ring
        _ = -(-1 : 𝓞 𝒟.K) := by rw [hiO_sq]
        _ = 1 := by ring
  have hcomm :
      (algebraMap 𝒟.L 𝒟.K).comp (algebraMap (𝓞 𝒟.L) 𝒟.L) =
        (algebraMap (𝓞 𝒟.K) 𝒟.K).comp (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) := by
    ext x
    rfl
  have haeval_map :
      (algebraMap (𝓞 𝒟.K) 𝒟.K)
        (Polynomial.aeval iO (Polynomial.derivative (minpoly (𝓞 𝒟.L) iO)))
        = (2 : 𝒟.K) * 𝒟.i_K := by
    rw [Polynomial.map_aeval_eq_aeval_map hcomm]
    rw [← Polynomial.derivative_map]
    rw [minpoly_iO_map_eq_X_sq_add_one]
    norm_num [pow_two, 𝒟.i_K_sq]
    rw [hcoe_iO, two_mul]
  have haeval :
      Polynomial.aeval iO (Polynomial.derivative (minpoly (𝓞 𝒟.L) iO)) = 2 * iO := by
    ext
    simpa [iO] using haeval_map
  have hspan :
      Ideal.span ({(2 : 𝓞 𝒟.K)} : Set (𝓞 𝒟.K)) =
        conductor (𝓞 𝒟.L) iO * differentIdeal (𝓞 𝒟.L) (𝓞 𝒟.K) := by
    calc
      Ideal.span ({(2 : 𝓞 𝒟.K)} : Set (𝓞 𝒟.K))
          = Ideal.span
              {(Polynomial.aeval iO (Polynomial.derivative (minpoly (𝓞 𝒟.L) iO)))} := by
            rw [haeval]
            symm
            exact Ideal.span_singleton_mul_right_unit hiO_unit (2 : 𝓞 𝒟.K)
      _ = conductor (𝓞 𝒟.L) iO * differentIdeal (𝓞 𝒟.L) (𝓞 𝒟.K) := by
          symm
          exact hmul
  have hspan_le : Ideal.span ({(2 : 𝓞 𝒟.K)} : Set (𝓞 𝒟.K)) ≤ conductor (𝓞 𝒟.L) iO := by
    rw [hspan]
    exact Ideal.mul_le_right
  have h2_mem_cond : (2 : 𝓞 𝒟.K) ∈ conductor (𝓞 𝒟.L) iO := by
    exact hspan_le (Ideal.subset_span (by simp))
  have h2_mem_comap :
      (2 : 𝓞 𝒟.L) ∈ (conductor (𝓞 𝒟.L) (admissibleDatum_iO 𝒟)).comap
        (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) := by
    rw [Ideal.mem_comap, hmap2]
    simpa [iO] using h2_mem_cond
  have h𝔮max : 𝔮.IsMaximal := Ideal.IsPrime.isMaximal h𝔮p h𝔮ne
  rw [Ideal.isMaximal_iff] at h𝔮max
  have hone_mem : (1 : 𝓞 𝒟.L) ∈
      (conductor (𝓞 𝒟.L) (admissibleDatum_iO 𝒟)).comap
        (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ⊔ 𝔮 := by
    exact h𝔮max.2 _ _ le_sup_right
      (q_two_not_mem_prime_over_q 𝒟 b 𝔮 h𝔮p h𝔮ne h𝔮over)
      (Ideal.mem_sup_left h2_mem_comap)
  exact top_unique (by
    intro x hx
    exact Ideal.mem_of_one_mem hone_mem x)

theorem q_splits_in_K_local (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t)
    (𝔮 : Ideal (𝓞 𝒟.L)) (_h𝔮p : 𝔮.IsPrime) (_h𝔮ne : 𝔮 ≠ ⊥)
    (_h𝔮over : 𝔮 ∈ (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.L)) :
    ∃ 𝔓 𝔓' : Ideal (𝓞 𝒟.K),
      𝔓 ≠ 𝔓' ∧ 𝔓.IsPrime ∧ 𝔓'.IsPrime ∧ 𝔓 ≠ ⊥ ∧ 𝔓' ≠ ⊥ ∧
      𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) = 𝔓 * 𝔓' := by
  classical
  let iO : 𝓞 𝒟.K := admissibleDatum_iO 𝒟
  have hiOint : IsIntegral (𝓞 𝒟.L) iO := by
    have hInt : Algebra.IsIntegral (𝓞 𝒟.L) (𝓞 𝒟.K) :=
      NumberField.RingOfIntegers.extension_algebra_isIntegral (K := 𝒟.L) (L := 𝒟.K)
    rw [Algebra.isIntegral_def] at hInt
    exact hInt iO
  have hminO_eq : minpoly (𝓞 𝒟.L) iO = (Polynomial.X ^ 2 + 1 : Polynomial (𝓞 𝒟.L)) := by
    apply (Polynomial.map_injective (f := algebraMap (𝓞 𝒟.L) 𝒟.L)
      (FaithfulSMul.algebraMap_injective (𝓞 𝒟.L) 𝒟.L))
    simpa [iO] using minpoly_iO_map_eq_X_sq_add_one 𝒟
  letI : 𝔮.IsMaximal := Ideal.IsPrime.isMaximal _h𝔮p _h𝔮ne
  letI := Ideal.Quotient.field 𝔮
  have hcond_sup : (conductor (𝓞 𝒟.L) iO).comap (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ⊔ 𝔮 = ⊤ := by
    simpa [iO] using conductor_iO_sup_prime_over_q_eq_top 𝒟 b 𝔮 _h𝔮p _h𝔮ne _h𝔮over
  obtain ⟨a, ha⟩ := exists_sq_eq_neg_one_residueField_of_prime_over_q 𝒟 b 𝔮 _h𝔮p _h𝔮ne _h𝔮over
  let Q : Polynomial (𝓞 𝒟.L ⧸ 𝔮) := Polynomial.X - Polynomial.C a
  let Q' : Polynomial (𝓞 𝒟.L ⧸ 𝔮) := Polynomial.X + Polynomial.C a
  have hred : Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO) = Q * Q' := by
    rw [hminO_eq]
    simp [Q, Q']
    ring_nf
    have hC : Polynomial.C a ^ 2 = Polynomial.C (a ^ 2) := by simp [pow_two]
    rw [hC, ha]
    simp [add_comm]
  have htwo_ne_zero : (2 : 𝓞 𝒟.L ⧸ 𝔮) ≠ 0 := by
    intro hzero
    have hmem : (2 : 𝓞 𝒟.L) ∈ 𝔮 := by
      simpa using (Submodule.Quotient.mk_eq_zero (p := 𝔮) (x := (2 : 𝓞 𝒟.L))).mp hzero
    exact q_two_not_mem_prime_over_q 𝒟 b 𝔮 _h𝔮p _h𝔮ne _h𝔮over hmem
  have ha_ne_zero : a ≠ 0 := by
    intro ha0
    have hneg : (-1 : 𝓞 𝒟.L ⧸ 𝔮) = 0 := by simp [ha0] at ha
    have hone : (1 : 𝓞 𝒟.L ⧸ 𝔮) = 0 := by simp at hneg
    exact one_ne_zero hone
  have hQ_ne_Q' : Q ≠ Q' := by
    intro hQQ
    have hcoeff := congrArg (fun p : Polynomial (𝓞 𝒟.L ⧸ 𝔮) => p.coeff 0) hQQ
    have haeq : -a = a := by
      simpa [Q, Q'] using hcoeff
    have haeq' : a = -a := by simpa using haeq.symm
    have h2a : (2 : 𝓞 𝒟.L ⧸ 𝔮) * a = 0 := by
      calc
        (2 : 𝓞 𝒟.L ⧸ 𝔮) * a = a + a := by simp [two_mul]
        _ = a + (-a) := by
          exact congrArg (fun x => a + x) haeq'
        _ = 0 := by simp
    have h2zero : (2 : 𝓞 𝒟.L ⧸ 𝔮) = 0 := by
      exact (mul_eq_zero.mp h2a).resolve_right ha_ne_zero
    exact htwo_ne_zero h2zero
  have hQ_irreducible : Irreducible Q := by
    simpa [Q] using (Polynomial.irreducible_X_sub_C a)
  have hQ'_irreducible : Irreducible Q' := by
    simpa [Q', sub_eq_add_neg] using (Polynomial.irreducible_X_sub_C (-a))
  have hQ_monic : Q.Monic := by
    simpa [Q] using (Polynomial.monic_X_sub_C a)
  have hQ'_monic : Q'.Monic := by
    simpa [Q'] using (Polynomial.monic_X_add_C a)
  have hQ_ne_zero : Q ≠ 0 := hQ_monic.ne_zero
  have hQ'_ne_zero : Q' ≠ 0 := hQ'_monic.ne_zero
  have hred_ne_zero : Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO) ≠ 0 := by
    rw [hred]
    exact mul_ne_zero hQ_ne_zero hQ'_ne_zero
  have hQ_mem : Q ∈ UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO)) := by
    rw [Polynomial.mem_normalizedFactors_iff hred_ne_zero]
    refine ⟨hQ_irreducible, hQ_monic, ?_⟩
    rw [hred]
    exact ⟨Q', by simp⟩
  have hQ'_mem : Q' ∈ UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO)) := by
    rw [Polynomial.mem_normalizedFactors_iff hred_ne_zero]
    refine ⟨hQ'_irreducible, hQ'_monic, ?_⟩
    rw [hred]
    exact ⟨Q, by simp [mul_comm]⟩
  have hqmap_ne : 𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ≠ ⊥ :=
    Ideal.map_ne_bot_of_ne_bot _h𝔮ne
  let e := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
    (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) (I := 𝔮) (x := iO) (show 𝔮.IsMaximal from inferInstance)
    _h𝔮ne hcond_sup hiOint
  let Pf := (e.symm ⟨Q, hQ_mem⟩ : {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))})
  let Pf' := (e.symm ⟨Q', hQ'_mem⟩ : {J : Ideal (𝓞 𝒟.K) | J ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))})
  let 𝔓 : Ideal (𝓞 𝒟.K) := Pf
  let 𝔓' : Ideal (𝓞 𝒟.K) := Pf'
  have h𝔓_mem : 𝔓 ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))) := by
    change (↑Pf) ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))
    exact Pf.prop
  have h𝔓'_mem : 𝔓' ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))) := by
    change (↑Pf') ∈ UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))
    exact Pf'.prop
  have hnorm_red :
      UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO)) =
        {Q} + {Q'} := by
    rw [hred, UniqueFactorizationMonoid.normalizedFactors_mul hQ_ne_zero hQ'_ne_zero,
      UniqueFactorizationMonoid.normalizedFactors_irreducible hQ_irreducible,
      UniqueFactorizationMonoid.normalizedFactors_irreducible hQ'_irreducible,
      Polynomial.Monic.normalize_eq_self hQ_monic,
      Polynomial.Monic.normalize_eq_self hQ'_monic]
  have hattach_red :
      (UniqueFactorizationMonoid.normalizedFactors
        (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO))).attach =
        ({⟨Q, hQ_mem⟩} + {⟨Q', hQ'_mem⟩} :
          Multiset {d : Polynomial (𝓞 𝒟.L ⧸ 𝔮) |
            d ∈ UniqueFactorizationMonoid.normalizedFactors
              (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO))}) := by
    apply (Multiset.map_injective (f := fun x :
      {d : Polynomial (𝓞 𝒟.L ⧸ 𝔮) |
        d ∈ UniqueFactorizationMonoid.normalizedFactors
          (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO))} => x.1)
      Subtype.val_injective)
    change Multiset.map Subtype.val
        ((UniqueFactorizationMonoid.normalizedFactors
          (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO))).attach) =
      Multiset.map Subtype.val ({⟨Q, hQ_mem⟩} + {⟨Q', hQ'_mem⟩})
    simpa [Multiset.attach_map_val, Multiset.map_add, Multiset.map_singleton] using hnorm_red
  have hnorm_map :
      UniqueFactorizationMonoid.normalizedFactors (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))) =
        {𝔓} + {𝔓'} := by
    rw [KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      (R := 𝓞 𝒟.L) (S := 𝓞 𝒟.K) (I := 𝔮) (x := iO)
      (show 𝔮.IsMaximal from inferInstance) _h𝔮ne hcond_sup hiOint,
      hattach_red,
      Multiset.map_add,
      Multiset.map_singleton,
      Multiset.map_singleton]
  have h𝔓_isPrime : 𝔓.IsPrime := (Ideal.mem_normalizedFactors_iff hqmap_ne).mp h𝔓_mem |>.1
  have h𝔓'_isPrime : 𝔓'.IsPrime := (Ideal.mem_normalizedFactors_iff hqmap_ne).mp h𝔓'_mem |>.1
  have hqmap_le_𝔓 : 𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ≤ 𝔓 :=
    (Ideal.mem_normalizedFactors_iff hqmap_ne).mp h𝔓_mem |>.2
  have hqmap_le_𝔓' : 𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ≤ 𝔓' :=
    (Ideal.mem_normalizedFactors_iff hqmap_ne).mp h𝔓'_mem |>.2
  have h𝔓_ne_bot : 𝔓 ≠ ⊥ := by
    intro h𝔓0
    have hle : 𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ≤ (⊥ : Ideal (𝓞 𝒟.K)) := by
      simpa [h𝔓0] using hqmap_le_𝔓
    exact hqmap_ne (le_antisymm hle bot_le)
  have h𝔓'_ne_bot : 𝔓' ≠ ⊥ := by
    intro h𝔓0
    have hle : 𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) ≤ (⊥ : Ideal (𝓞 𝒟.K)) := by
      simpa [h𝔓0] using hqmap_le_𝔓'
    exact hqmap_ne (le_antisymm hle bot_le)
  have h𝔓_ne_𝔓' : 𝔓 ≠ 𝔓' := by
    intro hPP
    have hPf_eq : Pf = Pf' := by
      apply Subtype.ext
      simpa [𝔓, 𝔓'] using hPP
    have hQQ' :
        (⟨Q, hQ_mem⟩ :
          {d : Polynomial (𝓞 𝒟.L ⧸ 𝔮) |
            d ∈ UniqueFactorizationMonoid.normalizedFactors
              (Polynomial.map (Ideal.Quotient.mk 𝔮) (minpoly (𝓞 𝒟.L) iO))}) =
        ⟨Q', hQ'_mem⟩ := by
      simpa [Pf, Pf'] using congrArg e hPf_eq
    exact hQ_ne_Q' (congrArg Subtype.val hQQ')
  have hfac :
      𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) = 𝔓 * 𝔓' := by
    calc
      𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) =
          (UniqueFactorizationMonoid.normalizedFactors
            (𝔮.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)))).prod := by
            symm
            exact prod_normalizedFactors_eq_self hqmap_ne
      _ = ({𝔓} + {𝔓'} : Multiset (Ideal (𝓞 𝒟.K))).prod := by
        rw [hnorm_map]
      _ = 𝔓 * 𝔓' := by simp
  exact ⟨𝔓, 𝔓', h𝔓_ne_𝔓', h𝔓_isPrime, h𝔓'_isPrime, h𝔓_ne_bot, h𝔓'_ne_bot, hfac⟩

theorem q_splits_in_K_of_split_in_L_and_mod4 (𝒟 : AdmissibleDatum) (b : Fin 𝒟.t) :
    (∀ 𝔓 ∈ (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.K),
        Ideal.ramificationIdx
          (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg
          (Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ) 𝔓 = 1) ∧
      ((Ideal.span {((𝒟.q b : ℤ))} : Ideal ℤ).primesOver (𝓞 𝒟.K)).ncard =
        Module.finrank ℚ 𝒟.K := by
  classical
  let p : Ideal ℤ := Ideal.span {((𝒟.q b : ℤ))}
  have hqprime : Nat.Prime (𝒟.q b) := 𝒟.q_prime b
  have hqne0 : ((𝒟.q b : ℤ)) ≠ 0 := by
    exact_mod_cast hqprime.ne_zero
  have hp0 : p ≠ ⊥ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact hqne0
  letI : Fact (Nat.Prime (𝒟.q b)) := ⟨hqprime⟩
  letI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime (𝒟.q b))
  rcases 𝒟.q_splits_in_L b with ⟨hLsplit, hLcard⟩
  have hsplitK : ∀ 𝔓 ∈ p.primesOver (𝓞 𝒟.K),
      Ideal.ramificationIdx p 𝔓 = 1 ∧ Ideal.inertiaDeg p 𝔓 = 1 := by
    intro 𝔓 h𝔓
    have h𝔓p : 𝔓.IsPrime := h𝔓.1
    have h𝔓over : 𝔓.LiesOver p := h𝔓.2
    let 𝔮 : Ideal (𝓞 𝒟.L) := 𝔓.under (𝓞 𝒟.L)
    have h𝔮p : 𝔮.IsPrime := by
      dsimp [𝔮]
      letI : 𝔓.IsPrime := h𝔓p
      exact Ideal.IsPrime.comap (f := algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K))
    have h𝔮_lies : 𝔮.LiesOver p := by
      dsimp [𝔮]
      letI : 𝔓.LiesOver p := h𝔓over
      exact Ideal.under_liesOver_of_liesOver (B := 𝓞 𝒟.L) (𝔓 := 𝔓) (p := p)
    have h𝔮over : 𝔮 ∈ p.primesOver (𝓞 𝒟.L) := by
      exact ⟨h𝔮p, h𝔮_lies⟩
    have h𝔮ne : 𝔮 ≠ ⊥ := by
      have h𝔮max : 𝔮.IsMaximal := Ideal.isMaximal_of_mem_primesOver h𝔮over
      exact Ring.ne_bot_of_isMaximal_of_not_isField h𝔮max
        (NumberField.RingOfIntegers.not_isField (K := 𝒟.L))
    have h𝔮e : Ideal.ramificationIdx p 𝔮 = 1 := (hLsplit 𝔮 h𝔮over).1
    have h𝔮f : Ideal.inertiaDeg p 𝔮 = 1 := (hLsplit 𝔮 h𝔮over).2
    letI : 𝔮.IsMaximal := Ideal.IsPrime.isMaximal h𝔮p h𝔮ne
    rcases q_splits_in_K_local 𝒟 b 𝔮 h𝔮p h𝔮ne h𝔮over with
      ⟨𝔓₁, 𝔓₂, hne, h𝔓₁p, h𝔓₂p, h𝔓₁ne, h𝔓₂ne, hmul⟩
    have h𝔓₁lies : 𝔓₁.LiesOver 𝔮 := by
      have hdiv : 𝔓₁ ∣ Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 𝔮 := by
        refine ⟨𝔓₂, ?_⟩
        simp [hmul, Ideal.mul_comm]
      exact (Ideal.liesOver_iff_dvd_map (p := 𝔮) (P := 𝔓₁)
        (Ideal.IsPrime.ne_top h𝔓₁p)).2 hdiv
    have h𝔓₂lies : 𝔓₂.LiesOver 𝔮 := by
      have hdiv : 𝔓₂ ∣ Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 𝔮 := by
        refine ⟨𝔓₁, ?_⟩
        simp [hmul, Ideal.mul_comm]
      exact (Ideal.liesOver_iff_dvd_map (p := 𝔮) (P := 𝔓₂)
        (Ideal.IsPrime.ne_top h𝔓₂p)).2 hdiv
    have h𝔓₁over : 𝔓₁ ∈ 𝔮.primesOver (𝓞 𝒟.K) := by
      exact ⟨h𝔓₁p, h𝔓₁lies⟩
    have h𝔓₂over : 𝔓₂ ∈ 𝔮.primesOver (𝓞 𝒟.K) := by
      exact ⟨h𝔓₂p, h𝔓₂lies⟩
    have h_nontriv : (𝔮.primesOver (𝓞 𝒟.K)).Nontrivial := by
      exact ⟨𝔓₁, h𝔓₁over, 𝔓₂, h𝔓₂over, hne⟩
    have h_two_le : 2 ≤ (𝔮.primesOver (𝓞 𝒟.K)).ncard := by
      have h_one_lt : 1 < (𝔮.primesOver (𝓞 𝒟.K)).ncard := by
        exact (Set.one_lt_ncard_iff_nontrivial).2 h_nontriv
      omega
    letI : IsGalois 𝒟.L 𝒟.K :=
      Algebra.IsQuadraticExtension.isGalois (F := 𝒟.L) (K := 𝒟.K)
    have hcount_mul :
        (𝔮.primesOver (𝓞 𝒟.K)).ncard *
            (Ideal.ramificationIdxIn 𝔮 (𝓞 𝒟.K) * Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K)) =
          Nat.card (𝒟.K ≃ₐ[𝒟.L] 𝒟.K) := by
      exact Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn
        (p := 𝔮) (B := 𝓞 𝒟.K) (G := 𝒟.K ≃ₐ[𝒟.L] 𝒟.K) h𝔮ne
    have hcard_gal : Nat.card (𝒟.K ≃ₐ[𝒟.L] 𝒟.K) = Module.finrank 𝒟.L 𝒟.K := by
      simpa using (IsGalois.card_aut_eq_finrank (F := 𝒟.L) (E := 𝒟.K))
    have hcount_mul' :
        (𝔮.primesOver (𝓞 𝒟.K)).ncard *
            (Ideal.ramificationIdxIn 𝔮 (𝓞 𝒟.K) * Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K)) = 2 := by
      rw [hcard_gal, Algebra.IsQuadraticExtension.finrank_eq_two] at hcount_mul
      exact hcount_mul
    have hram_in_ne : Ideal.ramificationIdxIn 𝔮 (𝓞 𝒟.K) ≠ 0 := by
      exact Ideal.ramificationIdxIn_ne_zero
        (G := 𝒟.K ≃ₐ[𝒟.L] 𝒟.K) (p := 𝔮) (B := 𝓞 𝒟.K) h𝔮ne
    have hiner_in_ne : Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K) ≠ 0 := by
      exact Ideal.inertiaDegIn_ne_zero
        (G := 𝒟.K ≃ₐ[𝒟.L] 𝒟.K) (p := 𝔮) (B := 𝓞 𝒟.K)
    set m : ℕ :=
      Ideal.ramificationIdxIn 𝔮 (𝓞 𝒟.K) * Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K)
    have hm_pos : 0 < m := by

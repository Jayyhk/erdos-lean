theorem lemma_2_4_integrable_shift_count (рқ’ҹ : AdmissibleDatum) (R : в„қ) (u : рқ’ҹ.K) (hОӣu : рқ’ҹ.ОҰ u вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V)) : MeasureTheory.Integrable (fun a : рқ’ҹ.V => (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ)) (MeasureTheory.volume.restrict (lemma_2_4_FD рқ’ҹ)) := by
  classical
  letI : MeasurableConstVAdd (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V := lemma_2_4_measurableConstVAdd рқ’ҹ
  letI : MeasureTheory.VAddInvariantMeasure (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V MeasureTheory.volume :=
    lemma_2_4_vaddInvariantVolume рқ’ҹ
  let F : Set рқ’ҹ.V := lemma_2_4_FD рқ’ҹ
  let S : Set рқ’ҹ.V := { a : рқ’ҹ.V | a вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R }
  let g_u : рқ’ҹ.V вҶ’ ENNReal := fun a =>
    (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal)
  have hclosed_eq : рқ’ҹ.closedPolydisc R = Metric.closedBall (0 : рқ’ҹ.V) R := by
    ext z
    simp [AdmissibleDatum.closedPolydisc, Metric.mem_closedBall, supNorm_eq_norm]
  have hB : MeasurableSet (рқ’ҹ.closedPolydisc R) := by
    rw [hclosed_eq]
    exact measurableSet_closedBall
  have hS : MeasurableSet S := by
    change MeasurableSet (рқ’ҹ.closedPolydisc R вҲ© {a : рқ’ҹ.V | a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R})
    refine hB.inter ?_
    exact hB.preimage (measurable_id.add measurable_const)
  have hmcv : MeasurableConstVAdd (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V := inferInstance
  have hvinv : MeasureTheory.VAddInvariantMeasure (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V MeasureTheory.volume := inferInstance
  have hcount (a : рқ’ҹ.V) :
      (вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a)) = g_u a := by
    let T : Set рқ’ҹ.Оӣ :=
      {l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R вҲ§
          a + (l : рқ’ҹ.V) + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R}
    calc
      (вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a))
          = вҲ‘' l : рқ’ҹ.Оӣ, T.indicator (fun _ => (1 : ENNReal)) l := by
            refine tsum_congr ?_
            intro l
            change S.indicator (fun _ => (1 : ENNReal)) ((l : рқ’ҹ.V) + a) = _
            by_cases hl : l вҲҲ T
            В· have hs : (l : рқ’ҹ.V) + a вҲҲ S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
            В· have hs : (l : рқ’ҹ.V) + a вҲү S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
      _ = вҲ‘' l : T, (1 : ENNReal) := by
            symm
            exact tsum_subtype T (fun _ => (1 : ENNReal))
      _ = T.encard := ENNReal.tsum_set_one T
      _ = g_u a := by
            dsimp [g_u, T]
            exact_mod_cast (lemma_2_4_shift_count_eq_lattice_encard рқ’ҹ a R u hОӣu)
  have hlin0 :
      вҲ«вҒ» x, S.indicator (fun _ => (1 : ENNReal)) x вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» x in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ x) вҲӮMeasureTheory.volume := by
    simpa [F] using
      (@MeasureTheory.IsAddFundamentalDomain.lintegral_eq_tsum'' (вҶҘрқ’ҹ.Оӣ) (рқ’ҹ.V)
        inferInstance inferInstance inferInstance (lemma_2_4_FD рқ’ҹ) MeasureTheory.volume
        hmcv hvinv inferInstance (lemma_2_4_isAddFundamentalDomain рқ’ҹ)
        (S.indicator (fun _ => (1 : ENNReal))))
  have hmeas_indicator : Measurable (S.indicator (fun _ : рқ’ҹ.V => (1 : ENNReal))) := by
    exact Measurable.indicator measurable_const hS
  have hmeas_l : вҲҖ l : рқ’ҹ.Оӣ,
      Measurable fun a : рқ’ҹ.V => S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) := by
    intro l
    exact hmeas_indicator.comp (measurable_const_vadd l)
  have hlin :
      вҲ«вҒ» a in F, вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» a in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := by
    simpa using
      (MeasureTheory.lintegral_tsum
        (Ој := MeasureTheory.volume.restrict F)
        (f := fun l : рқ’ҹ.Оӣ => fun a : рқ’ҹ.V => S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a))
        (fun l => (hmeas_l l).aemeasurable))
  have hglobal :
      вҲ«вҒ» a, S.indicator (fun _ => (1 : ENNReal)) a вҲӮMeasureTheory.volume = MeasureTheory.volume S := by
    simp [hS]
  have hlintegral_eq : вҲ«вҒ» a in F, g_u a вҲӮMeasureTheory.volume = MeasureTheory.volume S := by
    calc
      вҲ«вҒ» a in F, g_u a вҲӮMeasureTheory.volume
          = вҲ«вҒ» a in F, вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := by
              refine MeasureTheory.lintegral_congr_ae ?_
              exact Filter.Eventually.of_forall (fun a => (hcount a).symm)
      _ = вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» a in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := hlin
      _ = вҲ«вҒ» a, S.indicator (fun _ => (1 : ENNReal)) a вҲӮMeasureTheory.volume := hlin0.symm
      _ = MeasureTheory.volume S := hglobal
  have hg_meas : AEMeasurable g_u (MeasureTheory.volume.restrict F) := by
    simpa [hcount] using (Measurable.ennreal_tsum (fun l : рқ’ҹ.Оӣ => hmeas_l l)).aemeasurable
  have hS_subset : S вҠҶ рқ’ҹ.closedPolydisc R := fun _ ha => ha.1
  have hB_lt_top : MeasureTheory.volume (рқ’ҹ.closedPolydisc R) < вҠӨ := by
    rw [hclosed_eq]
    exact MeasureTheory.measure_closedBall_lt_top (Ој := MeasureTheory.volume) (x := (0 : рқ’ҹ.V)) (r := R)
  have hS_ne_top : MeasureTheory.volume S вү  вҠӨ :=
    (lt_of_le_of_lt (MeasureTheory.measure_mono hS_subset) hB_lt_top).ne
  simpa [g_u, ENNReal.toReal_natCast] using
    (MeasureTheory.integrable_toReal_of_lintegral_ne_top hg_meas (by
      rw [hlintegral_eq]
      exact hS_ne_top))


/-- B_k elements are all ≥ N_{k-1} + 1 for k ≥ 1 -/
lemma B_k_lower_bound (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    ∀ x ∈ seq.B_k k, x ≥ seq.N (k-1) + 1 := by

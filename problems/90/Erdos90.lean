noncomputable def inflatedSchreier2Cocycle
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N)) :
    C(G × G, ZMod p) :=
  (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
      (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
      (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
      (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1)).comp
    ⟨fun gh : G × G => ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2), by
      continuity⟩

theorem inflatedSchreier2Cocycle_isCoboundary (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N)) :
    _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p G
      (inflatedSchreier2Cocycle p G N hN χ) := by
  let χh := _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1
  let r := continuousQuotientSectionRemainder G N hN
  let σ := _root_.Erdos90.TransgressionContinuous.chosenSection G N hN
  have hχcont : Continuous fun n : Additive ↥N => χh n := by
    simpa [χh] using h1ToHom_continuous p G N hN χ.1
  have hrcont : Continuous fun g : G => (Additive.ofMul (r g) : Additive ↥N) := by
    simpa [r] using (continuousQuotientSectionRemainder G N hN).continuous
  refine ⟨
    { toFun := fun g => - χh (Additive.ofMul (r g))
      continuous_toFun := by
        exact (hχcont.comp hrcont).neg }, ?_⟩
  intro g h
  let δ :=
    _root_.Erdos90.TransgressionContinuous.schreierDefect G N
      (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
      (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
      ((QuotientGroup.mk' N) g) ((QuotientGroup.mk' N) h)
  have hmul :
      χh (Additive.ofMul (r (g * h))) =
        χh (Additive.ofMul (r g)) +
          χh (Additive.ofMul
            ((MulAut.conjNormal (H := N)
              (σ ((QuotientGroup.mk' N) g)) (r h)))) +
          χh (Additive.ofMul δ) := by
    have hmul0 :=
      congrArg (fun n : ↥N => χh (Additive.ofMul n))
        (continuousQuotientSectionRemainder_mul G N hN g h)
    simpa [r, σ, δ, map_add, add_assoc] using hmul0
  have hconj :
      χh (Additive.ofMul
        ((MulAut.conjNormal (H := N)
          (σ ((QuotientGroup.mk' N) g)) (r h)))) =
      χh (Additive.ofMul (r h)) := by
    have hconj0 :=
      congrArg
        (fun f : Additive ↥N →+ ZMod p => f (Additive.ofMul (r h)))
        (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit_conjugation_invariant
          (p := p) (G := G) (N := N) (hN := hN) χ (σ ((QuotientGroup.mk' N) g)))
    simpa [χh, σ] using hconj0
  have hmul' :
      χh (Additive.ofMul (r (g * h))) =
        χh (Additive.ofMul (r g)) +
          χh (Additive.ofMul (r h)) +
          χh (Additive.ofMul δ) := by
    rw [hmul, hconj]
  have hω :
      χh (Additive.ofMul δ) =
        χh (Additive.ofMul (r (g * h))) -
          χh (Additive.ofMul (r g)) -
          χh (Additive.ofMul (r h)) := by
    have hω0 :=
      congrArg
        (fun x : ZMod p =>
          x - χh (Additive.ofMul (r g)) - χh (Additive.ofMul (r h))) hmul'
    abel_nf at hω0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hω0.symm

  have hχcont' : Continuous (χh : Additive ↥N → ZMod p) := hχcont
  simpa [inflatedSchreier2Cocycle, χh, r, δ,
    _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle, hχcont',
    sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hω


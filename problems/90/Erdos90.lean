      ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L)).ncard =
        Module.finrank ℚ L := by
  classical
  have hbad : (↑badPrimes : Set ℕ).Finite := badPrimes.finite_toSet
  rcases (finiteGalois_splitCompletely_primes_infinite (L := L)).exists_notMem_finite hbad with ⟨q, hqS, hqbad⟩
  exact ⟨q, hqS.1, hqbad, hqS.2.1, hqS.2.2⟩


/-- n is monotone from 0 -/
lemma n_mono_from_zero (seq : NathansonSeq) (j : ℕ) : seq.n 0 ≤ seq.n j := by
  induction j with
  | zero => rfl
  | succ j ih => exact Nat.le_trans ih (seq.n_mono j)
/-- n is monotone: if i ≤ j then n_i ≤ n_j -/
lemma n_mono_le (seq : NathansonSeq) {i j : ℕ} (h : i ≤ j) : seq.n i ≤ seq.n j := by
  obtain ⟨d, rfl⟩ := Nat.exists_eq_add_of_le h
  clear h
  induction d with
  | zero => simp
  | succ d ih => exact Nat.le_trans ih (seq.n_mono (i + d))
/-- N is monotone from 0 -/
lemma N_mono_from_zero (seq : NathansonSeq) (j : ℕ) : seq.N 0 ≤ seq.N j := by
  simp only [N]
  have := seq.n_mono_from_zero j
  omega
/-- n is strictly increasing for k ≥ 1 -/
lemma n_strict_mono (seq : NathansonSeq) (k : ℕ) (hk : k ≥ 1) : seq.n (k - 1) < seq.n k := by
  have hexp := seq.exponential_growth k hk
  have hpos := seq.n_pos (k - 1)
  omega
/-- N is strictly increasing -/
lemma N_strict_mono (seq : NathansonSeq) (k : ℕ) : seq.N k < seq.N (k + 1) := by
  simp only [N]
  have := seq.n_strict_mono (k + 1) (Nat.one_le_iff_ne_zero.mpr (Nat.succ_ne_zero k))
  simp only [Nat.add_sub_cancel] at this
  omega
/-- N is strictly monotone: if i < j then N_i < N_j -/
lemma N_strict_mono_lt (seq : NathansonSeq) {i j : ℕ} (h : i < j) : seq.N i < seq.N j := by
  induction j with
  | zero => exact absurd h (Nat.not_lt_zero i)
  | succ j ih =>
    rcases Nat.lt_succ_iff_lt_or_eq.mp h with hlt | rfl
    · exact Nat.lt_trans (ih hlt) (seq.N_strict_mono j)
    · exact seq.N_strict_mono i
/-- N is weakly monotone -/
lemma N_mono_le (seq : NathansonSeq) {i j : ℕ} (h : i ≤ j) : seq.N i ≤ seq.N j := by
  rcases h.lt_or_eq with hlt | rfl
  · exact le_of_lt (seq.N_strict_mono_lt hlt)
  · rfl
/-- n grows at least exponentially: n_j ≥ 8^j * n_0 -/
lemma n_exponential_bound (seq : NathansonSeq) (j : ℕ) : seq.n j ≥ 8^j * seq.n 0 := by
  induction j with
  | zero => simp
  | succ j ih =>
    have hexp := seq.exponential_growth (j + 1) (Nat.one_le_iff_ne_zero.mpr (Nat.succ_ne_zero j))
    simp only [Nat.add_sub_cancel] at hexp
    calc seq.n (j + 1) ≥ 8 * seq.n j := hexp
      _ ≥ 8 * (8^j * seq.n 0) := Nat.mul_le_mul_left 8 ih
      _ = 8^(j+1) * seq.n 0 := by ring
/-- n_0 ≥ 10 from growth_bound with k=1 -/
lemma n0_ge_10 (seq : NathansonSeq) : seq.n 0 ≥ 10 := by
  have := seq.growth_bound 1 (Nat.le_refl 1)
  simp at this
  omega
/-- 8^k * 10 ≥ k + 1 for all k -/

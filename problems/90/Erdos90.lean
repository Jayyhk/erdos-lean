theorem continuous_towerEval_prefixProd_equivariant (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (n : в„•) (y : C(A, HomogTower p G (n + 1))) (hy : вҲҖ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom (y a) = y (b вҖў a)) : Continuous (fun z : A Г— (Fin n вҶ’ G) => towerEval p G (n + 1) (y z.1) (prefixProdTuple G n z.2)) := by
  induction n generalizing A with
  | zero =>
      change Continuous (fun z : A Г— (Fin 0 вҶ’ G) => ((show C(G, ZMod p) from y z.1) (1 : G)))
      have hy0 : Continuous (fun z : A Г— (Fin 0 вҶ’ G) => (show C(G, ZMod p) from y z.1)) := by
        simpa using y.continuous.comp continuous_fst
      simpa using hy0.eval_const (1 : G)
  | succ n ih =>
      letI : SMul G (A Г— G) := вҹЁfun c q => (q.1, q.2 * cвҒ»В№)вҹ©
      letI : MulAction G (A Г— G) :=
        { smul := fun c q => (q.1, q.2 * cвҒ»В№)
          one_smul := by
            intro q
            change (q.1, q.2 * (1 : G)вҒ»В№) = q
            simp
          mul_smul := by
            intro a b q
            change (q.1, q.2 * (a * b)вҒ»В№) = (q.1, (q.2 * bвҒ»В№) * aвҒ»В№)
            simp [mul_assoc] }
      letI : ContinuousSMul G (A Г— G) := by
        refine вҹЁ?_вҹ©
        change Continuous (fun p : G Г— (A Г— G) => (p.2.1, p.2.2 * p.1вҒ»В№))
        exact Continuous.prodMk continuous_snd.fst (continuous_snd.snd.mul continuous_fst.inv)
      let y' : C(A Г— G, HomogTower p G (n + 1)) :=
        вҹЁfun q : A Г— G => (towerAsC p G (n + 1) (y (q.2вҒ»В№ вҖў q.1))) (q.2вҒ»В№),
          continuous_partialTower_equivariant p G A n y hyвҹ©
      have hy' : вҲҖ (a : A Г— G) (b : G),
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom (y' a) =
            y' (b вҖў a) := by
        intro a b
        have hrhs :
            y' (b вҖў a) =
              (towerAsC p G (n + 1)
                ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                    (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom
                  (y (a.2вҒ»В№ вҖў a.1))))
                (b * a.2вҒ»В№) := by
          calc
            y' (b вҖў a)
                = (towerAsC p G (n + 1) (y ((b * a.2вҒ»В№) вҖў a.1))) (b * a.2вҒ»В№) := by
                    change (towerAsC p G (n + 1) (y (((a.2 * bвҒ»В№)вҒ»В№) вҖў a.1))) (((a.2 * bвҒ»В№)вҒ»В№)) =
                      (towerAsC p G (n + 1) (y ((b * a.2вҒ»В№) вҖў a.1))) (b * a.2вҒ»В№)
                    simp [mul_assoc]
            _ = (towerAsC p G (n + 1) (y (b вҖў (a.2вҒ»В№ вҖў a.1)))) (b * a.2вҒ»В№) := by
                  simp [mul_smul]
            _ = (towerAsC p G (n + 1)
                  ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                      (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom
                    (y (a.2вҒ»В№ вҖў a.1))))
                  (b * a.2вҒ»В№) := by
                    rw [вҶҗ hy (a.2вҒ»В№ вҖў a.1) b]
        rw [hrhs]
        change
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom
              ((towerAsC p G (n + 1) (y (a.2вҒ»В№ вҖў a.1))) (a.2вҒ»В№)) =
            (towerAsC p G (n + 1)
              ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                  (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom
                (y (a.2вҒ»В№ вҖў a.1))))
              (b * a.2вҒ»В№)
        convert (ContinuousCohomology.Iobj_ПҒ_apply (R := ZMod p) (G := G)
          (rep := ((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
            (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))))
          (g := b)
          (f := towerAsC p G (n + 1) (y (a.2вҒ»В№ вҖў a.1)))
          (x := b * a.2вҒ»В№)).symm using 1
        simp [mul_assoc]
      let decomp : A Г— (Fin (n + 1) вҶ’ G) вҶ’ (A Г— G) Г— (Fin n вҶ’ G) :=
        fun z => ((z.1, z.2 0), Fin.tail z.2)
      have hcont : Continuous (fun z : (A Г— G) Г— (Fin n вҶ’ G) =>
          towerEval p G (n + 1) (y' z.1) (prefixProdTuple G n z.2)) :=
        ih (A := A Г— G) y' hy'
      have hdecomp : Continuous decomp := by
        have hfst : Continuous (fun z : A Г— (Fin (n + 1) вҶ’ G) => (z.1, z.2 0)) :=
          Continuous.prodMk continuous_fst ((continuous_apply 0).comp continuous_snd)
        have htail : Continuous (fun z : A Г— (Fin (n + 1) вҶ’ G) => Fin.tail z.2) :=
          continuous_snd.finTail
        exact Continuous.prodMk hfst htail
      have hcomp : Continuous (fun z : A Г— (Fin (n + 1) вҶ’ G) =>
          towerEval p G (n + 1) (y' (z.1, z.2 0)) (prefixProdTuple G n (Fin.tail z.2))) := by
        simpa [decomp] using hcont.comp hdecomp
      convert hcomp using 1
      funext z
      have hsmul : (z.2 0) вҖў (z.1, z.2 0) = (z.1, (1 : G)) := by
        change (z.1, z.2 0 * (z.2 0)вҒ»В№) = (z.1, (1 : G))
        simp
      have hПҒ :
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ (z.2 0)).hom
              (y' (z.1, z.2 0)) =
            (towerAsC p G (n + 1) (y z.1)) (1 : G) := by
        rw [hy' (z.1, z.2 0) (z.2 0), hsmul]
        simp [y']
      rw [show z.2 = Fin.cons (z.2 0) (Fin.tail z.2) by
        simp]
      rw [prefixProdTuple_cons]
      change towerEval p G (n + 1) ((towerAsC p G (n + 1) (y z.1)) (1 : G))
          (fun i : Fin (n + 1) => z.2 0 * prefixProdTuple G n (Fin.tail z.2) i) =
        towerEval p G (n + 1) (y' (z.1, z.2 0)) (prefixProdTuple G n (Fin.tail z.2))
      rw [вҶҗ hПҒ]
      rw [towerEval_action]
      simp [mul_assoc]

theorem continuous_homogObj_prefixEval (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) (x : HomogObjType p G n) : Continuous (fun g : Fin n вҶ’ G => towerEval p G (n + 1) x.1 (prefixProdTuple G n g)) := by
  let y : C(PUnit, HomogTower p G (n + 1)) := ContinuousMap.const _ x.1
  have hy :
      вҲҖ (a : PUnit) (b : G),
        (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
            (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom (y a) = y (b вҖў a) := by
    intro a b
    have hx := x.2 b
    simp only [y] at hx вҠў
    exact hx
  have hcont := continuous_towerEval_prefixProd_equivariant p G PUnit n y hy
  have hpre : Continuous (fun g : Fin n вҶ’ G => (PUnit.unit, g)) := by

                ((Action.res _ f).obj X)) := by
      show _ ≫ (iobjMap R f hf _ ≫ (I R G).map _) = _
      simp only [← Category.assoc, iobjMap_const_app R f hf]
      exact ((const R G).naturality (multiIndMap R f hf (n + 1) X)).symm
    have hWhisk :
        (Action.res _ f).map ((I R H).map ((MultiInd.d R H n).app X))
            ≫ multiIndMap R f hf ((n + 1) + 1) X
          = multiIndMap R f hf (n + 1) X ≫
              (I R G).map ((MultiInd.d R G n).app ((Action.res _ f).obj X)) := by

      have step1 := congr_arg ((I R G).map) ih

      simp only [Functor.map_comp] at step1

      have h1 : (Action.res _ f).map ((I R H).map ((MultiInd.d R H n).app X))
            ≫ multiIndMap R f hf ((n + 1) + 1) X
          = iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
              ((I R G).map ((Action.res _ f).map ((MultiInd.d R H n).app X)) ≫
                (I R G).map (multiIndMap R f hf (n + 1) X)) := by

        show _ ≫ (iobjMap R f hf ((MultiInd.functor R H (n + 1)).obj X) ≫
            (I R G).map (multiIndMap R f hf (n + 1) X)) = _

        have specialized : (Action.res (TopModuleCat R) f).map ((I R H).map ((MultiInd.d R H n).app X)) ≫
              iobjMap R f hf ((MultiInd.functor R H (n + 1)).obj X) =
            iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
              (I R G).map ((Action.res (TopModuleCat R) f).map ((MultiInd.d R H n).app X)) :=
          hnat _
        calc (Action.res (TopModuleCat R) f).map ((I R H).map ((MultiInd.d R H n).app X)) ≫
              (iobjMap R f hf ((MultiInd.functor R H (n + 1)).obj X) ≫
                (I R G).map (multiIndMap R f hf (n + 1) X))
            = ((Action.res (TopModuleCat R) f).map ((I R H).map ((MultiInd.d R H n).app X)) ≫
                iobjMap R f hf ((MultiInd.functor R H (n + 1)).obj X)) ≫
                (I R G).map (multiIndMap R f hf (n + 1) X) :=
              (Category.assoc _ _ _).symm
          _ = (iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
                (I R G).map ((Action.res (TopModuleCat R) f).map ((MultiInd.d R H n).app X))) ≫
                (I R G).map (multiIndMap R f hf (n + 1) X) := by rw [specialized]; rfl
          _ = iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
                ((I R G).map ((Action.res (TopModuleCat R) f).map ((MultiInd.d R H n).app X)) ≫
                  (I R G).map (multiIndMap R f hf (n + 1) X)) :=
              Category.assoc _ _ _
      rw [h1]

      refine Eq.trans ?_ rfl

      have : iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
            ((I R G).map ((Action.res (TopModuleCat R) f).map ((MultiInd.d R H n).app X)) ≫
              (I R G).map (multiIndMap R f hf (n + 1) X)) =
          iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫
            ((I R G).map (multiIndMap R f hf n X) ≫
              (I R G).map ((MultiInd.d R G n).app ((Action.res _ f).obj X))) :=
        congr_arg (iobjMap R f hf ((MultiInd.functor R H n).obj X) ≫ ·) step1
      exact this.trans (by rw [← Category.assoc]; rfl)

    apply Action.Hom.ext
    apply ConcreteCategory.coe_ext

    funext c

    show (((Action.res _ f).map ((MultiInd.d R H (n + 1)).app X) ≫
          multiIndMap R f hf ((n + 1) + 1) X).hom.hom c :
        ((MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)).V) =
      ((multiIndMap R f hf (n + 1) X ≫
          (MultiInd.d R G (n + 1)).app ((Action.res _ f).obj X)).hom.hom c :
        ((MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)).V)

    apply ContinuousMap.ext
    intro x

    have hC := congr_arg (fun (u : (Action.res _ f).obj ((MultiInd.functor R H (n + 1)).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)) =>
            (show C(G, _) from u.hom.hom c) x) hConst
    have hW := congr_arg (fun (u : (Action.res _ f).obj ((MultiInd.functor R H (n + 1)).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)) =>
            (show C(G, _) from u.hom.hom c) x) hWhisk
    show (show C(G, _) from ((Action.res _ f).map ((MultiInd.d R H (n + 1)).app X) ≫
          multiIndMap R f hf ((n + 1) + 1) X).hom.hom c) x =
      (show C(G, _) from (multiIndMap R f hf (n + 1) X ≫
          (MultiInd.d R G (n + 1)).app ((Action.res _ f).obj X)).hom.hom c) x

    have hd_H_app : (MultiInd.d R H (n + 1)).app X =
        ((by exact (const R H).app ((MultiInd.functor R H (n + 1)).obj X) :
            (MultiInd.functor R H (n + 1)).obj X ⟶
              (MultiInd.functor R H (n + 1 + 1)).obj X) -
          (by exact (I R H).map ((MultiInd.d R H n).app X) :
            (MultiInd.functor R H (n + 1)).obj X ⟶
              (MultiInd.functor R H (n + 1 + 1)).obj X)) := by
      rw [MultiInd.d_succ]; rfl
    have hd_G_app : (MultiInd.d R G (n + 1)).app ((Action.res _ f).obj X) =
        ((by exact (const R G).app
              ((MultiInd.functor R G (n + 1)).obj ((Action.res _ f).obj X)) :
            (MultiInd.functor R G (n + 1)).obj ((Action.res _ f).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)) -
          (by exact (I R G).map ((MultiInd.d R G n).app ((Action.res _ f).obj X)) :
            (MultiInd.functor R G (n + 1)).obj ((Action.res _ f).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X))) := by
      rw [MultiInd.d_succ]; rfl
    rw [hd_H_app, hd_G_app]

    simp only [Functor.map_sub, Preadditive.sub_comp, Preadditive.comp_sub,
      TopModuleCat.hom_comp, TopModuleCat.hom_sub, Action.sub_hom,
      ContinuousLinearMap.coe_comp', ContinuousLinearMap.coe_sub',
      Function.comp_apply, Pi.sub_apply,
      ContinuousMap.coe_sub, ContinuousMap.sub_apply]
    simp only [TopModuleCat.hom_comp, ContinuousLinearMap.coe_comp',
      Function.comp_apply] at hC hW

    refine congrArg (fun (m : C(G, _)) => m x) ?_
    show (((Action.res _ f).map ((const R H).app ((MultiInd.functor R H (n + 1)).obj X)) ≫
          multiIndMap R f hf (n + 1 + 1) X).hom.hom c -
        ((Action.res _ f).map ((I R H).map ((MultiInd.d R H n).app X)) ≫
          multiIndMap R f hf (n + 1 + 1) X).hom.hom c : C(G, _)) =
      ((multiIndMap R f hf (n + 1) X ≫
          (const R G).app ((MultiInd.functor R G (n + 1)).obj ((Action.res _ f).obj X))).hom.hom c -
        (multiIndMap R f hf (n + 1) X ≫
          (I R G).map ((MultiInd.d R G n).app ((Action.res _ f).obj X))).hom.hom c : C(G, _))
    have hC_c : ((Action.res _ f).map ((const R H).app ((MultiInd.functor R H (n + 1)).obj X)) ≫
          multiIndMap R f hf (n + 1 + 1) X).hom.hom c =
        ((multiIndMap R f hf (n + 1) X ≫
            (const R G).app ((MultiInd.functor R G (n + 1)).obj ((Action.res _ f).obj X))).hom.hom c
            : C(G, _)) :=
      congr_arg (fun (u : (Action.res _ f).obj ((MultiInd.functor R H (n + 1)).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)) =>
            show C(G, _) from u.hom.hom c) hConst
    have hW_c : ((Action.res _ f).map ((I R H).map ((MultiInd.d R H n).app X)) ≫
          multiIndMap R f hf (n + 1 + 1) X).hom.hom c =
        ((multiIndMap R f hf (n + 1) X ≫
            (I R G).map ((MultiInd.d R G n).app ((Action.res _ f).obj X))).hom.hom c
            : C(G, _)) :=
      congr_arg (fun (u : (Action.res _ f).obj ((MultiInd.functor R H (n + 1)).obj X) ⟶
              (MultiInd.functor R G (n + 1 + 1)).obj ((Action.res _ f).obj X)) =>
            show C(G, _) from u.hom.hom c) hWhisk
    rw [hC_c, hW_c]; rfl

end MultiIndMap

section InvariantsRes

variable {G H : Type} [Group G] [Group H]
  [TopologicalSpace G] [TopologicalSpace H]
  [IsTopologicalGroup G] [IsTopologicalGroup H]
  (f : G →* H)

def invariantsRes : invariants R H ⟶ Action.res _ f ⋙ invariants R G where
  app M := TopModuleCat.ofHom
    { toLinearMap :=
        { toFun := fun x => ⟨x.1, fun g => x.2 (f g)⟩
          map_add' := fun _ _ => rfl
          map_smul' := fun _ _ => rfl }
      cont := continuous_induced_rng.mpr continuous_subtype_val }
  naturality _ _ _ := rfl

end InvariantsRes

section MultiIndComplexMap

variable {G H : Type} [Group G] [Group H]
  [TopologicalSpace G] [TopologicalSpace H]
  [IsTopologicalGroup G] [IsTopologicalGroup H]
  (f : G →* H) (hf : Continuous f)

def multiIndComplexMap (X : Action (TopModuleCat R) H) :
    ((Action.res _ f).mapHomologicalComplex _).obj
        ((MultiInd.complex R H).asFunctor.obj X) ⟶
      (MultiInd.complex R G).asFunctor.obj ((Action.res _ f).obj X) where
  f n := multiIndMap R f hf n X
  comm' i j hij := by

    obtain rfl : i + 1 = j := hij

    have eqH : ((MultiInd.complex R H).d i (i + 1)) = MultiInd.d R H i := by
      simp [MultiInd.complex]
    have eqG : ((MultiInd.complex R G).d i (i + 1)) = MultiInd.d R G i := by
      simp [MultiInd.complex]
    show multiIndMap R f hf i X ≫ ((MultiInd.complex R G).d i (i + 1)).app _ =
        (Action.res _ f).map (((MultiInd.complex R H).d i (i + 1)).app X) ≫
          multiIndMap R f hf (i + 1) X
    rw [eqH, eqG]
    exact (multiIndMap_d R f hf i X).symm

@[simp]
lemma multiIndComplexMap_f (X : Action (TopModuleCat R) H) (n : ℕ) :
    (multiIndComplexMap R f hf X).f n = multiIndMap R f hf n X := rfl

end MultiIndComplexMap

section CochainsMap

variable {G H : Type} [Group G] [Group H]
  [TopologicalSpace G] [TopologicalSpace H]
  [IsTopologicalGroup G] [IsTopologicalGroup H]
  (f : G →* H) (hf : Continuous f)

def cochainsMap (X : Action (TopModuleCat R) H) :
    (homogeneousCochains R H).obj X ⟶
      (homogeneousCochains R G).obj ((Action.res _ f).obj X) :=
  ((ComplexShape.embeddingUp'Add 1 1).restrictionFunctor (TopModuleCat R)).map
    ((NatTrans.mapHomologicalComplex (invariantsRes R f) _).app
        ((MultiInd.complex R H).asFunctor.obj X) ≫
      ((invariants R G).mapHomologicalComplex _).map (multiIndComplexMap R f hf X))

end CochainsMap

section TrivialCoeffMap

variable {G H : Type} [Group G] [Group H]
  [TopologicalSpace G] [TopologicalSpace H]
  [IsTopologicalGroup G] [IsTopologicalGroup H]
  (f : G →* H) (hf : Continuous f)

lemma res_trivial_eq (X : TopModuleCat R) :
    (Action.res _ f).obj (Action.trivial H X) = Action.trivial G X := rfl

@[simps! hom_hom inv_hom]
def resTrivialIso (X : TopModuleCat R) :
    (Action.res _ f).obj (Action.trivial H X) ≅ Action.trivial G X :=
  Iso.refl _

noncomputable def cochainsMapTrivial (X : TopModuleCat R) :
    (homogeneousCochains R H).obj (Action.trivial H X) ⟶
      (homogeneousCochains R G).obj (Action.trivial G X) :=
  cochainsMap R f hf (Action.trivial H X)

noncomputable def cohomologyMapTrivial (X : TopModuleCat R) (n : ℕ) :
    (continuousCohomology R H n).obj (Action.trivial H X) ⟶
      (continuousCohomology R G n).obj (Action.trivial G X) :=
  HomologicalComplex.homologyMap (cochainsMapTrivial R f hf X) n

end TrivialCoeffMap


    simpa [Function.comp] using
      (Real.fourier_comp_linearIsometry
        (A := (LinearIsometryEquiv.neg ℝ : ℝ ≃ₗᵢ[ℝ] ℝ)) (f := ψ) (w := ξ))
  refine CompactFreqKernel.mk ?_ ?_ ?_ ?_ ?_
  · exact hψ.continuous.comp continuous_neg
  · simpa using hψ.integrable.comp_mul_left' (show (-1 : ℝ) ≠ 0 by norm_num)
  · rw [hfourier]
    simpa [Function.comp] using hψ.fourier_continuous.comp continuous_neg
  · rw [hfourier]
    simpa [Function.comp] using
      hψ.fourier_compact.comp_homeomorph (Homeomorph.neg ℝ)
  · have hmass : (∫ u : ℝ, ψ (-u)) = ∫ u : ℝ, ψ u := by
      simpa using (MeasureTheory.Measure.integral_comp_mul_left (g := ψ) (-1 : ℝ))
    exact hmass.trans hψ.mass_one


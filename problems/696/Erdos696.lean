            have h_floor_le : (⌊Real.exp y_target⌋₊ : ℝ) ≤ Real.exp y_target :=
              Nat.floor_le (Real.exp_pos _).le
            have : (⌊Real.exp y_target⌋₊ : ℝ) < (q : ℝ) := lt_of_le_of_lt h_floor_le this

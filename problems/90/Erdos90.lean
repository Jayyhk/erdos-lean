    simpa [T] using (NumberField.finite_of_discr_bdd (A := AlgebraicClosure F) (N := B))
  let g : {L : IntermediateField F (AlgebraicClosure F) |
      ∃ _ : NumberField L, |NumberField.discr L| ≤ B} → T :=
    fun L =>
      letI : NumberField L.1 := Classical.choose L.2
      have hdisc : |NumberField.discr L.1| ≤ B := Classical.choose_spec L.2
      ⟨⟨L.1.restrictScalars ℚ, by
          change FiniteDimensional ℚ L.1
          infer_instance⟩, by
          simpa using hdisc⟩

    simpa [Polynomial.eval_comp, add_comm, add_left_comm, add_assoc] using hc0
  rcases hspecial hshift_deg hshift0 badPrimes with вҹЁq, hqprime, hqnotmem, n, hnвҹ©
  refine вҹЁq, hqprime, hqnotmem, n + c, ?_вҹ©
  simpa [Polynomial.eval_comp, add_comm, add_left_comm, add_assoc] using hn

theorem minpoly_discr_ne_zero (K : Type) [Field K] [NumberField K] {Оё : NumberField.RingOfIntegers K} :
    Polynomial.discr (minpoly в„Ө Оё) вү  0 := by
  classical
  let f : Polynomial в„Ө := minpoly в„Ө Оё
  let ПҶ : в„Ө вҶ’+* в„ҡ := Int.castRingHom в„ҡ
  let fQ : Polynomial в„ҡ := f.map ПҶ
  have hОёintO : IsIntegral в„Ө Оё := by
    let hAI : Algebra.IsIntegral в„Ө (NumberField.RingOfIntegers K) := inferInstance
    exact (Algebra.isIntegral_def.mp hAI) Оё
  have hОёint : IsIntegral в„Ө ((Оё : K)) := NumberField.RingOfIntegers.isIntegral_coe Оё
  have hfQ_eq : fQ = minpoly в„ҡ ((Оё : K)) := by
    dsimp [fQ, f]
    symm
    simpa [NumberField.RingOfIntegers.minpoly_coe Оё] using
      (minpoly.isIntegrallyClosed_eq_field_fractions' (R := в„Ө) (K := в„ҡ) (S := K) hОёint)
  have hsepQ : fQ.Separable := by
    rw [hfQ_eq]
    exact (show (minpoly в„ҡ ((Оё : K))).Separable from IsSeparable.of_integral в„ҡ ((Оё : K)))
  have hf_monic : f.Monic := by
    dsimp [f]
    exact minpoly.monic hОёintO
  have hfQ_monic : fQ.Monic := by
    dsimp [fQ]
    exact hf_monic.map ПҶ
  have hf_deg : 0 < f.degree := by
    dsimp [f]
    simpa using minpoly.degree_pos hОёintO
  have hfQ_natDegree : fQ.natDegree = f.natDegree := by
    dsimp [fQ]
    simpa using hf_monic.natDegree_map ПҶ
  have hcopQ : IsCoprime fQ fQ.derivative := (Polynomial.separable_def _).mp hsepQ
  have hresQ0 : fQ.resultant fQ.derivative вү  0 :=
    Polynomial.resultant_ne_zero _ _ hcopQ
  have hresQ_eq : fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) = fQ.resultant fQ.derivative := by
    let k : в„• := (fQ.natDegree - 1) - fQ.derivative.natDegree
    have hkdeg : fQ.derivative.natDegree вүӨ fQ.natDegree - 1 := Polynomial.natDegree_derivative_le fQ
    have htmp :=
      Polynomial.resultant_add_right_deg (f := fQ) (g := fQ.derivative)
        (m := fQ.natDegree) (n := fQ.derivative.natDegree) k (by exact le_rfl)
    dsimp [k] at htmp
    rw [Nat.add_sub_of_le hkdeg] at htmp
    simpa [hfQ_monic.leadingCoeff] using htmp
  have hresQ : fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) вү  0 := by
    rw [hresQ_eq]
    exact hresQ0
  have hderiv_map : fQ.derivative = f.derivative.map ПҶ := by
    dsimp [fQ]
    simp
  have hres_map :
      fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) =
        ПҶ (f.resultant f.derivative f.natDegree (f.natDegree - 1)) := by
    rw [hderiv_map, hfQ_natDegree]
    simp [fQ]
  have hformulaQ :
      fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) =
        ((-1 : в„ҡ) ^ (f.natDegree * (f.natDegree - 1) / 2)) * ПҶ f.discr := by
    rw [hres_map, Polynomial.resultant_deriv (f := f) hf_deg]
    simp [hf_monic.leadingCoeff]
  have hcast_discr_ne_zero : ПҶ f.discr вү  0 := by
    intro hzero
    have hresQ' := hresQ
    rw [hformulaQ, hzero] at hresQ'
    simp at hresQ'
  intro hzero
  apply hcast_discr_ne_zero
  simpa [hzero]

theorem minpoly_mod_separable_of_not_dvd_discr (K : Type) [Field K] [NumberField K] {Оё : NumberField.RingOfIntegers K}
    (p : в„•) [Fact p.Prime]
    (hdisc : В¬ p вҲЈ (Polynomial.discr (minpoly в„Ө Оё)).natAbs) :
    (Polynomial.map (Int.castRingHom (ZMod p)) (minpoly в„Ө Оё)).Separable := by
  set ПҶ : в„Ө вҶ’+* ZMod p := Int.castRingHom (ZMod p)
  set f : Polynomial в„Ө := minpoly в„Ө Оё
  set fbar : Polynomial (ZMod p) := Polynomial.map ПҶ f
  have hf_monic : f.Monic := by
    simpa [f] using minpoly.monic Оё.isIntegral
  have hfbar_monic : fbar.Monic := by
    simpa [fbar] using Polynomial.Monic.map ПҶ hf_monic
  have hdegmap : fbar.natDegree = f.natDegree := by
    simpa [fbar] using hf_monic.natDegree_map ПҶ
  have hdisc_zmod_ne : ((Polynomial.discr f : в„Ө) : ZMod p) вү  0 := by
    intro hzero
    apply hdisc
    exact Int.natCast_dvd.mp <| (ZMod.intCast_zmod_eq_zero_iff_dvd (Polynomial.discr f) p).mp hzero
  have hres0 :
      fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) =
        (-1 : ZMod p) ^ (fbar.natDegree * (fbar.natDegree - 1) / 2) *
          ((Polynomial.discr f : в„Ө) : ZMod p) := by
    have hres0' := congrArg ПҶ (Polynomial.resultant_deriv (f := f) (by simpa [f] using minpoly.degree_pos Оё.isIntegral))
    rw [вҶҗ Polynomial.resultant_map_map (ПҶ := ПҶ) (f := f) (g := f.derivative)
      (m := f.natDegree) (n := f.natDegree - 1), вҶҗ Polynomial.derivative_map] at hres0'
    simpa [fbar, hdegmap, hf_monic.leadingCoeff] using hres0'
  have hres0_ne : fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) вү  0 := by
    rw [hres0]
    exact mul_ne_zero (pow_ne_zero _ (by simp)) hdisc_zmod_ne
  have hres_eq :
      fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) =
        fbar.resultant fbar.derivative := by
    have h :=
      Polynomial.resultant_add_right_deg (f := fbar) (g := fbar.derivative) (m := fbar.natDegree)
        (n := fbar.derivative.natDegree)
        (k := fbar.natDegree - 1 - fbar.derivative.natDegree) le_rfl
    rw [Nat.add_sub_of_le (Polynomial.natDegree_derivative_le fbar), hfbar_monic.coeff_natDegree,
      one_pow, one_mul] at h
    simpa using h
  have hres_ne : fbar.resultant fbar.derivative вү  0 := by
    rw [вҶҗ hres_eq]
    exact hres0_ne
  rw [Polynomial.separable_def]
  exact (Polynomial.isUnit_resultant_iff_isCoprime hfbar_monic).mp (isUnit_iff_ne_zero.mpr hres_ne)

theorem numberField_exists_integral_primitive_element (K : Type) [Field K] [NumberField K] :
    вҲғ Оё : NumberField.RingOfIntegers K,
      IntermediateField.adjoin в„ҡ ({(Оё : K)} : Set K) = вҠӨ := by
  classical
  obtain вҹЁОұ, hОұвҹ© := Field.exists_primitive_element в„ҡ K
  obtain вҹЁy, hy, hyОұвҹ© := exists_integral_multiples в„Ө в„ҡ ({Оұ} : Finset K)
  let Оё : NumberField.RingOfIntegers K := вҹЁy вҖў Оұ, hyОұ Оұ (by simp)вҹ©
  refine вҹЁОё, ?_вҹ©
  set L : IntermediateField в„ҡ K := IntermediateField.adjoin в„ҡ ({(Оё : K)} : Set K)
  have hy_mem : algebraMap в„ҡ K (y : в„ҡ) вҲҲ L :=
    IntermediateField.algebraMap_mem L (y : в„ҡ)
  have hy_inv_mem : (algebraMap в„ҡ K (y : в„ҡ))вҒ»В№ вҲҲ L :=
    IntermediateField.inv_mem L hy_mem
  have hОё_mem : (Оё : K) вҲҲ L := by
    change (Оё : K) вҲҲ IntermediateField.adjoin в„ҡ ({(Оё : K)} : Set K)
    exact IntermediateField.subset_adjoin в„ҡ ({(Оё : K)} : Set K) (by simp)
  have hmem : Оұ вҲҲ L := by
    have hmul_mem : (algebraMap в„ҡ K (y : в„ҡ))вҒ»В№ * (Оё : K) вҲҲ L :=
      IntermediateField.mul_mem L hy_inv_mem hОё_mem
    have hEq : (algebraMap в„ҡ K (y : в„ҡ))вҒ»В№ * (Оё : K) = Оұ := by
      change (algebraMap в„ҡ K (y : в„ҡ))вҒ»В№ * (y вҖў Оұ) = Оұ
      simp [smul_eq_mul, hy, mul_assoc]
    exact hEq в–ё hmul_mem
  have hle := (IntermediateField.adjoin_simple_le_iff (F := в„ҡ) (Оұ := Оұ) (K := L)).2 hmem
  have htop_le : (вҠӨ : IntermediateField в„ҡ K) вүӨ L := by
    simpa [hОұ] using hle
  have hL_top : L = вҠӨ := le_antisymm le_top htop_le
  simpa [L] using hL_top

open NumberField in
theorem prime_above_ef_one_of_not_dvd_exponent_discr_and_eval (K : Type) [Field K] [NumberField K] {Оё : NumberField.RingOfIntegers K}
    (p : в„•) [Fact p.Prime]
    (hexp : В¬ p вҲЈ RingOfIntegers.exponent Оё)
    (hdisc : В¬ p вҲЈ (Polynomial.discr (minpoly в„Ө Оё)).natAbs)
    {n : в„Ө} (hn : (p : в„Ө) вҲЈ Polynomial.eval n (minpoly в„Ө Оё)) :
    вҲғ рқ”“ вҲҲ (Ideal.span {(p : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K),
      Ideal.ramificationIdx (Ideal.span {(p : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
      Ideal.inertiaDeg (Ideal.span {(p : в„Ө)} : Ideal в„Ө) рқ”“ = 1 := by
  classical
  let f : Polynomial в„Ө := minpoly в„Ө Оё
  let fbar : Polynomial (ZMod p) := Polynomial.map (Int.castRingHom (ZMod p)) f
  let a : ZMod p := n
  have hfbar_ne : fbar вү  0 := by
    dsimp [fbar, f]
    exact Polynomial.map_monic_ne_zero (minpoly.monic Оё.isIntegral)
  have hroot_eval : Polynomial.eval a fbar = 0 := by
    dsimp [fbar, a, f]
    rw [Polynomial.eval_intCast_map]
    exact (ZMod.intCast_zmod_eq_zero_iff_dvd (Polynomial.eval n (minpoly в„Ө Оё)) p).2 hn
  have hisroot : Polynomial.IsRoot fbar a := hroot_eval
  have hdvd : Polynomial.X - Polynomial.C a вҲЈ fbar := by
    exact (Polynomial.dvd_iff_isRoot).2 hisroot
  have hmem : Polynomial.X - Polynomial.C a вҲҲ RingOfIntegers.monicFactorsMod Оё p := by
    rw [RingOfIntegers.monicFactorsMod, Multiset.mem_toFinset]
    exact (Polynomial.mem_normalizedFactors_iff hfbar_ne).2
      вҹЁPolynomial.irreducible_X_sub_C a, Polynomial.monic_X_sub_C a, hdvdвҹ©
  let Q : RingOfIntegers.monicFactorsMod Оё p := вҹЁPolynomial.X - Polynomial.C a, hmemвҹ©
  let P : (Ideal.span {(p : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K) :=
    (NumberField.Ideal.primesOverSpanEquivMonicFactorsMod (Оё := Оё) (p := p) hexp).symm Q
  refine вҹЁP, P.2, ?_, ?_вҹ©
  В· have hsep : fbar.Separable := by
      simpa [fbar, f] using minpoly_mod_separable_of_not_dvd_discr K p hdisc
    have hpos : 0 < Polynomial.rootMultiplicity a fbar :=
      (Polynomial.rootMultiplicity_pos hfbar_ne).2 hisroot
    have hle : Polynomial.rootMultiplicity a fbar вүӨ 1 :=
      Polynomial.rootMultiplicity_le_one_of_separable hsep a
    have hrootmult : Polynomial.rootMultiplicity a fbar = 1 := by
      omega
    have hmult : multiplicity (Polynomial.X - Polynomial.C a) fbar = 1 := by
      rw [вҶҗ hrootmult]
      rw [Polynomial.rootMultiplicity_eq_multiplicity fbar a]
      simp [hfbar_ne]
    simpa [P, Q, fbar] using
      (NumberField.Ideal.ramificationIdx_primesOverSpanEquivMonicFactorsMod_symm_apply'
        (Оё := Оё) (p := p) hexp hmem).trans hmult
  В· simpa [P, Q] using
      (NumberField.Ideal.inertiaDeg_primesOverSpanEquivMonicFactorsMod_symm_apply'
        (Оё := Оё) (p := p) hexp hmem).trans (Polynomial.natDegree_X_sub_C a)

open NumberField in
theorem primewise_split_descends_of_tower (K L : Type) [Field K] [Field L] [NumberField K] [NumberField L]
    [Algebra в„ҡ K] [Algebra в„ҡ L] [Algebra K L] [IsScalarTower в„ҡ K L]
    (q : в„•) (_hq : q.Prime)
    (hL :
      вҲҖ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1) :
    вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K),
      Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
      Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
  intro рқ”ӯ hрқ”ӯ
  let p : Ideal в„Ө := Ideal.span {(q : в„Ө)}
  letI : Fact q.Prime := вҹЁ_hqвҹ©
  letI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime q)
  let pK : p.primesOver (рқ“һ K) := вҹЁрқ”ӯ, by simpa [p] using hрқ”ӯвҹ©
  letI : рқ”ӯ.IsPrime := Ideal.primesOver.isPrime p pK
  letI : рқ”ӯ.LiesOver p := Ideal.primesOver.liesOver p pK
  letI : рқ”ӯ.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p] using hрқ”ӯ)
  obtain вҹЁPsubвҹ© := Ideal.nonempty_primesOver (R := рқ“һ K) (S := рқ“һ L) рқ”ӯ
  let рқ”“ : Ideal (рқ“һ L) := Psub
  letI : рқ”“.IsPrime := Ideal.primesOver.isPrime рқ”ӯ Psub
  letI : рқ”“.LiesOver рқ”ӯ := Ideal.primesOver.liesOver рқ”ӯ Psub
  letI : рқ”“.LiesOver p := Ideal.LiesOver.trans рқ”“ рқ”ӯ p
  have hрқ”“ : рқ”“ вҲҲ p.primesOver (рқ“һ L) := by
    exact (Ideal.primesOver.mk p рқ”“).2
  rcases hL рқ”“ (by simpa [p] using hрқ”“) with вҹЁheрқ”“, hfрқ”“вҹ©
  have hp_ne_bot : p вү  вҠҘ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast _hq.ne_zero
  have hрқ”ӯ_ne_bot : рқ”ӯ вү  вҠҘ := Ideal.ne_bot_of_liesOver_of_ne_bot hp_ne_bot рқ”ӯ
  have hmap_рқ”ӯ_ne_bot : Ideal.map (algebraMap (рқ“һ K) (рқ“һ L)) рқ”ӯ вү  вҠҘ :=
    Ideal.map_ne_bot_of_ne_bot hрқ”ӯ_ne_bot
  have hmap_p_ne_bot : Ideal.map (algebraMap в„Ө (рқ“һ L)) p вү  вҠҘ :=
    Ideal.map_ne_bot_of_ne_bot hp_ne_bot
  have hmap_рқ”ӯ_le : Ideal.map (algebraMap (рқ“һ K) (рқ“һ L)) рқ”ӯ вүӨ рқ”“ := by
    rw [Ideal.map_le_iff_le_comap]
    exact le_of_eq (by simpa [Ideal.under_def] using (Ideal.over_def (A := рқ“һ K) (P := рқ”“) (p := рқ”ӯ)))
  have hram_tower :=
    Ideal.ramificationIdx_algebra_tower (R := в„Ө) (S := рқ“һ K) (T := рқ“һ L)
      (p := p) (P := рқ”ӯ) (Q := рқ”“) hmap_рқ”ӯ_ne_bot hmap_p_ne_bot hmap_рқ”ӯ_le
  have hmul_e : Ideal.ramificationIdx p рқ”ӯ * Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := by
    calc
      Ideal.ramificationIdx p рқ”ӯ * Ideal.ramificationIdx рқ”ӯ рқ”“
          = Ideal.ramificationIdx p рқ”“ := by simpa [p] using hram_tower.symm
      _ = 1 := by simpa [p] using heрқ”“
  have heрқ”ӯ : Ideal.ramificationIdx p рқ”ӯ = 1 := (mul_eq_one.mp hmul_e).1
  have hmul_f : Ideal.inertiaDeg p рқ”ӯ * Ideal.inertiaDeg рқ”ӯ рқ”“ = 1 := by
    calc
      Ideal.inertiaDeg p рқ”ӯ * Ideal.inertiaDeg рқ”ӯ рқ”“
          = Ideal.inertiaDeg p рқ”“ := by
              simpa [p] using (Ideal.inertiaDeg_algebra_tower (R := в„Ө) (S := рқ“һ K) (T := рқ“һ L) p рқ”ӯ рқ”“).symm
      _ = 1 := by simpa [p] using hfрқ”“
  have hfрқ”ӯ : Ideal.inertiaDeg p рқ”ӯ = 1 := (mul_eq_one.mp hmul_f).1
  exact вҹЁby simpa [p] using heрқ”ӯ, by simpa [p] using hfрқ”ӯвҹ©

open NumberField in
theorem primewise_split_in_cyclotomic4_implies_mod4 (C : Type) [Field C] [NumberField C] [Algebra в„ҡ C] [IsCyclotomicExtension {4} в„ҡ C]
    (q : в„•) (_hq : q.Prime)
    (hC :
      вҲҖ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ C),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1) :
    q % 4 = 1 := by
  classical
  let alg : Algebra в„ҡ C := inferInstance
  have hCyclo_old : @IsCyclotomicExtension ({4} : Set в„•) в„ҡ C _ _ alg := inferInstance
  letI : Algebra в„ҡ C := DivisionRing.toRatAlgebra
  have hAlg : alg = (inferInstance : Algebra в„ҡ C) := Subsingleton.elim _ _
  have hCyclo : IsCyclotomicExtension ({4} : Set в„•) в„ҡ C := by
    have hCyclo_old' := hCyclo_old
    rw [hAlg] at hCyclo_old'
    exact hCyclo_old'
  letI : IsCyclotomicExtension ({4} : Set в„•) в„ҡ C := hCyclo
  letI : Fact q.Prime := вҹЁ_hqвҹ©
  letI : (Ideal.span {(q : в„Ө)} : Ideal в„Ө).IsMaximal := Int.ideal_span_isMaximal_of_prime q
  obtain вҹЁвҹЁрқ”“, hрқ”“prime, hрқ”“overвҹ©вҹ© := (Ideal.span {(q : в„Ө)} : Ideal в„Ө).nonempty_primesOver (S := рқ“һ C)
  letI : рқ”“.IsPrime := hрқ”“prime
  letI : рқ”“.LiesOver (Ideal.span {(q : в„Ө)} : Ideal в„Ө) := hрқ”“over
  rcases hC рқ”“ вҹЁhрқ”“prime, hрқ”“overвҹ© with вҹЁhRam, hInerвҹ©
  by_cases hq2 : q = 2
  В· subst hq2
    letI : IsCyclotomicExtension ({2 ^ (1 + 1)} : Set в„•) в„ҡ C := by
      simpa using (inferInstance : IsCyclotomicExtension ({4} : Set в„•) в„ҡ C)
    have hramP : Ideal.ramificationIdx (Ideal.span {(2 : в„Ө)} : Ideal в„Ө) рқ”“ = 2 := by
      simpa using
        (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_prime_pow (p := 2) (k := 1)
          (K := C) (P := рқ”“))
    have : (1 : в„•) = 2 := by
      calc
        1 = Ideal.ramificationIdx (Ideal.span {(2 : в„Ө)} : Ideal в„Ө) рқ”“ := hRam.symm
        _ = 2 := hramP
    omega
  В· have hq4 : В¬ q вҲЈ 4 := by
      intro hdiv
      have hdiv' : q вҲЈ 2 ^ 2 := by simpa using hdiv
      have hdiv2 : q вҲЈ 2 := _hq.dvd_of_dvd_pow hdiv'
      have hqle : q вүӨ 2 := Nat.le_of_dvd (by norm_num) hdiv2
      have hqge : 2 вүӨ q := _hq.two_le
      omega
    have horder : orderOf (q : ZMod 4) = 1 := by
      have hcalc : Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = orderOf (q : ZMod 4) := by
        simpa using
          (IsCyclotomicExtension.Rat.inertiaDeg_eq_of_not_dvd (p := q) (m := 4)
            (K := C) (P := рқ”“) hq4)
      calc
        orderOf (q : ZMod 4) = Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ := hcalc.symm
        _ = 1 := hIner
    have hz : (q : ZMod 4) = 1 := (orderOf_eq_one_iff.mp horder)
    simpa [ZMod.val_natCast] using congrArg ZMod.val hz

open NumberField in
theorem primewise_split_transport_of_algEquiv (K L : Type) [Field K] [Field L] [NumberField K] [NumberField L]
    [Algebra в„ҡ K] [Algebra в„ҡ L]
    (e : K вүғвӮҗ[в„ҡ] L) (q : в„•) (_hq : q.Prime)
    (hL :
      вҲҖ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1) :
    вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ K),
      Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
      Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
  intro рқ”ӯ hрқ”ӯ
  let pZ : Ideal в„Ө := Ideal.span {(q : в„Ө)}
  let eрқ“һ : рқ“һ K вүғвӮҗ[в„Ө] рқ“һ L :=
    AlgEquiv.ofRingEquiv
      (f := NumberField.RingOfIntegers.mapRingEquiv e.toRingEquiv)
      (by
        intro z
        simp)
  have hprime : рқ”ӯ.IsPrime := by
    exact Ideal.primesOver.isPrime (Q := (вҹЁрқ”ӯ, hрқ”ӯвҹ© : pZ.primesOver (рқ“һ K)))
  have hlies : рқ”ӯ.LiesOver pZ := by
    exact Ideal.primesOver.liesOver (Q := (вҹЁрқ”ӯ, hрқ”ӯвҹ© : pZ.primesOver (рқ“һ K)))
  have hmap_mem : Ideal.map eрқ“һ рқ”ӯ вҲҲ pZ.primesOver (рқ“һ L) := by
    letI : рқ”ӯ.IsPrime := hprime
    letI : рқ”ӯ.LiesOver pZ := hlies
    letI : (Ideal.map eрқ“һ рқ”ӯ).IsPrime := Ideal.map_isPrime_of_equiv eрқ“һ
    letI : (Ideal.map eрқ“һ рқ”ӯ).LiesOver pZ :=
      Ideal.map_equiv_liesOver (P := рқ”ӯ) (p := pZ) (Пғ := eрқ“һ)
    exact (Ideal.primesOver.mk pZ (Ideal.map eрқ“һ рқ”ӯ)).2
  rcases hL (Ideal.map eрқ“һ рқ”ӯ) hmap_mem with вҹЁh_ram, h_inertвҹ©
  constructor
  В· rwa [Ideal.ramificationIdx_map_eq (p := pZ) (P := рқ”ӯ) (e := eрқ“һ)] at h_ram
  В· letI : Fact q.Prime := вҹЁ_hqвҹ©
    letI : pZ.IsMaximal := Int.ideal_span_isMaximal_of_prime q
    rwa [Ideal.inertiaDeg_map_eq (p := pZ) (P := рқ”ӯ) (e := eрқ“һ)] at h_inert

open NumberField in
theorem proposition_3_6_frattini_fixedField_exists
    (hFG : Hyp_FiniteTopologicalRank) (F : Type) [Field F] [NumberField F] :
    вҲғ (M : IntermediateField F (maximalUnramifiedProPF F 3))
      (_ : FiniteDimensional F M) (_ : NumberField M) (_ : IsGalois F M),
      IsEverywhereUnramified F M вҲ§
      M.fixingSubgroup =
        closedFrattini 3 (MaxUnramifiedProPGaloisGroup F 3) := by
  let G := MaxUnramifiedProPGaloisGroup F 3
  let K := maximalUnramifiedProPF F 3
  letI : IsGalois F K := MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F 3
  let H : OpenNormalSubgroup G :=
    { __ := closedFrattini 3 G
      isOpen' := closedFrattini_isOpen G 3
        (MaxUnramifiedProPGaloisGroup.isFinitelyGeneratedProPGroup hFG (F := F) (p := 3))
      isNormal' := closedFrattini_normal (p := 3) (G := G) }
  let M : IntermediateField F K := IntermediateField.fixedField (H : Subgroup G)
  have hfg : FiniteDimensional F M вҲ§ IsGalois F M :=
    fixedField_openNormal_finiteGalois (k := F) (K := K) H
  have hfin : FiniteDimensional F M := hfg.1
  have hgalois : IsGalois F M := hfg.2
  let _ : NumberField M := NumberField.of_module_finite F M
  have hfix : M.fixingSubgroup = (H : Subgroup G) := by
    let Hc : ClosedSubgroup G :=
      { toSubgroup := (H : Subgroup G)
        isClosed' := by
          simpa using H.isClosed }
    simpa [M] using (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc)
  refine вҹЁM, hfin, inferInstance, hgalois, ?_, ?_вҹ©
  В· exact finiteIntermediate_isUnramified (F := F) (p := 3) (L := M)
  В· simpa [H, G] using hfix

open NumberField in
def proposition_3_6_goodPrime
    (F : Type) [Field F] [NumberField F] (q : в„•) : Prop :=
  q.Prime вҲ§
    q % 4 = 1 вҲ§
    ((вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1) вҲ§
      ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F)).ncard =
        Module.finrank в„ҡ F) вҲ§
    (вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ),
      рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F) вҶ’
      splittingDetectorAt F 3 рқ”ӯ hp hne вҲҲ
        closedFrattini 3 (MaxUnramifiedProPGaloisGroup F 3))

open NumberField in
open NumberField.InfinitePlace in
theorem proposition_3_6_aux_extension_exists
    (hFG : Hyp_FiniteTopologicalRank)
    (F : Type) [Field F] [NumberField F] [IsTotallyReal F]
    (_hcubic : Module.finrank в„ҡ F = 3) :
    вҲғ (L : FiniteGaloisIntermediateField в„ҡ (AlgebraicClosure в„ҡ)) (_ : NumberField L),
      вҲҖ q : в„•,
        (q.Prime вҲ§
          (вҲҖ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
              Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
              Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1) вҲ§
          ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L)).ncard =
            Module.finrank в„ҡ L) вҶ’
        proposition_3_6_goodPrime F q := by
  classical
  letI : IsAlgClosure в„ҡ (AlgebraicClosure в„ҡ) := AlgebraicClosure.instIsAlgClosure в„ҡ
  letI : IsGalois в„ҡ (AlgebraicClosure в„ҡ) := IsAlgClosure.isGalois в„ҡ (AlgebraicClosure в„ҡ)
  rcases proposition_3_6_frattini_fixedField_exists hFG F with вҹЁM, hfdM, hnumM, hgalM, hMunr, hMfixвҹ©
  let Kmax := maximalUnramifiedProPF F 3
  haveI : IsGalois F Kmax := MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F 3
  have hopen_hnormal : IsOpen (M.fixingSubgroup : Set (Gal(Kmax/F))) вҲ§ M.fixingSubgroup.Normal := by
    exact (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := F) (K := Kmax) M).2 вҹЁhfdM, hgalMвҹ©
  have hnormal : M.fixingSubgroup.Normal := hopen_hnormal.2
  have hG : IsFinitelyGeneratedProPGroup 3 (MaxUnramifiedProPGaloisGroup F 3) :=
    MaxUnramifiedProPGaloisGroup.isFinitelyGeneratedProPGroup hFG F 3
  have hpquot : IsPGroup 3 (Gal(Kmax/F) в§ё M.fixingSubgroup) := by
    exact @IsFinitelyGeneratedProPGroup.isPGroup_quotient 3 (MaxUnramifiedProPGaloisGroup F 3) _ _ _ hG M.fixingSubgroup hnormal hopen_hnormal.1
  let H : ClosedSubgroup (Gal(Kmax/F)) :=
    { toSubgroup := M.fixingSubgroup
      isClosed' := Subgroup.isClosed_of_isOpen _ hopen_hnormal.1 }
  have hfixM : IntermediateField.fixedField (H : Subgroup Gal(Kmax/F)) = M := by
    simpa [H] using (InfiniteGalois.fixedField_fixingSubgroup (k := F) (K := Kmax) M)
  let eFix : IntermediateField.fixedField (H : Subgroup Gal(Kmax/F)) вүғвӮҗ[F] M :=
    IntermediateField.equivOfEq hfixM
  haveI : (H : Subgroup Gal(Kmax/F)).Normal := by
    change M.fixingSubgroup.Normal
    exact hopen_hnormal.2
  let hquotM : Gal(Kmax/F) в§ё M.fixingSubgroup вүғ* (M вүғвӮҗ[F] M) := by
    simpa [H] using (InfiniteGalois.normalAutEquivQuotient (k := F) (K := Kmax) H).trans (AlgEquiv.autCongr eFix)
  have hpM : IsPGroup 3 (M вүғвӮҗ[F] M) := IsPGroup.of_equiv hpquot hquotM
  let eM : M вҶ’вӮҗ[в„ҡ] AlgebraicClosure в„ҡ := IsAlgClosed.lift
  let M0 : IntermediateField в„ҡ (AlgebraicClosure в„ҡ) := eM.fieldRange
  let eMfield : M вүғвӮҗ[в„ҡ] M0 := AlgEquiv.ofInjectiveField eM
  letI : FiniteDimensional в„ҡ M0 := eMfield.toLinearEquiv.finiteDimensional
  letI : NumberField M0 := NumberField.of_module_finite в„ҡ M0
  let eC : CyclotomicField 4 в„ҡ вҶ’вӮҗ[в„ҡ] AlgebraicClosure в„ҡ := IsAlgClosed.lift
  let C0 : IntermediateField в„ҡ (AlgebraicClosure в„ҡ) := eC.fieldRange
  let eCfield : CyclotomicField 4 в„ҡ вүғвӮҗ[в„ҡ] C0 := AlgEquiv.ofInjectiveField eC
  letI : FiniteDimensional в„ҡ C0 := eCfield.toLinearEquiv.finiteDimensional
  letI : NumberField C0 := NumberField.of_module_finite в„ҡ C0
  obtain вҹЁL, hM0L, hC0Lвҹ© := finiteGaloisIntermediateField_contains_two_subfields M0 C0
  letI : NumberField L := NumberField.of_module_finite в„ҡ L
  refine вҹЁL, inferInstance, ?_вҹ©
  intro q hq
  rcases hq with вҹЁhqprime, hsplitL, hcardLвҹ©
  let LM0 : IntermediateField M0 (AlgebraicClosure в„ҡ) := IntermediateField.extendScalars hM0L
  let LC0 : IntermediateField C0 (AlgebraicClosure в„ҡ) := IntermediateField.extendScalars hC0L
  letI : NumberField вҶҘLM0 := by
    simpa [LM0] using (inferInstance : NumberField вҶҘL)
  letI : NumberField вҶҘLC0 := by
    simpa [LC0] using (inferInstance : NumberField вҶҘL)
  have hsplitM0 :
      вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ вҶҘM0),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower вҶҘM0 вҶҘLM0 q hqprime hsplitL
  have hsplitC0 :
      вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ вҶҘC0),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower вҶҘC0 вҶҘLC0 q hqprime hsplitL
  have hsplitM :
      вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
    exact primewise_split_transport_of_algEquiv M вҶҘM0 eMfield q hqprime hsplitM0
  have hsplitC :
      вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ (CyclotomicField 4 в„ҡ)),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
    exact primewise_split_transport_of_algEquiv (CyclotomicField 4 в„ҡ) вҶҘC0 eCfield q hqprime hsplitC0
  have hsplitF :
      вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower F M q hqprime hsplitM
  have hcountF :
      ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F)).ncard =
        Module.finrank в„ҡ F :=
    splitCount_of_primewiseSplit (K := F) q hqprime hsplitF
  haveI : IsCyclotomicExtension {4} в„ҡ (CyclotomicField 4 в„ҡ) :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero 4 в„ҡ
  have hmod4 : q % 4 = 1 :=
    primewise_split_in_cyclotomic4_implies_mod4 (CyclotomicField 4 в„ҡ) q hqprime hsplitC
  refine вҹЁhqprime, hmod4, вҹЁhsplitF, hcountFвҹ©, ?_вҹ©
  intro рқ”ӯ hp hne hmem
  let p0 : Ideal в„Ө := Ideal.span {(q : в„Ө)}
  let Пғ : MaxUnramifiedProPGaloisGroup F 3 := splittingDetectorAt F 3 рқ”ӯ hp hne
  have hsplitP : вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ M), Ideal.inertiaDeg рқ”ӯ рқ”“ = 1 := by
    intro рқ”“ hP
    have hPmem : рқ”“ вҲҲ p0.primesOver (рқ“һ M) := by
      refine вҹЁhP.1, ?_вҹ©
      letI : рқ”“.LiesOver рқ”ӯ := hP.2
      letI : рқ”ӯ.LiesOver p0 := by simpa [p0] using hmem.2
      exact Ideal.LiesOver.trans рқ”“ рқ”ӯ p0
    have hP0 : Ideal.inertiaDeg p0 рқ”“ = 1 := by
      exact (hsplitM рқ”“ (by simpa [p0] using hPmem)).2
    have hрқ”ӯ0 : Ideal.inertiaDeg p0 рқ”ӯ = 1 := by
      exact (hsplitF рқ”ӯ (by simpa [p0] using hmem)).2
    letI : Fact q.Prime := вҹЁhqprimeвҹ©
    letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
    letI : рқ”ӯ.LiesOver p0 := by simpa [p0] using hmem.2
    letI : рқ”“.LiesOver рқ”ӯ := hP.2
    letI : рқ”ӯ.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p0] using hmem)
    letI : рқ”“.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p0] using hPmem)
    rw [Ideal.inertiaDeg_algebra_tower p0 рқ”ӯ рқ”“] at hP0
    rw [hрқ”ӯ0, one_mul] at hP0
    exact hP0
  have hres : (AlgEquiv.restrictNormalHom M Пғ : M вүғвӮҗ[F] M) = 1 := by
    exact (splittingDetectorAt_spec F 3 рқ”ӯ hp hne M hpM).2 hsplitP
  have hker : Пғ вҲҲ (AlgEquiv.restrictNormalHom M).ker := by
    change (AlgEquiv.restrictNormalHom M) Пғ = 1
    exact hres
  have hfix : Пғ вҲҲ M.fixingSubgroup := by
    rwa [IntermediateField.restrictNormalHom_ker M] at hker
  simpa [Пғ, hMfix] using hfix

theorem ringOfIntegers_exponent_ne_zero_of_primitive_element (K : Type) [Field K] [NumberField K] {Оё : NumberField.RingOfIntegers K}
    (hОё : IntermediateField.adjoin в„ҡ ({(Оё : K)} : Set K) = вҠӨ) :
    RingOfIntegers.exponent Оё вү  0 := by
  have hОё' : Algebra.adjoin в„ҡ ({(Оё : K)} : Set K) = вҠӨ := by
    simpa only [IntermediateField.adjoin_eq_top_iff] using hОё
  have hmul :=
    conductor_mul_differentIdeal (A := в„Ө) (K := в„ҡ) (L := K)
      (B := NumberField.RingOfIntegers K) Оё hОё'
  have hderiv_ne_zero_K : (Polynomial.aeval (Оё : K)) (Polynomial.derivative (minpoly в„Ө Оё)) вү  0 := by
    letI : Algebra.IsIntegral в„ҡ K := Algebra.IsAlgebraic.isIntegral (K := в„ҡ) (A := K)
    have hsepQ : (minpoly в„ҡ (Оё : K)).Separable := by
      simpa [IsSeparable] using (IsSeparable.of_integral в„ҡ (Оё : K))
    have hderivQ : (Polynomial.aeval (Оё : K)) (Polynomial.derivative (minpoly в„ҡ (Оё : K))) вү  0 := by
      exact hsepQ.aeval_derivative_ne_zero (minpoly.aeval в„ҡ (Оё : K))
    have hmap : minpoly в„ҡ (Оё : K) = (minpoly в„Ө Оё).map (algebraMap в„Ө в„ҡ) := by
      simpa only [NumberField.RingOfIntegers.minpoly_coe] using
        (minpoly.isIntegrallyClosed_eq_field_fractions' (R := в„Ө) (K := в„ҡ)
          (S := K) (s := (Оё : K)) (NumberField.RingOfIntegers.isIntegral_coe Оё))
    rw [hmap, Polynomial.derivative_map] at hderivQ
    simpa only [Polynomial.aeval_map_algebraMap] using hderivQ
  have hderiv_ne_zero : (Polynomial.aeval Оё) (Polynomial.derivative (minpoly в„Ө Оё)) вү  0 := by
    rw [вҶҗ NumberField.RingOfIntegers.coe_ne_zero_iff]
    simpa using hderiv_ne_zero_K
  have hspan_ne_bot :
      Ideal.span ({(Polynomial.aeval Оё) (Polynomial.derivative (minpoly в„Ө Оё))} :
        Set (NumberField.RingOfIntegers K)) вү  вҠҘ := by
    intro hbot
    have hx0 : (Polynomial.aeval Оё) (Polynomial.derivative (minpoly в„Ө Оё)) = 0 :=
      (Ideal.span_singleton_eq_bot).mp hbot
    exact hderiv_ne_zero hx0
  have hconductor_ne_bot : conductor в„Ө Оё вү  вҠҘ := by
    intro hbot
    have hprod_bot : conductor в„Ө Оё * differentIdeal в„Ө (NumberField.RingOfIntegers K) = вҠҘ := by
      rw [hbot, Ideal.bot_mul]
    rw [hmul] at hprod_bot
    exact hspan_ne_bot hprod_bot
  have hunder_ne_bot : Ideal.under в„Ө (conductor в„Ө Оё) вү  вҠҘ := by
    exact Ideal.under_ne_bot в„Ө hconductor_ne_bot
  rw [RingOfIntegers.exponent]
  exact (Ideal.absNorm_ne_zero_iff (Ideal.under в„Ө (conductor в„Ө Оё))).2
    (Ideal.finiteQuotientOfFreeOfNeBot _ hunder_ne_bot)

open NumberField in
theorem splitCompletely_primes_infinite_via_kummerDedekind_aux (L : Type) [Field L] [NumberField L] [Algebra в„ҡ L]
    [FiniteDimensional в„ҡ L] [IsGalois в„ҡ L] :
    {q : в„• | q.Prime вҲ§
      вҲғ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1}.Infinite := by
  classical
  let P : в„• вҶ’ Prop := fun q =>
    q.Prime вҲ§
      вҲғ рқ”“ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
        Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”“ = 1
  have hP : вҲҖ badPrimes : Finset в„•, вҲғ q : в„•, P q вҲ§ q вҲү badPrimes := by
    intro badPrimes
    obtain вҹЁОё, hОёвҹ© := numberField_exists_integral_primitive_element L
    let f : Polynomial в„Ө := minpoly в„Ө Оё
    have hf_natDegree_ne_zero : f.natDegree вү  0 := by
      exact ne_of_gt (minpoly.natDegree_pos Оё.isIntegral)
    have hОёexp : RingOfIntegers.exponent Оё вү  0 :=
      ringOfIntegers_exponent_ne_zero_of_primitive_element L hОё
    have hdisc_ne_zero : Polynomial.discr f вү  0 := by
      simpa [f] using (minpoly_discr_ne_zero (K := L) (Оё := Оё))
    let bad : Finset в„• :=
      badPrimes вҲӘ (RingOfIntegers.exponent Оё).primeFactors вҲӘ (Polynomial.discr f).natAbs.primeFactors
    obtain вҹЁq, hqprime, hqbad, n, hqevalвҹ© :=
      intPolynomial_exists_prime_dvd_eval_outside f hf_natDegree_ne_zero bad
    have hqnot_badPrimes : q вҲү badPrimes := by
      intro hqmem
      exact hqbad (by simp [bad, hqmem])
    have hqexp : В¬ q вҲЈ RingOfIntegers.exponent Оё := by
      intro hqdiv
      have hqmem : q вҲҲ (RingOfIntegers.exponent Оё).primeFactors :=
        Nat.Prime.mem_primeFactors hqprime hqdiv hОёexp
      exact hqbad (by simp [bad, hqmem])

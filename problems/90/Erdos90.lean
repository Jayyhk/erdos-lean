    _ вүӨ |(вҲ« t in (0 : в„қ)..1, (leftTentKernel (t - (1 / 2 : в„қ))).re * g t) -
            (вҲ« t in (0 : в„қ)..1, (ПҲ (t - (1 / 2 : в„қ))).re * g t)| +

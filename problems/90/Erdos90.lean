    change
      (((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) Пүfun hПү :
            _root_.Erdos90.InhomogClassAPI.Cocycles p (G в§ё N) 2) :
          _root_.Erdos90.InhomogContsCochains.Cochain p (G в§ё N) 2) -
        ((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) f hf :
            _root_.Erdos90.InhomogClassAPI.Cocycles p (G в§ё N) 2) :
          _root_.Erdos90.InhomogContsCochains.Cochain p (G в§ё N) 2)) вҲҲ
      _root_.Erdos90.InhomogClassAPI.Coboundaries p (G в§ё N) 2
    have hdiff :
        (((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) Пүfun hПү :
              _root_.Erdos90.InhomogClassAPI.Cocycles p (G в§ё N) 2) :
            _root_.Erdos90.InhomogContsCochains.Cochain p (G в§ё N) 2) -
          ((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) f hf :
              _root_.Erdos90.InhomogClassAPI.Cocycles p (G в§ё N) 2) :
            _root_.Erdos90.InhomogContsCochains.Cochain p (G в§ё N) 2)) =
          _root_.Erdos90.InhomogClassAPI.ofProd p (G в§ё N) corr := by
      ext g
      change (Пүfun (g 0, g 1) - f (g 0, g 1)) = corr (g 0, g 1)
      simp [Пүfun, corr, c]
    rw [hdiff]
    exact _root_.Erdos90.InhomogClassAPI.ofProd_mem_coboundaries_of_isCoboundary2 p (G в§ё N) corr hcorr
  have hclass :
      _root_.Erdos90.InhomogClassAPI.classMap p (G в§ё N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) Пүfun hПү) =
      _root_.Erdos90.InhomogClassAPI.classMap p (G в§ё N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) f hf) := by
    rw [вҶҗ sub_eq_zero]
    rw [вҶҗ LinearMap.map_sub]
    exact hzero
  let Пү : {Пү : C((G в§ё N) Г— (G в§ё N), ZMod p) //
      _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G в§ё N) Пү} := вҹЁПүfun, hПүвҹ©
  refine вҹЁПү, ?_, ?_, ?_вҹ©
  В· dsimp [QClass, Пү]

theorem boundary_extension_local_interval_laplace_continuous {f : в„• вҶ’ в„қ} {b Оҙ : в„қ} :
  ContinuousOn
    (fun z : в„Ӯ =>
      вҲ« y in (0 : в„қ)..Оҙ,
        (((logRescalePartialSum f y - b : в„қ) : в„Ӯ) * Complex.exp (-z * y)))
    {z : в„Ӯ | 0 вүӨ z.re} := by
  classical

    hg_eq hxmem
  have hdivre : (a / ((x : в„Ӯ) - 1)).re = a.re / (x - 1) := by
    simpa using (Complex.div_ofReal_re a (x - 1))
  have hgre := congrArg Complex.re hgx
  rw [Complex.sub_re, hLre, hdivre] at hgre
  linarith


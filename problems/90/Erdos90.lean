theorem linearMapToCharacter_surjective (в„“ : в„•) (lin : (Fin в„“ вҶ’ ZMod 3) вҶ’вӮ—[ZMod 3] ZMod 3)
    (_hlin : lin вү  0) :
    Function.Surjective (linearMapToCharacter в„“ lin) := by
  classical
  have hx0 : вҲғ x : Fin в„“ вҶ’ ZMod 3, lin x вү  0 := by
    by_contra h
    apply _hlin
    apply LinearMap.ext
    intro x
    by_contra hx
    exact h вҹЁx, hxвҹ©
  intro y
  rcases hx0 with вҹЁx, hxвҹ©
  refine вҹЁMultiplicative.ofAdd (((Multiplicative.toAdd y) * (lin x)вҒ»В№) вҖў x), ?_вҹ©
  change lin (((Multiplicative.toAdd y) * (lin x)вҒ»В№) вҖў x) = Multiplicative.toAdd y
  rw [LinearMap.map_smulвӮӣвӮ—]
  change (((Multiplicative.toAdd y) * (lin x)вҒ»В№) * lin x) = Multiplicative.toAdd y
  rw [mul_assoc, inv_mul_cancelвӮҖ hx, mul_one]


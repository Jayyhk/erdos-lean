theorem homogToInhomog_aux_data (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] : вҲғ hi : вҲҖ n : в„•, HomogObjType p G n вҶ’вӮ—[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n, вҲҖ (n : в„•) (x : HomogObjType p G n) (g : Fin n вҶ’ G), (hi n x) g = towerEval p G (n + 1) x.1 (prefixProdTuple G n g) := by
  classical
  have h_eval_add :
      вҲҖ m (u v : HomogTower p G (m + 1)) (g0 : G),
        (towerAsC p G m (u + v)) g0 = (towerAsC p G m u) g0 + (towerAsC p G m v) g0 := by
    intro m u v g0
    cases m <;> rfl
  have h_eval_smul :
      вҲҖ m (a : ZMod p) (u : HomogTower p G (m + 1)) (g0 : G),
        (towerAsC p G m (a вҖў u)) g0 = a вҖў (towerAsC p G m u) g0 := by
    intro m a u g0
    cases m <;> rfl
  have towerEval_add :
      вҲҖ m (u v : HomogTower p G m) (g : Fin m вҶ’ G),
        towerEval p G m (u + v) g = towerEval p G m u g + towerEval p G m v g := by
    intro m
    induction m with
    | zero =>
        intro u v g
        rfl
    | succ m ih =>
        intro u v g
        simp only [towerEval]
        rw [h_eval_add m u v (g 0)]
        exact ih _ _ _
  have towerEval_smul :
      вҲҖ m (a : ZMod p) (u : HomogTower p G m) (g : Fin m вҶ’ G),
        towerEval p G m (a вҖў u) g = a вҖў towerEval p G m u g := by
    intro m
    induction m with
    | zero =>
        intro a u g
        rfl
    | succ m ih =>
        intro a u g
        simp only [towerEval]
        rw [h_eval_smul m a u (g 0)]
        exact ih _ _ _
  refine вҹЁ?_, ?_вҹ©
  intro n
  refine
    { toFun := fun x =>
        { toFun := fun g => towerEval p G (n + 1) x.1 (prefixProdTuple G n g)
          continuous_toFun := continuous_homogObj_prefixEval p G n x }
      map_add' := ?_
      map_smul' := ?_ }
  В· intro x y
    ext g
    simpa using towerEval_add (n + 1) x.1 y.1 (prefixProdTuple G n g)
  В· intro a x
    ext g
    simpa using towerEval_smul (n + 1) a x.1 (prefixProdTuple G n g)
  В· intro n x g
    rfl

theorem selectedHomogToInhomog_aux_apply (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) (x : HomogObjType p G n) (g : Fin n вҶ’ G) : (selectedHomogToInhomog_aux p G n x) g = towerEval p G (n + 1) x.1 (prefixProdTuple G n g) := by

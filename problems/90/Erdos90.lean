      (ProfiniteGrp.closedSubgroup_eq_sInf_open (G := G) (вҹЁN, hNвҹ© : ClosedSubgroup G))
  have hdiff : aвҒ»В№ * g вҲҲ N := by
    rw [hN_eq]
    rw [Subgroup.mem_sInf]
    intro M hM
    obtain вҹЁV, hVsubвҹ© :=
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hM.1 M.one_mem
    have hVle : V.toSubgroup вүӨ M := by
      intro y hy
      exact hVsub hy
    have hNV : N вҠ” V.toSubgroup вүӨ M := sup_le hM.2 hVle
    have hVeq := h V
    rw [QuotientGroup.map_mk', MonoidHom.id_apply, QuotientGroup.mk'_apply,
      QuotientGroup.eq] at hVeq
    exact hNV hVeq
  exact (QuotientGroup.eq).2 (by simpa using N.inv_mem hdiff)

theorem compatible_pointwise_lift {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] {W0 : OpenNormalSubgroup G}
    (y : G в§ё (N вҠ” W0.toSubgroup))
    (b : вҲҖ U : OpenNormalSubgroup G, W0 вүӨ U вҶ’ G в§ё U.toSubgroup)
    (hb_compat : вҲҖ {U1 U2 : OpenNormalSubgroup G}
      (h01 : W0 вүӨ U1) (h02 : W0 вүӨ U2) (h12 : U1 вүӨ U2),
      QuotientGroup.map U1.toSubgroup U2.toSubgroup (MonoidHom.id G)
        (show U1.toSubgroup вүӨ U2.toSubgroup from h12) (b U1 h01) = b U2 h02)
    (hb_fiber : вҲҖ U (h0U : W0 вүӨ U),
      QuotientGroup.map U.toSubgroup (N вҠ” U.toSubgroup) (MonoidHom.id G)
        (show U.toSubgroup вүӨ N вҠ” U.toSubgroup from le_sup_right) (b U h0U) =
      QuotientGroup.map (N вҠ” W0.toSubgroup) (N вҠ” U.toSubgroup) (MonoidHom.id G)
        (show N вҠ” W0.toSubgroup вүӨ N вҠ” U.toSubgroup from
          sup_le_sup_left (show W0.toSubgroup вүӨ U.toSubgroup from h0U) N) y) :
    вҲғ a : G в§ё W0.toSubgroup,
      QuotientGroup.map W0.toSubgroup (N вҠ” W0.toSubgroup) (MonoidHom.id G)
        (show W0.toSubgroup вүӨ N вҠ” W0.toSubgroup from le_sup_right) a = y вҲ§
      вҲҖ U (h0U : W0 вүӨ U),
        QuotientGroup.map W0.toSubgroup U.toSubgroup (MonoidHom.id G)
          (show W0.toSubgroup вүӨ U.toSubgroup from h0U) a = b U h0U := by
  refine вҹЁb W0 le_rfl, ?_, ?_вҹ©
  В· simpa using hb_fiber W0 le_rfl
  В· intro U h0U
    simpa using hb_compat (U1 := W0) (U2 := U) le_rfl h0U h0U

theorem open_normal_quotient_surj_hom_has_section
    {G H : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H]
    (N : Subgroup H) [N.Normal] (hN : IsOpen (N : Set H))
    (f : G вҶ’вӮң* H) (hf : Function.Surjective f) :
    вҲғ s : ContinuousMap (H в§ё N) (G в§ё N.comap f.toMonoidHom),
      вҲҖ y : H в§ё N,
        QuotientGroup.map (N.comap f.toMonoidHom) N f.toMonoidHom (le_rfl) (s y) = y := by
  classical
  letI : DiscreteTopology (H в§ё N) := QuotientGroup.discreteTopology (N := N) hN
  let q : G в§ё N.comap f.toMonoidHom вҶ’* H в§ё N :=
    QuotientGroup.map (N.comap f.toMonoidHom) N f.toMonoidHom le_rfl
  have hqf : Function.Surjective ((QuotientGroup.mk : H вҶ’ H в§ё N) вҲҳ f) := by
    intro y
    rcases QuotientGroup.mk_surjective y with вҹЁh, rflвҹ©
    rcases hf h with вҹЁg, rflвҹ©
    exact вҹЁg, rflвҹ©
  have hq : Function.Surjective q :=
    QuotientGroup.map_surjective_of_surjective
      (N := N.comap f.toMonoidHom) (M := N) (f := f.toMonoidHom) hqf le_rfl
  refine вҹЁвҹЁFunction.surjInv hq, continuous_of_discreteTopologyвҹ©, ?_вҹ©
  intro y
  exact Function.surjInv_eq hq y

theorem diagram_superquotient_map_has_continuous_section {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (V : OpenNormalSubgroup G) :
    вҲғ s : ContinuousMap (G в§ё (N вҠ” V.toSubgroup))
        ((ProfiniteGrp.diagram (ProfiniteGrp.of G)).obj V),
      вҲҖ y : G в§ё (N вҠ” V.toSubgroup),
        QuotientGroup.map V.toSubgroup (N вҠ” V.toSubgroup) (MonoidHom.id G)
          (show V.toSubgroup вүӨ N вҠ” V.toSubgroup from le_sup_right) (s y) = y := by
  rcases superquotient_map_has_continuous_section (G := G) N V with вҹЁs, hsвҹ©

    simp only [F, U, norm_mul, Complex.norm_exp]
    have hnorm : вҖ–(((logRescalePartialSum f y - b : в„қ) : в„Ӯ))вҖ– = |logRescalePartialSum f y - b| := by
      simpa using (RCLike.norm_ofReal (K := в„Ӯ) (logRescalePartialSum f y - b))
    rw [hnorm]

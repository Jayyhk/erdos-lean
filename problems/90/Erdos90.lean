theorem towerEval_action (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : в„•) (a : G) (x : HomogTower p G n) (g : Fin n вҶ’ G) : towerEval p G n ((((ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ a).hom x) g = towerEval p G n x (fun k : Fin n => aвҒ»В№ * g k) := by
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      let rep :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj
          (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))
      have hhead :
          (towerAsC p G n ((((ContinuousCohomology.I (ZMod p) G).obj rep).ПҒ a).hom x)) (g 0) =
            ((rep.ПҒ a).hom ((towerAsC p G n x) (aвҒ»В№ * g 0))) := by
        cases n <;> rfl
      have hhead' :
          (towerAsC p G n
              ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
                    (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ a).hom x))
              (g 0) =
            ((rep.ПҒ a).hom ((towerAsC p G n x) (aвҒ»В№ * g 0))) := by
        simpa [rep, ContinuousCohomology.MultiInd.functor] using hhead
      rw [towerEval, towerEval, hhead']

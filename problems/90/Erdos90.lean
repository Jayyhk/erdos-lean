    intro y
    rcases QuotientGroup.mk_surjective y with ⟨h, rfl⟩
    rcases hf h with ⟨g, rfl⟩
    exact ⟨g, rfl⟩
  have hq : Function.Surjective q :=
    QuotientGroup.map_surjective_of_surjective
      (N := N.comap f.toMonoidHom) (M := N) (f := f.toMonoidHom) hqf le_rfl
  refine ⟨⟨Function.surjInv hq, continuous_of_discreteTopology⟩, ?_⟩
  intro y
  exact Function.surjInv_eq hq y

theorem diagram_superquotient_map_has_continuous_section {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (V : OpenNormalSubgroup G) :
    ∃ s : ContinuousMap (G ⧸ (N ⊔ V.toSubgroup))
        ((ProfiniteGrp.diagram (ProfiniteGrp.of G)).obj V),
      ∀ y : G ⧸ (N ⊔ V.toSubgroup),
        QuotientGroup.map V.toSubgroup (N ⊔ V.toSubgroup) (MonoidHom.id G)
          (show V.toSubgroup ≤ N ⊔ V.toSubgroup from le_sup_right) (s y) = y := by
  rcases superquotient_map_has_continuous_section (G := G) N V with ⟨s, hs⟩
  have hNV_open : IsOpen (↑(N ⊔ V.toSubgroup) : Set G) :=
    Subgroup.isOpen_mono (show V.toSubgroup ≤ N ⊔ V.toSubgroup from le_sup_right) V.isOpen
  letI : DiscreteTopology (G ⧸ (N ⊔ V.toSubgroup)) :=
    QuotientGroup.discreteTopology (N := N ⊔ V.toSubgroup) hNV_open
  refine ⟨
    { toFun := fun y => s y
      continuous_toFun := continuous_of_discreteTopology },
    ?_⟩
  intro y
  simpa [ProfiniteGrp.diagram, ProfiniteGrp.toFiniteQuotientFunctor] using hs y

theorem countable_openNormalSubgroup_of_secondCountable {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G] :
    Countable (OpenNormalSubgroup G) := by
  let f : OpenNormalSubgroup G → TopologicalSpace.Clopens G := fun H =>
    ⟨(H : Set G), OpenSubgroup.isClopen H.toOpenSubgroup⟩
  have hclopen : Countable (TopologicalSpace.Clopens G) := by
    simpa using (TopologicalSpace.Clopens.countable_iff_secondCountable (X := G)).2 inferInstance
  have hf : Function.Injective f := by
    intro H K h
    apply OpenNormalSubgroup.toSubgroup_injective
    ext x
    change x ∈ ((f H : TopologicalSpace.Clopens G) : Set G) ↔ x ∈ ((f K : TopologicalSpace.Clopens G) : Set G)
    simpa [f] using congrArg (fun s : TopologicalSpace.Clopens G => x ∈ (s : Set G)) h
  letI := hclopen
  exact hf.countable

theorem exists_descending_cofinal_openNormalSequence_above {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G] (N : Subgroup G) :
    ∃ V : ℕ → OpenNormalSubgroup G,
      (∀ n, N ≤ (V n : Subgroup G)) ∧
      (∀ n, V (n + 1) ≤ V n) ∧
      (∀ U : OpenNormalSubgroup G, N ≤ (U : Subgroup G) → ∃ n, V n ≤ U) := by
  classical
  let S : Type _ := {V : OpenNormalSubgroup G // N ≤ (V : Subgroup G)}
  letI : Countable (OpenNormalSubgroup G) := countable_openNormalSubgroup_of_secondCountable
  letI : Countable S := by
    dsimp [S]
    infer_instance
  let topON : OpenNormalSubgroup G := ⟨(⊤ : OpenSubgroup G), by
    simp
  ⟩
  letI : Nonempty S := ⟨⟨topON, by
    change N ≤ (⊤ : Subgroup G)
    exact le_top
  ⟩⟩
  obtain ⟨e, hsurj⟩ := exists_surjective_nat S
  let V : ℕ → OpenNormalSubgroup G := fun n =>
    Nat.rec (e 0).1 (fun n W => W ⊓ (e (n + 1)).1) n
  refine ⟨V, ?_, ?_, ?_⟩
  · intro n
    induction n with
    | zero =>
        exact (e 0).2
    | succ n ihn =>
        intro x hx
        change x ∈ (V n ⊓ (e (n + 1)).1 : OpenNormalSubgroup G)
        exact ⟨ihn hx, (e (n + 1)).2 hx⟩
  · intro n
    change V n ⊓ (e (n + 1)).1 ≤ V n
    exact inf_le_left
  · intro U hNU
    rcases hsurj ⟨U, hNU⟩ with ⟨n, hn⟩
    refine ⟨n, ?_⟩
    have hVn : ∀ n, V n ≤ (e n).1 := by
      intro n
      induction n with
      | zero =>
          exact le_rfl
      | succ n ihn =>
          change V n ⊓ (e (n + 1)).1 ≤ (e (n + 1)).1
          exact inf_le_right
    simpa [hn] using hVn n

theorem cofinal_openNormalSequence_compatible_family_lift {G X : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [TopologicalSpace X]
    (W : ℕ → OpenNormalSubgroup G)
    (hWdesc : ∀ n, W (n + 1) ≤ W n)
    (hWcof : ∀ U : OpenNormalSubgroup G, ∃ n, W n ≤ U)
    (a : ∀ n, C(X, G ⧸ (W n).toSubgroup))
    (ha : ∀ n (x : X),
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n)
        (a (n + 1) x) = a n x) :
    ∃ s : C(X, G), ∀ n (x : X),
      QuotientGroup.mk' (W n).toSubgroup (s x) = a n x := by
  classical
  have hWle_add : ∀ n k : ℕ, (W (n + k)).toSubgroup ≤ (W n).toSubgroup := by
    intro n k
    induction k with
    | zero =>
        simp
    | succ k ih =>
        have hstep : (W (n + k + 1)).toSubgroup ≤ (W (n + k)).toSubgroup := by
          simpa [Nat.add_assoc] using (hWdesc (n + k))
        simpa [Nat.add_assoc] using le_trans hstep ih
  have hcompat_add : ∀ n k (x : X),
      QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + k)).toSubgroup ≤ (W n).toSubgroup from hWle_add n k) (a (n + k) x) = a n x := by
    intro n k
    induction k with
    | zero =>
        intro x
        simp
    | succ k ih =>
        intro x
        calc
          QuotientGroup.map (W (n + (k + 1))).toSubgroup (W n).toSubgroup (MonoidHom.id G)
              (show (W (n + (k + 1))).toSubgroup ≤ (W n).toSubgroup from hWle_add n (k + 1))
              (a (n + (k + 1)) x)
            = QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                (show (W (n + k)).toSubgroup ≤ (W n).toSubgroup from hWle_add n k)
                (QuotientGroup.map (W (n + (k + 1))).toSubgroup (W (n + k)).toSubgroup (MonoidHom.id G)
                  (show (W (n + (k + 1))).toSubgroup ≤ (W (n + k)).toSubgroup from by
                    simpa [Nat.add_assoc] using (hWdesc (n + k)))
                  (a (n + (k + 1)) x)) := by
                    symm
                    exact QuotientGroup.map_map (N := (W (n + (k + 1))).toSubgroup)
                      (M := (W (n + k)).toSubgroup) (O := (W n).toSubgroup)
                      (f := MonoidHom.id G) (g := MonoidHom.id G)
                      (hf := show (W (n + (k + 1))).toSubgroup ≤ Subgroup.comap (MonoidHom.id G) (W (n + k)).toSubgroup from by
                        simpa [Nat.add_assoc] using (hWdesc (n + k)))
                      (hg := show (W (n + k)).toSubgroup ≤ Subgroup.comap (MonoidHom.id G) (W n).toSubgroup from hWle_add n k)
                      (x := a (n + (k + 1)) x)
          _ = QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                (show (W (n + k)).toSubgroup ≤ (W n).toSubgroup from hWle_add n k)
                (a (n + k) x) := by
                  simpa [Nat.add_assoc] using congrArg
                    (QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                      (show (W (n + k)).toSubgroup ≤ (W n).toSubgroup from hWle_add n k))
                    (ha (n + k) x)
          _ = a n x := ih x
  have hWle : ∀ {n m : ℕ}, n ≤ m → (W m).toSubgroup ≤ (W n).toSubgroup := by
    intro n m hnm
    rcases Nat.exists_eq_add_of_le hnm with ⟨k, rfl⟩
    exact hWle_add n k
  have hcompat_nat : ∀ {n m : ℕ} (hnm : n ≤ m) (x : X),
      QuotientGroup.map (W m).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W m).toSubgroup ≤ (W n).toSubgroup from hWle hnm) (a m x) = a n x := by
    intro n m hnm x
    rcases Nat.exists_eq_add_of_le hnm with ⟨k, rfl⟩
    exact hcompat_add n k x
  let P : ProfiniteGrp := ProfiniteGrp.of G
  let aP : ∀ n : ℕ, C(X, (ProfiniteGrp.diagram P).obj (W n)) := by
    intro n
    refine { toFun := fun x => a n x, continuous_toFun := ?_ }
    convert (a n).continuous using 1
    · change (⊥ : TopologicalSpace (G ⧸ (W n).toSubgroup)) = QuotientGroup.instTopologicalSpace (W n).toSubgroup
      symm
      simpa using (show QuotientGroup.instTopologicalSpace (W n).toSubgroup = (⊥ : TopologicalSpace (G ⧸ (W n).toSubgroup)) from DiscreteTopology.eq_bot (α := (G ⧸ (W n).toSubgroup)))
  have haP_val : ∀ n x, aP n x = a n x := by
    intro n x
    rfl
  have hcompat_natP : ∀ {n m : ℕ} (hnm : n ≤ m) (x : X),
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hWle hnm)) (aP m x) = aP n x := by
    intro n m hnm x
    change QuotientGroup.map (W m).toSubgroup (W n).toSubgroup (MonoidHom.id G)
      (show (W m).toSubgroup ≤ (W n).toSubgroup from hWle hnm) (a m x) = a n x
    exact hcompat_nat hnm x
  let nU : OpenNormalSubgroup G → ℕ := fun U => Classical.choose (hWcof U)
  have hnU : ∀ U, (W (nU U)).toSubgroup ≤ U.toSubgroup := by
    intro U
    exact Classical.choose_spec (hWcof U)
  let coordP : ∀ U : OpenNormalSubgroup G, C(X, (ProfiniteGrp.diagram P).obj U) := fun U =>
    (((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U))).hom.toContinuousMap).comp (aP (nU U))
  have hcoordP_from_stage : ∀ (U : OpenNormalSubgroup G) {m : ℕ} (hm : nU U ≤ m) (x : X),
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm).trans (hnU U))) (aP m x) = coordP U x := by
    intro U m hm x
    calc
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm).trans (hnU U))) (aP m x)
        = ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U)))
            ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hWle hm)) (aP m x)) := by
              change QuotientGroup.map (W m).toSubgroup U.toSubgroup (MonoidHom.id G)
                (show (W m).toSubgroup ≤ U.toSubgroup from (hWle hm).trans (hnU U)) (a m x)
                = QuotientGroup.map (W (nU U)).toSubgroup U.toSubgroup (MonoidHom.id G)
                    (show (W (nU U)).toSubgroup ≤ U.toSubgroup from hnU U)
                    (QuotientGroup.map (W m).toSubgroup (W (nU U)).toSubgroup (MonoidHom.id G)
                      (show (W m).toSubgroup ≤ (W (nU U)).toSubgroup from hWle hm) (a m x))
              symm
              exact QuotientGroup.map_map (N := (W m).toSubgroup)
                (M := (W (nU U)).toSubgroup) (O := U.toSubgroup)
                (f := MonoidHom.id G) (g := MonoidHom.id G)
                (hf := show (W m).toSubgroup ≤ Subgroup.comap (MonoidHom.id G) (W (nU U)).toSubgroup from hWle hm)
                (hg := show (W (nU U)).toSubgroup ≤ Subgroup.comap (MonoidHom.id G) U.toSubgroup from hnU U)
                (x := a m x)
      _ = ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U))) (aP (nU U) x) := by
            rw [hcompat_natP hm x]
      _ = coordP U x := by rfl
  have hcoord_compat : ∀ x : X, ∀ {U1 U2 : OpenNormalSubgroup G} (f : U1 ⟶ U2),
      (ProfiniteGrp.diagram P).map f (coordP U1 x) = coordP U2 x := by
    intro x U1 U2 f
    let m := max (nU U1) (nU U2)
    have hm1 : nU U1 ≤ m := le_max_left _ _
    have hm2 : nU U2 ≤ m := le_max_right _ _
    calc
      (ProfiniteGrp.diagram P).map f (coordP U1 x)
          = (ProfiniteGrp.diagram P).map f
              ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm1).trans (hnU U1))) (aP m x)) := by
                rw [← hcoordP_from_stage U1 hm1 x]
      _ = (ProfiniteGrp.diagram P).map
            (CategoryTheory.homOfLE (((hWle hm1).trans (hnU U1)).trans (CategoryTheory.leOfHom f)))
            (aP m x) := by
              change QuotientGroup.map U1.toSubgroup U2.toSubgroup (MonoidHom.id G)
                (show U1.toSubgroup ≤ U2.toSubgroup from CategoryTheory.leOfHom f)
                (QuotientGroup.map (W m).toSubgroup U1.toSubgroup (MonoidHom.id G)
                  (show (W m).toSubgroup ≤ U1.toSubgroup from (hWle hm1).trans (hnU U1)) (a m x))
                = QuotientGroup.map (W m).toSubgroup U2.toSubgroup (MonoidHom.id G)
                    (show (W m).toSubgroup ≤ U2.toSubgroup from
                      ((hWle hm1).trans (hnU U1)).trans (CategoryTheory.leOfHom f)) (a m x)
              exact QuotientGroup.map_map (N := (W m).toSubgroup)
                (M := U1.toSubgroup) (O := U2.toSubgroup)
                (f := MonoidHom.id G) (g := MonoidHom.id G)
                (hf := show (W m).toSubgroup ≤ Subgroup.comap (MonoidHom.id G) U1.toSubgroup from (hWle hm1).trans (hnU U1))
                (hg := show U1.toSubgroup ≤ Subgroup.comap (MonoidHom.id G) U2.toSubgroup from CategoryTheory.leOfHom f)
                (x := a m x)
      _ = coordP U2 x := by
            simpa using hcoordP_from_stage U2 hm2 x
  let Lfun : X → ProfiniteGrp.limit (ProfiniteGrp.diagram P) := fun x =>
    ⟨fun U => coordP U x, by
      intro U1 U2 f
      exact hcoord_compat x f⟩
  have hLfun : Continuous Lfun := by
    apply Continuous.subtype_mk
    simpa using (continuous_pi fun U : OpenNormalSubgroup G => (coordP U).continuous)
  let L : C(X, ProfiniteGrp.limit (ProfiniteGrp.diagram P)) := ⟨Lfun, hLfun⟩
  let e := ProfiniteGrp.continuousMulEquivLimittoFiniteQuotientFunctor P
  let s : C(X, G) := ⟨fun x => e.symm (L x), e.symm.continuous_toFun.comp L.continuous⟩
  have hs_eq : ∀ x, e (s x) = L x := by
    intro x
    exact e.apply_symm_apply (L x)
  have hcoord_W : ∀ n x, coordP (W n) x = aP n x := by
    intro n x
    let m := max (nU (W n)) n
    have hm1 : nU (W n) ≤ m := le_max_left _ _
    have hm2 : n ≤ m := le_max_right _ _
    have h1 := hcoordP_from_stage (W n) hm1 x
    have h2 := hcompat_natP hm2 x
    exact h1.symm.trans h2
  refine ⟨s, ?_⟩
  intro n x
  have hproj := congrArg (fun y => y.val (W n)) (hs_eq x)
  change QuotientGroup.mk' (W n).toSubgroup (s x) = coordP (W n) x at hproj
  rw [hcoord_W n x] at hproj
  simpa [haP_val n x] using hproj
theorem quotient_eq_of_cofinal_openNormalSequence_sup_eq {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (V : ℕ → OpenNormalSubgroup G)
    (hcofinal : ∀ U : OpenNormalSubgroup G, ∃ n, V n ≤ U)
    {g : G} {x : G ⧸ N}
    (h : ∀ n,
      QuotientGroup.map N (N ⊔ (V n).toSubgroup) (MonoidHom.id G)
        (show N ≤ N ⊔ (V n).toSubgroup from le_sup_left) x =
      QuotientGroup.mk' (N ⊔ (V n).toSubgroup) g) :
    QuotientGroup.mk' N g = x := by
  apply quotient_eq_of_all_open_superquotients_eq N hN
  intro U
  rcases hcofinal U with ⟨n, hn⟩
  have hvu : (V n).toSubgroup ≤ U.toSubgroup := hn
  have hsup : N ⊔ (V n).toSubgroup ≤ N ⊔ U.toSubgroup := sup_le_sup_left hvu N
  have h' := congrArg
    (QuotientGroup.map (N ⊔ (V n).toSubgroup) (N ⊔ U.toSubgroup) (MonoidHom.id G) hsup)
    (h n)
  simpa using h'

theorem profinite_quotient_has_continuous_section (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (_hN : IsClosed (N : Set G)) :
    ∃ s : C(G ⧸ N, G), ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x := by
  classical
  have hN : IsClosed (N : Set G) := _hN
  obtain ⟨W, hWbot, hWdesc, hWcof⟩ :=
    exists_descending_cofinal_openNormalSequence_above (G := G) (N := (⊥ : Subgroup G))
  have hWcof' : ∀ U : OpenNormalSubgroup G, ∃ n, W n ≤ U := by
    intro U
    simpa using hWcof U bot_le
  let R : ℕ → Subgroup G := fun n => N ⊔ (W n).toSubgroup
  have hWle : ∀ {n m : ℕ}, n ≤ m → W m ≤ W n := by
    intro n m h
    induction h with
    | refl => exact le_rfl
    | @step m h ih => exact le_trans (hWdesc m) ih
  have hRle : ∀ n, R (n + 1) ≤ R n := by
    intro n
    exact sup_le_sup_left (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n) N
  have hT0 : Σ' s : C(G ⧸ R 0, G ⧸ (W 0).toSubgroup),
      ∀ y : G ⧸ R 0,
        QuotientGroup.map (W 0).toSubgroup (R 0) (MonoidHom.id G)
          (show (W 0).toSubgroup ≤ R 0 from le_sup_right) (s y) = y := by
    refine ⟨Classical.choose (superquotient_map_has_continuous_section (G := G) N (W 0)), ?_⟩
    exact Classical.choose_spec (superquotient_map_has_continuous_section (G := G) N (W 0))
  let T : ℕ → Type _ := fun n =>
    Σ' s : C(G ⧸ R n, G ⧸ (W n).toSubgroup),
      ∀ y : G ⧸ R n,
        QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ R n from le_sup_right) (s y) = y
  have hT0' : T 0 := hT0
  have hTstep : ∀ n (tn : T n), { tnext : T (n + 1) //
      ∀ y : G ⧸ R (n + 1),
        QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
          (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n)
          (tnext.1 y) =
        tn.1
          (QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
            (show R (n + 1) ≤ R n from hRle n) y) } := by
    intro n tn
    rcases tn with ⟨sn, hsn⟩
    let f : G ⧸ R (n + 1) → G ⧸ (W (n + 1)).toSubgroup := fun y =>
      let g : G := Classical.choose (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let hx : QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
          (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g) = y := by
            simpa [g] using Classical.choose_spec (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let y' : G ⧸ R n :=
        QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
          (show R (n + 1) ≤ R n from hRle n) y
      let b : G ⧸ (W n).toSubgroup := sn y'
      let hb : QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ R n from le_sup_right) b =
          QuotientGroup.map N (R n) (MonoidHom.id G)
            (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
              have hy' : y' = QuotientGroup.map N (R n) (MonoidHom.id G)
                  (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                calc
                  y' = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n) y := by rfl
                  _ = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n)
                      (QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
                        (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g)) := by
                        rw [← hx]
                  _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                      (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                        simp [QuotientGroup.map_comp_map
                            (N := N) (M := R (n + 1)) (O := R n)
                            (f := MonoidHom.id G) (g := MonoidHom.id G)
                            (hf := show N ≤ (R (n + 1)).comap (MonoidHom.id G) from le_sup_left)
                            (hg := show R (n + 1) ≤ (R n).comap (MonoidHom.id G) from hRle n)]
              calc
                QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
                    (show (W n).toSubgroup ≤ R n from le_sup_right) b = y' := hsn y'
                _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                    (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := hy'
      Classical.choose (quotient_fiber_lift_exists (G := G) N (V := W (n + 1)) (W := W n)
        (hWdesc n) (QuotientGroup.mk' N g) b hb)
    refine ⟨⟨⟨f, ?_⟩, ?_⟩, ?_⟩
    · have hRopen : IsOpen ((R (n + 1) : Subgroup G) : Set G) := by
        apply Subgroup.isOpen_mono (H₁ := (W (n + 1)).toSubgroup)
        · exact le_sup_right
        · simpa using (W (n + 1)).isOpen
      letI : DiscreteTopology (G ⧸ R (n + 1)) :=
        QuotientGroup.discreteTopology (G := G) (N := R (n + 1)) (hN := hRopen)
      exact continuous_of_discreteTopology
    · intro y
      dsimp [f]
      let g : G := Classical.choose (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let hx : QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
          (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g) = y := by
            simpa [g] using Classical.choose_spec (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let y' : G ⧸ R n :=
        QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
          (show R (n + 1) ≤ R n from hRle n) y
      let b : G ⧸ (W n).toSubgroup := sn y'
      let hb : QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ R n from le_sup_right) b =
          QuotientGroup.map N (R n) (MonoidHom.id G)
            (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
              have hy' : y' = QuotientGroup.map N (R n) (MonoidHom.id G)
                  (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                calc
                  y' = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n) y := by rfl
                  _ = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n)
                      (QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
                        (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g)) := by
                        rw [← hx]
                  _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                      (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                        simp [QuotientGroup.map_comp_map
                            (N := N) (M := R (n + 1)) (O := R n)
                            (f := MonoidHom.id G) (g := MonoidHom.id G)
                            (hf := show N ≤ (R (n + 1)).comap (MonoidHom.id G) from le_sup_left)
                            (hg := show R (n + 1) ≤ (R n).comap (MonoidHom.id G) from hRle n)]
              calc
                QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
                    (show (W n).toSubgroup ≤ R n from le_sup_right) b = y' := hsn y'
                _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                    (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := hy'
      exact (Classical.choose_spec (quotient_fiber_lift_exists (G := G) N (V := W (n + 1))
        (W := W n) (hWdesc n) (QuotientGroup.mk' N g) b hb)).2.trans hx
    · intro y
      dsimp [f]
      let g : G := Classical.choose (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let hx : QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
          (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g) = y := by
            simpa [g] using Classical.choose_spec (QuotientGroup.mk'_surjective (N := R (n + 1)) y)
      let y' : G ⧸ R n :=
        QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
          (show R (n + 1) ≤ R n from hRle n) y
      let b : G ⧸ (W n).toSubgroup := sn y'
      let hb : QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ R n from le_sup_right) b =
          QuotientGroup.map N (R n) (MonoidHom.id G)
            (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
              have hy' : y' = QuotientGroup.map N (R n) (MonoidHom.id G)
                  (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                calc
                  y' = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n) y := by rfl
                  _ = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) ≤ R n from hRle n)
                      (QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
                        (show N ≤ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g)) := by
                        rw [← hx]
                  _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                      (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                        simp [QuotientGroup.map_comp_map
                            (N := N) (M := R (n + 1)) (O := R n)
                            (f := MonoidHom.id G) (g := MonoidHom.id G)
                            (hf := show N ≤ (R (n + 1)).comap (MonoidHom.id G) from le_sup_left)
                            (hg := show R (n + 1) ≤ (R n).comap (MonoidHom.id G) from hRle n)]
              calc
                QuotientGroup.map (W n).toSubgroup (R n) (MonoidHom.id G)
                    (show (W n).toSubgroup ≤ R n from le_sup_right) b = y' := hsn y'
                _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                    (show N ≤ R n from le_sup_left) (QuotientGroup.mk' N g) := hy'
      simpa [b, y'] using (Classical.choose_spec (quotient_fiber_lift_exists (G := G) N (V := W (n + 1))
        (W := W n) (hWdesc n) (QuotientGroup.mk' N g) b hb)).1
  let t : ∀ n, T n := Nat.rec hT0' (fun n tn => (hTstep n tn).1)
  have hstep : ∀ n (y : G ⧸ R (n + 1)),
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n)
        ((t (n + 1)).1 y) =
      (t n).1
        (QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
          (show R (n + 1) ≤ R n from hRle n) y) := by
    intro n y
    simpa [t] using (hTstep n (t n)).2 y
  have hqcont : ∀ n,
      Continuous (QuotientGroup.map N (R n) (MonoidHom.id G)
        (show N ≤ R n from le_sup_left) : G ⧸ N → G ⧸ R n) := by
    intro n
    rw [← QuotientGroup.isOpenQuotientMap_mk.continuous_comp_iff]
    simpa [Function.comp, QuotientGroup.map_mk'] using
      (QuotientGroup.continuous_mk (N := R n))
  let q : ∀ n, C(G ⧸ N, G ⧸ R n) := fun n =>
    ⟨QuotientGroup.map N (R n) (MonoidHom.id G)
      (show N ≤ R n from le_sup_left), hqcont n⟩
  let aSeq : ∀ n, C(G ⧸ N, G ⧸ (W n).toSubgroup) := fun n => (t n).1.comp (q n)
  have hstepA : ∀ n (x : G ⧸ N),
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n)
        (aSeq (n + 1) x) = aSeq n x := by
    intro n x
    dsimp [aSeq]
    calc
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
          (show (W (n + 1)).toSubgroup ≤ (W n).toSubgroup from hWdesc n)
          ((t (n + 1)).1 ((q (n + 1)) x)) =
        (t n).1
          (QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
            (show R (n + 1) ≤ R n from hRle n) ((q (n + 1)) x)) := hstep n ((q (n + 1)) x)
      _ = (t n).1 ((q n) x) := by
        congr 1
        dsimp [q]
        simpa using congrArg (fun h => h x)
          (QuotientGroup.map_comp_map
            (N := N) (M := R (n + 1)) (O := R n)
            (f := MonoidHom.id G) (g := MonoidHom.id G)
            (hf := show N ≤ (R (n + 1)).comap (MonoidHom.id G) by
              simpa using (show N ≤ R (n + 1) from le_sup_left))
            (hg := show R (n + 1) ≤ (R n).comap (MonoidHom.id G) by
              simpa using (hRle n)))
  obtain ⟨s, hs⟩ :=
    cofinal_openNormalSequence_compatible_family_lift
      (G := G) (X := G ⧸ N) W hWdesc hWcof' aSeq hstepA
  refine ⟨s, ?_⟩
  intro x
  apply quotient_eq_of_cofinal_openNormalSequence_sup_eq
    (G := G) (N := N) hN W hWcof'
  intro n
  have ht := (t n).2 ((q n) x)
  calc
    QuotientGroup.map N (N ⊔ (W n).toSubgroup) (MonoidHom.id G)
        (show N ≤ N ⊔ (W n).toSubgroup from le_sup_left) x
      = QuotientGroup.map (W n).toSubgroup (N ⊔ (W n).toSubgroup) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ N ⊔ (W n).toSubgroup from le_sup_right)
          (aSeq n x) := by
            simpa [R, aSeq, q] using ht.symm
    _ = QuotientGroup.map (W n).toSubgroup (N ⊔ (W n).toSubgroup) (MonoidHom.id G)
          (show (W n).toSubgroup ≤ N ⊔ (W n).toSubgroup from le_sup_right)
          (QuotientGroup.mk' (W n).toSubgroup (s x)) := by
            rw [show aSeq n x = QuotientGroup.mk' (W n).toSubgroup (s x) from (hs n x).symm]
    _ = QuotientGroup.mk' (N ⊔ (W n).toSubgroup) (s x) := by
          simp [QuotientGroup.map_mk']

noncomputable def chosenSection
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    ContinuousMap (G ⧸ N) G :=
  Classical.choose (profinite_quotient_has_continuous_section G N hN)

theorem chosenSection_spec
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (x : G ⧸ N) :
    QuotientGroup.mk' N (chosenSection G N hN x) = x :=
  (Classical.choose_spec (profinite_quotient_has_continuous_section G N hN)) x

theorem profinite_group_surj_hom_has_section
    {G H : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G]
    [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H] [T2Space H]
    [CompactSpace H] [TotallyDisconnectedSpace H]
    (f : G →ₜ* H) (hf : Function.Surjective f) :
    ∃ s : ContinuousMap H G, ∀ y : H, f (s y) = y := by
  classical
  let K : Subgroup G := f.toMonoidHom.ker
  haveI : K.Normal := by
    dsimp [K]
    infer_instance
  have hK : IsClosed (K : Set G) := by
    dsimp [K]
    change IsClosed (f ⁻¹' ({1} : Set H))
    simpa [MonoidHom.mem_ker, Subgroup.mem_carrier] using
      (isClosed_singleton.preimage f.continuous_toFun)
  obtain ⟨t, ht⟩ := profinite_quotient_has_continuous_section (G := G) (N := K) hK
  let eMul : G ⧸ K ≃* H := QuotientGroup.quotientKerEquivOfSurjective f.toMonoidHom hf
  have hecont : Continuous eMul := by
    exact (QuotientGroup.isQuotientMap_mk K).continuous_iff.2 (by
      simpa [eMul, K] using f.continuous_toFun)
  let e : (G ⧸ K) ≃ₜ H := Continuous.homeoOfEquivCompactToT2 (f := eMul.toEquiv) hecont
  let eInv : ContinuousMap H (G ⧸ K) := ⟨e.symm, e.symm.continuous_toFun⟩
  refine ⟨t.comp eInv, ?_⟩
  intro y
  have h1 : QuotientGroup.mk' K (t (e.symm y)) = e.symm y := ht (e.symm y)
  have h2 : e (QuotientGroup.mk' K (t (e.symm y))) = e (e.symm y) := congrArg e h1
  have h3 : e (QuotientGroup.mk' K (t (e.symm y))) = y := by
    simpa using h2
  change eMul (QuotientGroup.mk' K (t (e.symm y))) = y
  simpa [e, eMul, K] using h3

noncomputable def schreierDefect
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x) :
    G ⧸ N → G ⧸ N → ↥N :=
  fun x y =>
    let π : G →* G ⧸ N := QuotientGroup.mk' N
    have hπ : π (s x * s y * (s (x * y))⁻¹) = 1 := by
      calc
        π (s x * s y * (s (x * y))⁻¹)
            = π (s x) * π (s y) * (π (s (x * y)))⁻¹ := by simp [map_mul]
        _ = x * y * (x * y)⁻¹ := by simp [π, hs]
        _ = 1 := by simp
    have hker : s x * s y * (s (x * y))⁻¹ ∈ π.ker := by
      rw [MonoidHom.mem_ker]; exact hπ
    have hmem : s x * s y * (s (x * y))⁻¹ ∈ N := by
      simpa [π, QuotientGroup.ker_mk' N] using hker
    ⟨s x * s y * (s (x * y))⁻¹, hmem⟩

theorem schreierDefect_mem
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x) (x y : G ⧸ N) :
    s x * s y * (s (x * y))⁻¹ ∈ N := by
  let π : G →* G ⧸ N := QuotientGroup.mk' N
  have hπ : π (s x * s y * (s (x * y))⁻¹) = 1 := by
    calc
      π (s x * s y * (s (x * y))⁻¹)
          = π (s x) * π (s y) * (π (s (x * y)))⁻¹ := by simp [map_mul]
      _ = x * y * (x * y)⁻¹ := by simp [π, hs]
      _ = 1 := by simp
  have hker : s x * s y * (s (x * y))⁻¹ ∈ π.ker := by
    rw [MonoidHom.mem_ker]; exact hπ
  simpa [π, QuotientGroup.ker_mk' N] using hker

theorem continuous_schreierDefect
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x) :
    Continuous (fun xy : (G ⧸ N) × (G ⧸ N) =>
      Additive.ofMul (schreierDefect G N s hs xy.1 xy.2)) := by
  change Continuous (fun xy : (G ⧸ N) × (G ⧸ N) => schreierDefect G N s hs xy.1 xy.2)
  unfold schreierDefect
  refine Continuous.subtype_mk ?_ ?_
  exact
    ((s.continuous.comp continuous_fst).mul (s.continuous.comp continuous_snd)).mul
      ((s.continuous.comp (continuous_fst.mul continuous_snd)).inv)

theorem schreierDefect_relation
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x)
    (x y z : G ⧸ N) :
    schreierDefect G N s hs x y * schreierDefect G N s hs (x * y) z =
      (MulAut.conjNormal (H := N) (s x)) (schreierDefect G N s hs y z) *
        schreierDefect G N s hs x (y * z) := by
  apply Subtype.ext
  simp [schreierDefect, MulAut.conjNormal_apply, mul_assoc]

noncomputable def schreier2Cocycle
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x)
    (χ : Additive ↥N →+ ZMod p) :
    ContinuousMap ((G ⧸ N) × (G ⧸ N)) (ZMod p) := by
  classical
  by_cases hχ : Continuous χ
  · exact
      { toFun := fun xy =>
          χ (Additive.ofMul (schreierDefect G N s hs xy.1 xy.2))
        continuous_toFun := by
          exact hχ.comp (continuous_schreierDefect G N s hs) }
  · exact 0

theorem schreier_isCocycle (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x)
    (χ : Additive ↥N →+ ZMod p)
    (_hχ : ∀ g : G, χ.comp (MonoidHom.toAdditive
      ((MulAut.conjNormal (H := N) g).toMonoidHom)) = χ) :
    _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N)
      (schreier2Cocycle p G N s hs χ) := by
  classical
  by_cases hχ : Continuous χ
  · intro x y z
    let c : G ⧸ N → G ⧸ N → ↥N := schreierDefect G N s hs
    have hrel := schreierDefect_relation G N s hs x y z
    have hχrel :
        χ (Additive.ofMul (c x y)) + χ (Additive.ofMul (c (x * y) z)) =
          χ (Additive.ofMul ((MulAut.conjNormal (H := N) (s x)) (c y z))) +
            χ (Additive.ofMul (c x (y * z))) := by
      simpa [c, map_mul] using (congrArg (fun n : ↥N => χ (Additive.ofMul n)) hrel)
    have hconj :
        χ (Additive.ofMul ((MulAut.conjNormal (H := N) (s x)) (c y z))) =
          χ (Additive.ofMul (c y z)) := by
      let n : Additive ↥N := Additive.ofMul (c y z)
      have hEq := congrArg (fun f : Additive ↥N →+ ZMod p => f n) (_hχ (s x))
      simpa [n, c, AddMonoidHom.comp_apply] using hEq
    have hχrel' :
        χ (Additive.ofMul (c x y)) + χ (Additive.ofMul (c (x * y) z)) =
          χ (Additive.ofMul (c y z)) + χ (Additive.ofMul (c x (y * z))) := by
      rw [hconj] at hχrel
      exact hχrel
    have hzero :
        χ (Additive.ofMul (c y z)) - χ (Additive.ofMul (c (x * y) z)) +
            χ (Additive.ofMul (c x (y * z))) - χ (Additive.ofMul (c x y)) = 0 := by
      calc
        χ (Additive.ofMul (c y z)) - χ (Additive.ofMul (c (x * y) z)) +
            χ (Additive.ofMul (c x (y * z))) - χ (Additive.ofMul (c x y)) =
            (χ (Additive.ofMul (c y z)) + χ (Additive.ofMul (c x (y * z)))) -
              (χ (Additive.ofMul (c x y)) + χ (Additive.ofMul (c (x * y) z))) := by
                abel
        _ = 0 := by rw [← hχrel']; simp
    simpa [_root_.Erdos90.InhomogClassAPI.IsCocycle2, schreier2Cocycle, hχ, c] using hzero
  · intro x y z
    simp [_root_.Erdos90.InhomogClassAPI.IsCocycle2, schreier2Cocycle, hχ]

theorem schreier2Cocycle_add_of_continuous (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x)
    (χ ψ : Additive ↥N →+ ZMod p)
    (hχ : Continuous χ) (hψ : Continuous ψ) :
    schreier2Cocycle p G N s hs (χ + ψ) =
      schreier2Cocycle p G N s hs χ + schreier2Cocycle p G N s hs ψ := by
  classical
  have hχψ : Continuous ⇑(χ + ψ) := hχ.add hψ
  ext xy
  simp [schreier2Cocycle, hχ, hψ, hχψ]

theorem schreier2Cocycle_smul_of_continuous (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (s : ContinuousMap (G ⧸ N) G)
    (hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x)
    (a : ZMod p) (χ : Additive ↥N →+ ZMod p)
    (hχ : Continuous χ) :
    schreier2Cocycle p G N s hs (a • χ) =
      a • schreier2Cocycle p G N s hs χ := by
  classical
  have haχ : Continuous (a • χ) := hχ.const_smul a
  ext xy
  simp [schreier2Cocycle, hχ, haχ, smul_eq_mul]

theorem ofIsCocycle2_add (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (f g : ContinuousMap (G × G) (ZMod p))
    (hf : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G f)
    (hg : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G g)
    (hfg : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G (f + g)) :
    _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (f + g) hfg =
      _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G f hf +
        _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G g hg := by
  ext x
  rfl

theorem ofIsCocycle2_smul (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (a : ZMod p) (f : ContinuousMap (G × G) (ZMod p))
    (hf : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G f)
    (haf : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G (a • f)) :
    _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G (a • f) haf =
      a • _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G f hf := by
  rfl


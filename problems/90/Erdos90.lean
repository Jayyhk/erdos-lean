    have hGeval (m : в„Ө) :
        Polynomial.eval m G = 1 + M * (m * Polynomial.eval ((a * M) * m) g.divX) := by
      simp [G, mul_assoc, mul_left_comm, mul_comm, add_assoc, add_left_comm, add_comm]
    have hRootsFinite :
        ({x : в„Ө | Polynomial.IsRoot (G - Polynomial.C 1) x} вҲӘ
          {x : в„Ө | Polynomial.IsRoot (G + Polynomial.C 1) x}).Finite := by

    Subgroup.isOpen_mono (show V.toSubgroup вүӨ N вҠ” V.toSubgroup from le_sup_right) V.isOpen
  letI : DiscreteTopology (G в§ё (N вҠ” V.toSubgroup)) :=
    QuotientGroup.discreteTopology (N := N вҠ” V.toSubgroup) hNV_open
  refine вҹЁ
    { toFun := fun y => s y
      continuous_toFun := continuous_of_discreteTopology },

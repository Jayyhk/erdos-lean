theorem fairSeedServiceExtension_protectedEndpoint_ge {seed : ℕ}
    (snode : ScheduledActiveState seed) {k : ℕ} (hreq : fairRequest k = seed) :
    k ≤ (snode.fairSeedServiceExtension_of_request_seed hreq).protectedEndpoint := by

theorem countable_clopens_of_countable_openNormalSubgroup
    {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (hON : Countable (OpenNormalSubgroup G)) :
    Countable (TopologicalSpace.Clopens G) := by
  classical
  let basisFun : (Σ H : OpenNormalSubgroup G, G ⧸ H.toSubgroup) → Set G :=
    fun p => (QuotientGroup.mk : G → G ⧸ p.1.toSubgroup) ⁻¹'
      ({p.2} : Set (G ⧸ p.1.toSubgroup))
  let B : Set (Set G) := Set.range basisFun
  have hBasis : TopologicalSpace.IsTopologicalBasis B := by
    refine TopologicalSpace.isTopologicalBasis_of_isOpen_of_nhds ?_ ?_
    · intro s hs
      rcases hs with ⟨⟨H, q⟩, rfl⟩
      simpa using (isOpen_discrete ({q} : Set (G ⧸ H.toSubgroup))).preimage
        (QuotientGroup.continuous_mk :
          Continuous (QuotientGroup.mk : G → G ⧸ H.toSubgroup))
    · intro x U hxU UOpen
      let V : Set G := (fun y : G => x * y) ⁻¹' U
      have hVOpen : IsOpen V := by
        simpa [V] using UOpen.preimage (Homeomorph.mulLeft x).continuous
      have h1V : (1 : G) ∈ V := by
        simpa [V] using hxU
      obtain ⟨H, hH⟩ :=
        ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one hVOpen h1V
      refine ⟨basisFun ⟨H, (x : G ⧸ H.toSubgroup)⟩,
        ⟨⟨H, (x : G ⧸ H.toSubgroup)⟩, rfl⟩, ?_, ?_⟩
      · simp [basisFun]
      · intro y hy
        have hxy : (y : G ⧸ H.toSubgroup) = x := by
          simpa [basisFun] using hy
        have hmem : x⁻¹ * y ∈ H := QuotientGroup.eq.mp hxy.symm
        simpa [V, mul_assoc] using hH hmem
  have hBCount : B.Countable := by
    letI : Countable (OpenNormalSubgroup G) := hON
    simpa [B] using Set.countable_range basisFun
  letI : SecondCountableTopology G := hBasis.secondCountableTopology hBCount
  exact (TopologicalSpace.Clopens.countable_iff_secondCountable (X := G)).2
    inferInstance

theorem countable_monoidHomToFinite_of_fg
    (Γ K : Type*) [Group Γ] [Group K] [Group.FG Γ] [Finite K] :
    Countable (Γ →* K) := by
  classical
  have hfg : Group.FG Γ := inferInstance
  rcases Group.fg_iff_exists_freeGroup_hom_surjective.mp hfg with
    ⟨S, hSfin, φ, hφsurj⟩
  let enc : (Γ →* K) → (S → K) := fun ψ =>
    (FreeGroup.lift : (S → K) ≃ (FreeGroup S →* K)).symm (ψ.comp φ)
  have henc : Function.Injective enc := by
    intro ψ₁ ψ₂ h
    have h' : ψ₁.comp φ = ψ₂.comp φ := by
      have h'' := congrArg
        (fun f : S → K => (FreeGroup.lift : (S → K) ≃ (FreeGroup S →* K)) f) h
      simpa [enc] using h''
    ext γ
    rcases hφsurj γ with ⟨x, rfl⟩
    exact DFunLike.congr_fun h' x
  letI : Finite S := hSfin.to_subtype
  letI : Countable (S → K) := Finite.to_countable
  exact Function.Injective.countable henc

theorem countable_finiteIndexNormalSubgroup_of_fg
    (Γ : Type*) [Group Γ] [Group.FG Γ] :
    Countable {N : Subgroup Γ // N.Normal ∧ N.FiniteIndex} := by
  classical
  let S := Σ n : ℕ, (Γ →* Equiv.Perm (Fin n))
  let g : S → {N : Subgroup Γ // N.Normal ∧ N.FiniteIndex} := fun s =>
    ⟨s.2.ker, MonoidHom.normal_ker s.2, by
      letI : Finite s.2.range := inferInstance
      exact Subgroup.finiteIndex_ker s.2⟩
  have hS : Countable S := by
    letI (n : ℕ) : Countable (Γ →* Equiv.Perm (Fin n)) :=
      countable_monoidHomToFinite_of_fg Γ (Equiv.Perm (Fin n))
    infer_instance
  have hsurj : Function.Surjective g := by
    intro N
    letI : N.1.Normal := N.2.1
    letI : N.1.FiniteIndex := N.2.2
    let Q := Γ ⧸ N.1
    letI : Fintype Q := by
      dsimp [Q]
      exact Subgroup.fintypeQuotientOfFiniteIndex (H := N.1)
    let e : Q ≃ Fin (Fintype.card Q) := Fintype.equivFin Q
    let ρ0 : Γ →* Equiv.Perm Q := MulAction.toPermHom Γ Q
    let ρ : Γ →* Equiv.Perm (Fin (Fintype.card Q)) :=
      (e.permCongrHom.toMonoidHom).comp ρ0
    refine ⟨⟨Fintype.card Q, ρ⟩, ?_⟩
    apply Subtype.ext
    change ρ.ker = N.1
    have hker0 : ρ0.ker = N.1 := by
      dsimp [ρ0, Q]
      exact (Subgroup.normalCore_eq_ker N.1).symm.trans
        (Subgroup.normalCore_eq_self N.1)
    ext x
    simp [ρ, hker0, MonoidHom.comp_apply]
  exact Function.Surjective.countable hsurj

theorem countable_openNormalSubgroup_of_dense_fg_subgroup
    {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] (Γ : Subgroup G) [Group.FG Γ]
    (hΓdense : Dense (Γ : Set G)) :
    Countable (OpenNormalSubgroup G) := by
  classical
  let enc : OpenNormalSubgroup G →
      {N : Subgroup Γ // N.Normal ∧ N.FiniteIndex} := fun H => by
    refine ⟨H.toSubgroup.subgroupOf Γ, inferInstance, ?_⟩
    letI : Finite ((⊤ : Subgroup G) ⧸
        H.toSubgroup.subgroupOf (⊤ : Subgroup G)) :=
      Subgroup.quotient_finite_of_isOpen' (U := (⊤ : Subgroup G))
        (K := H.toSubgroup.subgroupOf (⊤ : Subgroup G))
        (by simp)
        (Subgroup.subgroupOf_isOpen (⊤ : Subgroup G) H.toSubgroup
          H.toOpenSubgroup.isOpen)
    let e : Γ ⧸ H.toSubgroup.subgroupOf Γ ↪
        (⊤ : Subgroup G) ⧸ H.toSubgroup.subgroupOf (⊤ : Subgroup G) :=
      Subgroup.quotientSubgroupOfEmbeddingOfLE H.toSubgroup (by
        intro g hg
        simp)
    letI : Finite (Γ ⧸ H.toSubgroup.subgroupOf Γ) :=
      Finite.of_injective e e.injective
    exact Subgroup.finiteIndex_of_finite_quotient
      (G := Γ) (H := H.toSubgroup.subgroupOf Γ)
  have henc : Function.Injective enc := by
    intro H K h
    apply OpenNormalSubgroup.toSubgroup_injective
    ext g
    change g ∈ (H : Set G) ↔ g ∈ (K : Set G)
    constructor
    · intro hg
      have hEqSub : H.toSubgroup.subgroupOf Γ = K.toSubgroup.subgroupOf Γ :=
        congrArg Subtype.val h
      have hHK : ((H : Set G) ∩ (Γ : Set G)) ⊆ (K : Set G) := by
        intro x hx
        have hxH : (⟨x, hx.2⟩ : Γ) ∈ H.toSubgroup.subgroupOf Γ := by
          simpa using hx.1
        have hxK : (⟨x, hx.2⟩ : Γ) ∈ K.toSubgroup.subgroupOf Γ := by
          simpa [hEqSub] using hxH
        simpa using hxK
      have hg' : g ∈ closure ((H : Set G) ∩ (Γ : Set G)) :=
        (Dense.open_subset_closure_inter hΓdense
          H.toOpenSubgroup.isOpen) hg
      exact closure_minimal hHK
        (OpenSubgroup.isClosed K.toOpenSubgroup) hg'
    · intro hg
      have hEqSub : K.toSubgroup.subgroupOf Γ = H.toSubgroup.subgroupOf Γ :=
        (congrArg Subtype.val h).symm
      have hKH : ((K : Set G) ∩ (Γ : Set G)) ⊆ (H : Set G) := by
        intro x hx
        have hxK : (⟨x, hx.2⟩ : Γ) ∈ K.toSubgroup.subgroupOf Γ := by
          simpa using hx.1
        have hxH : (⟨x, hx.2⟩ : Γ) ∈ H.toSubgroup.subgroupOf Γ := by
          simpa [hEqSub] using hxK
        simpa using hxH
      have hg' : g ∈ closure ((K : Set G) ∩ (Γ : Set G)) :=
        (Dense.open_subset_closure_inter hΓdense
          K.toOpenSubgroup.isOpen) hg
      exact closure_minimal hKH
        (OpenSubgroup.isClosed H.toOpenSubgroup) hg'
  letI : Countable {N : Subgroup Γ // N.Normal ∧ N.FiniteIndex} :=
    countable_finiteIndexNormalSubgroup_of_fg Γ
  exact Function.Injective.countable henc

theorem secondCountableTopology_of_fg_profinite
    {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    {S : Finset G}
    (hS : (Subgroup.closure (S : Set G)).topologicalClosure = ⊤) :
    SecondCountableTopology G := by
  classical
  let Γ : Subgroup G := Subgroup.closure (S : Set G)
  have hΓdense : Dense (Γ : Set G) := by
    rw [dense_iff_closure_eq]
    rw [show closure (Γ : Set G) = (Γ.topologicalClosure : Set G) by
      rw [Subgroup.topologicalClosure_coe]]
    simpa [Γ] using congrArg (fun H : Subgroup G => (H : Set G)) hS
  have hΓfg_subgroup : Γ.FG := by
    rw [Subgroup.fg_iff]
    refine ⟨S, ?_⟩
    simp [Γ]
  have hΓfg : Group.FG Γ := by
    rw [Group.fg_iff_subgroup_fg]
    exact hΓfg_subgroup
  have hON : Countable (OpenNormalSubgroup G) :=
    countable_openNormalSubgroup_of_dense_fg_subgroup Γ hΓdense
  have hClopen : Countable (TopologicalSpace.Clopens G) :=
    countable_clopens_of_countable_openNormalSubgroup hON
  rw [← TopologicalSpace.Clopens.countable_iff_secondCountable]
  exact hClopen


theorem cochainsMapTrivial_cyclesMap_one_eq_zero (p : ℕ) [Fact p.Prime]
    (A : Type) [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (B : Type) [Group B] [TopologicalSpace B] [IsTopologicalGroup B]
    (hf : Continuous ((1 : A →* B))) :
    HomologicalComplex.cyclesMap
      (ContinuousCohomology.cochainsMapTrivial (ZMod p) (1 : A →* B) hf
        (TopModuleCat.of (ZMod p) (ZMod p))) 1 = 0 := by
  rw [← CategoryTheory.cancel_mono (((ContinuousCohomology.homogeneousCochains (ZMod p) A).obj
      (Action.trivial A (TopModuleCat.of (ZMod p) (ZMod p)))).iCycles 1)]
  rw [HomologicalComplex.cyclesMap_i]
  ext x
  let K : CochainComplex (TopModuleCat (ZMod p)) ℕ :=
    (ContinuousCohomology.homogeneousCochains (ZMod p) B).obj
      (Action.trivial B (TopModuleCat.of (ZMod p) (ZMod p)))
  let X : Action (TopModuleCat (ZMod p)) B :=
    Action.trivial B (TopModuleCat.of (ZMod p) (ZMod p))
  let z : K.X 1 := (TopModuleCat.Hom.hom (K.iCycles 1)) x
  let zz : C(B, C(B, ZMod p)) := z.1
  have hz : ((K.d 1 2).hom) z = 0 := by
    change (TopModuleCat.Hom.hom (CategoryTheory.CategoryStruct.comp (K.iCycles 1) (K.d 1 2)) x = 0)
    simp
  let d1zz : C(B, C(B, ZMod p)) :=
    ((ContinuousCohomology.MultiInd.d (ZMod p) B 1).app X).hom.hom (zz 1)
  have hd1_formula : d1zz 1 1 = 0 := by
    unfold d1zz
    rw [ContinuousCohomology.MultiInd.d_succ]
    change (zz 1 1 - zz 1 1 = 0)
    simp
  let d2z : K.X 2 := ((K.d 1 2).hom z)
  let d2zz : C(B, C(B, C(B, ZMod p))) := d2z.1
  have hd2_formula : d2zz 1 1 1 = zz 1 1 := by
    unfold d2zz d2z
    change (zz 1 1 - d1zz 1 1 = zz 1 1)
    rw [hd1_formula]
    simp
  have hd2_zero : d2zz = 0 := by
    simpa [d2zz, d2z] using congrArg Subtype.val hz
  have hz_eval : zz 1 1 = 0 := by
    rw [← hd2_formula]
    have h := congrArg (fun w : C(B, C(B, C(B, ZMod p))) => w 1 1 1) hd2_zero
    simpa using h
  simp [z]
  apply Subtype.ext
  apply ContinuousMap.ext
  intro a
  apply ContinuousMap.ext
  intro b
  change zz 1 1 = 0
  exact hz_eval


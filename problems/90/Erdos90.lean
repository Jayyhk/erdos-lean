    have h_exp :
        MeasureTheory.IntegrableOn
          (fun x : в„қ => Complex.exp ((-z) * x))
          (Set.Ioi (0 : в„қ)) :=
      integrableOn_exp_mul_complex_Ioi hz' 0
    simpa using h_exp.const_mul (((b : в„қ) : в„Ӯ))
  convert h1.sub h2 using 1
  ext x
  simp [sub_mul]

theorem lseries_eq_logRescalePartialSum_laplace {f : в„• вҶ’ в„қ} :
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hsumm : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    вҲҖ z : в„Ӯ, 0 < z.re вҶ’
      LSeries (fun n => (f n : в„Ӯ)) (1 + z) =
        (1 + z) * вҲ« x in Set.Ioi (0 : в„қ),
          (((logRescalePartialSum f x : в„қ) : в„Ӯ) * Complex.exp (-z * x)) := by
  intro hnonneg hsumm z hz
  let r : в„қ := 1 + z.re / 2
  have hr1 : 1 < r := by
    dsimp [r]
    linarith
  obtain вҹЁC, hCnonneg, hCвҹ© :=
    icc_growth_family_of_LSeriesSummable_nonneg hnonneg hsumm r hr1
  have hr0 : 0 вүӨ r := by
    dsimp [r]
    linarith
  have hrs : r < (1 + z).re := by
    dsimp [r]

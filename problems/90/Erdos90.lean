      (((logRescalePartialSum f (x + Оҙ) - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)) =
          (((logRescalePartialSum f (x + Оҙ) - b : в„қ) : в„Ӯ) *
            (Complex.exp (z * Оҙ) * Complex.exp (-z * (x + Оҙ)))) := by
            rw [hexp]

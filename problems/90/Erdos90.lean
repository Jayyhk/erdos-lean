theorem primesCongOneMod3_residueClass_nonprime_div_summable: Summable fun n : ℕ => (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n := by
  simpa [primesCongOneMod3_residueClass] using
    (ArithmeticFunction.vonMangoldt.summable_residueClass_non_primes_div (a := (1 : ZMod 3)))

theorem primesCongOneMod3_residueClass_nonprime_partial_sum_sublinear (ε : ℝ) : 0 < ε → ∃ X₀ : ℕ, ∀ X : ℕ, X₀ ≤ X →
    ∑ n ∈ Finset.range X,
      (if n.Prime then 0 else primesCongOneMod3_residueClass n) ≤ ε * X := by
  intro hε
  let a : ℕ → ℝ := fun n => if n.Prime then 0 else primesCongOneMod3_residueClass n
  let g : ℕ → ℝ := fun n => a n / n
  let G : ℕ → ℝ := fun X => ∑ n ∈ Finset.range X, g n
  let W : ℕ → ℝ := fun X => ∑ n ∈ Finset.range X, (n : ℝ) * g n
  have hg : Summable g := by
    simpa [g, a] using primesCongOneMod3_residueClass_nonprime_div_summable
  have ha0 : a 0 = 0 := by
    simp [a, primesCongOneMod3_residueClass]
  have hg0 : g 0 = 0 := by
    simp [g, a]
  have ha_mul (n : ℕ) (hn : n ≠ 0) : a n = (n : ℝ) * g n := by
    have hnr : (n : ℝ) ≠ 0 := by exact_mod_cast hn
    by_cases hp : n.Prime
    · simp [a, g, hp]
    · dsimp [g, a]
      simp [hp]
      field_simp [hnr]
  have hA_eq_W (X : ℕ) : (∑ n ∈ Finset.range X, a n) = W X := by
    unfold W
    refine Finset.sum_congr rfl ?_
    intro n hn
    by_cases hzero : n = 0
    · subst hzero
      simp [ha0, hg0]
    · simpa [hzero] using ha_mul n hzero
  let L : ℝ := ∑' n, g n
  have hG : Filter.Tendsto G Filter.atTop (nhds L) := by
    simpa [G, L] using hg.hasSum.tendsto_sum_nat
  have hGsucc : Filter.Tendsto (fun n : ℕ => G (n + 1)) Filter.atTop (nhds L) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).2 hG
  have hcesaro : Filter.Tendsto (fun n : ℕ => (n : ℝ)⁻¹ * ∑ i ∈ Finset.range n, G (i + 1)) Filter.atTop (nhds L) := by
    exact Filter.Tendsto.cesaro hGsucc
  have hden_nat : Filter.Tendsto (fun n : ℕ => ((n + 1 : ℕ) : ℝ)) Filter.atTop Filter.atTop := by
    simpa [Nat.add_comm] using (Filter.tendsto_add_atTop_iff_nat 1).2 (tendsto_natCast_atTop_atTop : Filter.Tendsto ((↑) : ℕ → ℝ) Filter.atTop Filter.atTop)
  have hden : Filter.Tendsto (fun n : ℕ => (n : ℝ) + 1) Filter.atTop Filter.atTop := by
    simpa [Nat.cast_add, add_comm, add_left_comm, add_assoc] using hden_nat
  have hterm_div : Filter.Tendsto (fun n : ℕ => G (n + 1) / (n + 1)) Filter.atTop (nhds 0) := by
    exact Filter.Tendsto.div_atTop hGsucc hden
  have hpaux : Filter.Tendsto (fun n : ℕ => ((n : ℝ) / (n + 1)) * G (n + 1)) Filter.atTop (nhds L) := by
    have hEq : (fun n : ℕ => ((n : ℝ) / (n + 1)) * G (n + 1)) = fun n : ℕ => G (n + 1) - G (n + 1) / (n + 1) := by
      funext n
      have hne : ((n + 1 : ℕ) : ℝ) ≠ 0 := by positivity
      field_simp [hne]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hGsucc.sub hterm_div
  have hcesaro_shift : Filter.Tendsto (fun n : ℕ => ((n + 1 : ℕ) : ℝ)⁻¹ * ∑ i ∈ Finset.range (n + 1), G (i + 1)) Filter.atTop (nhds L) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).2 hcesaro
  have hqaux : Filter.Tendsto (fun n : ℕ => (∑ i ∈ Finset.range n, G (i + 1)) / (n + 1)) Filter.atTop (nhds L) := by
    have hEq : (fun n : ℕ => (∑ i ∈ Finset.range n, G (i + 1)) / (n + 1)) = fun n : ℕ =>
      (((n + 1 : ℕ) : ℝ)⁻¹ * ∑ i ∈ Finset.range (n + 1), G (i + 1)) - G (n + 1) / (n + 1) := by
      funext n
      rw [Finset.sum_range_succ]
      have hne : ((n + 1 : ℕ) : ℝ) ≠ 0 := by positivity
      field_simp [hne]
      norm_num [Nat.cast_add]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hcesaro_shift.sub hterm_div
  have hparts (X : ℕ) : W X = ((X - 1 : ℕ) : ℝ) * G X - ∑ i ∈ Finset.range (X - 1), G (i + 1) := by
    simpa [W, G] using (Finset.sum_range_by_parts (fun n => (n : ℝ)) g X)
  have hWaux : Filter.Tendsto (fun n : ℕ => W (n + 1) / (n + 1)) Filter.atTop (nhds 0) := by
    have hEq : (fun n : ℕ => W (n + 1) / (n + 1)) = fun n : ℕ => ((n : ℝ) / (n + 1)) * G (n + 1) - (∑ i ∈ Finset.range n, G (i + 1)) / (n + 1) := by
      funext n
      rw [hparts (n + 1)]
      have hne : ((n + 1 : ℕ) : ℝ) ≠ 0 := by positivity
      field_simp [hne]
      norm_num [Nat.cast_add]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hpaux.sub hqaux
  have hWdiv : Filter.Tendsto (fun X : ℕ => W X / X) Filter.atTop (nhds 0) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).1 (by simpa using hWaux)
  have h_event : ∀ᶠ X : ℕ in Filter.atTop, W X / X < ε := by
    exact hWdiv (Iio_mem_nhds hε)
  rcases Filter.eventually_atTop.1 h_event with ⟨X₀, hX₀⟩
  refine ⟨X₀, ?_⟩
  intro X hX
  have hlt : W X / X < ε := hX₀ X hX
  by_cases hzero : X = 0
  · subst hzero
    simp [hA_eq_W]
  · have hXpos : (0 : ℝ) < X := by
      exact_mod_cast Nat.pos_of_ne_zero hzero
    have hmul : W X < ε * X := (div_lt_iff₀ hXpos).1 hlt
    have : ∑ n ∈ Finset.range X, a n < ε * X := by
      simpa [hA_eq_W X] using hmul
    exact le_of_lt this

theorem primesCongOneMod3_residueClass_prime_div_nonsummable: ¬ Summable fun n : ℕ => (if n.Prime then primesCongOneMod3_residueClass n else 0) / n := by
  simpa [primesCongOneMod3_residueClass] using
    (ArithmeticFunction.vonMangoldt.not_summable_residueClass_prime_div (a := (1 : ZMod 3)) (by simp))

theorem primesCongOneMod3_residueClass_div_nonsummable: ¬ Summable fun n : ℕ => primesCongOneMod3_residueClass n / n := by
  intro hsum
  have hsub : Summable (fun n : ℕ => primesCongOneMod3_residueClass n / n - (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n) :=
    hsum.sub primesCongOneMod3_residueClass_nonprime_div_summable
  have hprime : Summable (fun n : ℕ => (if n.Prime then primesCongOneMod3_residueClass n else 0) / n) := by
    refine hsub.congr ?_
    intro n
    by_cases hn : n.Prime <;> simp [hn]
  exact primesCongOneMod3_residueClass_prime_div_nonsummable hprime

theorem primesCongOneMod3_residueClass_prime_eq_log (p : ℕ) (hp : p.Prime) (hmod : p % 3 = 1) : primesCongOneMod3_residueClass p = Real.log p := by
  unfold primesCongOneMod3_residueClass ArithmeticFunction.vonMangoldt.residueClass
  rw [Set.indicator_of_mem]
  · exact ArithmeticFunction.vonMangoldt_apply_prime hp
  · exact (ZMod.natCast_eq_natCast_iff' p 1 3).2 hmod

theorem primesCongOneMod3_prime_series_lower_bound: ∃ C : ℝ, ∀ {x : ℝ}, x ∈ Set.Ioc 1 2 →
    ((Nat.totient 3 : ℝ)⁻¹ / (x - 1) - C) ≤
      ∑' n : ℕ, (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) / (n : ℝ) ^ x := by
  rcases primesCongOneMod3_residueClass_lower_bound with ⟨C₀, hC₀⟩
  let B : ℝ := ∑' n : ℕ, (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n
  refine ⟨C₀ + B, ?_⟩
  intro x hx
  let f : ℕ → ℝ := fun n => primesCongOneMod3_residueClass n / (n : ℝ) ^ x
  let fPrime : ℕ → ℝ := fun n => (if n.Prime then primesCongOneMod3_residueClass n else 0) / (n : ℝ) ^ x
  let fNonprime : ℕ → ℝ := fun n => (if n.Prime then 0 else primesCongOneMod3_residueClass n) / (n : ℝ) ^ x
  let target : ℕ → ℝ := fun n =>
    (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) / (n : ℝ) ^ x
  have hfull : ((Nat.totient 3 : ℝ)⁻¹ / (x - 1) - C₀) ≤ ∑' n, f n := by
    simpa [f] using hC₀ hx
  have hfullsumm : Summable f := by
    dsimp [f, primesCongOneMod3_residueClass]
    have hx' : (1 : EReal) < x := by
      exact_mod_cast hx.1
    exact LSeries.summable_real_of_abscissaOfAbsConv_lt <|
      (ArithmeticFunction.vonMangoldt.abscissaOfAbsConv_residueClass_le_one (a := (1 : ZMod 3))).trans_lt hx'
  have hNonprime_nonneg (n : ℕ) : 0 ≤ fNonprime n := by
    dsimp [fNonprime]
    by_cases hn : n.Prime
    · simp [hn]
    · simp [hn]
      exact div_nonneg
        (ArithmeticFunction.vonMangoldt.residueClass_nonneg (a := (1 : ZMod 3)) n)
        (Real.rpow_nonneg (by exact_mod_cast Nat.zero_le n) x)
  have hNonprime_le (n : ℕ) : fNonprime n ≤ (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n := by
    rcases n.eq_zero_or_pos with rfl | hn
    · simp [fNonprime, primesCongOneMod3_residueClass, ArithmeticFunction.vonMangoldt.residueClass_apply_zero]
    · refine div_le_div_of_nonneg_left ?_ (by exact_mod_cast hn) ?_
      · dsimp [fNonprime]
        split_ifs
        · exact le_rfl
        · exact ArithmeticFunction.vonMangoldt.residueClass_nonneg (a := (1 : ZMod 3)) n
      · conv_lhs => rw [← Real.rpow_one n]
        exact Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast Nat.succ_le_of_lt hn) hx.1.le
  have hNonprime_summ : Summable fNonprime := by
    refine Summable.of_nonneg_of_le hNonprime_nonneg hNonprime_le ?_
    exact primesCongOneMod3_residueClass_nonprime_div_summable
  have hNonprime_tsum_le : ∑' n, fNonprime n ≤ B := by
    simpa [B] using Summable.tsum_le_tsum hNonprime_le hNonprime_summ primesCongOneMod3_residueClass_nonprime_div_summable
  have hPrime_fun : fPrime = fun n : ℕ => f n - fNonprime n := by
    ext n
    by_cases hn : n.Prime <;> simp [f, fPrime, fNonprime, hn]
  have hPrime_summ : Summable fPrime := by
    simpa [hPrime_fun] using hfullsumm.sub hNonprime_summ
  have hsplit_fun : f = fun n : ℕ => fPrime n + fNonprime n := by
    ext n
    by_cases hn : n.Prime <;> simp [f, fPrime, fNonprime, hn]
  have hsplit : ∑' n, f n = ∑' n, fPrime n + ∑' n, fNonprime n := by
    have hsumPrime := hPrime_summ.hasSum
    have hsumNonprime := hNonprime_summ.hasSum
    have hsumAdd : HasSum (fun n : ℕ => fPrime n + fNonprime n) (∑' n, fPrime n + ∑' n, fNonprime n) :=
      hsumPrime.add hsumNonprime
    have hsumF : HasSum f (∑' n, fPrime n + ∑' n, fNonprime n) := by
      simpa [hsplit_fun] using hsumAdd
    exact hsumF.tsum_eq
  have hPrime_eq (n : ℕ) : fPrime n = target n := by
    by_cases hn : n.Prime
    · by_cases hmod : n % 3 = 1
      · simp [fPrime, target, hn, hmod, primesCongOneMod3_residueClass_prime_eq_log n hn hmod]
      · have hzmod : ¬ ((n : ZMod 3) = (1 : ZMod 3)) := by
          intro hz
          apply hmod
          simpa using (ZMod.natCast_eq_natCast_iff' n 1 3).mp hz
        have hzero : primesCongOneMod3_residueClass n = 0 := by
          unfold primesCongOneMod3_residueClass ArithmeticFunction.vonMangoldt.residueClass
          simp [hzmod]
        simp [fPrime, target, hn, hmod, hzero]
    · simp [fPrime, target, hn]
  have hPrime_tsum : ∑' n, fPrime n = ∑' n, target n := by
    refine tsum_congr ?_
    intro n
    exact hPrime_eq n
  have hbound : ∑' n, f n ≤ ∑' n, target n + B := by
    calc
      ∑' n, f n = ∑' n, fPrime n + ∑' n, fNonprime n := hsplit
      _ ≤ ∑' n, fPrime n + B := by
        simpa [add_comm, add_left_comm, add_assoc] using add_le_add_left hNonprime_tsum_le (∑' n, fPrime n)
      _ = ∑' n, target n + B := by rw [hPrime_tsum]
  have hfinal : ((Nat.totient 3 : ℝ)⁻¹ / (x - 1) - (C₀ + B)) ≤ ∑' n, target n := by
    linarith
  simpa [target, B] using hfinal

theorem primesCongOneMod3_spec (i : ℕ) : (primesCongOneMod3 i).Prime ∧ primesCongOneMod3 i % 3 = 1 := by
  unfold primesCongOneMod3
  simpa using Nat.nth_mem_of_infinite primesCongOneMod3_infinite i

theorem primesCongOneMod3_mod (i : ℕ) : primesCongOneMod3 i % 3 = 1 := by
  exact (primesCongOneMod3_spec i).2

theorem primesCongOneMod3_prime (i : ℕ) : (primesCongOneMod3 i).Prime := by
  exact (primesCongOneMod3_spec i).1

theorem primesCongOneMod3_strictMono: StrictMono primesCongOneMod3 := by
  unfold primesCongOneMod3
  exact Nat.nth_strictMono primesCongOneMod3_infinite

theorem primesCongOneMod3_weighted_prime_series_avg_lower_bound: ∃ c : ℝ, 0 < c ∧ ∃ M₀ : ℕ, ∀ M : ℕ, M₀ ≤ M →
    c * (M : ℝ) ≤
      ∑' n : ℕ,
        (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) /
          (n : ℝ) ^ (1 + (M : ℝ)⁻¹) := by
  rcases primesCongOneMod3_prime_series_lower_bound with ⟨C, hC⟩
  refine ⟨(1 : ℝ) / 4, by norm_num, ?_⟩
  let M₀ : ℕ := max 1 (Nat.ceil (4 * max C 0))
  refine ⟨M₀, ?_⟩
  intro M hM
  have hM' : max 1 (Nat.ceil (4 * max C 0)) ≤ M := by
    simpa [M₀] using hM
  let x : ℝ := 1 + (M : ℝ)⁻¹
  have hM1 : 1 ≤ M := le_trans (le_max_left 1 (Nat.ceil (4 * max C 0))) hM'
  have hM0_nat : 0 < M := lt_of_lt_of_le (by decide : 0 < 1) hM1
  have hMpos : 0 < (M : ℝ) := by
    exact_mod_cast hM0_nat
  have hMinv_le_one : (M : ℝ)⁻¹ ≤ 1 := by
    have hMge1 : (1 : ℝ) ≤ (M : ℝ) := by exact_mod_cast hM1
    simpa [one_div] using
      (one_div_le_one_div_of_le (show (0 : ℝ) < 1 by norm_num) hMge1)
  have hx_mem : x ∈ Set.Ioc 1 2 := by
    constructor
    · dsimp [x]
      have hInvPos : 0 < (M : ℝ)⁻¹ := by positivity
      linarith
    · dsimp [x]
      linarith
  have hmain := hC hx_mem
  have htot_nat : Nat.totient 3 = 2 := by
    simpa using Nat.totient_prime (by norm_num : Nat.Prime 3)
  have htot : (Nat.totient 3 : ℝ) = 2 := by
    exact_mod_cast htot_nat
  have hxsub : x - 1 = (M : ℝ)⁻¹ := by
    dsimp [x]
    ring
  rw [htot, hxsub] at hmain
  have hEq : ((2 : ℝ)⁻¹ / (M : ℝ)⁻¹ - C) = ((1 : ℝ) / 2) * (M : ℝ) - C := by
    have hMne : (M : ℝ) ≠ 0 := by positivity
    field_simp [hMne, two_ne_zero]
  rw [hEq] at hmain
  have hceil_nat_le_M : Nat.ceil (4 * max C 0) ≤ M :=
    le_trans (le_max_right 1 (Nat.ceil (4 * max C 0))) hM'
  have hceil : 4 * max C 0 ≤ (Nat.ceil (4 * max C 0) : ℝ) := Nat.le_ceil _
  have hceil_le_M : (Nat.ceil (4 * max C 0) : ℝ) ≤ (M : ℝ) := by
    exact_mod_cast hceil_nat_le_M
  have h4max_le_M : 4 * max C 0 ≤ (M : ℝ) := le_trans hceil hceil_le_M
  have hC_le_quarterM : C ≤ (1 : ℝ) / 4 * (M : ℝ) := by
    have hC_le_max : C ≤ max C 0 := le_max_left _ _
    have hmax_le_quarterM : max C 0 ≤ (1 : ℝ) / 4 * (M : ℝ) := by
      nlinarith
    exact le_trans hC_le_max hmax_le_quarterM
  have hquarterM_le : (1 : ℝ) / 4 * (M : ℝ) ≤ ((1 : ℝ) / 2) * (M : ℝ) - C := by
    nlinarith
  have hfinal : (1 : ℝ) / 4 * (M : ℝ) ≤
      ∑' n : ℕ, (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) / (n : ℝ) ^ x := by
    exact le_trans hquarterM_le hmain
  simpa [x, add_comm, add_left_comm, add_assoc] using hfinal

theorem residue_im_eq_zero_of_continuous_eqOn {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    a.im = 0 := by
  intro hsumm hcont heq
  have hL_real_im : ∀ y : ℝ, 1 < y → (LSeries (fun n => (f n : ℂ)) y).im = 0 := by
    intro y hy
    have hs : LSeriesSummable (fun n => (f n : ℂ)) y := hsumm y (by simpa using hy)
    rw [LSeries, Complex.im_tsum hs]
    have hterm : (fun n => (LSeries.term (fun n => (f n : ℂ)) y n).im) = 0 := by
      funext n
      rcases eq_or_ne n 0 with rfl | hn
      · simp
      · rw [LSeries.term_of_ne_zero hn]
        have hpow : (n : ℂ) ^ (y : ℂ) = (((n : ℝ) ^ y : ℝ) : ℂ) := by
          simpa using (Complex.ofReal_cpow n.cast_nonneg y).symm
        rw [hpow]
        simp
    rw [hterm]
    exact tsum_zero
  let x : ℕ → ℝ := fun n => 1 + 1 / (n + 1 : ℝ)
  let u : ℕ → ℂ := fun n => (x n : ℂ)
  have hu_mem : ∀ n, u n ∈ {s : ℂ | 1 ≤ s.re} := by
    intro n
    change 1 ≤ x n
    dsimp [x]
    have hnonneg : 0 ≤ 1 / (n + 1 : ℝ) := by positivity
    linarith
  have hu_gt : ∀ n, 1 < (u n).re := by
    intro n
    change 1 < x n
    dsimp [x]
    have hpos : 0 < 1 / (n + 1 : ℝ) := by positivity
    linarith
  have hzero : Filter.Tendsto (fun n : ℕ => 1 / ((n : ℝ) + 1)) Filter.atTop (nhds 0) := by
    simpa using (tendsto_one_div_add_atTop_nhds_zero_nat : Filter.Tendsto (fun n : ℕ => 1 / ((n : ℝ) + 1)) Filter.atTop (nhds 0))
  have hx_tendsto : Filter.Tendsto x Filter.atTop (nhds 1) := by
    simpa [x] using (tendsto_const_nhds.add hzero)
  have hu_tendsto : Filter.Tendsto u Filter.atTop (nhds (1 : ℂ)) := by
    simpa [u] using Complex.continuous_ofReal.continuousAt.tendsto.comp hx_tendsto
  have hu_tendsto_within : Filter.Tendsto u Filter.atTop (nhdsWithin (1 : ℂ) {s : ℂ | 1 ≤ s.re}) := by
    simpa [nhdsWithin] using (Filter.tendsto_inf.2 ⟨hu_tendsto, Filter.tendsto_principal.2 (Filter.Eventually.of_forall hu_mem)⟩)
  have hprod_cont : ContinuousWithinAt (fun z : ℂ => (z - 1) * g z) {s : ℂ | 1 ≤ s.re} 1 := by
    refine ((continuous_id.sub continuous_const).continuousAt.continuousWithinAt).mul ?_
    exact hcont 1 (by simp)
  have hprod_tendsto : Filter.Tendsto (fun n => (u n - 1) * g (u n)) Filter.atTop (nhds 0) := by
    simpa [u] using hprod_cont.tendsto.comp hu_tendsto_within
  have him_tendsto : Filter.Tendsto (fun n => Complex.im ((u n - 1) * g (u n))) Filter.atTop (nhds 0) := by
    exact Complex.continuous_im.continuousAt.tendsto.comp hprod_tendsto
  have him_const : ∀ n, Complex.im ((u n - 1) * g (u n)) = -a.im := by
    intro n
    have hEq : g (u n) = LSeries (fun n => (f n : ℂ)) (u n) - a / (u n - 1) := by
      exact heq (by simpa using hu_gt n)
    have hx_gt_n : 1 < x n := by
      change 1 < (1 + 1 / (n + 1 : ℝ))
      have hpos : 0 < 1 / (n + 1 : ℝ) := by positivity
      linarith
    have hx_ne_one : x n ≠ 1 := by linarith
    have hu_ne : u n - 1 ≠ 0 := by
      apply sub_ne_zero.mpr
      change (x n : ℂ) ≠ (1 : ℂ)
      exact_mod_cast hx_ne_one
    have hImL : (LSeries (fun n => (f n : ℂ)) (u n)).im = 0 := by
      simpa [u] using hL_real_im (x n) hx_gt_n
    have hu_im : (u n - 1).im = 0 := by
      simp [u]
    have hmul : (u n - 1) * (LSeries (fun n => (f n : ℂ)) (u n) - a / (u n - 1)) =
        (u n - 1) * LSeries (fun n => (f n : ℂ)) (u n) - a := by
      rw [mul_sub]
      congr 1
      field_simp [hu_ne]
    calc
      Complex.im ((u n - 1) * g (u n))
          = Complex.im ((u n - 1) * (LSeries (fun n => (f n : ℂ)) (u n) - a / (u n - 1))) := by rw [hEq]
      _ = Complex.im (((u n - 1) * LSeries (fun n => (f n : ℂ)) (u n)) - a) := by rw [hmul]
      _ = -a.im := by
            rw [Complex.sub_im]
            have hprod_im_zero : (((u n - 1) * LSeries (fun n => (f n : ℂ)) (u n)).im) = 0 := by
              rw [Complex.mul_im, hu_im, hImL]
              simp
            simp [hprod_im_zero]
  have hconst_tendsto : Filter.Tendsto (fun n => Complex.im ((u n - 1) * g (u n))) Filter.atTop (nhds (-a.im)) := by
    have hfun : (fun n => Complex.im ((u n - 1) * g (u n))) = fun _ : ℕ => -a.im := by
      funext n
      exact him_const n
    rw [hfun]
    exact tendsto_const_nhds
  have hlim : (-a.im : ℝ) = 0 := by
    exact tendsto_nhds_unique hconst_tendsto him_tendsto
  linarith

theorem integrableOn_logRescalePartialSum_kernel_of_boundary_extension {f : ℕ → ℝ} {b : ℝ} : HasBoundaryLaplaceExtension f b → ∀ z : ℂ, 0 < z.re → MeasureTheory.IntegrableOn (fun x : ℝ => (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) (Set.Ioi (0 : ℝ)) := by
  intro hExt z hz
  rcases hExt with ⟨G, hGcont, hGint, hGeq⟩
  have hcenter :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ)) :=
    hGint z hz
  have hzneg : (-z).re < 0 := by
    simpa [Complex.neg_re] using (neg_lt_zero.mpr hz)
  have hexp :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => Complex.exp ((-z) * x))
        (Set.Ioi (0 : ℝ)) := by
    simpa using integrableOn_exp_mul_complex_Ioi (a := -z) hzneg 0
  have hconst :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => ((b : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ)) := by
    have hconst' := hexp.integrable.const_mul (b : ℂ)
    change MeasureTheory.Integrable
      (fun x : ℝ => (b : ℂ) * Complex.exp (-z * x))
      (MeasureTheory.volume.restrict (Set.Ioi (0 : ℝ)))
    simpa [neg_mul] using hconst'
  have hsum :
      MeasureTheory.IntegrableOn
        (fun x : ℝ =>
          ((((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) +
            ((b : ℂ) * Complex.exp (-z * x))))
        (Set.Ioi (0 : ℝ)) := by
    change MeasureTheory.Integrable
      (fun x : ℝ =>
        ((((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) +
          ((b : ℂ) * Complex.exp (-z * x))))
      (MeasureTheory.volume.restrict (Set.Ioi (0 : ℝ)))
    exact hcenter.integrable.add hconst.integrable
  simpa [sub_mul, add_mul, sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
    using hsum

theorem logRescalePartialSum_tendsto_of_tendsto_sum_Icc_div {f : ℕ → ℝ} {b : ℝ} : Filter.Tendsto (fun m : ℕ => (∑ k ∈ Finset.Icc 1 m, f k) / (m : ℝ)) Filter.atTop (nhds b) → Filter.Tendsto (fun x : ℝ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
  intro h
  have h1 : Filter.Tendsto (fun x : ℝ => ((∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / ((⌊Real.exp x⌋₊ : ℕ) : ℝ))) Filter.atTop (nhds b) := by
    simpa using h.comp (tendsto_nat_floor_atTop.comp Real.tendsto_exp_atTop)
  have h2 : Filter.Tendsto (fun x : ℝ => (((⌊Real.exp x⌋₊ : ℕ) : ℝ) / Real.exp x)) Filter.atTop (nhds 1) := by
    simpa using tendsto_nat_floor_div_atTop.comp Real.tendsto_exp_atTop
  have hmul : Filter.Tendsto (fun x : ℝ => (((∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / ((⌊Real.exp x⌋₊ : ℕ) : ℝ)) * (((⌊Real.exp x⌋₊ : ℕ) : ℝ) / Real.exp x))) Filter.atTop (nhds (b * 1)) :=
    h1.mul h2
  have h_eq : (fun x : ℝ => logRescalePartialSum f x) =ᶠ[Filter.atTop]
      (fun x : ℝ => (((∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / ((⌊Real.exp x⌋₊ : ℕ) : ℝ)) * (((⌊Real.exp x⌋₊ : ℕ) : ℝ) / Real.exp x)) ) := by
    filter_upwards [Filter.eventually_ge_atTop (0 : ℝ)] with x hx
    have hxexp : 1 ≤ Real.exp x := by
      have := Real.exp_le_exp.mpr hx
      simpa using this
    have hfloor_one : (1 : ℕ) ≤ ⌊Real.exp x⌋₊ := (Nat.one_le_floor_iff (Real.exp x)).2 hxexp
    have hfloor_ne : (⌊Real.exp x⌋₊ : ℕ) ≠ 0 := Nat.one_le_iff_ne_zero.mp hfloor_one
    have hfloor_ne' : (((⌊Real.exp x⌋₊ : ℕ) : ℝ)) ≠ 0 := by
      exact_mod_cast hfloor_ne
    rw [logRescalePartialSum, if_pos hx, Real.exp_neg]
    field_simp [hfloor_ne', Real.exp_ne_zero x]
  have hmul' : Filter.Tendsto (fun x : ℝ => (((∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / ((⌊Real.exp x⌋₊ : ℕ) : ℝ)) * (((⌊Real.exp x⌋₊ : ℕ) : ℝ) / Real.exp x))) Filter.atTop (nhds b) := by
    simpa using hmul
  exact Filter.Tendsto.congr' h_eq.symm hmul'

theorem boundary_extension_complex_identity {f : ℕ → ℝ} {b : ℝ} {G : ℂ → ℂ} :
    (hGint : ∀ z : ℂ, 0 < z.re →
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ))) →
    (hGeq : Set.EqOn G
      (fun z : ℂ => ∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
      {z : ℂ | 0 < z.re}) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ∀ z : ℂ, 0 < z.re →
      G z =
        LSeries (fun n => (f n : ℂ)) (1 + z) / (1 + z) -
          Complex.ofReal b / z := by
  intro hGint hGeq hnonneg hsumm z hz
  have hG :
      G z = ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) := by
    exact hGeq (by simpa using hz)
  have hL := lseries_eq_logRescalePartialSum_laplace hnonneg hsumm z hz
  have h1z_ne : 1 + z ≠ 0 := by
    intro h
    have hre : (1 + z).re = 0 := by simp [h]
    have : 1 + z.re = 0 := by simp at hre; exact hre
    linarith
  have hL' :
      ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))
        = LSeries (fun n => (f n : ℂ)) (1 + z) / (1 + z) := by
    apply (eq_div_iff h1z_ne).2
    simpa [mul_comm, mul_left_comm, mul_assoc] using hL.symm
  have hzneg : (-z).re < 0 := by
    have : -z.re < 0 := by linarith
    simpa using this
  have hconst_int :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => Complex.ofReal b * Complex.exp (-z * x))
        (Set.Ioi (0 : ℝ)) := by
    simpa using
      (integrableOn_exp_mul_complex_Ioi (a := -z) hzneg (0 : ℝ)).const_mul (Complex.ofReal b)
  have hadd :
      ∫ x in Set.Ioi (0 : ℝ),
          ((((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) +
            (Complex.ofReal b * Complex.exp (-z * x)))
        =
          (∫ x in Set.Ioi (0 : ℝ),
            (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))) +
          (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := by
    rw [MeasureTheory.integral_add (hGint z hz) hconst_int]
  have hsum :
      ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))
        =
          (∫ x in Set.Ioi (0 : ℝ),
            (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))) +
          (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := by
    calc
      ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))
          =
            ∫ x in Set.Ioi (0 : ℝ),
              ((((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) +
                (Complex.ofReal b * Complex.exp (-z * x))) := by
            congr with x
            simp [Complex.ofReal_sub, sub_mul, mul_comm, mul_left_comm, mul_assoc]
      _ =
          (∫ x in Set.Ioi (0 : ℝ),
            (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))) +
          (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := hadd
  have hcentered :
      ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))
        =
          (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
          (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := by
    calc
      ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))
          =
            ((∫ x in Set.Ioi (0 : ℝ),
                (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))) +
              (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x)))) -
            (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := by
            ring
      _ =
          (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
          (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := by
            rw [← hsum]
  calc
    G z = ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)) := hG
    _ =
        (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
        (∫ x in Set.Ioi (0 : ℝ), (Complex.ofReal b * Complex.exp (-z * x))) := hcentered
    _ = LSeries (fun n => (f n : ℂ)) (1 + z) / (1 + z) - Complex.ofReal b / z := by
      rw [hL', integral_const_mul_cexp_neg_Ioi (b := b) (z := z) hz]

theorem lseries_summable_complex_of_nterm {f : ℕ → ℝ} : (∀ σ' : ℝ, 1 < σ' → Summable (nterm (fun n => (f n : ℂ)) σ')) → ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s := by
  intro hf s hs
  rw [LSeriesSummable]
  exact (summable_norm_iff).1 (by
    simpa [norm_term_eq_nterm_re] using hf s.re hs)

theorem nat_le_floor_exp_of_log_lt {n : ℕ} {x : ℝ} : 1 ≤ n → Real.log (n : ℝ) < x → n ≤ ⌊Real.exp x⌋₊ := by
  intro hn hx
  have hnpos : (0 : ℝ) < n := by
    exact_mod_cast hn
  have hlt : (n : ℝ) < Real.exp x := by
    exact (Real.log_lt_iff_lt_exp hnpos).mp hx
  exact Nat.le_floor (le_of_lt hlt)

theorem sum_filter_log_lt_le_sum_Icc_floor_exp {f : ℕ → ℝ} {N : ℕ} {x : ℝ} : (hnonneg : ∀ n, 0 ≤ f n) → 0 < x → ∑ n ∈ (Finset.Icc 1 N).filter (fun n : ℕ => Real.log (n : ℝ) < x), f n ≤ ∑ n ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f n := by
  intro hnonneg hx
  refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnonneg
  · intro n hn
    rcases Finset.mem_filter.mp hn with ⟨hnIcc, hlog⟩
    rw [Finset.mem_Icc] at hnIcc ⊢
    exact ⟨hnIcc.1, nat_le_floor_exp_of_log_lt hnIcc.1 hlog⟩
  · intro n hn hnot
    exact hnonneg n

theorem partial_sum_div_rpow_le_logRescale_kernel_integral {f : ℕ → ℝ} {σ' : ℝ} : (hnonneg : ∀ n, 0 ≤ f n) → 1 < σ' → MeasureTheory.IntegrableOn (fun x : ℝ => logRescalePartialSum f x * Real.exp (-(σ' - 1) * x)) (Set.Ioi (0 : ℝ)) → ∀ N : ℕ, ∑ n ∈ Finset.Icc 1 N, f n / (n : ℝ) ^ σ' ≤ σ' * ∫ x in Set.Ioi (0 : ℝ), logRescalePartialSum f x * Real.exp (-(σ' - 1) * x) := by
  intro hnonneg hσ hint N
  have hσ0 : 0 < σ' := by linarith
  have hrew (x S : ℝ) :
      S * Real.exp (-σ' * x) = (Real.exp (-x) * S) * Real.exp (-(σ' - 1) * x) := by
    have hExp : Real.exp (-σ' * x) = Real.exp (-x) * Real.exp (-(σ' - 1) * x) := by
      rw [← Real.exp_add]
      congr 1
      ring
    rw [hExp]
    ring
  have hleftExp (x : ℝ) :
      ∑ n ∈ Finset.Icc 1 N, Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
        = (∑ n ∈ Finset.filter (fun n : ℕ => Real.log n < x) (Finset.Icc 1 N), f n) * Real.exp (-σ' * x) := by
    have hEq :
        (∑ n ∈ Finset.Icc 1 N, Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x)
          = ∑ n ∈ Finset.Icc 1 N, (if Real.log n < x then f n else 0) * Real.exp (-σ' * x) := by
      refine Finset.sum_congr rfl ?_
      intro n hn
      by_cases hnx : Real.log n < x
      · simp [Set.indicator, Set.mem_Ioi, hnx]
      · simp [Set.indicator, Set.mem_Ioi, hnx]
    rw [hEq, Finset.sum_filter, Finset.sum_mul]
  have hsubset (x : ℝ) :
      Finset.filter (fun n : ℕ => Real.log n < x) (Finset.Icc 1 N) ⊆ Finset.Icc 1 ⌊Real.exp x⌋₊ := by
    intro n hn
    rcases Finset.mem_filter.mp hn with ⟨hnIcc, hlog⟩
    have hn1 : 1 ≤ n := (Finset.mem_Icc.mp hnIcc).1
    have hn0 : 0 < (n : ℝ) := by exact_mod_cast (lt_of_lt_of_le (show 0 < (1:ℕ) by decide) hn1)
    have hle : (n : ℝ) ≤ Real.exp x := (Real.log_le_iff_le_exp hn0).mp (le_of_lt hlog)
    exact Finset.mem_Icc.mpr ⟨hn1, Nat.le_floor hle⟩
  have hbase (n : ℕ) : MeasureTheory.IntegrableOn (fun x : ℝ => f n * Real.exp (-σ' * x)) (Set.Ioi (0 : ℝ)) := by
    simpa [mul_comm] using (integrableOn_exp_mul_Ioi (show -σ' < 0 by linarith) (0 : ℝ)).const_mul (f n)
  have htermInt (n : ℕ) (hn : n ∈ Finset.Icc 1 N) :
      MeasureTheory.IntegrableOn
        (Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)))
        (Set.Ioi (0 : ℝ)) := by
    exact (hbase n).indicator measurableSet_Ioi
  have hsumInt :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => ∑ n ∈ Finset.Icc 1 N,
          Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x)
        (Set.Ioi (0 : ℝ)) := by
    simpa [MeasureTheory.IntegrableOn] using
      (MeasureTheory.integrable_finset_sum (μ := MeasureTheory.Measure.restrict MeasureTheory.volume (Set.Ioi (0 : ℝ)))
        (Finset.Icc 1 N) (fun n hn => htermInt n hn))
  have hpoint (x : ℝ) (hx : x ∈ Set.Ioi (0 : ℝ)) :
      (∑ n ∈ Finset.Icc 1 N,
          Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x)
        ≤ logRescalePartialSum f x * Real.exp (-(σ' - 1) * x) := by
    rw [hleftExp x]
    have hsumle :
        ∑ n ∈ Finset.filter (fun n : ℕ => Real.log n < x) (Finset.Icc 1 N), f n
          ≤ ∑ n ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f n := by
      exact Finset.sum_le_sum_of_subset_of_nonneg (hsubset x) (by intro i hi his; exact hnonneg i)
    have hexp_nonneg : 0 ≤ Real.exp (-σ' * x) := by positivity
    calc
      (∑ n ∈ Finset.filter (fun n : ℕ => Real.log n < x) (Finset.Icc 1 N), f n) * Real.exp (-σ' * x)
          ≤ (∑ n ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f n) * Real.exp (-σ' * x) := by
            exact mul_le_mul_of_nonneg_right hsumle hexp_nonneg
      _ = logRescalePartialSum f x * Real.exp (-(σ' - 1) * x) := by
            rw [logRescalePartialSum, if_pos (le_of_lt hx)]
            simpa using (hrew x (∑ n ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f n))
  have hmono :
      ∫ x in Set.Ioi (0 : ℝ),
          ∑ n ∈ Finset.Icc 1 N,
            Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
        ≤ ∫ x in Set.Ioi (0 : ℝ), logRescalePartialSum f x * Real.exp (-(σ' - 1) * x) := by
    exact MeasureTheory.setIntegral_mono_on_ae hsumInt hint measurableSet_Ioi (Filter.Eventually.of_forall hpoint)
  have htermEvalRaw (n : ℕ) (hn : n ∈ Finset.Icc 1 N) :
      ∫ x in Set.Ioi (Real.log n), f n * Real.exp (-σ' * x)
        = f n * ((n : ℝ) ^ (-σ')) / σ' := by
    have hn1 : 1 ≤ n := (Finset.mem_Icc.mp hn).1
    have hn0 : 0 < (n : ℝ) := by exact_mod_cast (lt_of_lt_of_le (show 0 < (1:ℕ) by decide) hn1)
    rw [show (∫ x in Set.Ioi (Real.log n), f n * Real.exp (-σ' * x))
          = f n * ∫ x in Set.Ioi (Real.log n), Real.exp (-σ' * x) by
          simpa using (MeasureTheory.integral_const_mul (μ := MeasureTheory.Measure.restrict MeasureTheory.volume (Set.Ioi (Real.log n))) (f n) (fun x : ℝ => Real.exp (-σ' * x)))]
    rw [integral_exp_mul_Ioi (show -σ' < 0 by linarith) (Real.log n)]
    have hExp : Real.exp (-σ' * Real.log n) = (n : ℝ) ^ (-σ') := by
      rw [mul_comm, Real.exp_mul, Real.exp_log hn0]
    rw [neg_div_neg_eq, hExp]
    ring
  have htermEval (n : ℕ) (hn : n ∈ Finset.Icc 1 N) :
      ∫ x in Set.Ioi (0 : ℝ),
          Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
        = f n * ((n : ℝ) ^ (-σ')) / σ' := by
    rw [MeasureTheory.setIntegral_indicator (s := Set.Ioi (0 : ℝ)) (t := Set.Ioi (Real.log n))
          (f := fun x : ℝ => f n * Real.exp (-σ' * x)) measurableSet_Ioi]
    have hinter : Set.Ioi (0 : ℝ) ∩ Set.Ioi (Real.log n) = Set.Ioi (Real.log n) := by
      ext x
      constructor
      · intro hx
        exact hx.2
      · intro hx
        exact ⟨lt_of_le_of_lt (Real.log_natCast_nonneg n) hx, hx⟩
    rw [hinter]
    exact htermEvalRaw n hn
  have hsumEval :
      ∫ x in Set.Ioi (0 : ℝ),
          ∑ n ∈ Finset.Icc 1 N,
            Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
        = ∑ n ∈ Finset.Icc 1 N, f n * ((n : ℝ) ^ (-σ')) / σ' := by
    calc
      ∫ x in Set.Ioi (0 : ℝ),
          ∑ n ∈ Finset.Icc 1 N,
            Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
          = ∑ n ∈ Finset.Icc 1 N,
              ∫ x in Set.Ioi (0 : ℝ),
                Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x := by
            simpa using
              (MeasureTheory.integral_finset_sum (μ := MeasureTheory.Measure.restrict MeasureTheory.volume (Set.Ioi (0 : ℝ)))
                (Finset.Icc 1 N) (fun n hn => htermInt n hn))
      _ = ∑ n ∈ Finset.Icc 1 N, f n * ((n : ℝ) ^ (-σ')) / σ' := by
            refine Finset.sum_congr rfl ?_
            intro n hn
            exact htermEval n hn
  have hscaled :
      σ' * ∫ x in Set.Ioi (0 : ℝ),
          ∑ n ∈ Finset.Icc 1 N,
            Set.indicator (Set.Ioi (Real.log n)) (fun x : ℝ => f n * Real.exp (-σ' * x)) x
        = ∑ n ∈ Finset.Icc 1 N, f n / (n : ℝ) ^ σ' := by
    rw [hsumEval, Finset.mul_sum]
    refine Finset.sum_congr rfl ?_
    intro n hn
    have hn1 : 1 ≤ n := (Finset.mem_Icc.mp hn).1
    have hn0 : 0 < (n : ℝ) := by exact_mod_cast (lt_of_lt_of_le (show 0 < (1:ℕ) by decide) hn1)
    have hpow0 : (n : ℝ) ^ σ' ≠ 0 := by
      exact (Real.rpow_ne_zero (show 0 ≤ (n : ℝ) by positivity) hσ0.ne').2 hn0.ne'
    rw [Real.rpow_neg (show 0 ≤ (n : ℝ) by positivity)]
    field_simp [hσ0.ne', hpow0]
  have hmain := mul_le_mul_of_nonneg_left hmono (le_of_lt hσ0)
  rw [hscaled] at hmain
  exact hmain

theorem summable_div_rpow_of_logRescale_kernel_integrable {f : ℕ → ℝ} {σ' : ℝ} : (hnonneg : ∀ n, 0 ≤ f n) → 1 < σ' → MeasureTheory.IntegrableOn (fun x : ℝ => logRescalePartialSum f x * Real.exp (-(σ' - 1) * x)) (Set.Ioi (0 : ℝ)) → Summable (fun n : ℕ => if n = 0 then 0 else f n / (n : ℝ) ^ σ') := by
  intro hnonneg hσ h_int
  let a : ℕ → ℝ := fun n => if n = 0 then 0 else f n / (n : ℝ) ^ σ'
  have ha_nonneg : ∀ n, 0 ≤ a n := by
    intro n
    by_cases h0 : n = 0
    · simp [a, h0]
    · simp only [a, h0, if_false]
      exact div_nonneg (hnonneg n) (le_of_lt (Real.rpow_pos_of_pos (by exact_mod_cast Nat.pos_of_ne_zero h0) _))
  let C : ℝ := σ' * ∫ x in Set.Ioi (0 : ℝ), logRescalePartialSum f x * Real.exp (-(σ' - 1) * x)
  have hsum_le : ∀ N : ℕ, ∑ n ∈ Finset.Icc 1 N, f n / (n : ℝ) ^ σ' ≤ C := by
    intro N
    simpa only [C] using partial_sum_div_rpow_le_logRescale_kernel_integral hnonneg hσ h_int N
  have hsum_range_eq : ∀ N : ℕ, ∑ n ∈ Finset.range (N + 1), a n = ∑ n ∈ Finset.Icc 1 N, f n / (n : ℝ) ^ σ' := by
    intro N
    rw [Nat.range_succ_eq_Icc_zero]
    have hinsert : insert 0 (Finset.Icc 1 N) = Finset.Icc 0 N := by
      simpa using (Finset.insert_Icc_succ_left_eq_Icc (a := 0) (b := N) (Nat.zero_le N))
    rw [← hinsert, Finset.sum_insert]
    · simp only [a, if_pos rfl, zero_add]
      refine Finset.sum_congr rfl ?_
      intro n hn
      have hnpos : 0 < n := by
        exact Nat.succ_le_iff.mp (Finset.mem_Icc.mp hn).1
      have hn0 : n ≠ 0 := Nat.ne_of_gt hnpos
      simp only [a, hn0, if_false]
    · simp
  have hsum_range_le : ∀ N : ℕ, ∑ n ∈ Finset.range N, a n ≤ C := by
    intro N
    cases N with
    | zero =>
        have h0 := hsum_le 0
        simpa using h0
    | succ N =>
        rw [hsum_range_eq N]
        exact hsum_le N
  simpa only [a] using (summable_of_sum_range_le ha_nonneg hsum_range_le)

theorem summable_nterm_of_boundary_extension {f : ℕ → ℝ} {b : ℝ} : (hnonneg : ∀ n, 0 ≤ f n) → HasBoundaryLaplaceExtension f b → ∀ σ' : ℝ, 1 < σ' → Summable (nterm (fun n => (f n : ℂ)) σ') := by
  intro hnonneg hbound σ' hσ'
  have hIntC :=
    integrableOn_logRescalePartialSum_kernel_of_boundary_extension hbound
      (((σ' - 1 : ℝ) : ℂ)) (by
        simpa using hσ')
  have hIntR' :
      MeasureTheory.Integrable
        (fun x : ℝ => logRescalePartialSum f x * Real.exp (-(σ' - 1) * x))
        (MeasureTheory.volume.restrict (Set.Ioi (0 : ℝ))) := by
    convert (MeasureTheory.Integrable.re hIntC) using 1
    ext x
    simp [Complex.exp_re, mul_assoc, mul_left_comm, mul_comm]
  have hIntR :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => logRescalePartialSum f x * Real.exp (-(σ' - 1) * x))
        (Set.Ioi (0 : ℝ)) := hIntR'
  have hsum :=
    summable_div_rpow_of_logRescale_kernel_integrable hnonneg hσ' hIntR
  refine hsum.congr ?_
  intro n
  by_cases hn : n = 0
  · simp [nterm, hn]
  · simp [nterm, hn, RCLike.norm_ofReal, abs_of_nonneg (hnonneg n)]

theorem tendsto_sum_Icc_div_of_tendsto_cumsum_div {f : ℕ → ℝ} {b : ℝ} : Filter.Tendsto (fun N : ℕ => cumsum f N / (N : ℝ)) Filter.atTop (nhds b) → Filter.Tendsto (fun m : ℕ => (∑ k ∈ Finset.Icc 1 m, f k) / (m : ℝ)) Filter.atTop (nhds b) := by
  intro h
  have h_shift : Filter.Tendsto (fun m : ℕ => cumsum f (m + 1) / (((m + 1 : ℕ) : ℝ))) Filter.atTop (nhds b) := by
    simpa [Nat.cast_add] using (Filter.tendsto_add_atTop_iff_nat (f := fun N : ℕ => cumsum f N / (N : ℝ)) (l := nhds b) 1).2 h
  have hratio : Filter.Tendsto (fun m : ℕ => (((m + 1 : ℕ) : ℝ) / (m : ℝ))) Filter.atTop (nhds 1) := by
    simpa [Nat.cast_add, add_comm, add_left_comm, add_assoc] using
      (tendsto_add_mul_div_add_mul_atTop_nhds (a := (1 : ℝ)) (b := 0) (c := (1 : ℝ)) (d := (1 : ℝ)) one_ne_zero)
  have h0 : Filter.Tendsto (fun m : ℕ => f 0 / (m : ℝ)) Filter.atTop (nhds 0) := by
    simpa using tendsto_const_div_atTop_nhds_zero_nat (f 0)
  have hsum : ∀ m : ℕ, cumsum f (m + 1) = f 0 + ∑ k ∈ Finset.Icc 1 m, f k := by
    intro m
    induction m with
    | zero =>
        simp [cumsum]
    | succ m ihm =>
        rw [cumsum_succ, ihm, Finset.sum_Icc_succ_top]
        · ring
        · omega
  have hmain : Filter.Tendsto
      (fun m : ℕ => (((m + 1 : ℕ) : ℝ) / (m : ℝ)) * (cumsum f (m + 1) / (((m + 1 : ℕ) : ℝ)))- f 0 / (m : ℝ))
      Filter.atTop (nhds b) := by
    simpa [one_mul] using (hratio.mul h_shift).sub h0
  refine Filter.Tendsto.congr' ?_ hmain
  filter_upwards [Filter.eventually_gt_atTop 0] with m hm
  have hmR : (m : ℝ) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt hm)
  have hm1R : (((m + 1 : ℕ) : ℝ)) ≠ 0 := by
    positivity
  rw [hsum m]
  field_simp [hmR, hm1R]
  ring

theorem logRescalePartialSum_tendsto_of_tendsto_cumsum_div {f : ℕ → ℝ} {b : ℝ} : Filter.Tendsto (fun N : ℕ => cumsum f N / (N : ℝ)) Filter.atTop (nhds b) → Filter.Tendsto (fun x : ℝ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
  intro h
  exact logRescalePartialSum_tendsto_of_tendsto_sum_Icc_div (tendsto_sum_Icc_div_of_tendsto_cumsum_div h)

noncomputable def wiener_boundary_function (G : ℂ → ℂ) (b : ℝ) : ℂ → ℂ :=
  fun s => s * G (s - (1 : ℂ)) + (b : ℂ)

theorem wiener_boundary_function_eqOn {f : ℕ → ℝ} {b : ℝ} {G : ℂ → ℂ} :
    (hGint : ∀ z : ℂ, 0 < z.re →
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ))) →
    (hGeq : Set.EqOn G
      (fun z : ℂ => ∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
      {z : ℂ | 0 < z.re}) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    Set.EqOn (wiener_boundary_function G b)
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - Complex.ofReal b / (s - 1))
      {s : ℂ | 1 < s.re} := by
  intro hGint hGeq hnonneg hsumm s hs
  have hsre : 1 < s.re := hs
  have hz : 0 < (s - (1 : ℂ)).re := by
    simpa [Complex.sub_re] using sub_pos.mpr hsre
  have hG := boundary_extension_complex_identity hGint hGeq hnonneg hsumm (s - (1 : ℂ)) hz
  dsimp [wiener_boundary_function]
  rw [hG]
  have h_one_add_sub : (1 : ℂ) + (s - 1) = s := by ring
  rw [h_one_add_sub]
  have hs_ne : s ≠ 0 := by
    intro hs0
    have hspos : 0 < s.re := lt_trans zero_lt_one hsre
    simp [hs0] at hspos
  have hsub_ne : s - (1 : ℂ) ≠ 0 := by
    intro hzero
    have : 0 < (s - (1 : ℂ)).re := hz
    simp [hzero] at this
  field_simp [hs_ne, hsub_ne]
  ring_nf

theorem logRescalePartialSum_tendsto_of_boundary_extension {f : ℕ → ℝ} {b : ℝ} (hF : HasBoundaryLaplaceExtension f b) (hnonneg : ∀ n, 0 ≤ f n) : Filter.Tendsto (fun x : ℝ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
  have hf : ∀ σ' : ℝ, 1 < σ' → Summable (nterm (fun n => (f n : ℂ)) σ') :=
    summable_nterm_of_boundary_extension hnonneg hF
  rcases hF with ⟨G, hGcont, hGint, hGeq⟩
  have hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s :=
    lseries_summable_complex_of_nterm hf
  let W : ℂ → ℂ := wiener_boundary_function G b
  have hWcont : ContinuousOn W {s : ℂ | 1 ≤ s.re} := by
    have hshift : ContinuousOn (fun s : ℂ => s - (1 : ℂ)) {s : ℂ | 1 ≤ s.re} := by
      simpa using (continuous_id.sub continuous_const).continuousOn
    have hmaps : Set.MapsTo (fun s : ℂ => s - (1 : ℂ)) {s : ℂ | 1 ≤ s.re} {z : ℂ | 0 ≤ z.re} := by
      intro s hs
      simpa using hs
    have hGshift : ContinuousOn (fun s : ℂ => G (s - (1 : ℂ))) {s : ℂ | 1 ≤ s.re} := by
      simpa [Function.comp] using hGcont.comp hshift hmaps
    have hmul : ContinuousOn (fun s : ℂ => s * G (s - (1 : ℂ))) {s : ℂ | 1 ≤ s.re} :=
      continuousOn_id.mul hGshift
    simpa [W, wiener_boundary_function] using hmul.add continuousOn_const
  have hWeq : Set.EqOn W
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - Complex.ofReal b / (s - 1))
      {s : ℂ | 1 < s.re} := by
    exact wiener_boundary_function_eqOn hGint hGeq hnonneg hsumm
  have hcum : Filter.Tendsto (fun N : ℕ => cumsum f N / (N : ℝ)) Filter.atTop (nhds b) := by
    exact WienerIkeharaTheorem'' hnonneg hf hWcont hWeq
  exact logRescalePartialSum_tendsto_of_tendsto_cumsum_div hcum

theorem liminf_logRescalePartialSum_pos_of_boundary_extension {f : ℕ → ℝ} {b : ℝ} :
    (hb : 0 < b) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hF : HasBoundaryLaplaceExtension f b) →
    ∃ c : ℝ, 0 < c ∧ ∃ x₀ : ℝ, ∀ x : ℝ, x₀ ≤ x → c ≤ logRescalePartialSum f x := by
  intro hb hnonneg hF
  refine ⟨b / 2, by linarith, ?_⟩
  have htend := logRescalePartialSum_tendsto_of_boundary_extension hF hnonneg
  have hhalf : b / 2 < b := by linarith
  have hIoi : Set.Ioi (b / 2) ∈ nhds b := Ioi_mem_nhds hhalf
  have hev : ∀ᶠ x in Filter.atTop, logRescalePartialSum f x ∈ Set.Ioi (b / 2) :=
    htend hIoi
  rcases (Filter.eventually_atTop.mp hev) with ⟨x₀, hx₀⟩
  exact ⟨x₀, fun x hx => le_of_lt (hx₀ x hx)⟩

theorem liminf_logRescalePartialSum_pos_of_LSeries_pole {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    0 < a.re →
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∃ c : ℝ, 0 < c ∧ ∃ x₀ : ℝ, ∀ x : ℝ, x₀ ≤ x → c ≤ logRescalePartialSum f x := by
  intro ha hnonneg hsumm hcont heq
  have haim : a.im = 0 :=
    residue_im_eq_zero_of_continuous_eqOn hsumm hcont heq
  have hF : HasBoundaryLaplaceExtension f a.re :=
    hasBoundaryLaplaceExtension_of_eqOn haim hnonneg hsumm hcont heq
  exact liminf_logRescalePartialSum_pos_of_boundary_extension ha hnonneg hF

theorem tendsto_lSeries_eval_one_add_inv_floor_pow_of_real_pole_bound {f : ℕ → ℝ} {a : ℝ} :
    (∃ C : ℝ, 0 ≤ C ∧ ∀ {x : ℝ}, x ∈ Set.Ioc 1 2 →
      abs ((∑' n, f n / (n : ℝ) ^ x) - a / (x - 1)) ≤ C) →
    ∀ c : ℝ, 1 < c →
      Filter.Tendsto
        (fun n : ℕ =>
          (∑' k, f k / (k : ℝ) ^ (1 + (⌊c ^ n⌋₊ : ℝ)⁻¹)) / (⌊c ^ n⌋₊ : ℝ))
        Filter.atTop (nhds a) := by
  intro h c hc
  rcases h with ⟨C, hC_nonneg, hC⟩
  let m : ℕ → ℕ := fun n => ⌊c ^ n⌋₊
  let x : ℕ → ℝ := fun n => 1 + (m n : ℝ)⁻¹
  let F : ℝ → ℝ := fun s => ∑' k, f k / (k : ℝ) ^ s
  let seq : ℕ → ℝ := fun n => F (x n) / (m n : ℝ)
  have hm_pos : ∀ n, 0 < m n := by
    intro n
    dsimp [m]
    exact Nat.floor_pos.2 (by
      simpa using (one_le_pow₀ (show 1 ≤ c by linarith) : 1 ≤ c ^ n))
  have hx_mem : ∀ n, x n ∈ Set.Ioc 1 2 := by
    intro n
    constructor
    · have hm_real_pos : 0 < (m n : ℝ) := by
        exact_mod_cast hm_pos n
      have hinv_pos : 0 < ((m n : ℝ)⁻¹) := by
        exact inv_pos.2 hm_real_pos
      dsimp [x]
      linarith
    · dsimp [x]
      have hm_ge_one : (1 : ℝ) ≤ m n := by
        exact_mod_cast (Nat.succ_le_of_lt (hm_pos n))
      have hinv_le_one : ((m n : ℝ)⁻¹) ≤ 1 := inv_le_one_of_one_le₀ hm_ge_one
      linarith
  have hbound : ∀ n, abs (seq n - a) ≤ C / (m n : ℝ) := by
    intro n
    have h0 : abs (F (x n) - a * (m n : ℝ)) ≤ C := by
      have h0' := hC (hx_mem n)
      dsimp [F, x] at h0'
      rw [show (1 + (m n : ℝ)⁻¹) - 1 = (m n : ℝ)⁻¹ by ring] at h0'
      simpa [div_inv_eq_mul] using h0'
    have hm_real_pos : 0 < (m n : ℝ) := by
      exact_mod_cast hm_pos n
    have hm_real_ne : (m n : ℝ) ≠ 0 := ne_of_gt hm_real_pos
    have hdiv : abs (F (x n) - a * (m n : ℝ)) / (m n : ℝ) ≤ C / (m n : ℝ) := by
      exact div_le_div_of_nonneg_right h0 (le_of_lt hm_real_pos)
    have hEq : seq n - a = (F (x n) - a * (m n : ℝ)) / (m n : ℝ) := by
      dsimp [seq]
      field_simp [hm_real_ne]
    calc
      abs (seq n - a)
          = abs ((F (x n) - a * (m n : ℝ)) / (m n : ℝ)) := by rw [hEq]
      _ = abs (F (x n) - a * (m n : ℝ)) / (m n : ℝ) := by
            rw [abs_div, abs_of_pos hm_real_pos]
      _ ≤ C / (m n : ℝ) := hdiv
  have hm_atTop : Filter.Tendsto m Filter.atTop Filter.atTop := by
    simpa [m] using (tendsto_nat_floor_atTop.comp (tendsto_pow_atTop_atTop_of_one_lt hc))
  have hm_real_atTop : Filter.Tendsto (fun n => (m n : ℝ)) Filter.atTop Filter.atTop := by
    exact (tendsto_natCast_atTop_iff.2 hm_atTop)
  have hCdiv : Filter.Tendsto (fun n => C / (m n : ℝ)) Filter.atTop (nhds 0) := by
    exact Filter.Tendsto.const_div_atTop hm_real_atTop C
  have habs : Filter.Tendsto (fun n => abs (seq n - a)) Filter.atTop (nhds 0) := by
    exact squeeze_zero (fun n => abs_nonneg _) hbound hCdiv
  have hdist : Filter.Tendsto (fun n => dist (seq n) a) Filter.atTop (nhds 0) := by
    simpa [Real.dist_eq] using habs
  have hseq : Filter.Tendsto seq Filter.atTop (nhds a) :=
    (tendsto_iff_dist_tendsto_zero.2 hdist)
  simpa [seq, F, x, m] using hseq

theorem tendsto_sum_range_div_of_tendsto_sum_Icc_div {f : ℕ → ℝ} {l : ℝ} :
    Filter.Tendsto
      (fun m : ℕ => (∑ k ∈ Finset.Icc 1 m, f k) / (m : ℝ))
      Filter.atTop (nhds l) →
    Filter.Tendsto
      (fun m : ℕ => (∑ k ∈ Finset.range m, f k) / (m : ℝ))
      Filter.atTop (nhds l) := by
  intro h
  let g : ℕ → ℝ := fun m => (∑ k ∈ Finset.Icc 1 m, f k) / (m : ℝ)
  have hg : Filter.Tendsto g Filter.atTop (nhds l) := h
  have hcomp : Filter.Tendsto (fun m : ℕ => g (m - 1)) Filter.atTop (nhds l) := by
    simpa using hg.comp (Filter.tendsto_sub_atTop_nat 1)
  have hzero : Filter.Tendsto (fun m : ℕ => f 0 / (m : ℝ)) Filter.atTop (nhds 0) := by
    simpa using tendsto_const_div_atTop_nhds_zero_nat (f 0)
  have hratio_aux : Filter.Tendsto (fun n : ℕ => (n : ℝ) / ((n : ℝ) + 1)) Filter.atTop (nhds 1) := by
    simpa using (tendsto_natCast_div_add_atTop (1 : ℝ))
  have hu : Filter.Tendsto (fun m : ℕ => (((m - 1 : ℕ) : ℝ) / ((((m - 1 : ℕ) : ℝ)) + 1))) Filter.atTop (nhds 1) := by
    simpa using hratio_aux.comp (Filter.tendsto_sub_atTop_nat 1)
  have hratio : Filter.Tendsto (fun m : ℕ => (((m - 1 : ℕ) : ℝ) / (m : ℝ))) Filter.atTop (nhds 1) := by
    refine Filter.Tendsto.congr' (Filter.Eventually.of_forall ?_) hu
    intro m
    cases m with
    | zero => norm_num
    | succ n =>
        simp [Nat.cast_sub (Nat.succ_le_succ (Nat.zero_le n))]
  have hmul : Filter.Tendsto (fun m : ℕ => (((m - 1 : ℕ) : ℝ) / (m : ℝ)) * g (m - 1)) Filter.atTop (nhds (1 * l)) := by
    exact hratio.mul hcomp
  have hadd : Filter.Tendsto (fun m : ℕ => f 0 / (m : ℝ) + (((m - 1 : ℕ) : ℝ) / (m : ℝ)) * g (m - 1)) Filter.atTop (nhds (0 + 1 * l)) := by
    exact hzero.add hmul
  have hadd' : Filter.Tendsto (fun m : ℕ => f 0 / (m : ℝ) + (((m - 1 : ℕ) : ℝ) / (m : ℝ)) * g (m - 1)) Filter.atTop (nhds l) := by
    simpa using hadd
  have hEq :
      (fun m : ℕ => f 0 / (m : ℝ) + (((m - 1 : ℕ) : ℝ) / (m : ℝ)) * g (m - 1)) =ᶠ[Filter.atTop]
        (fun m : ℕ => (∑ k ∈ Finset.range m, f k) / (m : ℝ)) := by
    filter_upwards [Filter.eventually_gt_atTop 0] with m hm
    rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hm) with ⟨n, rfl⟩
    have hsum : (∑ k ∈ Finset.range (n + 1), f k) = f 0 + ∑ k ∈ Finset.Icc 1 n, f k := by
      rw [Nat.range_succ_eq_Icc_zero]
      rw [← Finset.insert_Icc_succ_left_eq_Icc (a := 0) (b := n) (Nat.zero_le n)]
      rw [Finset.sum_insert]
      · simp
      · simp
    rw [hsum, add_div]
    congr 1
    by_cases hn : n = 0
    · simp [hn, g]
    · have hn0 : (n : ℝ) ≠ 0 := by
        exact_mod_cast hn
      simpa [g] using (div_mul_div_cancel₀' hn0 (↑n + 1) (∑ k ∈ Finset.Icc 1 n, f k))
  exact Filter.Tendsto.congr' hEq hadd'

theorem tendsto_weighted_average_floor_pow_of_LSeries_pole {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∀ c : ℝ, 1 < c →
      Filter.Tendsto
        (fun n : ℕ =>
          (∑' k, f k / (k : ℝ) ^ (1 + (⌊c ^ n⌋₊ : ℝ)⁻¹)) / (⌊c ^ n⌋₊ : ℝ))
        Filter.atTop (nhds a.re) := by
  intro hsumm hcont heq c hc
  exact tendsto_lSeries_eval_one_add_inv_floor_pow_of_real_pole_bound
    (lSeries_real_sub_pole_abs_le_of_continuous_eqOn hsumm hcont heq) c hc

theorem unitIntervalAverage_tendsto_of_tendsto_sum_div {f : ℕ → ℝ} {b : ℝ} :
  (hsumdiv : Filter.Tendsto (fun n : ℕ => (∑ k ∈ Finset.Icc 1 n, f k) / (n : ℝ))
      Filter.atTop (nhds b)) →
  Filter.Tendsto (fun X : ℝ => ∫ t in X - 1..X, logRescalePartialSum f t)
    Filter.atTop (nhds b) := by
  intro hsumdiv
  have hsumdiv_floor :
      Filter.Tendsto
        (fun x : ℝ => (∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / (⌊Real.exp x⌋₊ : ℝ))
        Filter.atTop (nhds b) := by
    exact hsumdiv.comp (tendsto_nat_floor_atTop.comp Real.tendsto_exp_atTop)
  have hfloor_div :
      Filter.Tendsto (fun x : ℝ => (⌊Real.exp x⌋₊ : ℝ) / Real.exp x) Filter.atTop (nhds 1) := by
    exact tendsto_nat_floor_div_atTop.comp Real.tendsto_exp_atTop
  have hprod :
      Filter.Tendsto
        (fun x : ℝ =>
          ((∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) / (⌊Real.exp x⌋₊ : ℝ)) *
            ((⌊Real.exp x⌋₊ : ℝ) / Real.exp x))
        Filter.atTop (nhds b) := by
    simpa using hsumdiv_floor.mul hfloor_div
  have hlog : Filter.Tendsto (fun x : ℝ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
    refine Filter.Tendsto.congr' ?_ hprod
    filter_upwards [Filter.eventually_ge_atTop (0 : ℝ)] with x hx
    rw [logRescalePartialSum, if_pos hx, Real.exp_neg]
    have hxexp : 1 ≤ Real.exp x := by
      rw [← Real.exp_zero]
      exact (Real.exp_le_exp).2 hx
    have hfloor_pos : 0 < ⌊Real.exp x⌋₊ := Nat.floor_pos.2 hxexp
    have hfloor_ne : (⌊Real.exp x⌋₊ : ℝ) ≠ 0 := by
      exact_mod_cast (Nat.ne_of_gt hfloor_pos)
    field_simp [hfloor_ne, Real.exp_ne_zero]
  have hA : Measurable (fun n : ℕ => ∑ k ∈ Finset.Icc 1 n, f k) := measurable_from_nat
  have hsum_meas :
      Measurable fun x : ℝ => ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k := by
    exact hA.comp ((Real.measurable_exp).nat_floor)
  have hmeas : Measurable (logRescalePartialSum f) := by
    unfold logRescalePartialSum
    refine Measurable.ite measurableSet_Ici ?_ measurable_const
    exact (Real.measurable_exp.comp measurable_id.neg).mul hsum_meas
  refine Metric.tendsto_atTop.2 ?_
  intro ε hε
  have hε2 : 0 < ε / 2 := by positivity
  rcases (Metric.tendsto_atTop.1 hlog) (ε / 2) hε2 with ⟨R, hR⟩
  refine ⟨R + 1, ?_⟩
  intro X hX
  have hXle : X - 1 ≤ X := by linarith
  have hXR : R ≤ X - 1 := by linarith
  have hbound_Ioc : ∀ t ∈ Set.Ioc (X - 1) X, ‖logRescalePartialSum f t - b‖ ≤ ε / 2 := by
    intro t ht
    have htR : R ≤ t := by linarith [ht.1, hXR]
    have htε : dist (logRescalePartialSum f t) b < ε / 2 := hR t htR
    simpa [dist_eq_norm] using le_of_lt htε
  have hbound_uIoc : ∀ t ∈ Set.uIoc (X - 1) X, ‖logRescalePartialSum f t - b‖ ≤ ε / 2 := by
    intro t ht
    have ht' : t ∈ Set.Ioc (X - 1) X := by
      simpa [Set.uIoc_of_le hXle] using ht
    exact hbound_Ioc t ht'
  have hbound_norm : ∀ t ∈ Set.Ioc (X - 1) X, ‖logRescalePartialSum f t‖ ≤ ε / 2 + ‖b‖ := by
    intro t ht
    calc
      ‖logRescalePartialSum f t‖ = ‖(logRescalePartialSum f t - b) + b‖ := by ring_nf
      _ ≤ ‖logRescalePartialSum f t - b‖ + ‖b‖ := norm_add_le _ _
      _ ≤ ε / 2 + ‖b‖ := add_le_add (hbound_Ioc t ht) le_rfl
  have hlog_int_on :
      MeasureTheory.IntegrableOn (logRescalePartialSum f) (Set.Ioc (X - 1) X)
        MeasureTheory.MeasureSpace.volume := by
    refine MeasureTheory.Measure.integrableOn_of_bounded
      (μ := MeasureTheory.MeasureSpace.volume) (s := Set.Ioc (X - 1) X)
      (M := ε / 2 + ‖b‖) ?_ hmeas.aestronglyMeasurable ?_
    · simp [Real.volume_Ioc]
    · rw [MeasureTheory.ae_restrict_iff' measurableSet_Ioc]
      filter_upwards with t ht
      exact hbound_norm t ht
  have hlog_int :
      IntervalIntegrable (logRescalePartialSum f) MeasureTheory.MeasureSpace.volume (X - 1) X := by
    exact (intervalIntegrable_iff_integrableOn_Ioc_of_le hXle).2 hlog_int_on
  have hconst : ∫ t in X - 1..X, b = b := by
    simp
  have hsub :
      (∫ t in X - 1..X, logRescalePartialSum f t) - b =
        ∫ t in X - 1..X, (logRescalePartialSum f t - b) := by
    calc
      (∫ t in X - 1..X, logRescalePartialSum f t) - b
          = (∫ t in X - 1..X, logRescalePartialSum f t) - ∫ t in X - 1..X, b := by rw [hconst]
      _ = ∫ t in X - 1..X, (logRescalePartialSum f t - b) := by
        symm
        exact intervalIntegral.integral_sub hlog_int intervalIntegral.intervalIntegrable_const
  have hlen' : X - (X - 1) = 1 := by ring
  have hlen : |X - (X - 1)| = 1 := by
    rw [hlen']
    norm_num
  have hnorm : ‖(∫ t in X - 1..X, logRescalePartialSum f t) - b‖ ≤ ε / 2 := by
    rw [hsub]
    have htmp :=
      intervalIntegral.norm_integral_le_of_norm_le_const
        (a := X - 1) (b := X) (C := ε / 2)
        (f := fun t : ℝ => logRescalePartialSum f t - b) hbound_uIoc
    simpa [hlen] using htmp
  have hlt : ε / 2 < ε := by linarith
  simpa [dist_eq_norm] using lt_of_le_of_lt hnorm hlt

theorem weighted_dirichlet_series_monotone {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    Monotone (fun m : ℕ =>
      if m = 0 then 0 else ∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) := by
  intro hf hsum m n hmn
  by_cases hm : m = 0
  · subst hm
    by_cases hn : n = 0
    · simp [hn]
    · simp [hn]
      have hq_pos : 0 < (1 + (n : ℝ)⁻¹ : ℝ) := by
        have hnpos : (0 : ℝ) < (n : ℝ) := by
          exact_mod_cast Nat.pos_of_ne_zero hn
        have hinv : 0 < (n : ℝ)⁻¹ := inv_pos.mpr hnpos
        linarith
      have h_eq :
          (∑' k, f k / (k : ℝ) ^ (1 + (n : ℝ)⁻¹)) =
            ∑' k, (if k = 0 then 0 else f k / (k : ℝ) ^ (1 + (n : ℝ)⁻¹)) := by
        apply tsum_congr
        intro k
        by_cases hk : k = 0
        · subst hk
          simp [Real.zero_rpow (ne_of_gt hq_pos)]
        · simp [hk]
      rw [h_eq]
      exact tsum_nonneg (fun k => by
        by_cases hk : k = 0
        · simp [hk]
        · simp [hk]
          have hkpos : (0 : ℝ) < (k : ℝ) := by
            exact_mod_cast Nat.pos_of_ne_zero hk
          exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _)))
  · have hn : n ≠ 0 := by
      intro h0
      apply hm
      exact Nat.eq_zero_of_le_zero (by simpa [h0] using hmn)
    have hmpos : (0 : ℝ) < (m : ℝ) := by
      exact_mod_cast Nat.pos_of_ne_zero hm
    have hnpos : (0 : ℝ) < (n : ℝ) := by
      exact_mod_cast Nat.pos_of_ne_zero hn
    let qm : ℝ := 1 + (m : ℝ)⁻¹
    let qn : ℝ := 1 + (n : ℝ)⁻¹
    have hqm_pos : 0 < qm := by
      dsimp [qm]
      have h : 0 < (m : ℝ)⁻¹ := inv_pos.mpr hmpos
      linarith
    have hqn_pos : 0 < qn := by
      dsimp [qn]
      have h : 0 < (n : ℝ)⁻¹ := inv_pos.mpr hnpos
      linarith
    have hqn_gt1 : 1 < qn := by
      dsimp [qn]
      have h : 0 < (n : ℝ)⁻¹ := inv_pos.mpr hnpos
      linarith
    have hqle : qn ≤ qm := by
      dsimp [qn, qm]
      have hmn' : (m : ℝ) ≤ (n : ℝ) := by
        exact_mod_cast hmn
      have hinv : (n : ℝ)⁻¹ ≤ (m : ℝ)⁻¹ := by
        simpa [one_div] using one_div_le_one_div_of_le hmpos hmn'
      linarith
    let a : ℕ → ℝ := fun k => if k = 0 then 0 else f k / (k : ℝ) ^ qm
    let b : ℕ → ℝ := fun k => if k = 0 then 0 else f k / (k : ℝ) ^ qn
    have ha_nonneg : ∀ k, 0 ≤ a k := by
      intro k
      by_cases hk : k = 0
      · simp [a, hk]
      · simp [a, hk]
        have hkpos : (0 : ℝ) < (k : ℝ) := by
          exact_mod_cast Nat.pos_of_ne_zero hk
        exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _))
    have hb_nonneg : ∀ k, 0 ≤ b k := by
      intro k
      by_cases hk : k = 0
      · simp [b, hk]
      · simp [b, hk]
        have hkpos : (0 : ℝ) < (k : ℝ) := by
          exact_mod_cast Nat.pos_of_ne_zero hk
        exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _))
    have hab : ∀ k, a k ≤ b k := by
      intro k
      by_cases hk : k = 0
      · simp [a, b, hk]
      · simp [a, b, hk]
        have hkpos_nat : 0 < k := Nat.pos_of_ne_zero hk
        have hkpos : (0 : ℝ) < (k : ℝ) := by
          exact_mod_cast hkpos_nat
        have hkone : (1 : ℝ) ≤ (k : ℝ) := by
          exact_mod_cast Nat.succ_le_of_lt hkpos_nat
        have hpow : (k : ℝ) ^ qn ≤ (k : ℝ) ^ qm := by
          exact Real.rpow_le_rpow_of_exponent_le hkone hqle
        have hpowpos : 0 < (k : ℝ) ^ qn := Real.rpow_pos_of_pos hkpos _
        exact div_le_div_of_nonneg_left (hf k) hpowpos hpow
    have hls : LSeriesSummable (fun n => (f n : ℂ)) (qn : ℂ) := by
      exact hsum (qn : ℂ) (by simpa using hqn_gt1)
    have hsummable_b_norm : Summable (fun k => ‖LSeries.term (fun n => (f n : ℂ)) (qn : ℂ) k‖) := by
      rw [LSeriesSummable, ← summable_norm_iff] at hls
      exact hls
    have hsummable_b : Summable b := by
      simpa [b, qn, LSeries.norm_term_eq, Real.norm_eq_abs, abs_of_nonneg, hf] using hsummable_b_norm
    have htsum_a :
        (∑' k, f k / (k : ℝ) ^ qm) = ∑' k, a k := by
      apply tsum_congr
      intro k
      by_cases hk : k = 0
      · subst hk
        simp [a, Real.zero_rpow (ne_of_gt hqm_pos)]
      · simp [a, hk]
    have htsum_b :
        (∑' k, f k / (k : ℝ) ^ qn) = ∑' k, b k := by
      apply tsum_congr
      intro k
      by_cases hk : k = 0
      · subst hk
        simp [b, Real.zero_rpow (ne_of_gt hqn_pos)]
      · simp [b, hk]
    simp [hm, hn]
    change (∑' k, f k / (k : ℝ) ^ qm) ≤ ∑' k, f k / (k : ℝ) ^ qn
    rw [htsum_a, htsum_b]
    exact Real.tsum_le_of_sum_range_le ha_nonneg (fun N => by
      refine (Finset.sum_le_sum fun i hi => hab i).trans ?_
      exact hsummable_b.sum_le_tsum (Finset.range N) (fun i hi => hb_nonneg i))

theorem tendsto_dirichlet_weighted_average_atTop_of_LSeries_pole {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    Filter.Tendsto
      (fun m : ℕ =>
        (∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))
      Filter.atTop (nhds a.re) := by
  intro hf_nonneg hsumm hcont hEq
  let u : ℕ → ℝ := fun m =>
    if m = 0 then 0 else ∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)
  have hu_mono : Monotone u := by
    simpa [u] using weighted_dirichlet_series_monotone hf_nonneg hsumm
  let d : ℕ → ℝ := fun k => 1 + 1 / ((k : ℝ) + 1)
  have hd_gt_one : ∀ k, 1 < d k := by
    intro k
    dsimp [d]
    have hk : (0 : ℝ) < 1 / ((k : ℝ) + 1) := by
      positivity
    linarith
  have hd_tendsto : Filter.Tendsto d Filter.atTop (nhds 1) := by
    have h1 : Filter.Tendsto (fun k : ℕ => 1 / ((k : ℝ) + 1)) Filter.atTop (nhds 0) :=
      (tendsto_one_div_add_atTop_nhds_zero_nat :
        Filter.Tendsto (fun k : ℕ => 1 / ((k : ℝ) + 1)) Filter.atTop (nhds 0))
    simpa [d] using tendsto_const_nhds.add h1
  have hdk : ∀ k,
      Filter.Tendsto (fun n : ℕ => u ⌊d k ^ n⌋₊ / (⌊d k ^ n⌋₊ : ℝ))
        Filter.atTop (nhds a.re) := by
    intro k
    have hk :=
      tendsto_weighted_average_floor_pow_of_LSeries_pole hsumm hcont hEq (d k) (hd_gt_one k)
    have hfloor : ∀ n : ℕ, (⌊d k ^ n⌋₊ : ℕ) ≠ 0 := by
      intro n
      have hpow : (1 : ℝ) ≤ d k ^ n := by
        exact one_le_pow₀ (show (1 : ℝ) ≤ d k by linarith [hd_gt_one k])
      exact ne_of_gt ((Nat.floor_pos).2 hpow)
    simpa [u, hfloor] using hk
  have hmain :
      Filter.Tendsto (fun m : ℕ => u m / (m : ℝ))
        Filter.atTop (nhds a.re) := by
    simpa using
      (tendsto_div_of_monotone_of_tendsto_div_floor_pow u a.re hu_mono d hd_gt_one hd_tendsto hdk)
  have h_eq :
      (fun m : ℕ => u m / (m : ℝ)) =ᶠ[Filter.atTop]
        (fun m : ℕ =>
          (∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)) := by
    refine Filter.Eventually.of_forall ?_
    intro m
    by_cases hm : m = 0 <;> simp [u, hm]
  exact Filter.Tendsto.congr' h_eq hmain

theorem tendsto_dirichlet_weighted_average_atTop_of_real_pole_bound {f : ℕ → ℝ} {a : ℝ} :
    (∀ n, 0 ≤ f n) →
    (∃ C : ℝ, 0 ≤ C ∧ ∀ {x : ℝ}, x ∈ Set.Ioc 1 2 →
      abs ((∑' n, f n / (n : ℝ) ^ x) - a / (x - 1)) ≤ C) →
    (∀ r : ℝ, 1 < r → ∃ C : ℝ, 0 ≤ C ∧ ∀ N : ℕ,
      ∑ k ∈ Finset.Icc 1 N, f k ≤ C * (N : ℝ) ^ r) →
    Filter.Tendsto
      (fun m : ℕ =>
        (∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))
      Filter.atTop (nhds a) := by
  intro hnonneg hpole hgrowth
  let u : ℕ → ℝ := fun m =>
    if m = 0 then 0 else ∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)
  have hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s :=
    lSeriesSummable_of_Icc_growth_family (f := f) hnonneg hgrowth
  have hu_mono : Monotone u := by
    simpa [u] using weighted_dirichlet_series_monotone hnonneg hsumm
  let d : ℕ → ℝ := fun k => 1 + 1 / ((k : ℝ) + 1)
  have hd_gt_one : ∀ k, 1 < d k := by
    intro k
    dsimp [d]
    have hpos : 0 < (1 / ((k : ℝ) + 1)) := by
      positivity
    linarith
  have hd_tendsto : Filter.Tendsto d Filter.atTop (nhds 1) := by
    have h1 : Filter.Tendsto (fun k : ℕ => 1 / ((k : ℝ) + 1)) Filter.atTop (nhds 0) :=
      (tendsto_one_div_add_atTop_nhds_zero_nat :
        Filter.Tendsto (fun k : ℕ => 1 / ((k : ℝ) + 1)) Filter.atTop (nhds 0))
    simpa [d] using tendsto_const_nhds.add h1
  have hdk : ∀ k,
      Filter.Tendsto (fun n : ℕ => u ⌊d k ^ n⌋₊ / (⌊d k ^ n⌋₊ : ℝ))
        Filter.atTop (nhds a) := by
    intro k
    have hk :=
      tendsto_lSeries_eval_one_add_inv_floor_pow_of_real_pole_bound
        (f := f) (a := a) hpole (d k) (hd_gt_one k)
    have hfloor : ∀ n : ℕ, (⌊d k ^ n⌋₊ : ℕ) ≠ 0 := by
      intro n
      have hpow : (1 : ℝ) ≤ d k ^ n := by
        exact one_le_pow₀ (show (1 : ℝ) ≤ d k by linarith [hd_gt_one k])
      exact ne_of_gt ((Nat.floor_pos).2 hpow)
    simpa [u, hfloor] using hk
  have hmain :
      Filter.Tendsto (fun m : ℕ => u m / (m : ℝ)) Filter.atTop (nhds a) := by
    simpa using
      (tendsto_div_of_monotone_of_tendsto_div_floor_pow u a hu_mono d hd_gt_one hd_tendsto hdk)
  have h_eq :
      (fun m : ℕ => u m / (m : ℝ)) =ᶠ[Filter.atTop]
        (fun m : ℕ =>
          (∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)) := by
    refine Filter.Eventually.of_forall ?_
    intro m
    by_cases hm : m = 0 <;> simp [u, hm]
  exact Filter.Tendsto.congr' h_eq hmain

theorem tendsto_weighted_average_of_LSeries_pole {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    Filter.Tendsto
      (fun N : ℕ =>
        (∑' k, f k / (k : ℝ) ^ (1 + (N : ℝ)⁻¹)) / (N : ℝ))
      Filter.atTop (nhds a.re) := by
  intro hf hs hcont heq
  let u : ℕ → ℝ := fun m => if m = 0 then 0 else ∑' k, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)
  have hmono : Monotone u := weighted_dirichlet_series_monotone hf hs
  let c : ℕ → ℝ := fun k => 1 + 1 / ((k : ℝ) + 1)
  have hcone : ∀ k, 1 < c k := by
    intro k
    dsimp [c]
    have hpos : 0 < 1 / ((k : ℝ) + 1) := by
      positivity
    linarith
  have hclim : Filter.Tendsto c Filter.atTop (nhds 1) := by
    have h0 : Filter.Tendsto (fun n : ℕ => 1 / ((n : ℝ) + 1)) Filter.atTop (nhds 0) := by
      simpa using
        (tendsto_one_div_add_atTop_nhds_zero_nat :
          Filter.Tendsto (fun n : ℕ => 1 / ((n : ℝ) + 1)) Filter.atTop (nhds 0))
    simpa [c, add_comm, add_left_comm, add_assoc] using h0.const_add (1 : ℝ)
  have hfloor : ∀ k : ℕ,
      Filter.Tendsto (fun n : ℕ => u ⌊c k ^ n⌋₊ / (⌊c k ^ n⌋₊ : ℝ)) Filter.atTop (nhds a.re) := by
    intro k
    have hEq :
        (fun n : ℕ => u ⌊c k ^ n⌋₊ / (⌊c k ^ n⌋₊ : ℝ)) =
          (fun n : ℕ =>
            (∑' j, f j / (j : ℝ) ^ (1 + (⌊c k ^ n⌋₊ : ℝ)⁻¹)) / (⌊c k ^ n⌋₊ : ℝ)) := by
      funext n
      have hpow : ¬ c k ^ n < 1 := by
        exact not_lt.mpr (one_le_pow₀ (a := c k) (n := n) (le_of_lt (hcone k)))
      simp [u, hpow]
    rw [hEq]
    exact tendsto_weighted_average_floor_pow_of_LSeries_pole hs hcont heq (c k) (hcone k)
  have hmain : Filter.Tendsto (fun n : ℕ => u n / (n : ℝ)) Filter.atTop (nhds a.re) :=
    tendsto_div_of_monotone_of_tendsto_div_floor_pow u a.re hmono c hcone hclim hfloor
  have hEqMain :
      (fun N : ℕ => u N / (N : ℝ)) =
        (fun N : ℕ => (∑' k, f k / (k : ℝ) ^ (1 + (N : ℝ)⁻¹)) / (N : ℝ)) := by
    funext N
    by_cases hN : N = 0
    · subst N
      simp [u]
    · simp [u, hN]
  rw [← hEqMain]
  exact hmain

theorem tendsto_weighted_average_sub_const_of_LSeries_pole {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∀ B : ℝ,
      Filter.Tendsto
        (fun m : ℕ =>
          (∑' k, (f k - B) / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))
        Filter.atTop (nhds (a.re - B)) := by
  intro hnonneg hsumm hcont heq B
  let Wf : ℕ → ℝ := fun m =>
    (∑' k : ℕ, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)
  let V : ℕ → ℝ := fun m =>
    B * (((1 + (m : ℝ)⁻¹) - 1) * ∑' k : ℕ, 1 / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
  have hWf : Filter.Tendsto Wf Filter.atTop (nhds a.re) := by
    simpa [Wf] using
      tendsto_dirichlet_weighted_average_atTop_of_LSeries_pole hnonneg hsumm hcont heq
  have hinv : Filter.Tendsto (fun m : ℕ => ((m : ℝ))⁻¹) Filter.atTop (nhdsWithin (0 : ℝ) (Set.Ioi 0)) := by
    exact tendsto_inv_atTop_nhdsGT_zero.comp tendsto_natCast_atTop_atTop
  have hseq : Filter.Tendsto (fun m : ℕ => 1 + (m : ℝ)⁻¹) Filter.atTop (nhdsWithin (1 : ℝ) (Set.Ioi 1)) := by
    have hadd : Filter.Tendsto (fun x : ℝ => 1 + x) (nhdsWithin (0 : ℝ) (Set.Ioi 0)) (nhdsWithin (1 : ℝ) (Set.Ioi 1)) := by
      simpa using
        (show ContinuousWithinAt (fun x : ℝ => 1 + x) (Set.Ioi 0) 0 from
          (continuous_const.add continuous_id).continuousWithinAt).tendsto_nhdsWithin (t := Set.Ioi 1) (by
            intro x hx
            have hx' : 0 < x := by simpa using hx
            change 1 < 1 + x
            linarith)
    simpa using hadd.comp hinv
  have hV : Filter.Tendsto V Filter.atTop (nhds B) := by
    simpa [V, one_div, mul_assoc] using (tendsto_sub_mul_tsum_nat_rpow.comp hseq).const_mul B
  have hsumf (s : ℝ) (hs : 1 < s) : Summable (fun k : ℕ => f k / (k : ℝ) ^ s) := by
    have hsumc : LSeriesSummable (fun n => (f n : ℂ)) (s : ℂ) := hsumm s hs
    rw [LSeriesSummable] at hsumc
    have hs0r : s ≠ 0 := by linarith
    have hs0 : (s : ℂ) ≠ 0 := by exact_mod_cast hs0r
    have hsumc' : Summable (fun k : ℕ => ((f k / (k : ℝ) ^ s : ℝ) : ℂ)) := by
      refine hsumc.congr ?_
      intro n
      rw [LSeries.term_of_ne_zero' hs0]
      simp [Complex.ofReal_div, Complex.ofReal_cpow (Nat.cast_nonneg n)]
    exact (Complex.summable_ofReal).mp hsumc'
  have hsum1 (s : ℝ) (hs : 1 < s) : Summable (fun k : ℕ => B / (k : ℝ) ^ s) := by
    have h : Summable (fun k : ℕ => 1 / (k : ℝ) ^ s) := (Real.summable_one_div_nat_rpow).2 hs
    simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using h.mul_left B
  have htsum (m : ℕ) (hm : 0 < m) :
      (∑' k : ℕ, (f k - B) / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
        = (∑' k : ℕ, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
          - ∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹) := by
    have hs : 1 < 1 + (m : ℝ)⁻¹ := by
      have hm' : (0 : ℝ) < m := by exact_mod_cast hm
      have hminv : 0 < (m : ℝ)⁻¹ := inv_pos.mpr hm'
      linarith
    have hf := hsumf (1 + (m : ℝ)⁻¹) hs
    have hB := hsum1 (1 + (m : ℝ)⁻¹) hs
    calc
      (∑' k : ℕ, (f k - B) / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
          = ∑' k : ℕ, (f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹) - B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) := by
              congr with k
              ring
      _ = (∑' k : ℕ, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) - ∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹) := by
            simpa using hf.tsum_sub hB
  have hVeq :
      (fun m : ℕ =>
        ((∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))) = V := by
    funext m
    have hmul :
        (∑' k : ℕ, B * ((k : ℝ) ^ (1 + (m : ℝ)⁻¹))⁻¹)
          = B * ∑' k : ℕ, ((k : ℝ) ^ (1 + (m : ℝ)⁻¹))⁻¹ := by
      simpa [div_eq_mul_inv] using (tsum_mul_left :
        (∑' k : ℕ, B * (1 / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)))
          = B * ∑' k : ℕ, 1 / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
    simp only [V, div_eq_mul_inv]
    rw [hmul]
    ring_nf
  have hsplit :
      (fun m : ℕ =>
        (∑' k : ℕ, (f k - B) / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))
        =ᶠ[Filter.atTop] fun m => Wf m - V m := by
    refine Filter.eventually_atTop.2 ?_
    refine ⟨1, ?_⟩
    intro m hm
    have hmpos : 0 < m := Nat.succ_le_iff.mp hm
    have hVm := congrFun hVeq m
    calc
      (∑' k : ℕ, (f k - B) / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)
          = (((∑' k : ℕ, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹))
              - ∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)) := by
                rw [htsum m hmpos]
      _ = ((∑' k : ℕ, f k / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ))
            - ((∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)) := by
              ring
      _ = Wf m - ((∑' k : ℕ, B / (k : ℝ) ^ (1 + (m : ℝ)⁻¹)) / (m : ℝ)) := by
            rfl
      _ = Wf m - V m := by rw [hVm]
  exact (hWf.sub hV).congr' hsplit.symm

theorem wiener_ikehara_lower_bound_lseries_nonneg {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    0 < a.re →
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∃ c : ℝ, 0 < c ∧ ∃ X₀ : ℕ, ∀ X : ℕ, X₀ ≤ X →
      c * X ≤ ∑ n ∈ Finset.range X, f n := by
  intro ha hnonneg hsumm hcont heq
  obtain ⟨c, hc, x0, hx0⟩ :=
    liminf_logRescalePartialSum_pos_of_LSeries_pole ha hnonneg hsumm hcont heq
  refine ⟨c / 2, by linarith, Nat.ceil (Real.exp x0) + 2, ?_⟩
  intro X hX
  have hX1 : 1 < X := by
    have : 2 ≤ X := by omega
    omega
  have hXge : 1 ≤ X := by omega
  have hX' : Nat.ceil (Real.exp x0) + 1 ≤ X - 1 := by
    omega
  have hXm1pos_nat : 0 < X - 1 := by omega
  have hXm1pos : 0 < ((X - 1 : ℕ) : ℝ) := by
    exact_mod_cast hXm1pos_nat
  have hXm1one : 1 ≤ ((X - 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_le_of_lt hXm1pos_nat
  have hX'r : ((Nat.ceil (Real.exp x0) + 1 : ℕ) : ℝ) ≤ ((X - 1 : ℕ) : ℝ) := by
    exact_mod_cast hX'
  have hx_le_log : x0 ≤ Real.log ((X - 1 : ℕ) : ℝ) := by
    rw [Real.le_log_iff_exp_le hXm1pos]
    have hceil : Real.exp x0 ≤ Nat.ceil (Real.exp x0) := Nat.le_ceil _
    have hceil' : (Nat.ceil (Real.exp x0) : ℝ) ≤ ((Nat.ceil (Real.exp x0) + 1 : ℕ) : ℝ) := by
      exact_mod_cast (Nat.le_succ (Nat.ceil (Real.exp x0)))
    exact hceil.trans (hceil'.trans hX'r)
  have hc_log : c ≤ logRescalePartialSum f (Real.log ((X - 1 : ℕ) : ℝ)) := hx0 _ hx_le_log
  have hsum_Icc : c * ((X - 1 : ℕ) : ℝ) ≤ ∑ n ∈ Finset.Icc 1 (X - 1), f n := by
    have hnonneglog : 0 ≤ Real.log ((X - 1 : ℕ) : ℝ) := by
      exact Real.log_nonneg hXm1one
    rw [logRescalePartialSum, if_pos hnonneglog] at hc_log
    rw [Real.exp_neg, Real.exp_log hXm1pos, Nat.floor_natCast] at hc_log
    have hmul := mul_le_mul_of_nonneg_right hc_log hXm1pos.le
    simpa [hXm1pos.ne', mul_assoc, mul_comm, mul_left_comm, inv_mul_cancel₀] using hmul
  have hsum_range : c * ((X - 1 : ℕ) : ℝ) ≤ ∑ n ∈ Finset.range X, f n := by
    rw [Nat.range_eq_Icc_zero_sub_one X (by omega)]
    have hsplit : Finset.Icc 0 (X - 1) = insert 0 (Finset.Icc 1 (X - 1)) := by
      simpa using (Finset.insert_Icc_add_one_left_eq_Icc (a := 0) (b := X - 1) (by omega)).symm
    rw [hsplit, Finset.sum_insert]
    · have hf0 : 0 ≤ f 0 := hnonneg 0
      linarith
    · simp
  have hlin : c / 2 * (X : ℝ) ≤ c * ((X - 1 : ℕ) : ℝ) := by
    have h2X : (2 : ℝ) ≤ X := by exact_mod_cast (by omega : 2 ≤ X)
    rw [Nat.cast_sub hXge]
    nlinarith [hc, h2X]
  exact le_trans hlin hsum_range

theorem primesCongOneMod3_residueClass_partial_sum_range_lower_bound: ∃ c : ℝ, 0 < c ∧ ∃ X₀ : ℕ, ∀ X : ℕ, X₀ ≤ X →
    c * X ≤ ∑ n ∈ Finset.range X, primesCongOneMod3_residueClass n := by
  have htotient : (Nat.totient 3 : ℕ) = 2 := by
    decide
  have ha : 0 < (((Nat.totient 3 : ℂ)⁻¹).re) := by
    rw [htotient]
    norm_num
  have hS : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n ↦ (primesCongOneMod3_residueClass n : ℂ)) s := by
    intro s hs
    exact LSeriesSummable_of_abscissaOfAbsConv_lt_re <| by
      simpa [primesCongOneMod3_residueClass] using
        (ArithmeticFunction.vonMangoldt.abscissaOfAbsConv_residueClass_le_one (a := (1 : ZMod 3))).trans_lt (mod_cast hs)
  exact wiener_ikehara_lower_bound_lseries_nonneg
    ha
    (fun n ↦ by
      simpa [primesCongOneMod3_residueClass] using
        (ArithmeticFunction.vonMangoldt.residueClass_nonneg (a := (1 : ZMod 3)) n))
    hS
    primesCongOneMod3_residueClassAux_continuous
    primesCongOneMod3_residueClassAux_eq_LSeries_sub_pole

theorem primesCongOneMod3_partial_sum_range_lower_bound: ∃ c : ℝ, 0 < c ∧ ∃ X₀ : ℕ, ∀ X : ℕ, X₀ ≤ X →
    c * X ≤ ∑ n ∈ Finset.range X, (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) := by
  have hsplit (X : ℕ) :
      ∑ n ∈ Finset.range X, (if n.Prime ∧ n % 3 = 1 then Real.log (n : ℝ) else 0) =
        (∑ n ∈ Finset.range X, ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n) -
          ∑ n ∈ Finset.range X,
            (if n.Prime then 0 else ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n) := by
    trans
      ∑ n ∈ Finset.range X,
        (ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n -
          (if n.Prime then 0 else ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n))
    · refine Finset.sum_congr rfl ?_
      intro n hn
      by_cases hp : n.Prime
      · by_cases hmod : n % 3 = 1
        · have hz : (n : ZMod 3) = (1 : ZMod 3) :=
              (ZMod.natCast_eq_natCast_iff' n 1 3).2 hmod
          simp [ArithmeticFunction.vonMangoldt.residueClass, hp, hz, ArithmeticFunction.vonMangoldt_apply_prime hp, hmod]
        · have hz : ¬((n : ZMod 3) = (1 : ZMod 3)) := by
              intro hz
              exact hmod ((ZMod.natCast_eq_natCast_iff' n 1 3).1 hz)
          have hres : ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n = 0 := by
            simp [ArithmeticFunction.vonMangoldt.residueClass, hz]
          simp [hp, hmod, hres]
      · simp [ArithmeticFunction.vonMangoldt.residueClass, hp]
    · rw [Finset.sum_sub_distrib]
  rcases primesCongOneMod3_residueClass_partial_sum_range_lower_bound with ⟨c, hc, X₀, hX₀⟩
  rcases primesCongOneMod3_residueClass_nonprime_partial_sum_sublinear (c / 2) (by positivity) with ⟨Y₀, hY₀⟩
  refine ⟨c / 2, by positivity, ?_⟩
  refine ⟨max X₀ Y₀, ?_⟩
  intro X hX
  have hfull :
      c * X ≤ ∑ n ∈ Finset.range X, ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n := by
    simpa [primesCongOneMod3_residueClass] using hX₀ X (le_trans (le_max_left _ _) hX)
  have herr :
      ∑ n ∈ Finset.range X,
        (if n.Prime then 0 else ArithmeticFunction.vonMangoldt.residueClass (1 : ZMod 3) n) ≤
          (c / 2) * X := by
    simpa [primesCongOneMod3_residueClass] using hY₀ X (le_trans (le_max_right _ _) hX)
  rw [hsplit X]

theorem leftTentKernel_integrable: MeasureTheory.Integrable leftTentKernel := by
  let f : в„қ вҶ’ в„Ӯ := fun u => ((2 * (u + 1) : в„қ) : в„Ӯ)
  have hf_cont : Continuous f := by
    continuity
  have hf_int : MeasureTheory.IntegrableOn f (Set.Icc (-1 : в„қ) 0) := by
    simpa [f] using hf_cont.integrableOn_Icc (a := (-1 : в„қ)) (b := 0)
  have h_eq : leftTentKernel = Set.indicator (Set.Icc (-1 : в„қ) 0) f := by
    funext u
    by_cases hu : u вҲҲ Set.Icc (-1 : в„қ) 0
    В· rcases hu with вҹЁhu1, hu2вҹ©
      simp [leftTentKernel, f, hu1, hu2]
    В· have hnot : В¬ (-1 вүӨ u вҲ§ u вүӨ 0) := by
        simpa [Set.mem_Icc] using hu
      simp [leftTentKernel, f, hu, hnot]
  rw [h_eq]
  exact hf_int.integrable_indicator (by measurability)


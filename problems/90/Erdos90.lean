theorem compactFreqKernel_damped_eq_fourier {f : в„• вҶ’ в„қ} {b : в„қ} {ПҲ : в„қ вҶ’ в„Ӯ} {G : в„Ӯ вҶ’ в„Ӯ} :
    (hGint : вҲҖ z : в„Ӯ, 0 < z.re вҶ’

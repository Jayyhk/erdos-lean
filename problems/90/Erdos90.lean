          symm
          exact Ideal.ramificationIdxIn_eq_ramificationIdx
            (p := 𝔮) (P := 𝔓) (G := 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
        _ = 1 := hram_in_eq
    have hrel_f : Ideal.inertiaDeg 𝔮 𝔓 = 1 := by
      letI : 𝔓.IsPrime := h𝔓p
      letI : 𝔓.LiesOver 𝔮 := h𝔓over𝔮
      calc
        Ideal.inertiaDeg 𝔮 𝔓 = Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K) := by
          symm
          exact Ideal.inertiaDegIn_eq_inertiaDeg
            (p := 𝔮) (P := 𝔓) (G := 𝒟.K ≃ₐ[𝒟.L] 𝒟.K)
        _ = 1 := hiner_in_eq
    have hmap𝔮_ne : Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 𝔮 ≠ ⊥ := by
      exact Ideal.map_ne_bot_of_ne_bot (I := 𝔮) h𝔮ne
    have hpmap_ne : Ideal.map (algebraMap ℤ (𝓞 𝒟.K)) p ≠ ⊥ := by
      exact Ideal.map_ne_bot_of_ne_bot (I := p) hp0
    have hmap_le : Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 𝔮 ≤ 𝔓 := by
      have hdivP : 𝔓 ∣ Ideal.map (algebraMap (𝓞 𝒟.L) (𝓞 𝒟.K)) 𝔮 :=
        (Ideal.liesOver_iff_dvd_map (p := 𝔮) (P := 𝔓) (Ideal.IsPrime.ne_top h𝔓p)).1
          h𝔓over𝔮
      rcases hdivP with ⟨I, hI⟩
      rw [hI]
      simpa [Ideal.mul_comm] using (Ideal.mul_le_left : I * 𝔓 ≤ 𝔓)
    have habs_e : Ideal.ramificationIdx p 𝔓 = 1 := by
      letI : 𝔓.IsPrime := h𝔓p

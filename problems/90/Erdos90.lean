theorem bk_h1Conts_linearEquiv_cycles1 (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    вҲғ e : _root_.Erdos90.H1ContsTrivial p G N вүғвӮ—[ZMod p] (BKHomogeneousComplex p G N).cycles 1,
      вҲҖ (g : G) (x : _root_.Erdos90.H1ContsTrivial p G N),

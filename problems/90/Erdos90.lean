    simpa [B, hdeg] using (IsEverywhereUnramified.discr_eq (F := F) (M := L) hUnr)
  rw [Int.abs_eq_natAbs]
  simp [hdiscr]

theorem finite_galois_degree_p_subextensions_of_maximal: {L : IntermediateField F (maximalUnramifiedProPF F p) |
      Module.finrank F L = p ∧ IsGalois F L}.Finite := by
  classical
  let S : Set (IntermediateField F (maximalUnramifiedProPF F p)) :=
    {L | Module.finrank F L = p ∧ IsGalois F L}
  let T : Set {M : IntermediateField ℚ (AlgebraicClosure F) // FiniteDimensional ℚ M} :=
    {M | letI : NumberField M := @NumberField.mk _ _ inferInstance M.prop
         |NumberField.discr M| ≤ (NumberField.discr F).natAbs ^ p}
  have hT : T.Finite := by
    simpa [T] using
      (NumberField.finite_of_discr_bdd (A := AlgebraicClosure F) ((NumberField.discr F).natAbs ^ p))
  haveI : Finite T := hT.to_subtype
  let φ : S → T := by
    intro L
    have hp : Nat.Prime p := Fact.out
    have hfinpos : 0 < Module.finrank F L.1 := by
      simpa [L.2.1] using hp.pos
    letI : FiniteDimensional F L.1 := FiniteDimensional.of_finrank_pos hfinpos
    letI : Module.Finite F L.1 := show Module.Finite F L.1 from inferInstance
    letI : NumberField L.1 := NumberField.of_module_finite F L.1
    letI : IsGalois F L.1 := L.2.2
    let L0 : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift L.1
    let e : L.1 ≃ₐ[F] L0 := IntermediateField.liftAlgEquiv L.1
    letI : FiniteDimensional F ↥L0 := e.toLinearEquiv.finiteDimensional
    letI : Module.Finite F ↥L0 := show Module.Finite F ↥L0 from inferInstance
    letI : NumberField ↥L0 := NumberField.of_module_finite F ↥L0
    letI : IsGalois F ↥L0 := IsGalois.of_algEquiv e
    have h_unram_L : _root_.Erdos90.IsEverywhereUnramified F L.1 :=
      _root_.Erdos90.finiteIntermediate_isUnramified F p L.1
    have h_unram_L0 : _root_.Erdos90.IsEverywhereUnramified F L0 := by
      simpa [L0] using _root_.Erdos90.IsEverywhereUnramified.transport e h_unram_L
    have hdiscr : (NumberField.discr L0).natAbs = (NumberField.discr F).natAbs ^ p := by
      calc
        (NumberField.discr L0).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F L0 := by
          simpa using _root_.Erdos90.IsEverywhereUnramified.discr_eq (F := F) (M := L0) h_unram_L0
        _ = (NumberField.discr F).natAbs ^ Module.finrank F L.1 := by
          rw [← LinearEquiv.finrank_eq e.toLinearEquiv]
        _ = (NumberField.discr F).natAbs ^ p := by rw [L.2.1]
    letI : FiniteDimensional ℚ ↥L0 := FiniteDimensional.trans ℚ F ↥L0
    letI : FiniteDimensional ℚ ↥(IntermediateField.restrictScalars ℚ L0) := by
      change FiniteDimensional ℚ ↥L0
      infer_instance
    let M : {M : IntermediateField ℚ (AlgebraicClosure F) // FiniteDimensional ℚ M} :=
      ⟨IntermediateField.restrictScalars ℚ L0, inferInstance⟩
    refine ⟨M, ?_⟩
    letI : NumberField M := @NumberField.mk _ _ inferInstance M.prop
    simpa [T, M, L0] using (show |NumberField.discr L0| ≤ (NumberField.discr F).natAbs ^ p from by
      rw [← Int.natCast_natAbs, hdiscr]
      exact le_rfl)
  have hφinj : Function.Injective φ := by
    intro L1 L2 h
    have h0 : (φ L1).1 = (φ L2).1 := congrArg Subtype.val h
    have hval :
        IntermediateField.restrictScalars ℚ (IntermediateField.lift L1.1) =
          IntermediateField.restrictScalars ℚ (IntermediateField.lift L2.1) := by
      simpa [φ] using congrArg Subtype.val h0
    apply Subtype.ext
    exact (IntermediateField.lift_injective (maximalUnramifiedProPF F p)) <|
      (IntermediateField.restrictScalars_injective (K := ℚ)) hval
  haveI : Finite S := Finite.of_injective φ hφinj
  simpa [S] using (Set.toFinite S : S.Finite)

theorem fixedField_of_index_p_open_normal (H : Subgroup (MaxUnramifiedProPGaloisGroup F p)) :
    H.Normal →
      IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p)) →
      H.index = p →
      Module.finrank F (IntermediateField.fixedField H) = p ∧
        IsGalois F (IntermediateField.fixedField H) := by
  intro hNormal hOpen hHp
  letI : IsGalois F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let N : OpenNormalSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toOpenSubgroup := ⟨H, hOpen⟩
      isNormal' := hNormal }
  have hfg : FiniteDimensional F (IntermediateField.fixedField H) ∧
      IsGalois F (IntermediateField.fixedField H) := by
    simpa [N] using
      (_root_.Erdos90.fixedField_openNormal_finiteGalois
        (k := F) (K := maximalUnramifiedProPF F p) N)
  rcases hfg with ⟨hfd, hgal⟩
  letI : FiniteDimensional F (IntermediateField.fixedField H) := hfd
  letI : IsGalois F (IntermediateField.fixedField H) := hgal
  let Hc : ClosedSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toSubgroup := H
      isClosed' := Subgroup.isClosed_of_isOpen H hOpen }
  have hHcNormal : (Hc : Subgroup (MaxUnramifiedProPGaloisGroup F p)).Normal := by
    change H.Normal
    exact hNormal
  have hcard : Module.finrank F (IntermediateField.fixedField H) =
      Nat.card ((MaxUnramifiedProPGaloisGroup F p) ⧸ H) := by
    let e : ((MaxUnramifiedProPGaloisGroup F p) ⧸ H) ≃*
        Gal(IntermediateField.fixedField H / F) :=
      @InfiniteGalois.normalAutEquivQuotient F (maximalUnramifiedProPF F p) _ _ _ _ Hc hHcNormal
    calc
      Module.finrank F (IntermediateField.fixedField H)
          = Nat.card (Gal(IntermediateField.fixedField H / F)) := by
              symm
              simpa using (IsGalois.card_aut_eq_finrank F (IntermediateField.fixedField H))
      _ = Nat.card ((MaxUnramifiedProPGaloisGroup F p) ⧸ H) := by
              symm
              exact Nat.card_congr e.toEquiv
  refine ⟨?_, hgal⟩
  calc
    Module.finrank F (IntermediateField.fixedField H) =
        Nat.card ((MaxUnramifiedProPGaloisGroup F p) ⧸ H) := hcard
    _ = p := by
      simpa [Subgroup.index_eq_card] using hHp

theorem finite_index_p_open_normal_subgroups :
    {H : Subgroup (MaxUnramifiedProPGaloisGroup F p) |
        H.Normal ∧ IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p)) ∧
          H.index = p}.Finite := by
  let G := MaxUnramifiedProPGaloisGroup F p
  let K := maximalUnramifiedProPF F p
  let S : Set (Subgroup G) :=
    {H | H.Normal ∧ IsOpen (H : Set G) ∧ H.index = p}
  let U : Set (IntermediateField F K) :=
    {L | Module.finrank F L = p ∧ IsGalois F L}
  have hU : U.Finite := by
    simpa [K, U] using finite_galois_degree_p_subextensions_of_maximal (F := F) (p := p)
  haveI : Finite U := hU.to_subtype
  haveI : IsGalois F K := by
    dsimp [K]
    exact MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let f : S → U :=
    fun H => ⟨IntermediateField.fixedField H.1, by
      simpa [G, K, S, U] using
        fixedField_of_index_p_open_normal (F := F) (p := p) H.1 H.2.1 H.2.2.1 H.2.2.2⟩
  have hf : Function.Injective f := by
    intro H1 H2 hEq
    apply Subtype.ext
    change H1.1 = H2.1
    have hff : IntermediateField.fixedField H1.1 = IntermediateField.fixedField H2.1 := by
      exact congrArg Subtype.val hEq
    let Hc1 : ClosedSubgroup G :=
      { toSubgroup := H1.1
        isClosed' := Subgroup.isClosed_of_isOpen H1.1 H1.2.2.1 }
    let Hc2 : ClosedSubgroup G :=
      { toSubgroup := H2.1
        isClosed' := Subgroup.isClosed_of_isOpen H2.1 H2.2.2.1 }
    have hfix1 : ((IntermediateField.fixedField H1.1).fixingSubgroup : Subgroup G) = H1.1 := by
      simpa [G, K, Hc1] using
        (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc1)
    have hfix2 : ((IntermediateField.fixedField H2.1).fixingSubgroup : Subgroup G) = H2.1 := by
      simpa [G, K, Hc2] using
        (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc2)
    have hmid : ((IntermediateField.fixedField H1.1).fixingSubgroup : Subgroup G) =
        ((IntermediateField.fixedField H2.1).fixingSubgroup : Subgroup G) := by
      rw [hff]
    exact hfix1.symm.trans (hmid.trans hfix2)
  haveI : Finite S := Finite.of_injective f hf
  simpa [G, S] using (Set.toFinite S)

end HermiteMinkowski

theorem IsPGroup.coatom_normal (p : ℕ) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (K : Subgroup G) (hK : IsCoatom K) : K.Normal := by
  letI : Group.IsNilpotent G := hG.isNilpotent
  exact Subgroup.NormalizerCondition.normal_of_coatom K (normalizerCondition_of_isNilpotent (G := G)) hK

theorem IsPGroup.coatom_index_eq_p (p : ℕ) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (K : Subgroup G) (hK : IsCoatom K) : K.index = p := by
  classical
  letI : K.Normal := IsPGroup.coatom_normal p hG K hK
  obtain ⟨n, hn⟩ := hG.index K
  have hne_top : K ≠ ⊤ := hK.1
  have hn_ne_zero : n ≠ 0 := by
    intro h0
    apply hne_top
    exact Subgroup.index_eq_one.mp (by rw [hn, h0, pow_zero])
  have hn_eq_one : n = 1 := by
    by_contra hn1
    have hp : Nat.Prime p := Fact.out
    have hp1 : 1 < p := hp.one_lt
    have hQp : IsPGroup p (G ⧸ K) := hG.to_quotient K
    have hcardQ : Nat.card (G ⧸ K) = p ^ n := by
      simpa [hn] using (Subgroup.index_eq_card (H := K)).symm
    have hp_pow_le_cardQ : p ^ 1 ≤ Nat.card (G ⧸ K) := by
      rw [hcardQ]
      exact pow_le_pow_right' (le_of_lt hp1) (by omega)
    obtain ⟨M, hMcard⟩ :=
      Sylow.exists_subgroup_card_pow_prime_of_le_card (G := G ⧸ K) (p := p) (n := 1) hp hQp hp_pow_le_cardQ
    have hM_ne_bot : M ≠ ⊥ := by
      intro hbot
      have hcardbot : Nat.card (⊥ : Subgroup (G ⧸ K)) = p := by
        simpa [hbot, pow_one] using hMcard
      have : p = 1 := by
        calc
          p = Nat.card (⊥ : Subgroup (G ⧸ K)) := hcardbot.symm
          _ = 1 := Subgroup.card_bot (G := G ⧸ K)
      exact (Nat.ne_of_gt hp1) this
    have hM_ne_top : M ≠ ⊤ := by
      intro htop
      have hcardtop : Nat.card M = Nat.card (G ⧸ K) :=
        (Subgroup.card_eq_iff_eq_top (H := M)).2 htop
      rw [hcardQ, hMcard, pow_one] at hcardtop
      have hlt : p < p ^ n := by
        calc
          p = p ^ 1 := by rw [pow_one]
          _ < p ^ n := by
            exact pow_lt_pow_right₀ hp1 (by omega : 1 < n)
      exact (ne_of_lt hlt) hcardtop
    have hbot_lt_M : (⊥ : Subgroup (G ⧸ K)) < M := bot_lt_iff_ne_bot.mpr hM_ne_bot
    have hpre1 : (⊥ : Subgroup (G ⧸ K)).comap (QuotientGroup.mk' K) < M.comap (QuotientGroup.mk' K) :=
      (Subgroup.comap_lt_comap_of_surjective (f := QuotientGroup.mk' K)
        (K := (⊥ : Subgroup (G ⧸ K))) (L := M) (hf := QuotientGroup.mk'_surjective (N := K))).2 hbot_lt_M
    have hK_lt_comap : K < M.comap (QuotientGroup.mk' K) := by
      simpa [MonoidHom.comap_bot, QuotientGroup.ker_mk'] using hpre1
    have hM_lt_top : M < ⊤ := lt_top_iff_ne_top.mpr hM_ne_top
    have hpre2 : M.comap (QuotientGroup.mk' K) < (⊤ : Subgroup (G ⧸ K)).comap (QuotientGroup.mk' K) :=
      (Subgroup.comap_lt_comap_of_surjective (f := QuotientGroup.mk' K)
        (K := M) (L := ⊤) (hf := QuotientGroup.mk'_surjective (N := K))).2 hM_lt_top
    have hcomap_lt_top : M.comap (QuotientGroup.mk' K) < ⊤ := by
      simpa [Subgroup.comap_top] using hpre2
    have hEqTop : M.comap (QuotientGroup.mk' K) = ⊤ := (hK.lt_iff).mp hK_lt_comap
    exact hcomap_lt_top.ne hEqTop
  rw [hn, hn_eq_one, pow_one]

theorem finite_group_exists_coatom_over {G : Type*} [Group G] [Finite G] (H : Subgroup G) (hH : H < ⊤) : ∃ K : Subgroup G, IsCoatom K ∧ H ≤ K := by
  classical
  letI : IsCoatomic (Subgroup G) := Finite.to_isCoatomic
  rcases eq_top_or_exists_le_coatom H with htop | ⟨K, hK, hHK⟩
  · exfalso
    exact hH.ne htop
  · exact ⟨K, hK, hHK⟩

theorem IsPGroup.proper_subgroup_contained_in_index_p (p : ℕ) [Fact p.Prime] {G : Type*} [Group G] [Finite G] (hG : IsPGroup p G) (H : Subgroup G) (hH : H < ⊤) : ∃ K : Subgroup G, K.Normal ∧ H ≤ K ∧ K.index = p := by
  rcases finite_group_exists_coatom_over H hH with ⟨K, hK, hHK⟩
  refine ⟨K, IsPGroup.coatom_normal p hG K hK, hHK, IsPGroup.coatom_index_eq_p p hG K hK⟩

theorem exists_finset_not_subset_any_index_p_open_normal (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (hFin : {H : Subgroup G | H.Normal ∧ IsOpen (H : Set G) ∧ H.index = p}.Finite) :
    ∃ S : Finset G,
      ∀ H : Subgroup G, H.Normal → IsOpen (H : Set G) → H.index = p →
        ¬ ((S : Set G) ⊆ H) := by
  classical
  let I := {H : Subgroup G // H.Normal ∧ IsOpen (H : Set G) ∧ H.index = p}
  let _ : Fintype I := hFin.fintype
  let _ : ∀ i : I, Finite (G ⧸ (i : Subgroup G)) := fun i =>
    Subgroup.quotient_finite_of_isOpen (i : Subgroup G) i.2.2.1
  let _ : ∀ i : I, Fintype (G ⧸ (i : Subgroup G)) := fun i =>
    Fintype.ofFinite (G ⧸ (i : Subgroup G))
  let Q := ∀ i : I, G ⧸ (i : Subgroup G)
  let _ : Fintype Q := by
    infer_instance
  let φ : G → Q := fun g i => by
    letI : (i : Subgroup G).Normal := i.2.1
    exact QuotientGroup.mk' (i : Subgroup G) g
  let R : Set Q := Set.range φ
  choose lift hlift using fun r : R => r.2
  let S : Finset G := Finset.univ.image lift
  refine ⟨S, ?_⟩
  intro H hHn hHo hHp hsubset
  letI : H.Normal := hHn
  let i : I := ⟨H, hHn, hHo, hHp⟩
  have hHne : H ≠ ⊤ := by
    intro htop
    have hp1 : p = 1 := by
      calc
        p = H.index := hHp.symm
        _ = 1 := by rw [htop, Subgroup.index_top]
    exact (Fact.out : p.Prime).ne_one hp1
  have hnontriv : Nontrivial (G ⧸ H) := (QuotientGroup.nontrivial_iff).2 hHne
  letI : Nontrivial (G ⧸ H) := hnontriv
  obtain ⟨x, hx⟩ := exists_ne (1 : G ⧸ H)
  obtain ⟨g, hg⟩ := QuotientGroup.mk'_surjective H x
  let r : R := ⟨φ g, ⟨g, rfl⟩⟩
  have hmemS : lift r ∈ S := by
    refine Finset.mem_image.mpr ?_
    exact ⟨r, Finset.mem_univ _, rfl⟩
  have hcoord : QuotientGroup.mk' H (lift r) = x := by
    have h := congrArg (fun q => q i) (hlift r)
    simpa [r, φ, i] using h.trans hg
  have hnotmem : lift r ∉ H := by
    intro hmem
    have hone : QuotientGroup.mk' H (lift r) = 1 := by
      rw [← MonoidHom.mem_ker, QuotientGroup.ker_mk']
      exact hmem
    exact hx (hcoord.symm.trans hone)
  exact hnotmem (hsubset hmemS)

theorem proper_closed_subgroup_le_proper_open_subgroup (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (H : Subgroup G) (hClosed : IsClosed (H : Set G)) (hProper : H < ⊤) :
    ∃ U : Subgroup G, IsOpen (U : Set G) ∧ H ≤ U ∧ U < ⊤ := by
  classical
  let HC : ClosedSubgroup G := ⟨H, hClosed⟩
  have hHne : H ≠ ⊤ := ne_of_lt hProper
  obtain ⟨g, hgH⟩ : ∃ g : G, g ∉ H := by
    by_contra h
    apply hHne
    ext x
    constructor
    · intro hx
      trivial
    · intro hx
      by_contra hxH
      exact h ⟨x, hxH⟩
  have hsInf : H = sInf {N : Subgroup G | IsOpen (N : Set G) ∧ H ≤ N} := by
    simpa [HC] using ProfiniteGrp.closedSubgroup_eq_sInf_open HC
  have hgNotMemSInf : g ∉ sInf {N : Subgroup G | IsOpen (N : Set G) ∧ H ≤ N} := by
    rwa [← hsInf]
  by_contra hNoU
  apply hgNotMemSInf
  rw [Subgroup.mem_sInf]
  intro N hN
  by_contra hgN
  apply hNoU
  refine ⟨N, hN.1, hN.2, ?_⟩
  refine lt_top_iff_ne_top.mpr ?_
  intro hNtop
  apply hgN
  simp [hNtop]

theorem topologicalClosure_eq_top_of_not_subset_any_index_p_open_normal (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (hP : ∀ (H : Subgroup G) [H.Normal], IsOpen (H : Set G) → IsPGroup p (G ⧸ H))
    (S : Finset G)
    (hS : ∀ H : Subgroup G, H.Normal → IsOpen (H : Set G) → H.index = p →
      ¬ ((S : Set G) ⊆ H)) :
    (Subgroup.closure (S : Set G)).topologicalClosure = ⊤ := by
  classical
  let C : Subgroup G := (Subgroup.closure (S : Set G)).topologicalClosure
  by_contra hCeq
  have hCproper : C < ⊤ := by
    exact lt_of_le_of_ne le_top hCeq
  have hCclosed : IsClosed (C : Set G) := by
    simp [C]
  obtain ⟨U, hUOpen, hCU, hUproper⟩ :=
    proper_closed_subgroup_le_proper_open_subgroup G C hCclosed hCproper
  obtain ⟨N, hNsubU⟩ :=
    ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hUOpen
      (show (1 : G) ∈ (U : Set G) from U.one_mem)
  have hN_le_U : (N : Subgroup G) ≤ U := by
    intro x hx
    exact hNsubU hx
  have hCsupN_le_U : C ⊔ (N : Subgroup G) ≤ U := by
    exact sup_le hCU hN_le_U
  have hCsupN_proper : C ⊔ (N : Subgroup G) < ⊤ :=
    lt_of_le_of_lt hCsupN_le_U hUproper
  let q : G →* G ⧸ (N : Subgroup G) := QuotientGroup.mk' (N : Subgroup G)
  let J : Subgroup (G ⧸ (N : Subgroup G)) := Subgroup.map q (C ⊔ (N : Subgroup G))
  have hJproper : J < ⊤ := by
    refine lt_of_le_of_ne le_top ?_
    intro hJtop
    have hcomap : Subgroup.comap q J = C ⊔ (N : Subgroup G) := by
      simp [J, q, sup_comm]
    have : C ⊔ (N : Subgroup G) = ⊤ := by
      rw [← hcomap, hJtop, Subgroup.comap_top]
    exact hCsupN_proper.ne this
  have hNOpen : IsOpen ((N : Subgroup G) : Set G) := by
    simpa using (OpenSubgroup.isOpen (U := N.toOpenSubgroup))
  haveI : Finite (G ⧸ (N : Subgroup G)) :=
    Subgroup.quotient_finite_of_isOpen (N : Subgroup G) hNOpen
  have hPquot : IsPGroup p (G ⧸ (N : Subgroup G)) := by
    let _ : (N : Subgroup G).Normal := OpenNormalSubgroup.instNormal N
    exact hP (N : Subgroup G) hNOpen
  obtain ⟨Kq, hKqNormal, hJKq, hKqindex⟩ :=
    IsPGroup.proper_subgroup_contained_in_index_p (p := p) hPquot J hJproper
  let K : Subgroup G := Subgroup.comap q Kq
  have hKNormal : K.Normal := by
    exact Subgroup.Normal.comap hKqNormal q
  have hKOpen : IsOpen (K : Set G) := by
    have hNleK : (N : Subgroup G) ≤ K := by
      simpa [K, q] using QuotientGroup.le_comap_mk' (N := (N : Subgroup G)) Kq
    exact Subgroup.isOpen_mono hNleK hNOpen
  have hKindex : K.index = p := by
    change (Subgroup.comap q Kq).index = p
    rw [Subgroup.index_comap_of_surjective (H := Kq) (f := q)
      (QuotientGroup.mk'_surjective (N : Subgroup G))]
    exact hKqindex
  have hC_le_K : C ≤ K := by
    have hcomap_le : Subgroup.comap q J ≤ Subgroup.comap q Kq :=
      Subgroup.comap_mono hJKq
    have hCN_eq : Subgroup.comap q J = C ⊔ (N : Subgroup G) := by
      simp [J, q, sup_comm]
    have hsup_le_K : C ⊔ (N : Subgroup G) ≤ K := by
      rw [← hCN_eq]
      simpa [K] using hcomap_le
    exact le_trans le_sup_left hsup_le_K
  have hSsubsetK : (S : Set G) ⊆ K := by
    intro x hx
    have hx1 : x ∈ Subgroup.closure (S : Set G) := Subgroup.subset_closure hx
    have hx2 : x ∈ C := by
      exact (show Subgroup.closure (S : Set G) ≤ C by
        simpa [C] using Subgroup.le_topologicalClosure (Subgroup.closure (S : Set G))) hx1
    exact hC_le_K hx2
  have hcontra := hS K hKNormal hKOpen hKindex
  exact hcontra hSsubsetK

theorem proP_topologicallyFG_of_finite_index_p_subgroups (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (_hP : ∀ (H : Subgroup G) [H.Normal], IsOpen (H : Set G) → IsPGroup p (G ⧸ H))
    (_hFin : {H : Subgroup G | H.Normal ∧ IsOpen (H : Set G) ∧ H.index = p}.Finite) :
    ∃ S : Finset G, (Subgroup.closure (S : Set G)).topologicalClosure = ⊤ := by
  classical
  obtain ⟨S, hS⟩ := exists_finset_not_subset_any_index_p_open_normal (p := p) (G := G) _hFin
  refine ⟨S, ?_⟩
  exact topologicalClosure_eq_top_of_not_subset_any_index_p_open_normal (p := p) (G := G) _hP S hS

section StructuralConjunct

variable (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact p.Prime]

theorem galois_sup_isPGroup_of_galois_pgroup
    (K L : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F K] [FiniteDimensional F L]
    [IsGalois F K] [IsGalois F L]
    (hK : IsPGroup p (K ≃ₐ[F] K))
    (hL : IsPGroup p (L ≃ₐ[F] L)) :
    IsPGroup p (↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F]
      ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F))) := by
  letI : Algebra ↥K ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_left).toRingHom)
  letI : IsScalarTower F ↥K ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_left)
  letI : Algebra ↥L ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_right).toRingHom)
  letI : IsScalarTower F ↥L ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_right)
  letI : Normal F ↥K := (isGalois_iff.mp (show IsGalois F ↥K from inferInstance)).2
  letI : Normal F ↥L := (isGalois_iff.mp (show IsGalois F ↥L from inferInstance)).2
  letI : FiniteDimensional F ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    IntermediateField.finiteDimensional_sup (E1 := K) (E2 := L)
  letI : Normal F ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) :=
    IntermediateField.normal_sup (E := K) (E' := L)
  letI : IsGalois F ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) := by
    rw [isGalois_iff]; exact ⟨inferInstance, inferInstance⟩
  intro σ
  obtain ⟨a, ha⟩ := hK (AlgEquiv.restrictNormalHom (F := F)
    (K₁ := ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F))) ↥K σ)
  obtain ⟨b, hb⟩ := hL (AlgEquiv.restrictNormalHom (F := F)
    (K₁ := ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F))) ↥L σ)
  refine ⟨max a b, ?_⟩
  have hAlgK : ∀ x : ↥K, algebraMap ↥K ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) x
      = IntermediateField.inclusion le_sup_left x := fun _ => rfl
  have hAlgL : ∀ x : ↥L, algebraMap ↥L ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F)) x
      = IntermediateField.inclusion le_sup_right x := fun _ => rfl
  have hresK : (AlgEquiv.restrictNormalHom (F := F)
      (K₁ := ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F))) ↥K (σ ^ p ^ max a b)) = 1 := by
    rw [map_pow]
    have : p ^ a ∣ p ^ max a b := pow_dvd_pow p (le_max_left _ _)
    obtain ⟨c, hc⟩ := this
    rw [hc, pow_mul, ha, one_pow]
  have hresL : (AlgEquiv.restrictNormalHom (F := F)
      (K₁ := ↥(K ⊔ L : IntermediateField F (AlgebraicClosure F))) ↥L (σ ^ p ^ max a b)) = 1 := by
    rw [map_pow]
    have : p ^ b ∣ p ^ max a b := pow_dvd_pow p (le_max_right _ _)
    obtain ⟨c, hc⟩ := this
    rw [hc, pow_mul, hb, one_pow]
  exact restrict_eq_one_of_eq_one_on_sup_left_right F K L (σ ^ p ^ max a b)
    hAlgK hAlgL hresK hresL

theorem finsetSup_isPGroup
    (s : Finset (maximalUnramifiedProPFIndex F p)) :
    IsPGroup p (↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F]
      ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F))) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      have hempty :
          (⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)),
              i.M : IntermediateField F (AlgebraicClosure F)) = ⊥ := by
        simp
      let eEq : ↥(⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)),
          i.M : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F]
          (⊥ : IntermediateField F (AlgebraicClosure F)) :=
        IntermediateField.equivOfEq hempty
      have hBot : IsPGroup p ((⊥ : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F]
          (⊥ : IntermediateField F (AlgebraicClosure F))) := by
        apply IsPGroup.of_card (n := 0)
        rw [pow_zero]
        have e : (⊥ : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F] F :=
          IntermediateField.botEquiv F (AlgebraicClosure F)
        haveI : Subsingleton ((⊥ : IntermediateField F (AlgebraicClosure F)) ≃ₐ[F]
            (⊥ : IntermediateField F (AlgebraicClosure F))) :=
          (AlgEquiv.autCongr e).toEquiv.subsingleton
        exact Nat.card_unique
      exact IsPGroup.of_equiv hBot (AlgEquiv.autCongr eEq).symm
  | @insert i s his ih =>
      let Ks : IntermediateField F (AlgebraicClosure F) := ⨆ j ∈ s, j.M
      letI : ∀ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F j.M := fun j => j.hfd
      haveI : FiniteDimensional F ↥Ks :=
        IntermediateField.finiteDimensional_iSup_of_finset'
          (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s)
          (by intro j _; exact j.hfd)
      letI : FiniteDimensional F i.M := i.hfd
      haveI : IsGalois F i.M := i.hg
      haveI : IsGalois F ↥Ks := finsetSup_isGalois (F := F) (p := p) (s := s)
      have hIns : (i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) =
          ⨆ j ∈ insert i s, j.M := by
        simpa [Ks] using
          (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M)).symm
      have hKsP : IsPGroup p (↥Ks ≃ₐ[F] ↥Ks) := by
        simpa [Ks] using ih
      have hsup := galois_sup_isPGroup_of_galois_pgroup F p i.M Ks i.hpG hKsP
      exact IsPGroup.of_equiv hsup (AlgEquiv.autCongr (IntermediateField.equivOfEq hIns))

theorem galois_isPGroup_of_le_galois_pgroup
    (L M : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F L] [FiniteDimensional F M]
    [IsGalois F L] [IsGalois F M]
    (hLM : L ≤ M)
    (hM : IsPGroup p (M ≃ₐ[F] M)) :
    IsPGroup p (L ≃ₐ[F] L) := by
  letI : Algebra ↥L ↥M := (IntermediateField.inclusion hLM).toAlgebra
  letI : IsScalarTower F ↥L ↥M := IsScalarTower.of_algHom (IntermediateField.inclusion hLM)
  letI : Normal F ↥L := (isGalois_iff.mp (show IsGalois F ↥L from inferInstance)).2
  exact hM.of_surjective (AlgEquiv.restrictNormalHom (F := F) (K₁ := ↥M) ↥L)
    (AlgEquiv.restrictNormalHom_surjective (F := F) (K₁ := L) (E := M))

theorem isPGroup_quotient_of_open_normal
    (H : Subgroup (MaxUnramifiedProPGaloisGroup F p)) [hHN : H.Normal]
    (hHO : IsOpen (H : Set (MaxUnramifiedProPGaloisGroup F p))) :
    IsPGroup p (MaxUnramifiedProPGaloisGroup F p ⧸ H) := by
  classical
  letI : IsGalois F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let N : OpenNormalSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toOpenSubgroup := ⟨H, hHO⟩
      isNormal' := hHN }
  have hfg : FiniteDimensional F (IntermediateField.fixedField H) ∧
      IsGalois F (IntermediateField.fixedField H) := by
    simpa [N] using
      (_root_.Erdos90.fixedField_openNormal_finiteGalois
        (k := F) (K := maximalUnramifiedProPF F p) N)
  rcases hfg with ⟨hfd, hgal⟩
  letI : FiniteDimensional F (IntermediateField.fixedField H) := hfd
  letI : IsGalois F (IntermediateField.fixedField H) := hgal
  let Hc : ClosedSubgroup (MaxUnramifiedProPGaloisGroup F p) :=
    { toSubgroup := H
      isClosed' := Subgroup.isClosed_of_isOpen H hHO }
  have hHcNormal : (Hc : Subgroup (MaxUnramifiedProPGaloisGroup F p)).Normal := by
    change H.Normal; exact hHN
  let L : IntermediateField F (maximalUnramifiedProPF F p) :=
    IntermediateField.fixedField H
  let L₀ : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift L
  let eLift : L ≃ₐ[F] L₀ := IntermediateField.liftAlgEquiv L
  letI : FiniteDimensional F L₀ := eLift.toLinearEquiv.finiteDimensional
  letI : IsGalois F L₀ := IsGalois.of_algEquiv eLift
  obtain ⟨s, hs⟩ :=
    finiteIntermediate_lift_le_finsetSup (F := F) (p := p) (L := L)
  let Ms : IntermediateField F (AlgebraicClosure F) := ⨆ i ∈ s, i.M
  have hsub : L₀ ≤ Ms := by simpa [L₀, Ms] using hs
  letI : ∀ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F j.M := fun j => j.hfd
  letI : FiniteDimensional F ↥Ms :=
    IntermediateField.finiteDimensional_iSup_of_finset'
      (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s)
      (by intro j _; exact j.hfd)
  haveI : IsGalois F ↥Ms := finsetSup_isGalois (F := F) (p := p) (s := s)
  have hMsP : IsPGroup p (↥Ms ≃ₐ[F] ↥Ms) :=
    finsetSup_isPGroup (F := F) (p := p) (s := s)
  have hL₀P : IsPGroup p (↥L₀ ≃ₐ[F] ↥L₀) :=
    galois_isPGroup_of_le_galois_pgroup F p L₀ Ms hsub hMsP
  have hLP : IsPGroup p (L ≃ₐ[F] L) :=
    IsPGroup.of_equiv hL₀P (AlgEquiv.autCongr eLift).symm
  let eQ : ((MaxUnramifiedProPGaloisGroup F p) ⧸ H) ≃*
      Gal(IntermediateField.fixedField H / F) :=
    @InfiniteGalois.normalAutEquivQuotient F (maximalUnramifiedProPF F p) _ _ _ _ Hc hHcNormal
  exact IsPGroup.of_equiv hLP eQ.symm

theorem hyp_FiniteTopologicalRank_structural_proved :
    Hyp_FiniteTopologicalRank_structural := by
  intro F _ _ p _
  refine ⟨?_, inferInstance, inferInstance, inferInstance⟩
  intro H _ hHO
  exact isPGroup_quotient_of_open_normal F p H hHO

end StructuralConjunct

theorem isTopologicallyFinitelyGenerated
    (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact p.Prime]
    (hStr : Hyp_FiniteTopologicalRank_structural) :
    ∃ S : Finset (MaxUnramifiedProPGaloisGroup F p),
      (Subgroup.closure (S : Set (MaxUnramifiedProPGaloisGroup F p))).topologicalClosure = ⊤ := by
  obtain ⟨hP, hCompact, hT2, hTD⟩ := hStr F p
  exact
    proP_topologicallyFG_of_finite_index_p_subgroups
      (p := p) (G := MaxUnramifiedProPGaloisGroup F p) hP
      (finite_index_p_open_normal_subgroups F p)

theorem hyp_FiniteTopologicalRank_substantive_proved
    (hStr : Hyp_FiniteTopologicalRank_structural) :
    Hyp_FiniteTopologicalRank_substantive := by
  unfold Hyp_FiniteTopologicalRank_substantive
  intro F _ _ p _
  exact isTopologicallyFinitelyGenerated F p hStr

theorem hyp_FiniteTopologicalRank_proved :
    _root_.Erdos90.Hyp_FiniteTopologicalRank := by
  rw [Hyp_FiniteTopologicalRank_iff]
  exact ⟨hyp_FiniteTopologicalRank_substantive_proved
    hyp_FiniteTopologicalRank_structural_proved,
    hyp_FiniteTopologicalRank_structural_proved⟩


    rw [hq j Пғ]
    simpa using (InfiniteGalois.normalAutEquivQuotient_apply (k := F) (K := K) (H := H j) Пғ)
  have hunramified : вҲҖ j, IsEverywhereUnramified F (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j

theorem QuotientGroup.totallyDisconnectedSpace
    {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] [T2Space G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    TotallyDisconnectedSpace (G ⧸ N) := by
  haveI : T2Space (G ⧸ N) := by
    haveI : T1Space (G ⧸ N) := QuotientGroup.instT1Space
    infer_instance
  refine ⟨fun S _ hScon => ?_⟩

  by_contra hne
  obtain ⟨x, hxS, y, hyS, hxy⟩ := Set.not_subsingleton_iff.mp hne

  obtain ⟨x₀, rfl⟩ := QuotientGroup.mk_surjective x
  obtain ⟨y₀, rfl⟩ := QuotientGroup.mk_surjective y

  set yN : Set G := { g | y₀⁻¹ * g ∈ N } with hyN_def
  have hyN_closed : IsClosed yN := by
    have hcont : Continuous (fun g : G => y₀⁻¹ * g) := continuous_const.mul continuous_id
    exact hN.preimage hcont
  have hx_notin : x₀ ∉ yN := by
    intro hin
    apply hxy
    show QuotientGroup.mk x₀ = QuotientGroup.mk y₀
    rw [QuotientGroup.eq]

    have hinv : (y₀⁻¹ * x₀)⁻¹ ∈ N := N.inv_mem hin
    have heq : (y₀⁻¹ * x₀)⁻¹ = x₀⁻¹ * y₀ := by group
    rw [heq] at hinv
    exact hinv

  obtain ⟨W, hWclopen, hxW, hWdisj⟩ :=
    exists_clopen_of_closed_subset_open
      (Z := ({x₀} : Set G)) (U := (yN)ᶜ)
      isClosed_singleton hyN_closed.isOpen_compl
      (by intro z hz; rw [Set.mem_singleton_iff] at hz; subst hz; exact hx_notin)

  have hUopen : IsOpen (QuotientGroup.mk '' W : Set (G ⧸ N)) :=
    QuotientGroup.isOpenQuotientMap_mk.isOpenMap _ hWclopen.isOpen
  have hUclosed : IsClosed (QuotientGroup.mk '' W : Set (G ⧸ N)) :=
    (hWclopen.isClosed.isCompact.image continuous_quotient_mk').isClosed

  have hx_in : (QuotientGroup.mk x₀ : G ⧸ N) ∈ (QuotientGroup.mk '' W) :=
    ⟨x₀, hxW rfl, rfl⟩
  have hy_notin : (QuotientGroup.mk y₀ : G ⧸ N) ∉ (QuotientGroup.mk '' W) := by
    rintro ⟨w, hw, hwy⟩
    apply hWdisj hw

    rw [QuotientGroup.eq] at hwy
    show y₀⁻¹ * w ∈ N

    have : (y₀⁻¹ * w) = (w⁻¹ * y₀)⁻¹ := by group
    rw [this]
    exact N.inv_mem hwy

  have hSU_inter : (S ∩ (QuotientGroup.mk '' W)).Nonempty := ⟨_, hxS, hx_in⟩
  have hSUc_inter : (S ∩ (QuotientGroup.mk '' W)ᶜ).Nonempty := ⟨_, hyS, hy_notin⟩
  have hSU_nempty : (S ∩ ((QuotientGroup.mk '' W) ∩ (QuotientGroup.mk '' W)ᶜ)).Nonempty :=
    hScon (QuotientGroup.mk '' W) ((QuotientGroup.mk '' W)ᶜ) hUopen hUclosed.isOpen_compl
      (fun z _ => (em _).imp_right (fun h => h)) hSU_inter hSUc_inter
  obtain ⟨z, _, hz1, hz2⟩ := hSU_nempty
  exact hz2 hz1


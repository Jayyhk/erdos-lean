    have hspan_mul :
        Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({e x} : Set (рқ“һ рқ’ҹ.K)) =
          proposition_2_2_qIdeal рқ’ҹ * proposition_2_2_qIdeal рқ’ҹ := by
      calc
        Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K)) * Ideal.span ({e x} : Set (рқ“һ рқ’ҹ.K))
            = (I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)) *
                (proposition_2_2_conjIdeal рқ’ҹ (I Оө.1) * I ОөвӮҖ) := by
                  rw [вҶҗ hx, вҶҗ hx_conj]
        _ = (I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I Оө.1)) *
              (I ОөвӮҖ * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)) := by
              simp [mul_assoc, mul_left_comm, mul_comm]
        _ = proposition_2_2_qIdeal рқ’ҹ * proposition_2_2_qIdeal рқ’ҹ := by
              rw [hI_mul_conj Оө.1, hI_mul_conj ОөвӮҖ]
    have hsingle :
        Ideal.span ({x * e x} : Set (рқ“һ рқ’ҹ.K)) =
          Ideal.span ({(рқ’ҹ.Q : рқ“һ рқ’ҹ.K) * (рқ’ҹ.Q : рқ“һ рқ’ҹ.K)} : Set (рқ“һ рқ’ҹ.K)) := by
      simpa [proposition_2_2_qIdeal, Ideal.span_singleton_mul_span_singleton] using hspan_mul
    have hmem : ((рқ’ҹ.Q : рқ“һ рқ’ҹ.K) * (рқ’ҹ.Q : рқ“һ рқ’ҹ.K)) вҲҲ Ideal.span ({x * e x} : Set (рқ“һ рқ’ҹ.K)) := by
      rw [hsingle]
      exact Ideal.subset_span (by simp)
    have hdiv : x * e x вҲЈ (рқ’ҹ.Q : рқ“һ рқ’ҹ.K) * (рқ’ҹ.Q : рқ“һ рқ’ҹ.K) := by
      rwa [Ideal.mem_span_singleton] at hmem
    rcases hdiv with вҹЁa, haвҹ©
    refine вҹЁa * x * x, ?_вҹ©
    have he_apply : ((e x : рқ“һ рқ’ҹ.K) : рқ’ҹ.K) = рқ’ҹ.c (x : рқ’ҹ.K) := by
      rfl
    have haK : ((рқ’ҹ.Q : рқ’ҹ.K) * (рқ’ҹ.Q : рқ’ҹ.K)) = (((x : рқ’ҹ.K) * рқ’ҹ.c (x : рқ’ҹ.K)) * (a : рқ’ҹ.K)) := by
      have ha' := congrArg (fun z : рқ“һ рқ’ҹ.K => (z : рқ’ҹ.K)) ha
      simpa [he_apply, mul_assoc] using ha'
    have hcancel : (рқ’ҹ.c (x : рқ’ҹ.K)) * ((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)) = (x : рқ’ҹ.K) := by
      field_simp [hcx0]
    change ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K))) = (((a * x * x : рқ“һ рқ’ҹ.K) : рқ’ҹ.K))
    calc
      ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)))
          = (((рқ’ҹ.Q : рқ’ҹ.K) * (рқ’ҹ.Q : рқ’ҹ.K)) * (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)))) := by
              simp [pow_two]
      _ = ((((x : рқ’ҹ.K) * рқ’ҹ.c (x : рқ’ҹ.K)) * (a : рқ’ҹ.K)) * (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)))) := by
            rw [haK]
      _ = (((a : рқ’ҹ.K) * (x : рқ’ҹ.K)) * ((рқ’ҹ.c (x : рқ’ҹ.K)) * (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K))))) := by
            ring
      _ = (((a : рқ’ҹ.K) * (x : рқ’ҹ.K)) * (x : рқ’ҹ.K)) := by
            rw [hcancel]
      _ = (((a * x * x : рқ“һ рқ’ҹ.K) : рқ’ҹ.K)) := by
            simp [mul_assoc]

theorem proposition_2_2_fiber_injective_normOneMap (рқ’ҹ : AdmissibleDatum)
    (I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K))
    (hI_nonzero : вҲҖ Оө, I Оө вү  вҠҘ)
    (hI_mul_conj : вҲҖ Оө, I Оө * proposition_2_2_conjIdeal рқ’ҹ (I Оө) = proposition_2_2_qIdeal рқ’ҹ)
    (hI_cross : вҲҖ {Оө О· : proposition_2_2_choice_type рқ’ҹ},
      I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) =
        I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) вҶ’ Оө = О·)
    (C : ClassGroup (рқ“һ рқ’ҹ.K))
    (ОөвӮҖ : proposition_2_2_choice_type рқ’ҹ)
    (hОөвӮҖ : ClassGroup.mk0 вҹЁI ОөвӮҖ, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ОөвӮҖ)вҹ© = C) :
    вҲғ u : {Оө : proposition_2_2_choice_type рқ’ҹ //
          ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C} вҶ’ рқ’ҹ.K,
      Function.Injective u вҲ§ вҲҖ Оө, рқ’ҹ.IsNormOneIntegral (u Оө) := by
  classical
  let cInt : (рқ“һ рқ’ҹ.K) вүғвӮҗ[рқ“һ рқ’ҹ.L] (рқ“һ рқ’ҹ.K) :=
    NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
  let conjI0 : Ideal (рқ“һ рқ’ҹ.K) := proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)
  have hconjI0_nonzero : conjI0 вү  вҠҘ := by
    dsimp [conjI0, proposition_2_2_conjIdeal]
    rw [Ideal.map_eq_bot_iff_of_injective]
    В· exact hI_nonzero ОөвӮҖ
    В· exact cInt.injective
  have hI0_inv :
      ClassGroup.mk0 вҹЁI ОөвӮҖ, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ОөвӮҖ)вҹ© =
        (ClassGroup.mk0 вҹЁconjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzeroвҹ©)вҒ»В№ := by
    rw [ClassGroup.mk0_eq_mk0_inv_iff]
    refine вҹЁ(рқ’ҹ.Q : рқ“һ рқ’ҹ.K), ?_, ?_вҹ©
    В· exact_mod_cast (Nat.ne_of_gt рқ’ҹ.Q_pos)
    В· simpa [conjI0, proposition_2_2_qIdeal] using hI_mul_conj ОөвӮҖ
  let F := {Оө : proposition_2_2_choice_type рқ’ҹ //
    ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C}
  have hprincipal : вҲҖ Оө : F,
      вҲғ x : рқ“һ рқ’ҹ.K, x вү  0 вҲ§ I Оө.1 * conjI0 = Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K)) := by
    intro Оө
    have hclass :
        ClassGroup.mk0 вҹЁI Оө.1, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө.1)вҹ© =
          (ClassGroup.mk0 вҹЁconjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzeroвҹ©)вҒ»В№ := by
      calc
        ClassGroup.mk0 вҹЁI Оө.1, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө.1)вҹ© = C := Оө.2
        _ = ClassGroup.mk0 вҹЁI ОөвӮҖ, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ОөвӮҖ)вҹ© := hОөвӮҖ.symm
        _ = (ClassGroup.mk0 вҹЁconjI0, mem_nonZeroDivisors_iff_ne_zero.mpr hconjI0_nonzeroвҹ©)вҒ»В№ := hI0_inv
    rw [ClassGroup.mk0_eq_mk0_inv_iff] at hclass
    simpa [conjI0] using hclass
  let xgen : F вҶ’ рқ“һ рқ’ҹ.K := fun Оө => Classical.choose (hprincipal Оө)
  have hxgen_nonzero : вҲҖ Оө : F, xgen Оө вү  0 := by
    intro Оө
    exact (Classical.choose_spec (hprincipal Оө)).1
  have hxgen_ideal : вҲҖ Оө : F,
      I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) =
        Ideal.span ({xgen Оө} : Set (рқ“һ рқ’ҹ.K)) := by
    intro Оө
    exact (Classical.choose_spec (hprincipal Оө)).2
  let u : F вҶ’ рқ’ҹ.K := fun Оө => (xgen Оө : рқ’ҹ.K) / рқ’ҹ.c (xgen Оө : рқ’ҹ.K)
  refine вҹЁu, ?_, ?_вҹ©
  В· simpa [u] using
      proposition_2_2_fiber_principal_generator_injective рқ’ҹ I hI_nonzero @hI_cross C ОөвӮҖ xgen hxgen_nonzero hxgen_ideal
  В· intro Оө
    simpa [u] using
      proposition_2_2_fiber_principal_generator_normOne рқ’ҹ I hI_nonzero hI_mul_conj C ОөвӮҖ Оө (xgen Оө)
        (hxgen_nonzero Оө) (hxgen_ideal Оө)

theorem proposition_2_2_class_fiber_to_finset (рқ’ҹ : AdmissibleDatum)
    (I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K))
    (hI_nonzero : вҲҖ Оө, I Оө вү  вҠҘ)
    (hI_mul_conj : вҲҖ Оө, I Оө * proposition_2_2_conjIdeal рқ’ҹ (I Оө) = proposition_2_2_qIdeal рқ’ҹ)
    (hI_cross : вҲҖ {Оө О· : proposition_2_2_choice_type рқ’ҹ},
      I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) =
        I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) вҶ’ Оө = О·)
    (C : ClassGroup (рқ“һ рқ’ҹ.K))
    (ОөвӮҖ : proposition_2_2_choice_type рқ’ҹ)
    (hОөвӮҖ : ClassGroup.mk0 вҹЁI ОөвӮҖ, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero ОөвӮҖ)вҹ© = C) :
    вҲғ U : Finset рқ’ҹ.K,
      U.card =
        Nat.card {Оө : proposition_2_2_choice_type рқ’ҹ //
          ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C} вҲ§
      (вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u) := by
  classical
  let fiber : Type := {Оө : proposition_2_2_choice_type рқ’ҹ //
    ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C}
  let _ : Fintype fiber := Fintype.ofFinite fiber
  obtain вҹЁu, huinj, hnormвҹ© := proposition_2_2_fiber_injective_normOneMap рқ’ҹ I hI_nonzero hI_mul_conj hI_cross C ОөвӮҖ hОөвӮҖ
  refine вҹЁFinset.univ.image u, ?_, ?_вҹ©
  В· simpa [fiber] using (Finset.card_image_of_injective (s := (Finset.univ : Finset fiber)) huinj)
  В· intro v hv
    rcases Finset.mem_image.mp hv with вҹЁОө, -, rflвҹ©
    exact hnorm Оө

open UniqueFactorizationMonoid in
theorem proposition_2_2_quadratic_split_normalizedFactors (Оә : Type*) [Field Оә] [DecidableEq Оә] (r : Оә) (hr : r ^ 2 = (-1 : Оә)) :
    UniqueFactorizationMonoid.normalizedFactors
      ((Polynomial.X ^ 2 + Polynomial.C (1 : Оә) : Polynomial Оә)) =
      ({(Polynomial.X - Polynomial.C r : Polynomial Оә)} : Multiset (Polynomial Оә)) +
      ({(Polynomial.X + Polynomial.C r : Polynomial Оә)} : Multiset (Polynomial Оә)) := by
  let qвӮҒ : Polynomial Оә := Polynomial.X - Polynomial.C r
  let qвӮӮ : Polynomial Оә := Polynomial.X + Polynomial.C r
  have hfac : (Polynomial.X ^ 2 + Polynomial.C (1 : Оә) : Polynomial Оә) = qвӮҒ * qвӮӮ := by
    calc
      (Polynomial.X ^ 2 + Polynomial.C (1 : Оә) : Polynomial Оә)
          = Polynomial.X ^ 2 - Polynomial.C (r ^ 2) := by
              rw [hr]
              simp [sub_eq_add_neg]
      _ = Polynomial.X ^ 2 - (Polynomial.C r) ^ 2 := by
            rw [Polynomial.C_pow]
      _ = qвӮҒ * qвӮӮ := by
            simp [qвӮҒ, qвӮӮ, pow_two]
            ring
  have hqвӮҒirr : Irreducible qвӮҒ := by
    simpa [qвӮҒ] using Polynomial.irreducible_X_sub_C r
  have hqвӮӮirr : Irreducible qвӮӮ := by
    simpa [qвӮӮ, sub_eq_add_neg, Polynomial.C_neg, add_comm, add_left_comm, add_assoc] using
      (Polynomial.irreducible_X_sub_C (-r))
  have hqвӮҒ0 : qвӮҒ вү  0 := hqвӮҒirr.ne_zero
  have hqвӮӮ0 : qвӮӮ вү  0 := hqвӮӮirr.ne_zero
  calc
    UniqueFactorizationMonoid.normalizedFactors
        ((Polynomial.X ^ 2 + Polynomial.C (1 : Оә) : Polynomial Оә))
        = UniqueFactorizationMonoid.normalizedFactors (qвӮҒ * qвӮӮ) := by rw [hfac]
    _ = UniqueFactorizationMonoid.normalizedFactors qвӮҒ +
        UniqueFactorizationMonoid.normalizedFactors qвӮӮ := by
          rw [UniqueFactorizationMonoid.normalizedFactors_mul hqвӮҒ0 hqвӮӮ0]
    _ = ({normalize qвӮҒ} : Multiset (Polynomial Оә)) + ({normalize qвӮӮ} : Multiset (Polynomial Оә)) := by
          rw [UniqueFactorizationMonoid.normalizedFactors_irreducible hqвӮҒirr,
            UniqueFactorizationMonoid.normalizedFactors_irreducible hqвӮӮirr]
    _ = ({qвӮҒ} : Multiset (Polynomial Оә)) + ({qвӮӮ} : Multiset (Polynomial Оә)) := by
          congr 1
          В· rw [Polynomial.Monic.normalize_eq_self (Polynomial.monic_X_sub_C r)]
          В· rw [Polynomial.Monic.normalize_eq_self (Polynomial.monic_X_add_C r)]
    _ = ({(Polynomial.X - Polynomial.C r : Polynomial Оә)} : Multiset (Polynomial Оә)) +
        ({(Polynomial.X + Polynomial.C r : Polynomial Оә)} : Multiset (Polynomial Оә)) := by
          simp [qвӮҒ, qвӮӮ]

theorem proposition_2_2_split_prime_over_L_residue_root (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) (p : Ideal (рқ“һ рқ’ҹ.L))
    (hp0 : p вү  вҠҘ) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)))
    (hp_inertia : Ideal.inertiaDeg (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) p = 1) :
    вҲғ r : (рқ“һ рқ’ҹ.L в§ё p), r ^ 2 = (-1 : (рқ“һ рқ’ҹ.L в§ё p)) вҲ§ (-r : (рқ“һ рқ’ҹ.L в§ё p)) вү  r := by
  classical
  letI : p.IsMaximal := hp_prime.isMaximal hp0
  letI : Field (рқ“һ рқ’ҹ.L в§ё p) := Ideal.Quotient.field p
  letI : Finite (рқ“һ рқ’ҹ.L в§ё p) := by
    infer_instance
  letI : Fintype (рқ“һ рқ’ҹ.L в§ё p) := Fintype.ofFinite (рқ“һ рқ’ҹ.L в§ё p)
  letI : p.LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) := hp_lies
  letI : Fact (Nat.Prime (рқ’ҹ.q b)) := вҹЁрқ’ҹ.q_prime bвҹ©
  have hcard_nat : Nat.card (рқ“һ рқ’ҹ.L в§ё p) = рқ’ҹ.q b := by
    calc
      Nat.card (рқ“һ рқ’ҹ.L в§ё p) = Submodule.cardQuot p := by
        symm
        exact Submodule.cardQuot_apply p
      _ = Ideal.absNorm p := by
        symm
        exact Ideal.absNorm_apply p
      _ = рқ’ҹ.q b ^ Ideal.inertiaDeg (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) p := by
        simpa using
          (Ideal.absNorm_eq_pow_inertiaDeg' (P := p) (p := рқ’ҹ.q b) (hp := рқ’ҹ.q_prime b))
      _ = рқ’ҹ.q b ^ 1 := by rw [hp_inertia]
      _ = рқ’ҹ.q b := by simp only [pow_one]
  have hcard : Fintype.card (рқ“һ рқ’ҹ.L в§ё p) = рқ’ҹ.q b := by
    rw [Fintype.card_eq_nat_card]
    exact hcard_nat
  let e : ZMod (рқ’ҹ.q b) вүғ+* (рқ“һ рқ’ҹ.L в§ё p) :=
    ZMod.ringEquivOfPrime (R := (рқ“һ рқ’ҹ.L в§ё p)) (рқ’ҹ.q_prime b) hcard
  have hmod4_ne3 : рқ’ҹ.q b % 4 вү  3 := by
    have hmod4 : рқ’ҹ.q b % 4 = 1 := рқ’ҹ.q_mod4 b
    omega
  have hsq : вҲғ z : ZMod (рқ’ҹ.q b), z ^ 2 = (-1 : ZMod (рқ’ҹ.q b)) := by
    have hsq' : IsSquare (-1 : ZMod (рқ’ҹ.q b)) :=
      (ZMod.exists_sq_eq_neg_one_iff).2 hmod4_ne3
    rw [isSquare_iff_exists_sq] at hsq'
    rcases hsq' with вҹЁz, hzвҹ©
    exact вҹЁz, by simpa [eq_comm] using hzвҹ©
  rcases hsq with вҹЁz, hzвҹ©
  have hz0 : z вү  0 := by
    intro hz0
    have hneg1_ne_zero : (-1 : ZMod (рқ’ҹ.q b)) вү  0 := by
      exact neg_ne_zero.mpr one_ne_zero
    apply hneg1_ne_zero
    calc
      (-1 : ZMod (рқ’ҹ.q b)) = z ^ 2 := by simpa using hz.symm
      _ = 0 := by simp [hz0]
  have hodd : Odd (рқ’ҹ.q b) := by
    rw [Nat.odd_iff]
    exact Nat.odd_of_mod_four_eq_one (рқ’ҹ.q_mod4 b)
  have hz_ne_neg : z вү  (-z : ZMod (рқ’ҹ.q b)) :=
    ZMod.ne_neg_self hodd hz0
  refine вҹЁe z, ?_, ?_вҹ©
  В· calc
      (e z) ^ 2 = e (z ^ 2) := by
        simp
      _ = e (-1) := by rw [hz]
      _ = (-1 : (рқ“һ рқ’ҹ.L в§ё p)) := by
        simp
  В· intro h
    have h' : (-z : ZMod (рқ’ҹ.q b)) = z := by
      apply e.injective
      simpa using h
    exact hz_ne_neg h'.symm

theorem proposition_2_2_theta_minpoly (рқ’ҹ : AdmissibleDatum) :
    вҲғ Оё : рқ“һ рқ’ҹ.K,
      ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K) вҲ§
      minpoly (рқ“һ рқ’ҹ.L) Оё = Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L) := by
  classical
  let hiL : IsIntegral (рқ“һ рқ’ҹ.L) рқ’ҹ.i_K := by
    refine вҹЁPolynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L), ?_, ?_вҹ©
    В· simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : рқ“һ рқ’ҹ.L)) (n := 2) (by decide))
    В· rw [Polynomial.evalвӮӮ_add, Polynomial.evalвӮӮ_X_pow, Polynomial.evalвӮӮ_C]
      simp [pow_two, рқ’ҹ.i_K_sq]
  let Оё : рқ“һ рқ’ҹ.K := IsIntegralClosure.mk' (рқ“һ рқ’ҹ.K) рқ’ҹ.i_K hiL
  have hОё : ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K) := by
    simp [Оё]
  have hiField : IsIntegral рқ’ҹ.L рқ’ҹ.i_K := by
    refine вҹЁPolynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L), ?_, ?_вҹ©
    В· simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : рқ’ҹ.L)) (n := 2) (by decide))
    В· rw [Polynomial.evalвӮӮ_add, Polynomial.evalвӮӮ_X_pow, Polynomial.evalвӮӮ_C]
      simp [pow_two, рқ’ҹ.i_K_sq]
  have htwo : 2 вүӨ (minpoly рқ’ҹ.L рқ’ҹ.i_K).natDegree :=
    (minpoly.two_le_natDegree_iff hiField).2 рқ’ҹ.i_K_notMem_range
  have hdeg :
      (Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L)).degree вүӨ
        (minpoly рқ’ҹ.L рқ’ҹ.i_K).degree := by
    have hdeg' : (2 : WithBot в„•) вүӨ (minpoly рқ’ҹ.L рқ’ҹ.i_K).degree := by
      rw [Polynomial.degree_eq_natDegree (minpoly.ne_zero hiField)]
      exact_mod_cast htwo
    rw [Polynomial.degree_X_pow_add_C (R := рқ’ҹ.L) (n := 2) (by decide : 0 < 2) (1 : рқ’ҹ.L)]
    exact hdeg'
  have hmin_field : Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L) = minpoly рқ’ҹ.L рқ’ҹ.i_K := by
    apply minpoly.unique_of_degree_le_degree_minpoly (A := рқ’ҹ.L) (x := рқ’ҹ.i_K)
    В· simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : рқ’ҹ.L)) (n := 2) (by decide))
    В· change Polynomial.evalвӮӮ (algebraMap рқ’ҹ.L рқ’ҹ.K) рқ’ҹ.i_K
          (Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L)) = 0
      rw [Polynomial.evalвӮӮ_add, Polynomial.evalвӮӮ_X_pow, Polynomial.evalвӮӮ_C]
      simp [pow_two, рқ’ҹ.i_K_sq]
    В· exact hdeg
  have hОё_integral : IsIntegral (рқ“һ рқ’ҹ.L) Оё :=
    IsIntegralClosure.isIntegral (R := рқ“һ рқ’ҹ.L) (A := рқ“һ рқ’ҹ.K) (B := рқ’ҹ.K) Оё
  have hfrac :
      minpoly рқ’ҹ.L ((Оё : рқ’ҹ.K)) =
        (minpoly (рқ“һ рқ’ҹ.L) Оё).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) := by
    simpa using
      (minpoly.isIntegrallyClosed_eq_field_fractions
        (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) (K := рқ’ҹ.L) (L := рқ’ҹ.K) (s := Оё)
        hОё_integral)
  refine вҹЁОё, hОё, ?_вҹ©
  have hmap' :
      (minpoly (рқ“һ рқ’ҹ.L) Оё).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) =
        Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L) := by
    calc
      (minpoly (рқ“һ рқ’ҹ.L) Оё).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L)
          = minpoly рқ’ҹ.L ((Оё : рқ’ҹ.K)) := by
              symm
              exact hfrac
      _ = minpoly рқ’ҹ.L рқ’ҹ.i_K := by rw [hОё]
      _ = Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L) := hmin_field.symm
  have himg :
      (Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L)).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) =
        Polynomial.X ^ 2 + Polynomial.C (1 : рқ’ҹ.L) := by
    rw [Polynomial.map_add, Polynomial.map_pow, Polynomial.map_X, Polynomial.map_C]
    rw [map_one]
  have hmap :
      (minpoly (рқ“һ рқ’ҹ.L) Оё).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) =
        (Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L)).map (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) :=
    hmap'.trans himg.symm
  exact
    (Polynomial.map_injective (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L)
      (FaithfulSMul.algebraMap_injective (рқ“һ рқ’ҹ.L) рқ’ҹ.L)) hmap

theorem proposition_2_2_split_prime_over_L_kd_setup (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) (p : Ideal (рқ“һ рқ’ҹ.L))
    (hp0 : p вү  вҠҘ) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө))) :
    вҲғ Оё : рқ“һ рқ’ҹ.K,
      ((Оё : рқ’ҹ.K) = рқ’ҹ.i_K) вҲ§
      minpoly (рқ“һ рқ’ҹ.L) Оё = Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L) вҲ§
      (conductor (рқ“һ рқ’ҹ.L) Оё).comap (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҠ” p = вҠӨ := by
  obtain вҹЁОё, hОё, hminвҹ© := proposition_2_2_theta_minpoly рқ’ҹ
  refine вҹЁОё, hОё, hmin, ?_вҹ©
  exact proposition_2_2_conductor_coprime_p рқ’ҹ b p hp0 hp_prime hp_lies Оё hОё hmin

open UniqueFactorizationMonoid in
theorem proposition_2_2_split_prime_over_L (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) (p : Ideal (рқ“һ рқ’ҹ.L))
    (hp0 : p вү  вҠҘ) (hp_prime : p.IsPrime)
    (hp_lies : p.LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)))
    (hp_inertia : Ideal.inertiaDeg (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) p = 1) :
    вҲғ P : Ideal (рқ“һ рқ’ҹ.K),
      P вү  вҠҘ вҲ§ P.IsPrime вҲ§ P.LiesOver p вҲ§
      (proposition_2_2_conjIdeal рқ’ҹ P).LiesOver p вҲ§
      P вү  proposition_2_2_conjIdeal рқ’ҹ P вҲ§
      P * proposition_2_2_conjIdeal рқ’ҹ P =
        p.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) := by
  classical
  have hp_max : p.IsMaximal := hp_prime.isMaximal hp0
  letI : p.IsMaximal := hp_max
  letI : Field (рқ“һ рқ’ҹ.L в§ё p) := Ideal.Quotient.field p
  letI : DecidableEq (рқ“һ рқ’ҹ.L в§ё p) := Classical.decEq _
  obtain вҹЁОё, hОёi, hmin, hcondвҹ© :=
    proposition_2_2_split_prime_over_L_kd_setup рқ’ҹ b p hp0 hp_prime hp_lies
  have hОёint : IsIntegral (рқ“һ рқ’ҹ.L) Оё := by
    exact
      (Algebra.isIntegral_def.mp
        (NumberField.RingOfIntegers.extension_algebra_isIntegral (K := рқ’ҹ.L) (L := рқ’ҹ.K))) Оё
  obtain вҹЁr, hr, hr_neвҹ© :=
    proposition_2_2_split_prime_over_L_residue_root рқ’ҹ b p hp0 hp_prime hp_lies hp_inertia
  obtain вҹЁa, haвҹ© := (Ideal.Quotient.mk_surjective (I := p)) r
  let QвӮҒ : Polynomial (рқ“һ рқ’ҹ.L) := Polynomial.X - Polynomial.C a
  let QвӮӮ : Polynomial (рқ“һ рқ’ҹ.L) := Polynomial.X + Polynomial.C a
  have hQвӮҒmap : QвӮҒ.map (Ideal.Quotient.mk p) = Polynomial.X - Polynomial.C r := by
    dsimp [QвӮҒ]
    simp [ha]
  have hQвӮӮmap : QвӮӮ.map (Ideal.Quotient.mk p) = Polynomial.X + Polynomial.C r := by
    dsimp [QвӮӮ]
    simp [ha]
  have hminmap : (minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p) =
      (Polynomial.X ^ 2 + Polynomial.C (1 : рқ“һ рқ’ҹ.L в§ё p)) := by
    rw [hmin]
    simp
  have hnormFactors_fbar :
      UniqueFactorizationMonoid.normalizedFactors
        ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p)) =
        ({(Polynomial.X - Polynomial.C r : Polynomial (рқ“һ рқ’ҹ.L в§ё p))} :
            Multiset (Polynomial (рқ“һ рқ’ҹ.L в§ё p))) +
        ({(Polynomial.X + Polynomial.C r : Polynomial (рқ“һ рқ’ҹ.L в§ё p))} :
            Multiset (Polynomial (рқ“һ рқ’ҹ.L в§ё p))) := by
    rw [hminmap]
    exact proposition_2_2_quadratic_split_normalizedFactors (Оә := (рқ“һ рқ’ҹ.L в§ё p)) r hr
  have hQвӮҒfac : QвӮҒ.map (Ideal.Quotient.mk p) вҲҲ
      UniqueFactorizationMonoid.normalizedFactors ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p)) := by
    rw [hnormFactors_fbar, hQвӮҒmap]
    simp
  have hQвӮӮfac : QвӮӮ.map (Ideal.Quotient.mk p) вҲҲ
      UniqueFactorizationMonoid.normalizedFactors ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p)) := by
    rw [hnormFactors_fbar, hQвӮӮmap]
    simp
  let Оұ : рқ“һ рқ’ҹ.L вҶ’+* рқ“һ рқ’ҹ.K := algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)
  let kd := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk hp_max hp0 hcond hОёint
  let PвӮҒ : Ideal (рқ“һ рқ’ҹ.K) :=
    (kd.symm вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ© :
        {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)})
  let PвӮӮ : Ideal (рқ“һ рқ’ҹ.K) :=
    (kd.symm вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ© :
        {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)})
  have hPвӮҒ_mem : PвӮҒ вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ) := by
    dsimp [PвӮҒ]
    exact (kd.symm вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ©).property
  have hPвӮӮ_mem : PвӮӮ вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ) := by
    dsimp [PвӮӮ]
    exact (kd.symm вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ©).property
  have hPвӮҒ_over : PвӮҒ вҲҲ p.primesOver (рқ“һ рқ’ҹ.K) := by
    rw [Ideal.mem_primesOver_iff_mem_normalizedFactors (A := рқ“һ рқ’ҹ.K) hp0]
    simpa [Оұ] using hPвӮҒ_mem
  have hPвӮӮ_over : PвӮӮ вҲҲ p.primesOver (рқ“һ рқ’ҹ.K) := by
    rw [Ideal.mem_primesOver_iff_mem_normalizedFactors (A := рқ“һ рқ’ҹ.K) hp0]
    simpa [Оұ] using hPвӮӮ_mem
  have hPвӮҒ0 : PвӮҒ вү  вҠҘ := by
    exact Ideal.ne_bot_of_mem_primesOver (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) hp0 hPвӮҒ_over
  have hPвӮӮ0 : PвӮӮ вү  вҠҘ := by
    exact Ideal.ne_bot_of_mem_primesOver (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) hp0 hPвӮӮ_over
  have hPвӮҒ_prime : PвӮҒ.IsPrime := hPвӮҒ_over.1
  have hPвӮӮ_prime : PвӮӮ.IsPrime := hPвӮӮ_over.1
  have hPвӮҒ_lies : PвӮҒ.LiesOver p := hPвӮҒ_over.2
  have hPвӮӮ_lies : PвӮӮ.LiesOver p := hPвӮӮ_over.2
  have hPвӮҒ_span : PвӮҒ = Ideal.span (p.map Оұ вҲӘ {QвӮҒ.aeval Оё}) := by
    simpa [PвӮҒ, Оұ, kd] using
      KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
        hp_max hQвӮҒfac hp0 hcond hОёint
  have hPвӮӮ_span : PвӮӮ = Ideal.span (p.map Оұ вҲӘ {QвӮӮ.aeval Оё}) := by
    simpa [PвӮӮ, Оұ, kd] using
      KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
        hp_max hQвӮӮfac hp0 hcond hОёint
  have hconjP : proposition_2_2_conjIdeal рқ’ҹ PвӮҒ = PвӮӮ := by
    rw [hPвӮҒ_span, hPвӮӮ_span]
    exact proposition_2_2_conjIdeal_span_X_sub_C_eq_span_X_add_C рқ’ҹ Оё hОёi p a
  have hPвӮҒ_sub : (вҹЁPвӮҒ, hPвӮҒ_memвҹ© : {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)}) =
      kd.symm вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ© := by
    apply Subtype.ext
    rfl
  have hPвӮӮ_sub : (вҹЁPвӮӮ, hPвӮӮ_memвҹ© : {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)}) =
      kd.symm вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ© := by
    apply Subtype.ext
    rfl
  have hkd1 : kd вҹЁPвӮҒ, hPвӮҒ_memвҹ© = вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ© := by
    rw [hPвӮҒ_sub]
    exact Equiv.apply_symm_apply kd _
  have hkd2 : kd вҹЁPвӮӮ, hPвӮӮ_memвҹ© = вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ© := by
    rw [hPвӮӮ_sub]
    exact Equiv.apply_symm_apply kd _
  have hPneq : PвӮҒ вү  PвӮӮ := by
    intro hEq
    have hsubEq : (вҹЁPвӮҒ, hPвӮҒ_memвҹ© : {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)}) =
        вҹЁPвӮӮ, hPвӮӮ_memвҹ© := by
      apply Subtype.ext
      exact hEq
    have hpolySub :
        ((вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ© :
          {f : Polynomial (рқ“һ рқ’ҹ.L в§ё p) |
            f вҲҲ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p))}) =
        (вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ© :
          {f : Polynomial (рқ“һ рқ’ҹ.L в§ё p) |
            f вҲҲ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p))})) := by
      calc
        (вҹЁQвӮҒ.map (Ideal.Quotient.mk p), hQвӮҒfacвҹ© :
          {f : Polynomial (рқ“һ рқ’ҹ.L в§ё p) |
            f вҲҲ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p))}) = kd вҹЁPвӮҒ, hPвӮҒ_memвҹ© := by
          symm
          exact hkd1
        _ = kd вҹЁPвӮӮ, hPвӮӮ_memвҹ© := by
          rw [hsubEq]
        _ = (вҹЁQвӮӮ.map (Ideal.Quotient.mk p), hQвӮӮfacвҹ© :
          {f : Polynomial (рқ“һ рқ’ҹ.L в§ё p) |
            f вҲҲ UniqueFactorizationMonoid.normalizedFactors
              ((minpoly (рқ“һ рқ’ҹ.L) Оё).map (Ideal.Quotient.mk p))}) := by
          exact hkd2
    have hpolyEq : QвӮҒ.map (Ideal.Quotient.mk p) = QвӮӮ.map (Ideal.Quotient.mk p) := by
      exact congrArg Subtype.val hpolySub
    have hxeq : (Polynomial.X - Polynomial.C r : Polynomial (рқ“һ рқ’ҹ.L в§ё p)) = Polynomial.X + Polynomial.C r := by
      calc
        (Polynomial.X - Polynomial.C r : Polynomial (рқ“һ рқ’ҹ.L в§ё p)) = QвӮҒ.map (Ideal.Quotient.mk p) := by
          symm
          exact hQвӮҒmap
        _ = QвӮӮ.map (Ideal.Quotient.mk p) := hpolyEq
        _ = Polynomial.X + Polynomial.C r := hQвӮӮmap
    have hneg_eq : (-r : рқ“һ рқ’ҹ.L в§ё p) = r := by
      have hcoeff := congrArg (fun f : Polynomial (рқ“һ рқ’ҹ.L в§ё p) => f.coeff 0) hxeq
      simpa [sub_eq_add_neg] using hcoeff
    exact hr_ne hneg_eq
  have hpmap0 : p.map Оұ вү  вҠҘ := by
    simpa [Оұ] using (Ideal.map_ne_bot_of_ne_bot (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) hp0)
  have hcard :
      (UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)).card = 2 := by
    rw [KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) (x := Оё) (I := p) hp_max hp0 hcond hОёint]
    simp [hnormFactors_fbar]
  obtain вҹЁJвӮҒ, JвӮӮ, hnfвҹ© := (Multiset.card_eq_two).mp hcard
  have hmem1 : PвӮҒ = JвӮҒ вҲЁ PвӮҒ = JвӮӮ := by
    simpa [hnf] using hPвӮҒ_mem
  have hmem2 : PвӮӮ = JвӮҒ вҲЁ PвӮӮ = JвӮӮ := by
    simpa [hnf] using hPвӮӮ_mem
  have hnormFactors_map :
      UniqueFactorizationMonoid.normalizedFactors (p.map Оұ) =
        ({PвӮҒ} : Multiset (Ideal (рқ“һ рқ’ҹ.K))) +
        ({PвӮӮ} : Multiset (Ideal (рқ“һ рқ’ҹ.K))) := by
    rcases hmem1 with h1 | h1 <;> rcases hmem2 with h2 | h2
    В· exfalso
      exact hPneq (by simp [h1, h2])
    В· simp [h1, h2, hnf]
    В· simp [h1, h2, Multiset.add_comm, hnf]
    В· exfalso
      exact hPneq (by simp [h1, h2])
  have hprod : PвӮҒ * PвӮӮ = p.map Оұ := by
    calc
      PвӮҒ * PвӮӮ =
          (({PвӮҒ} : Multiset (Ideal (рқ“һ рқ’ҹ.K))) +
            ({PвӮӮ} : Multiset (Ideal (рқ“һ рқ’ҹ.K)))).prod := by
        simp
      _ = (UniqueFactorizationMonoid.normalizedFactors (p.map Оұ)).prod := by
        rw [hnormFactors_map]
      _ = p.map Оұ := prod_normalizedFactors_eq_self hpmap0
  refine вҹЁPвӮҒ, hPвӮҒ0, hPвӮҒ_prime, hPвӮҒ_lies, ?_, ?_, ?_вҹ©
  В· simpa [hconjP] using hPвӮӮ_lies
  В· simpa [hconjP] using hPneq
  В· simpa [hconjP] using hprod

open scoped BigOperators in
theorem proposition_2_2_prime_family (рқ’ҹ : AdmissibleDatum) :
    вҲғ P : (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Ideal (рқ“һ рқ’ҹ.K),
      (вҲҖ j, P j вү  вҠҘ) вҲ§
      (вҲҖ j, (P j).IsPrime) вҲ§
      (вҲҖ {j k}, j вү  k вҶ’ P j вү  P k) вҲ§
      (вҲҖ j k, P j вү  proposition_2_2_conjIdeal рқ’ҹ (P k)) вҲ§
      ((вҲҸ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, P j * proposition_2_2_conjIdeal рқ’ҹ (P j)) = proposition_2_2_qIdeal рқ’ҹ) := by
  classical
  choose p hp_ne hp_prime hp_dist hp_fact hp_prod using proposition_2_2_prime_family_L рқ’ҹ
  have hsplit :
      вҲҖ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f,
        вҲғ P : Ideal (рқ“һ рқ’ҹ.K),
          P вү  вҠҘ вҲ§
          P.IsPrime вҲ§
          P.LiesOver (p j.1 j.2) вҲ§
          (proposition_2_2_conjIdeal рқ’ҹ P).LiesOver (p j.1 j.2) вҲ§
          P вү  proposition_2_2_conjIdeal рқ’ҹ P вҲ§
          P * proposition_2_2_conjIdeal рқ’ҹ P =
            (p j.1 j.2).map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) := by
    intro j
    refine proposition_2_2_split_prime_over_L рқ’ҹ j.1 (p j.1 j.2) (hp_ne j.1 j.2) (hp_prime j.1 j.2) ?_ ?_
    В· exact (hp_fact j.1 j.2).1
    В· exact (hp_fact j.1 j.2).2.2
  choose P hP_ne hP_prime hP_lies hP_conj_lies hP_ne_conj hP_mul using hsplit
  have hp_under_Z :
      вҲҖ b i,
        Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө) = (p b i).under в„Ө := by
    intro b i
    haveI := (hp_fact b i).1
    exact Ideal.over_def (A := в„Ө) (P := p b i)
      (p := Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө))
  have p_eq_imp_eq :
      вҲҖ {j k : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f}, p j.1 j.2 = p k.1 k.2 вҶ’ j = k := by
    rintro вҹЁb, iвҹ© вҹЁb', i'вҹ© hp_eq
    have hspan :
        Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө) = Ideal.span ({(рқ’ҹ.q b' : в„Ө)} : Set в„Ө) := by
      calc
        Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө) = (p b i).under в„Ө := hp_under_Z b i
        _ = (p b' i').under в„Ө := by simp [hp_eq]
        _ = Ideal.span ({(рқ’ҹ.q b' : в„Ө)} : Set в„Ө) := (hp_under_Z b' i').symm
    have hassoc : Associated (рқ’ҹ.q b : в„Ө) (рқ’ҹ.q b' : в„Ө) :=
      (Ideal.span_singleton_eq_span_singleton).1 hspan
    have hq : рқ’ҹ.q b = рқ’ҹ.q b' := by
      have hnatAbs : ((рқ’ҹ.q b : в„Ө).natAbs) = ((рқ’ҹ.q b' : в„Ө).natAbs) :=
        (Int.associated_iff_natAbs).1 hassoc
      simpa using hnatAbs
    have hb : b = b' := рқ’ҹ.q_inj hq
    subst hb
    by_cases hi : i = i'
    В· subst hi
      rfl
    В· exfalso
      exact (hp_dist b hi) hp_eq
  refine вҹЁP, hP_ne, hP_prime, ?_, ?_, ?_вҹ©
  В· intro j k hjk hEq
    apply hjk
    apply p_eq_imp_eq
    calc
      p j.1 j.2 = (P j).under (рқ“һ рқ’ҹ.L) := by
        haveI := hP_lies j
        exact Ideal.over_def (A := рқ“һ рқ’ҹ.L) (P := P j) (p := p j.1 j.2)
      _ = (P k).under (рқ“һ рқ’ҹ.L) := by simp [hEq]
      _ = p k.1 k.2 := by
        haveI := hP_lies k
        exact (Ideal.over_def (A := рқ“һ рқ’ҹ.L) (P := P k) (p := p k.1 k.2)).symm
  В· intro j k hEq
    have hp_eq : p j.1 j.2 = p k.1 k.2 := by
      calc
        p j.1 j.2 = (P j).under (рқ“һ рқ’ҹ.L) := by
          haveI := hP_lies j
          exact Ideal.over_def (A := рқ“һ рқ’ҹ.L) (P := P j) (p := p j.1 j.2)
        _ = (proposition_2_2_conjIdeal рқ’ҹ (P k)).under (рқ“һ рқ’ҹ.L) := by simp [hEq]
        _ = p k.1 k.2 := by
          haveI := hP_conj_lies k
          exact (Ideal.over_def (A := рқ“һ рқ’ҹ.L)
            (P := proposition_2_2_conjIdeal рқ’ҹ (P k)) (p := p k.1 k.2)).symm
    have hjk : j = k := p_eq_imp_eq hp_eq
    cases hjk
    exact hP_ne_conj j hEq
  В· calc
      вҲҸ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, P j * proposition_2_2_conjIdeal рқ’ҹ (P j)
          = вҲҸ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f,
              Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) (p j.1 j.2) := by
            refine Finset.prod_congr rfl ?_
            intro j hj
            exact hP_mul j
      _ = вҲҸ b : Fin рқ’ҹ.t, вҲҸ i : Fin рқ’ҹ.f,
            Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) (p b i) := by
            simpa using
              (Fintype.prod_prod_type' (f := fun b i =>
                Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) (p b i)))
      _ = вҲҸ b : Fin рқ’ҹ.t,
            Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) (вҲҸ i : Fin рқ’ҹ.f, p b i) := by
            refine Finset.prod_congr rfl ?_
            intro b hb
            exact (map_prod (Ideal.mapHom (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))
              (fun i : Fin рқ’ҹ.f => p b i) Finset.univ).symm
      _ = вҲҸ b : Fin рқ’ҹ.t,
            Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
              (Ideal.span ({(рқ’ҹ.q b : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L))) := by
            refine Finset.prod_congr rfl ?_
            intro b hb
            rw [hp_prod b]
      _ = Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
            (вҲҸ b : Fin рқ’ҹ.t, Ideal.span ({(рқ’ҹ.q b : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L))) := by
            symm
            exact (map_prod (Ideal.mapHom (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))
              (fun b : Fin рқ’ҹ.t => Ideal.span ({(рқ’ҹ.q b : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L)))
              Finset.univ)
      _ = Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
            (Ideal.span ({(вҲҸ b : Fin рқ’ҹ.t, (рқ’ҹ.q b : рқ“һ рқ’ҹ.L))} : Set (рқ“һ рқ’ҹ.L))) := by
            congr 1
            simpa using
              (Ideal.prod_span_singleton (s := Finset.univ) (I := fun b : Fin рқ’ҹ.t => (рқ’ҹ.q b : рқ“һ рқ’ҹ.L)))
      _ = Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
            (Ideal.span ({(рқ’ҹ.Q : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L))) := by
            simp [AdmissibleDatum.Q]
      _ = proposition_2_2_qIdeal рқ’ҹ := by
            rw [Ideal.map_span]
            simp [proposition_2_2_qIdeal]

open scoped BigOperators in
theorem proposition_2_2_ideal_family_exists (рқ’ҹ : AdmissibleDatum) :
    вҲғ I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K),
      (вҲҖ Оө, I Оө вү  вҠҘ) вҲ§
      (вҲҖ Оө, I Оө * proposition_2_2_conjIdeal рқ’ҹ (I Оө) = proposition_2_2_qIdeal рқ’ҹ) вҲ§
      (вҲҖ {Оө О· : proposition_2_2_choice_type рқ’ҹ},
        I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) =
          I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) вҶ’ Оө = О·) := by
  classical
  let e := NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
  have hconj_conj : вҲҖ I : Ideal (рқ“һ рқ’ҹ.K), proposition_2_2_conjIdeal рқ’ҹ (proposition_2_2_conjIdeal рқ’ҹ I) = I := by
    intro I
    unfold proposition_2_2_conjIdeal
    change Ideal.map (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) (Ideal.map (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) I) = I
    rw [show Ideal.map (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) (Ideal.map (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) I)
          = Ideal.map ((e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)).comp (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K))) I by
          simpa using (Ideal.map_map (I := I) (f := (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K))) (g := (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K))))]
    have hcomp : (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)).comp (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) = RingHom.id _ := by
      ext x
      change (рқ’ҹ.c (рқ’ҹ.c (x : рқ’ҹ.K))) = (x : рқ’ҹ.K)
      simpa using рқ’ҹ.c_sq_eq_id (x : рқ’ҹ.K)
    simp [hcomp]
  obtain вҹЁP, hPnz, hPprime, hPneq, hPneqConj, hPprodвҹ© := proposition_2_2_prime_family рқ’ҹ
  let C : (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Ideal (рқ“һ рқ’ҹ.K) := fun j => proposition_2_2_conjIdeal рқ’ҹ (P j)
  have hCnz : вҲҖ j, C j вү  вҠҘ := by
    intro j h
    exact hPnz j ((Ideal.map_eq_bot_iff_of_injective (show Function.Injective (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K)) from e.injective)).1 (by simpa [C, proposition_2_2_conjIdeal] using h))
  have hCprime : вҲҖ j, (C j).IsPrime := by
    intro j
    dsimp [C, proposition_2_2_conjIdeal]
    let _ : (P j).IsPrime := hPprime j
    simpa using Ideal.map_isPrime_of_equiv e (I := P j)
  let F : proposition_2_2_choice_type рқ’ҹ вҶ’ (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Ideal (рқ“һ рқ’ҹ.K) :=
    fun Оө j => if Оө j then P j else C j
  let G : proposition_2_2_choice_type рқ’ҹ вҶ’ (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Ideal (рқ“һ рқ’ҹ.K) :=
    fun Оө j => if Оө j then C j else P j
  let I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K) :=
    fun Оө => вҲҸ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, F Оө j
  have hconj_prod' (Оө : proposition_2_2_choice_type рқ’ҹ) (s : Finset (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f)) :
      proposition_2_2_conjIdeal рқ’ҹ (вҲҸ j вҲҲ s, F Оө j) = вҲҸ j вҲҲ s, G Оө j := by
    induction s using Finset.induction_on with
    | empty =>
        simpa [proposition_2_2_conjIdeal] using (Ideal.map_top (f := (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K))))
    | @insert a s ha hs =>
        rw [Finset.prod_insert ha, Finset.prod_insert ha]
        rw [show proposition_2_2_conjIdeal рқ’ҹ (F Оө a * вҲҸ j вҲҲ s, F Оө j) = proposition_2_2_conjIdeal рқ’ҹ (F Оө a) * proposition_2_2_conjIdeal рқ’ҹ (вҲҸ j вҲҲ s, F Оө j) by
          simpa [proposition_2_2_conjIdeal] using (Ideal.map_mul (f := (e : (рқ“һ рқ’ҹ.K) вҶ’+* (рқ“һ рқ’ҹ.K))) (F Оө a) (вҲҸ j вҲҲ s, F Оө j))]
        rw [hs]
        by_cases hОөa : Оө a
        В· simp [F, G, C, hОөa]
        В· simp [F, G, C, hОөa, hconj_conj]
  have hconjI (Оө : proposition_2_2_choice_type рқ’ҹ) : proposition_2_2_conjIdeal рқ’ҹ (I Оө) = вҲҸ j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, G Оө j := by
    simpa [I] using hconj_prod' Оө Finset.univ
  have hPmax : вҲҖ j, (P j).IsMaximal := by
    intro j
    exact Ideal.IsPrime.isMaximal (hPprime j) (hPnz j)
  have hCmax : вҲҖ j, (C j).IsMaximal := by
    intro j
    exact Ideal.IsPrime.isMaximal (hCprime j) (hCnz j)
  have hnot_le_Pj (j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) {J : Ideal (рқ“һ рқ’ҹ.K)} (hJmax : J.IsMaximal) (hne : J вү  P j) :
      В¬ J вүӨ P j := by
    intro hle
    have hsup : J вҠ” P j = вҠӨ := Ideal.IsMaximal.coprime_of_ne hJmax (hPmax j) hne
    have hsup' : J вҠ” P j = P j := sup_eq_right.mpr hle
    exact (Ideal.IsMaximal.ne_top (hPmax j)) (hsup'.symm.trans hsup)
  have hprod_not_le (j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) (H : (Fin рқ’ҹ.t Г— Fin рқ’ҹ.f) вҶ’ Ideal (рқ“һ рқ’ҹ.K))
      (hHprime : вҲҖ k, (H k).IsPrime) (hHnz : вҲҖ k, H k вү  вҠҘ) (hHne : вҲҖ k, H k вү  P j) :
      В¬ (вҲҸ k : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, H k) вүӨ P j := by
    intro hle
    rw [show (вҲҸ k : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, H k) = вҲҸ k вҲҲ Finset.univ, H k by rfl] at hle
    rw [Ideal.IsPrime.prod_le (hp := hPprime j)] at hle
    rcases hle with вҹЁk, hk, hkleвҹ©
    exact hnot_le_Pj j (Ideal.IsPrime.isMaximal (hHprime k) (hHnz k)) (hHne k) hkle
  have hneq_true_false (Оө О· : proposition_2_2_choice_type рқ’ҹ) (j : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f)
      (hОө : Оө j = true) (hО· : В¬ О· j = true) :
      I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) вү  I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) := by
    intro hEq
    have hIОө_le : I Оө вүӨ P j := by
      dsimp [I]
      rw [show (вҲҸ k : Fin рқ’ҹ.t Г— Fin рқ’ҹ.f, F Оө k) = вҲҸ k вҲҲ Finset.univ, F Оө k by rfl]
      rw [Ideal.IsPrime.prod_le (hp := hPprime j)]
      refine вҹЁj, by simp, by simp [F, hОө]вҹ©
    have hleft_le : I Оө * proposition_2_2_conjIdeal рқ’ҹ (I О·) вүӨ P j := le_trans Ideal.mul_le_right hIОө_le
    have hright_le : I О· * proposition_2_2_conjIdeal рқ’ҹ (I Оө) вүӨ P j := by simpa [hEq] using hleft_le
    rw [hconjI Оө] at hright_le
    dsimp [I] at hright_le
    rw [Ideal.IsPrime.mul_le (hp := hPprime j)] at hright_le
    rcases hright_le with hО·le | hОөle
    В· have hFО·prime : вҲҖ k, (F О· k).IsPrime := by
        intro k
        by_cases hk : О· k
        В· simp [F, hk, hPprime k]
        В· simp [F, hk, hCprime k]
      have hFО·nz : вҲҖ k, F О· k вү  вҠҘ := by
        intro k
        by_cases hk : О· k
        В· simp [F, hk, hPnz k]
        В· simp [F, hk, hCnz k]
      have hFО·ne : вҲҖ k, F О· k вү  P j := by
        intro k
        by_cases hk : О· k
        В· by_cases hkj : k = j
          В· subst hkj
            simp [hО·] at hk
          В· simpa [F, hk] using hPneq (j := k) (k := j) hkj
        В· simpa [F, hk, C] using (hPneqConj j k).symm
      exact (hprod_not_le j (F О·) hFО·prime hFО·nz hFО·ne) hО·le
    В· have hGОөprime : вҲҖ k, (G Оө k).IsPrime := by
        intro k
        by_cases hk : Оө k
        В· simp [G, hk, hCprime k]
        В· simp [G, hk, hPprime k]
      have hGОөnz : вҲҖ k, G Оө k вү  вҠҘ := by
        intro k
        by_cases hk : Оө k
        В· simp [G, hk, hCnz k]
        В· simp [G, hk, hPnz k]
      have hGОөne : вҲҖ k, G Оө k вү  P j := by
        intro k
        by_cases hk : Оө k
        В· simpa [G, hk, C] using (hPneqConj j k).symm
        В· by_cases hkj : k = j
          В· subst hkj
            simp [hОө] at hk
          В· simpa [G, hk] using hPneq (j := k) (k := j) hkj
      exact (hprod_not_le j (G Оө) hGОөprime hGОөnz hGОөne) hОөle
  refine вҹЁI, ?_, ?_, ?_вҹ©
  В· intro Оө
    dsimp [I]
    simpa using (Finset.prod_ne_zero_iff (s := Finset.univ) (f := F Оө)).2 (by
      intro j hj
      by_cases hОө : Оө j
      В· simp [F, hОө, hPnz j]
      В· simp [F, hОө, hCnz j])
  В· intro Оө
    rw [hconjI Оө]
    dsimp [I]
    rw [вҶҗ Finset.prod_mul_distrib]
    refine Eq.trans ?_ hPprod
    refine Finset.prod_congr rfl ?_
    intro j hj
    by_cases hОө : Оө j
    В· simp [F, G, C, hОө]
    В· simp [F, G, C, hОө, hconj_conj, mul_comm]
  В· intro Оө О· hEq
    ext j
    by_cases hОө : Оө j <;> by_cases hО· : О· j <;> simp [hОө, hО·]
    В· exact False.elim (hneq_true_false Оө О· j hОө hО· hEq)
    В· exact False.elim (hneq_true_false О· Оө j hО· hОө hEq.symm)

theorem proposition_2_2 (рқ’ҹ : AdmissibleDatum) (H : в„қ) (hH : 0 < H)
    (hClass : (NumberField.classNumber рқ’ҹ.K : в„қ) вүӨ H ^ рқ’ҹ.f) :
    вҲғ U : Finset рқ’ҹ.K,
      (U.card : в„қ) вүҘ Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f) вҲ§
      (вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u) := by
  rcases proposition_2_2_ideal_family_exists рқ’ҹ with вҹЁI, hI_nonzero, hI_mul_conj, hI_crossвҹ©
  rcases proposition_2_2_large_class_fiber рқ’ҹ H hH hClass I hI_nonzero with вҹЁC, ОөвӮҖ, hОөвӮҖ, hfiberвҹ©
  rcases proposition_2_2_class_fiber_to_finset рқ’ҹ I hI_nonzero hI_mul_conj (fun {Оө О·} h => hI_cross h) C ОөвӮҖ hОөвӮҖ with вҹЁU, hUcard, hUnormвҹ©
  refine вҹЁU, ?_, hUnormвҹ©
  rw [hUcard]
  exact hfiber

theorem lemma_2_4_E_count_eq_zero_of_N_count_eq_zero (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) (U : Finset рқ’ҹ.K) : рқ’ҹ.N_count a R = 0 вҶ’ рқ’ҹ.E_count a R U = 0 := by
  intro hN
  unfold AdmissibleDatum.N_count at hN
  rw [Finset.card_eq_zero] at hN
  unfold AdmissibleDatum.E_count
  simp [hN]

theorem lemma_2_4_E_count_term_le_N_count (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) (u : рқ’ҹ.K) : ((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card вүӨ рқ’ҹ.N_count a R := by
  simpa [AdmissibleDatum.N_count] using
    (Finset.card_filter_le (s := рқ’ҹ.X_finset a R)
      (p := fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R))

noncomputable def lemma_2_4_FD (рқ’ҹ : AdmissibleDatum) : Set рқ’ҹ.V :=
  ZSpan.fundamentalDomain ((Module.Free.chooseBasis в„Ө рқ’ҹ.Оӣ).ofZLatticeBasis в„қ)

theorem lemma_2_4_N_count_eq_lattice_encard (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) : ({l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R}.encard) = рқ’ҹ.N_count a R := by
  classical
  let S : Set рқ’ҹ.Оӣ := {l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R}
  let f : рқ’ҹ.Оӣ вҶ’ рқ’ҹ.V := fun l => a + (l : рқ’ҹ.V)
  have hbij : Set.BijOn f S (рқ’ҹ.X a R) := by
    refine вҹЁ?_, ?_, ?_вҹ©
    В· intro l hl
      exact вҹЁвҹЁl, rflвҹ©, hlвҹ©
    В· intro lвӮҒ hlвӮҒ lвӮӮ hlвӮӮ h
      exact Subtype.ext (add_left_cancel h)
    В· intro z hz
      rcases hz.1 with вҹЁl, rflвҹ©
      exact вҹЁl, hz.2, rflвҹ©
  have hSX : S.encard = (рқ’ҹ.X a R).encard := by
    refine Set.encard_congr ?_
    exact Equiv.ofBijective (hbij.mapsTo.restrict f S (рқ’ҹ.X a R)) hbij.bijective
  calc
    ({l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R}.encard) = S.encard := by rfl
    _ = (рқ’ҹ.X a R).encard := hSX
    _ = рқ’ҹ.N_count a R := by
      simpa [AdmissibleDatum.X_finset, AdmissibleDatum.N_count] using
        (X_finite рқ’ҹ a R).encard_eq_coe_toFinset_card

theorem lemma_2_4_ball_overlap_volume (R : в„қ) (z : в„Ӯ) (hz : вҖ–zвҖ– = 1) :
    MeasureTheory.volume.real (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R) = overlapArea R :=

  overlapArea_eq_volume R z hz

theorem lemma_2_4_closedBall_overlap_volume (R : в„қ) (z : в„Ӯ) (hz : вҖ–zвҖ– = 1) : MeasureTheory.volume.real (Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R) = overlapArea R := by
  have hsub :
      Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R вҠҶ
        Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R := by
    intro w hw
    exact вҹЁMetric.ball_subset_closedBall hw.1, Metric.ball_subset_closedBall hw.2вҹ©
  have hdiff_sub :
      (Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R) \
          (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R) вҠҶ
        Metric.sphere (0 : в„Ӯ) R вҲӘ Metric.sphere (-z) R := by
    intro w hw
    rcases hw with вҹЁhwA, hwBвҹ©
    rcases hwA with вҹЁhw0, hwzвҹ©
    by_cases h0 : w вҲҲ Metric.ball (0 : в„Ӯ) R
    В· have hz' : w вҲү Metric.ball (-z) R := by
        intro hzB
        exact hwB вҹЁh0, hzBвҹ©
      right
      have hle : dist w (-z) вүӨ R := by
        simpa [Metric.mem_closedBall] using hwz
      have hge : R вүӨ dist w (-z) := by
        simpa [Metric.mem_ball, not_lt] using hz'
      have hEq : dist w (-z) = R := le_antisymm hle hge
      rw [Metric.mem_sphere]
      exact hEq
    В· left
      have hle : dist w (0 : в„Ӯ) вүӨ R := by
        simpa [Metric.mem_closedBall] using hw0
      have hge : R вүӨ dist w (0 : в„Ӯ) := by
        simpa [Metric.mem_ball, not_lt] using h0
      have hEq : dist w (0 : в„Ӯ) = R := le_antisymm hle hge
      rw [Metric.mem_sphere]
      exact hEq
  have hcircles :
      MeasureTheory.volume (Metric.sphere (0 : в„Ӯ) R вҲӘ Metric.sphere (-z) R) = 0 := by
    exact MeasureTheory.measure_union_null
      (MeasureTheory.Measure.addHaar_sphere (Ој := MeasureTheory.volume) (x := (0 : в„Ӯ)) (r := R))
      (MeasureTheory.Measure.addHaar_sphere (Ој := MeasureTheory.volume) (x := (-z)) (r := R))
  have hdiff :
      MeasureTheory.volume
          ((Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R) \
            (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R)) = 0 :=
    MeasureTheory.measure_mono_null hdiff_sub hcircles
  have hmeas :
      MeasureTheory.volume (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R) =
        MeasureTheory.volume (Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R) :=
    MeasureTheory.measure_eq_measure_of_null_diff hsub hdiff
  have hreal :
      MeasureTheory.volume.real (Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-z) R) =
        MeasureTheory.volume.real (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R) := by
    rw [MeasureTheory.measureReal_def, MeasureTheory.measureReal_def, hmeas]
  have hopen :
      MeasureTheory.volume.real (Metric.ball (0 : в„Ӯ) R вҲ© Metric.ball (-z) R) = overlapArea R := by
    exact lemma_2_4_ball_overlap_volume R z hz
  exact hreal.trans hopen

noncomputable def lemma_2_4_gap (рқ’ҹ : AdmissibleDatum) (H R : в„қ) (U : Finset рқ’ҹ.K) (a : рқ’ҹ.V) : в„қ :=
  (рқ’ҹ.E_count a R U : в„қ) -
    Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f / 2) * рқ’ҹ.N_count a R

theorem lemma_2_4_isAddFundamentalDomain (рқ’ҹ : AdmissibleDatum) : MeasureTheory.IsAddFundamentalDomain (вҶҘрқ’ҹ.Оӣ) (lemma_2_4_FD рқ’ҹ) MeasureTheory.volume := by
  simpa [lemma_2_4_FD] using
    (ZLattice.isAddFundamentalDomain (L := рқ’ҹ.Оӣ)
      (b := Module.Free.chooseBasis в„Ө рқ’ҹ.Оӣ) MeasureTheory.volume)

theorem lemma_2_4_exists_gap_positive (рқ’ҹ : AdmissibleDatum) (H R : в„қ) (U : Finset рқ’ҹ.K) (havg : 0 < вЁҚ a in lemma_2_4_FD рқ’ҹ, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume) : вҲғ a вҲҲ lemma_2_4_FD рқ’ҹ, 0 < lemma_2_4_gap рқ’ҹ H R U a := by
  classical
  let F := lemma_2_4_FD рқ’ҹ
  by_contra h
  push Not at h
  have hF_meas : MeasurableSet F := by
    simpa [F, lemma_2_4_FD] using
      (ZSpan.fundamentalDomain_measurableSet
        (b := (Module.Free.chooseBasis в„Ө рқ’ҹ.Оӣ).ofZLatticeBasis в„қ))
  have hОјreal_eq : ZLattice.covolume рқ’ҹ.Оӣ MeasureTheory.volume = MeasureTheory.volume.real F := by
    simpa [F] using
      (ZLattice.covolume_eq_measure_fundamentalDomain (L := рқ’ҹ.Оӣ)
        (Ој := MeasureTheory.volume) (F := F) (lemma_2_4_isAddFundamentalDomain рқ’ҹ))
  have hОјreal_pos : 0 < MeasureTheory.volume.real F := by
    have hcovol : 0 < ZLattice.covolume рқ’ҹ.Оӣ MeasureTheory.volume :=
      ZLattice.covolume_pos (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume)
    rwa [hОјreal_eq] at hcovol
  have hInt_nonpos :
      вҲ« a in F, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume вүӨ 0 := by
    exact MeasureTheory.setIntegral_nonpos hF_meas h
  have hAvg_nonpos :
      (вЁҚ a in F, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume) вүӨ 0 := by
    rw [MeasureTheory.setAverage_eq (Ој := MeasureTheory.volume)]
    have hinv_nonneg : 0 вүӨ (MeasureTheory.volume.real F)вҒ»В№ := by
      positivity
    have hmul :
        (MeasureTheory.volume.real F)вҒ»В№ *
            (вҲ« a in F, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume) вүӨ 0 :=
      mul_nonpos_of_nonneg_of_nonpos hinv_nonneg hInt_nonpos
    simpa [smul_eq_mul] using hmul
  linarith

theorem lemma_2_4_measurableConstVAdd (рқ’ҹ : AdmissibleDatum) : MeasurableConstVAdd (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V := by

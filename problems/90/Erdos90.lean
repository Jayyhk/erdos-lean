          exact (div_lt_iff₀ hpow_pos).1 hm
        simpa [pow_add, Nat.add_assoc, mul_comm, mul_left_comm, mul_assoc] using hm''
      have hfloor : X + 1 ≤ ⌊c ^ (m + n₀ + 1)⌋₊ := by
        have hm_le : ((X + 1 : ℕ) : ℝ) ≤ c ^ (m + n₀ + 1) := by
          exact le_of_lt (by simpa using hm')

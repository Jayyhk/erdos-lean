      _ = Module.finrank в„ҡ (J1 вҠ” J2 : IntermediateField в„ҡ M0) := by rw [вҶҗ hJsup]
      _ = Module.finrank в„ҡ J1 * Module.finrank в„ҡ J2 := hfinSup

    calc
      (вҲ‘ n вҲҲ Finset.filter (fun n : в„• => Real.log n < x) (Finset.Icc 1 N), f n) * Real.exp (-Пғ' * x)
          вүӨ (вҲ‘ n вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f n) * Real.exp (-Пғ' * x) := by
            exact mul_le_mul_of_nonneg_right hsumle hexp_nonneg
      _ = logRescalePartialSum f x * Real.exp (-(Пғ' - 1) * x) := by
            rw [logRescalePartialSum, if_pos (le_of_lt hx)]
            simpa using (hrew x (вҲ‘ n вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f n))
  have hmono :
      вҲ« x in Set.Ioi (0 : в„қ),
          вҲ‘ n вҲҲ Finset.Icc 1 N,
            Set.indicator (Set.Ioi (Real.log n)) (fun x : в„қ => f n * Real.exp (-Пғ' * x)) x
        вүӨ вҲ« x in Set.Ioi (0 : в„қ), logRescalePartialSum f x * Real.exp (-(Пғ' - 1) * x) := by
    exact MeasureTheory.setIntegral_mono_on_ae hsumInt hint measurableSet_Ioi (Filter.Eventually.of_forall hpoint)
  have htermEvalRaw (n : в„•) (hn : n вҲҲ Finset.Icc 1 N) :
      вҲ« x in Set.Ioi (Real.log n), f n * Real.exp (-Пғ' * x)

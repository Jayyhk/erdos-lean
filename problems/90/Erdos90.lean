    intro L₁ L₂ h
    apply Subtype.ext
    apply IntermediateField.restrictScalars_injective (K := ℚ)
    simpa [g] using congrArg (fun x => x.1.1) h
  letI : Fintype T := hT.fintype
  letI : Finite {L : IntermediateField F (AlgebraicClosure F) |
      ∃ _ : NumberField L, |NumberField.discr L| ≤ B} := Finite.of_injective g hg

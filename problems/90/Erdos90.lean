theorem continuous_partialTower_equivariant_zero (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (y : C(A, HomogTower p G 2)) (hy : вҲҖ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G 2).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ b).hom (y a) = y (b вҖў a)) : Continuous (fun q : A Г— G => (towerAsC p G 1 (y (q.2вҒ»В№ вҖў q.1))) (q.2вҒ»В№)) := by

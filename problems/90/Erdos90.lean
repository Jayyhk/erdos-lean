theorem splitCompletely_primes_infinite_via_kummerDedekind (L : Type) [Field L] [NumberField L] [Algebra ℚ L]
    [FiniteDimensional ℚ L] [IsGalois ℚ L] :
    {q : ℕ | q.Prime ∧
      (∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),

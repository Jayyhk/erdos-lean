  classical
  let basisFun : (ОЈ H : OpenNormalSubgroup G, G в§ё H.toSubgroup) вҶ’ Set G :=
    fun p => (QuotientGroup.mk : G вҶ’ G в§ё p.1.toSubgroup) вҒ»В№'
      ({p.2} : Set (G в§ё p.1.toSubgroup))

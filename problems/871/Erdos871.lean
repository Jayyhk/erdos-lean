/-- Elements of B_j are strictly less than elements of B_{j+1} -/
lemma B_stage_separation (j : ℕ) (hj : j ≥ 1) :
    ∀ x ∈ concreteSeq.B_k j, ∀ y ∈ concreteSeq.B_k (j + 1),  x < y := by
  intro x hx y hy
  have hub := concreteSeq.B_k_upper_bound j hj x hx
  have hlb := concreteSeq.B_k_lower_bound (j + 1) (by omega) y hy
  simp only [NathansonSeq.N] at hub hlb
  have hexp := concreteSeq.exponential_growth j hj
  have hn_pos := concreteSeq.n_pos (j - 1)
  simp only [concreteSeq] at hexp hn_pos hub hlb
  have hkey : concreteN j + 2 * concreteN (j - 1) + 1 < 2 * concreteN j + 2 := by nlinarith
  calc x ≤ concreteN j + 2 * concreteN (j - 1) + 1 := hub
    _ < 2 * concreteN j + 2 := hkey
    _ ≤ y := hlb
/-- Count of B elements ≤ enumerateB i is exactly i for i ≥ 1 -/
lemma B_count_le_enumerateB (i : ℕ) (hi : i ≥ 1) :
    ∀ x, inB_concrete x → x ≤ enumerateB i → ∃ k, 1 ≤ k ∧ k ≤ i ∧ enumerateB k = x := by
  intro x hx_in hx_le
  obtain ⟨k, hk_ge, hk_eq⟩ := enumerateB_covers x hx_in
  refine ⟨k, hk_ge, ?_, hk_eq⟩
  by_contra hk_gt
  push_neg at hk_gt
  have hmono : StrictMono enumerateB := strictMono_nat_of_lt_succ enumerateB_mono
  have hlt : enumerateB i < enumerateB k := hmono hk_gt
  rw [hk_eq] at hlt
  omega

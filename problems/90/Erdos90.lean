    rw [show (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ)) + leftTentKernel ((1 / 2 : в„қ) - t)).re * g t) =
        (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re * g t + (leftTentKernel ((1 / 2 : в„қ) - t)).re * g t) by
        funext t; simp [add_mul], intervalIntegral.integral_add hL1 hL2]
  have hsplitP :
      (вҲ« t in (0 : в„қ)..1,

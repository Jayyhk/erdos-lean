        ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 (T.L j))).ncard =
          Module.finrank ℚ (T.L j) :=
  MaxUnramifiedProPGaloisGroup.killed_frobenius_splits_in_tower F p Q T q _hq _hq_splits_F _h_killed

theorem prop38_mkAdmissibleDatum (L : Type) [Field L] [CharZero L] [NumberField L] [IsTotallyReal L]
    (t : ℕ) (_ht : 0 < t) (q : Fin t → ℕ)
    (_hq_prime : ∀ b, (q b).Prime)
    (_hq_inj : Function.Injective q)
    (_hq_mod4 : ∀ b, q b % 4 = 1)
    (_hq_splits : ∀ b,
      (∀ 𝔭 ∈ (Ideal.span {((q b : ℤ))} : Ideal ℤ).primesOver (𝓞 L),
          Ideal.ramificationIdx (Ideal.span {((q b : ℤ))} : Ideal ℤ) 𝔭 = 1 ∧
          Ideal.inertiaDeg (Ideal.span {((q b : ℤ))} : Ideal ℤ) 𝔭 = 1) ∧
        ((Ideal.span {((q b : ℤ))} : Ideal ℤ).primesOver (𝓞 L)).ncard =
          Module.finrank ℚ L) :
    ∃ 𝒟 : AdmissibleDatum,
      Nonempty (𝒟.L ≃ₐ[ℚ] L) ∧
      ∃ ht_eq : 𝒟.t = t,
        ∀ b : Fin t, 𝒟.q (Fin.cast ht_eq.symm b) = q b := by
  classical
  let K := CyclotomicField 4 L
  haveI : IsCyclotomicExtension ({4} : Set ℕ) L K := by
    dsimp [K]
    exact CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := 4) (K := L)
  have hmem4 : 4 ∈ ({4} : Set ℕ) := by simp
  obtain ⟨iK, hiK_prim⟩ :=
    IsCyclotomicExtension.exists_isPrimitiveRoot L K hmem4 (by decide : (4 : ℕ) ≠ 0)
  have hiK_sq : iK * iK = (-1 : K) := by
    have hsq_prim : IsPrimitiveRoot (iK ^ 2) 2 :=
      hiK_prim.pow_of_dvd (by decide : (2 : ℕ) ≠ 0) (by decide : 2 ∣ 4)
    have hsq : iK ^ 2 = (-1 : K) := IsPrimitiveRoot.eq_neg_one_of_two_right hsq_prim
    simpa [pow_two] using hsq
  haveI : Algebra.IsIntegral L K := Algebra.IsIntegral.of_finite L K
  have hiK_int : IsIntegral L iK := Algebra.IsIntegral.isIntegral iK
  have hiK_not_range : iK ∉ (algebraMap L K).range := by
    rintro ⟨a, ha⟩
    have ha2 : a * a = (-1 : L) := by
      have h : (algebraMap L K) (a * a) = (algebraMap L K) (-1) := by
        rw [map_mul, ha, hiK_sq, map_neg, map_one]
      exact (algebraMap L K).injective h
    obtain ⟨φ⟩ := (inferInstance : Nonempty (L →+* ℂ))
    have hφ : NumberField.ComplexEmbedding.IsReal φ :=
      NumberField.IsTotallyReal.complexEmbedding_isReal φ
    let ψ : L →+* ℝ := hφ.embedding
    have hψ : ψ a * ψ a = -1 := by
      have h := congrArg ψ ha2
      simpa [map_mul, map_neg, map_one] using h
    have hnn : 0 ≤ ψ a * ψ a := mul_self_nonneg _
    linarith
  have hdeg_ge2 : 2 ≤ (minpoly L iK).natDegree := by
    exact (minpoly.two_le_natDegree_iff hiK_int).2 hiK_not_range
  have hroot : Polynomial.aeval iK (Polynomial.X ^ 2 + 1 : Polynomial L) = 0 := by
    simp [Polynomial.aeval_def, hiK_sq, pow_two]
  have hdiv : minpoly L iK ∣ (Polynomial.X ^ 2 + 1 : Polynomial L) :=
    minpoly.dvd L iK hroot
  have hdeg_poly : (Polynomial.X ^ 2 + (1 : Polynomial L)).natDegree = 2 := by
    simpa using (Polynomial.natDegree_X_pow_add_C (R := L) (n := 2) (r := (1 : L)))
  have hdeg_le2 : (minpoly L iK).natDegree ≤ 2 := by
    have h := Polynomial.natDegree_le_of_dvd hdiv
      (Polynomial.X_pow_add_C_ne_zero (R := L) (n := 2) (by decide : 0 < (2 : ℕ)) (1 : L))
    rw [hdeg_poly] at h
    exact h
  have hdeg_eq2 : (minpoly L iK).natDegree = 2 := by
    omega
  have hgen : IntermediateField.adjoin L ({iK} : Set K) = ⊤ := by
    simpa using (IsCyclotomicExtension.adjoin_primitive_root_eq_top (A := L) (B := K) (n := 4) hiK_prim)
  have hfinrank : Module.finrank L K = 2 := by
    have h := (Field.primitive_element_iff_minpoly_natDegree_eq (F := L) (E := K) iK).1 hgen
    rw [← h]
    exact hdeg_eq2
  haveI : Module.Free L K := inferInstance
  haveI : Algebra.IsQuadraticExtension L K := { finrank_eq_two' := hfinrank }
  refine ⟨{
    L := L
    K := K
    i_K := iK
    i_K_sq := hiK_sq
    t := t
    t_pos := _ht
    q := q
    q_prime := _hq_prime
    q_inj := _hq_inj
    q_mod4 := _hq_mod4
    q_splits_in_L := _hq_splits
  }, ?_⟩
  constructor
  · exact ⟨1⟩
  · refine ⟨rfl, ?_⟩
    intro b
    rfl


noncomputable def cohomologyIso (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) :
    _root_.Erdos90.InhomogClassAPI.Cohomology p G n ≃ₗ[ZMod p] ((continuousCohomology (ZMod p) G n).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))) : Type) := by
  classical
  let F := (CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p)))
  let Kinh : CochainComplex (ModuleCat (ZMod p)) ℕ :=
    _root_.Erdos90.InhomogContsCochains.complex p G
  let KhomTop : CochainComplex (TopModuleCat (ZMod p)) ℕ :=
    (ContinuousCohomology.homogeneousCochains (ZMod p) G).obj
      (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))
  let Khom : CochainComplex (ModuleCat (ZMod p)) ℕ :=
    (F.mapHomologicalComplex _).obj KhomTop
  let e₁ : _root_.Erdos90.InhomogClassAPI.Cohomology p G n ≃ₗ[ZMod p] (Kinh.homology n : Type) :=
    inhomogCohomology_complexHomologyEquiv p G n
  let ecomp : ∀ i, Kinh.X i ≅ Khom.X i := fun i =>
    (LinearEquiv.ofLinear (inhomogToHomog p G i) (homogToInhomog p G i)
      (inhomogToHomog_homogToInhomog p G i)
      (homogToInhomog_inhomogToHomog p G i)).toModuleIso
  let eK : Kinh ≅ Khom :=
    HomologicalComplex.Hom.isoOfComponents ecomp (by
      intro i j hij
      obtain rfl : i + 1 = j := by simpa using hij
      dsimp [ecomp]
      apply ModuleCat.hom_ext
      change (((KhomTop.d i (i + 1)).hom.toLinearMap).comp (inhomogToHomog p G i) =
        (inhomogToHomog p G (i + 1)).comp ((Kinh.d i (i + 1)).hom))
      simpa [KhomTop, Kinh, homogObjDiff, _root_.Erdos90.InhomogContsCochains.complex] using inhomogToHomog_comm_d p G i)
  let e₂ : (Kinh.homology n : Type) ≃ₗ[ZMod p] (Khom.homology n : Type) :=
    (HomologicalComplex.homologyMapIso (K := Kinh) (L := Khom) eK n).toLinearEquiv
  let e₃ : (Khom.homology n : Type) ≃ₗ[ZMod p]
      (((continuousCohomology (ZMod p) G n).obj
        (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))) : Type)) :=
    (((HomologicalComplex.sc (K := KhomTop) n).mapHomologyIso F).toLinearEquiv)
  exact e₁.trans (e₂.trans e₃)

theorem cohomologyIso_exists (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) :
    Nonempty (_root_.Erdos90.InhomogClassAPI.Cohomology p G n ≃ₗ[ZMod p] ((continuousCohomology (ZMod p) G n).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))) : Type)) :=
  ⟨cohomologyIso p G n⟩


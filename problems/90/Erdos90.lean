    have hnf : normalizedFactors x.2.1 = normalizedFactors y.2.1 := by
      apply (Multiset.ext).2
      intro P
      by_cases hP : P вҲҲ s
      В· have := congrArg (fun ОҪ => ОҪ вҹЁP, hPвҹ©) hxy
        simpa [encode] using this
      В· have hx0 : Multiset.count P (normalizedFactors x.2.1) = 0 := by
          apply Multiset.count_eq_zero_of_notMem
          intro hxP
          exact hP (hencode_support x hxP)
        have hy0 : Multiset.count P (normalizedFactors y.2.1) = 0 := by
          apply Multiset.count_eq_zero_of_notMem
          intro hyP
          exact hP (hencode_support y hyP)
        rw [hx0, hy0]
    calc
      x.2.1 = (normalizedFactors x.2.1).prod := (prod_normalizedFactors_eq_self (hnot_bot x)).symm
      _ = (normalizedFactors y.2.1).prod := by simp [hnf]
      _ = y.2.1 := prod_normalizedFactors_eq_self (hnot_bot y)
  have hcomp : Summable (g вҲҳ encode) := by
    exact hg.comp_injective hencode_inj
  have hpoint : вҲҖ x : Sigma ОІ, weight x вүӨ g (encode x) := by
    intro x
    let m : Multiset (Ideal (рқ“һ K)) := normalizedFactors x.2.1
    have hs : m.toFinset вҠҶ s := by
      intro P hP
      exact hencode_support x (by simpa [m] using hP)
    have hnorm_prod : (Ideal.absNorm x.2.1 : в„қ) = вҲҸ P вҲҲ s, (Ideal.absNorm P : в„қ) ^ m.count P := by
      calc
        (Ideal.absNorm x.2.1 : в„қ) = (Ideal.absNorm m.prod : в„қ) := by
          simpa [m] using congrArg (fun I : Ideal (рқ“һ K) => (Ideal.absNorm I : в„қ)) ((prod_normalizedFactors_eq_self (hnot_bot x)).symm)
        _ = вҲҸ P вҲҲ s, (Ideal.absNorm P : в„қ) ^ m.count P := by
          rw [show m.prod = вҲҸ P вҲҲ s, P ^ m.count P by exact Finset.prod_multiset_count_of_subset m s hs]
          simp
    have hprod_le : вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P вүӨ (Ideal.absNorm x.2.1 : в„қ) := by
      rw [hnorm_prod]
      refine Finset.prod_le_prod ?_ ?_
      В· intro P hP
        positivity
      В· intro P hP
        exact pow_le_pow_leftвӮҖ (by positivity) (hnorm_ge_p hP) _
    have h1 :
        вҲҸ P : s, (((p : в„қ) ^ (2 : в„•)) ^ encode x P) = вҲҸ P вҲҲ s.attach, (((p : в„қ) ^ (2 : в„•)) ^ m.count P.1) := by
      simp [encode, m]
    have hmid :
        вҲҸ P вҲҲ s.attach, (((p : в„қ) ^ (2 : в„•)) ^ m.count P.1) = вҲҸ P вҲҲ s.attach, (((p : в„қ) ^ m.count P.1) ^ (2 : в„•)) := by
      refine Finset.prod_congr rfl ?_
      intro P hP
      rw [вҶҗ pow_mul, вҶҗ pow_mul, Nat.mul_comm]
    have h2 :
        (вҲҸ P вҲҲ s.attach, ((p : в„қ) ^ m.count P.1)) ^ (2 : в„•) = (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) := by
      have hattach : вҲҸ P вҲҲ s.attach, ((p : в„қ) ^ m.count P.1) = вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P := by
        simpa using (Finset.prod_attach (s := s) (f := fun P => ((p : в„қ) ^ m.count P)))

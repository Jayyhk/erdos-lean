  have hprod_r' : вҲҸ i, r' i = (вҲҸ i, r i) * s := by
    simp [r']
  have hdiscrM0' :
      (NumberField.discr M0).natAbs = (вҲҸ i, r' i) ^ (2 * 3 ^ ((k + 2) - 1)) := by
    calc
      (NumberField.discr M0).natAbs = ((вҲҸ i, r i) * s) ^ (2 * 3 ^ (k + 1)) := hdiscrM0
      _ = (вҲҸ i, r' i) ^ (2 * 3 ^ ((k + 2) - 1)) := by

      exact Filter.eventually_atTop.2 ⟨1, by intro n hn; exact hn⟩
    have h_both : ∀ᶠ X : ℕ in Filter.atTop,
        c * X ≤ ∑ k ∈ Finset.range X, f k := by
      filter_upwards [h_event, h_one] with X hX h1
      have hX0nat : 0 < X := by
        exact lt_of_lt_of_le (show (0 : ℕ) < 1 by decide) h1
      have hX0 : (0 : ℝ) < (X : ℝ) := by
        exact_mod_cast hX0nat
      have hmul : c * (X : ℝ) < ((∑ k ∈ Finset.range X, f k) / (X : ℝ)) * (X : ℝ) := by
        exact mul_lt_mul_of_pos_right hX hX0
      have hXne : (X : ℝ) ≠ 0 := ne_of_gt hX0
      have hcancel :
          ((∑ k ∈ Finset.range X, f k) / (X : ℝ)) * (X : ℝ) =
            ∑ k ∈ Finset.range X, f k := by
        rw [div_eq_mul_inv, mul_assoc, inv_mul_cancel₀ hXne, mul_one]
      have hle : c * (X : ℝ) ≤ ∑ k ∈ Finset.range X, f k := by
        rw [← hcancel]
        exact le_of_lt hmul
      simpa using hle
    rcases Filter.eventually_atTop.1 h_both with ⟨X₀, hX₀⟩
    refine ⟨X₀, ?_⟩
    intro X hX
    exact hX₀ X hX

theorem integrable_fourier_of_contDiff_hasCompactSupport (f : ℝ → ℂ) :
    ContDiff ℝ (⊤ : ℕ∞) f → HasCompactSupport f →
    MeasureTheory.Integrable (FourierTransform.fourier f) := by
  intro hf hsupp
  have h_int_iter : ∀ n : ℕ, MeasureTheory.Integrable (iteratedFDeriv ℝ n f) := by
    intro n
    refine Continuous.integrable_of_hasCompactSupport ?_ (hsupp.iteratedFDeriv n)
    let hfn : ContDiff ℝ n f := (contDiff_iff_forall_nat_le.1 hf) n le_top
    exact hfn.continuous_iteratedFDeriv'
  have hf2 : ContDiff ℝ 2 f := (contDiff_iff_forall_nat_le.1 hf) 2 le_top
  have h_int_pow2 : ∀ (k n : ℕ), (k : ℕ∞) ≤ (0 : ℕ∞) → (n : ℕ∞) ≤ (2 : ℕ∞) →
      MeasureTheory.Integrable (fun v : ℝ ↦ ‖v‖ ^ k * ‖iteratedFDeriv ℝ n f v‖) := by
    intro k n hk hn
    have hk' : k ≤ 0 := by exact_mod_cast hk
    have hk0 : k = 0 := Nat.eq_zero_of_le_zero hk'
    subst hk0
    simpa [pow_zero] using (h_int_iter n).norm
  let C0 : ℝ :=
    (2 * Real.pi) ^ (0 : ℕ) * (2 * (0 : ℕ) + 2) ^ (0 : ℕ) *
      ∑ p ∈ Finset.range ((0 : ℕ) + 1) ×ˢ Finset.range ((0 : ℕ) + 1),
        ∫ v : ℝ, ‖v‖ ^ p.1 * ‖iteratedFDeriv ℝ p.2 f v‖
  let C2 : ℝ :=
    (2 * Real.pi) ^ (0 : ℕ) * (2 * (0 : ℕ) + 2) ^ (2 : ℕ) *
      ∑ p ∈ Finset.range ((0 : ℕ) + 1) ×ˢ Finset.range ((2 : ℕ) + 1),
        ∫ v : ℝ, ‖v‖ ^ p.1 * ‖iteratedFDeriv ℝ p.2 f v‖
  have h0 : ∀ x : ℝ, ‖FourierTransform.fourier f x‖ ≤ C0 := by
    intro x
    simpa [C0, pow_zero, norm_iteratedFDeriv_zero] using
      (Real.pow_mul_norm_iteratedFDeriv_fourier_le (f := f) (K := 0) (N := 2) hf2 h_int_pow2
        (k := 0) (n := 0) (hk := by simp) (hn := by simp) x)
  have h2 : ∀ x : ℝ, ‖x‖ ^ 2 * ‖FourierTransform.fourier f x‖ ≤ C2 := by
    intro x
    simpa [C2, norm_iteratedFDeriv_zero] using
      (Real.pow_mul_norm_iteratedFDeriv_fourier_le (f := f) (K := 0) (N := 2) hf2 h_int_pow2
        (k := 0) (n := 2) (hk := by simp) (hn := by simp) x)
  have hfourier_cont : Continuous (FourierTransform.fourier f) := by
    have hfourier_cd : ContDiff ℝ 0 (FourierTransform.fourier f) := by
      simpa using (Real.contDiff_fourier (f := f) (N := 0) (by
        intro n hn
        have hn' : n ≤ 0 := by exact_mod_cast hn
        have hn0 : n = 0 := Nat.eq_zero_of_le_zero hn'
        subst hn0
        simpa [pow_zero] using ((hf.continuous.integrable_of_hasCompactSupport hsupp).norm)))
    exact hfourier_cd.continuous
  have h_weight : MeasureTheory.Integrable (fun x : ℝ ↦ ((1 : ℝ) + ‖x‖ ^ 2)⁻¹) := by
    have hdim : (Module.finrank ℝ ℝ : ℝ) < 2 := by
      norm_num [Module.finrank_self]
    simpa [Real.rpow_neg_one] using
      (integrable_rpow_neg_one_add_norm_sq (E := ℝ) (μ := MeasureTheory.volume) (r := 2) hdim)
  refine (h_weight.const_mul (C0 + C2)).mono' hfourier_cont.aestronglyMeasurable ?_
  filter_upwards with x
  have hsum : ((1 : ℝ) + ‖x‖ ^ 2) * ‖FourierTransform.fourier f x‖ ≤ C0 + C2 := by
    calc
      ((1 : ℝ) + ‖x‖ ^ 2) * ‖FourierTransform.fourier f x‖ =
          ‖FourierTransform.fourier f x‖ + ‖x‖ ^ 2 * ‖FourierTransform.fourier f x‖ := by ring
      _ ≤ C0 + C2 := by
        gcongr
        · exact h0 x
        · exact h2 x
  have hpos : 0 < (1 : ℝ) + ‖x‖ ^ 2 := by
    positivity
  have hdiv : ‖FourierTransform.fourier f x‖ ≤ (C0 + C2) / ((1 : ℝ) + ‖x‖ ^ 2) := by
    exact (le_div_iff₀' hpos).2 hsum
  simpa [div_eq_mul_inv] using hdiv

theorem integrable_translation_l1_tendsto_zero (f : ℝ → ℂ) :
  MeasureTheory.Integrable f →
  Filter.Tendsto
    (fun h : ℝ => ∫ u : ℝ, ‖f (u - h) - f u‖)
    (nhds 0) (nhds 0) := by
  intro hf
  let tr : ℝ → C(ℝ, ℝ) := fun h =>
    { toFun := fun u => u - h
      continuous_toFun := continuous_id.sub continuous_const }
  have htr_cont : Continuous tr := by
    refine ContinuousMap.continuous_of_continuous_uncurry tr ?_
    simpa [tr, Function.uncurry] using (continuous_snd.sub continuous_fst)
  have hgm : ∀ h : ℝ, MeasureTheory.MeasurePreserving (tr h) MeasureTheory.volume MeasureTheory.volume := by
    intro h
    simpa [tr] using MeasureTheory.measurePreserving_sub_right MeasureTheory.volume h
  let F : ℝ → MeasureTheory.Lp ℂ 1 MeasureTheory.volume := fun h =>
    MeasureTheory.Lp.compMeasurePreserving (tr h) (hgm h) (hf.toL1 f)
  have hp1 : (1 : ENNReal) ≠ ⊤ := by simp
  have hFcont : Continuous F := by
    simpa [F] using (continuous_const.compMeasurePreservingLp htr_cont hgm hp1)
  have hF0 : F 0 = hf.toL1 f := by
    apply MeasureTheory.Lp.ext
    have htr0 : tr 0 = ContinuousMap.id ℝ := by
      ext u
      simp [tr]
    change ((MeasureTheory.Lp.compMeasurePreserving (tr 0) (hgm 0) (hf.toL1 f) :
      MeasureTheory.Lp ℂ 1 MeasureTheory.volume) : ℝ → ℂ) =ᵐ[MeasureTheory.volume] hf.toL1 f
    simp [htr0]
  have hnorm : Filter.Tendsto (fun h => ‖F h - hf.toL1 f‖) (nhds 0) (nhds 0) := by
    have hcont_sub : ContinuousAt (fun h => F h - hf.toL1 f) 0 :=
      hFcont.continuousAt.sub continuousAt_const
    simpa [hF0] using hcont_sub.norm.tendsto
  have hpoint :
      (fun h : ℝ => ∫ u : ℝ, ‖f (u - h) - f u‖) = fun h => ‖F h - hf.toL1 f‖ := by
    funext h
    have hFae : (F h : ℝ → ℂ) =ᵐ[MeasureTheory.volume] fun u => f (u - h) := by
      refine (MeasureTheory.Lp.coeFn_compMeasurePreserving (hf.toL1 f) (hgm h)).trans ?_
      simpa [Function.comp, tr] using
        (MeasureTheory.Measure.QuasiMeasurePreserving.ae_eq
          (MeasureTheory.MeasurePreserving.quasiMeasurePreserving (hgm h))
          (MeasureTheory.Integrable.coeFn_toL1 hf))
    have hsub : ((F h - hf.toL1 f : MeasureTheory.Lp ℂ 1 MeasureTheory.volume) : ℝ → ℂ) =ᵐ[MeasureTheory.volume]
        fun u => f (u - h) - f u := by
      filter_upwards [MeasureTheory.Lp.coeFn_sub (F h) (hf.toL1 f), hFae,
        MeasureTheory.Integrable.coeFn_toL1 hf] with u hu_sub huF huf
      calc
        ((F h - hf.toL1 f : MeasureTheory.Lp ℂ 1 MeasureTheory.volume) : ℝ → ℂ) u
            = (F h : ℝ → ℂ) u - (hf.toL1 f : ℝ → ℂ) u := by
              simpa using hu_sub
        _ = f (u - h) - f u := by rw [huF, huf]
    calc
      ∫ u : ℝ, ‖f (u - h) - f u‖ = ∫ u : ℝ, ‖(F h - hf.toL1 f : MeasureTheory.Lp ℂ 1 MeasureTheory.volume) u‖ := by
        refine MeasureTheory.integral_congr_ae ?_
        filter_upwards [hsub] with u hu
        simpa using (congrArg norm hu).symm
      _ = ‖F h - hf.toL1 f‖ := by
        symm
        exact MeasureTheory.L1.norm_eq_integral_norm (F h - hf.toL1 f)
  simpa [hpoint] using hnorm

theorem integrable_mass_one_scaled_convolution_l1_tendsto (ρ f : ℝ → ℂ) :
  MeasureTheory.Integrable ρ →
  (∫ u : ℝ, ρ u = 1) →
  MeasureTheory.Integrable f →
  ∀ ε : ℝ, 0 < ε →
    ∃ R : ℝ, 0 < R ∧
      ∫ u : ℝ, ‖f u - (∫ t : ℝ, (((R : ℝ) : ℂ) * ρ (R * t)) * f (u - t))‖ ≤ ε := by
  intro hρ hρmass hf ε hε
  let d : ℝ → ℝ := fun h => ∫ u : ℝ, ‖f u - f (u - h)‖
  let C : ℝ := ∫ u : ℝ, ‖f u‖
  let M : ℝ := ∫ s : ℝ, ‖ρ s‖
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact MeasureTheory.integral_nonneg_of_ae (Filter.Eventually.of_forall fun u => norm_nonneg _)
  have hM_nonneg : 0 ≤ M := by
    dsimp [M]
    exact MeasureTheory.integral_nonneg_of_ae (Filter.Eventually.of_forall fun u => norm_nonneg _)
  have hd_le : ∀ h : ℝ, d h ≤ 2 * C := by
    intro h
    have hf_sub : MeasureTheory.Integrable (fun u : ℝ => f u - f (u - h)) := hf.sub (hf.comp_sub_right h)
    have hf_norm_add : MeasureTheory.Integrable (fun u : ℝ => ‖f u‖ + ‖f (u - h)‖) := hf.norm.add (hf.comp_sub_right h).norm
    calc
      d h = ∫ u : ℝ, ‖f u - f (u - h)‖ := by rfl
      _ ≤ ∫ u : ℝ, (‖f u‖ + ‖f (u - h)‖) := by
        apply MeasureTheory.integral_mono hf_sub.norm hf_norm_add
        intro u
        exact norm_sub_le _ _
      _ = (∫ u : ℝ, ‖f u‖) + ∫ u : ℝ, ‖f (u - h)‖ := by
        rw [MeasureTheory.integral_add hf.norm ((hf.comp_sub_right h).norm)]
      _ = C + C := by
        dsimp [C]
        rw [MeasureTheory.integral_sub_right_eq_self (f := fun u : ℝ => ‖f u‖) (μ := MeasureTheory.volume) (g := h)]
      _ = 2 * C := by ring
  have hd_eq : d = fun h : ℝ => ∫ u : ℝ, ‖f (u - h) - f u‖ := by
    funext h
    dsimp [d]
    refine MeasureTheory.integral_congr_ae ?_
    filter_upwards with u
    rw [norm_sub_rev]
  have hd_tendsto : Filter.Tendsto d (nhds 0) (nhds 0) := by
    rw [hd_eq]
    exact integrable_translation_l1_tendsto_zero f hf
  have hρnorm : MeasureTheory.Integrable (fun x : ℝ => ‖ρ x‖) := hρ.norm
  let tail : ℕ → Set ℝ := fun n => {x : ℝ | (n : ℝ) ≤ |x|}
  have htail_meas : ∀ n, MeasurableSet (tail n) := by
    intro n
    dsimp [tail]
    exact measurableSet_le measurable_const measurable_abs
  have htail_anti : Antitone tail := by
    intro m n hmn x hx
    dsimp [tail] at hx ⊢
    exact le_trans (by exact_mod_cast hmn) hx
  have htail_inter : (⋂ n : ℕ, tail n) = (∅ : Set ℝ) := by
    ext x
    constructor
    · intro hx
      exfalso
      have hxall : ∀ n : ℕ, (n : ℝ) ≤ |x| := by
        intro n
        have hxn : x ∈ tail n := Set.mem_iInter.mp hx n
        simpa [tail] using hxn
      obtain ⟨n, hn⟩ := exists_nat_gt |x|
      exact not_le_of_gt hn (hxall n)
    · intro hx
      exact False.elim hx
  have htail_tendsto : Filter.Tendsto (fun n : ℕ => ∫ x in tail n, ‖ρ x‖) Filter.atTop (nhds 0) := by
    simpa [htail_inter] using
      (Antitone.tendsto_setIntegral (f := fun x : ℝ => ‖ρ x‖) (s := tail) htail_meas htail_anti hρnorm.integrableOn)
  let α : ℝ := ε / (4 * (C + 1))
  have hαpos : 0 < α := by
    dsimp [α]
    have : 0 < 4 * (C + 1) := by nlinarith
    exact div_pos hε this
  have htail_event : ∀ᶠ n : ℕ in Filter.atTop, ∫ x in tail n, ‖ρ x‖ < α := by
    exact htail_tendsto.eventually (gt_mem_nhds hαpos)
  rcases Filter.eventually_atTop.1 htail_event with ⟨N, hN⟩
  let η : ℝ := ε / (2 * (M + 1))
  have hηpos : 0 < η := by
    dsimp [η]
    have : 0 < 2 * (M + 1) := by nlinarith
    exact div_pos hε this
  have hηset : {h : ℝ | d h < η} ∈ nhds 0 := hd_tendsto.eventually (gt_mem_nhds hηpos)
  rcases Metric.mem_nhds_iff.mp hηset with ⟨δ, hδpos, hδ⟩
  have hδ' : ∀ h : ℝ, |h| < δ → d h < η := by
    intro h hh
    exact hδ (by simpa [Metric.ball, Real.dist_eq] using hh)
  let R : ℝ := max ((N : ℝ) / δ) 1
  have hRpos : 0 < R := by
    dsimp [R]
    positivity
  have hRne : R ≠ 0 := by linarith
  let G : ℝ → ℝ := fun s => ‖ρ s‖ * d (s / R)
  let k : ℝ → ℂ := fun t => (((R : ℝ) : ℂ) * ρ (R * t))
  let A : ℝ × ℝ → ℂ := fun p => k p.2 * f p.1
  let B : ℝ × ℝ → ℂ := fun p => k p.2 * f (p.1 - p.2)
  have hk_int : MeasureTheory.Integrable k := by
    simpa [k, R] using (hρ.comp_mul_left' (g := ρ) (hR := hRne)).const_mul (((R : ℝ) : ℂ))
  have hmassR : ∫ t : ℝ, k t = 1 := by
    calc
      ∫ t : ℝ, k t = (((R : ℝ) : ℂ) * ∫ t : ℝ, ρ (R * t)) := by
        simpa [k] using (MeasureTheory.integral_const_mul (((R : ℝ) : ℂ)) (fun t : ℝ => ρ (R * t)))
      _ = (((R : ℝ) : ℂ) * (|R⁻¹| • ∫ t : ℝ, ρ t)) := by
        rw [MeasureTheory.Measure.integral_comp_mul_left (g := ρ) (a := R)]
        rfl
      _ = (((R : ℝ) : ℂ) * ((((|R⁻¹| : ℝ) : ℂ)) * ∫ t : ℝ, ρ t)) := by
        simp [smul_eq_mul]
      _ = 1 := by
        rw [hρmass]
        have hRabs : |R⁻¹| = R⁻¹ := abs_of_pos (inv_pos.mpr hRpos)
        rw [hRabs]
        norm_num [hRne]
  have hA_int : MeasureTheory.Integrable A := by
    simpa [A, k, mul_comm] using (hf.mul_prod hk_int)
  have hB_int : MeasureTheory.Integrable B := by
    simpa [B, k] using (hk_int.convolution_integrand (L := ContinuousLinearMap.mul ℂ ℂ) hf)
  have hAB_int : MeasureTheory.Integrable (fun p : ℝ × ℝ => A p - B p) := hA_int.sub hB_int
  have hA_eval : ∀ u : ℝ, ∫ t : ℝ, A (u, t) = f u := by
    intro u
    calc
      ∫ t : ℝ, A (u, t) = ∫ t : ℝ, k t * f u := by simp [A]
      _ = (∫ t : ℝ, k t) * f u := by
        simpa using (MeasureTheory.integral_mul_const (r := f u) (f := k))
      _ = f u := by rw [hmassR, one_mul]
  have hmain :
      ∫ u : ℝ, ‖f u - (∫ t : ℝ, k t * f (u - t))‖
        ≤ ∫ u : ℝ, ∫ t : ℝ, ‖A (u, t) - B (u, t)‖ := by
    calc
      ∫ u : ℝ, ‖f u - (∫ t : ℝ, k t * f (u - t))‖
          = ∫ u : ℝ, ‖(∫ t : ℝ, A (u, t)) - ∫ t : ℝ, B (u, t)‖ := by
              refine MeasureTheory.integral_congr_ae ?_
              filter_upwards with u
              rw [hA_eval]
      _ = ∫ u : ℝ, ‖∫ t : ℝ, A (u, t) - B (u, t)‖ := by
            simpa using (MeasureTheory.integral_fn_integral_sub (F := norm) hA_int hB_int).symm
      _ ≤ ∫ u : ℝ, ∫ t : ℝ, ‖A (u, t) - B (u, t)‖ := by
            apply MeasureTheory.integral_mono
            · exact hAB_int.integral_prod_left.norm
            · exact hAB_int.integral_norm_prod_left
            · intro u
              exact MeasureTheory.norm_integral_le_integral_norm (fun t : ℝ => A (u, t) - B (u, t))
  have hkD_int : MeasureTheory.Integrable (fun t : ℝ => ‖k t‖ * d t) := by
    refine (hAB_int.norm.integral_prod_right).congr ?_
    filter_upwards with t
    calc
      ∫ u : ℝ, ‖A (u, t) - B (u, t)‖ = ∫ u : ℝ, ‖k t‖ * ‖f u - f (u - t)‖ := by
        refine MeasureTheory.integral_congr_ae ?_
        filter_upwards with u
        dsimp [A, B]
        rw [← mul_sub, norm_mul]
      _ = ‖k t‖ * ∫ u : ℝ, ‖f u - f (u - t)‖ := by
        simpa using (MeasureTheory.integral_const_mul ‖k t‖ (fun u : ℝ => ‖f u - f (u - t)‖))
      _ = ‖k t‖ * d t := by rfl
  have hkD_int' : MeasureTheory.Integrable (fun t : ℝ => R * ((fun s : ℝ => ‖ρ s‖ * d (s / R)) (R * t))) := by
    refine hkD_int.congr ?_
    filter_upwards with t
    simp [k, hRpos.le, norm_mul, mul_assoc, mul_left_comm, mul_comm, d, hRne, div_eq_mul_inv]
  have hRunit : IsUnit R := isUnit_iff_ne_zero.mpr hRne
  have hcomp_int : MeasureTheory.Integrable (fun t : ℝ => (fun s : ℝ => ‖ρ s‖ * d (s / R)) (R * t)) := by
    exact (MeasureTheory.integrable_const_mul_iff (c := R) hRunit (fun t : ℝ => (fun s : ℝ => ‖ρ s‖ * d (s / R)) (R * t))).1 hkD_int'
  have hG_int : MeasureTheory.Integrable G := by
    dsimp [G]
    exact (MeasureTheory.integrable_comp_mul_left_iff (g := fun s : ℝ => ‖ρ s‖ * d (s / R)) (hR := hRne)).1 hcomp_int
  have hbound : ∫ u : ℝ, ‖f u - (∫ t : ℝ, k t * f (u - t))‖ ≤ ∫ s : ℝ, G s := by
    refine hmain.trans_eq ?_
    calc
      ∫ u : ℝ, ∫ t : ℝ, ‖A (u, t) - B (u, t)‖ = ∫ t : ℝ, ∫ u : ℝ, ‖A (u, t) - B (u, t)‖ := by
        simpa using (MeasureTheory.integral_integral_swap (f := fun u t : ℝ => ‖A (u, t) - B (u, t)‖) hAB_int.norm)
      _ = ∫ t : ℝ, ‖k t‖ * d t := by
        refine MeasureTheory.integral_congr_ae ?_
        filter_upwards with t
        calc
          ∫ u : ℝ, ‖A (u, t) - B (u, t)‖ = ∫ u : ℝ, ‖k t‖ * ‖f u - f (u - t)‖ := by
            refine MeasureTheory.integral_congr_ae ?_
            filter_upwards with u
            dsimp [A, B]
            rw [← mul_sub, norm_mul]
          _ = ‖k t‖ * ∫ u : ℝ, ‖f u - f (u - t)‖ := by
            simpa using (MeasureTheory.integral_const_mul ‖k t‖ (fun u : ℝ => ‖f u - f (u - t)‖))
          _ = ‖k t‖ * d t := by rfl
      _ = ∫ s : ℝ, G s := by
        calc
          ∫ t : ℝ, ‖k t‖ * d t = ∫ t : ℝ, R * (‖ρ (R * t)‖ * d t) := by
            refine MeasureTheory.integral_congr_ae ?_
            filter_upwards with t
            simp [k, hRpos.le, norm_mul, mul_assoc, mul_left_comm, mul_comm]
          _ = R * ∫ t : ℝ, ‖ρ (R * t)‖ * d t := by
            simpa [mul_assoc] using (MeasureTheory.integral_const_mul R (fun t : ℝ => ‖ρ (R * t)‖ * d t))
          _ = R * (|R⁻¹| • ∫ s : ℝ, ‖ρ s‖ * d (s / R)) := by
            congr 1
            simpa [hRne, mul_assoc, mul_left_comm, mul_comm, div_eq_mul_inv] using
              (MeasureTheory.Measure.integral_comp_mul_left
                (g := fun s : ℝ => ‖ρ s‖ * d (s / R)) (a := R))
          _ = ∫ s : ℝ, G s := by
            have hRabs : |R⁻¹| = R⁻¹ := abs_of_pos (inv_pos.mpr hRpos)
            rw [hRabs]
            simp [G, smul_eq_mul, hRne, mul_assoc]
  have hnear : ∀ s : ℝ, s ∈ (tail N)ᶜ → |s / R| < δ := by
    intro s hs
    have hsltN : |s| < N := by
      have hsnot : ¬ ((N : ℝ) ≤ |s|) := by simpa [tail] using hs
      exact lt_of_not_ge hsnot
    have hRge : (N : ℝ) / δ ≤ R := by
      dsimp [R]
      exact le_max_left _ _
    have hNle : (N : ℝ) ≤ R * δ := by
      have hmul := mul_le_mul_of_nonneg_right hRge hδpos.le
      simpa [div_eq_mul_inv, hδpos.ne'] using hmul
    rw [abs_div]
    have hRabs : |R| = R := abs_of_pos hRpos
    rw [hRabs]
    rw [div_lt_iff₀ hRpos]
    have : |s| < R * δ := lt_of_lt_of_le hsltN hNle
    simpa [mul_comm, mul_left_comm, mul_assoc] using this
  have htail_le : ∫ s in tail N, G s ∂MeasureTheory.volume ≤ (2 * C) * ∫ s in tail N, ‖ρ s‖ := by
    have hconst_on : MeasureTheory.IntegrableOn (fun s : ℝ => (2 * C) * ‖ρ s‖) (tail N) MeasureTheory.volume :=
      (hρnorm.const_mul (2 * C)).integrableOn
    calc
      ∫ s in tail N, G s ≤ ∫ s in tail N, (2 * C) * ‖ρ s‖ := by
        apply MeasureTheory.setIntegral_mono_on hG_int.integrableOn hconst_on (hs := htail_meas N)
        intro s hs
        dsimp [G]
        have := hd_le (s / R)
        nlinarith [norm_nonneg (ρ s)]
      _ = (2 * C) * ∫ s in tail N, ‖ρ s‖ := by
        simpa using (MeasureTheory.integral_const_mul (2 * C) (fun s : ℝ => ‖ρ s‖) (μ := MeasureTheory.volume.restrict (tail N)))
  have hhead_le : ∫ s in (tail N)ᶜ, G s ∂MeasureTheory.volume ≤ η * ∫ s in (tail N)ᶜ, ‖ρ s‖ := by
    have hconst_on : MeasureTheory.IntegrableOn (fun s : ℝ => η * ‖ρ s‖) (tail N)ᶜ MeasureTheory.volume :=
      (hρnorm.const_mul η).integrableOn
    calc
      ∫ s in (tail N)ᶜ, G s ≤ ∫ s in (tail N)ᶜ, η * ‖ρ s‖ := by
        apply MeasureTheory.setIntegral_mono_on hG_int.integrableOn hconst_on (hs := (htail_meas N).compl)
        intro s hs
        dsimp [G]
        have hsdiv : |s / R| < δ := hnear s hs
        have hsη : d (s / R) < η := hδ' (s / R) hsdiv
        nlinarith [norm_nonneg (ρ s)]
      _ = η * ∫ s in (tail N)ᶜ, ‖ρ s‖ := by
        simpa using (MeasureTheory.integral_const_mul η (fun s : ℝ => ‖ρ s‖) (μ := MeasureTheory.volume.restrict ((tail N)ᶜ)))
  have hhead_le' : η * ∫ s in (tail N)ᶜ, ‖ρ s‖ ≤ η * M := by
    have hset : ∫ s in (tail N)ᶜ, ‖ρ s‖ ≤ ∫ s : ℝ, ‖ρ s‖ := by
      exact MeasureTheory.setIntegral_le_integral (s := (tail N)ᶜ) (f := fun s : ℝ => ‖ρ s‖) hρnorm
        (Filter.Eventually.of_forall fun s => norm_nonneg _)
    dsimp [M]
    exact mul_le_mul_of_nonneg_left hset (le_of_lt hηpos)
  have hC1pos : 0 < C + 1 := by nlinarith
  have hM1pos : 0 < M + 1 := by nlinarith
  have hfracC : C / (C + 1) ≤ 1 := by
    rw [div_le_iff₀ hC1pos]
    nlinarith
  have hfracM : M / (M + 1) ≤ 1 := by
    rw [div_le_iff₀ hM1pos]
    nlinarith
  have htail_half : (2 * C) * α ≤ ε / 2 := by
    calc
      (2 * C) * α = (ε / 2) * (C / (C + 1)) := by
        dsimp [α]
        field_simp [hC1pos.ne']
        ring
      _ ≤ (ε / 2) * 1 := by
        gcongr
      _ = ε / 2 := by ring
  have hhead_half : η * M ≤ ε / 2 := by
    calc
      η * M = (ε / 2) * (M / (M + 1)) := by
        dsimp [η]
        field_simp [hM1pos.ne']
      _ ≤ (ε / 2) * 1 := by
        gcongr
      _ = ε / 2 := by ring
  refine ⟨R, hRpos, ?_⟩
  calc
    ∫ u : ℝ, ‖f u - (∫ t : ℝ, (((R : ℝ) : ℂ) * ρ (R * t)) * f (u - t))‖
        = ∫ u : ℝ, ‖f u - (∫ t : ℝ, k t * f (u - t))‖ := by rfl
    _ ≤ ∫ s : ℝ, G s := hbound
    _ = (∫ s in tail N, G s) + ∫ s in (tail N)ᶜ, G s := by
      symm
      exact MeasureTheory.integral_add_compl (s := tail N) (f := G) (μ := MeasureTheory.volume) (hs := htail_meas N) hG_int
    _ ≤ ((2 * C) * ∫ s in tail N, ‖ρ s‖) + η * ∫ s in (tail N)ᶜ, ‖ρ s‖ := by
      exact add_le_add htail_le hhead_le
    _ ≤ (2 * C) * α + η * M := by
      refine add_le_add ?_ hhead_le'
      exact mul_le_mul_of_nonneg_left (le_of_lt (hN N le_rfl)) (by nlinarith)
    _ ≤ ε / 2 + ε / 2 := by
      exact add_le_add htail_half hhead_half
    _ = ε := by ring

theorem integral_const_mul_cexp_neg_Ioi (b : ℝ) {z : ℂ} : 0 < z.re →
    ∫ x in Set.Ioi (0 : ℝ), (((b : ℝ) : ℂ) * Complex.exp (-z * x)) = (b : ℂ) / z := by
  intro hz
  calc
    ∫ x in Set.Ioi (0 : ℝ), ((b : ℂ) * Complex.exp (-z * x))
        = (b : ℂ) * ∫ x in Set.Ioi (0 : ℝ), Complex.exp (-z * x) := by
            simpa using
              (MeasureTheory.integral_const_mul
                (μ := MeasureTheory.Measure.restrict (MeasureTheory.MeasureSpace.volume)
                  (Set.Ioi (0 : ℝ)))
                (r := (b : ℂ)) (f := fun x : ℝ => Complex.exp (-z * x)))
    _ = (b : ℂ) * (-Complex.exp ((-z) * (0 : ℝ)) / (-z)) := by
          have hz' : (-z).re < 0 := by
            simpa using neg_neg_iff_pos.mpr hz
          rw [integral_exp_mul_complex_Ioi hz' (0 : ℝ)]
    _ = (b : ℂ) / z := by
          simp [Complex.exp_zero, div_eq_mul_inv, mul_assoc]

theorem lSeriesSummable_of_Icc_growth_family {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    (∀ r : ℝ, 1 < r → ∃ C : ℝ, 0 ≤ C ∧ ∀ N : ℕ,
      ∑ k ∈ Finset.Icc 1 N, f k ≤ C * (N : ℝ) ^ r) →
    ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s := by
  intro hnonneg hgrowth s hs
  let r : ℝ := (1 + s.re) / 2
  have hr1 : 1 < r := by
    dsimp [r]
    linarith
  have hrs : r < s.re := by
    dsimp [r]
    linarith
  have hr0 : 0 ≤ r := by
    dsimp [r]
    linarith
  rcases hgrowth r hr1 with ⟨C, hC0, hC⟩
  have hO : (fun n : ℕ => ∑ k ∈ Finset.Icc 1 n, f k) =O[Filter.atTop] fun n : ℕ => (n : ℝ) ^ r := by
    refine Asymptotics.IsBigO.of_bound C ?_
    filter_upwards [Filter.Eventually.of_forall hC] with n hn
    have hsum_nonneg : 0 ≤ ∑ k ∈ Finset.Icc 1 n, f k := by
      exact Finset.sum_nonneg (by
        intro k hk
        exact hnonneg k)
    have hrpow_nonneg : 0 ≤ (n : ℝ) ^ r := by
      exact Real.rpow_nonneg (by positivity) r
    simpa [Real.norm_eq_abs, abs_of_nonneg hsum_nonneg, abs_of_nonneg hrpow_nonneg] using hn
  exact LSeriesSummable_of_sum_norm_bigO_and_nonneg hO hnonneg hr0 hrs

theorem lSeries_real_eq_re_add_pole_of_eqOn {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∀ {x : ℝ}, 1 < x →
      (∑' n, f n / (n : ℝ) ^ x) = (g x).re + a.re / (x - 1) := by
  intro hS hg_eq x hx
  have hxmem : (x : ℂ) ∈ {s : ℂ | 1 < s.re} := by
    simpa using hx
  have hx0 : x ≠ 0 := by linarith
  have hLre : (LSeries (fun n => (f n : ℂ)) (x : ℂ)).re = ∑' n, f n / (n : ℝ) ^ x := by
    rw [LSeries, Complex.re_tsum (hS (x : ℂ) (by simpa using hx))]
    refine tsum_congr fun n ↦ ?_
    rcases eq_or_ne n 0 with rfl | hn
    · simp only [LSeries.term_zero, Complex.zero_re, Complex.ofReal_zero]
      simp [hx0, Real.zero_rpow]
    · simp only [LSeries.term_of_ne_zero hn, ← Complex.ofReal_natCast n,
        ← Complex.ofReal_cpow n.cast_nonneg, ← Complex.ofReal_div, Complex.ofReal_re]
  have hgx : g (x : ℂ) = LSeries (fun n => (f n : ℂ)) (x : ℂ) - a / ((x : ℂ) - 1) :=
    hg_eq hxmem
  have hdivre : (a / ((x : ℂ) - 1)).re = a.re / (x - 1) := by
    simpa using (Complex.div_ofReal_re a (x - 1))
  have hgre := congrArg Complex.re hgx
  rw [Complex.sub_re, hLre, hdivre] at hgre
  linarith

theorem lSeries_real_sub_pole_abs_le_of_continuous_eqOn {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    Set.EqOn g
      (fun s : ℂ => LSeries (fun n => (f n : ℂ)) s - a / (s - 1))
      {s : ℂ | 1 < s.re} →
    ∃ C : ℝ, 0 ≤ C ∧ ∀ {x : ℝ}, x ∈ Set.Ioc 1 2 →
      abs ((∑' n, f n / (n : ℝ) ^ x) - a.re / (x - 1)) ≤ C := by
  intro hf hg_cont hg_eq
  have hcontg : ContinuousOn (fun x : ℝ => g (x : ℂ)) (Set.Icc 1 2) := by
    refine hg_cont.comp' Complex.continuous_ofReal.continuousOn ?_
    intro x hx
    simpa using hx.1
  have hcontre : ContinuousOn (fun x : ℝ => (g (x : ℂ)).re) (Set.Icc 1 2) := by
    simpa [Function.comp] using
      (Continuous.comp_continuousOn (g := Complex.re) (f := fun x : ℝ => g (x : ℂ))
        Complex.continuous_re hcontg)
  have hcontabs : ContinuousOn (fun x : ℝ => abs ((g (x : ℂ)).re)) (Set.Icc 1 2) := by
    simpa [Function.comp] using
      (Continuous.comp_continuousOn (g := fun t : ℝ => abs t) (f := fun x : ℝ => (g (x : ℂ)).re)
        Real.uniformContinuous_abs.continuous hcontre)
  have hnonempty : (Set.Icc (1 : ℝ) 2).Nonempty := ⟨1, by simp⟩
  rcases (isCompact_Icc : IsCompact (Set.Icc (1 : ℝ) 2)).exists_isMaxOn hnonempty hcontabs with
    ⟨y, hyIcc, hyMax⟩
  refine ⟨abs ((g (y : ℂ)).re), abs_nonneg _, ?_⟩
  intro x hx
  have hx' : x ∈ Set.Icc (1 : ℝ) 2 := ⟨le_of_lt hx.1, hx.2⟩
  have hEqx : (∑' n, f n / (n : ℝ) ^ x) = (g (x : ℂ)).re + a.re / (x - 1) :=
    lSeries_real_eq_re_add_pole_of_eqOn (f := f) (a := a) (g := g) hf hg_eq hx.1
  have hrewrite : (∑' n, f n / (n : ℝ) ^ x) - a.re / (x - 1) = (g (x : ℂ)).re := by
    linarith
  rw [hrewrite]
  exact hyMax hx'

noncomputable def leftTentKernel (u : ℝ) : ℂ :=
  if -1 ≤ u ∧ u ≤ 0 then ((2 * (u + 1) : ℝ) : ℂ) else 0

noncomputable def leftTentConvolution (κ : ℝ → ℂ) : ℝ → ℂ :=
  fun x => ∫ t : ℝ, κ t * leftTentKernel (x - t)

theorem leftTentConvolution_eq_convolution {κ : ℝ → ℂ} :
  leftTentConvolution κ =
    MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ) MeasureTheory.volume := by
  ext x
  rfl

theorem leftTentKernel_integrable: MeasureTheory.Integrable leftTentKernel := by
  let f : ℝ → ℂ := fun u => ((2 * (u + 1) : ℝ) : ℂ)
  have hf_cont : Continuous f := by
    continuity
  have hf_int : MeasureTheory.IntegrableOn f (Set.Icc (-1 : ℝ) 0) := by
    simpa [f] using hf_cont.integrableOn_Icc (a := (-1 : ℝ)) (b := 0)
  have h_eq : leftTentKernel = Set.indicator (Set.Icc (-1 : ℝ) 0) f := by
    funext u
    by_cases hu : u ∈ Set.Icc (-1 : ℝ) 0
    · rcases hu with ⟨hu1, hu2⟩
      simp [leftTentKernel, f, hu1, hu2]
    · have hnot : ¬ (-1 ≤ u ∧ u ≤ 0) := by
        simpa [Set.mem_Icc] using hu
      simp [leftTentKernel, f, hu, hnot]
  rw [h_eq]
  exact hf_int.integrable_indicator (by measurability)

theorem leftTentKernel_fourier_contDiff: ContDiff ℝ (⊤ : ℕ∞) (FourierTransform.fourier leftTentKernel) := by
  refine Real.contDiff_fourier (N := (⊤ : ℕ∞)) ?_
  intro n hn
  let g : ℝ → ℝ := fun u => ‖u‖ ^ n * ‖((2 * (u + 1) : ℝ) : ℂ)‖
  have hg_cont : Continuous g := by
    dsimp [g]
    continuity
  have hg_int : MeasureTheory.IntegrableOn g (Set.Icc (-1 : ℝ) 0) := by
    simpa using hg_cont.integrableOn_Icc (μ := MeasureTheory.volume) (a := (-1 : ℝ)) (b := (0 : ℝ))
  have h_eq :
      (fun u : ℝ => ‖u‖ ^ n * ‖leftTentKernel u‖) = Set.indicator (Set.Icc (-1 : ℝ) 0) g := by
    funext u
    by_cases hu : u ∈ Set.Icc (-1 : ℝ) 0
    · have hu' : -1 ≤ u ∧ u ≤ 0 := by
        simpa [Set.mem_Icc] using hu
      simp [leftTentKernel, g, hu, hu']
    · have hnot : ¬ (-1 ≤ u ∧ u ≤ 0) := by
        simpa [Set.mem_Icc] using hu
      simp [leftTentKernel, g, hu, hnot]
  rw [h_eq]
  exact hg_int.integrable_indicator measurableSet_Icc

theorem leftTentKernel_mass_one: ∫ u : ℝ, leftTentKernel u = 1 := by
  have hsupp : Function.support leftTentKernel ⊆ Set.Ioc (-1 : ℝ) 0 := by
    intro x hx
    change leftTentKernel x ≠ 0 at hx
    by_cases h : -1 ≤ x ∧ x ≤ 0
    · refine ⟨?_, h.2⟩
      by_contra hxlt
      push Not at hxlt
      have hxeq : x = -1 := by linarith [h.1, hxlt]
      have : leftTentKernel x = 0 := by
        simp [leftTentKernel, h, hxeq]
      exact hx this
    · exfalso
      exact hx (by simp [leftTentKernel, h])
  rw [← intervalIntegral.integral_eq_integral_of_support_subset hsupp]
  have hcongr : (∫ u in (-1 : ℝ)..0, leftTentKernel u)
      = ∫ u in (-1 : ℝ)..0, (((2 * (u + 1) : ℝ) : ℂ)) := by
    refine intervalIntegral.integral_congr ?_
    intro x hx
    have hx' : x ∈ Set.Icc (-1 : ℝ) 0 := by
      simpa [Set.uIcc_of_le (show (-1 : ℝ) ≤ 0 by norm_num)] using hx
    have hx'' : -1 ≤ x ∧ x ≤ 0 := by
      simpa [Set.mem_Icc] using hx'
    simp [leftTentKernel, hx'']
  rw [hcongr]
  rw [intervalIntegral.integral_ofReal]
  have hfi1 : IntervalIntegrable (fun u : ℝ => 2 * u) MeasureTheory.volume (-1 : ℝ) 0 := by
    apply Continuous.intervalIntegrable
    continuity
  have hfi2 : IntervalIntegrable (fun _ : ℝ => (2 : ℝ)) MeasureTheory.volume (-1 : ℝ) 0 := by
    apply Continuous.intervalIntegrable
    continuity
  have hcalc : ∫ u in (-1 : ℝ)..0, (2 * (u + 1) : ℝ) = 1 := by
    calc
      ∫ u in (-1 : ℝ)..0, (2 * (u + 1) : ℝ)
          = ∫ u in (-1 : ℝ)..0, (2 * u + 2 : ℝ) := by
              refine intervalIntegral.integral_congr ?_
              intro u hu
              ring
      _ = (∫ u in (-1 : ℝ)..0, (2 * u : ℝ)) + ∫ u in (-1 : ℝ)..0, (2 : ℝ) := by
            rw [intervalIntegral.integral_add hfi1 hfi2]
      _ = 2 * (∫ u in (-1 : ℝ)..0, (u : ℝ)) + ∫ u in (-1 : ℝ)..0, (2 : ℝ) := by
            rw [intervalIntegral.integral_const_mul]
      _ = 2 * (((0 : ℝ) ^ 2 - (-1 : ℝ) ^ 2) / 2) + ∫ u in (-1 : ℝ)..0, (2 : ℝ) := by
            rw [integral_id]
      _ = 2 * (((0 : ℝ) ^ 2 - (-1 : ℝ) ^ 2) / 2) + ((0 : ℝ) - (-1 : ℝ)) • (2 : ℝ) := by
            rw [intervalIntegral.integral_const]
      _ = 1 := by
            norm_num
  exact_mod_cast hcalc

theorem compactFreqKernel_convolution_leftTent {κ : ℝ → ℂ} :
  CompactFreqKernel κ →
  CompactFreqKernel (leftTentConvolution κ) := by
  intro hκ
  rw [leftTentConvolution_eq_convolution]
  rcases compactFreqKernel_bounded hκ with ⟨Cκ, _, hκbd⟩
  have hBdd : BddAbove (Set.range fun x => ‖κ x‖) := by
    refine ⟨Cκ, ?_⟩
    rintro _ ⟨x, rfl⟩
    exact hκbd x
  have h_int :
      MeasureTheory.Integrable
        (MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
          MeasureTheory.volume) := by
    simpa using
      (MeasureTheory.Integrable.integrable_convolution
        (L := ContinuousLinearMap.mul ℂ ℂ) hκ.integrable leftTentKernel_integrable)
  have hmul : Continuous fun p : ℝ × ℝ => (LinearMap.mul ℝ ℝ) p.1 p.2 := by
    simpa using (continuous_fst.mul continuous_snd)
  have hphase_conv (w : ℝ) :
      (fun x : ℝ =>
        (Real.fourierChar (-(x * w)) : ℂ) *
          MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
            MeasureTheory.volume x) =
        MeasureTheory.convolution
          (fun t : ℝ => (Real.fourierChar (-(t * w)) : ℂ) * κ t)
          (fun s : ℝ => (Real.fourierChar (-(s * w)) : ℂ) * leftTentKernel s)
          (ContinuousLinearMap.mul ℂ ℂ) MeasureTheory.volume := by
    ext x
    calc
      (Real.fourierChar (-(x * w)) : ℂ) *
          MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
            MeasureTheory.volume x
        = (Real.fourierChar (-(x * w)) : ℂ) *
            ∫ t : ℝ, κ t * leftTentKernel (x - t) := by
              rw [MeasureTheory.convolution_mul]
      _ = ∫ t : ℝ, (Real.fourierChar (-(x * w)) : ℂ) * (κ t * leftTentKernel (x - t)) := by
            simpa using
              (MeasureTheory.integral_const_mul
                (μ := MeasureTheory.volume)
                (r := (Real.fourierChar (-(x * w)) : ℂ))
                (f := fun t : ℝ => κ t * leftTentKernel (x - t))).symm
      _ = ∫ t : ℝ,
            ((Real.fourierChar (-(t * w)) : ℂ) * κ t) *
              (((Real.fourierChar (-((x - t) * w)) : ℂ)) * leftTentKernel (x - t)) := by
            apply MeasureTheory.integral_congr_ae
            filter_upwards with t
            have hphase_circle :
                Real.fourierChar (-(x * w)) =
                  Real.fourierChar (-(t * w)) *
                    Real.fourierChar (-((x - t) * w)) := by
              calc
                Real.fourierChar (-(x * w))
                    = Real.fourierChar (-(t * w) + -((x - t) * w)) := by
                        congr 1
                        ring
                _ = Real.fourierChar (-(t * w)) *
                    Real.fourierChar (-((x - t) * w)) := by
                      simpa using
                        (AddChar.map_add_eq_mul Real.fourierChar (-(t * w))
                          (-((x - t) * w)))
            have hphase :
                (Real.fourierChar (-(x * w)) : ℂ) =
                  (Real.fourierChar (-(t * w)) : ℂ) *
                    (Real.fourierChar (-((x - t) * w)) : ℂ) := by
              simpa using congrArg (fun z : Circle => (z : ℂ)) hphase_circle
            calc
              (Real.fourierChar (-(x * w)) : ℂ) * (κ t * leftTentKernel (x - t))
                  = ((Real.fourierChar (-(t * w)) : ℂ) *
                      (Real.fourierChar (-((x - t) * w)) : ℂ)) *
                    (κ t * leftTentKernel (x - t)) := by
                      rw [hphase]
              _ = ((Real.fourierChar (-(t * w)) : ℂ) * κ t) *
                    (((Real.fourierChar (-((x - t) * w)) : ℂ)) * leftTentKernel (x - t)) := by
                    ring
      _ = MeasureTheory.convolution
            (fun t : ℝ => (Real.fourierChar (-(t * w)) : ℂ) * κ t)
            (fun s : ℝ => (Real.fourierChar (-(s * w)) : ℂ) * leftTentKernel s)
            (ContinuousLinearMap.mul ℂ ℂ) MeasureTheory.volume x := by
            rw [MeasureTheory.convolution_mul]
  have hFourier_conv :
      FourierTransform.fourier
        (MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
          MeasureTheory.volume) =
        (FourierTransform.fourier κ) * (FourierTransform.fourier leftTentKernel) := by
    ext w
    have hκw' :
        MeasureTheory.Integrable
          (fun x : ℝ => Real.fourierChar (-(x * w)) • κ x) := by
      exact
        (VectorFourier.fourierIntegral_convergent_iff
          (e := Real.fourierChar) (μ := MeasureTheory.volume) (L := LinearMap.mul ℝ ℝ)
          Real.continuous_fourierChar hmul (f := κ) w).2 hκ.integrable
    have hκw : MeasureTheory.Integrable (fun x : ℝ => (Real.fourierChar (-(x * w)) : ℂ) * κ x) := by
      simpa [Circle.smul_def, smul_eq_mul] using hκw'
    have htw' :
        MeasureTheory.Integrable
          (fun x : ℝ => Real.fourierChar (-(x * w)) • leftTentKernel x) := by
      exact
        (VectorFourier.fourierIntegral_convergent_iff
          (e := Real.fourierChar) (μ := MeasureTheory.volume) (L := LinearMap.mul ℝ ℝ)
          Real.continuous_fourierChar hmul (f := leftTentKernel) w).2 leftTentKernel_integrable
    have htw : MeasureTheory.Integrable
        (fun x : ℝ => (Real.fourierChar (-(x * w)) : ℂ) * leftTentKernel x) := by
      simpa [Circle.smul_def, smul_eq_mul] using htw'
    calc
      FourierTransform.fourier
          (MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
            MeasureTheory.volume) w
        = ∫ x : ℝ, (Real.fourierChar (-(x * w)) : ℂ) *
            MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
              MeasureTheory.volume x := by
              rw [Real.fourier_real_eq]
              apply MeasureTheory.integral_congr_ae
              filter_upwards with x
              simp [Circle.smul_def, smul_eq_mul]
      _ = ∫ x : ℝ,
            MeasureTheory.convolution
              (fun t : ℝ => (Real.fourierChar (-(t * w)) : ℂ) * κ t)
              (fun s : ℝ => (Real.fourierChar (-(s * w)) : ℂ) * leftTentKernel s)
              (ContinuousLinearMap.mul ℂ ℂ) MeasureTheory.volume x := by
            apply MeasureTheory.integral_congr_ae
            filter_upwards with x
            exact congrFun (hphase_conv w) x
      _ = FourierTransform.fourier κ w * FourierTransform.fourier leftTentKernel w := by
            simpa [Real.fourier_real_eq, Circle.smul_def, smul_eq_mul] using
              (MeasureTheory.integral_convolution (L := ContinuousLinearMap.mul ℂ ℂ)
                hκw htw)
  refine ⟨?_, h_int, ?_, ?_, ?_⟩
  · simpa using
      hBdd.continuous_convolution_left_of_integrable
        (L := ContinuousLinearMap.mul ℂ ℂ) (μ := MeasureTheory.volume)
        hκ.continuous leftTentKernel_integrable
  · simpa using
      (VectorFourier.fourierIntegral_continuous
        (e := Real.fourierChar) (μ := MeasureTheory.volume) (L := innerₗ ℝ)
        Real.continuous_fourierChar (innerSL ℝ).continuous₂ h_int)
  · simpa [hFourier_conv] using
      hκ.fourier_compact.mul_right (f' := FourierTransform.fourier leftTentKernel)
  · calc
      ∫ u : ℝ,
          MeasureTheory.convolution κ leftTentKernel (ContinuousLinearMap.mul ℂ ℂ)
            MeasureTheory.volume u
        = (∫ u : ℝ, κ u) * (∫ u : ℝ, leftTentKernel u) := by
            simpa using
              (MeasureTheory.integral_convolution (L := ContinuousLinearMap.mul ℂ ℂ)
                hκ.integrable leftTentKernel_integrable)
      _ = 1 := by
            simp [hκ.mass_one, leftTentKernel_mass_one]

theorem leftTentKernel_support_subset: Function.support leftTentKernel ⊆ Set.Ioc (-1 : ℝ) 0 := by
  intro x hx
  by_cases h : -1 ≤ x ∧ x ≤ 0
  · refine ⟨?_, h.2⟩
    by_contra hxle
    have hxeq : x = -1 := by linarith [h.1, hxle]
    have : leftTentKernel x = 0 := by
      rw [hxeq]
      simp [leftTentKernel]
    exact hx this
  · exfalso
    exact hx (by simp [leftTentKernel, h])

theorem exists_compactFreqKernel_cutoff_leftTent: ∃ ψ : ℝ → ℂ,
    CompactFreqKernel ψ ∧
    ∃ η : ℝ → ℂ,
      ContDiff ℝ (⊤ : ℕ∞) η ∧ HasCompactSupport η ∧ η 0 = 1 ∧
      FourierTransform.fourier ψ = fun ξ : ℝ => η ξ * FourierTransform.fourier leftTentKernel ξ := by
  classical
  have hleft_weighted : ∀ n : ℕ, MeasureTheory.Integrable (fun v : ℝ => ‖v‖ ^ n * ‖leftTentKernel v‖) := by
    intro n
    let g : ℝ → ℝ := fun v => ‖v‖ ^ n * ‖(((2 * (v + 1) : ℝ) : ℂ))‖
    have hg_cont : Continuous g := by
      dsimp [g]
      exact (continuous_norm.pow n).mul ((Complex.ofRealCLM.continuous.comp (continuous_const.mul (continuous_id.add continuous_const))).norm)
    have hg_int : MeasureTheory.IntegrableOn g (Set.Icc (-1 : ℝ) 0) := by
      exact hg_cont.integrableOn_Icc
    have hg_ind : MeasureTheory.Integrable ((Set.Icc (-1 : ℝ) 0).indicator g) := by
      exact hg_int.integrable_indicator measurableSet_Icc
    have h_eq : (fun v : ℝ => ‖v‖ ^ n * ‖leftTentKernel v‖) = (Set.Icc (-1 : ℝ) 0).indicator g := by
      ext v
      by_cases hv : v ∈ Set.Icc (-1 : ℝ) 0
      · have hcond : -1 ≤ v ∧ v ≤ 0 := by
          simpa [Set.mem_Icc] using hv
        simp [g, leftTentKernel, hv, hcond]
      · have hcond : ¬ (-1 ≤ v ∧ v ≤ 0) := by
          simpa [Set.mem_Icc] using hv
        simp [g, leftTentKernel, hv, hcond]
    rw [h_eq]
    exact hg_ind
  have hleft_fourier_smooth : ContDiff ℝ (⊤ : ℕ∞) (FourierTransform.fourier leftTentKernel) := by
    apply Real.contDiff_fourier
    intro n hn
    exact hleft_weighted n
  have hleft_fourier_zero : FourierTransform.fourier leftTentKernel 0 = 1 := by
    rw [Real.fourier_real_eq]
    simpa using leftTentKernel_mass_one
  obtain ⟨ηR, hηR_tsupport, hηR_cpt, hηR_smooth, hηR_range, hηR_zero⟩ :=
    exists_contDiff_tsupport_subset (s := Set.Ioo (-1 : ℝ) 1) (x := (0 : ℝ)) (n := (⊤ : ℕ∞)) (by
      exact IsOpen.mem_nhds isOpen_Ioo (by constructor <;> norm_num))
  let η : ℝ → ℂ := fun x => (ηR x : ℂ)
  have hη_smooth : ContDiff ℝ (⊤ : ℕ∞) η := by
    simpa [η] using hηR_smooth.continuousLinearMap_comp Complex.ofRealCLM
  have hη_cpt_norm : HasCompactSupport (fun x : ℝ => ‖η x‖) := by
    simpa [η] using hηR_cpt.abs
  have hη_cpt : HasCompactSupport η := by
    exact hasCompactSupport_norm_iff.mp hη_cpt_norm
  have hη_zero : η 0 = 1 := by
    simpa [η] using congrArg (fun t : ℝ => (t : ℂ)) hηR_zero
  let b : ℝ → ℂ := fun x => η x * FourierTransform.fourier leftTentKernel x
  have hb_smooth : ContDiff ℝ (⊤ : ℕ∞) b := by
    exact hη_smooth.mul hleft_fourier_smooth
  have hb_cpt : HasCompactSupport b := by
    simpa [b] using hη_cpt.mul_right (f' := FourierTransform.fourier leftTentKernel)
  have hb_cont : Continuous b := by
    exact hb_smooth.continuous
  have hb_int : MeasureTheory.Integrable b := by
    exact hb_cont.integrable_of_hasCompactSupport hb_cpt
  have hFb_int : MeasureTheory.Integrable (FourierTransform.fourier b) := by
    exact integrable_fourier_of_contDiff_hasCompactSupport b hb_smooth hb_cpt
  have hbneg_smooth : ContDiff ℝ (⊤ : ℕ∞) (fun x : ℝ => b (-x)) := by
    simpa using hb_smooth.comp (contDiff_const_smul (-1 : ℝ))
  have hbneg_cpt : HasCompactSupport (fun x : ℝ => b (-x)) := by
    simpa using hb_cpt.comp_smul (c := (-1 : ℝ)) (by norm_num)
  have hbneg_cont : Continuous (fun x : ℝ => b (-x)) := by
    exact hbneg_smooth.continuous
  have hbneg_int : MeasureTheory.Integrable (fun x : ℝ => b (-x)) := by
    exact hbneg_cont.integrable_of_hasCompactSupport hbneg_cpt
  let ψ : ℝ → ℂ := FourierTransform.fourier (fun x : ℝ => b (-x))
  have hψ_int : MeasureTheory.Integrable ψ := by
    exact integrable_fourier_of_contDiff_hasCompactSupport (fun x : ℝ => b (-x)) hbneg_smooth hbneg_cpt
  have h_inner_cont : Continuous (fun p : ℝ × ℝ => ((innerₗ ℝ) p.1) p.2) := by
    simpa using (continuous_inner : Continuous (fun p : ℝ × ℝ => inner ℝ p.1 p.2))
  have hψ_cont : Continuous ψ := by
    simpa [ψ] using
      (VectorFourier.fourierIntegral_continuous Real.continuous_fourierChar h_inner_cont hbneg_int)
  have hψ_eq_inv : ψ = FourierTransformInv.fourierInv b := by
    simpa [ψ] using (Real.fourierInv_eq_fourier_comp_neg b).symm
  have hψ_fourier : FourierTransform.fourier ψ = b := by
    rw [hψ_eq_inv]
    exact Continuous.fourier_fourierInv_eq hb_cont hb_int hFb_int
  refine ⟨ψ, ?_, ?_⟩
  · refine {
      continuous := hψ_cont
      integrable := hψ_int
      fourier_continuous := ?_
      fourier_compact := ?_
      mass_one := ?_ }
    · simpa [hψ_fourier] using hb_cont
    · simpa [hψ_fourier] using hb_cpt
    · have hψ_fourier_zero : FourierTransform.fourier ψ 0 = 1 := by
        calc
          FourierTransform.fourier ψ 0 = b 0 := by simpa using congrArg (fun f : ℝ → ℂ => f 0) hψ_fourier
          _ = η 0 * FourierTransform.fourier leftTentKernel 0 := by rfl
          _ = 1 := by simp [hη_zero, hleft_fourier_zero]
      have hfourier_eq_int : FourierTransform.fourier ψ 0 = ∫ u : ℝ, ψ u := by
        simpa using (Real.fourier_real_eq ψ 0)
      exact hfourier_eq_int.symm.trans hψ_fourier_zero
  · refine ⟨η, hη_smooth, hη_cpt, hη_zero, ?_⟩
    funext ξ
    simpa [b] using congrArg (fun f : ℝ → ℂ => f ξ) hψ_fourier

theorem leftTentKernel_support_subset_Ioi_of_one_le {X : ℝ} (hX : 1 ≤ X) : Function.support leftTentKernel ⊆ Set.Ioi (-X) := by
  intro u hu
  have hu' := leftTentKernel_support_subset hu
  have hu_gt : -1 < u := hu'.1
  have hnegX : -X ≤ -1 := by
    linarith
  exact lt_of_le_of_lt hnegX hu_gt

theorem leftTentKernel_product_support_subset_Ioi_of_one_le {X : ℝ} (hX : 1 ≤ X) (H : ℝ → ℂ) : Function.support (fun u => leftTentKernel u * H u) ⊆ Set.Ioi (-X) := by
  intro u hu
  have hu' : u ∈ Function.support leftTentKernel := by
    rw [Function.mem_support]
    intro h0
    rw [Function.mem_support] at hu
    apply hu
    simp [h0]
  exact leftTentKernel_support_subset_Ioi_of_one_le hX hu'

noncomputable def logRescalePartialSum (f : ℕ → ℝ) (x : ℝ) : ℝ :=
  if 0 ≤ x then
    Real.exp (-x) * (∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k)
  else
    0

def HasBoundaryLaplaceExtension (f : ℕ → ℝ) (b : ℝ) : Prop :=
  ∃ G : ℂ → ℂ,
    ContinuousOn G {z : ℂ | 0 ≤ z.re} ∧
    (∀ z : ℂ, 0 < z.re →
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ))) ∧
    Set.EqOn G
      (fun z : ℂ => ∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
      {z : ℂ | 0 < z.re}

theorem boundary_extension_real_bounded_near_zero {f : ℕ → ℝ} {b : ℝ} :
  HasBoundaryLaplaceExtension f b →
  ∃ ε M : ℝ, 0 < ε ∧
    ∀ σ : ℝ, 0 < σ → σ < ε →
      Complex.re (∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-(σ : ℂ) * x))) ≤ M := by
  intro h
  rcases h with ⟨G, hGcont, hGint, hGeq⟩
  let S : Set ℂ := {z : ℂ | 0 ≤ z.re}
  have h0mem : (0 : ℂ) ∈ S := by
    simp [S]
  have hcont0 : ContinuousWithinAt G S 0 := hGcont 0 h0mem
  rcases (Metric.continuousWithinAt_iff.mp hcont0) 1 (by positivity : (0 : ℝ) < 1) with
    ⟨ε, hεpos, hεbound⟩
  refine ⟨ε, ‖G 0‖ + 1, hεpos, ?_⟩
  intro σ hσpos hσlt
  have hσmemS : (σ : ℂ) ∈ S := by
    simp [S, le_of_lt hσpos]
  have hσdist : dist (σ : ℂ) 0 < ε := by
    simpa [dist_eq_norm, RCLike.norm_ofReal, abs_of_pos hσpos] using hσlt
  have hGdist : dist (G (σ : ℂ)) (G 0) < 1 := hεbound hσmemS hσdist
  have hGnorm : ‖G (σ : ℂ)‖ ≤ ‖G 0‖ + 1 := by
    have hdiff : ‖G (σ : ℂ) - G 0‖ < 1 := by
      simpa [dist_eq_norm] using hGdist
    have hdiff' : ‖G (σ : ℂ) - G 0‖ ≤ 1 := le_of_lt hdiff
    calc
      ‖G (σ : ℂ)‖ = ‖(G (σ : ℂ) - G 0) + G 0‖ := by rw [sub_add_cancel]
      _ ≤ ‖G (σ : ℂ) - G 0‖ + ‖G 0‖ := norm_add_le _ _
      _ ≤ 1 + ‖G 0‖ := add_le_add hdiff' le_rfl
      _ = ‖G 0‖ + 1 := by ring
  have hEq :
      G (σ : ℂ) = ∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-(σ : ℂ) * x)) := by
    exact hGeq (by simpa using hσpos)
  rw [← hEq]
  have hAbs : |Complex.re (G (σ : ℂ))| ≤ ‖G (σ : ℂ)‖ := by
    simpa using (RCLike.abs_re_le_norm (G (σ : ℂ)))
  have hre : Complex.re (G (σ : ℂ)) ≤ ‖G (σ : ℂ)‖ :=
    le_trans (le_abs_self _) hAbs
  exact le_trans hre hGnorm

theorem boundary_extension_translate_difference_damped_integrable {f : ℕ → ℝ} {b δ : ℝ} :
  HasBoundaryLaplaceExtension f b → 0 < δ →
  ∀ z : ℂ, 0 < z.re →
    MeasureTheory.IntegrableOn
      (fun x : ℝ =>
        ((((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b) : ℝ) : ℂ) *
          Complex.exp (-z * x)))
      (Set.Ioi (0 : ℝ)) := by
  intro hExt hδ z hz
  rcases hExt with ⟨G, hGcont, hGint, hGeq⟩
  let U : ℝ → ℂ := fun x => (((logRescalePartialSum f x - b : ℝ) : ℂ))
  let g : ℝ → ℂ := fun x => U x * Complex.exp (-z * x)
  have h_orig : MeasureTheory.IntegrableOn g (Set.Ioi (0 : ℝ)) := by
    simpa only [g, U] using hGint z hz
  have h_tail : MeasureTheory.IntegrableOn g (Set.Ioi δ) := by
    exact h_orig.mono_set (by intro x hx; exact lt_trans hδ hx)
  have h_tail_ind : MeasureTheory.Integrable (Set.indicator (Set.Ioi δ) g) := by
    exact h_tail.integrable_indicator measurableSet_Ioi
  have h_shift_ind : MeasureTheory.Integrable (fun x : ℝ => Set.indicator (Set.Ioi δ) g (x + δ)) := by
    simpa only [g] using h_tail_ind.comp_add_right δ
  have h_shift0 : MeasureTheory.IntegrableOn
      (fun x : ℝ => U (x + δ) * Complex.exp (-z * (((x + δ : ℝ) : ℂ))))
      (Set.Ioi (0 : ℝ)) := by
    refine (h_shift_ind.integrableOn).congr_fun ?_ measurableSet_Ioi
    intro x hx
    have hxδ : x + δ ∈ Set.Ioi δ := by
      dsimp [Set.Ioi] at hx ⊢
      linarith
    simp only [Set.indicator_of_mem, hxδ, g]
  have h_const : MeasureTheory.IntegrableOn
      (fun x : ℝ => Complex.exp (z * δ) * (U (x + δ) * Complex.exp (-z * (((x + δ : ℝ) : ℂ)))))
      (Set.Ioi (0 : ℝ)) :=
    h_shift0.const_mul _
  have h_shift : MeasureTheory.IntegrableOn (fun x : ℝ => U (x + δ) * Complex.exp (-z * x)) (Set.Ioi (0 : ℝ)) := by
    refine h_const.congr_fun ?_ measurableSet_Ioi
    intro x hx
    calc
      Complex.exp (z * δ) * (U (x + δ) * Complex.exp (-z * (((x + δ : ℝ) : ℂ))))
          = U (x + δ) * (Complex.exp (z * δ) * Complex.exp (-z * (((x + δ : ℝ) : ℂ)))) := by ring
      _ = U (x + δ) * Complex.exp (z * δ + -z * (((x + δ : ℝ) : ℂ))) := by rw [← Complex.exp_add]
      _ = U (x + δ) * Complex.exp (-z * x) := by
          congr 2
          push_cast
          ring
  have h_sub : MeasureTheory.IntegrableOn
      (fun x : ℝ => (U (x + δ) * Complex.exp (-z * x)) - (U x * Complex.exp (-z * x)))
      (Set.Ioi (0 : ℝ)) :=
    h_shift.sub h_orig
  refine h_sub.congr_fun ?_ measurableSet_Ioi
  intro x hx
  change
    ↑(logRescalePartialSum f (x + δ) - b) * Complex.exp (-z * x) -
      ↑(logRescalePartialSum f x - b) * Complex.exp (-z * x) =
    ↑((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b)) * Complex.exp (-z * x)
  rw [← sub_mul]
  push_cast
  rfl

theorem centeredTentWeight_intervalIntegral_eq_leftTent_shift_add_reflect {f : ℕ → ℝ} {b X : ℝ} :
  ∫ t in (0 : ℝ)..1,
      centeredTentWeight t * (logRescalePartialSum f (X + t) - b)
    =
      ∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re *
          (logRescalePartialSum f (X + t) - b) := by
  refine intervalIntegral.integral_congr_ae ?_
  have hne : ∀ᵐ t ∂(MeasureTheory.volume), t ≠ (1 / 2 : ℝ) := by
    rw [MeasureTheory.ae_iff]
    simp
  filter_upwards [hne] with t htne htI
  have ht0 : (0 : ℝ) < t := by simpa using htI.1
  have ht1 : t ≤ (1 : ℝ) := by simpa using htI.2
  have hcoeff :
      centeredTentWeight t =
        (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re := by
    by_cases hlt : t < (1 / 2 : ℝ)
    · have hle1 : t - (1 / 2 : ℝ) ≤ 0 := by linarith
      have hleft :
          leftTentKernel (t - (1 / 2 : ℝ)) =
            (((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) : ℂ) := by
        unfold leftTentKernel
        have hcond : -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0 := by
          constructor <;> linarith
        rw [if_pos hcond]
      have hright : leftTentKernel ((1 / 2 : ℝ) - t) = 0 := by
        unfold leftTentKernel
        have hnot : ¬ (-1 ≤ (1 / 2 : ℝ) - t ∧ (1 / 2 : ℝ) - t ≤ 0) := by
          intro h
          linarith [h.2]
        rw [if_neg hnot]
      unfold centeredTentWeight
      rw [abs_of_nonpos hle1, max_eq_right]
      · rw [hleft, hright]
        simp
        ring
      · linarith [ht0]
    · have hhalf_le : (1 / 2 : ℝ) ≤ t := by linarith
      have hgt : (1 / 2 : ℝ) < t := lt_of_le_of_ne hhalf_le htne.symm
      have hleft : leftTentKernel (t - (1 / 2 : ℝ)) = 0 := by
        unfold leftTentKernel
        have hnot : ¬ (-1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0) := by
          intro h
          linarith [h.2]
        rw [if_neg hnot]
      have hright :
          leftTentKernel ((1 / 2 : ℝ) - t) =
            (((2 * (((1 / 2 : ℝ) - t) + 1) : ℝ)) : ℂ) := by
        unfold leftTentKernel
        have hcond : -1 ≤ (1 / 2 : ℝ) - t ∧ (1 / 2 : ℝ) - t ≤ 0 := by
          constructor <;> linarith
        rw [if_pos hcond]
      unfold centeredTentWeight
      rw [abs_of_nonneg (by linarith), max_eq_right]
      · rw [hleft, hright]
        simp
        ring
      · linarith [ht1]
  rw [hcoeff]

theorem centered_tent_intervalIntegral_eq_additive {f : ℕ → ℝ} {b X : ℝ} :
  ∫ t in X..(X + 1),
      (logRescalePartialSum f t - b) *
        (max (0 : ℝ) (2 - 2 * |(t - X) - (1 / 2 : ℝ)|))
    =
      ∫ t in (0 : ℝ)..1,
        centeredTentWeight t * (logRescalePartialSum f (X + t) - b) := by
  simpa [centeredTentWeight, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, mul_comm, mul_left_comm, mul_assoc] using
    (intervalIntegral.integral_comp_add_right
      (f := fun t : ℝ =>
        (logRescalePartialSum f t - b) *
          (max (0 : ℝ) (2 - 2 * |(t - X) - (1 / 2 : ℝ)|)))
      (a := (0 : ℝ)) (b := 1) X).symm

theorem compactFreqKernel_damped_eq_fourier {f : ℕ → ℝ} {b : ℝ} {ψ : ℝ → ℂ} {G : ℂ → ℂ} :
    (hGint : ∀ z : ℂ, 0 < z.re →
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ))) →
    (hGeq : Set.EqOn G
      (fun z : ℂ => ∫ x in Set.Ioi (0 : ℝ),
        (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
      {z : ℂ | 0 < z.re}) →
    (hψ : CompactFreqKernel ψ) →
    ∀ X σ : ℝ, 0 < σ →
      ∫ u in Set.Ioi (-X),
        ψ u * ((((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) *
          Complex.exp (-((σ : ℂ) * (X + u)))) =
        FourierTransform.fourier
          (fun ξ : ℝ => (FourierTransform.fourier ψ ξ) *
            G ((σ : ℂ) + (((( -2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I)))) X := by
  intro hGint hGeq hψ X σ hσ
  let U : ℝ → ℂ := fun x => (((logRescalePartialSum f x - b : ℝ) : ℂ))
  let F : ℝ → ℂ := Set.indicator (Set.Ioi (0 : ℝ)) (fun x => U x * Complex.exp (-((σ : ℂ) * x)) )
  let f0 : ℝ → ℂ := fun x => F (-x)
  let ψX : ℝ → ℂ := fun x => ψ (x - X)
  let g0 : ℝ → ℂ := fun ξ =>
    Complex.exp (-(Complex.I * (↑Real.pi * (↑(inner ℝ X ξ) * 2)))) * FourierTransform.fourier ψ ξ
  have hinner : ∀ x y : ℝ, inner ℝ x y = x * y := by
    intro x y
    have h1 : inner ℝ (1 : ℝ) y = y := by
      calc
        inner ℝ (1 : ℝ) y = inner ℝ (1 : ℝ) (y • (1 : ℝ)) := by simp
        _ = y * inner ℝ (1 : ℝ) (1 : ℝ) := by
          simpa [one_mul] using (real_inner_smul_right (1 : ℝ) (1 : ℝ) y)
        _ = y := by
          norm_num [real_inner_self_eq_norm_mul_norm]
    calc
      inner ℝ x y = inner ℝ (x • (1 : ℝ)) y := by simp
      _ = x * inner ℝ (1 : ℝ) y := by
        simpa [one_mul] using (real_inner_smul_left (1 : ℝ) y x)
      _ = x * y := by rw [h1]
  have hFint : MeasureTheory.Integrable F := by
    have hσ' : 0 < ((σ : ℂ).re) := by simpa using hσ
    simpa [F, U] using (hGint (σ : ℂ) hσ').integrable_indicator measurableSet_Ioi
  have hG_as_fourierInv : ∀ ξ : ℝ,
      G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))) = FourierTransformInv.fourierInv F ξ := by
    intro ξ
    have hz : 0 < (((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))).re) := by
      simpa
    rw [Real.fourierInv_eq' F ξ]
    simp_rw [F, smul_eq_mul]
    have hind :
        (fun v : ℝ =>
          Complex.exp (↑(2 * Real.pi * inner ℝ v ξ) * Complex.I) *
            (Set.Ioi (0 : ℝ)).indicator (fun x => U x * Complex.exp (-((σ : ℂ) * x))) v) =
          (Set.Ioi (0 : ℝ)).indicator
            (fun x => Complex.exp (↑(2 * Real.pi * inner ℝ x ξ) * Complex.I) *
              (U x * Complex.exp (-((σ : ℂ) * x)))) := by
      funext v
      by_cases hv : v ∈ Set.Ioi (0 : ℝ)
      · simp [hv, mul_assoc, mul_left_comm, mul_comm]
      · simp [hv]
    rw [hind, MeasureTheory.integral_indicator measurableSet_Ioi]
    have hEq := hGeq hz
    simpa [U, hinner, Complex.exp_add, mul_add, add_mul, mul_assoc, mul_left_comm, mul_comm] using hEq
  have hG_as_fourier : ∀ ξ : ℝ,
      G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))) = FourierTransform.fourier f0 ξ := by
    intro ξ
    rw [← Real.fourierInv_eq_fourier_comp_neg F]
    simpa [f0] using hG_as_fourierInv ξ
  have hf0_int : MeasureTheory.Integrable f0 := by
    simpa [f0, neg_mul] using (MeasureTheory.Integrable.comp_mul_left' (g := F) hFint (show (-1 : ℝ) ≠ 0 by norm_num))
  have hψ_fourier_int : MeasureTheory.Integrable (FourierTransform.fourier ψ) := by
    exact hψ.fourier_continuous.integrable_of_hasCompactSupport hψ.fourier_compact
  have hψX_cont : Continuous ψX := by
    simpa [ψX, sub_eq_add_neg] using hψ.continuous.comp (continuous_id.add continuous_const)
  have hψX_int : MeasureTheory.Integrable ψX := by
    simpa [ψX, sub_eq_add_neg] using hψ.integrable.comp_add_right (-X)
  have hg0_eq : g0 = FourierTransform.fourier ψX := by
    have htrans := VectorFourier.fourierIntegral_comp_add_right
      (V := ℝ) (W := ℝ) (e := Real.fourierChar) (μ := MeasureTheory.volume)
      (L := innerₗ ℝ) (f := ψ) (-X)
    simpa [g0, ψX, sub_eq_add_neg, Circle.smul_def, Real.fourierChar_apply,
      mul_assoc, mul_left_comm, mul_comm, add_comm, add_left_comm, add_assoc] using htrans.symm
  have hg0_int : MeasureTheory.Integrable g0 := by
    have hmod : MeasureTheory.Integrable (fun ξ : ℝ => Real.fourierChar (-inner ℝ ξ X) • FourierTransform.fourier ψ ξ) := by
      exact (Real.fourierIntegral_convergent_iff (μ := MeasureTheory.volume) (f := FourierTransform.fourier ψ) X).2 hψ_fourier_int
    simpa [g0, Circle.smul_def, Real.fourierChar_apply, hinner, mul_assoc, mul_left_comm, mul_comm] using hmod
  have hψX_fourier_int : MeasureTheory.Integrable (FourierTransform.fourier ψX) := by
    rw [← hg0_eq]
    exact hg0_int
  have hdouble : ∀ x : ℝ, FourierTransform.fourier g0 x = ψ (-x - X) := by
    intro x
    calc
      FourierTransform.fourier g0 x = FourierTransform.fourier (FourierTransform.fourier ψX) x := by rw [hg0_eq]
      _ = FourierTransformInv.fourierInv (FourierTransform.fourier ψX) (-x) := by
        simpa using (Real.fourierInv_eq_fourier_neg (FourierTransform.fourier ψX) (-x)).symm
      _ = ψX (-x) := by rw [hψX_cont.fourierInv_fourier_eq hψX_int hψX_fourier_int]
      _ = ψ (-x - X) := by simp [ψX]
  have hmain := VectorFourier.integral_fourierIntegral_smul_eq_flip
    (V := ℝ) (W := ℝ) (μ := MeasureTheory.volume) (ν := MeasureTheory.volume)
    (e := Real.fourierChar) (L := innerₗ ℝ)
    (f := f0) (g := g0) Real.continuous_fourierChar (by fun_prop) hf0_int hg0_int
  let J : ℝ → ℂ := fun ξ => FourierTransform.fourier ψ ξ *
    G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I)))
  have hleft :
      ∫ ξ : ℝ, FourierTransform.fourier f0 ξ * g0 ξ = FourierTransform.fourier J X := by
    calc
      ∫ ξ : ℝ, FourierTransform.fourier f0 ξ * g0 ξ
          = ∫ ξ : ℝ,
              G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))) *
                (Complex.exp (-(Complex.I * (↑Real.pi * (↑(inner ℝ X ξ) * 2)))) * FourierTransform.fourier ψ ξ) := by
              congr with ξ
              change FourierTransform.fourier f0 ξ *
                  (Complex.exp (-(Complex.I * (↑Real.pi * (↑(inner ℝ X ξ) * 2)))) * FourierTransform.fourier ψ ξ) =
                G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))) *
                  (Complex.exp (-(Complex.I * (↑Real.pi * (↑(inner ℝ X ξ) * 2)))) * FourierTransform.fourier ψ ξ)
              rw [hG_as_fourier ξ]
      _ = ∫ ξ : ℝ,
              Complex.exp (-(Complex.I * (↑Real.pi * (↑(inner ℝ X ξ) * 2)))) * J ξ := by
              congr with ξ
              simp [J, mul_assoc, mul_left_comm, mul_comm]
      _ = FourierTransform.fourier J X := by
              simpa [J, smul_eq_mul, hinner, mul_assoc, mul_left_comm, mul_comm] using
                (Real.fourier_real_eq_integral_exp_smul J X).symm
  let K : ℝ → ℂ := fun x => ψ (x - X) * (U x * Complex.exp (-((σ : ℂ) * x)))
  let H : ℝ → ℂ := (Set.Ioi (0 : ℝ)).indicator K
  have hright :
      ∫ x : ℝ, f0 x * FourierTransform.fourier g0 x =
        ∫ u in Set.Ioi (-X), ψ u * (U (X + u) * Complex.exp (-((σ : ℂ) * (X + u)))) := by
    have hfun : (fun x : ℝ => f0 x * FourierTransform.fourier g0 x) = fun x => H (-x) := by
      funext x
      by_cases hx : -x ∈ Set.Ioi (0 : ℝ)
      · simp [H, K, f0, F, hdouble, U, hx, mul_assoc, mul_left_comm, mul_comm]
      · simp [H, K, f0, F, hdouble, U, hx, mul_assoc, mul_left_comm, mul_comm]
    rw [hfun]
    have hneg : ∫ x : ℝ, H (-x) = ∫ y : ℝ, H y := by
      simpa using (MeasureTheory.integral_comp (f := LinearIsometryEquiv.neg ℝ) (g := H))
    rw [hneg]
    have hshift := (MeasureTheory.measurePreserving_add_right (μ := MeasureTheory.volume) X).integral_comp'
      (f := MeasurableEquiv.addRight X) H
    have hshift' : ∫ u : ℝ, H (u + X) = ∫ y : ℝ, H y := by
      simpa using hshift
    rw [← hshift']
    have hshift_fun :
        (fun u : ℝ => H (u + X)) =
          (Set.Ioi (-X)).indicator (fun u => ψ u * (U (X + u) * Complex.exp (-((σ : ℂ) * (X + u))))) := by
      funext u
      by_cases hu : u ∈ Set.Ioi (-X)
      · have hu' : u + X ∈ Set.Ioi (0 : ℝ) := by
          simp [Set.mem_Ioi] at hu ⊢
          linarith
        have hu'' : X + u ∈ Set.Ioi (0 : ℝ) := by simpa [add_comm] using hu'
        have hsub : X + u - X = u := by ring
        simp [H, K, hu, hu', hu'', hsub, sub_eq_add_neg, add_comm, add_left_comm, add_assoc,
          mul_assoc, mul_left_comm, mul_comm]
      · have hu' : u + X ∉ Set.Ioi (0 : ℝ) := by
          simp [Set.mem_Ioi] at hu ⊢
          linarith
        simp [H, hu, hu']
    rw [hshift_fun, MeasureTheory.integral_indicator measurableSet_Ioi]
  have hmain' :
      ∫ x : ℝ, f0 x * FourierTransform.fourier g0 x = ∫ ξ : ℝ, FourierTransform.fourier f0 ξ * g0 ξ := by
    simpa [smul_eq_mul, real_inner_comm, mul_assoc, mul_left_comm, mul_comm] using hmain.symm
  calc
    ∫ u in Set.Ioi (-X), ψ u * (U (X + u) * Complex.exp (-((σ : ℂ) * (X + u))))
        = ∫ x : ℝ, f0 x * FourierTransform.fourier g0 x := hright.symm
    _ = ∫ ξ : ℝ, FourierTransform.fourier f0 ξ * g0 ξ := hmain'
    _ = FourierTransform.fourier J X := hleft
    _ = FourierTransform.fourier
          (fun ξ : ℝ => (FourierTransform.fourier ψ ξ) *
            G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I)))) X := rfl

theorem compactFreqKernel_physical_tendsto {f : ℕ → ℝ} {b : ℝ} {ψ : ℝ → ℂ} :
    (hF : HasBoundaryLaplaceExtension f b) →
    (hψ : CompactFreqKernel ψ) →
    (hconv : ∀ X : ℝ,
      MeasureTheory.IntegrableOn
        (fun u : ℝ => ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))
        (Set.Ioi (-X))) →
    ∀ X : ℝ,
      Filter.Tendsto
        (fun σ : ℝ =>
          ∫ u in Set.Ioi (-X),
            ψ u * ((((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) *
              Complex.exp (-((σ : ℂ) * (X + u)))))
        (nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)))
        (nhds
          (∫ u in Set.Ioi (-X),
            ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))) := by
  intro hF hψ hconv X
  let g : ℝ → ℂ := fun u => ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ))
  let F : ℝ → ℝ → ℂ := fun σ u => g u * Complex.exp (-((σ : ℂ) * (X + u)))
  let μ : MeasureTheory.Measure ℝ := MeasureTheory.volume.restrict (Set.Ioi (-X))
  have hg_int_on : MeasureTheory.IntegrableOn g (Set.Ioi (-X)) := by
    simpa [g] using hconv X
  have hg_int : MeasureTheory.Integrable g μ := by
    simpa [μ] using hg_int_on
  have hF_meas :
      ∀ᶠ σ : ℝ in nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)),
        MeasureTheory.AEStronglyMeasurable (F σ) μ := by
    refine Filter.Eventually.of_forall ?_
    intro σ
    have hExp_cont : Continuous fun u : ℝ => Complex.exp (-((σ : ℂ) * (X + u))) := by
      continuity
    simpa [F] using hg_int.aestronglyMeasurable.mul hExp_cont.aestronglyMeasurable
  have h_bound :
      ∀ᶠ σ : ℝ in nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)),
        ∀ᵐ u ∂μ, ‖F σ u‖ ≤ ‖g u‖ := by
    have hσmem : ∀ᶠ σ : ℝ in nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)), σ ∈ Set.Ioi (0 : ℝ) := by
      show Set.Ioi (0 : ℝ) ∈ nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ))
      exact self_mem_nhdsWithin
    filter_upwards [hσmem] with σ hσmem
    refine MeasureTheory.ae_restrict_of_forall_mem (μ := MeasureTheory.volume) (s := Set.Ioi (-X)) measurableSet_Ioi ?_
    intro u hu
    have hu' : -X < u := by simpa using hu
    have hXu : 0 < X + u := by
      linarith
    have hσ : 0 < σ := hσmem
    have hExp_le : ‖Complex.exp (-((σ : ℂ) * (X + u)))‖ ≤ 1 := by
      rw [Complex.norm_exp]
      have hle : Complex.re (-((σ : ℂ) * (X + u))) ≤ 0 := by
        simp
        nlinarith [hσ, hXu]
      have hle' := Real.exp_le_exp.mpr hle
      simpa using hle'
    calc
      ‖F σ u‖ = ‖g u‖ * ‖Complex.exp (-((σ : ℂ) * (X + u)))‖ := by
        simp [F, norm_mul]
      _ ≤ ‖g u‖ * 1 := by
        exact mul_le_mul_of_nonneg_left hExp_le (norm_nonneg _)
      _ = ‖g u‖ := by simp
  have h_lim :
      ∀ᵐ u ∂μ,
        Filter.Tendsto (fun σ : ℝ => F σ u)
          (nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)))
          (nhds (g u)) := by
    refine Filter.Eventually.of_forall ?_
    intro u
    have hcont : ContinuousAt (fun σ : ℝ => F σ u) 0 := by
      have hcont' : Continuous fun σ : ℝ => F σ u := by
        continuity
      exact hcont'.continuousAt
    simpa [F] using hcont.continuousWithinAt.tendsto
  simpa [μ, F, g, mul_assoc] using
    MeasureTheory.tendsto_integral_filter_of_dominated_convergence
      (μ := μ) (bound := fun u => ‖g u‖) hF_meas h_bound (hg_int.norm) h_lim

theorem compactFreqKernel_convolution_eq_fourier {f : ℕ → ℝ} {b : ℝ} {ψ : ℝ → ℂ} :
    (hF : HasBoundaryLaplaceExtension f b) →
    (hψ : CompactFreqKernel ψ) →
    (hconv : ∀ X : ℝ,
      MeasureTheory.IntegrableOn
        (fun u : ℝ => ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))
        (Set.Ioi (-X))) →
    ∃ F : ℝ → ℂ, Continuous F ∧ HasCompactSupport F ∧
      ∀ X : ℝ,
        ∫ u in Set.Ioi (-X), ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) =
          FourierTransform.fourier F X := by
  intro hF hψ hconv
  classical
  rcases hF with ⟨G, hGcont, hGint, hGeq⟩
  have hF' : HasBoundaryLaplaceExtension f b := ⟨G, hGcont, hGint, hGeq⟩
  let F : ℝ → ℂ := fun ξ =>
    (FourierTransform.fourier ψ ξ) * G ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I))
  refine ⟨F, ?_, ?_, ?_⟩
  · have hGaxis : Continuous fun ξ : ℝ => G ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I)) := by
      refine hGcont.comp_continuous ?_ ?_
      · continuity
      · intro ξ
        simp
    simpa [F] using hψ.fourier_continuous.mul hGaxis
  · simpa [F] using hψ.fourier_compact.mul_right
  · intro X
    let phys : ℝ → ℂ := fun σ =>
      ∫ u in Set.Ioi (-X),
        ψ u * ((((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) *
          Complex.exp (-((σ : ℂ) * (X + u))))
    let freq : ℝ → ℂ := fun σ =>
      FourierTransform.fourier
        (fun ξ : ℝ => (FourierTransform.fourier ψ ξ) *
          G ((σ : ℂ) + ((((-2 * Real.pi * ξ : ℝ) : ℂ) * Complex.I)))) X
    have hphys : Filter.Tendsto phys
        (nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)))
        (nhds (∫ u in Set.Ioi (-X),
          ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))) := by
      simpa [phys] using compactFreqKernel_physical_tendsto hF' hψ hconv X
    have hfreq : Filter.Tendsto freq
        (nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)))
        (nhds (FourierTransform.fourier F X)) := by
      simpa [freq, F] using compactFreqKernel_frequency_tendsto hψ hGcont X
    have heq : phys =ᶠ[nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ))] freq := by
      have hIoi : Set.Ioi (0 : ℝ) ∈ nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ)) := by
        rw [Metric.mem_nhdsWithin_iff]
        refine ⟨1, by norm_num, ?_⟩
        intro y hy
        exact hy.2
      filter_upwards [hIoi] with σ hσ
      simpa [phys, freq] using compactFreqKernel_damped_eq_fourier hGint hGeq hψ X σ hσ
    haveI : Filter.NeBot (nhdsWithin (0 : ℝ) (Set.Ioi (0 : ℝ))) := nhdsWithin_Ioi_neBot le_rfl
    exact tendsto_nhds_unique_of_eventuallyEq hphys hfreq heq

theorem compactFreqKernel_tendsto_zero {f : ℕ → ℝ} {b : ℝ} {ψ : ℝ → ℂ} :
    (hF : HasBoundaryLaplaceExtension f b) →
    (hψ : CompactFreqKernel ψ) →
    (hconv : ∀ X : ℝ,
      MeasureTheory.IntegrableOn
        (fun u : ℝ => ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))
        (Set.Ioi (-X))) →
    Filter.Tendsto
      (fun X : ℝ =>
        ∫ u : ℝ, ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)))
      Filter.atTop (nhds 0) := by
  intro hF hψ hconv
  rcases compactFreqKernel_convolution_eq_fourier hF hψ hconv with ⟨F, hFcont, hFcomp, hEq⟩
  have hzero : Filter.Tendsto (fun X : ℝ => FourierTransform.fourier F X) (Filter.cocompact ℝ) (nhds 0) := by
    simpa using Real.zero_at_infty_fourier F
  have hzero' : Filter.Tendsto (fun X : ℝ => FourierTransform.fourier F X) Filter.atTop (nhds 0) := by
    exact hzero.mono_left (by simp)
  have htail : Filter.Tendsto
      (fun X : ℝ => ∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ)))
      Filter.atTop (nhds 0) := by
    simpa using compactFreqKernel_negativeTail_tendsto_zero (hψ := hψ) (c := (((-b : ℝ) : ℂ)))
  have hdecomp :
      (fun X : ℝ =>
        ∫ u : ℝ, ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ))) =
      (fun X : ℝ =>
        FourierTransform.fourier F X +
          ∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ))) := by
    funext X
    let g : ℝ → ℂ := fun u => ψ u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ))
    have hpos_int_ioi : MeasureTheory.IntegrableOn g (Set.Ioi (-X)) := by
      simpa [g] using hconv X
    have hpos_int_ici : MeasureTheory.IntegrableOn g (Set.Ici (-X)) := by
      exact hpos_int_ioi.congr_set_ae ((MeasureTheory.Ioi_ae_eq_Ici (μ := MeasureTheory.volume) (a := -X)).symm)
    have hconst_int : MeasureTheory.Integrable (fun u : ℝ => ψ u * (((-b : ℝ) : ℂ))) := by
      simpa using hψ.integrable.mul_const (((-b : ℝ) : ℂ))
    have hneg_int_iio : MeasureTheory.IntegrableOn g (Set.Iio (-X)) := by
      refine (hconst_int.integrableOn).congr_fun ?_ measurableSet_Iio
      intro u hu
      have hu' : u < -X := hu
      have hxu : X + u < 0 := by
        have hsum : X + u < X + -X := add_lt_add_right hu' X
        simpa using hsum
      have hnot : ¬ 0 ≤ X + u := not_le.mpr hxu
      simp [g, logRescalePartialSum, hnot]
    have hsplit' :
        (∫ u in Set.Iio (-X), g u) +
          (∫ u in Set.Ici (-X), g u) =
        ∫ u : ℝ, g u := by
      exact intervalIntegral.integral_Iio_add_Ici (b := -X) (f := g) hneg_int_iio hpos_int_ici
    have htail_eq :
        ∫ u in Set.Iio (-X), g u =
          ∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ)) := by
      calc
        ∫ u in Set.Iio (-X), g u =
            ∫ u in Set.Iio (-X), ψ u * (((-b : ℝ) : ℂ)) := by
          refine MeasureTheory.setIntegral_congr_fun measurableSet_Iio ?_
          intro u hu
          have hu' : u < -X := hu
          have hxu : X + u < 0 := by
            have hsum : X + u < X + -X := add_lt_add_right hu' X
            simpa using hsum
          have hnot : ¬ 0 ≤ X + u := not_le.mpr hxu
          simp [g, logRescalePartialSum, hnot]
        _ = ∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ)) := by
          simpa using
            (MeasureTheory.integral_Iic_eq_integral_Iio
              (μ := MeasureTheory.volume)
              (x := -X)
              (f := fun u : ℝ => ψ u * (((-b : ℝ) : ℂ)))).symm
    have hEqg :
        ∫ u in Set.Ioi (-X), g u = FourierTransform.fourier F X := by
      simpa [g] using hEq X
    calc
      ∫ u : ℝ, g u =
          (∫ u in Set.Iio (-X), g u) +
            (∫ u in Set.Ici (-X), g u) := by
        simpa using hsplit'.symm
      _ =
          (∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ))) +
            (∫ u in Set.Ioi (-X), g u) := by
        rw [htail_eq, MeasureTheory.integral_Ici_eq_integral_Ioi (μ := MeasureTheory.volume) (x := -X) (f := g)]
      _ =
          (∫ u in Set.Ioi (-X), g u) +
            (∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ))) := by
        rw [add_comm]
      _ = FourierTransform.fourier F X +
            (∫ u in Set.Iic (-X), ψ u * (((-b : ℝ) : ℂ))) := by
        rw [hEqg]
  rw [hdecomp]
  simpa using hzero'.add htail

theorem eventual_pos_of_quasi_monotone_and_unitIntervalAverage {f : ℕ → ℝ} {b : ℝ} :
    (hb : 0 < b) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hqm : ∀ {x y : ℝ}, 0 ≤ x → 0 ≤ y →
      logRescalePartialSum f x ≤ Real.exp y * logRescalePartialSum f (x + y)) →
    (havg : Filter.Tendsto (fun X : ℝ => ∫ t in X - 1..X, logRescalePartialSum f t)
      Filter.atTop (nhds b)) →
    ∃ c : ℝ, 0 < c ∧ ∃ x₀ : ℝ, ∀ x : ℝ, x₀ ≤ x → c ≤ logRescalePartialSum f x := by
  intro hb hnonneg hqm havg
  let U : ℝ → ℝ := logRescalePartialSum f
  have hU_nonneg : ∀ x : ℝ, 0 ≤ U x := by
    intro x
    dsimp [U, logRescalePartialSum]
    split_ifs with hx
    · refine mul_nonneg ?_ ?_
      · positivity
      · exact Finset.sum_nonneg (by
          intro k hk
          exact hnonneg k)
    · positivity
  have hEventuallyAvg : ∀ᶠ X in Filter.atTop, b / 2 < ∫ t in X - 1..X, U t := by
    have hmem : Set.Ioi (b / 2) ∈ nhds b := by
      exact Ioi_mem_nhds (by linarith [hb])
    simpa [U] using havg hmem
  rcases Filter.eventually_atTop.mp hEventuallyAvg with ⟨x1, hx1⟩
  refine ⟨b / 2 / Real.exp 1, ?_, max x1 1, ?_⟩
  · positivity
  · intro x hx
    have hx1_le : x1 ≤ x := le_trans (le_max_left _ _) hx
    have hx_ge_one : 1 ≤ x := le_trans (le_max_right _ _) hx
    have hAvgLower : b / 2 < ∫ t in x - 1..x, U t := hx1 x hx1_le
    have hpoint : ∀ t ∈ Set.uIoc (x - 1) x, ‖U t‖ ≤ Real.exp 1 * U x := by
      intro t ht
      have hxx : x - 1 ≤ x := by linarith
      have ht' : t ∈ Set.Ioc (x - 1) x := by
        simpa [Set.uIoc_of_le hxx] using ht
      have hlt : x - 1 < t := ht'.1
      have hle : t ≤ x := ht'.2
      have htnonneg : 0 ≤ t := by linarith
      have hyt : 0 ≤ x - t := by linarith
      have hsum : t + (x - t) = x := by ring
      have hq : U t ≤ Real.exp (x - t) * U x := by
        simpa [U, hsum] using hqm (x := t) (y := x - t) htnonneg hyt
      have hxt_le_one : x - t ≤ 1 := by linarith
      have hexp_le : Real.exp (x - t) ≤ Real.exp 1 := by
        gcongr
      have hmul : Real.exp (x - t) * U x ≤ Real.exp 1 * U x := by
        exact mul_le_mul_of_nonneg_right hexp_le (hU_nonneg x)
      have hq' : U t ≤ Real.exp 1 * U x := le_trans hq hmul
      simpa [Real.norm_eq_abs, abs_of_nonneg (hU_nonneg t)] using hq'
    have hnorm : ‖∫ t in x - 1..x, U t‖ ≤ Real.exp 1 * U x := by
      have htmp := intervalIntegral.norm_integral_le_of_norm_le_const (a := x - 1) (b := x) (f := U)
        (C := Real.exp 1 * U x) hpoint
      have hxlen : |x - (x - 1)| = 1 := by
        have : x - (x - 1) = 1 := by ring
        rw [this, abs_of_nonneg (by norm_num : (0 : ℝ) ≤ 1)]
      simpa [hxlen] using htmp
    have hIntNonneg : 0 ≤ ∫ t in x - 1..x, U t := by
      refine intervalIntegral.integral_nonneg ?_ ?_
      · linarith
      · intro t ht
        exact hU_nonneg t
    have hIntUpper : ∫ t in x - 1..x, U t ≤ Real.exp 1 * U x := by
      simpa [Real.norm_eq_abs, abs_of_nonneg hIntNonneg] using hnorm
    have hbound : b / 2 < Real.exp 1 * U x := lt_of_lt_of_le hAvgLower hIntUpper
    have hxlower : b / 2 / Real.exp 1 < U x := by
      have hpos : 0 < Real.exp 1 := Real.exp_pos 1
      rw [div_lt_iff₀' hpos]
      simpa [mul_comm, mul_left_comm, mul_assoc] using hbound
    exact le_of_lt hxlower

theorem intervalIntegral_compare_leftTent_compactKernel {f : ℕ → ℝ} {b C δ X : ℝ} {ψ : ℝ → ℂ} :
  CompactFreqKernel ψ →
  (∀ t ∈ Set.Icc (0 : ℝ) 1, |logRescalePartialSum f (X + t) - b| ≤ C) →
  (∫ u : ℝ, ‖leftTentKernel u - ψ u‖ ≤ δ) →
  0 ≤ C →
  0 ≤ δ →
  |(∫ t in (0 : ℝ)..1,
      (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re *
        (logRescalePartialSum f (X + t) - b)) -
    (∫ t in (0 : ℝ)..1,
      ((ψ (t - (1 / 2 : ℝ))).re + (ψ ((1 / 2 : ℝ) - t)).re) *
        (logRescalePartialSum f (X + t) - b))| ≤
    2 * C * δ := by
  intro hψ hbound hδ hC0 hδ0
  let g : ℝ → ℝ := fun t => logRescalePartialSum f (X + t) - b
  let K : ℝ → ℝ := fun u => ‖leftTentKernel u - ψ u‖
  have h01 : (0 : ℝ) ≤ 1 := by norm_num
  have hKint : MeasureTheory.Integrable K := by
    simp [K]
    simpa using (leftTentKernel_integrable.sub hψ.integrable).norm
  have hsum_meas : Measurable (fun x : ℝ => ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) := by
    let s : ℕ → ℝ := fun n => ∑ k ∈ Finset.Icc 1 n, f k
    have hs : Measurable s := measurable_from_nat
    simpa [s] using hs.comp ((Real.continuous_exp.measurable).nat_floor)
  have hlog_meas : Measurable (logRescalePartialSum f) := by
    unfold logRescalePartialSum
    refine Measurable.ite measurableSet_Ici ?_ measurable_const
    exact ((Real.continuous_exp.comp continuous_neg).measurable.mul hsum_meas)
  have hg_meas : Measurable g := by
    simpa [g] using ((hlog_meas.comp (measurable_const.add measurable_id)).sub measurable_const)
  have hg_ae : MeasureTheory.AEStronglyMeasurable g ((MeasureTheory.volume).restrict (Set.uIoc (0 : ℝ) 1)) := by
    simpa using (hg_meas.aestronglyMeasurable.restrict (s := Set.uIoc (0 : ℝ) 1))
  have hg_bound_ae : ∀ᵐ t ∂((MeasureTheory.volume).restrict (Set.uIoc (0 : ℝ) 1)), ‖g t‖ ≤ C := by
    rw [MeasureTheory.ae_restrict_iff' measurableSet_uIoc]
    refine Filter.Eventually.of_forall ?_
    intro t ht
    have htIoc : t ∈ Set.Ioc (0 : ℝ) 1 := by
      simpa [Set.uIoc_of_le h01] using ht
    have ht' : t ∈ Set.Icc (0 : ℝ) 1 := ⟨le_of_lt htIoc.1, htIoc.2⟩
    simpa [g, Real.norm_eq_abs] using hbound t ht'
  have hkL1 : MeasureTheory.Integrable (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re) := by
    simpa [sub_eq_add_neg] using (leftTentKernel_integrable.comp_add_right (-(1 / 2 : ℝ))).re
  have hkP1 : MeasureTheory.Integrable (fun t : ℝ => (ψ (t - (1 / 2 : ℝ))).re) := by
    simpa [sub_eq_add_neg] using (hψ.integrable.comp_add_right (-(1 / 2 : ℝ))).re
  have hkL2 : MeasureTheory.Integrable (fun t : ℝ => (leftTentKernel ((1 / 2 : ℝ) - t)).re) := by
    simpa [sub_eq_add_neg] using (leftTentKernel_integrable.comp_sub_left (1 / 2 : ℝ)).re
  have hkP2 : MeasureTheory.Integrable (fun t : ℝ => (ψ ((1 / 2 : ℝ) - t)).re) := by
    simpa [sub_eq_add_neg] using (hψ.integrable.comp_sub_left (1 / 2 : ℝ)).re
  have hL1 : IntervalIntegrable (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) MeasureTheory.volume 0 1 := by
    rw [intervalIntegrable_iff]
    exact (hkL1.intervalIntegrable.def').mul_bdd hg_ae hg_bound_ae
  have hP1 : IntervalIntegrable (fun t : ℝ => (ψ (t - (1 / 2 : ℝ))).re * g t) MeasureTheory.volume 0 1 := by
    rw [intervalIntegrable_iff]
    exact (hkP1.intervalIntegrable.def').mul_bdd hg_ae hg_bound_ae
  have hL2 : IntervalIntegrable (fun t : ℝ => (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) MeasureTheory.volume 0 1 := by
    rw [intervalIntegrable_iff]
    exact (hkL2.intervalIntegrable.def').mul_bdd hg_ae hg_bound_ae
  have hP2 : IntervalIntegrable (fun t : ℝ => (ψ ((1 / 2 : ℝ) - t)).re * g t) MeasureTheory.volume 0 1 := by
    rw [intervalIntegrable_iff]
    exact (hkP2.intervalIntegrable.def').mul_bdd hg_ae hg_bound_ae
  have hB1 : IntervalIntegrable (fun t : ℝ => C * K (t - (1 / 2 : ℝ))) MeasureTheory.volume 0 1 := by
    simpa [K, sub_eq_add_neg] using ((hKint.comp_add_right (-(1 / 2 : ℝ))).intervalIntegrable.const_mul C)
  have hB2 : IntervalIntegrable (fun t : ℝ => C * K ((1 / 2 : ℝ) - t)) MeasureTheory.volume 0 1 := by
    simpa [K, sub_eq_add_neg] using ((hKint.comp_sub_left (1 / 2 : ℝ)).intervalIntegrable.const_mul C)
  have hpiece1 :
      |(∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
        (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)| ≤
        ∫ t in (0 : ℝ)..1, C * K (t - (1 / 2 : ℝ)) := by
    calc
      |(∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
          (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)| =
          ‖∫ t in (0 : ℝ)..1,
            ((leftTentKernel (t - (1 / 2 : ℝ))).re * g t - (ψ (t - (1 / 2 : ℝ))).re * g t)‖ := by
            rw [← intervalIntegral.integral_sub hL1 hP1, Real.norm_eq_abs]
      _ ≤ ∫ t in (0 : ℝ)..1, C * K (t - (1 / 2 : ℝ)) := by
        exact intervalIntegral.norm_integral_le_of_norm_le (μ := MeasureTheory.volume) h01
          (Filter.Eventually.of_forall (fun t ht => by
            have ht' : t ∈ Set.Icc (0 : ℝ) 1 := ⟨le_of_lt ht.1, ht.2⟩
            have hgt : |g t| ≤ C := hbound t ht'
            have hrew :
                (leftTentKernel (t - (1 / 2 : ℝ))).re * g t - (ψ (t - (1 / 2 : ℝ))).re * g t =
                  ((leftTentKernel (t - (1 / 2 : ℝ)) - ψ (t - (1 / 2 : ℝ))).re) * g t := by
              simp [sub_mul]
            rw [hrew, Real.norm_eq_abs, abs_mul]
            calc
              |(leftTentKernel (t - (1 / 2 : ℝ)) - ψ (t - (1 / 2 : ℝ))).re| * |g t|
                  ≤ K (t - (1 / 2 : ℝ)) * C := by
                    gcongr
                    · simpa [K] using (RCLike.abs_re_le_norm (leftTentKernel (t - (1 / 2 : ℝ)) - ψ (t - (1 / 2 : ℝ))))
              _ = C * K (t - (1 / 2 : ℝ)) := by ring)) hB1
  have hpiece2 :
      |(∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
        (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)| ≤
        ∫ t in (0 : ℝ)..1, C * K ((1 / 2 : ℝ) - t) := by
    calc
      |(∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
          (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)| =
          ‖∫ t in (0 : ℝ)..1,
            ((leftTentKernel ((1 / 2 : ℝ) - t)).re * g t - (ψ ((1 / 2 : ℝ) - t)).re * g t)‖ := by
            rw [← intervalIntegral.integral_sub hL2 hP2, Real.norm_eq_abs]
      _ ≤ ∫ t in (0 : ℝ)..1, C * K ((1 / 2 : ℝ) - t) := by
        exact intervalIntegral.norm_integral_le_of_norm_le (μ := MeasureTheory.volume) h01
          (Filter.Eventually.of_forall (fun t ht => by
            have ht' : t ∈ Set.Icc (0 : ℝ) 1 := ⟨le_of_lt ht.1, ht.2⟩
            have hgt : |g t| ≤ C := hbound t ht'
            have hrew :
                (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t - (ψ ((1 / 2 : ℝ) - t)).re * g t =
                  ((leftTentKernel ((1 / 2 : ℝ) - t) - ψ ((1 / 2 : ℝ) - t)).re) * g t := by
              simp [sub_mul]
            rw [hrew, Real.norm_eq_abs, abs_mul]
            calc
              |(leftTentKernel ((1 / 2 : ℝ) - t) - ψ ((1 / 2 : ℝ) - t)).re| * |g t|
                  ≤ K ((1 / 2 : ℝ) - t) * C := by
                    gcongr
                    · simpa [K] using (RCLike.abs_re_le_norm (leftTentKernel ((1 / 2 : ℝ) - t) - ψ ((1 / 2 : ℝ) - t)))
              _ = C * K ((1 / 2 : ℝ) - t) := by ring)) hB2
  have hmono : ∫ u in Set.Ioc (-(1 / 2 : ℝ)) (1 / 2 : ℝ), K u ≤ ∫ u in Set.univ, K u := by
    exact MeasureTheory.setIntegral_mono_set (s := Set.Ioc (-(1 / 2 : ℝ)) (1 / 2 : ℝ)) (t := Set.univ)
      (by simpa using hKint)
      (by
        show 0 ≤ᵐ[((MeasureTheory.volume).restrict Set.univ)] K
        exact Filter.Eventually.of_forall (fun u => by simp [K]))
      (Set.subset_univ _).eventuallyLE
  have hKsmall : ∫ u in (-(1 / 2 : ℝ))..(1 / 2 : ℝ), K u ≤ δ := by
    calc
      ∫ u in (-(1 / 2 : ℝ))..(1 / 2 : ℝ), K u
          = ∫ u in Set.Ioc (-(1 / 2 : ℝ)) (1 / 2 : ℝ), K u := by
              rw [intervalIntegral.integral_of_le]
              norm_num
      _ ≤ ∫ u in Set.univ, K u := hmono
      _ = ∫ u : ℝ, K u := by simp
      _ ≤ δ := hδ
  have hCKsmall : ∫ u in (-(1 / 2 : ℝ))..(1 / 2 : ℝ), C * K u ≤ C * δ := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left hKsmall hC0
  have hpiece1' :
      |(∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
        (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)| ≤ C * δ := by
    calc
      |(∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
          (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)| ≤
          ∫ t in (0 : ℝ)..1, C * K (t - (1 / 2 : ℝ)) := hpiece1
      _ = ∫ u in (-(1 / 2 : ℝ))..(1 / 2 : ℝ), C * K u := by
            convert (intervalIntegral.integral_comp_sub_right (f := fun u : ℝ => C * K u)
              (a := (0 : ℝ)) (b := 1) (d := (1 / 2 : ℝ))) using 1
            ring_nf
      _ ≤ C * δ := hCKsmall
  have hpiece2' :
      |(∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
        (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)| ≤ C * δ := by
    calc
      |(∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
          (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)| ≤
          ∫ t in (0 : ℝ)..1, C * K ((1 / 2 : ℝ) - t) := hpiece2
      _ = ∫ u in (-(1 / 2 : ℝ))..(1 / 2 : ℝ), C * K u := by
            convert (intervalIntegral.integral_comp_sub_left (f := fun u : ℝ => C * K u)
              (a := (0 : ℝ)) (b := 1) (d := (1 / 2 : ℝ))) using 1
            ring_nf
      _ ≤ C * δ := hCKsmall
  have hsplitL :
      (∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) =
      (∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) +
        (∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) := by
    rw [show (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) =
        (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re * g t + (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) by
        funext t; simp [add_mul], intervalIntegral.integral_add hL1 hL2]
  have hsplitP :
      (∫ t in (0 : ℝ)..1,
        ((ψ (t - (1 / 2 : ℝ))).re + (ψ ((1 / 2 : ℝ) - t)).re) * g t) =
      (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t) +
        (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t) := by
    rw [show (fun t : ℝ => ((ψ (t - (1 / 2 : ℝ))).re + (ψ ((1 / 2 : ℝ) - t)).re) * g t) =
        (fun t : ℝ => (ψ (t - (1 / 2 : ℝ))).re * g t + (ψ ((1 / 2 : ℝ) - t)).re * g t) by
        funext t; ring, intervalIntegral.integral_add hP1 hP2]
  have hsplitL' :
      (∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re *
          (logRescalePartialSum f (X + t) - b)) =
      (∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) +
        (∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) := by
    simpa [g] using hsplitL
  have hsplitP' :
      (∫ t in (0 : ℝ)..1,
        ((ψ (t - (1 / 2 : ℝ))).re + (ψ ((1 / 2 : ℝ) - t)).re) *
          (logRescalePartialSum f (X + t) - b)) =
      (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t) +
        (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t) := by
    simpa [g] using hsplitP
  calc
    |(∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ)) + leftTentKernel ((1 / 2 : ℝ) - t)).re *
          (logRescalePartialSum f (X + t) - b)) -
      (∫ t in (0 : ℝ)..1,
        ((ψ (t - (1 / 2 : ℝ))).re + (ψ ((1 / 2 : ℝ) - t)).re) *
          (logRescalePartialSum f (X + t) - b))|
        = |((∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) +
              (∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t)) -
            ((∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t) +
              (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t))| := by
              rw [hsplitL', hsplitP']
    _ = |((∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
            (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)) +
          ((∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
            (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t))| := by ring_nf
    _ ≤ |(∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
            (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t)| +
          |(∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
            (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)| := by
            simpa [Real.norm_eq_abs] using
              (norm_add_le
                ((∫ t in (0 : ℝ)..1, (leftTentKernel (t - (1 / 2 : ℝ))).re * g t) -
                  (∫ t in (0 : ℝ)..1, (ψ (t - (1 / 2 : ℝ))).re * g t))
                ((∫ t in (0 : ℝ)..1, (leftTentKernel ((1 / 2 : ℝ) - t)).re * g t) -
                  (∫ t in (0 : ℝ)..1, (ψ ((1 / 2 : ℝ) - t)).re * g t)))
    _ ≤ C * δ + C * δ := add_le_add hpiece1' hpiece2'
    _ = 2 * C * δ := by ring

noncomputable def leftTentAverage (f : ℕ → ℝ) (X : ℝ) : ℝ :=
  ∫ t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t

theorem eventual_pos_of_quasi_monotone_and_leftTentAverage {f : ℕ → ℝ} {b : ℝ} :
    (hb : 0 < b) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hqm : ∀ {x y : ℝ}, 0 ≤ x → 0 ≤ y →
      logRescalePartialSum f x ≤ Real.exp y * logRescalePartialSum f (x + y)) →
    (havg : Filter.Tendsto (fun X : ℝ => leftTentAverage f X)
      Filter.atTop (nhds b)) →
    ∃ c : ℝ, 0 < c ∧ ∃ x₀ : ℝ, ∀ x : ℝ, x₀ ≤ x → c ≤ logRescalePartialSum f x := by
  intro hb hnonneg hqm havg
  let U : ℝ → ℝ := logRescalePartialSum f
  have hU_nonneg : ∀ x : ℝ, 0 ≤ U x := by
    intro x
    by_cases hx : 0 ≤ x
    · dsimp [U, logRescalePartialSum]
      rw [if_pos hx]
      refine mul_nonneg (le_of_lt (Real.exp_pos (-x))) ?_
      exact Finset.sum_nonneg (by
        intro n hn
        exact hnonneg n)
    · dsimp [U, logRescalePartialSum]
      rw [if_neg hx]
  have havg_pos : ∀ᶠ X in Filter.atTop, b / 2 < leftTentAverage f X := by
    have hb2ltb : b / 2 < b := by linarith
    have hmem : Set.Ioi (b / 2) ∈ nhds b := Ioi_mem_nhds hb2ltb
    have hpre : ∀ᶠ X in Filter.atTop, leftTentAverage f X ∈ Set.Ioi (b / 2) := havg hmem
    simpa [Set.mem_Ioi] using hpre
  rcases Filter.eventually_atTop.1 havg_pos with ⟨X₀, hX₀⟩
  refine ⟨b / (2 * Real.exp 1), ?_, max X₀ 1, ?_⟩
  · have hexp : 0 < Real.exp 1 := Real.exp_pos 1
    positivity
  · intro X hX
    have hX₀X : X₀ ≤ X := le_trans (le_max_left _ _) hX
    have hX1 : 1 ≤ X := le_trans (le_max_right _ _) hX
    have hhalf_lt : b / 2 < leftTentAverage f X := hX₀ X hX₀X
    have hb2pos : 0 < b / 2 := by linarith
    have hleft_ne_zero : leftTentAverage f X ≠ 0 := by
      intro hzero
      rw [hzero] at hhalf_lt
      linarith
    have hfi : IntervalIntegrable (fun t : ℝ => (2 * (t - (X - 1))) * U t) MeasureTheory.volume (X - 1) X := by
      apply intervalIntegral.intervalIntegrable_of_integral_ne_zero
      simpa [leftTentAverage, U] using hleft_ne_zero
    have hgi_base : IntervalIntegrable (fun t : ℝ => 2 * (t - (X - 1))) MeasureTheory.volume (X - 1) X := by
      exact (by continuity : Continuous (fun t : ℝ => 2 * (t - (X - 1)))).intervalIntegrable (X - 1) X
    have hgi : IntervalIntegrable (fun t : ℝ => (2 * (t - (X - 1))) * (Real.exp 1 * U X)) MeasureTheory.volume (X - 1) X := by
      simpa using hgi_base.mul_const (Real.exp 1 * U X)
    have havg_le : leftTentAverage f X ≤ Real.exp 1 * U X := by
      unfold leftTentAverage
      change ∫ t in X - 1..X, (2 * (t - (X - 1))) * U t ≤ Real.exp 1 * U X
      calc
        ∫ t in X - 1..X, (2 * (t - (X - 1))) * U t
          ≤ ∫ t in X - 1..X, (2 * (t - (X - 1))) * (Real.exp 1 * U X) := by
              apply intervalIntegral.integral_mono_on
              · linarith
              · exact hfi
              · exact hgi
              · intro t ht
                have hw_nonneg : 0 ≤ 2 * (t - (X - 1)) := by nlinarith [ht.1]
                have ht_nonneg : 0 ≤ t := by linarith [hX1, ht.1]
                have hXt_nonneg : 0 ≤ X - t := by linarith [ht.2]
                have hsum : t + (X - t) = X := by ring
                have hU_le : U t ≤ Real.exp (X - t) * U X := by
                  simpa [hsum] using hqm (x := t) (y := X - t) ht_nonneg hXt_nonneg
                have hXt_le_one : X - t ≤ 1 := by linarith [ht.1]
                have hExp_le : Real.exp (X - t) ≤ Real.exp 1 := Real.exp_monotone hXt_le_one
                have hU_le' : U t ≤ Real.exp 1 * U X := by
                  calc
                    U t ≤ Real.exp (X - t) * U X := hU_le
                    _ ≤ Real.exp 1 * U X := mul_le_mul_of_nonneg_right hExp_le (hU_nonneg X)
                exact mul_le_mul_of_nonneg_left hU_le' hw_nonneg
        _ = Real.exp 1 * U X := by
              have hweight : ∫ t in X - 1..X, (2 * (t - (X - 1)) : ℝ) = 1 := by
                have hshift : (∫ t in X - 1..X, (2 : ℝ) * (t - (X - 1))) = ∫ u in (0 : ℝ)..1, (2 : ℝ) * u := by
                  simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
                    (intervalIntegral.integral_comp_sub_right (f := fun u : ℝ => (2 : ℝ) * u) (a := X - 1) (b := X) (d := X - 1))
                calc
                  ∫ t in X - 1..X, (2 * (t - (X - 1)) : ℝ)
                      = ∫ u in (0 : ℝ)..1, (2 : ℝ) * u := by simpa [mul_comm] using hshift
                  _ = (2 : ℝ) * ∫ u in (0 : ℝ)..1, u := by rw [intervalIntegral.integral_const_mul]
                  _ = (2 : ℝ) * ((1 ^ 2 - (0 : ℝ) ^ 2) / 2) := by rw [integral_id]
                  _ = 1 := by norm_num
              rw [intervalIntegral.integral_mul_const, hweight, one_mul]
    have hmul_lt : b / 2 < Real.exp 1 * U X := lt_of_lt_of_le hhalf_lt havg_le
    have hden_pos : 0 < 2 * Real.exp 1 := by positivity
    have hc_lt : b / (2 * Real.exp 1) < U X := by
      rw [div_lt_iff₀ hden_pos]
      have hmul2 : b < 2 * (Real.exp 1 * U X) := by linarith
      simpa [mul_assoc, mul_comm, mul_left_comm] using hmul2
    exact hc_lt.le

theorem leftTent_reflect_pairing_eq_shift_comp_sub {f : ℕ → ℝ} {b X : ℝ} :
  ∫ t in (0 : ℝ)..1,
      (leftTentKernel ((1 / 2 : ℝ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
    =
      ∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ))).re *
          (logRescalePartialSum f (X + 1 - t) - b) := by
  convert
    (intervalIntegral.integral_comp_sub_left
      (f := fun s : ℝ =>
        (leftTentKernel (s - (1 / 2 : ℝ))).re *
          (logRescalePartialSum f (X + 1 - s) - b))
      (a := (0 : ℝ)) (b := (1 : ℝ)) (d := (1 : ℝ))) using 1
  · congr with t
    ring
  · ring_nf

theorem logRescalePartialSum_le_sum_floor_exp_bound {f : ℕ → ℝ} :
  (∀ n, 0 ≤ f n) →
  ∀ {x B : ℝ}, 0 ≤ x → x ≤ B →
    logRescalePartialSum f x ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp B⌋₊, f k := by
  intro hnonneg x B hx0 hxB
  unfold logRescalePartialSum
  rw [if_pos hx0]
  have hsum_nonneg : 0 ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k := by
    exact Finset.sum_nonneg (by
      intro k hk
      exact hnonneg k)
  have hexp_le_one : Real.exp (-x) ≤ 1 := by
    have hneg : -x ≤ 0 := by linarith
    simpa using Real.exp_le_one_iff.mpr hneg
  have hfloor_le : ⌊Real.exp x⌋₊ ≤ ⌊Real.exp B⌋₊ := by
    exact Nat.floor_le_floor (by
      gcongr)
  have hsum_le :
      ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp B⌋₊, f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnon
    · intro k hk
      rw [Finset.mem_Icc] at hk ⊢
      exact ⟨hk.1, le_trans hk.2 hfloor_le⟩
    · intro k hk1 hk2
      exact hnonneg k
  have hmul_le :
      Real.exp (-x) * (∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k) ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k := by
    nlinarith [mul_le_mul_of_nonneg_right hexp_le_one hsum_nonneg]
  exact le_trans hmul_le hsum_le

theorem logRescalePartialSum_nonneg {f : ℕ → ℝ} :
  (∀ n, 0 ≤ f n) → ∀ x : ℝ, 0 ≤ logRescalePartialSum f x := by
  intro hnonneg x
  by_cases hx : 0 ≤ x
  · simp [logRescalePartialSum, hx]
    exact mul_nonneg (Real.exp_nonneg (-x)) (Finset.sum_nonneg (by
      intro n hn
      exact hnonneg n))
  · simp [logRescalePartialSum, hx]

theorem logRescalePartialSum_quasi_monotone {f : ℕ → ℝ} :
    (hnonneg : ∀ n, 0 ≤ f n) →
    ∀ {x y : ℝ}, 0 ≤ x → 0 ≤ y →
      logRescalePartialSum f x ≤ Real.exp y * logRescalePartialSum f (x + y) := by
  intro hnonneg x y hx hy
  have hxy : 0 ≤ x + y := add_nonneg hx hy
  simp only [logRescalePartialSum, if_pos hx, if_pos hxy]
  have hfloor : ⌊Real.exp x⌋₊ ≤ ⌊Real.exp (x + y)⌋₊ := by
    apply Nat.floor_mono
    exact Real.exp_le_exp.mpr (le_add_of_nonneg_right hy)
  have hsum : ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp (x + y)⌋₊, f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnn
    · intro k hk
      exact Finset.mem_Icc.mpr ⟨(Finset.mem_Icc.mp hk).1, le_trans (Finset.mem_Icc.mp hk).2 hfloor⟩
    · intro k hk hkn
      exact hnonneg k
  have hexp : Real.exp (-x) = Real.exp y * Real.exp (-(x + y)) := by
    calc
      Real.exp (-x) = Real.exp (y + (-(x + y))) := by
        congr 1
        ring
      _ = Real.exp y * Real.exp (-(x + y)) := by
        rw [Real.exp_add]
  rw [hexp, mul_assoc]
  exact mul_le_mul_of_nonneg_left
    (mul_le_mul_of_nonneg_left hsum (by positivity))
    (by positivity)

theorem measurable_logRescalePartialSum {f : ℕ → ℝ} : Measurable (logRescalePartialSum f) := by
  classical
  unfold logRescalePartialSum
  let F : ℕ → ℝ := fun n => ∑ k ∈ Finset.Icc 1 n, f k
  have hF : Measurable F := by
    simpa [F] using (measurable_from_nat : Measurable F)
  have hfloor : Measurable fun x : ℝ => ⌊Real.exp x⌋₊ :=
    Measurable.nat_floor Real.measurable_exp
  have hsum : Measurable fun x : ℝ => F ⌊Real.exp x⌋₊ := hF.comp hfloor
  have hexpneg : Measurable fun x : ℝ => Real.exp (-x) :=
    Real.measurable_exp.comp measurable_neg
  refine Measurable.ite ?_ ?_ measurable_const
  · exact measurableSet_Ici
  · simpa [F] using hexpneg.mul hsum

theorem centered_leftTentAverage_eq_convolution_leftTentKernel {f : ℕ → ℝ} {b : ℝ} (X : ℝ) :
      (((leftTentAverage f X - b : ℝ) : ℂ)) =
        ∫ u : ℝ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) := by
  let N : ℕ := ⌊Real.exp (|X| + 1)⌋₊
  have hlog_bound :
      ∀ t ∈ Set.Icc (X - 1) X,
        |logRescalePartialSum f t| ≤
          Real.exp (|X| + 1) * ∑ k ∈ Finset.Icc 1 N, |f k| := by
    intro t ht
    have ht_upper : t ≤ |X| + 1 := by
      have h1 : t ≤ X := ht.2
      have h2 : X ≤ |X| := le_abs_self X
      linarith
    by_cases ht0 : 0 ≤ t
    · unfold logRescalePartialSum
      rw [if_pos ht0]
      have hfloor : ⌊Real.exp t⌋₊ ≤ N := by
        apply Nat.floor_le_floor
        simpa [N] using Real.exp_le_exp.mpr ht_upper
      have hsum_abs :
          |∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, f k|
            ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, |f k| := by
        simpa using
          (Finset.abs_sum_le_sum_abs (fun k : ℕ => f k) (Finset.Icc 1 ⌊Real.exp t⌋₊))
      have hsubset : Finset.Icc 1 ⌊Real.exp t⌋₊ ⊆ Finset.Icc 1 N := by
        intro k hk
        simp [Finset.mem_Icc] at hk ⊢
        exact ⟨hk.1, le_trans hk.2 hfloor⟩
      have hsum_mono :
          ∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, |f k|
            ≤ ∑ k ∈ Finset.Icc 1 N, |f k| := by
        exact Finset.sum_le_sum_of_subset_of_nonneg hsubset (by
          intro k hk hknot
          positivity)
      have hneg_t : -t ≤ |X| + 1 := by
        have hmin : X - 1 ≤ t := ht.1
        have hnegX : -X ≤ |X| := by
          simpa [abs_neg] using (le_abs_self (-X))
        linarith
      have hexp : Real.exp (-t) ≤ Real.exp (|X| + 1) := by
        exact Real.exp_le_exp.mpr hneg_t
      have hsum_nonneg : 0 ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, |f k| := by
        positivity
      calc
        |Real.exp (-t) * (∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, f k)|
            = Real.exp (-t) * |∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, f k| := by
                rw [abs_mul, abs_of_nonneg (le_of_lt (Real.exp_pos _))]
        _ ≤ Real.exp (-t) * ∑ k ∈ Finset.Icc 1 ⌊Real.exp t⌋₊, |f k| := by
                gcongr
        _ ≤ Real.exp (|X| + 1) * ∑ k ∈ Finset.Icc 1 N, |f k| := by
                exact mul_le_mul hexp hsum_mono hsum_nonneg (by positivity)
    · unfold logRescalePartialSum
      rw [if_neg ht0]
      have hC : 0 ≤ Real.exp (|X| + 1) * ∑ k ∈ Finset.Icc 1 N, |f k| := by
        positivity
      simpa using hC
  have hlog_on :
      MeasureTheory.IntegrableOn (logRescalePartialSum f) (Set.Icc (X - 1) X) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound (s := Set.Icc (X - 1) X) ?_ ?_
      (Real.exp (|X| + 1) * ∑ k ∈ Finset.Icc 1 N, |f k|) ?_
    · simp
    · exact measurable_logRescalePartialSum.aestronglyMeasurable
    · rw [MeasureTheory.ae_restrict_iff' measurableSet_Icc]
      exact Filter.Eventually.of_forall (fun t ht => by simpa using hlog_bound t ht)
  have hlog_int : IntervalIntegrable (logRescalePartialSum f) MeasureTheory.volume (X - 1) X := by
    apply MeasureTheory.IntegrableOn.intervalIntegrable
    simpa [Set.uIcc_of_le (by linarith : X - 1 ≤ X)] using hlog_on
  have hweight_cont :
      ContinuousOn (fun t : ℝ => 2 * (t - (X - 1))) (Set.uIcc (X - 1) X) := by
    exact (continuous_const.mul (continuous_id.sub continuous_const)).continuousOn
  have hweighted_int :
      IntervalIntegrable (fun t : ℝ => (2 * (t - (X - 1))) * logRescalePartialSum f t)
        MeasureTheory.volume (X - 1) X := by
    exact hlog_int.continuousOn_mul hweight_cont
  have hb_int :
      IntervalIntegrable (fun t : ℝ => (2 * (t - (X - 1))) * b)
        MeasureTheory.volume (X - 1) X := by
    exact ((continuous_const.mul (continuous_id.sub continuous_const)).mul continuous_const).intervalIntegrable _ _
  have hweight_mass : ∫ t in X - 1..X, (2 * (t - (X - 1)) : ℝ) = 1 := by
    rw [intervalIntegral.integral_const_mul]
    rw [intervalIntegral.integral_sub intervalIntegral.intervalIntegrable_id intervalIntegral.intervalIntegrable_const]
    rw [integral_id, intervalIntegral.integral_const]
    simp [one_smul]
    ring_nf
  have hb_eval : ∫ t in X - 1..X, (2 * (t - (X - 1))) * b = b := by
    rw [intervalIntegral.integral_mul_const, hweight_mass]
    ring
  have hcenter_real :
      leftTentAverage f X - b =
        ∫ t in X - 1..X, (2 * (t - (X - 1))) * (logRescalePartialSum f t - b) := by
    rw [leftTentAverage]
    calc
      (∫ t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t) - b
          = (∫ t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t) -
              ∫ t in X - 1..X, (2 * (t - (X - 1))) * b := by rw [hb_eval]
      _ = ∫ t in X - 1..X,
            ((2 * (t - (X - 1))) * logRescalePartialSum f t - (2 * (t - (X - 1))) * b) := by
          symm
          exact intervalIntegral.integral_sub hweighted_int hb_int
      _ = ∫ t in X - 1..X, (2 * (t - (X - 1))) * (logRescalePartialSum f t - b) := by
          apply intervalIntegral.integral_congr
          intro t ht
          ring
  have hrhs :
      ∫ u : ℝ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) =
        ∫ t in X - 1..X, (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : ℝ) : ℂ) := by
    have hsupport :
        Function.support (fun u : ℝ => leftTentKernel u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ))) ⊆
          Set.Ioc (-1 : ℝ) 0 := by
      exact Set.Subset.trans (Function.support_mul_subset_left _ _) leftTentKernel_support_subset
    rw [← intervalIntegral.integral_eq_integral_of_support_subset hsupport]
    trans ∫ u in (-1 : ℝ)..0, (((2 * (u + 1)) * (logRescalePartialSum f (X + u) - b) : ℝ) : ℂ)
    · apply intervalIntegral.integral_congr
      intro u hu
      have hu' : -1 ≤ u ∧ u ≤ 0 := by
        simpa [Set.uIcc_of_le (by norm_num : (-1 : ℝ) ≤ 0)] using hu
      simp [leftTentKernel, hu', mul_assoc]
    · let F : ℝ → ℂ := fun t =>
          (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : ℝ) : ℂ)
      convert (intervalIntegral.integral_comp_add_left (f := F) (a := (-1 : ℝ)) (b := 0) X) using 1
      · apply intervalIntegral.integral_congr
        intro u hu
        simp [F]
      · rw [show X + (-1 : ℝ) = X - 1 by ring, show X + (0 : ℝ) = X by ring]
  calc
    (((leftTentAverage f X - b : ℝ) : ℂ)) =
        ∫ t in X - 1..X, (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : ℝ) : ℂ) := by
          rw [hcenter_real, ← intervalIntegral.integral_ofReal]
    _ = ∫ u : ℝ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : ℝ) : ℂ)) := by
          symm
          exact hrhs

theorem leftTent_reflect_pairing_intervalIntegrable {f : ℕ → ℝ} {b : ℝ} :
  (∀ n, 0 ≤ f n) →
  ∀ X : ℝ,
    IntervalIntegrable
      (fun t : ℝ =>
        (leftTentKernel ((1 / 2 : ℝ) - t)).re *
          (logRescalePartialSum f (X + t) - b))
      MeasureTheory.volume (0 : ℝ) 1 := by
  intro hf X
  classical
  let M : ℝ := ∑ k ∈ Finset.Icc 1 ⌊Real.exp (max 0 (X + 1))⌋₊, f k
  have hM_nonneg : 0 ≤ M := by
    dsimp [M]
    exact Finset.sum_nonneg (by intro n hn; exact hf n)
  have hkernel_bound : ∀ t : ℝ, |(leftTentKernel ((1 / 2 : ℝ) - t)).re| ≤ 2 := by
    intro t
    by_cases hcond : -1 ≤ (1 / 2 : ℝ) - t ∧ (1 / 2 : ℝ) - t ≤ 0
    · rw [leftTentKernel, if_pos hcond]
      simp only [Complex.ofReal_re]
      have hnonneg : 0 ≤ 2 * (((1 / 2 : ℝ) - t) + 1) := by
        nlinarith [hcond.1]
      rw [abs_of_nonneg hnonneg]
      nlinarith [hcond.2]
    · rw [leftTentKernel, if_neg hcond]
      norm_num
  have hlog_bound : ∀ t ∈ Set.Icc (0 : ℝ) 1, |logRescalePartialSum f (X + t)| ≤ M := by
    intro t ht
    rcases ht with ⟨ht0, ht1⟩
    by_cases hXt : 0 ≤ X + t
    · have hupper : X + t ≤ max 0 (X + 1) := by
        have hleX1 : X + t ≤ X + 1 := by linarith
        exact le_trans hleX1 (le_max_right 0 (X + 1))
      have hle := logRescalePartialSum_le_sum_floor_exp_bound hf hXt hupper
      have hnonneg := logRescalePartialSum_nonneg hf (X + t)
      rw [abs_of_nonneg hnonneg]
      simpa [M] using hle
    · rw [logRescalePartialSum, if_neg hXt]
      simpa using hM_nonneg
  have hdiff_bound : ∀ t ∈ Set.Icc (0 : ℝ) 1, |logRescalePartialSum f (X + t) - b| ≤ M + |b| := by
    intro t ht
    have h1 : |logRescalePartialSum f (X + t) - b| ≤ |logRescalePartialSum f (X + t)| + |b| := by
      simpa [Real.norm_eq_abs] using norm_sub_le (logRescalePartialSum f (X + t)) b
    have h2 := hlog_bound t ht
    nlinarith
  have hbound : ∀ t ∈ Set.Icc (0 : ℝ) 1,
      ‖(leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b)‖ ≤
        2 * (M + |b|) := by
    intro t ht
    rw [Real.norm_eq_abs, abs_mul]
    have hk := hkernel_bound t
    have hd := hdiff_bound t ht
    have hk_nonneg : 0 ≤ |(leftTentKernel ((1 / 2 : ℝ) - t)).re| := abs_nonneg _
    have hd_nonneg : 0 ≤ |logRescalePartialSum f (X + t) - b| := abs_nonneg _
    have hC_nonneg : 0 ≤ M + |b| := by
      nlinarith [hM_nonneg, abs_nonneg b]
    nlinarith
  have h_meas_kernel_complex : Measurable (fun t : ℝ => leftTentKernel ((1 / 2 : ℝ) - t)) := by
    unfold leftTentKernel
    refine Measurable.ite ?_ ?_ measurable_const
    · let hshift : Measurable fun t : ℝ => (1 / 2 : ℝ) - t := measurable_const.sub measurable_id
      exact (measurableSet_le measurable_const hshift).inter (measurableSet_le hshift measurable_const)
    · have hreal : Measurable fun t : ℝ => 2 * (((1 / 2 : ℝ) - t) + 1) := by
        let hshift : Measurable fun t : ℝ => (1 / 2 : ℝ) - t := measurable_const.sub measurable_id
        exact measurable_const.mul (hshift.add measurable_const)
      simpa using hreal.complex_ofReal
  have h_meas_kernel : Measurable (fun t : ℝ => (leftTentKernel ((1 / 2 : ℝ) - t)).re) :=
    h_meas_kernel_complex.re
  have h_meas_log : Measurable (fun t : ℝ => logRescalePartialSum f (X + t)) := by
    simpa using measurable_logRescalePartialSum.comp (measurable_const.add measurable_id)
  have h_meas_integrand : Measurable (fun t : ℝ =>
      (leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b)) := by
    exact h_meas_kernel.mul (h_meas_log.sub measurable_const)
  have h_ae : MeasureTheory.AEStronglyMeasurable
      (fun t : ℝ => (leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b))
      (MeasureTheory.volume.restrict (Set.Icc (0 : ℝ) 1)) :=
    h_meas_integrand.aestronglyMeasurable.restrict
  have h_ae_bound :
      ∀ᵐ t ∂MeasureTheory.volume.restrict (Set.Icc (0 : ℝ) 1),
        ‖(leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b)‖ ≤
          2 * (M + |b|) := by
    refine MeasureTheory.ae_restrict_of_forall_mem measurableSet_Icc ?_
    intro t ht
    exact hbound t ht
  have hInt : MeasureTheory.IntegrableOn
      (fun t : ℝ => (leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b))
      (Set.Icc (0 : ℝ) 1) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound ?_ h_ae (2 * (M + |b|)) h_ae_bound
    simp
  apply MeasureTheory.IntegrableOn.intervalIntegrable
  simpa [Set.uIcc_of_le] using hInt

theorem leftTent_reflect_pairing_eq_negativeShift {f : ℕ → ℝ} {b : ℝ} :
  (hf : ∀ n, 0 ≤ f n) → ∀ X : ℝ,
    ∫ t in (0 : ℝ)..1,
      (leftTentKernel ((1 / 2 : ℝ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
    =
      ∫ t in (-(1 / 2 : ℝ))..0,
        (1 - 2 * t) *
          (logRescalePartialSum f (X + 1 + t) - b) := by
  intro hf X
  let F : ℝ → ℝ := fun t =>
    (leftTentKernel ((1 / 2 : ℝ) - t)).re * (logRescalePartialSum f (X + t) - b)
  have hInt : IntervalIntegrable F MeasureTheory.volume (0 : ℝ) 1 := by
    simpa [F] using leftTent_reflect_pairing_intervalIntegrable (f := f) (b := b) hf X
  have hmid : (1 / 2 : ℝ) ∈ Set.uIcc (0 : ℝ) (1 : ℝ) := by
    exact Set.mem_uIcc_of_le (by norm_num) (by norm_num)
  have hsplit :
      IntervalIntegrable F MeasureTheory.volume (0 : ℝ) (1 / 2 : ℝ) ∧
        IntervalIntegrable F MeasureTheory.volume (1 / 2 : ℝ) 1 := by
    exact
      (IntervalIntegrable.trans_iff (f := F) (μ := MeasureTheory.volume)
        (a := (0 : ℝ)) (b := (1 / 2 : ℝ)) (c := (1 : ℝ)) hmid).mp hInt
  have hzero_ae :
      F =ᵐ[MeasureTheory.volume.restrict (Set.uIoc (0 : ℝ) (1 / 2 : ℝ))] fun _ => (0 : ℝ) := by
    rw [Set.uIoc_of_le (show (0 : ℝ) ≤ (1 / 2 : ℝ) by norm_num)]
    rw [← MeasureTheory.restrict_Ioo_eq_restrict_Ioc (μ := MeasureTheory.volume)
      (a := (0 : ℝ)) (b := (1 / 2 : ℝ))]
    change ∀ᵐ x ∂MeasureTheory.volume.restrict (Set.Ioo (0 : ℝ) (1 / 2 : ℝ)), F x = 0
    rw [MeasureTheory.ae_restrict_iff' (μ := MeasureTheory.volume)
      (s := Set.Ioo (0 : ℝ) (1 / 2 : ℝ)) measurableSet_Ioo]
    refine Filter.Eventually.of_forall ?_
    intro t ht
    have hnot : ¬ (-1 ≤ (1 / 2 : ℝ) - t ∧ (1 / 2 : ℝ) - t ≤ 0) := by
      intro hcond
      linarith [ht.2]
    unfold F
    rw [leftTentKernel, if_neg hnot]
    simp
  have hzero : ∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t = 0 := by
    calc
      ∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t
          = ∫ t in (0 : ℝ)..(1 / 2 : ℝ), (0 : ℝ) := by
              exact intervalIntegral.integral_congr_ae_restrict hzero_ae
      _ = 0 := by
            simp
  have hright_congr :
      ∫ t in (1 / 2 : ℝ)..1, F t =
        ∫ t in (1 / 2 : ℝ)..1,
          (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) := by
    apply intervalIntegral.integral_congr
    intro t ht
    have ht' : (1 / 2 : ℝ) ≤ t ∧ t ≤ 1 ∨ 1 ≤ t ∧ t ≤ (1 / 2 : ℝ) := by
      simpa using (Set.mem_uIcc.mp ht)
    have ht1 : (1 / 2 : ℝ) ≤ t := by
      rcases ht' with h | h
      · exact h.1
      · linarith
    have ht2 : t ≤ 1 := by
      rcases ht' with h | h
      · exact h.2
      · linarith
    have hcond : -1 ≤ (1 / 2 : ℝ) - t ∧ (1 / 2 : ℝ) - t ≤ 0 := by
      constructor <;> linarith
    have hker : (leftTentKernel ((1 / 2 : ℝ) - t)).re = 3 - 2 * t := by
      rw [leftTentKernel, if_pos hcond]
      simp
      ring_nf
    unfold F
    rw [hker]
  have hshift :
      ∫ t in (1 / 2 : ℝ)..1,
        (3 - 2 * t) * (logRescalePartialSum f (X + t) - b)
      =
      ∫ t in (-(1 / 2 : ℝ))..0,
        (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
    calc
      ∫ t in (1 / 2 : ℝ)..1,
        (3 - 2 * t) * (logRescalePartialSum f (X + t) - b)
        = ∫ t in (1 / 2 : ℝ)..1,
            (fun u : ℝ =>
              (1 - 2 * u) * (logRescalePartialSum f (X + 1 + u) - b)) (t - 1) := by
              apply intervalIntegral.integral_congr
              intro t ht
              change
                (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) =
                  (1 - 2 * (t - 1)) *
                    (logRescalePartialSum f (X + 1 + (t - 1)) - b)
              have h1 : (1 - 2 * (t - 1) : ℝ) = 3 - 2 * t := by ring
              have h2 : X + 1 + (t - 1) = X + t := by ring
              rw [h1, h2]
      _ = ∫ t in ((1 / 2 : ℝ) - 1)..0,
            (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
              simpa using
                (intervalIntegral.integral_comp_sub_right
                  (f := fun u : ℝ =>
                    (1 - 2 * u) * (logRescalePartialSum f (X + 1 + u) - b))
                  (a := (1 / 2 : ℝ)) (b := (1 : ℝ)) (d := (1 : ℝ)))
      _ = ∫ t in (-(1 / 2 : ℝ))..0,
            (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
              have hhalf : ((1 / 2 : ℝ) - 1) = -(1 / 2 : ℝ) := by ring
              rw [hhalf]
  have hadd :
      (∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t) + ∫ t in (1 / 2 : ℝ)..1, F t
        = ∫ t in (0 : ℝ)..1, F t := by
    exact intervalIntegral.integral_add_adjacent_intervals hsplit.1 hsplit.2
  calc
    ∫ t in (0 : ℝ)..1,
      (leftTentKernel ((1 / 2 : ℝ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
      = ∫ t in (0 : ℝ)..1, F t := by
          rfl
    _ = (∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t) + ∫ t in (1 / 2 : ℝ)..1, F t := by
          symm
          exact hadd
    _ = 0 + ∫ t in (1 / 2 : ℝ)..1, F t := by rw [hzero]
    _ = ∫ t in (1 / 2 : ℝ)..1, F t := by
          simp
    _ = ∫ t in (1 / 2 : ℝ)..1,
          (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) := hright_congr
    _ = ∫ t in (-(1 / 2 : ℝ))..0,
          (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := hshift

theorem leftTent_shift_pairing_intervalIntegrable {f : ℕ → ℝ} {b : ℝ} :
  (∀ n, 0 ≤ f n) →
  ∀ X : ℝ,
    IntervalIntegrable
      (fun t : ℝ =>
        (leftTentKernel (t - (1 / 2 : ℝ))).re *
          (logRescalePartialSum f (X + t) - b))
      MeasureTheory.volume (0 : ℝ) 1 := by
  classical
  intro hf X
  let g : ℝ → ℝ := fun t => logRescalePartialSum f (X + t) - b
  have hlog_meas : Measurable fun t : ℝ => logRescalePartialSum f (X + t) := by
    exact (measurable_logRescalePartialSum (f := f)).comp (measurable_const.add measurable_id)
  have hg_meas : Measurable g := by
    simpa [g] using hlog_meas.sub measurable_const
  let M : ℝ := ∑ k ∈ Finset.Icc 1 ⌊Real.exp (max 0 (X + 1))⌋₊, f k
  have hM_nonneg : 0 ≤ M := by
    unfold M
    exact Finset.sum_nonneg fun n hn => hf n
  have hg_bound : ∀ t ∈ Set.Icc (0 : ℝ) 1, ‖g t‖ ≤ M + |b| := by
    intro t ht
    rcases ht with ⟨ht0, ht1⟩
    by_cases hXt : 0 ≤ X + t
    · have hXt_le : X + t ≤ max 0 (X + 1) := by
        have h1 : X + t ≤ X + 1 := by linarith
        exact le_trans h1 (le_max_right 0 (X + 1))
      have hle := logRescalePartialSum_le_sum_floor_exp_bound (f := f) hf hXt hXt_le
      have hnonneg := logRescalePartialSum_nonneg (f := f) hf (X + t)
      unfold g
      rw [Real.norm_eq_abs]
      have htri : |logRescalePartialSum f (X + t) - b| ≤ |logRescalePartialSum f (X + t)| + |b| := by
        simpa [Real.norm_eq_abs] using norm_sub_le (logRescalePartialSum f (X + t)) b
      rw [abs_of_nonneg hnonneg] at htri
      exact le_trans htri (by linarith)
    · have hneg : X + t < 0 := by linarith
      have hzero : logRescalePartialSum f (X + t) = 0 := by
        simp [logRescalePartialSum, not_le_of_gt hneg]
      unfold g
      rw [Real.norm_eq_abs, hzero, zero_sub, abs_neg]
      linarith
  have hker_meas : Measurable fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re := by
    have hker_eqfun :
        (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re) =
          fun t : ℝ =>
            if -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0 then
              2 * (t - (1 / 2 : ℝ) + 1)
            else 0 := by
      funext t
      unfold leftTentKernel
      split_ifs <;> norm_num
    rw [hker_eqfun]
    have hset : MeasurableSet {t : ℝ | -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0} := by
      refine (measurableSet_le measurable_const (measurable_id.sub measurable_const)).inter ?_
      exact measurableSet_le (measurable_id.sub measurable_const) measurable_const
    have hbranch : Measurable fun t : ℝ => 2 * (t - (1 / 2 : ℝ) + 1) := by
      exact measurable_const.mul ((measurable_id.sub measurable_const).add measurable_const)
    exact Measurable.ite
      (p := fun t : ℝ => -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0)
      hset hbranch measurable_const
  have hker_bound : ∀ t : ℝ, ‖(leftTentKernel (t - (1 / 2 : ℝ))).re‖ ≤ (2 : ℝ) := by
    intro t
    by_cases h : -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0
    · have hnonneg : 0 ≤ 2 * (t - (1 / 2 : ℝ) + 1) := by linarith [h.1, h.2]
      have hle2 : 2 * (t - (1 / 2 : ℝ) + 1) ≤ 2 := by linarith [h.1, h.2]
      have hker_eq : (leftTentKernel (t - (1 / 2 : ℝ))).re = 2 * (t - (1 / 2 : ℝ) + 1) := by
        unfold leftTentKernel
        rw [if_pos h]
        norm_num
      rw [hker_eq, Real.norm_eq_abs, abs_of_nonneg hnonneg]
      exact hle2
    · have hker_eq : (leftTentKernel (t - (1 / 2 : ℝ))).re = 0 := by
        unfold leftTentKernel
        rw [if_neg h]
        norm_num
      rw [hker_eq, Real.norm_eq_abs]
      norm_num
  have hprod_meas : Measurable fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re * g t := by
    exact hker_meas.mul hg_meas
  have hbound : ∀ t ∈ Set.Icc (0 : ℝ) 1,
      ‖(leftTentKernel (t - (1 / 2 : ℝ))).re * g t‖ ≤ 2 * (M + |b|) := by
    intro t ht
    have hk := hker_bound t
    have hg := hg_bound t ht
    rw [norm_mul]
    exact mul_le_mul hk hg (norm_nonneg _) (by positivity : 0 ≤ (2 : ℝ))
  have h_int_on : MeasureTheory.IntegrableOn
      (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re * g t)
      (Set.Icc (0 : ℝ) 1) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound ?_ hprod_meas.aestronglyMeasurable (2 * (M + |b|)) ?_
    · exact measure_Icc_lt_top
    · exact MeasureTheory.ae_restrict_of_forall_mem measurableSet_Icc hbound
  have h_int_on_uIcc : MeasureTheory.IntegrableOn
      (fun t : ℝ => (leftTentKernel (t - (1 / 2 : ℝ))).re * g t)
      (Set.uIcc (0 : ℝ) 1) MeasureTheory.volume := by
    simpa [Set.uIcc_of_le (show (0 : ℝ) ≤ 1 by positivity)] using h_int_on
  simpa [g] using h_int_on_uIcc.intervalIntegrable

theorem leftTent_shift_pairing_eq_negativeShift {f : ℕ → ℝ} {b : ℝ} :
  (hf : ∀ n, 0 ≤ f n) → ∀ X : ℝ,
    ∫ t in (0 : ℝ)..1,
      (leftTentKernel (t - (1 / 2 : ℝ))).re *
        (logRescalePartialSum f (X + t) - b)
    =
      ∫ t in (-(1 / 2 : ℝ))..0,
        ((2 * (t + 1) : ℝ)) *
          (logRescalePartialSum f (X + (1 / 2 : ℝ) + t) - b) := by
  intro hf X
  let F : ℝ → ℝ := fun t =>
    (leftTentKernel (t - (1 / 2 : ℝ))).re *
      (logRescalePartialSum f (X + t) - b)
  have hFint : IntervalIntegrable F MeasureTheory.volume (0 : ℝ) 1 := by
    simpa [F] using leftTent_shift_pairing_intervalIntegrable (f := f) (b := b) hf X
  have hmid : (1 / 2 : ℝ) ∈ Set.uIcc (0 : ℝ) 1 := by
    exact Set.mem_uIcc_of_le (by norm_num) (by norm_num)
  have hFsplit :=
    (IntervalIntegrable.trans_iff
      (f := F) (μ := MeasureTheory.volume)
      (a := (0 : ℝ)) (b := (1 / 2 : ℝ)) (c := (1 : ℝ)) hmid).1 hFint
  have hF01 : IntervalIntegrable F MeasureTheory.volume (0 : ℝ) (1 / 2 : ℝ) := hFsplit.1
  have hF12 : IntervalIntegrable F MeasureTheory.volume (1 / 2 : ℝ) 1 := hFsplit.2
  have hsplit :
      ∫ t in (0 : ℝ)..1, F t
        = (∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t) + ∫ t in (1 / 2 : ℝ)..1, F t := by
    simpa using (intervalIntegral.integral_add_adjacent_intervals hF01 hF12).symm
  have hright_zero : ∫ t in (1 / 2 : ℝ)..1, F t = 0 := by
    apply intervalIntegral.integral_zero_ae
    refine Filter.Eventually.of_forall ?_
    intro t ht
    rw [Set.mem_uIoc] at ht
    rcases ht with ht | ht
    · have hkernel : leftTentKernel (t - (1 / 2 : ℝ)) = 0 := by
        rw [leftTentKernel]
        apply if_neg
        intro h
        linarith [h.2, ht.1]
      change (leftTentKernel (t - (1 / 2 : ℝ))).re * (logRescalePartialSum f (X + t) - b) = 0
      rw [hkernel]
      simp
    · linarith
  have hleft_explicit :
      ∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t
        = ∫ t in (0 : ℝ)..(1 / 2 : ℝ),
            ((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) *
              (logRescalePartialSum f (X + t) - b) := by
    apply intervalIntegral.integral_congr
    intro t ht
    have ht' : t ∈ Set.Icc (0 : ℝ) (1 / 2 : ℝ) := by
      simpa [Set.uIcc_of_le (show (0 : ℝ) ≤ (1 / 2 : ℝ) by norm_num)] using ht
    have hcond : -1 ≤ t - (1 / 2 : ℝ) ∧ t - (1 / 2 : ℝ) ≤ 0 := by
      constructor <;> linarith [ht'.1, ht'.2]
    have hkernel :
        leftTentKernel (t - (1 / 2 : ℝ)) =
          (((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) : ℂ) := by
      rw [leftTentKernel]
      rw [if_pos hcond]
    change (leftTentKernel (t - (1 / 2 : ℝ))).re * (logRescalePartialSum f (X + t) - b) =
      ((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) * (logRescalePartialSum f (X + t) - b)
    rw [hkernel]
    simp
  let G : ℝ → ℝ := fun t =>
    ((2 * (t + 1) : ℝ)) *
      (logRescalePartialSum f (X + (1 / 2 : ℝ) + t) - b)
  have hleft_shift :
      ∫ t in (0 : ℝ)..(1 / 2 : ℝ),
        ((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) *
          (logRescalePartialSum f (X + t) - b)
      = ∫ t in (-(1 / 2 : ℝ))..0, G t := by
    simpa [G, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
      (intervalIntegral.integral_comp_sub_right
        (f := G) (a := (0 : ℝ)) (b := (1 / 2 : ℝ)) (d := (1 / 2 : ℝ)))
  calc
    ∫ t in (0 : ℝ)..1,
        (leftTentKernel (t - (1 / 2 : ℝ))).re *
          (logRescalePartialSum f (X + t) - b)
      = ∫ t in (0 : ℝ)..1, F t := by
          rfl
    _ = (∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t) + ∫ t in (1 / 2 : ℝ)..1, F t := hsplit
    _ = (∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t) + 0 := by rw [hright_zero]
    _ = ∫ t in (0 : ℝ)..(1 / 2 : ℝ), F t := by
          simp
    _ = ∫ t in (0 : ℝ)..(1 / 2 : ℝ),
          ((2 * ((t - (1 / 2 : ℝ)) + 1) : ℝ)) *
            (logRescalePartialSum f (X + t) - b) := hleft_explicit
    _ = ∫ t in (-(1 / 2 : ℝ))..0, G t := hleft_shift
    _ = ∫ t in (-(1 / 2 : ℝ))..0,
          ((2 * (t + 1) : ℝ)) *
            (logRescalePartialSum f (X + (1 / 2 : ℝ) + t) - b) := by
          rfl

theorem logRescalePartialSum_intervalIntegrable (f : ℕ → ℝ) (b a d : ℝ) :
  IntervalIntegrable
    (fun y : ℝ => logRescalePartialSum f y - b)
    MeasureTheory.volume a d := by
  rw [intervalIntegrable_iff]
  let N : ℕ := ⌊Real.exp (max a d)⌋₊
  let C : ℝ := ∑ k ∈ Finset.Icc 1 N, ‖f k‖
  refine MeasureTheory.Measure.integrableOn_of_bounded ?_ ?_ (M := C + ‖b‖) ?_
  · rw [Real.volume_uIoc]
    exact ENNReal.ofReal_ne_top
  · exact (measurable_logRescalePartialSum.sub measurable_const).aestronglyMeasurable
  · rw [MeasureTheory.ae_restrict_iff' measurableSet_uIoc]
    refine Filter.Eventually.of_forall ?_
    intro y hy
    have hy' : y ≤ max a d := by
      rcases (Set.mem_uIoc.mp hy) with h | h
      · exact le_max_of_le_right h.2
      · exact le_max_of_le_left h.2
    have hfloor : ⌊Real.exp y⌋₊ ≤ N := by
      dsimp [N]
      gcongr
    have hsum : ‖∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, f k‖ ≤ C := by
      calc
        ‖∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, f k‖ ≤ ∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, ‖f k‖ := by
          simpa using (norm_sum_le (Finset.Icc 1 ⌊Real.exp y⌋₊) fun k => f k)
        _ ≤ ∑ k ∈ Finset.Icc 1 N, ‖f k‖ := by
          dsimp [C]
          refine Finset.sum_le_sum_of_subset_of_nonneg (Finset.Icc_subset_Icc le_rfl hfloor) ?_
          intro x hx hx'
          positivity
    have hlog : ‖logRescalePartialSum f y‖ ≤ C := by
      by_cases hy0 : 0 ≤ y
      · rw [logRescalePartialSum, if_pos hy0]
        calc
          ‖Real.exp (-y) * ∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, f k‖
              = Real.exp (-y) * ‖∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, f k‖ := by
                  rw [norm_mul, Real.norm_of_nonneg (by positivity)]
          _ ≤ 1 * ‖∑ k ∈ Finset.Icc 1 ⌊Real.exp y⌋₊, f k‖ := by
                gcongr
                have : -y ≤ 0 := by linarith
                have hexp : Real.exp (-y) ≤ Real.exp 0 := by gcongr
                simpa using hexp
          _ ≤ 1 * C := by gcongr
          _ = C := by ring
      · rw [logRescalePartialSum, if_neg hy0]
        dsimp [C]
        have : 0 ≤ C := by positivity
        simpa [norm_zero] using this
    calc
      ‖logRescalePartialSum f y - b‖ ≤ ‖logRescalePartialSum f y‖ + ‖b‖ := norm_sub_le _ _
      _ ≤ C + ‖b‖ := by gcongr

theorem boundary_extension_local_interval_laplace_continuous {f : ℕ → ℝ} {b δ : ℝ} :
  ContinuousOn
    (fun z : ℂ =>
      ∫ y in (0 : ℝ)..δ,
        (((logRescalePartialSum f y - b : ℝ) : ℂ) * Complex.exp (-z * y)))
    {z : ℂ | 0 ≤ z.re} := by
  classical
  let S : Set ℂ := {z : ℂ | 0 ≤ z.re}
  let U : ℝ → ℂ := fun y => (((logRescalePartialSum f y - b : ℝ) : ℂ))
  let F : ℂ → ℝ → ℂ := fun z y => U y * Complex.exp (-z * y)
  refine fun z hz => ?_
  let C : ℝ := Real.exp ((z.re + 1) * max (-δ) 0)
  let bound : ℝ → ℝ := fun y => C * |logRescalePartialSum f y - b|
  have h_bound_int : IntervalIntegrable bound MeasureTheory.volume 0 δ := by
    simpa [bound, C] using ((logRescalePartialSum_intervalIntegrable f b 0 δ).abs.const_mul C)
  refine intervalIntegral.continuousWithinAt_of_dominated_interval ?_ ?_ h_bound_int ?_
  · refine Filter.Eventually.of_forall ?_
    intro w
    have hUreal : Measurable fun y : ℝ => logRescalePartialSum f y - b :=
      measurable_logRescalePartialSum.sub_const b
    have hU : Measurable fun y : ℝ => (((logRescalePartialSum f y - b : ℝ) : ℂ)) :=
      hUreal.complex_ofReal
    have hExp : Measurable fun y : ℝ => Complex.exp (-w * (y : ℂ)) := by
      exact (Complex.continuous_exp.comp ((continuous_const.neg).mul Complex.continuous_ofReal)).measurable
    simpa [F, U] using (hU.mul hExp).aestronglyMeasurable
  · have hnear' : ∀ᶠ w : ℂ in nhds z, w.re < z.re + 1 :=
      Complex.continuous_re.continuousAt.eventually_lt continuousAt_const (by linarith)
    have hnear : ∀ᶠ w : ℂ in nhdsWithin z S, w.re < z.re + 1 :=
      hnear'.filter_mono nhdsWithin_le_nhds
    have hmem : ∀ᶠ w : ℂ in nhdsWithin z S, w ∈ S := by
      change S ∈ nhds z ⊓ Filter.principal S
      simpa using Filter.inter_mem_inf (Filter.univ_mem : Set.univ ∈ nhds z)
        (by simp [Filter.mem_principal])
    have hnear_mem : ∀ᶠ w : ℂ in nhdsWithin z S, w.re < z.re + 1 ∧ w ∈ S := by
      filter_upwards [hnear, hmem] with w hwre hwS
      exact ⟨hwre, hwS⟩
    refine hnear_mem.mono ?_
    intro w hw
    rcases hw with ⟨hwre, hwS⟩
    have hw_nonneg : 0 ≤ w.re := by
      simpa [S] using hwS
    refine Filter.Eventually.of_forall ?_
    intro y hyI
    rw [show bound y = C * |logRescalePartialSum f y - b| by rfl]
    simp only [F, U, norm_mul, Complex.norm_exp]
    have hnorm : ‖(((logRescalePartialSum f y - b : ℝ) : ℂ))‖ = |logRescalePartialSum f y - b| := by
      simpa using (RCLike.norm_ofReal (K := ℂ) (logRescalePartialSum f y - b))
    rw [hnorm]
    have hexp_le : Real.exp (-w * (y : ℂ)).re ≤ C := by
      change Real.exp (-w * (y : ℂ)).re ≤ Real.exp ((z.re + 1) * max (-δ) 0)
      refine Real.exp_le_exp.mpr ?_
      have hre : (-w * (y : ℂ)).re = -(w.re * y) := by
        simp [Complex.mul_re]
      rw [hre]
      rcases Set.mem_uIoc.mp hyI with hy | hy
      · have hleft : -(w.re * y) ≤ 0 := by
          nlinarith [hw_nonneg, hy.1.le]
        have hright : 0 ≤ (z.re + 1) * max (-δ) 0 := by
          have hz1 : 0 ≤ z.re + 1 := by linarith [hz]
          exact mul_nonneg hz1 (by exact le_max_right (-δ) 0)
        linarith
      · have hz1 : 0 ≤ z.re + 1 := by linarith [hz]
        have hyneg : 0 ≤ -y := by linarith [hy.2]
        have hy_le : -y ≤ max (-δ) 0 := by
          have h1 : -y ≤ -δ := by linarith [hy.1]
          exact le_trans h1 (le_max_left (-δ) 0)
        have hmul1 : w.re * (-y) ≤ (z.re + 1) * (-y) := by
          exact mul_le_mul_of_nonneg_right hwre.le hyneg
        have hmul2 : (z.re + 1) * (-y) ≤ (z.re + 1) * max (-δ) 0 := by
          exact mul_le_mul_of_nonneg_left hy_le hz1
        have hrew : -(w.re * y) = w.re * (-y) := by ring
        rw [hrew]
        exact le_trans hmul1 hmul2
    have hmul := mul_le_mul_of_nonneg_left hexp_le (abs_nonneg (logRescalePartialSum f y - b))
    simpa [mul_comm, mul_left_comm, mul_assoc] using hmul
  · refine Filter.Eventually.of_forall ?_
    intro y hyI
    have hExp : Continuous fun w : ℂ => Complex.exp (-w * (y : ℂ)) := by
      exact Complex.continuous_exp.comp ((continuous_id.neg).mul continuous_const)
    have h : Continuous fun w : ℂ => (((logRescalePartialSum f y - b : ℝ) : ℂ)) * Complex.exp (-w * (y : ℂ)) := by
      exact continuous_const.mul hExp
    exact h.continuousWithinAt

theorem boundary_extension_shifted_laplace_eq {f : ℕ → ℝ} {b δ : ℝ} :
  HasBoundaryLaplaceExtension f b → 0 < δ →
  ∀ z : ℂ, 0 < z.re →
    ∫ x in Set.Ioi (0 : ℝ),
      ((((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) * Complex.exp (-z * x)))
    = Complex.exp (z * δ) *
        ((∫ x in Set.Ioi (0 : ℝ),
            (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
          - ∫ y in (0 : ℝ)..δ,
              (((logRescalePartialSum f y - b : ℝ) : ℂ) * Complex.exp (-z * y))) := by
  intro hExt hδ z hz
  rcases hExt with ⟨G, hGcont, hGint, hGeq⟩
  let U : ℝ → ℂ := fun x => (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x))
  have hU_integrable : MeasureTheory.IntegrableOn U (Set.Ioi (0 : ℝ)) := by
    simpa [U] using hGint z hz
  have hpreim : (fun x : ℝ => x + δ) ⁻¹' Set.Ioi δ = Set.Ioi (0 : ℝ) := by
    ext x
    constructor
    · intro hx
      have hx' : δ < x + δ := by
        simpa [Set.mem_preimage, Set.mem_Ioi] using hx
      show 0 < x
      linarith
    · intro hx
      have hx' : 0 < x := by simpa [Set.mem_Ioi] using hx
      have : δ < x + δ := by simpa using add_lt_add_right hx' δ
      simpa [Set.mem_preimage, Set.mem_Ioi] using this
  have hU_shift :
      (∫ x in Set.Ioi (0 : ℝ), U (x + δ)) = ∫ y in Set.Ioi δ, U y := by
    simpa [hpreim] using
      (MeasureTheory.MeasurePreserving.setIntegral_preimage_emb
        (MeasureTheory.measurePreserving_add_right (MeasureTheory.volume : MeasureTheory.Measure ℝ) δ)
        (MeasurableEquiv.addRight δ).measurableEmbedding
        U
        (Set.Ioi δ))
  have h_base_real : IntervalIntegrable (fun y : ℝ => logRescalePartialSum f y - b) MeasureTheory.volume (0 : ℝ) δ :=
    logRescalePartialSum_intervalIntegrable f b 0 δ
  have h_base_complex :
      IntervalIntegrable (fun y : ℝ => (((logRescalePartialSum f y - b : ℝ) : ℂ))) MeasureTheory.volume (0 : ℝ) δ := by
    rw [intervalIntegrable_iff]
    exact MeasureTheory.Integrable.ofReal (𝕜 := ℂ) h_base_real.def'.integrable
  have h_exp_cont : ContinuousOn (fun y : ℝ => Complex.exp (-z * y)) (Set.uIcc (0 : ℝ) δ) := by
    fun_prop
  have h_interval : IntervalIntegrable U MeasureTheory.volume (0 : ℝ) δ := by
    simpa [U] using h_base_complex.mul_continuousOn h_exp_cont
  have hU_tail : MeasureTheory.IntegrableOn U (Set.Ioi δ) := by
    exact hU_integrable.mono_set (by
      intro x hx
      have hx' : δ < x := by simpa [Set.mem_Ioi] using hx
      simpa [Set.mem_Ioi] using lt_trans hδ hx')
  have h_split := intervalIntegral.integral_interval_add_Ioi' h_interval hU_tail
  have h_tail_eq :
      ∫ y in Set.Ioi δ, U y =
        (∫ x in Set.Ioi (0 : ℝ), U x) - ∫ y in (0 : ℝ)..δ, U y := by
    exact eq_sub_iff_add_eq.mpr (by simpa [add_comm] using h_split)
  have h_exp_rewrite :
      ∀ x : ℝ,
        ((((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) * Complex.exp (-z * x))) =
          Complex.exp (z * δ) * U (x + δ) := by
    intro x
    have hexp : Complex.exp (-z * x) = Complex.exp (z * δ) * Complex.exp (-z * (x + δ)) := by
      rw [← Complex.exp_add]
      congr 1
      ring
    calc
      (((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) * Complex.exp (-z * x)) =
          (((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) *
            (Complex.exp (z * δ) * Complex.exp (-z * (x + δ)))) := by
            rw [hexp]
      _ = Complex.exp (z * δ) *
          (((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) * Complex.exp (-z * (x + δ))) := by
            ring
      _ = Complex.exp (z * δ) * U (x + δ) := by
            have hcast : Complex.exp (-z * (x + δ)) = Complex.exp (-z * (((x + δ : ℝ) : ℂ))) := by
              congr 1
              norm_num
            rw [hcast]
  calc
    ∫ x in Set.Ioi (0 : ℝ),
        ((((logRescalePartialSum f (x + δ) - b : ℝ) : ℂ) * Complex.exp (-z * x)))
      = ∫ x in Set.Ioi (0 : ℝ), Complex.exp (z * δ) * U (x + δ) := by
          apply MeasureTheory.integral_congr_ae
          exact Filter.Eventually.of_forall h_exp_rewrite
    _ = Complex.exp (z * δ) * ∫ x in Set.Ioi (0 : ℝ), U (x + δ) := by
          simpa using
            (MeasureTheory.integral_const_mul
              (μ := MeasureTheory.volume.restrict (Set.Ioi (0 : ℝ)))
              (Complex.exp (z * δ))
              (fun x : ℝ => U (x + δ)))
    _ = Complex.exp (z * δ) * ∫ y in Set.Ioi δ, U y := by rw [hU_shift]
    _ = Complex.exp (z * δ) *
          ((∫ x in Set.Ioi (0 : ℝ), U x) - ∫ y in (0 : ℝ)..δ, U y) := by rw [h_tail_eq]
    _ = Complex.exp (z * δ) *
          ((∫ x in Set.Ioi (0 : ℝ),
              (((logRescalePartialSum f x - b : ℝ) : ℂ) * Complex.exp (-z * x)))
            - ∫ y in (0 : ℝ)..δ,
                (((logRescalePartialSum f y - b : ℝ) : ℂ) * Complex.exp (-z * y))) := by
          rfl

theorem boundary_extension_translate_difference_abel_identity {f : ℕ → ℝ} {b δ σ X : ℝ} :
  0 < σ →
  0 ≤ X →
  ∫ t in (0 : ℝ)..X,
    (((logRescalePartialSum f (t + δ) - b) - (logRescalePartialSum f t - b)) * Real.exp (-σ * t))
  =
    Real.exp (-σ * X) *
      (∫ s in (0 : ℝ)..X,
        ((logRescalePartialSum f (s + δ) - b) - (logRescalePartialSum f s - b)))
    + σ *
      (∫ t in (0 : ℝ)..X,
        (∫ s in (0 : ℝ)..t,
          ((logRescalePartialSum f (s + δ) - b) - (logRescalePartialSum f s - b))) *
          Real.exp (-σ * t)) := by
  intro hσ hX
  let D : ℝ → ℝ := fun t => (logRescalePartialSum f (t + δ) - b) - (logRescalePartialSum f t - b)
  let E : ℝ → ℝ := fun t => Real.exp (-(σ * t))
  let P : ℝ → ℝ := fun t => ∫ s in (0 : ℝ)..t, D s
  let Q : ℝ → ℝ := fun t => ∫ s in (0 : ℝ)..t, E s
  have hD_int : ∀ a d : ℝ, IntervalIntegrable D MeasureTheory.volume a d := by
    intro a d
    have hshift : IntervalIntegrable (fun y : ℝ => logRescalePartialSum f (y + δ) - b) MeasureTheory.volume a d := by
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
        (logRescalePartialSum_intervalIntegrable f b (a + δ) (d + δ)).comp_add_right δ
    simpa [D] using hshift.sub (logRescalePartialSum_intervalIntegrable f b a d)
  have hE_cont : Continuous E := by
    simpa [E] using (Real.continuous_exp.comp ((continuous_const.mul continuous_id).neg))
  have hE_int : IntervalIntegrable E MeasureTheory.volume (0 : ℝ) X :=
    hE_cont.intervalIntegrable 0 X
  have hP_ac : AbsolutelyContinuousOnInterval P 0 X := by
    simpa [P] using (hD_int 0 X).absolutelyContinuousOnInterval_intervalIntegral (c := 0)
      (by simpa [Set.uIcc_of_le hX])
  have hQ_ac : AbsolutelyContinuousOnInterval Q 0 X := by
    simpa [Q] using hE_int.absolutelyContinuousOnInterval_intervalIntegral (c := 0)
      (by simpa [Set.uIcc_of_le hX])
  have hderivP_eq :
      ∀ᵐ t ∂MeasureTheory.volume, t ∈ Set.uIoc (0 : ℝ) X → deriv P t = D t := by
    filter_upwards [(hD_int 0 X).ae_hasDerivAt_integral] with t ht htmem
    exact (ht (Set.uIoc_subset_uIcc htmem) 0 (by simpa [Set.uIcc_of_le hX])).deriv
  have hderivQ_eq :
      ∀ᵐ t ∂MeasureTheory.volume, t ∈ Set.uIoc (0 : ℝ) X → deriv Q t = E t := by
    filter_upwards [hE_int.ae_hasDerivAt_integral] with t ht htmem
    exact (ht (Set.uIoc_subset_uIcc htmem) 0 (by simpa [Set.uIcc_of_le hX])).deriv
  have hparts' :
      (∫ t in (0 : ℝ)..X, D t * Q t) =
        Q X * P X - Q 0 * P 0 - (∫ t in (0 : ℝ)..X, P t * E t) := by
    calc
      (∫ t in (0 : ℝ)..X, D t * Q t) = ∫ t in (0 : ℝ)..X, deriv P t * Q t := by
        apply intervalIntegral.integral_congr_ae
        filter_upwards [hderivP_eq] with t ht htmem
        rw [ht htmem]
      _ = ∫ t in (0 : ℝ)..X, Q t * deriv P t := by
        apply intervalIntegral.integral_congr
        intro t ht
        ring
      _ = Q X * P X - Q 0 * P 0 - (∫ t in (0 : ℝ)..X, deriv Q t * P t) := by
        simpa [mul_comm, mul_left_comm, mul_assoc] using
          (AbsolutelyContinuousOnInterval.integral_mul_deriv_eq_deriv_mul hQ_ac hP_ac)
      _ = Q X * P X - Q 0 * P 0 - (∫ t in (0 : ℝ)..X, P t * E t) := by
        congr 1
        calc
          (∫ t in (0 : ℝ)..X, deriv Q t * P t) = ∫ t in (0 : ℝ)..X, E t * P t := by
            apply intervalIntegral.integral_congr_ae
            filter_upwards [hderivQ_eq] with t ht htmem
            rw [ht htmem]
          _ = ∫ t in (0 : ℝ)..X, P t * E t := by
            apply intervalIntegral.integral_congr
            intro t ht
            ring
  have hQ_formula : ∀ t ∈ Set.Icc (0 : ℝ) X, Q t = (1 - E t) / σ := by
    intro t ht
    have hσ0 : (-σ) ≠ 0 := neg_ne_zero.mpr hσ.ne'
    change ∫ x in (0 : ℝ)..t, Real.exp (-(σ * x)) = (1 - Real.exp (-(σ * t))) / σ
    calc
      ∫ x in (0 : ℝ)..t, Real.exp (-(σ * x))
          = (-σ)⁻¹ • ∫ x in (-σ) * (0 : ℝ)..(-σ) * t, Real.exp x := by
              simpa [neg_mul] using
                (intervalIntegral.integral_comp_mul_left (f := Real.exp) (a := (0 : ℝ))
                  (b := t) (c := -σ) hσ0)
      _ = (-σ)⁻¹ * (Real.exp ((-σ) * t) - Real.exp 0) := by
            rw [smul_eq_mul, integral_exp]
            simp
      _ = (1 - Real.exp (-(σ * t))) / σ := by
            rw [div_eq_mul_inv, Real.exp_zero, inv_neg]
            ring
  have hDE_int : IntervalIntegrable (fun t : ℝ => D t * E t) MeasureTheory.volume (0 : ℝ) X :=
    (hD_int 0 X).mul_continuousOn hE_cont.continuousOn
  have hDQ_expand :
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) = ∫ t in (0 : ℝ)..X, D t * (1 - E t) := by
    calc
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) = ∫ t in (0 : ℝ)..X, σ * (D t * Q t) := by
        rw [← intervalIntegral.integral_const_mul]
      _ = ∫ t in (0 : ℝ)..X, D t * (1 - E t) := by
        apply intervalIntegral.integral_congr
        intro t ht
        have ht' : t ∈ Set.Icc (0 : ℝ) X := by
          simpa [Set.uIcc_of_le hX] using ht
        change σ * (D t * Q t) = D t * (1 - E t)
        rw [hQ_formula t ht']
        field_simp [hσ.ne']
  have hDQ_split :
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) =
        (∫ t in (0 : ℝ)..X, D t) - (∫ t in (0 : ℝ)..X, D t * E t) := by
    calc
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) = ∫ t in (0 : ℝ)..X, D t * (1 - E t) := hDQ_expand
      _ = ∫ t in (0 : ℝ)..X, (D t - D t * E t) := by
            apply intervalIntegral.integral_congr
            intro t ht
            ring
      _ = (∫ t in (0 : ℝ)..X, D t) - (∫ t in (0 : ℝ)..X, D t * E t) := by
            simpa using
              (intervalIntegral.integral_sub (μ := MeasureTheory.volume) (a := (0 : ℝ)) (b := X)
                (f := D) (g := fun t => D t * E t) (hD_int 0 X) hDE_int)
  have hQ0 : Q 0 = 0 := by
    simp [Q]
  have hP0 : P 0 = 0 := by
    simp [P]
  have hpartsσ :
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) =
        (1 - E X) * P X - σ * (∫ t in (0 : ℝ)..X, P t * E t) := by
    calc
      σ * (∫ t in (0 : ℝ)..X, D t * Q t) =
          σ * (Q X * P X - Q 0 * P 0 - (∫ t in (0 : ℝ)..X, P t * E t)) := by
            simpa using congrArg (fun z => σ * z) hparts'
      _ = (1 - E X) * P X - σ * (∫ t in (0 : ℝ)..X, P t * E t) := by
            rw [hQ0, hP0, hQ_formula X (by simp [hX])]
            field_simp [hσ.ne']
            ring
  have hDQ_split' :
      (∫ t in (0 : ℝ)..X, D t) =
        σ * (∫ t in (0 : ℝ)..X, D t * Q t) + (∫ t in (0 : ℝ)..X, D t * E t) := by
    exact (sub_eq_iff_eq_add).mp hDQ_split.symm
  have hfinal :
      (∫ t in (0 : ℝ)..X, D t * E t) =
        E X * P X + σ * (∫ t in (0 : ℝ)..X, P t * E t) := by
    calc
      (∫ t in (0 : ℝ)..X, D t * E t) =
          (∫ t in (0 : ℝ)..X, D t) - σ * (∫ t in (0 : ℝ)..X, D t * Q t) := by
            linarith [hDQ_split']
      _ = P X - σ * (∫ t in (0 : ℝ)..X, D t * Q t) := by
            simp [P]
      _ = P X - ((1 - E X) * P X - σ * (∫ t in (0 : ℝ)..X, P t * E t)) := by
            rw [hpartsσ]
      _ = E X * P X + σ * (∫ t in (0 : ℝ)..X, P t * E t) := by
            ring
  simpa [D, E, P, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, mul_comm, mul_left_comm,
    mul_assoc] using hfinal

theorem boundary_extension_translate_difference_damped_eq {f : ℕ → ℝ} {b δ : ℝ} :
  HasBoundaryLaplaceExtension f b → 0 < δ →
  ∃ F : ℂ → ℂ,
    ContinuousOn F {z : ℂ | 0 ≤ z.re} ∧
    Set.EqOn F
      (fun z : ℂ =>
        ∫ x in Set.Ioi (0 : ℝ),
          ((((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b) : ℝ) : ℂ) *
            Complex.exp (-z * x)))
      {z : ℂ | 0 < z.re} ∧
    F 0 = -∫ y in (0 : ℝ)..δ, (((logRescalePartialSum f y - b : ℝ) : ℂ)) := by
  intro hExt hδ
  rcases hExt with ⟨G, hGcont, hGint, hGeq⟩
  let U : ℝ → ℂ := fun y => ((logRescalePartialSum f y - b : ℝ) : ℂ)
  let J : ℂ → ℂ := fun z => ∫ y in (0 : ℝ)..δ, U y * Complex.exp (-z * y)
  let F : ℂ → ℂ := fun z => (Complex.exp (z * δ) - 1) * G z - Complex.exp (z * δ) * J z
  refine ⟨F, ?_, ?_, ?_⟩
  · have hJcont : ContinuousOn J {z : ℂ | 0 ≤ z.re} := by
      simpa [J, U] using
        (boundary_extension_local_interval_laplace_continuous (f := f) (b := b) (δ := δ))
    have hExp : Continuous fun z : ℂ => Complex.exp (z * δ) := by
      continuity
    have hExpSubOne : Continuous fun z : ℂ => Complex.exp (z * δ) - 1 := by
      continuity
    exact (hExpSubOne.continuousOn.mul hGcont).sub (hExp.continuousOn.mul hJcont)
  · intro z hz
    have hOrig : MeasureTheory.IntegrableOn
        (fun x : ℝ => U x * Complex.exp (-z * x)) (Set.Ioi (0 : ℝ)) := by
      simpa [U] using hGint z hz
    have hTail : MeasureTheory.IntegrableOn
        (fun x : ℝ => U x * Complex.exp (-z * x)) (Set.Ioi δ) := by
      refine hOrig.mono_set ?_
      intro x hx
      exact lt_trans hδ hx
    have hTailInd : MeasureTheory.Integrable
        ((Set.Ioi δ).indicator (fun x : ℝ => U x * Complex.exp (-z * x))) := by
      exact hTail.integrable_indicator measurableSet_Ioi
    have hShiftCoreInd : MeasureTheory.Integrable
        (fun x : ℝ => (Set.Ioi δ).indicator (fun x : ℝ => U x * Complex.exp (-z * x)) (x + δ)) := by
      simpa using hTailInd.comp_add_right δ
    have hShiftCore : MeasureTheory.IntegrableOn
        (fun x : ℝ => U (x + δ) * Complex.exp (-z * (x + δ))) (Set.Ioi (0 : ℝ)) := by
      rw [← MeasureTheory.integrable_indicator_iff measurableSet_Ioi]
      convert hShiftCoreInd using 1
      ext x
      by_cases hx : x ∈ Set.Ioi (0 : ℝ)
      · have hxd : x + δ ∈ Set.Ioi δ := by
          simp only [Set.mem_Ioi] at hx ⊢
          linarith
        simp [hx, hxd, U]
      · have hxd : x + δ ∉ Set.Ioi δ := by
          simp only [Set.mem_Ioi, not_lt] at hx ⊢
          linarith
        simp [hx, hxd, U]
    have hShiftInd : MeasureTheory.Integrable
        ((Set.Ioi (0 : ℝ)).indicator (fun x : ℝ => U (x + δ) * Complex.exp (-z * x))) := by
      have hShiftCoreInd0 : MeasureTheory.Integrable
          ((Set.Ioi (0 : ℝ)).indicator
            (fun x : ℝ => U (x + δ) * Complex.exp (-z * (x + δ)))) := by
        exact hShiftCore.integrable_indicator measurableSet_Ioi
      have hScaled : MeasureTheory.Integrable
          (fun x : ℝ => Complex.exp (z * δ) *
            ((Set.Ioi (0 : ℝ)).indicator
              (fun x : ℝ => U (x + δ) * Complex.exp (-z * (x + δ))) x)) := by
        exact hShiftCoreInd0.const_mul (Complex.exp (z * δ))
      convert hScaled using 1
      ext x
      by_cases hx : x ∈ Set.Ioi (0 : ℝ)
      · simp [hx]
        calc
          U (x + δ) * Complex.exp (-(z * x))
              = U (x + δ) *
                  (Complex.exp (z * δ) * Complex.exp (-(z * (x + δ)))) := by
                  congr 1
                  rw [← Complex.exp_add]
                  congr 1
                  ring
          _ = Complex.exp (z * δ) * (U (x + δ) * Complex.exp (-(z * (x + δ)))) := by
                ring
      · simp [hx]
    have hShift : MeasureTheory.IntegrableOn
        (fun x : ℝ => U (x + δ) * Complex.exp (-z * x)) (Set.Ioi (0 : ℝ)) := by
      rw [← MeasureTheory.integrable_indicator_iff measurableSet_Ioi]
      exact hShiftInd
    have hShiftEq :
        ∫ x in Set.Ioi (0 : ℝ), U (x + δ) * Complex.exp (-z * x)
          = Complex.exp (z * δ) *
              ((∫ x in Set.Ioi (0 : ℝ), U x * Complex.exp (-z * x)) - J z) := by
      simpa [J, U] using
        boundary_extension_shifted_laplace_eq
          (f := f) (b := b) (δ := δ) ⟨G, hGcont, hGint, hGeq⟩ hδ z hz
    have hOrigEq : G z = ∫ x in Set.Ioi (0 : ℝ), U x * Complex.exp (-z * x) := by
      exact hGeq hz
    calc
      F z = (∫ x in Set.Ioi (0 : ℝ), U (x + δ) * Complex.exp (-z * x))
            - ∫ x in Set.Ioi (0 : ℝ), U x * Complex.exp (-z * x) := by
        rw [hShiftEq, ← hOrigEq]
        simp only [F]
        ring
      _ = ∫ x in Set.Ioi (0 : ℝ),
            (U (x + δ) * Complex.exp (-z * x)) - (U x * Complex.exp (-z * x)) := by
        symm
        simpa using
          (MeasureTheory.integral_sub (μ := MeasureTheory.volume.restrict (Set.Ioi (0 : ℝ)))
            hShift hOrig)
      _ = ∫ x in Set.Ioi (0 : ℝ),
            ((((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b) : ℝ) : ℂ) *
              Complex.exp (-z * x)) := by
        congr with x
        simp [U, sub_mul]
  · simp [F, J, U]

theorem boundary_extension_translate_difference_real_bounded_near_zero {f : ℕ → ℝ} {b δ : ℝ} :
  HasBoundaryLaplaceExtension f b → 0 < δ →
  ∃ ε M : ℝ, 0 < ε ∧
    ∀ σ : ℝ, 0 < σ → σ < ε →
      Complex.re (∫ x in Set.Ioi (0 : ℝ),
        ((((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b) : ℝ) : ℂ) *
          Complex.exp (-(σ : ℂ) * x))) ≤ M := by
  intro hExt hδ
  rcases boundary_extension_translate_difference_damped_eq hExt hδ with ⟨F, hFcont, hFeq, hF0⟩
  have h0mem : (0 : ℂ) ∈ {z : ℂ | 0 ≤ z.re} := by
    simp
  have hcont0 : ContinuousWithinAt F {z : ℂ | 0 ≤ z.re} 0 := hFcont 0 h0mem
  rcases Metric.continuousWithinAt_iff.mp hcont0 1 zero_lt_one with ⟨ε, hεpos, hε⟩
  refine ⟨ε, ‖F 0‖ + 1, hεpos, ?_⟩
  intro σ hσpos hσlt
  have hσmem : ((σ : ℂ) ∈ {z : ℂ | 0 ≤ z.re}) := by
    simp [le_of_lt hσpos]
  have hdist : dist ((σ : ℂ)) 0 < ε := by
    simpa [dist_eq_norm, Complex.norm_real, Real.norm_eq_abs, abs_of_pos hσpos] using hσlt
  have hFclose : dist (F (σ : ℂ)) (F 0) < 1 := by
    exact hε hσmem hdist
  have hFnorm : ‖F (σ : ℂ)‖ < ‖F 0‖ + 1 := by
    have hdist' : ‖F (σ : ℂ) - F 0‖ < 1 := by
      simpa [dist_eq_norm] using hFclose
    have htriangle : ‖F (σ : ℂ)‖ ≤ ‖F (σ : ℂ) - F 0‖ + ‖F 0‖ := by
      have := norm_add_le (F (σ : ℂ) - F 0) (F 0)
      simpa [sub_add_cancel] using this
    linarith
  have hEq : F (σ : ℂ) = ∫ x in Set.Ioi (0 : ℝ),
      ((((logRescalePartialSum f (x + δ) - b) - (logRescalePartialSum f x - b) : ℝ) : ℂ) *
        Complex.exp (-(σ : ℂ) * x)) := by
    have hσre : 0 < ((σ : ℂ)).re := by simpa using hσpos
    exact hFeq hσre
  rw [← hEq]
  have hre : Complex.re (F (σ : ℂ)) ≤ ‖F (σ : ℂ)‖ := by
    simpa using (RCLike.re_le_norm (F (σ : ℂ)))
  linarith

theorem interval_average_eq_sub_translate_difference {f : ℕ → ℝ} {b δ x y : ℝ} :
  ∫ t in x..y,
      ((logRescalePartialSum f (t + δ) - b) - (logRescalePartialSum f t - b))
    =
      (∫ t in y..(y + δ), (logRescalePartialSum f t - b)) -
        ∫ t in x..(x + δ), (logRescalePartialSum f t - b) := by
  let U : ℝ → ℝ := fun t => logRescalePartialSum f t - b
  have hxy : IntervalIntegrable U MeasureTheory.volume x y := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b x y
  have hx : IntervalIntegrable U MeasureTheory.volume x (x + δ) := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b x (x + δ)
  have hshift : IntervalIntegrable U MeasureTheory.volume (x + δ) (y + δ) := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b (x + δ) (y + δ)
  have hxy_shift : IntervalIntegrable (fun t : ℝ => U (t + δ)) MeasureTheory.volume x y := by
    simpa using
      (IntervalIntegrable.comp_add_right_iff (f := U) (a := x) (b := y) (c := δ)).2 hshift
  calc
    ∫ t in x..y,
        ((logRescalePartialSum f (t + δ) - b) - (logRescalePartialSum f t - b))
        = ∫ t in x..y, (U (t + δ) - U t) := by
            simp [U]
    _ = (∫ t in x..y, U (t + δ)) - ∫ t in x..y, U t := by
          rw [intervalIntegral.integral_sub hxy_shift hxy]
    _ = (∫ t in (x + δ)..(y + δ), U t) - ∫ t in x..y, U t := by
          congr 1
          rw [intervalIntegral.integral_comp_add_right (f := U) (a := x) (b := y) (d := δ)]
    _ = (∫ t in y..(y + δ), U t) - ∫ t in x..(x + δ), U t := by
          rw [intervalIntegral.integral_interval_sub_interval_comm' hshift hxy hx.symm]
    _ = (∫ t in y..(y + δ), (logRescalePartialSum f t - b)) -
          ∫ t in x..(x + δ), (logRescalePartialSum f t - b) := by
          simp [U]

theorem interval_average_lower_bound_of_quasi_monotone {f : ℕ → ℝ} {b X δ η : ℝ} :
  (∀ n, 0 ≤ f n) →
  0 ≤ X →
  0 ≤ δ →
  0 ≤ η →
  (∫ y in (X + η)..(X + η + δ), (logRescalePartialSum f y - b))
    ≥ Real.exp (-η) * (∫ y in X..(X + δ), (logRescalePartialSum f y - b))
      - (1 - Real.exp (-η)) * b * δ := by
  intro hnonneg hX hδ hη
  let L : ℝ → ℝ := logRescalePartialSum f
  have hXδ : X ≤ X + δ := by linarith
  have hbaseInt : IntervalIntegrable (fun y : ℝ => L y - b) MeasureTheory.volume X (X + δ) :=
    logRescalePartialSum_intervalIntegrable f b X (X + δ)
  have hshiftInt : IntervalIntegrable (fun t : ℝ => L (t + η) - b) MeasureTheory.volume X (X + δ) := by
    convert (logRescalePartialSum_intervalIntegrable f b (X + η) (X + η + δ)).comp_add_right η using 1 <;> ring_nf
  have hpoint : ∀ t ∈ Set.Icc X (X + δ),
      Real.exp (-η) * (L t - b) - (1 - Real.exp (-η)) * b ≤ L (t + η) - b := by
    intro t ht
    have ht0 : 0 ≤ t := le_trans hX ht.1
    have hmono : L t ≤ Real.exp η * L (t + η) := by
      simpa [L] using (logRescalePartialSum_quasi_monotone hnonneg (x := t) (y := η) ht0 hη)
    have hexp : Real.exp (-η) * Real.exp η = 1 := by
      rw [← Real.exp_add]
      ring_nf
      simp
    have hscaled : Real.exp (-η) * L t ≤ L (t + η) := by
      calc
        Real.exp (-η) * L t ≤ Real.exp (-η) * (Real.exp η * L (t + η)) := by
          exact mul_le_mul_of_nonneg_left hmono (by positivity)
        _ = (Real.exp (-η) * Real.exp η) * L (t + η) := by ring
        _ = L (t + η) := by rw [hexp, one_mul]
    have hrew : Real.exp (-η) * (L t - b) - (1 - Real.exp (-η)) * b = Real.exp (-η) * L t - b := by
      ring
    rw [hrew]
    linarith
  have hshift :
      (∫ y in (X + η)..(X + η + δ), (L y - b)) = ∫ t in X..(X + δ), (L (t + η) - b) := by
    symm
    convert (intervalIntegral.integral_comp_add_right (f := fun y : ℝ => L y - b) (a := X) (b := X + δ) (d := η)) using 1
    ring_nf
  have hconst : IntervalIntegrable (fun _ : ℝ => (1 - Real.exp (-η)) * b) MeasureTheory.volume X (X + δ) := by
    simp
  have hlowerInt :
      IntervalIntegrable (fun t : ℝ => Real.exp (-η) * (L t - b) - (1 - Real.exp (-η)) * b) MeasureTheory.volume X (X + δ) := by
    exact (hbaseInt.const_mul (Real.exp (-η))).sub hconst
  have hmono_int :
      ∫ t in X..(X + δ), (Real.exp (-η) * (L t - b) - (1 - Real.exp (-η)) * b)
        ≤ ∫ t in X..(X + δ), (L (t + η) - b) := by
    exact intervalIntegral.integral_mono_on hXδ hlowerInt hshiftInt hpoint
  have hsmul : δ • ((1 - Real.exp (-η)) * b) = (1 - Real.exp (-η)) * b * δ := by
    change δ * ((1 - Real.exp (-η)) * b) = (1 - Real.exp (-η)) * b * δ
    ring
  have hcalc :
      ∫ t in X..(X + δ), (Real.exp (-η) * (L t - b) - (1 - Real.exp (-η)) * b)
        = Real.exp (-η) * (∫ t in X..(X + δ), (L t - b)) - (1 - Real.exp (-η)) * b * δ := by
    rw [intervalIntegral.integral_sub (hbaseInt.const_mul (Real.exp (-η))) hconst]
    rw [intervalIntegral.integral_const_mul (Real.exp (-η))]
    rw [intervalIntegral.integral_const]
    have hlen : X + δ - X = δ := by ring
    rw [hlen, hsmul]
  rw [hshift]
  linarith

theorem overshoot_intervals {f : ℕ → ℝ} {b A : ℝ} :
  (∀ n, 0 ≤ f n) →
  0 < A →
  ∃ δ c : ℝ, 0 < δ ∧ 0 < c ∧
    ∀ {x : ℝ}, 0 ≤ x → A < logRescalePartialSum f x - b →
      ∀ y ∈ Set.Icc x (x + δ), c ≤ logRescalePartialSum f y - b := by
  intro hnonneg hA
  by_cases hb : 0 ≤ b
  · refine ⟨Real.log ((A + b) / (A / 2 + b)), A / 2, ?_, ?_, ?_⟩
    · have hden : 0 < A / 2 + b := by linarith
      have hr_one : 1 < (A + b) / (A / 2 + b) := by
        have hlt : A / 2 + b < A + b := by linarith
        have hEq : (1 : ℝ) = (A / 2 + b) / (A / 2 + b) := by
          field_simp [hden.ne']
        rw [hEq]
        exact div_lt_div_of_pos_right hlt hden
      exact Real.log_pos hr_one
    · linarith
    · intro x hx hovers y hy
      have hxy : x ≤ y := hy.1
      have hy_upper : y ≤ x + Real.log ((A + b) / (A / 2 + b)) := hy.2
      have hyx_nonneg : 0 ≤ y - x := by linarith
      have hy_eq : x + (y - x) = y := by ring
      have hUxy := logRescalePartialSum_quasi_monotone (f := f) hnonneg (x := x) (y := y - x) hx hyx_nonneg
      rw [hy_eq] at hUxy
      have hAxb : A + b < logRescalePartialSum f x := by linarith
      have hden : 0 < A / 2 + b := by linarith
      have hyx_le : y - x ≤ Real.log ((A + b) / (A / 2 + b)) := by
        linarith
      have hr_pos : 0 < (A + b) / (A / 2 + b) := by
        have hnum : 0 < A + b := by linarith
        positivity
      have hr : Real.exp (y - x) ≤ (A + b) / (A / 2 + b) := by
        have htmp := Real.exp_le_exp.mpr hyx_le
        simpa [Real.exp_log hr_pos] using htmp
      have hy_nonneg : 0 ≤ logRescalePartialSum f y := logRescalePartialSum_nonneg hnonneg y
      have hmul : logRescalePartialSum f x ≤ ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
        calc
          logRescalePartialSum f x ≤ Real.exp (y - x) * logRescalePartialSum f y := hUxy
          _ ≤ ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
            gcongr
      have hlt : A + b < ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
        exact lt_of_lt_of_le hAxb hmul
      have hAy : A / 2 + b < logRescalePartialSum f y := by
        by_contra hcontra
        have hy_le : logRescalePartialSum f y ≤ A / 2 + b := by linarith
        have hmul_le : ((A + b) / (A / 2 + b)) * logRescalePartialSum f y ≤ ((A + b) / (A / 2 + b)) * (A / 2 + b) := by
          gcongr
        have hEq : ((A + b) / (A / 2 + b)) * (A / 2 + b) = A + b := by
          field_simp [hden.ne']
        linarith
      linarith
  · have hbneg : b < 0 := by linarith
    refine ⟨1, min (A / 2) (-b / 2), by norm_num, ?_, ?_⟩
    · have h1 : 0 < A / 2 := by linarith
      have h2 : 0 < -b / 2 := by linarith
      exact lt_min h1 h2
    · intro x hx hovers y hy
      have hy_nonneg : 0 ≤ logRescalePartialSum f y := logRescalePartialSum_nonneg hnonneg y
      have hmain : -b ≤ logRescalePartialSum f y - b := by linarith
      have hmin : min (A / 2) (-b / 2) ≤ -b := by
        have h2 : -b / 2 ≤ -b := by linarith
        exact le_trans (min_le_right _ _) h2
      exact le_trans hmin hmain

noncomputable def partialSumIccDiv (f : ℕ → ℝ) (Y : ℕ) : ℝ :=
  Finset.sum (Finset.Icc 1 Y) f / (Y : ℝ)

def partialSumIccEReal (f : ℕ → ℝ) (X : ℕ) : EReal :=
  ((∑ n ∈ Finset.Icc 1 X, f n : ℝ) : EReal)

theorem frequently_small_partialSumIcc_of_linearGrowthInf_nonpos {f : ℕ → ℝ} :
    LinearGrowth.linearGrowthInf (partialSumIccEReal f) ≤ 0 →
    ∀ ε : ℝ, 0 < ε →
      ∃ᶠ N : ℕ in Filter.atTop,
        ∑ k ∈ Finset.Icc 1 N, f k ≤ ε * (N : ℝ) := by
  intro h ε hε
  have hεE : (0 : EReal) < (ε : EReal) := by
    exact_mod_cast hε
  have hlt : LinearGrowth.linearGrowthInf (partialSumIccEReal f) < (ε : EReal) := by
    exact lt_of_le_of_lt h hεE
  have hfreq : ∃ᶠ N : ℕ in Filter.atTop, partialSumIccEReal f N ≤ (ε : EReal) * N := by
    exact LinearGrowth.frequently_le_mul hlt
  refine hfreq.mono ?_
  intro N hN
  have hN' : ((∑ n ∈ Finset.Icc 1 N, f n : ℝ) : EReal) ≤ (((ε * (N : ℝ) : ℝ) : EReal)) := by
    simpa [partialSumIccEReal] using hN
  exact_mod_cast hN'

def partialSumRangeEReal (f : ℕ → ℝ) (X : ℕ) : EReal :=
  ((∑ n ∈ Finset.range X, f n : ℝ) : EReal)

theorem partialSum_Icc_le_const_mul_rpow_of_LSeriesSummable_nonneg {f : ℕ → ℝ} {r : ℝ} :
    1 < r →
    (∀ n, 0 ≤ f n) →
    LSeriesSummable (fun n => (f n : ℂ)) (r : ℂ) →
    ∃ C : ℝ, 0 ≤ C ∧ ∀ N : ℕ,
      ∑ k ∈ Finset.Icc 1 N, f k ≤ C * (N : ℝ) ^ r := by
  intro hr h_nonneg hL
  have hr0 : 0 ≤ r := le_trans zero_le_one hr.le
  let g : ℕ → ℝ := fun n => ‖LSeries.term (fun m => (f m : ℂ)) (r : ℂ) n‖
  have hsum : Summable g := hL.norm
  have hsum_le (N : ℕ) : ∑ k ∈ Finset.Icc 1 N, g k ≤ ∑' n, g n := by
    refine Summable.sum_le_tsum (Finset.Icc 1 N) ?_ hsum
    intro k hk
    exact norm_nonneg _
  refine ⟨∑' n, g n, ?_, ?_⟩
  · exact tsum_nonneg (fun n => norm_nonneg _)
  · intro N
    have hpowN_nonneg : 0 ≤ (N : ℝ) ^ r := Real.rpow_nonneg (Nat.cast_nonneg N) _
    calc
      ∑ k ∈ Finset.Icc 1 N, f k ≤ ∑ k ∈ Finset.Icc 1 N, (N : ℝ) ^ r * g k := by
        refine Finset.sum_le_sum ?_
        intro k hk
        have hk_mem : k ∈ Finset.Icc 1 N := hk
        have hk_nat_pos : 0 < k := Nat.succ_le_iff.mp (Finset.mem_Icc.mp hk_mem).1
        have hk_nat_ne : k ≠ 0 := hk_nat_pos.ne'
        have hk_pos : 0 < (k : ℝ) := Nat.cast_pos.mpr hk_nat_pos
        have hk_nonneg : 0 ≤ (k : ℝ) := hk_pos.le
        have hk_le_N : (k : ℝ) ≤ (N : ℝ) := by
          exact_mod_cast (Finset.mem_Icc.mp hk_mem).2
        have hpow_le : (k : ℝ) ^ r ≤ (N : ℝ) ^ r := by
          exact Real.rpow_le_rpow hk_nonneg hk_le_N hr0
        have hkr_pos : 0 < (k : ℝ) ^ r := Real.rpow_pos_of_pos hk_pos _
        have hratio_nonneg : 0 ≤ f k / (k : ℝ) ^ r := by
          exact div_nonneg (h_nonneg k) (Real.rpow_nonneg hk_nonneg _)
        have hgk : g k = f k / (k : ℝ) ^ r := by
          dsimp [g]
          rw [LSeries.norm_term_eq]
          simp [hk_nat_ne]
          rw [abs_of_nonneg (h_nonneg k)]
        calc
          f k = (f k / (k : ℝ) ^ r) * (k : ℝ) ^ r := by
            rw [div_eq_mul_inv, mul_assoc, inv_mul_cancel₀ hkr_pos.ne', mul_one]
          _ ≤ (f k / (k : ℝ) ^ r) * (N : ℝ) ^ r := by
            exact mul_le_mul_of_nonneg_left hpow_le hratio_nonneg
          _ = (N : ℝ) ^ r * g k := by rw [hgk, mul_comm]
      _ = (N : ℝ) ^ r * ∑ k ∈ Finset.Icc 1 N, g k := by
        rw [Finset.mul_sum]
      _ ≤ (N : ℝ) ^ r * ∑' n, g n := by
        exact mul_le_mul_of_nonneg_left (hsum_le N) hpowN_nonneg
      _ = (∑' n, g n) * (N : ℝ) ^ r := by ring

theorem icc_growth_family_of_LSeriesSummable_nonneg {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ∀ r : ℝ, 1 < r → ∃ C : ℝ, 0 ≤ C ∧ ∀ N : ℕ,
      ∑ k ∈ Finset.Icc 1 N, f k ≤ C * (N : ℝ) ^ r := by
  intro hnonneg hsumm_family r hr
  have hsumm : LSeriesSummable (fun n => (f n : ℂ)) (r : ℂ) := by
    simpa using hsumm_family (r : ℂ) hr
  simpa using
    partialSum_Icc_le_const_mul_rpow_of_LSeriesSummable_nonneg (r := r) hr hnonneg hsumm

theorem icc_growth_family_sub_const {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    (∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ∀ B r : ℝ, 1 < r →
      ∃ C : ℝ, 0 ≤ C ∧ ∀ N : ℕ,
        |∑ k ∈ Finset.Icc 1 N, (f k - B)| ≤ C * (N : ℝ) ^ r := by
  intro hnonneg hsumm B r hr
  rcases icc_growth_family_of_LSeriesSummable_nonneg hnonneg hsumm r hr with ⟨C1, hC1_nonneg, hC1⟩
  refine ⟨C1 + |B|, add_nonneg hC1_nonneg (abs_nonneg B), ?_⟩
  intro N
  cases N with
  | zero =>
      have hpow_nonneg : 0 ≤ (((0 : ℕ) : ℝ) ^ r) := by
        positivity
      have hmul_nonneg : 0 ≤ (C1 + |B|) * (((0 : ℕ) : ℝ) ^ r) := by
        exact mul_nonneg (add_nonneg hC1_nonneg (abs_nonneg B)) hpow_nonneg
      simpa using hmul_nonneg
  | succ n =>
      have hsum_nonneg : 0 ≤ ∑ k ∈ Finset.Icc 1 (Nat.succ n), f k := by
        exact Finset.sum_nonneg (by
          intro k hk
          exact hnonneg k)
      have hbase : (1 : ℝ) ≤ ((Nat.succ n : ℕ) : ℝ) := by
        exact_mod_cast Nat.succ_le_succ (Nat.zero_le n)
      have hN_le_pow : ((Nat.succ n : ℕ) : ℝ) ≤ ((Nat.succ n : ℕ) : ℝ) ^ r := by
        exact Real.self_le_rpow_of_one_le hbase hr.le
      have hBmul : |B| * ((Nat.succ n : ℕ) : ℝ) ≤ |B| * ((Nat.succ n : ℕ) : ℝ) ^ r := by
        exact mul_le_mul_of_nonneg_left hN_le_pow (abs_nonneg B)
      have hconst : ∑ k ∈ Finset.Icc 1 (Nat.succ n), B = B * ((Nat.succ n : ℕ) : ℝ) := by
        calc
          ∑ k ∈ Finset.Icc 1 (Nat.succ n), B = ((Finset.Icc 1 (Nat.succ n)).card : ℝ) * B := by
            simp [nsmul_eq_mul]
          _ = B * ((Nat.succ n : ℕ) : ℝ) := by
            rw [Nat.card_Icc]
            norm_num
            ring
      have hsum_eq :
          ∑ k ∈ Finset.Icc 1 (Nat.succ n), (f k - B)
            = (∑ k ∈ Finset.Icc 1 (Nat.succ n), f k) - B * ((Nat.succ n : ℕ) : ℝ) := by
        rw [Finset.sum_sub_distrib, hconst]
      rw [hsum_eq]
      calc
        |(∑ k ∈ Finset.Icc 1 (Nat.succ n), f k) - B * ((Nat.succ n : ℕ) : ℝ)|
            ≤ |∑ k ∈ Finset.Icc 1 (Nat.succ n), f k| + |B * ((Nat.succ n : ℕ) : ℝ)| := by
              simpa using (AbsoluteValue.sub_le_add (abv := AbsoluteValue.abs)
                (∑ k ∈ Finset.Icc 1 (Nat.succ n), f k) (B * ((Nat.succ n : ℕ) : ℝ)))
        _ = (∑ k ∈ Finset.Icc 1 (Nat.succ n), f k) + |B| * ((Nat.succ n : ℕ) : ℝ) := by
              rw [abs_of_nonneg hsum_nonneg, abs_mul, abs_of_nonneg (show 0 ≤ ((Nat.succ n : ℕ) : ℝ) by positivity)]
        _ ≤ C1 * ((Nat.succ n : ℕ) : ℝ) ^ r + |B| * ((Nat.succ n : ℕ) : ℝ) := by
              gcongr
              exact hC1 (Nat.succ n)
        _ ≤ C1 * ((Nat.succ n : ℕ) : ℝ) ^ r + |B| * ((Nat.succ n : ℕ) : ℝ) ^ r := by
              gcongr
        _ = (C1 + |B|) * ((Nat.succ n : ℕ) : ℝ) ^ r := by ring

theorem integrableOn_logRescalePartialSum_kernel {f : ℕ → ℝ} :
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ∀ z : ℂ, 0 < z.re →
      MeasureTheory.IntegrableOn

lemma no_primitive_cubeRoot_of_cubic
    (F : Type) [Field F] [CharZero F] [NumberField F]
    (h_cubic : Module.finrank ℚ F = 3) :
    ¬ ∃ ζ : F, IsPrimitiveRoot ζ 3 := by
  rintro ⟨ζ, hζ⟩
  have hint : IsIntegral ℚ ζ := Algebra.IsIntegral.isIntegral ζ
  have hirr : Irreducible (Polynomial.cyclotomic 3 ℚ) :=
    Polynomial.cyclotomic.irreducible_rat (by decide)
  have hcyc : minpoly ℚ ζ = Polynomial.cyclotomic 3 ℚ :=
    (hζ.minpoly_eq_cyclotomic_of_irreducible hirr).symm
  have hdeg : (minpoly ℚ ζ).natDegree = 2 := by
    rw [hcyc, Polynomial.natDegree_cyclotomic]; decide
  have hdvd : (minpoly ℚ ζ).natDegree ∣ Module.finrank ℚ F :=
    minpoly.degree_dvd hint
  rw [hdeg, h_cubic] at hdvd
  exact absurd hdvd (by decide)


theorem prop38_burnside_basis (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (_hG : IsFinitelyGeneratedProPGroup p G)
    (k : ℕ)
    (Q : Type) [AddCommGroup Q] [Module (ZMod p) Q]
    [TopologicalSpace Q] [DiscreteTopology Q]
    (_hQrank : Module.finrank (ZMod p) Q = k)
    (φ : G →* Multiplicative Q)
    (_hφ_surj : Function.Surjective φ)
    (_hφ_cont : Continuous φ)
    : k ≤ generatorRank G := by
  rcases Nat.eq_zero_or_pos k with rfl | hk
  · exact Nat.zero_le _
  · rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hk) with ⟨n, rfl⟩
    have hfinrank : Module.finrank (ZMod p) Q = n.succ := _hQrank
    haveI : FiniteDimensional (ZMod p) Q := FiniteDimensional.of_finrank_eq_succ hfinrank
    classical
    rw [generatorRank]
    apply le_csInf
    · rcases _hG.1 with ⟨S, hS⟩
      exact ⟨S.card, ⟨S, rfl, hS⟩⟩
    · intro m hm
      rcases hm with ⟨S, rfl, hS⟩
      have h_dense : (Subgroup.closure (φ '' (S : Set G))).topologicalClosure = ⊤ := by
        have hmap := DenseRange.topologicalClosure_map_subgroup (f := φ) _hφ_cont (_hφ_surj.denseRange) hS
        simpa [MonoidHom.map_closure] using hmap
      have h_closure : Subgroup.closure (φ '' (S : Set G)) = ⊤ := by
        apply top_unique
        intro x hx
        have : x ∈ ((Subgroup.closure (φ '' (S : Set G))).topologicalClosure : Set (Multiplicative Q)) := by
          rw [h_dense]
          simp
        rwa [Subgroup.topologicalClosure_coe, closure_discrete] at this
      let T : Finset Q := S.image fun g => (φ g).toAdd
      have h_span_top : Submodule.span (ZMod p) (T : Set Q) = ⊤ := by
        apply top_unique
        intro q hq
        let K : Subgroup (Multiplicative Q) :=
          { carrier := {x | x.toAdd ∈ Submodule.span (ZMod p) (T : Set Q)}
            one_mem' := by
              change (0 : Q) ∈ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.zero_mem _
            mul_mem' := by
              intro x y hx hy
              change x.toAdd + y.toAdd ∈ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.add_mem _ hx hy
            inv_mem' := by
              intro x hx
              change -x.toAdd ∈ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.neg_mem _ hx }
        have hK : Subgroup.closure (φ '' (S : Set G)) ≤ K := by
          rw [Subgroup.closure_le]
          intro x hx
          rcases hx with ⟨g, hg, rfl⟩
          change (φ g).toAdd ∈ Submodule.span (ZMod p) (T : Set Q)
          apply Submodule.subset_span
          simpa [T] using Finset.mem_image_of_mem (fun g => (φ g).toAdd) hg
        have hqK : Multiplicative.ofAdd q ∈ K := by
          have hq_closure : Multiplicative.ofAdd q ∈ Subgroup.closure (φ '' (S : Set G)) := by
            rw [h_closure]
            simp
          exact hK hq_closure
        simpa [K] using hqK
      have h_finrank_sub : Module.finrank (ZMod p) (Submodule.span (ZMod p) (T : Set Q)) ≤ T.card := by
        simpa [T, Set.finrank] using (finrank_span_finset_le_card (R := ZMod p) T)
      have h_finrank_le : Module.finrank (ZMod p) Q ≤ T.card := by
        rw [← finrank_top (R := ZMod p) (M := Q)]
        rw [← h_span_top]
        exact h_finrank_sub
      calc
        n.succ = Module.finrank (ZMod p) Q := hfinrank.symm
        _ ≤ T.card := h_finrank_le
        _ ≤ S.card := by
          simpa [T] using (Finset.card_image_le (s := S) (f := fun g => (φ g).toAdd))

theorem prop38_killed_frobenius_splits (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))

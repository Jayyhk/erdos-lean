theorem intPolynomial_exists_prime_dvd_eval_outside (f : Polynomial ℤ) (hf : f.natDegree ≠ 0) (badPrimes : Finset ℕ) :
    ∃ q : ℕ, q.Prime ∧ q ∉ badPrimes ∧ ∃ n : ℤ, (q : ℤ) ∣ Polynomial.eval n f := by
  classical
  have hspecial : ∀ {f : Polynomial ℤ}, f.natDegree ≠ 0 → f.eval 0 ≠ 0 →
      ∀ badPrimes : Finset ℕ,
        ∃ q : ℕ, q.Prime ∧ q ∉ badPrimes ∧ ∃ n : ℤ, (q : ℤ) ∣ Polynomial.eval n f := by
    intro g hg h0 badPrimes
    let a : ℤ := Polynomial.eval 0 g
    let M : ℤ := ∏ p ∈ badPrimes.filter Nat.Prime, (p : ℤ)
    have ha : a ≠ 0 := h0
    have hM : M ≠ 0 := by
      classical
      dsimp [M]
      refine Finset.prod_ne_zero_iff.mpr ?_
      intro p hp
      exact_mod_cast (Finset.mem_filter.mp hp).2.ne_zero
    have hdivX_ne : g.divX ≠ 0 := by
      intro hzero
      apply hg
      rw [Polynomial.natDegree_eq_zero]
      exact ⟨g.coeff 0, (Polynomial.divX_eq_zero_iff.mp hzero).symm⟩
    have hAM_nz : a * M ≠ 0 := mul_ne_zero ha hM
    have hcomp_ne : g.divX.comp (Polynomial.C (a * M) * Polynomial.X) ≠ 0 := by
      exact fun h => hdivX_ne ((Polynomial.comp_C_mul_X_eq_zero_iff (by
        simpa [mem_nonZeroDivisors_iff_ne_zero] using hAM_nz)).mp h)
    let G : Polynomial ℤ :=
      Polynomial.C 1 + Polynomial.C M * Polynomial.X * (g.divX.comp (Polynomial.C (a * M) * Polynomial.X))
    have hA_ne : Polynomial.C M * Polynomial.X * (g.divX.comp (Polynomial.C (a * M) * Polynomial.X)) ≠ 0 := by
      exact mul_ne_zero (mul_ne_zero (by simpa using hM) Polynomial.X_ne_zero) hcomp_ne
    have hGsub_ne : G - Polynomial.C 1 ≠ 0 := by
      simpa [G, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hA_ne
    have hGadd_ne : G + Polynomial.C 1 ≠ 0 := by
      intro hzero
      have hz := congrArg (Polynomial.eval 0) hzero
      simp [G] at hz
    have hGeval (m : ℤ) :
        Polynomial.eval m G = 1 + M * (m * Polynomial.eval ((a * M) * m) g.divX) := by
      simp [G, mul_assoc, mul_left_comm, mul_comm, add_assoc, add_left_comm, add_comm]
    have hRootsFinite :
        ({x : ℤ | Polynomial.IsRoot (G - Polynomial.C 1) x} ∪
          {x : ℤ | Polynomial.IsRoot (G + Polynomial.C 1) x}).Finite := by
      exact (Polynomial.finite_setOf_isRoot hGsub_ne).union (Polynomial.finite_setOf_isRoot hGadd_ne)
    rcases hRootsFinite.exists_notMem with ⟨m, hm⟩
    have hm1 : ¬ Polynomial.IsRoot (G - Polynomial.C 1) m := by
      exact fun hroot => hm (Or.inl hroot)
    have hm2 : ¬ Polynomial.IsRoot (G + Polynomial.C 1) m := by
      exact fun hroot => hm (Or.inr hroot)
    have hm_ne_one : Polynomial.eval m G ≠ 1 := by
      intro hEq
      apply hm1
      simp [Polynomial.IsRoot, hEq]
    have hm_ne_neg_one : Polynomial.eval m G ≠ -1 := by
      intro hEq
      apply hm2
      simp [Polynomial.IsRoot, hEq]
    have hnatAbs_ne_one : (Polynomial.eval m G).natAbs ≠ 1 := by
      intro hna
      have hu : IsUnit (Polynomial.eval m G) := (Int.isUnit_iff_natAbs_eq).2 hna
      rcases (Int.isUnit_iff.mp hu) with hEq | hEq
      · exact hm_ne_one hEq
      · exact hm_ne_neg_one hEq
    rcases Int.exists_prime_and_dvd hnatAbs_ne_one with ⟨p, hp_prime, hp_dvd⟩
    have hqprime : p.natAbs.Prime := (Int.prime_iff_natAbs_prime).mp hp_prime
    have hq_dvd_G : ((p.natAbs : ℤ) ∣ Polynomial.eval m G) := by
      exact (Associated.dvd_iff_dvd_left (Int.associated_natAbs p)).mp hp_dvd
    have hq_not_mem : p.natAbs ∉ badPrimes := by
      intro hp_mem
      have hp_mem' : p.natAbs ∈ badPrimes.filter Nat.Prime := by
        simp [hp_mem, hqprime]
      have hq_dvd_M : ((p.natAbs : ℤ) ∣ M) := by
        change ((p.natAbs : ℤ) ∣ ∏ r ∈ badPrimes.filter Nat.Prime, ((r : ℕ) : ℤ))
        exact Finset.dvd_prod_of_mem (s := badPrimes.filter Nat.Prime) (a := p.natAbs)
          (fun r : ℕ => (r : ℤ)) hp_mem'
      have hq_dvd_term : ((p.natAbs : ℤ) ∣ M * (m * Polynomial.eval ((a * M) * m) g.divX)) := by
        exact dvd_mul_of_dvd_left hq_dvd_M (m * Polynomial.eval ((a * M) * m) g.divX)
      have hq_dvd_one : ((p.natAbs : ℤ) ∣ 1) := by
        have hsub : ((p.natAbs : ℤ) ∣ Polynomial.eval m G - M * (m * Polynomial.eval ((a * M) * m) g.divX)) := by
          exact dvd_sub hq_dvd_G hq_dvd_term
        simpa [hGeval, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, mul_assoc] using hsub
      have hnat_dvd_one : p.natAbs ∣ (1 : ℕ) := by
        simpa using (Int.natCast_dvd.mp hq_dvd_one)
      exact hqprime.ne_one (Nat.dvd_one.mp hnat_dvd_one)
    have hmain_eval (m : ℤ) : Polynomial.eval ((a * M) * m) g = a * Polynomial.eval m G := by
      have hdecomp0 := congrArg (Polynomial.eval ((a * M) * m)) (Polynomial.X_mul_divX_add g)
      have hdecomp : Polynomial.eval ((a * M) * m) g = ((a * M) * m) * Polynomial.eval ((a * M) * m) g.divX + a := by
        simpa [a, mul_assoc, mul_left_comm, mul_comm, add_assoc, add_left_comm, add_comm,
          Polynomial.coeff_zero_eq_eval_zero] using hdecomp0.symm
      calc
        Polynomial.eval ((a * M) * m) g
            = ((a * M) * m) * Polynomial.eval ((a * M) * m) g.divX + a := hdecomp
        _ = a * (1 + M * (m * Polynomial.eval ((a * M) * m) g.divX)) := by ring
        _ = a * Polynomial.eval m G := by rw [hGeval]
    refine ⟨p.natAbs, hqprime, hq_not_mem, (a * M) * m, ?_⟩
    rw [hmain_eval]
    exact dvd_mul_of_dvd_right hq_dvd_G a
  have hf_ne_zero : f ≠ 0 := by
    intro hzero
    apply hf
    simp [hzero]
  have hRootsFinite : ({x : ℤ | Polynomial.IsRoot f x}).Finite :=
    Polynomial.finite_setOf_isRoot hf_ne_zero
  rcases hRootsFinite.exists_notMem with ⟨c, hc⟩
  have hc0 : Polynomial.eval c f ≠ 0 := by
    exact fun hroot => hc hroot
  have hshift_lin : (Polynomial.X + Polynomial.C c).natDegree ≠ 0 := by
    rw [Polynomial.natDegree_X_add_C]
    decide
  have hshift_deg : (f.comp (Polynomial.X + Polynomial.C c)).natDegree ≠ 0 := by
    simpa [Polynomial.natDegree_comp] using And.intro hf hshift_lin
  have hshift0 : Polynomial.eval 0 (f.comp (Polynomial.X + Polynomial.C c)) ≠ 0 := by
    simpa [Polynomial.eval_comp, add_comm, add_left_comm, add_assoc] using hc0
  rcases hspecial hshift_deg hshift0 badPrimes with ⟨q, hqprime, hqnotmem, n, hn⟩
  refine ⟨q, hqprime, hqnotmem, n + c, ?_⟩
  simpa [Polynomial.eval_comp, add_comm, add_left_comm, add_assoc] using hn

theorem minpoly_discr_ne_zero (K : Type) [Field K] [NumberField K] {θ : NumberField.RingOfIntegers K} :
    Polynomial.discr (minpoly ℤ θ) ≠ 0 := by
  classical
  let f : Polynomial ℤ := minpoly ℤ θ
  let φ : ℤ →+* ℚ := Int.castRingHom ℚ
  let fQ : Polynomial ℚ := f.map φ
  have hθintO : IsIntegral ℤ θ := by
    let hAI : Algebra.IsIntegral ℤ (NumberField.RingOfIntegers K) := inferInstance
    exact (Algebra.isIntegral_def.mp hAI) θ
  have hθint : IsIntegral ℤ ((θ : K)) := NumberField.RingOfIntegers.isIntegral_coe θ
  have hfQ_eq : fQ = minpoly ℚ ((θ : K)) := by
    dsimp [fQ, f]
    symm
    simpa [NumberField.RingOfIntegers.minpoly_coe θ] using
      (minpoly.isIntegrallyClosed_eq_field_fractions' (R := ℤ) (K := ℚ) (S := K) hθint)
  have hsepQ : fQ.Separable := by
    rw [hfQ_eq]
    exact (show (minpoly ℚ ((θ : K))).Separable from IsSeparable.of_integral ℚ ((θ : K)))
  have hf_monic : f.Monic := by
    dsimp [f]
    exact minpoly.monic hθintO
  have hfQ_monic : fQ.Monic := by
    dsimp [fQ]
    exact hf_monic.map φ
  have hf_deg : 0 < f.degree := by
    dsimp [f]
    simpa using minpoly.degree_pos hθintO
  have hfQ_natDegree : fQ.natDegree = f.natDegree := by
    dsimp [fQ]
    simpa using hf_monic.natDegree_map φ
  have hcopQ : IsCoprime fQ fQ.derivative := (Polynomial.separable_def _).mp hsepQ
  have hresQ0 : fQ.resultant fQ.derivative ≠ 0 :=
    Polynomial.resultant_ne_zero _ _ hcopQ
  have hresQ_eq : fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) = fQ.resultant fQ.derivative := by
    let k : ℕ := (fQ.natDegree - 1) - fQ.derivative.natDegree
    have hkdeg : fQ.derivative.natDegree ≤ fQ.natDegree - 1 := Polynomial.natDegree_derivative_le fQ
    have htmp :=
      Polynomial.resultant_add_right_deg (f := fQ) (g := fQ.derivative)
        (m := fQ.natDegree) (n := fQ.derivative.natDegree) k (by exact le_rfl)
    dsimp [k] at htmp
    rw [Nat.add_sub_of_le hkdeg] at htmp
    simpa [hfQ_monic.leadingCoeff] using htmp
  have hresQ : fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) ≠ 0 := by
    rw [hresQ_eq]
    exact hresQ0
  have hderiv_map : fQ.derivative = f.derivative.map φ := by
    dsimp [fQ]
    simp
  have hres_map :
      fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) =
        φ (f.resultant f.derivative f.natDegree (f.natDegree - 1)) := by
    rw [hderiv_map, hfQ_natDegree]
    simp [fQ]
  have hformulaQ :
      fQ.resultant fQ.derivative fQ.natDegree (fQ.natDegree - 1) =
        ((-1 : ℚ) ^ (f.natDegree * (f.natDegree - 1) / 2)) * φ f.discr := by
    rw [hres_map, Polynomial.resultant_deriv (f := f) hf_deg]
    simp [hf_monic.leadingCoeff]
  have hcast_discr_ne_zero : φ f.discr ≠ 0 := by
    intro hzero
    have hresQ' := hresQ
    rw [hformulaQ, hzero] at hresQ'
    simp at hresQ'
  intro hzero
  apply hcast_discr_ne_zero
  simpa [hzero]

theorem minpoly_mod_separable_of_not_dvd_discr (K : Type) [Field K] [NumberField K] {θ : NumberField.RingOfIntegers K}
    (p : ℕ) [Fact p.Prime]
    (hdisc : ¬ p ∣ (Polynomial.discr (minpoly ℤ θ)).natAbs) :
    (Polynomial.map (Int.castRingHom (ZMod p)) (minpoly ℤ θ)).Separable := by
  set φ : ℤ →+* ZMod p := Int.castRingHom (ZMod p)
  set f : Polynomial ℤ := minpoly ℤ θ
  set fbar : Polynomial (ZMod p) := Polynomial.map φ f
  have hf_monic : f.Monic := by
    simpa [f] using minpoly.monic θ.isIntegral
  have hfbar_monic : fbar.Monic := by
    simpa [fbar] using Polynomial.Monic.map φ hf_monic
  have hdegmap : fbar.natDegree = f.natDegree := by
    simpa [fbar] using hf_monic.natDegree_map φ
  have hdisc_zmod_ne : ((Polynomial.discr f : ℤ) : ZMod p) ≠ 0 := by
    intro hzero
    apply hdisc
    exact Int.natCast_dvd.mp <| (ZMod.intCast_zmod_eq_zero_iff_dvd (Polynomial.discr f) p).mp hzero
  have hres0 :
      fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) =
        (-1 : ZMod p) ^ (fbar.natDegree * (fbar.natDegree - 1) / 2) *
          ((Polynomial.discr f : ℤ) : ZMod p) := by
    have hres0' := congrArg φ (Polynomial.resultant_deriv (f := f) (by simpa [f] using minpoly.degree_pos θ.isIntegral))
    rw [← Polynomial.resultant_map_map (φ := φ) (f := f) (g := f.derivative)
      (m := f.natDegree) (n := f.natDegree - 1), ← Polynomial.derivative_map] at hres0'
    simpa [fbar, hdegmap, hf_monic.leadingCoeff] using hres0'
  have hres0_ne : fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) ≠ 0 := by
    rw [hres0]
    exact mul_ne_zero (pow_ne_zero _ (by simp)) hdisc_zmod_ne
  have hres_eq :
      fbar.resultant fbar.derivative fbar.natDegree (fbar.natDegree - 1) =
        fbar.resultant fbar.derivative := by
    have h :=
      Polynomial.resultant_add_right_deg (f := fbar) (g := fbar.derivative) (m := fbar.natDegree)
        (n := fbar.derivative.natDegree)
        (k := fbar.natDegree - 1 - fbar.derivative.natDegree) le_rfl
    rw [Nat.add_sub_of_le (Polynomial.natDegree_derivative_le fbar), hfbar_monic.coeff_natDegree,
      one_pow, one_mul] at h
    simpa using h
  have hres_ne : fbar.resultant fbar.derivative ≠ 0 := by
    rw [← hres_eq]
    exact hres0_ne
  rw [Polynomial.separable_def]
  exact (Polynomial.isUnit_resultant_iff_isCoprime hfbar_monic).mp (isUnit_iff_ne_zero.mpr hres_ne)

theorem numberField_exists_integral_primitive_element (K : Type) [Field K] [NumberField K] :
    ∃ θ : NumberField.RingOfIntegers K,
      IntermediateField.adjoin ℚ ({(θ : K)} : Set K) = ⊤ := by
  classical
  obtain ⟨α, hα⟩ := Field.exists_primitive_element ℚ K
  obtain ⟨y, hy, hyα⟩ := exists_integral_multiples ℤ ℚ ({α} : Finset K)
  let θ : NumberField.RingOfIntegers K := ⟨y • α, hyα α (by simp)⟩
  refine ⟨θ, ?_⟩
  set L : IntermediateField ℚ K := IntermediateField.adjoin ℚ ({(θ : K)} : Set K)
  have hy_mem : algebraMap ℚ K (y : ℚ) ∈ L :=
    IntermediateField.algebraMap_mem L (y : ℚ)
  have hy_inv_mem : (algebraMap ℚ K (y : ℚ))⁻¹ ∈ L :=
    IntermediateField.inv_mem L hy_mem
  have hθ_mem : (θ : K) ∈ L := by
    change (θ : K) ∈ IntermediateField.adjoin ℚ ({(θ : K)} : Set K)
    exact IntermediateField.subset_adjoin ℚ ({(θ : K)} : Set K) (by simp)
  have hmem : α ∈ L := by
    have hmul_mem : (algebraMap ℚ K (y : ℚ))⁻¹ * (θ : K) ∈ L :=
      IntermediateField.mul_mem L hy_inv_mem hθ_mem
    have hEq : (algebraMap ℚ K (y : ℚ))⁻¹ * (θ : K) = α := by
      change (algebraMap ℚ K (y : ℚ))⁻¹ * (y • α) = α
      simp [smul_eq_mul, hy, mul_assoc]
    exact hEq ▸ hmul_mem
  have hle := (IntermediateField.adjoin_simple_le_iff (F := ℚ) (α := α) (K := L)).2 hmem
  have htop_le : (⊤ : IntermediateField ℚ K) ≤ L := by
    simpa [hα] using hle
  have hL_top : L = ⊤ := le_antisymm le_top htop_le
  simpa [L] using hL_top

open NumberField in
theorem prime_above_ef_one_of_not_dvd_exponent_discr_and_eval (K : Type) [Field K] [NumberField K] {θ : NumberField.RingOfIntegers K}
    (p : ℕ) [Fact p.Prime]
    (hexp : ¬ p ∣ RingOfIntegers.exponent θ)
    (hdisc : ¬ p ∣ (Polynomial.discr (minpoly ℤ θ)).natAbs)
    {n : ℤ} (hn : (p : ℤ) ∣ Polynomial.eval n (minpoly ℤ θ)) :
    ∃ 𝔓 ∈ (Ideal.span {(p : ℤ)} : Ideal ℤ).primesOver (𝓞 K),
      Ideal.ramificationIdx (Ideal.span {(p : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
      Ideal.inertiaDeg (Ideal.span {(p : ℤ)} : Ideal ℤ) 𝔓 = 1 := by
  classical
  let f : Polynomial ℤ := minpoly ℤ θ
  let fbar : Polynomial (ZMod p) := Polynomial.map (Int.castRingHom (ZMod p)) f
  let a : ZMod p := n
  have hfbar_ne : fbar ≠ 0 := by
    dsimp [fbar, f]
    exact Polynomial.map_monic_ne_zero (minpoly.monic θ.isIntegral)
  have hroot_eval : Polynomial.eval a fbar = 0 := by
    dsimp [fbar, a, f]
    rw [Polynomial.eval_intCast_map]
    exact (ZMod.intCast_zmod_eq_zero_iff_dvd (Polynomial.eval n (minpoly ℤ θ)) p).2 hn
  have hisroot : Polynomial.IsRoot fbar a := hroot_eval
  have hdvd : Polynomial.X - Polynomial.C a ∣ fbar := by
    exact (Polynomial.dvd_iff_isRoot).2 hisroot
  have hmem : Polynomial.X - Polynomial.C a ∈ RingOfIntegers.monicFactorsMod θ p := by
    rw [RingOfIntegers.monicFactorsMod, Multiset.mem_toFinset]
    exact (Polynomial.mem_normalizedFactors_iff hfbar_ne).2
      ⟨Polynomial.irreducible_X_sub_C a, Polynomial.monic_X_sub_C a, hdvd⟩
  let Q : RingOfIntegers.monicFactorsMod θ p := ⟨Polynomial.X - Polynomial.C a, hmem⟩
  let P : (Ideal.span {(p : ℤ)} : Ideal ℤ).primesOver (𝓞 K) :=
    (NumberField.Ideal.primesOverSpanEquivMonicFactorsMod (θ := θ) (p := p) hexp).symm Q
  refine ⟨P, P.2, ?_, ?_⟩
  · have hsep : fbar.Separable := by
      simpa [fbar, f] using minpoly_mod_separable_of_not_dvd_discr K p hdisc
    have hpos : 0 < Polynomial.rootMultiplicity a fbar :=
      (Polynomial.rootMultiplicity_pos hfbar_ne).2 hisroot
    have hle : Polynomial.rootMultiplicity a fbar ≤ 1 :=
      Polynomial.rootMultiplicity_le_one_of_separable hsep a
    have hrootmult : Polynomial.rootMultiplicity a fbar = 1 := by
      omega
    have hmult : multiplicity (Polynomial.X - Polynomial.C a) fbar = 1 := by
      rw [← hrootmult]
      rw [Polynomial.rootMultiplicity_eq_multiplicity fbar a]
      simp [hfbar_ne]
    simpa [P, Q, fbar] using
      (NumberField.Ideal.ramificationIdx_primesOverSpanEquivMonicFactorsMod_symm_apply'
        (θ := θ) (p := p) hexp hmem).trans hmult
  · simpa [P, Q] using
      (NumberField.Ideal.inertiaDeg_primesOverSpanEquivMonicFactorsMod_symm_apply'
        (θ := θ) (p := p) hexp hmem).trans (Polynomial.natDegree_X_sub_C a)

open NumberField in
theorem primewise_split_descends_of_tower (K L : Type) [Field K] [Field L] [NumberField K] [NumberField L]
    [Algebra ℚ K] [Algebra ℚ L] [Algebra K L] [IsScalarTower ℚ K L]
    (q : ℕ) (_hq : q.Prime)
    (hL :
      ∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) :
    ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 K),
      Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
      Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
  intro 𝔭 h𝔭
  let p : Ideal ℤ := Ideal.span {(q : ℤ)}
  letI : Fact q.Prime := ⟨_hq⟩
  letI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime q)
  let pK : p.primesOver (𝓞 K) := ⟨𝔭, by simpa [p] using h𝔭⟩
  letI : 𝔭.IsPrime := Ideal.primesOver.isPrime p pK
  letI : 𝔭.LiesOver p := Ideal.primesOver.liesOver p pK
  letI : 𝔭.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p] using h𝔭)
  obtain ⟨Psub⟩ := Ideal.nonempty_primesOver (R := 𝓞 K) (S := 𝓞 L) 𝔭
  let 𝔓 : Ideal (𝓞 L) := Psub
  letI : 𝔓.IsPrime := Ideal.primesOver.isPrime 𝔭 Psub
  letI : 𝔓.LiesOver 𝔭 := Ideal.primesOver.liesOver 𝔭 Psub
  letI : 𝔓.LiesOver p := Ideal.LiesOver.trans 𝔓 𝔭 p
  have h𝔓 : 𝔓 ∈ p.primesOver (𝓞 L) := by
    exact (Ideal.primesOver.mk p 𝔓).2
  rcases hL 𝔓 (by simpa [p] using h𝔓) with ⟨he𝔓, hf𝔓⟩
  have hp_ne_bot : p ≠ ⊥ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast _hq.ne_zero
  have h𝔭_ne_bot : 𝔭 ≠ ⊥ := Ideal.ne_bot_of_liesOver_of_ne_bot hp_ne_bot 𝔭
  have hmap_𝔭_ne_bot : Ideal.map (algebraMap (𝓞 K) (𝓞 L)) 𝔭 ≠ ⊥ :=
    Ideal.map_ne_bot_of_ne_bot h𝔭_ne_bot
  have hmap_p_ne_bot : Ideal.map (algebraMap ℤ (𝓞 L)) p ≠ ⊥ :=
    Ideal.map_ne_bot_of_ne_bot hp_ne_bot
  have hmap_𝔭_le : Ideal.map (algebraMap (𝓞 K) (𝓞 L)) 𝔭 ≤ 𝔓 := by
    rw [Ideal.map_le_iff_le_comap]
    exact le_of_eq (by simpa [Ideal.under_def] using (Ideal.over_def (A := 𝓞 K) (P := 𝔓) (p := 𝔭)))
  have hram_tower :=
    Ideal.ramificationIdx_algebra_tower (R := ℤ) (S := 𝓞 K) (T := 𝓞 L)
      (p := p) (P := 𝔭) (Q := 𝔓) hmap_𝔭_ne_bot hmap_p_ne_bot hmap_𝔭_le
  have hmul_e : Ideal.ramificationIdx p 𝔭 * Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
    calc
      Ideal.ramificationIdx p 𝔭 * Ideal.ramificationIdx 𝔭 𝔓
          = Ideal.ramificationIdx p 𝔓 := by simpa [p] using hram_tower.symm
      _ = 1 := by simpa [p] using he𝔓
  have he𝔭 : Ideal.ramificationIdx p 𝔭 = 1 := (mul_eq_one.mp hmul_e).1
  have hmul_f : Ideal.inertiaDeg p 𝔭 * Ideal.inertiaDeg 𝔭 𝔓 = 1 := by
    calc
      Ideal.inertiaDeg p 𝔭 * Ideal.inertiaDeg 𝔭 𝔓
          = Ideal.inertiaDeg p 𝔓 := by
              simpa [p] using (Ideal.inertiaDeg_algebra_tower (R := ℤ) (S := 𝓞 K) (T := 𝓞 L) p 𝔭 𝔓).symm
      _ = 1 := by simpa [p] using hf𝔓
  have hf𝔭 : Ideal.inertiaDeg p 𝔭 = 1 := (mul_eq_one.mp hmul_f).1
  exact ⟨by simpa [p] using he𝔭, by simpa [p] using hf𝔭⟩

open NumberField in
theorem primewise_split_in_cyclotomic4_implies_mod4 (C : Type) [Field C] [NumberField C] [Algebra ℚ C] [IsCyclotomicExtension {4} ℚ C]
    (q : ℕ) (_hq : q.Prime)
    (hC :
      ∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 C),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) :
    q % 4 = 1 := by
  classical
  let alg : Algebra ℚ C := inferInstance
  have hCyclo_old : @IsCyclotomicExtension ({4} : Set ℕ) ℚ C _ _ alg := inferInstance
  letI : Algebra ℚ C := DivisionRing.toRatAlgebra
  have hAlg : alg = (inferInstance : Algebra ℚ C) := Subsingleton.elim _ _
  have hCyclo : IsCyclotomicExtension ({4} : Set ℕ) ℚ C := by
    have hCyclo_old' := hCyclo_old
    rw [hAlg] at hCyclo_old'
    exact hCyclo_old'
  letI : IsCyclotomicExtension ({4} : Set ℕ) ℚ C := hCyclo
  letI : Fact q.Prime := ⟨_hq⟩
  letI : (Ideal.span {(q : ℤ)} : Ideal ℤ).IsMaximal := Int.ideal_span_isMaximal_of_prime q
  obtain ⟨⟨𝔓, h𝔓prime, h𝔓over⟩⟩ := (Ideal.span {(q : ℤ)} : Ideal ℤ).nonempty_primesOver (S := 𝓞 C)
  letI : 𝔓.IsPrime := h𝔓prime
  letI : 𝔓.LiesOver (Ideal.span {(q : ℤ)} : Ideal ℤ) := h𝔓over
  rcases hC 𝔓 ⟨h𝔓prime, h𝔓over⟩ with ⟨hRam, hIner⟩
  by_cases hq2 : q = 2
  · subst hq2
    letI : IsCyclotomicExtension ({2 ^ (1 + 1)} : Set ℕ) ℚ C := by
      simpa using (inferInstance : IsCyclotomicExtension ({4} : Set ℕ) ℚ C)
    have hramP : Ideal.ramificationIdx (Ideal.span {(2 : ℤ)} : Ideal ℤ) 𝔓 = 2 := by
      simpa using
        (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_prime_pow (p := 2) (k := 1)
          (K := C) (P := 𝔓))
    have : (1 : ℕ) = 2 := by
      calc
        1 = Ideal.ramificationIdx (Ideal.span {(2 : ℤ)} : Ideal ℤ) 𝔓 := hRam.symm
        _ = 2 := hramP
    omega
  · have hq4 : ¬ q ∣ 4 := by
      intro hdiv
      have hdiv' : q ∣ 2 ^ 2 := by simpa using hdiv
      have hdiv2 : q ∣ 2 := _hq.dvd_of_dvd_pow hdiv'
      have hqle : q ≤ 2 := Nat.le_of_dvd (by norm_num) hdiv2
      have hqge : 2 ≤ q := _hq.two_le
      omega
    have horder : orderOf (q : ZMod 4) = 1 := by
      have hcalc : Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = orderOf (q : ZMod 4) := by
        simpa using
          (IsCyclotomicExtension.Rat.inertiaDeg_eq_of_not_dvd (p := q) (m := 4)
            (K := C) (P := 𝔓) hq4)
      calc
        orderOf (q : ZMod 4) = Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 := hcalc.symm
        _ = 1 := hIner
    have hz : (q : ZMod 4) = 1 := (orderOf_eq_one_iff.mp horder)
    simpa [ZMod.val_natCast] using congrArg ZMod.val hz

open NumberField in
theorem primewise_split_transport_of_algEquiv (K L : Type) [Field K] [Field L] [NumberField K] [NumberField L]
    [Algebra ℚ K] [Algebra ℚ L]
    (e : K ≃ₐ[ℚ] L) (q : ℕ) (_hq : q.Prime)
    (hL :
      ∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) :
    ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 K),
      Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
      Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
  intro 𝔭 h𝔭
  let pZ : Ideal ℤ := Ideal.span {(q : ℤ)}
  let e𝓞 : 𝓞 K ≃ₐ[ℤ] 𝓞 L :=
    AlgEquiv.ofRingEquiv
      (f := NumberField.RingOfIntegers.mapRingEquiv e.toRingEquiv)
      (by
        intro z
        simp)
  have hprime : 𝔭.IsPrime := by
    exact Ideal.primesOver.isPrime (Q := (⟨𝔭, h𝔭⟩ : pZ.primesOver (𝓞 K)))
  have hlies : 𝔭.LiesOver pZ := by
    exact Ideal.primesOver.liesOver (Q := (⟨𝔭, h𝔭⟩ : pZ.primesOver (𝓞 K)))
  have hmap_mem : Ideal.map e𝓞 𝔭 ∈ pZ.primesOver (𝓞 L) := by
    letI : 𝔭.IsPrime := hprime
    letI : 𝔭.LiesOver pZ := hlies
    letI : (Ideal.map e𝓞 𝔭).IsPrime := Ideal.map_isPrime_of_equiv e𝓞
    letI : (Ideal.map e𝓞 𝔭).LiesOver pZ :=
      Ideal.map_equiv_liesOver (P := 𝔭) (p := pZ) (σ := e𝓞)
    exact (Ideal.primesOver.mk pZ (Ideal.map e𝓞 𝔭)).2
  rcases hL (Ideal.map e𝓞 𝔭) hmap_mem with ⟨h_ram, h_inert⟩
  constructor
  · rwa [Ideal.ramificationIdx_map_eq (p := pZ) (P := 𝔭) (e := e𝓞)] at h_ram
  · letI : Fact q.Prime := ⟨_hq⟩
    letI : pZ.IsMaximal := Int.ideal_span_isMaximal_of_prime q
    rwa [Ideal.inertiaDeg_map_eq (p := pZ) (P := 𝔭) (e := e𝓞)] at h_inert

open NumberField in
theorem proposition_3_6_frattini_fixedField_exists
    (hFG : Hyp_FiniteTopologicalRank) (F : Type) [Field F] [NumberField F] :
    ∃ (M : IntermediateField F (maximalUnramifiedProPF F 3))
      (_ : FiniteDimensional F M) (_ : NumberField M) (_ : IsGalois F M),
      IsEverywhereUnramified F M ∧
      M.fixingSubgroup =
        closedFrattini 3 (MaxUnramifiedProPGaloisGroup F 3) := by
  let G := MaxUnramifiedProPGaloisGroup F 3
  let K := maximalUnramifiedProPF F 3
  letI : IsGalois F K := MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F 3
  let H : OpenNormalSubgroup G :=
    { __ := closedFrattini 3 G
      isOpen' := closedFrattini_isOpen G 3
        (MaxUnramifiedProPGaloisGroup.isFinitelyGeneratedProPGroup hFG (F := F) (p := 3))
      isNormal' := closedFrattini_normal (p := 3) (G := G) }
  let M : IntermediateField F K := IntermediateField.fixedField (H : Subgroup G)
  have hfg : FiniteDimensional F M ∧ IsGalois F M :=
    fixedField_openNormal_finiteGalois (k := F) (K := K) H
  have hfin : FiniteDimensional F M := hfg.1
  have hgalois : IsGalois F M := hfg.2
  let _ : NumberField M := NumberField.of_module_finite F M
  have hfix : M.fixingSubgroup = (H : Subgroup G) := by
    let Hc : ClosedSubgroup G :=
      { toSubgroup := (H : Subgroup G)
        isClosed' := by
          simpa using H.isClosed }
    simpa [M] using (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) Hc)
  refine ⟨M, hfin, inferInstance, hgalois, ?_, ?_⟩
  · exact finiteIntermediate_isUnramified (F := F) (p := 3) (L := M)
  · simpa [H, G] using hfix

open NumberField in
def proposition_3_6_goodPrime
    (F : Type) [Field F] [NumberField F] (q : ℕ) : Prop :=
  q.Prime ∧
    q % 4 = 1 ∧
    ((∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
      ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F)).ncard =
        Module.finrank ℚ F) ∧
    (∀ (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥),
      𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F) →
      splittingDetectorAt F 3 𝔭 hp hne ∈
        closedFrattini 3 (MaxUnramifiedProPGaloisGroup F 3))


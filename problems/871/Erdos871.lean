/-- P_k is a subset of [N_{k-1}+1, n_k] for k ≥ 1 -/
lemma P_subset (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    ∀ x ∈ seq.P k, seq.N (k-1) + 1 ≤ x ∧ x ≤ seq.n k := by
  intro x hx
  simp only [P, if_neg (Nat.one_le_iff_ne_zero.mp hk), Finset.mem_Icc] at hx
  constructor
  · exact hx.1
  · have := seq.exponential_growth k hk
    simp only [N] at hx
    omega
/-- R_k is a subset of [n_k+1, n_k + N_{k-1}] for k ≥ 1 -/
lemma R_subset (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    ∀ x ∈ seq.R k, seq.n k + 1 ≤ x ∧ x ≤ seq.n k + seq.N (k-1) := by
  intro x hx
  simp only [R, if_neg (Nat.one_le_iff_ne_zero.mp hk)] at hx
  simp only [Finset.mem_sdiff, Finset.mem_Icc] at hx
  exact hx.1
/-- S_k is a subset of R_k for k ≥ 1 -/
lemma S_subset_R (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    seq.S k ⊆ seq.R k := by
  intro x hx
  simp only [S, if_neg (Nat.one_le_iff_ne_zero.mp hk), Finset.mem_Icc] at hx
  simp only [R, if_neg (Nat.one_le_iff_ne_zero.mp hk)]
  simp only [Finset.mem_sdiff, Finset.mem_Icc, Finset.mem_image, not_exists, not_and]
  constructor
  · -- x is in [n_k + 1, n_k + N_{k-1}]
    constructor
    · exact hx.1
    · -- x ≤ n_k + n_{k-1} + k + 1 ≤ n_k + N_{k-1} = n_k + 2n_{k-1} + 1
      simp only [N]
      have hbound := seq.growth_bound k hk
      omega
  · -- x is not a forbidden element
    intro u hu_mem rfl
    have hu_lo : 1 ≤ u := hu_mem.1
    have : 3 * k * u ≥ 3 * k := by nlinarith [hu_lo]
    have : seq.n k + seq.n (k - 1) + 3 * k * u ≥ seq.n k + seq.n (k - 1) + 3 * k := by omega
    omega
/-- S_k is a subset of B_k for k ≥ 1 -/
lemma S_subset_B (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    seq.S k ⊆ seq.B_k k := by
  intro x hx
  have hR := seq.S_subset_R k hk hx
  simp only [B_k]
  exact Finset.mem_union_right _ hR
/-- Q_k elements are bounded above by n_k - n_{k-1} - 3k + 1 for k ≥ 1 -/
lemma Q_upper_bound (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :
    ∀ x ∈ seq.Q k, x ≤ seq.n k - seq.n (k-1) - 3*k + 1 := by
  intro x hx
  simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hk)] at hx
  simp only [Finset.mem_image, Finset.mem_Icc] at hx
  obtain ⟨u, ⟨hu_lo, _⟩, rfl⟩ := hx
  have : 3 * k * u ≥ 3 * k * 1 := Nat.mul_le_mul_left (3*k) hu_lo
  omega
/-- Q_k elements are less than n_k for k ≥ 1 -/
lemma Q_lt_n (seq : NathansonSeq) (k : ℕ) (hk : 1 ≤ k) :

    have hPb_periodic_d : ∀ r r' : ℕ, r % b = r' % b →
        ((¬ GoodCompositeSuccessor 20 y_target d r) ↔ ¬ GoodCompositeSuccessor 20 y_target d r') := by
      intros r r' hmod
      have h := hPb_periodic d r r' hmod
      rw [hA_eq_20] at h
      exact h

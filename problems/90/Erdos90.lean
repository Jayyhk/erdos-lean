theorem exists_conjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (f : groupCohomology.cocycles₂ (quotientTrivialMulRep A G N))
    (hf1 : ∀ q : G ⧸ N, f (1, q) = 0)
    (hf2 : ∀ q : G ⧸ N, f (q, 1) = 0)
    (hinfl : letI := trivialMulDistribMulAction G A;
      groupCohomology.IsMulCoboundary₂
        (fun gh : G × G =>
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2)))) :
    ∃ χ : ConjInvariantHom A G N, ∃ u : G ⧸ N → A,
      ∀ x y : G ⧸ N,
        Additive.toMul (show Additive A from f (x, y)) =
          u y / u (x * y) * u x * quotientTransgressionFactor A G N χ.1 (x, y) := by
  classical
  letI := trivialMulDistribMulAction G A
  rcases hinfl with ⟨b, hb⟩
  have hb' :
      ∀ g h : G,
        b h / b (g * h) * b g =
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) g, (QuotientGroup.mk' N) h)) := by
    intro g h
    simpa using hb g h
  have hnq : ∀ n : N, QuotientGroup.mk' N (n : G) = 1 := by
    intro n
    simp
  have hf1mul : ∀ q : G ⧸ N, Additive.toMul (show Additive A from f (1, q)) = (1 : A) := by
    intro q
    simp [hf1 q]
  have hf2mul : ∀ q : G ⧸ N, Additive.toMul (show Additive A from f (q, 1)) = (1 : A) := by
    intro q
    simp [hf2 q]
  have hb_one : b 1 = 1 := by
    have h := hb' (1 : G) 1
    simpa using h.trans (hf1mul (1 : G ⧸ N))
  have hb_leftN : ∀ n : N, ∀ g : G, b ((n : G) * g) = b n * b g := by
    intro n g
    have h : b g / b ((n : G) * g) * b n = 1 := by
      have h0 := hb' (n : G) g
      rw [hnq n] at h0
      exact h0.trans (hf1mul ((QuotientGroup.mk' N) g))
    have h' := congrArg (fun z : A => z * b ((n : G) * g)) h
    simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using h'.symm
  have hb_rightN : ∀ g : G, ∀ n : N, b (g * n) = b g * b n := by
    intro g n
    have h : b n / b (g * (n : G)) * b g = 1 := by
      have h0 := hb' g (n : G)
      rw [hnq n] at h0
      exact h0.trans (hf2mul ((QuotientGroup.mk' N) g))
    have h' := congrArg (fun z : A => z * b (g * (n : G))) h
    simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using h'.symm
  have hb_mulN : ∀ n1 n2 : N, b ((n1 : G) * n2) = b n1 * b n2 := by
    intro n1 n2
    simpa using hb_leftN n1 (n2 : G)
  let χ0 : N →* A :=
    { toFun := fun n => (b n)⁻¹
      map_one' := by
        change (b (1 : G))⁻¹ = 1
        simp [hb_one]
      map_mul' := by
        intro n1 n2
        change (b ((n1 : G) * n2))⁻¹ = (b n1)⁻¹ * (b n2)⁻¹
        rw [hb_mulN n1 n2]
        simp [mul_comm] }
  let σ := quotientGroupSection G N
  let u : G ⧸ N → A := fun q => b (σ q)
  refine ⟨⟨χ0, ?_⟩, u, ?_⟩
  · intro g
    ext n
    change (b ((MulAut.conjNormal (H := N) g) n))⁻¹ = (b n)⁻¹
    have hleft : b (g * (n : G)) = b ((MulAut.conjNormal (H := N) g) n) * b g := by
      simpa [MulAut.conjNormal_apply, mul_assoc] using
        (hb_leftN ((MulAut.conjNormal (H := N) g) n) g)
    have hright : b (g * (n : G)) = b g * b n := by
      simpa using hb_rightN g n
    have hcomp : b ((MulAut.conjNormal (H := N) g) n) * b g = b n * b g := by
      exact hleft.symm.trans (by simpa [mul_comm] using hright)
    have hEq' := congrArg (fun z : A => z * (b g)⁻¹) hcomp
    have hEq : b ((MulAut.conjNormal (H := N) g) n) = b n := by
      simpa [mul_assoc, mul_left_comm, mul_comm] using hEq'
    simpa using congrArg Inv.inv hEq
  · intro x y
    have hsecx : QuotientGroup.mk' N (σ x) = x := by
      simpa [σ, quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section
          (S := quotientGroupExtension G N) (σ := quotientGroupSection G N) x)
    have hsecy : QuotientGroup.mk' N (σ y) = y := by
      simpa [σ, quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section
          (S := quotientGroupExtension G N) (σ := quotientGroupSection G N) y)
    have hmain : u y / b (σ x * σ y) * u x =
        Additive.toMul (show Additive A from f (x, y)) := by
      simpa [u, σ, hsecx, hsecy] using hb' (σ x) (σ y)
    have hdefmul : σ x * σ y = (quotientSectionDefect G N (x, y) : G) * σ (x * y) := by
      have h := congrArg (fun z : G => z * σ (x * y)) (quotientSectionDefect_spec G N x y)
      simpa [σ, mul_assoc] using h.symm
    have hbdef : b (σ x * σ y) = b (quotientSectionDefect G N (x, y)) * u (x * y) := by
      rw [hdefmul]
      simpa [u, σ] using hb_leftN (quotientSectionDefect G N (x, y)) (σ (x * y))
    calc
      Additive.toMul (show Additive A from f (x, y))
          = u y / b (σ x * σ y) * u x := by
            simpa using hmain.symm
      _ = u y / (b (quotientSectionDefect G N (x, y)) * u (x * y)) * u x := by
            rw [hbdef]
      _ = u y / u (x * y) * u x * quotientTransgressionFactor A G N χ0 (x, y) := by
            simp [u, σ, χ0, quotientTransgressionFactor, div_eq_mul_inv,
              mul_assoc, mul_left_comm, mul_comm]

theorem quotientH2_exists_normalized_cocycle (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (x : groupCohomology.H2 (quotientTrivialMulRep A G N)) :
    ∃ f : groupCohomology.cocycles₂ (quotientTrivialMulRep A G N),
      groupCohomology.H2π (quotientTrivialMulRep A G N) f = x ∧
        (∀ q : G ⧸ N, f (1, q) = 0) ∧
        (∀ q : G ⧸ N, f (q, 1) = 0) := by
  classical
  letI := trivialMulDistribMulAction (G ⧸ N) A
  change groupCohomology.H2 (Rep.ofMulDistribMulAction (G ⧸ N) A) at x
  change
    ∃ f : groupCohomology.cocycles₂ (Rep.ofMulDistribMulAction (G ⧸ N) A),
      groupCohomology.H2π (Rep.ofMulDistribMulAction (G ⧸ N) A) f = x ∧
        (∀ q : G ⧸ N, f (1, q) = 0) ∧
        (∀ q : G ⧸ N, f (q, 1) = 0)
  refine groupCohomology.H2_induction_on x ?_
  intro z
  let c : A := Additive.toMul (z (1, 1))
  have hcob : groupCohomology.IsMulCoboundary₂ (fun _ : (G ⧸ N) × (G ⧸ N) => c⁻¹) := by
    refine ⟨fun _ : G ⧸ N => c⁻¹, ?_⟩
    intro g h
    change c⁻¹ / c⁻¹ * c⁻¹ = c⁻¹
    simp
  let b : groupCohomology.coboundaries₂ (Rep.ofMulDistribMulAction (G ⧸ N) A) :=
    groupCohomology.coboundariesOfIsMulCoboundary₂ hcob
  let f : groupCohomology.cocycles₂ (Rep.ofMulDistribMulAction (G ⧸ N) A) :=
    z + groupCohomology.coboundariesToCocycles₂ _ b
  refine ⟨f, ?_, ?_, ?_⟩
  · rw [groupCohomology.H2π_eq_iff]
    have hdiff : ⇑f - ⇑z = ⇑b := by
      ext p
      change z p + b p - z p = b p
      abel
    rw [hdiff]
    exact b.2
  · intro q
    have hz : z (1, q) = z (1, 1) := groupCohomology.cocycles₂_map_one_fst z q
    have hb : b (1, q) = - z (1, 1) := by
      rfl
    change z (1, q) + b (1, q) = 0
    rw [hz, hb]
    abel
  · intro q
    have hz : z (q, 1) = z (1, 1) := by
      simpa [Rep.ofMulDistribMulAction_ρ_apply_apply, c] using
        groupCohomology.cocycles₂_map_one_snd z q
    have hb : b (q, 1) = - z (1, 1) := by
      rfl
    change z (q, 1) + b (q, 1) = 0
    rw [hz, hb]
    abel

noncomputable def quotientTransgressionCocycle (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (χ : N →* A)
    (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) :
    groupCohomology.cocycles₂ (quotientTrivialMulRep A G N) := by
  letI := trivialMulDistribMulAction (G ⧸ N) A
  have hf : groupCohomology.IsMulCocycle₂ (quotientTransgressionFactor A G N χ) := by
    classical
    intro x y z
    change
      χ (quotientSectionDefect G N (x * y, z)) * χ (quotientSectionDefect G N (x, y)) =
        χ (quotientSectionDefect G N (y, z)) * χ (quotientSectionDefect G N (x, y * z))
    let S := quotientGroupExtension G N
    let σ := quotientGroupSection G N
    let c : (G ⧸ N) × (G ⧸ N) → N := quotientSectionDefect G N
    have hmul (a b : G ⧸ N) : σ a * σ b = ↑(c (a, b)) * σ (a * b) := by
      calc
        σ a * σ b = (σ a * σ b * (σ (a * b))⁻¹) * σ (a * b) := by
          simp [mul_assoc]
        _ = ↑(c (a, b)) * σ (a * b) := by
          congr 1
          unfold c quotientSectionDefect
          simpa [quotientGroupSection, quotientGroupExtension] using
            (Classical.choose_spec
              (show ∃ n : N,
                  (quotientGroupExtension G N).inl n =
                    quotientGroupSection G N a * quotientGroupSection G N b *
                      (quotientGroupSection G N (a * b))⁻¹ from by
                simpa [MonoidHom.mem_range, quotientGroupSection, quotientGroupExtension] using
                  (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
                    (S := quotientGroupExtension G N)
                    (σ := quotientGroupSection G N) (g₁ := a) (g₂ := b)))).symm
    have hleft : σ x * σ y * σ z = (((c (x, y) * c (x * y, z) : N) : G) * σ (x * (y * z))) := by
      calc
        σ x * σ y * σ z = (σ x * σ y) * σ z := by
          simp [mul_assoc]
        _ = (↑(c (x, y)) * σ (x * y)) * σ z := by
          rw [hmul x y]
        _ = ↑(c (x, y)) * (σ (x * y) * σ z) := by
          simp [mul_assoc]
        _ = ↑(c (x, y)) * (↑(c (x * y, z)) * σ ((x * y) * z)) := by
          rw [hmul (x * y) z]
        _ = (((c (x, y) * c (x * y, z) : N) : G) * σ ((x * y) * z)) := by
          simp [mul_assoc]
        _ = (((c (x, y) * c (x * y, z) : N) : G) * σ (x * (y * z))) := by
          rw [mul_assoc]
    have hright : σ x * σ y * σ z =
        (((((S.conjAct (σ x)) (c (y, z))) * c (x, y * z) : N) : G) * σ (x * (y * z))) := by
      calc
        σ x * σ y * σ z = σ x * (σ y * σ z) := by
          simp [mul_assoc]
        _ = σ x * (↑(c (y, z)) * σ (y * z)) := by
          rw [hmul y z]
        _ = (σ x * ↑(c (y, z)) * (σ x)⁻¹) * (σ x * σ (y * z)) := by
          simp [mul_assoc]
        _ = (↑((S.conjAct (σ x)) (c (y, z))) * (σ x * σ (y * z))) := by
          congr 1
          simpa [S] using (GroupExtension.inl_conjAct_comm (S := S) (e := σ x) (n := c (y, z))).symm
        _ = ↑((S.conjAct (σ x)) (c (y, z))) * (↑(c (x, y * z)) * σ (x * (y * z))) := by
          rw [hmul x (y * z)]
        _ = (((((S.conjAct (σ x)) (c (y, z))) * c (x, y * z) : N) : G) * σ (x * (y * z))) := by
          simp [mul_assoc]
    have hEqG : (((c (x, y) * c (x * y, z) : N) : G)) =
        (((((S.conjAct (σ x)) (c (y, z))) * c (x, y * z) : N) : G)) := by
      have htmp :
          (((c (x, y) * c (x * y, z) : N) : G) * σ (x * (y * z))) =
            (((((S.conjAct (σ x)) (c (y, z))) * c (x, y * z) : N) : G) * σ (x * (y * z))) := by
        calc
          (((c (x, y) * c (x * y, z) : N) : G) * σ (x * (y * z))) = σ x * σ y * σ z := by
            simpa using hleft.symm
          _ = (((((S.conjAct (σ x)) (c (y, z))) * c (x, y * z) : N) : G) * σ (x * (y * z))) := by
            simpa using hright
      have htmp' := congrArg (fun g : G => g * (σ (x * (y * z)))⁻¹) htmp
      simpa [mul_assoc] using htmp'
    have hEqN : c (x, y) * c (x * y, z) = (S.conjAct (σ x)) (c (y, z)) * c (x, y * z) := by
      exact Subtype.ext hEqG
    have hχeq : χ (c (x, y)) * χ (c (x * y, z)) =
        χ ((S.conjAct (σ x)) (c (y, z))) * χ (c (x, y * z)) := by
      simpa using congrArg χ hEqN
    have hχconj : χ ((S.conjAct (σ x)) (c (y, z))) = χ (c (y, z)) := by
      have hconjEq : S.conjAct (σ x) = MulAut.conjNormal (H := N) (σ x) := by
        ext n
        simpa [S, quotientGroupExtension, MulAut.conjNormal_apply] using
          ((quotientGroupExtension G N).inl_conjAct_comm (e := σ x) (n := n))
      have hχσ : χ.comp ((S.conjAct (σ x)).toMonoidHom) = χ := by
        rw [hconjEq]
        exact hχ (σ x)
      simpa using DFunLike.congr_fun hχσ (c (y, z))
    have hfinal : χ (c (x, y)) * χ (c (x * y, z)) = χ (c (y, z)) * χ (c (x, y * z)) := by
      calc
        χ (c (x, y)) * χ (c (x * y, z)) = χ ((S.conjAct (σ x)) (c (y, z))) * χ (c (x, y * z)) := hχeq
        _ = χ (c (y, z)) * χ (c (x, y * z)) := by rw [hχconj]
    simpa [c, mul_comm] using hfinal
  simpa [quotientTrivialMulRep, Rep.ofMulDistribMulAction] using
    (groupCohomology.cocyclesOfIsMulCocycle₂ hf)

noncomputable abbrev quotientTransgressionClass (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (χ : N →* A)
    (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) :
    groupCohomology.H2 (quotientTrivialMulRep A G N) :=
  groupCohomology.H2π (quotientTrivialMulRep A G N)
    (quotientTransgressionCocycle A G N χ hχ)

noncomputable def quotientTransgressionMap (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    ConjInvariantHom A G N → groupCohomology.H2 (quotientTrivialMulRep A G N) := fun χ =>
  quotientTransgressionClass A G N χ.1 χ.2

theorem normalized_quotientCocycle_class_eq_transgressionMap_of_inflated_coboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (f : groupCohomology.cocycles₂ (quotientTrivialMulRep A G N))
    (hf1 : ∀ q : G ⧸ N, f (1, q) = 0)
    (hf2 : ∀ q : G ⧸ N, f (q, 1) = 0)
    (hinfl : letI := trivialMulDistribMulAction G A;
      groupCohomology.IsMulCoboundary₂
        (fun gh : G × G =>
          Additive.toMul
            (show Additive A from f ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2)))) :
    ∃ χ : ConjInvariantHom A G N,
      groupCohomology.H2π (quotientTrivialMulRep A G N) f = quotientTransgressionMap A G N χ := by
  rcases
      exists_conjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary
        A G N f hf1 hf2 hinfl with ⟨χ, u, hu⟩
  refine ⟨χ, ?_⟩
  rw [quotientTransgressionMap, quotientTransgressionClass]
  apply
    (groupCohomology.H2π_eq_iff (A := quotientTrivialMulRep A G N) f
      (quotientTransgressionCocycle A G N χ.1 χ.2)).2
  letI := trivialMulDistribMulAction (G ⧸ N) A
  change
    (Additive.ofMul ∘ fun xy : (G ⧸ N) × (G ⧸ N) =>
      Additive.toMul
        (show Additive A from
          f xy - quotientTransgressionCocycle A G N χ.1 χ.2 xy)) ∈
      groupCohomology.coboundaries₂ (Rep.ofMulDistribMulAction (G ⧸ N) A)
  refine
    (groupCohomology.coboundariesOfIsMulCoboundary₂
      (f := fun xy : (G ⧸ N) × (G ⧸ N) =>
        Additive.toMul
          (show Additive A from
            f xy - quotientTransgressionCocycle A G N χ.1 χ.2 xy)) ?_).property
  refine ⟨u, ?_⟩
  intro x y
  have htrans :
      Additive.toMul
          (show Additive A from
            quotientTransgressionCocycle A G N χ.1 χ.2 (x, y)) =
        quotientTransgressionFactor A G N χ.1 (x, y) := by
    unfold quotientTransgressionCocycle
    rfl
  calc
    u y / u (x * y) * u x =
        (u y / u (x * y) * u x * quotientTransgressionFactor A G N χ.1 (x, y)) /
          quotientTransgressionFactor A G N χ.1 (x, y) := by
      simp [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm]
    _ =
        Additive.toMul (show Additive A from f (x, y)) /
          quotientTransgressionFactor A G N χ.1 (x, y) := by
      rw [hu x y]
    _ =
        Additive.toMul (show Additive A from f (x, y)) /
          Additive.toMul
            (show Additive A from
              quotientTransgressionCocycle A G N χ.1 χ.2 (x, y)) := by
      rw [htrans]
    _ =
        Additive.toMul
          (show Additive A from
            f (x, y) - quotientTransgressionCocycle A G N χ.1 χ.2 (x, y)) := by
      rfl

theorem transgressionFactor_isMulCoboundary_of_exists_lift (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : N →* A) : (∃ ψ : G →* A, ψ.comp N.subtype = χ) → letI := trivialMulDistribMulAction (G ⧸ N) A; groupCohomology.IsMulCoboundary₂ (quotientTransgressionFactor A G N χ) := by
  intro hχ
  classical
  letI := trivialMulDistribMulAction (G ⧸ N) A
  rcases hχ with ⟨ψ, hψ⟩
  refine ⟨fun q => ψ (quotientGroupSection G N q), ?_⟩
  intro x y
  dsimp [quotientTransgressionFactor]
  have hdef := quotientSectionDefect_spec G N x y
  have hcomp := congrArg (fun f => f (quotientSectionDefect G N (x, y))) hψ
  dsimp [MonoidHom.comp] at hcomp
  change ψ ((quotientGroupSection G N) y) / ψ ((quotientGroupSection G N) (x * y)) *
      ψ ((quotientGroupSection G N) x) = χ (quotientSectionDefect G N (x, y))
  rw [← hcomp, hdef]
  simp [map_mul, map_inv, div_eq_mul_inv, mul_comm, mul_left_comm, mul_assoc]

theorem transgressionFactor_isMulCoboundary_iff_exists_lift (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : N →* A) (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) : letI := trivialMulDistribMulAction (G ⧸ N) A; groupCohomology.IsMulCoboundary₂ (quotientTransgressionFactor A G N χ) ↔ ∃ ψ : G →* A, ψ.comp N.subtype = χ := by
  constructor
  · intro h
    exact exists_lift_of_transgressionFactor_isMulCoboundary A G N χ hχ h
  · intro h
    exact transgressionFactor_isMulCoboundary_of_exists_lift A G N χ h

theorem quotientTransgressionClass_eq_zero_iff_exists_lift (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : N →* A) (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) : quotientTransgressionClass A G N χ hχ = 0 ↔ ∃ ψ : G →* A, ψ.comp N.subtype = χ := by
  constructor
  · intro h0
    letI := trivialMulDistribMulAction (G ⧸ N) A
    have hmem :
        ⇑(quotientTransgressionCocycle A G N χ hχ) ∈
          groupCohomology.coboundaries₂ (quotientTrivialMulRep A G N) := by
      exact
        (groupCohomology.H2π_eq_zero_iff
          (A := quotientTrivialMulRep A G N)
          (x := quotientTransgressionCocycle A G N χ hχ)).1 (by
            simpa [quotientTransgressionClass] using h0)
    have hcb : groupCohomology.IsMulCoboundary₂ (quotientTransgressionFactor A G N χ) := by
      simpa [Function.comp_def] using
        (groupCohomology.isMulCoboundary₂_of_mem_coboundaries₂
          (f := quotientTransgressionFactor A G N χ) (by
            simpa [quotientTransgressionCocycle, quotientTrivialMulRep,
              Rep.ofMulDistribMulAction, Function.comp_def] using hmem))
    exact (transgressionFactor_isMulCoboundary_iff_exists_lift A G N χ hχ).1 hcb
  · rintro ⟨ψ, hψ⟩
    letI := trivialMulDistribMulAction (G ⧸ N) A
    have hcb : groupCohomology.IsMulCoboundary₂ (quotientTransgressionFactor A G N χ) := by
      exact (transgressionFactor_isMulCoboundary_iff_exists_lift A G N χ hχ).2 ⟨ψ, hψ⟩
    have hmem :
        ⇑(quotientTransgressionCocycle A G N χ hχ) ∈
          groupCohomology.coboundaries₂ (quotientTrivialMulRep A G N) := by
      simpa [quotientTransgressionCocycle, quotientTrivialMulRep,
        Rep.ofMulDistribMulAction, Function.comp_def] using
          (groupCohomology.coboundariesOfIsMulCoboundary₂ hcb).2
    exact
      (groupCohomology.H2π_eq_zero_iff
        (A := quotientTrivialMulRep A G N)
        (x := quotientTransgressionCocycle A G N χ hχ)).2 (by
          simpa [quotientTransgressionClass] using hmem)

theorem quotientTransgressionMap_eq_zero_iff_mem_range_restrictToConjInvariantHom (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : ConjInvariantHom A G N) : quotientTransgressionMap A G N χ = 0 ↔ χ ∈ Set.range (restrictToConjInvariantHom A G N) := by
  constructor
  · intro hzero
    rcases
      (quotientTransgressionClass_eq_zero_iff_exists_lift A G N χ.1 χ.2).1
        (by simpa [quotientTransgressionMap] using hzero) with ⟨ψ, hψ⟩
    exact ⟨ψ, Subtype.ext hψ⟩
  · rintro ⟨ψ, rfl⟩
    simpa [quotientTransgressionMap, restrictToConjInvariantHom] using
      (quotientTransgressionClass_eq_zero_iff_exists_lift A G N
        (ψ.comp N.subtype) ((restrictToConjInvariantHom A G N ψ).2)).2 ⟨ψ, rfl⟩

noncomputable abbrev trivialMulRep (A G : Type) [CommGroup A] [Group G] : Rep ℤ G := by
  letI := trivialMulDistribMulAction G A
  exact Rep.of (Representation.ofMulDistribMulAction (M := G) (G := A))

noncomputable abbrev quotientTrivialToTrivialHom (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    Rep.res (QuotientGroup.mk' N) (quotientTrivialMulRep A G N) ⟶
      trivialMulRep A G :=
  CategoryTheory.CategoryStruct.id _

noncomputable abbrev quotientH2Inflation (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    groupCohomology.H2 (quotientTrivialMulRep A G N) ⟶ groupCohomology.H2 (trivialMulRep A G) :=
  groupCohomology.map (QuotientGroup.mk' N) (quotientTrivialToTrivialHom A G N) 2

theorem quotientTransgressionMap_inflates_to_zero (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (χ : ConjInvariantHom A G N) :
    quotientH2Inflation A G N (quotientTransgressionMap A G N χ) = 0 := by
  change (groupCohomology.map (QuotientGroup.mk' N) (quotientTrivialToTrivialHom A G N) 2)
      (groupCohomology.H2π (quotientTrivialMulRep A G N)
        (quotientTransgressionCocycle A G N χ.1 χ.2)) = 0
  rw [show (groupCohomology.map (QuotientGroup.mk' N) (quotientTrivialToTrivialHom A G N) 2)
      (groupCohomology.H2π (quotientTrivialMulRep A G N)
        (quotientTransgressionCocycle A G N χ.1 χ.2)) =
      groupCohomology.H2π (trivialMulRep A G)
        (groupCohomology.mapCocycles₂ (QuotientGroup.mk' N) (quotientTrivialToTrivialHom A G N)
          (quotientTransgressionCocycle A G N χ.1 χ.2)) by
      simp]
  apply (groupCohomology.H2π_eq_zero_iff _).2
  letI := trivialMulDistribMulAction G A
  simpa [groupCohomology.coe_mapCocycles₂, inflatedQuotientTransgressionFactor,
    quotientTransgressionFactor, quotientTrivialToTrivialHom, quotientTrivialMulRep, trivialMulRep,
    trivialMulDistribMulAction] using
    (groupCohomology.coboundariesOfIsMulCoboundary₂
      (G := G) (M := A) (f := inflatedQuotientTransgressionFactor A G N χ.1)
      (inflatedQuotientTransgressionFactor_isMulCoboundary A G N χ.1 χ.2)).2

theorem quotientH2Inflation_eq_zero_iff_mem_range_quotientTransgressionMap (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal]
    (x : groupCohomology.H2 (quotientTrivialMulRep A G N)) :
    quotientH2Inflation A G N x = 0 ↔ x ∈ Set.range (quotientTransgressionMap A G N) := by
  constructor
  · intro hx
    rcases quotientH2_exists_normalized_cocycle A G N x with ⟨f, hfclass, hf1, hf2⟩
    rw [← hfclass] at hx
    have hcomp :
        quotientH2Inflation A G N ((groupCohomology.H2π (quotientTrivialMulRep A G N)) f) =
          groupCohomology.H2π (trivialMulRep A G)
            (groupCohomology.mapCocycles₂ (QuotientGroup.mk' N)
              (quotientTrivialToTrivialHom A G N) f) := by
      simp [quotientH2Inflation]
    rw [hcomp] at hx
    have hmem :
        ⇑(groupCohomology.mapCocycles₂ (QuotientGroup.mk' N)
          (quotientTrivialToTrivialHom A G N) f) ∈
          groupCohomology.coboundaries₂ (trivialMulRep A G) := by
      exact (groupCohomology.H2π_eq_zero_iff _).mp hx
    letI := trivialMulDistribMulAction G A
    have hmem' :
        (fun gh : G × G =>
          Additive.toMul
            (show Additive A from
              (groupCohomology.mapCocycles₂ (QuotientGroup.mk' N)
                (quotientTrivialToTrivialHom A G N) f) gh)) ∈
          groupCohomology.coboundaries₂ (Rep.of (Representation.ofMulDistribMulAction (M := G) (G := A))) := by
      simpa [trivialMulRep, quotientTrivialToTrivialHom, quotientTrivialMulRep,
        trivialMulDistribMulAction] using hmem
    have hinfl :
        groupCohomology.IsMulCoboundary₂
          (fun gh : G × G =>
            Additive.toMul
              (show Additive A from f ((QuotientGroup.mk' N) gh.1, (QuotientGroup.mk' N) gh.2))) := by
      simpa [trivialMulRep, quotientTrivialToTrivialHom, quotientTrivialMulRep,
        trivialMulDistribMulAction] using
        (groupCohomology.isMulCoboundary₂_of_mem_coboundaries₂ (M := A)
          (f := fun gh : G × G =>
            Additive.toMul
              (show Additive A from
                (groupCohomology.mapCocycles₂ (QuotientGroup.mk' N)
                  (quotientTrivialToTrivialHom A G N) f) gh)) hmem')
    rcases normalized_quotientCocycle_class_eq_transgressionMap_of_inflated_coboundary
        A G N f hf1 hf2 hinfl with ⟨χ, hχ⟩
    refine ⟨χ, ?_⟩
    rw [← hfclass]
    exact hχ.symm
  · rintro ⟨χ, rfl⟩
    exact quotientTransgressionMap_inflates_to_zero A G N χ

theorem inflation_restriction_five_term_zmod_abstract (p : ℕ) (G : Type) [Group G] (N : Subgroup G) [N.Normal] : Function.Injective ((groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).f) ∧ (groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).Exact ∧ (∀ χ : ConjInvariantHom (Multiplicative (ZMod p)) G N, quotientTransgressionMap (Multiplicative (ZMod p)) G N χ = 0 ↔ χ ∈ Set.range (restrictToConjInvariantHom (Multiplicative (ZMod p)) G N)) ∧ (∀ x : groupCohomology.H2 (quotientTrivialMulRep (Multiplicative (ZMod p)) G N), quotientH2Inflation (Multiplicative (ZMod p)) G N x = 0 ↔ x ∈ Set.range (quotientTransgressionMap (Multiplicative (ZMod p)) G N)) := by
  refine ⟨inflation_restriction_H1_injective_zmod p G N, inflation_restriction_H1_exact_zmod p G N, ?_, ?_⟩
  · intro χ
    exact quotientTransgressionMap_eq_zero_iff_mem_range_restrictToConjInvariantHom
      (A := Multiplicative (ZMod p)) (G := G) (N := N) χ
  · intro x
    exact quotientH2Inflation_eq_zero_iff_mem_range_quotientTransgressionMap
      (A := Multiplicative (ZMod p)) (G := G) (N := N) x


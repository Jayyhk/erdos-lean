theorem primesCongOneMod3_prime_series_lower_bound: вҲғ C : в„қ, вҲҖ {x : в„қ}, x вҲҲ Set.Ioc 1 2 вҶ’
    ((Nat.totient 3 : в„қ)вҒ»В№ / (x - 1) - C) вүӨ
      вҲ‘' n : в„•, (if n.Prime вҲ§ n % 3 = 1 then Real.log (n : в„қ) else 0) / (n : в„қ) ^ x := by
  rcases primesCongOneMod3_residueClass_lower_bound with вҹЁCвӮҖ, hCвӮҖвҹ©
  let B : в„қ := вҲ‘' n : в„•, (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n
  refine вҹЁCвӮҖ + B, ?_вҹ©
  intro x hx
  let f : в„• вҶ’ в„қ := fun n => primesCongOneMod3_residueClass n / (n : в„қ) ^ x
  let fPrime : в„• вҶ’ в„қ := fun n => (if n.Prime then primesCongOneMod3_residueClass n else 0) / (n : в„қ) ^ x
  let fNonprime : в„• вҶ’ в„қ := fun n => (if n.Prime then 0 else primesCongOneMod3_residueClass n) / (n : в„қ) ^ x
  let target : в„• вҶ’ в„қ := fun n =>
    (if n.Prime вҲ§ n % 3 = 1 then Real.log (n : в„қ) else 0) / (n : в„қ) ^ x
  have hfull : ((Nat.totient 3 : в„қ)вҒ»В№ / (x - 1) - CвӮҖ) вүӨ вҲ‘' n, f n := by
    simpa [f] using hCвӮҖ hx
  have hfullsumm : Summable f := by
    dsimp [f, primesCongOneMod3_residueClass]
    have hx' : (1 : EReal) < x := by
      exact_mod_cast hx.1
    exact LSeries.summable_real_of_abscissaOfAbsConv_lt <|
      (ArithmeticFunction.vonMangoldt.abscissaOfAbsConv_residueClass_le_one (a := (1 : ZMod 3))).trans_lt hx'
  have hNonprime_nonneg (n : в„•) : 0 вүӨ fNonprime n := by
    dsimp [fNonprime]
    by_cases hn : n.Prime
    В· simp [hn]
    В· simp [hn]
      exact div_nonneg
        (ArithmeticFunction.vonMangoldt.residueClass_nonneg (a := (1 : ZMod 3)) n)
        (Real.rpow_nonneg (by exact_mod_cast Nat.zero_le n) x)
  have hNonprime_le (n : в„•) : fNonprime n вүӨ (if n.Prime then 0 else primesCongOneMod3_residueClass n) / n := by
    rcases n.eq_zero_or_pos with rfl | hn
    В· simp [fNonprime, primesCongOneMod3_residueClass, ArithmeticFunction.vonMangoldt.residueClass_apply_zero]
    В· refine div_le_div_of_nonneg_left ?_ (by exact_mod_cast hn) ?_
      В· dsimp [fNonprime]
        split_ifs
        В· exact le_rfl
        В· exact ArithmeticFunction.vonMangoldt.residueClass_nonneg (a := (1 : ZMod 3)) n
      В· conv_lhs => rw [вҶҗ Real.rpow_one n]
        exact Real.rpow_le_rpow_of_exponent_le (by exact_mod_cast Nat.succ_le_of_lt hn) hx.1.le
  have hNonprime_summ : Summable fNonprime := by
    refine Summable.of_nonneg_of_le hNonprime_nonneg hNonprime_le ?_
    exact primesCongOneMod3_residueClass_nonprime_div_summable
  have hNonprime_tsum_le : вҲ‘' n, fNonprime n вүӨ B := by
    simpa [B] using Summable.tsum_le_tsum hNonprime_le hNonprime_summ primesCongOneMod3_residueClass_nonprime_div_summable
  have hPrime_fun : fPrime = fun n : в„• => f n - fNonprime n := by
    ext n
    by_cases hn : n.Prime <;> simp [f, fPrime, fNonprime, hn]
  have hPrime_summ : Summable fPrime := by
    simpa [hPrime_fun] using hfullsumm.sub hNonprime_summ
  have hsplit_fun : f = fun n : в„• => fPrime n + fNonprime n := by
    ext n
    by_cases hn : n.Prime <;> simp [f, fPrime, fNonprime, hn]
  have hsplit : вҲ‘' n, f n = вҲ‘' n, fPrime n + вҲ‘' n, fNonprime n := by
    have hsumPrime := hPrime_summ.hasSum
    have hsumNonprime := hNonprime_summ.hasSum
    have hsumAdd : HasSum (fun n : в„• => fPrime n + fNonprime n) (вҲ‘' n, fPrime n + вҲ‘' n, fNonprime n) :=
      hsumPrime.add hsumNonprime
    have hsumF : HasSum f (вҲ‘' n, fPrime n + вҲ‘' n, fNonprime n) := by
      simpa [hsplit_fun] using hsumAdd
    exact hsumF.tsum_eq
  have hPrime_eq (n : в„•) : fPrime n = target n := by
    by_cases hn : n.Prime
    В· by_cases hmod : n % 3 = 1
      В· simp [fPrime, target, hn, hmod, primesCongOneMod3_residueClass_prime_eq_log n hn hmod]
      В· have hzmod : В¬ ((n : ZMod 3) = (1 : ZMod 3)) := by
          intro hz
          apply hmod
          simpa using (ZMod.natCast_eq_natCast_iff' n 1 3).mp hz
        have hzero : primesCongOneMod3_residueClass n = 0 := by
          unfold primesCongOneMod3_residueClass ArithmeticFunction.vonMangoldt.residueClass
          simp [hzmod]
        simp [fPrime, target, hn, hmod, hzero]
    В· simp [fPrime, target, hn]
  have hPrime_tsum : вҲ‘' n, fPrime n = вҲ‘' n, target n := by
    refine tsum_congr ?_
    intro n
    exact hPrime_eq n
  have hbound : вҲ‘' n, f n вүӨ вҲ‘' n, target n + B := by
    calc
      вҲ‘' n, f n = вҲ‘' n, fPrime n + вҲ‘' n, fNonprime n := hsplit
      _ вүӨ вҲ‘' n, fPrime n + B := by
        simpa [add_comm, add_left_comm, add_assoc] using add_le_add_left hNonprime_tsum_le (вҲ‘' n, fPrime n)
      _ = вҲ‘' n, target n + B := by rw [hPrime_tsum]
  have hfinal : ((Nat.totient 3 : в„қ)вҒ»В№ / (x - 1) - (CвӮҖ + B)) вүӨ вҲ‘' n, target n := by
    linarith
  simpa [target, B] using hfinal

theorem primesCongOneMod3_spec (i : в„•) : (primesCongOneMod3 i).Prime вҲ§ primesCongOneMod3 i % 3 = 1 := by
  unfold primesCongOneMod3

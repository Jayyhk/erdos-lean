private lemma greedy_H_chain_large_epsilon :
    ∀ ε : ℝ, 1 ≤ ε →
      almostAll (fun n => (HChain n : ℝ) ≥ (1 - ε) * (logStar n : ℝ)) := by
  intro ε hε
  apply almostAll_of_forall
  intro n
  have hH : (0 : ℝ) ≤ (HChain n : ℝ) := by positivity
  have hlog : (0 : ℝ) ≤ (logStar n : ℝ) := by positivity

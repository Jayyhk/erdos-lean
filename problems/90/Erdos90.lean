    exact (hquot_equiv j).trans (InfiniteGalois.normalAutEquivQuotient (k := F) (K := K) (H j))
  let quotientMap : вҲҖ j, Q.Q вҶ’* ((L j) вүғвӮҗ[F] (L j)) := fun j =>
    (hquot_aut_equiv j).toMonoidHom.comp (QuotientGroup.mk' (U j : Subgroup Q.Q))
  have hquotientMap_surj : вҲҖ j, Function.Surjective (quotientMap j) := by
    intro j П„
    rcases (QuotientGroup.mk'_surjective (N := (U j : Subgroup Q.Q)) ((hquot_aut_equiv j).symm П„)) with вҹЁx, hxвҹ©
    refine вҹЁx, ?_вҹ©
    change (hquot_aut_equiv j) ((x : Q.Q в§ё (U j : Subgroup Q.Q))) = П„
    exact by

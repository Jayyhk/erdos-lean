theorem MaxUnramifiedProPGaloisGroup.quotient_of_unramified_p_extension
    (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (M : Type) [Field M] [NumberField M] [Algebra F M] [IsGalois F M]
    [FiniteDimensional F M]
    (_hunr : IsEverywhereUnramified F M)

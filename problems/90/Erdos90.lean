theorem cft_D1_universal (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (M : Type) [Field M] [NumberField M] [Algebra F M]
    [IsGalois F M] [FiniteDimensional F M]
    (_hunr : IsEverywhereUnramified F M)
    (_hp : IsPGroup p (M ≃ₐ[F] M)) :
    ∃ (ι : M →ₐ[F] maximalUnramifiedProPF F p)
      (φ : MaxUnramifiedProPGaloisGroup F p →* (M ≃ₐ[F] M)),
      Function.Surjective φ ∧ Continuous φ ∧
      (∀ (σ : MaxUnramifiedProPGaloisGroup F p) (x : M),
        ι ((φ σ : M ≃ₐ[F] M) x) =
          (show (maximalUnramifiedProPF F p) ≃ₐ[F] (maximalUnramifiedProPF F p) from σ)
            (ι x)) := by
  classical
  let f : M →ₐ[F] AlgebraicClosure F := IsAlgClosed.lift
  let N : IntermediateField F (AlgebraicClosure F) := (⊤ : IntermediateField F M).map f
  let e : M ≃ₐ[F] N :=
    (IntermediateField.topEquiv (F := F) (E := M)).symm.trans
      (IntermediateField.equivMap (L := (⊤ : IntermediateField F M)) f)
  letI : FiniteDimensional F N := e.toLinearEquiv.finiteDimensional
  letI : NumberField N := NumberField.of_module_finite F N
  letI : IsGalois F N := IsGalois.of_algEquiv e
  have hN_unr : IsEverywhereUnramified F N := IsEverywhereUnramified.transport e _hunr
  have hN_pgrp : IsPGroup p (N ≃ₐ[F] N) := IsPGroup.of_equiv _hp (AlgEquiv.autCongr e)
  have hN_le : N ≤ maximalUnramifiedProPF F p := by
    unfold maximalUnramifiedProPF
    exact le_iSup_of_le N <|
      le_iSup_of_le (inferInstance : FiniteDimensional F N) <|
      le_iSup_of_le (inferInstance : IsGalois F N) <|
      le_iSup_of_le hN_pgrp <|
      le_iSup_of_le (inferInstance : NumberField N) <|
      le_iSup_of_le hN_unr le_rfl
  let N' : IntermediateField F (maximalUnramifiedProPF F p) := IntermediateField.restrict hN_le
  let eN : N' ≃ₐ[F] N :=
    (IntermediateField.liftAlgEquiv (F := N')).trans
      (IntermediateField.equivOfEq (IntermediateField.lift_restrict hN_le))
  let e' : M ≃ₐ[F] N' := e.trans eN.symm
  letI : FiniteDimensional F N' := e'.toLinearEquiv.finiteDimensional
  letI : NumberField N' := NumberField.of_module_finite F N'
  letI : IsGalois F N' := IsGalois.of_algEquiv e'
  let ι : M →ₐ[F] maximalUnramifiedProPF F p := N'.val.comp e'.toAlgHom
  letI : IsGalois F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  let ψ : MaxUnramifiedProPGaloisGroup F p →* (N' ≃ₐ[F] N') :=
    AlgEquiv.restrictNormalHom N'
  let φ : MaxUnramifiedProPGaloisGroup F p →* (M ≃ₐ[F] M) :=
    (AlgEquiv.autCongr e'.symm).toMonoidHom.comp ψ
  refine ⟨ι, φ, ?_, ?_, ?_⟩
  · simpa [φ, ψ] using
      (AlgEquiv.autCongr e'.symm).surjective.comp
        (AlgEquiv.restrictNormalHom_surjective (F := F) (K₁ := N') (E := maximalUnramifiedProPF F p))
  · letI : TopologicalSpace (N' ≃ₐ[F] N') := krullTopology F N'
    letI : DiscreteTopology (N' ≃ₐ[F] N') := krullTopology_discreteTopology_of_finiteDimensional F N'
    have hcont_conj : Continuous (AlgEquiv.autCongr e'.symm : (N' ≃ₐ[F] N') → (M ≃ₐ[F] M)) := by
      exact continuous_of_discreteTopology
    have hcont_ψ : Continuous (AlgEquiv.restrictNormalHom (F := F) (K₁ := maximalUnramifiedProPF F p) N') := by
      exact InfiniteGalois.restrictNormalHom_continuous (k := F) (K := maximalUnramifiedProPF F p) N'
    simpa [φ, ψ] using hcont_conj.comp hcont_ψ
  · intro σ x
    have hconj : e' ((φ σ : M ≃ₐ[F] M) x) = (ψ σ) (e' x) := by
      change e' (((AlgEquiv.autCongr e'.symm) (ψ σ)) x) = (ψ σ) (e' x)
      simp [AlgEquiv.trans_apply]
    change N'.val (e' ((φ σ : M ≃ₐ[F] M) x)) =
        (show (maximalUnramifiedProPF F p) ≃ₐ[F] (maximalUnramifiedProPF F p) from σ)
          (N'.val (e' x))
    rw [hconj]
    simpa [ψ] using
      (AlgEquiv.restrictNormalHom_apply (F := F) (K₁ := maximalUnramifiedProPF F p) N' σ (e' x))

theorem finiteIntermediate_lift_le_finsetSup (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)] (L : IntermediateField F (maximalUnramifiedProPF F p)) [FiniteDimensional F L] : ∃ s : Finset (maximalUnramifiedProPFIndex F p), IntermediateField.lift L ≤ (⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  let I := maximalUnramifiedProPFIndex F p
  have hFG : L.FG := by
    simpa using
      (IntermediateField.essFiniteType_iff (F := F) (E := maximalUnramifiedProPF F p)
        (K := L)).mp (inferInstance : Algebra.EssFiniteType F L)
  have hx_all :
      ∀ x : maximalUnramifiedProPF F p,
        ∃ t : Finset I,
          (x : AlgebraicClosure F) ∈
            (⨆ i ∈ t, i.M : IntermediateField F (AlgebraicClosure F)) := by
    intro x
    have hx :
        (x : AlgebraicClosure F) ∈
          (⨆ i : I, i.M : IntermediateField F (AlgebraicClosure F)) := by
      simpa [MaxUnramifiedProPGaloisGroup.maximalUnramifiedProPF_eq_iSup_index
        (F := F) (p := p)] using x.2
    exact IntermediateField.exists_finset_of_mem_iSup hx
  choose t ht using hx_all
  obtain ⟨u, hu⟩ := hFG
  refine ⟨u.biUnion t, ?_⟩
  rw [← hu, IntermediateField.lift_adjoin]
  rw [IntermediateField.adjoin_le_iff]
  rintro _ ⟨x, hx, rfl⟩
  exact SetLike.le_def.mp
    (iSup₂_le fun i hi => le_iSup_of_le i <| le_iSup_of_le ((Finset.subset_biUnion_of_mem t hx) hi) le_rfl)
    (ht x)

theorem finsetSup_isGalois (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)] (s : Finset (maximalUnramifiedProPFIndex F p)) : IsGalois F ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  refine Finset.induction_on s ?_ ?_
  · by_cases h : Nonempty (maximalUnramifiedProPFIndex F p)
    · haveI := h
      have hempty : (⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = ⊥ := by
        simp only [Finset.notMem_empty, iSup_false, iSup_const]
      rw [hempty]
      simpa using (isGalois_bot (F := F) (E := AlgebraicClosure F))
    · haveI : IsEmpty (maximalUnramifiedProPFIndex F p) := not_nonempty_iff.mp h
      have hempty : (⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = ⊥ := by
        rw [show (⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = ⨆ i : maximalUnramifiedProPFIndex F p, ⨆ _ : i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)), i.M by rfl]
        rw [iSup_of_empty]
      rw [hempty]
      simpa using (isGalois_bot (F := F) (E := AlgebraicClosure F))
  · intro i s his ih
    rw [Finset.iSup_insert]
    let Ks : IntermediateField F (AlgebraicClosure F) := ⨆ j ∈ s, j.M
    haveI : IsGalois F ↥Ks := by
      simpa [Ks] using ih
    haveI : IsGalois F ↥i.M := i.hg
    simpa [Ks] using (inferInstance : IsGalois F ↥(i.M ⊔ Ks))

theorem fixedField_openNormal_finiteGalois (k : Type) [Field k] (K : Type) [Field K] [Algebra k K] [IsGalois k K] (N : OpenNormalSubgroup (Gal(K/k))) : FiniteDimensional k (IntermediateField.fixedField (N : Subgroup Gal(K/k))) ∧ IsGalois k (IntermediateField.fixedField (N : Subgroup Gal(K/k))) := by
  let H : ClosedSubgroup (Gal(K/k)) :=
    { toSubgroup := (N : Subgroup Gal(K/k))
      isClosed' := by
        simpa using N.isClosed }
  let L := IntermediateField.fixedField (H : Subgroup Gal(K/k))
  have hfix : L.fixingSubgroup = (N : Subgroup Gal(K/k)) := by
    simpa [L] using InfiniteGalois.fixingSubgroup_fixedField (k := k) (K := K) H
  have hopen : IsOpen (L.fixingSubgroup : Set (Gal(K/k))) := by
    simpa [hfix] using N.toOpenSubgroup.isOpen
  have hnormal : (L.fixingSubgroup : Subgroup Gal(K/k)).Normal := by
    simpa [hfix] using (show (N : Subgroup Gal(K/k)).Normal from inferInstance)
  have h :=
    (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := k) (K := K) (L := L)).mp
      ⟨hopen, hnormal⟩
  simpa [L] using h

theorem localUnramified_diffTop (F M : Type) [Field F] [Field M] [NumberField F] [NumberField M] [Algebra F M] (hfin : ∀ (𝔭 : Ideal (𝓞 F)) (𝔓 : Ideal (𝓞 M)), 𝔭.IsPrime → 𝔭 ≠ ⊥ → 𝔓 ∈ 𝔭.primesOver (𝓞 M) → Ideal.ramificationIdx 𝔭 𝔓 = 1) : differentIdeal (𝓞 F) (𝓞 M) = (⊤ : Ideal (𝓞 M)) := by
  by_contra htop
  obtain ⟨P, hPmax, hle⟩ := Ideal.exists_le_maximal (differentIdeal (𝓞 F) (𝓞 M)) htop
  letI : P.IsMaximal := hPmax
  letI : P.IsPrime := hPmax.isPrime
  have hpmax : (P.under (𝓞 F)).IsMaximal :=
    Ideal.isMaximal_comap_of_isIntegral_of_isMaximal (R := 𝓞 F) (S := 𝓞 M) P
  have hpne : (P.under (𝓞 F)) ≠ ⊥ :=
    Ring.ne_bot_of_isMaximal_of_not_isField hpmax (NumberField.RingOfIntegers.not_isField F)
  have hP_over : P ∈ (P.under (𝓞 F)).primesOver (𝓞 M) := by
    exact ⟨inferInstance, inferInstance⟩
  have he : Ideal.ramificationIdx (P.under (𝓞 F)) P = 1 :=
    hfin (P.under (𝓞 F)) P (Ideal.IsMaximal.isPrime hpmax) hpne hP_over
  have hPne : P ≠ ⊥ :=
    Ring.ne_bot_of_isMaximal_of_not_isField hPmax (NumberField.RingOfIntegers.not_isField M)
  have hunram : Algebra.IsUnramifiedAt (𝓞 F) P :=
    (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := 𝓞 F) (S := 𝓞 M) (p := P) hPne).2 <| by
      simpa using he
  have hnotdvd : ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M) :=
    (not_dvd_differentIdeal_iff (A := 𝓞 F) (B := 𝓞 M) (P := P)).2 hunram
  have hdvd : P ∣ differentIdeal (𝓞 F) (𝓞 M) := by
    simpa [Ideal.dvd_iff_le] using hle
  exact hnotdvd hdvd

theorem openNormalChain (Q0 : Type) [Group Q0] [TopologicalSpace Q0] [IsTopologicalGroup Q0] [T2Space Q0] [CompactSpace Q0] [TotallyDisconnectedSpace Q0] [Infinite Q0] : ∃ U : ℕ → OpenNormalSubgroup Q0, ((U 0 : Subgroup Q0) = ⊤) ∧ (∀ j, U (j + 1) ≤ U j) ∧ Filter.Tendsto (fun j => Nat.card (Q0 ⧸ (U j).toSubgroup)) Filter.atTop Filter.atTop := by
  classical
  let e : ℕ ↪ Q0 := Infinite.natEmbedding Q0
  let bad : ℕ → Finset Q0 := fun n =>
    ((((Finset.univ : Finset (Fin (n + 1))).product Finset.univ).filter
      (fun p : Fin (n + 1) × Fin (n + 1) => p.1 ≠ p.2)).image
      (fun p => (e p.1)⁻¹ * e p.2))
  have hbad_one : ∀ n, (1 : Q0) ∉ bad n := by
    intro n h1
    rcases Finset.mem_image.mp h1 with ⟨p, hp, hp1⟩
    have hpne : p.1 ≠ p.2 := (Finset.mem_filter.mp hp).2
    have heq : e p.1 = e p.2 := by
      exact inv_mul_eq_one.mp hp1
    exact hpne (Fin.ext (e.injective heq))
  let H : ℕ → OpenNormalSubgroup Q0 := fun n =>
    Classical.choose <|
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one
        (U := (bad n : Set Q0)ᶜ)
        ((bad n).isClosed.isOpen_compl)
        (by
          change (1 : Q0) ∉ bad n
          exact hbad_one n)
  have hHsub : ∀ n, ((H n : Set Q0) ⊆ (bad n : Set Q0)ᶜ) := by
    intro n
    exact Classical.choose_spec <|
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one
        (U := (bad n : Set Q0)ᶜ)
        ((bad n).isClosed.isOpen_compl)
        (by
          change (1 : Q0) ∉ bad n
          exact hbad_one n)
  let topON : OpenNormalSubgroup Q0 :=
    { toOpenSubgroup := ⊤
      isNormal' := Subgroup.normal_top }
  let U : ℕ → OpenNormalSubgroup Q0 := Nat.rec topON (fun n Un => Un ⊓ H n)
  have hsize : ∀ n, n + 1 ≤ Nat.card (Q0 ⧸ (U (n + 1)).toSubgroup) := by
    intro n
    let f : Fin (n + 1) → Q0 ⧸ (U (n + 1)).toSubgroup := fun i => QuotientGroup.mk (e i)
    have hf : Function.Injective f := by
      intro i j hij
      by_contra hne
      have hmemU : (e i)⁻¹ * e j ∈ (U (n + 1) : Subgroup Q0) := by
        exact QuotientGroup.eq.mp hij
      have hmemH : (e i)⁻¹ * e j ∈ (H n : Subgroup Q0) := by
        have hle : U (n + 1) ≤ H n := by
          change Nat.rec topON (fun n Un => Un ⊓ H n) n ⊓ H n ≤ H n
          exact inf_le_right
        exact hle hmemU
      have hnotbad : (e i)⁻¹ * e j ∉ bad n := by
        simpa using hHsub n hmemH
      have hbadmem : (e i)⁻¹ * e j ∈ bad n := by
        apply Finset.mem_image.mpr
        refine ⟨(i, j), ?_, rfl⟩
        exact Finset.mem_filter.mpr ⟨by simp, hne⟩
      exact hnotbad hbadmem
    simpa [f, Nat.card_fin] using (Nat.card_le_card_of_injective f hf)
  have hbound : ∀ j, j ≤ Nat.card (Q0 ⧸ (U j).toSubgroup) := by
    intro j
    cases j with
    | zero => exact Nat.zero_le _
    | succ n => exact hsize n
  refine ⟨U, ?_, ?_, ?_⟩
  · change (topON : Subgroup Q0) = ⊤
    rfl
  · intro j
    cases j with
    | zero =>
        change topON ⊓ H 0 ≤ topON
        exact inf_le_left
    | succ n =>
        change (Nat.rec topON (fun n Un => Un ⊓ H n) (n + 1) ⊓ H (n + 1)) ≤
          Nat.rec topON (fun n Un => Un ⊓ H n) (n + 1)
        exact inf_le_left
  · rw [Filter.tendsto_atTop_atTop]
    intro b
    refine ⟨b, ?_⟩
    intro a ha
    exact le_trans ha (hbound a)

theorem restrict_mem_inertia (F : Type) [Field F] [NumberField F] (N : Type) [Field N] [Algebra F N] [NumberField N] [IsGalois F N] (K : IntermediateField F N) [NumberField K] [IsGalois F K] (𝔓 : Ideal (𝓞 N)) [𝔓.IsPrime] (σ : Gal(N/F)) : σ ∈ Ideal.inertia (Gal(N/F)) 𝔓 → AlgEquiv.restrictNormalHom K σ ∈ Ideal.inertia (Gal(K/F)) (𝔓.comap (NumberField.RingOfIntegers.mapAlgHom K.val)) := by
  intro hσ
  rw [AddSubgroup.mem_inertia] at hσ ⊢
  intro x
  change NumberField.RingOfIntegers.mapAlgHom K.val (((AlgEquiv.restrictNormalHom K σ) • x) - x) ∈ 𝔓
  rw [map_sub]
  have hcomm :
      NumberField.RingOfIntegers.mapAlgHom K.val (((AlgEquiv.restrictNormalHom K σ) • x)) =
        σ • (NumberField.RingOfIntegers.mapAlgHom K.val x) := by
    ext
    change K.val ((((AlgEquiv.restrictNormalHom K σ) • x : 𝓞 K)) : K) =
      σ (K.val (x : K))
    simpa using AlgEquiv.restrictNormalHom_apply K σ (x : K)
  simpa [hcomm] using hσ ((NumberField.RingOfIntegers.mapAlgHom K.val) x)

theorem subfield_isUnramified_of_le (F : Type) [Field F] [NumberField F] (L M : IntermediateField F (AlgebraicClosure F)) [NumberField L] [NumberField M] [IsGalois F L] (hLM : L ≤ M) (hM : IsEverywhereUnramified F M) : IsEverywhereUnramified F L := by
  letI : Algebra L M := (IntermediateField.inclusion hLM).toAlgebra
  rcases hM with ⟨hfinM, hinfM⟩
  have hfinL :
      ∀ (𝔭 : Ideal (𝓞 F)) (𝔓 : Ideal (𝓞 L)),
        𝔭.IsPrime → 𝔭 ≠ ⊥ → 𝔓 ∈ 𝔭.primesOver (𝓞 L) → 𝔭.ramificationIdx 𝔓 = 1 := by
    intro 𝔭 𝔓 hp hne hP
    letI : 𝔭.IsPrime := hp
    let P' : 𝔭.primesOver (𝓞 L) := ⟨𝔓, hP⟩
    letI : 𝔓.IsPrime := Ideal.primesOver.isPrime 𝔭 P'
    letI : 𝔓.LiesOver 𝔭 := Ideal.primesOver.liesOver 𝔭 P'
    obtain ⟨Q⟩ := Ideal.nonempty_primesOver (R := 𝓞 L) (S := 𝓞 M) 𝔓
    letI : (Q : Ideal (𝓞 M)).LiesOver 𝔓 := Ideal.primesOver.liesOver 𝔓 Q
    letI : (Q : Ideal (𝓞 M)).LiesOver 𝔭 := Ideal.LiesOver.trans (𝔓 := (Q : Ideal (𝓞 M))) (P := 𝔓) (p := 𝔭)
    have hQmem : (Q : Ideal (𝓞 M)) ∈ 𝔭.primesOver (𝓞 M) :=
      (Ideal.primesOver.mk 𝔭 (Q : Ideal (𝓞 M))).2
    have hQe : Ideal.ramificationIdx 𝔭 (Q : Ideal (𝓞 M)) = 1 :=
      hfinM 𝔭 (Q : Ideal (𝓞 M)) hp hne hQmem
    have hQne : (Q : Ideal (𝓞 M)) ≠ ⊥ :=
      Ideal.ne_bot_of_liesOver_of_ne_bot hne (Q : Ideal (𝓞 M))
    rw [Ideal.over_def (A := 𝓞 F) (P := (Q : Ideal (𝓞 M))) (p := 𝔭)] at hQe
    have hQunram : Algebra.IsUnramifiedAt (𝓞 F) (Q : Ideal (𝓞 M)) :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := 𝓞 F) (S := 𝓞 M) (p := (Q : Ideal (𝓞 M))) hQne).2 hQe
    have hPunram : Algebra.IsUnramifiedAt (𝓞 F) 𝔓 :=
      Algebra.IsUnramifiedAt.of_liesOver (R := 𝓞 F) (p := 𝔓) (P := (Q : Ideal (𝓞 M)))
    have hPe : Ideal.ramificationIdx (Ideal.under (𝓞 F) 𝔓) 𝔓 = 1 :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := 𝓞 F) (S := 𝓞 L) (p := 𝔓) (Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔓)).1 hPunram
    simpa [Ideal.over_def (A := 𝓞 F) (P := 𝔓) (p := 𝔭)] using hPe
  have hinfL :
      ∀ (w : InfinitePlace F), w.IsReal →
        ∀ (w' : InfinitePlace L), w'.comap (algebraMap F L) = w → w'.IsReal := by
    intro w hw w' hw'
    obtain ⟨w'', hw''⟩ := InfinitePlace.comap_surjective (k := L) (K := M) w'
    have hw''F : (w''.comap (algebraMap L M)).comap (algebraMap F L) = w'.comap (algebraMap F L) := by
      simpa using congrArg (fun x => x.comap (algebraMap F L)) hw''
    have hwM : w''.comap (algebraMap F M) = w := by
      calc
        w''.comap (algebraMap F M) = w''.comap ((algebraMap L M).comp (algebraMap F L)) := by
          rw [IsScalarTower.algebraMap_eq F L M]
        _ = (w''.comap (algebraMap L M)).comap (algebraMap F L) := by
          rw [InfinitePlace.comap_comp]
        _ = w'.comap (algebraMap F L) := hw''F
        _ = w := hw'
    have hw''real : w''.IsReal := hinfM w hw w'' hwM
    have hw'real : (w''.comap (algebraMap L M)).IsReal :=
      NumberField.InfinitePlace.IsReal.comap (algebraMap L M) hw''real
    simpa [hw''] using hw'real
  exact IsEverywhereUnramified.of_local F L hfinL hinfL

theorem sup_real_lifts_real (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField ↥(K ⊔ M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : ∀ (w : InfinitePlace F), w.IsReal → ∀ (w' : InfinitePlace ↥(K ⊔ M)), w'.comap (algebraMap F ↥(K ⊔ M)) = w → w'.IsReal := by
  set_option maxHeartbeats 600000 in
  intro w hw w' hw'
  let N : IntermediateField F (AlgebraicClosure F) := K ⊔ M
  let S : Set (AlgebraicClosure F) := (K ∪ M : Set (AlgebraicClosure F))
  have hN : N = IntermediateField.adjoin F S := by
    simpa [N, S] using (IntermediateField.sup_def K M)
  letI : Algebra K ↥N :=
    (IntermediateField.inclusion (show K ≤ N by
      simp [N])).toAlgebra
  letI : IsScalarTower F K ↥N := IsScalarTower.of_algebraMap_eq' rfl
  letI : Algebra M ↥N :=
    (IntermediateField.inclusion (show M ≤ N by
      simp [N])).toAlgebra
  letI : IsScalarTower F M ↥N := IsScalarTower.of_algebraMap_eq' rfl
  let vK : InfinitePlace K := w'.comap (algebraMap K ↥N)
  let vM : InfinitePlace M := w'.comap (algebraMap M ↥N)
  have hvKcomap : vK.comap (algebraMap F K) = w := by
    simpa [vK, N, IsScalarTower.algebraMap_eq F K ↥N] using hw'
  have hvMcomap : vM.comap (algebraMap F M) = w := by
    simpa [vM, N, IsScalarTower.algebraMap_eq F M ↥N] using hw'
  have hvKreal : vK.IsReal := hK.real_lifts_real w hw vK hvKcomap
  have hvMreal : vM.IsReal := hM.real_lifts_real w hw vM hvMcomap
  letI : Algebra F ℂ := w.embedding.toAlgebra
  have hbase : w'.embedding.comp (algebraMap F ↥N) = w.embedding := by
    symm
    simpa [N, hw'] using
      (NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap F ↥N) (w := w')
        (by simpa [N, hw'] using hw))
  let φ : ↥N →ₐ[F] ℂ :=
    { toRingHom := w'.embedding
      commutes' := by
        intro x
        exact congrArg (fun f => f x) hbase }
  let ψ : ↥N →ₐ[F] ℂ :=
    { toRingHom := NumberField.ComplexEmbedding.conjugate w'.embedding
      commutes' := by
        intro x
        have hbase_conj : (NumberField.ComplexEmbedding.conjugate w'.embedding).comp
            (algebraMap F ↥N) = w.embedding := by
          calc
            (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap F ↥N)
                = NumberField.ComplexEmbedding.conjugate (w'.embedding.comp (algebraMap F ↥N)) := by
                    rw [NumberField.ComplexEmbedding.conjugate_comp]
            _ = NumberField.ComplexEmbedding.conjugate w.embedding := by rw [hbase]
            _ = w.embedding := NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hw
        exact congrArg (fun f => f x) hbase_conj }
  have hgenK : ∀ x (hxK : x ∈ K),
      let hxS : x ∈ S := Or.inl hxK
      let xN : N := ⟨x, hN.ge (IntermediateField.subset_adjoin F S hxS)⟩
      let xK : K := ⟨x, hxK⟩
      ψ xN = φ xN := by
    intro x hxK
    let hxS : x ∈ S := Or.inl hxK
    let xN : N := ⟨x, hN.ge (IntermediateField.subset_adjoin F S hxS)⟩
    let xK : K := ⟨x, hxK⟩
    have hkemb : vK.embedding = w'.embedding.comp (algebraMap K ↥N) :=
      NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap K ↥N) (w := w') hvKreal
    have hkemb_conj : NumberField.ComplexEmbedding.conjugate vK.embedding =
        (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap K ↥N) := by
      rw [hkemb, NumberField.ComplexEmbedding.conjugate_comp]
    have hkval : vK.embedding xK = w'.embedding xN := by
      simpa [xK, xN] using congrArg (fun f => f xK) hkemb
    have hkval_conj : (NumberField.ComplexEmbedding.conjugate vK.embedding) xK =
        (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := by
      simpa [xK, xN] using congrArg (fun f => f xK) hkemb_conj
    calc
      ψ xN = (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := rfl
      _ = (NumberField.ComplexEmbedding.conjugate vK.embedding) xK := by symm; exact hkval_conj
      _ = vK.embedding xK := by
        exact congrArg (fun f => f xK) (NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hvKreal)
      _ = w'.embedding xN := hkval
      _ = φ xN := rfl
  have hgenM : ∀ x (hxM : x ∈ M),
      let hxS : x ∈ S := Or.inr hxM
      let xN : N := ⟨x, hN.ge (IntermediateField.subset_adjoin F S hxS)⟩
      let xM : M := ⟨x, hxM⟩
      ψ xN = φ xN := by
    intro x hxM
    let hxS : x ∈ S := Or.inr hxM
    let xN : N := ⟨x, hN.ge (IntermediateField.subset_adjoin F S hxS)⟩
    let xM : M := ⟨x, hxM⟩
    have hmemb : vM.embedding = w'.embedding.comp (algebraMap M ↥N) :=
      NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap M ↥N) (w := w') hvMreal
    have hmemb_conj : NumberField.ComplexEmbedding.conjugate vM.embedding =
        (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap M ↥N) := by
      rw [hmemb, NumberField.ComplexEmbedding.conjugate_comp]
    have hmval : vM.embedding xM = w'.embedding xN := by
      simpa [xM, xN] using congrArg (fun f => f xM) hmemb
    have hmval_conj : (NumberField.ComplexEmbedding.conjugate vM.embedding) xM =
        (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := by
      simpa [xM, xN] using congrArg (fun f => f xM) hmemb_conj
    calc
      ψ xN = (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := rfl
      _ = (NumberField.ComplexEmbedding.conjugate vM.embedding) xM := by symm; exact hmval_conj
      _ = vM.embedding xM := by
        exact congrArg (fun f => f xM) (NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hvMreal)
      _ = w'.embedding xN := hmval
      _ = φ xN := rfl
  have hψφ : ψ = φ := by
    refine IntermediateField.algHom_ext_of_eq_adjoin (F := F) (E := AlgebraicClosure F) (S := N)
      (K := ℂ) hN ?_
    intro x hx
    rcases hx with hxK | hxM
    · simpa [S] using hgenK x hxK
    · simpa [S] using hgenM x hxM
  have hconj : NumberField.ComplexEmbedding.conjugate w'.embedding = w'.embedding := by
    simpa [ψ, φ] using congrArg (fun f : ↥N →ₐ[F] ℂ => (f : ↥N →+* ℂ)) hψφ
  exact NumberField.InfinitePlace.isReal_iff.mpr <|
    NumberField.ComplexEmbedding.isReal_iff.mpr hconj

theorem unramified_inertia_card_one (F : Type) [Field F] [NumberField F] (K : Type) [Field K] [Algebra F K] [NumberField K] [FiniteDimensional F K] [IsGalois F K] (hK : IsEverywhereUnramified F K) (𝔭 : Ideal (𝓞 F)) (𝔓 : Ideal (𝓞 K)) [𝔓.IsPrime] (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥) (h𝔓 : 𝔓 ∈ 𝔭.primesOver (𝓞 K)) : Nat.card (Ideal.inertia (Gal(K/F)) 𝔓) = 1 := by
  letI : 𝔭.IsMaximal := hp.isMaximal hne
  letI : 𝔓.LiesOver 𝔭 := h𝔓.2
  have hP_ne : 𝔓 ≠ ⊥ := Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔓
  letI : 𝔓.IsMaximal := h𝔓.1.isMaximal hP_ne
  have hunder : Ideal.under (𝓞 F) 𝔓 = 𝔭 := by
    simpa using (Ideal.over_def (A := 𝓞 F) (P := 𝔓) (p := 𝔭)).symm
  haveI : Algebra.IsUnramifiedAt (𝓞 F) 𝔓 :=
    (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := 𝓞 F) (S := 𝓞 K) (p := 𝔓)
      hP_ne).2 <| by
        simpa [hunder] using hK.unramified_at_finite 𝔭 𝔓 hp hne h𝔓
  calc
    Nat.card (Ideal.inertia (Gal(K/F)) 𝔓)
        = 𝔭.ramificationIdxIn (𝓞 K) := by
            simpa using Ideal.card_inertia_eq_ramificationIdxIn (G := Gal(K/F)) 𝔭 hne 𝔓
    _ = Ideal.ramificationIdx 𝔭 𝔓 := by
            simpa using Ideal.ramificationIdxIn_eq_ramificationIdx (p := 𝔭) (P := 𝔓) (G := Gal(K/F))
    _ = 1 := hK.unramified_at_finite 𝔭 𝔓 hp hne h𝔓

theorem sup_unramified_at_finite (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField ↥(K ⊔ M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : ∀ (𝔭 : Ideal (𝓞 F)) (𝔓 : Ideal (𝓞 ↥(K ⊔ M))), 𝔭.IsPrime → 𝔭 ≠ ⊥ → 𝔓 ∈ 𝔭.primesOver (𝓞 ↥(K ⊔ M)) → Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
  intro 𝔭 𝔓 hp hne h𝔓
  let N : IntermediateField F (AlgebraicClosure F) := K ⊔ M
  let K' : IntermediateField F ↥N := IntermediateField.restrict (show K ≤ N by exact le_sup_left)
  let M' : IntermediateField F ↥N := IntermediateField.restrict (show M ≤ N by exact le_sup_right)
  let eK : K ≃ₐ[F] ↥K' := IntermediateField.restrict_algEquiv (show K ≤ N by exact le_sup_left)
  let eM : M ≃ₐ[F] ↥M' := IntermediateField.restrict_algEquiv (show M ≤ N by exact le_sup_right)
  haveI : IsGalois F ↥N := by infer_instance
  haveI : IsGalois F ↥K' := IsGalois.of_algEquiv eK
  haveI : IsGalois F ↥M' := IsGalois.of_algEquiv eM
  haveI : FiniteDimensional F ↥N := by infer_instance
  haveI : FiniteDimensional F ↥K' := by infer_instance
  haveI : FiniteDimensional F ↥M' := by infer_instance
  have hK' : IsEverywhereUnramified F ↥K' := IsEverywhereUnramified.transport eK hK
  have hM' : IsEverywhereUnramified F ↥M' := IsEverywhereUnramified.transport eM hM
  let OK : (𝓞 ↥K') →ₐ[𝓞 F] (𝓞 ↥N) := NumberField.RingOfIntegers.mapAlgHom K'.val
  let OM : (𝓞 ↥M') →ₐ[𝓞 F] (𝓞 ↥N) := NumberField.RingOfIntegers.mapAlgHom M'.val
  let PK : Ideal (𝓞 ↥K') := 𝔓.comap OK
  let PM : Ideal (𝓞 ↥M') := 𝔓.comap OM
  letI : 𝔓.IsPrime := h𝔓.1
  have hPK : PK ∈ 𝔭.primesOver (𝓞 ↥K') := by
    change (𝔓.comap OK).IsPrime ∧ (𝔓.comap OK).LiesOver 𝔭
    refine ⟨Ideal.IsPrime.comap (f := OK), ?_⟩
    letI : 𝔓.LiesOver 𝔭 := h𝔓.2
    simpa [PK, OK] using (Ideal.comap_liesOver (Q := 𝔓) (p := 𝔭) OK)
  have hPM : PM ∈ 𝔭.primesOver (𝓞 ↥M') := by
    change (𝔓.comap OM).IsPrime ∧ (𝔓.comap OM).LiesOver 𝔭
    refine ⟨Ideal.IsPrime.comap (f := OM), ?_⟩
    letI : 𝔓.LiesOver 𝔭 := h𝔓.2
    simpa [PM, OM] using (Ideal.comap_liesOver (Q := 𝔓) (p := 𝔭) OM)
  letI : PK.IsPrime := hPK.1
  letI : PM.IsPrime := hPM.1
  have hsup' : K' ⊔ M' = (⊤ : IntermediateField F ↥N) := by
    apply (IntermediateField.lift_injective N)
    rw [IntermediateField.lift_sup]
    rw [show IntermediateField.lift K' = K by
      simp [K']]
    rw [show IntermediateField.lift M' = M by
      simp [M']]
    rw [IntermediateField.lift_top]
  set_option maxHeartbeats 800000 in
  have hInertia_eq_bot : Ideal.inertia (Gal(↥N/F)) 𝔓 = ⊥ := by
    apply Subgroup.ext
    intro σ
    constructor
    · intro hσ
      have hσK : AlgEquiv.restrictNormalHom K' σ ∈ Ideal.inertia (Gal(↥K'/F)) PK := by
        exact restrict_mem_inertia (F := F) (N := ↥N) (K := K') (𝔓 := 𝔓) (σ := σ) hσ
      have hσM : AlgEquiv.restrictNormalHom M' σ ∈ Ideal.inertia (Gal(↥M'/F)) PM := by
        exact restrict_mem_inertia (F := F) (N := ↥N) (K := M') (𝔓 := 𝔓) (σ := σ) hσ
      have hcardK : Nat.card (Ideal.inertia (Gal(↥K'/F)) PK) = 1 :=
        unramified_inertia_card_one (F := F) (K := ↥K') hK' 𝔭 PK hp hne hPK
      have hcardM : Nat.card (Ideal.inertia (Gal(↥M'/F)) PM) = 1 :=
        unramified_inertia_card_one (F := F) (K := ↥M') hM' 𝔭 PM hp hne hPM
      have hbotK : Ideal.inertia (Gal(↥K'/F)) PK = ⊥ :=
        (Subgroup.card_eq_one).1 hcardK
      have hbotM : Ideal.inertia (Gal(↥M'/F)) PM = ⊥ :=
        (Subgroup.card_eq_one).1 hcardM
      have hresK : AlgEquiv.restrictNormalHom K' σ = 1 := by
        have : AlgEquiv.restrictNormalHom K' σ ∈ (⊥ : Subgroup Gal(↥K'/F)) := by
          simpa [hbotK] using hσK
        simpa using this
      have hresM : AlgEquiv.restrictNormalHom M' σ = 1 := by
        have : AlgEquiv.restrictNormalHom M' σ ∈ (⊥ : Subgroup Gal(↥M'/F)) := by
          simpa [hbotM] using hσM
        simpa using this
      have hfixK : σ ∈ K'.fixingSubgroup := by
        rw [IntermediateField.mem_fixingSubgroup_iff]
        intro x hx
        simpa [hresK] using (AlgEquiv.restrictNormalHom_apply K' σ ⟨x, hx⟩).symm
      have hfixM : σ ∈ M'.fixingSubgroup := by
        rw [IntermediateField.mem_fixingSubgroup_iff]
        intro x hx
        simpa [hresM] using (AlgEquiv.restrictNormalHom_apply M' σ ⟨x, hx⟩).symm
      have hfixSup : σ ∈ (K' ⊔ M').fixingSubgroup := by
        rw [IntermediateField.fixingSubgroup_sup]
        exact ⟨hfixK, hfixM⟩
      have hσ1 : σ = 1 := by
        have : σ ∈ (⊤ : IntermediateField F ↥N).fixingSubgroup := by
          simpa [hsup'] using hfixSup
        simpa [IntermediateField.fixingSubgroup_top, Subgroup.mem_bot] using this
      simp [Subgroup.mem_bot, hσ1]
    · intro hσ
      rw [Subgroup.mem_bot] at hσ
      simp [hσ]
  letI : 𝔭.IsMaximal := hp.isMaximal hne
  letI : 𝔓.LiesOver 𝔭 := h𝔓.2
  have hP_ne : 𝔓 ≠ ⊥ := Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔓
  letI : 𝔓.IsMaximal := h𝔓.1.isMaximal hP_ne
  letI : Field (𝓞 F ⧸ 𝔭) := Ideal.Quotient.field 𝔭
  letI : Field (𝓞 ↥N ⧸ 𝔓) := Ideal.Quotient.field 𝔓
  haveI : Module.Finite (𝓞 F ⧸ 𝔭) (𝓞 ↥N ⧸ 𝔓) :=
    module_finite_of_liesOver (A := 𝓞 F) (B := 𝓞 ↥N) (p := 𝔭) (P := 𝔓)
  haveI : Algebra.IsAlgebraic (𝓞 F ⧸ 𝔭) (𝓞 ↥N ⧸ 𝔓) :=
    Algebra.IsAlgebraic.of_finite (R := 𝓞 F ⧸ 𝔭) (A := 𝓞 ↥N ⧸ 𝔓)
  haveI : Finite (𝓞 F ⧸ 𝔭) := by infer_instance
  letI : PerfectField (𝓞 F ⧸ 𝔭) := PerfectField.ofFinite (K := 𝓞 F ⧸ 𝔭)
  haveI : Algebra.IsSeparable (𝓞 F ⧸ 𝔭) (𝓞 ↥N ⧸ 𝔓) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hCardN : Nat.card (Ideal.inertia (Gal(↥N/F)) 𝔓) = 1 := by
    rw [hInertia_eq_bot]
    exact (Subgroup.card_eq_one).2 rfl
  calc
    Ideal.ramificationIdx 𝔭 𝔓 = 𝔭.ramificationIdxIn (𝓞 ↥N) := by
      symm
      simpa using Ideal.ramificationIdxIn_eq_ramificationIdx (p := 𝔭) (P := 𝔓) (G := Gal(↥N/F))
    _ = Nat.card (Ideal.inertia (Gal(↥N/F)) 𝔓) := by
      symm
      simpa using Ideal.card_inertia_eq_ramificationIdxIn (G := Gal(↥N/F)) 𝔭 hne 𝔓
    _ = 1 := hCardN

theorem sup_isUnramified (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField ↥(K ⊔ M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : IsEverywhereUnramified F ↥(K ⊔ M) := by
  let N : IntermediateField F (AlgebraicClosure F) := K ⊔ M
  refine IsEverywhereUnramified.of_local F ↥N ?_ ?_
  · intro 𝔭 𝔓 hp hne h𝔓
    simpa [N] using sup_unramified_at_finite F K M hK hM 𝔭 𝔓 hp hne h𝔓
  · intro w hw w' hw'
    simpa [N] using sup_real_lifts_real F K M hK hM w hw w' hw'

theorem finsetSup_isUnramified (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)] (s : Finset (maximalUnramifiedProPFIndex F p)) [NumberField ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F))] : IsEverywhereUnramified F ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  let P : Finset (maximalUnramifiedProPFIndex F p) → Prop :=
    fun s =>
      ∀ [_inst : NumberField ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F))],
        IsEverywhereUnramified F ↥(⨆ i ∈ s, i.M : IntermediateField F (AlgebraicClosure F))
  have hP : ∀ s : Finset (maximalUnramifiedProPFIndex F p), P s := by
    intro s
    induction s using Finset.induction_on with
    | empty =>
        intro _inst
        haveI : NumberField ↥(⊥ : IntermediateField F (AlgebraicClosure F)) := by
          simpa using (NumberField.of_ringEquiv (K := F)
            (L := ↥(⊥ : IntermediateField F (AlgebraicClosure F)))
            ((IntermediateField.botEquiv F (AlgebraicClosure F)).symm.toRingEquiv))
        have hFF : IsEverywhereUnramified F F := by
          refine IsEverywhereUnramified.of_local F F ?_ ?_
          · intro 𝔭 𝔓 hp hne h𝔓
            have hPeq : 𝔓 = 𝔭 := by
              haveI : 𝔓.LiesOver 𝔭 := h𝔓.2
              simpa using (Ideal.over_def 𝔓 𝔭).symm
            rw [hPeq]
            have hram : Ideal.ramificationIdx 𝔭 (Ideal.map (algebraMap (𝓞 F) (𝓞 F)) 𝔭) = 1 := by
              exact Ideal.ramificationIdx_map_self_eq_one (R := 𝓞 F) (S := 𝓞 F) (p := 𝔭)
                (by simpa using hp.ne_top) (by simpa using hne)
            simpa using hram
          · intro w hw w' hw'
            have hw'' : w'.comap (RingHom.id F) = w := by
              simpa using hw'
            cases hw''
            simpa using hw
        have hbot : IsEverywhereUnramified F ↥(⊥ : IntermediateField F (AlgebraicClosure F)) :=
          IsEverywhereUnramified.transport
            ((IntermediateField.botEquiv F (AlgebraicClosure F)).symm) hFF
        have hEmpty : (⊥ : IntermediateField F (AlgebraicClosure F)) =
            ⨆ i ∈ (∅ : Finset (maximalUnramifiedProPFIndex F p)),
              i.M := by
          simp
        exact IsEverywhereUnramified.transport (IntermediateField.equivOfEq hEmpty) hbot
    | @insert i s his ih =>
        intro _inst
        let Ks : IntermediateField F (AlgebraicClosure F) :=
          ⨆ j ∈ s, j.M
        letI : FiniteDimensional F i.M := i.hfd
        letI : NumberField i.M := i.hnf
        haveI : FiniteDimensional F ↥Ks :=
          IntermediateField.finiteDimensional_iSup_of_finset' (t := fun j : maximalUnramifiedProPFIndex F p => j.M)
            (s := s) (by intro j hj; exact j.hfd)
        haveI : FiniteDimensional F ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) :=
          IntermediateField.finiteDimensional_sup (E1 := i.M) (E2 := Ks)
        letI : Module.Finite F ↥Ks := show Module.Finite F ↥Ks from inferInstance
        letI : NumberField ↥Ks := NumberField.of_module_finite F ↥Ks
        letI : Module.Finite F ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) :=
          show Module.Finite F ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) from inferInstance
        letI : NumberField ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) :=
          NumberField.of_module_finite F ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F))
        haveI : IsGalois F i.M := i.hg
        haveI : IsGalois F ↥Ks := finsetSup_isGalois (F := F) (p := p) (s := s)
        have hKs : IsEverywhereUnramified F ↥Ks := by
          simpa [Ks] using (ih : IsEverywhereUnramified F ↥(⨆ j ∈ s, j.M : IntermediateField F (AlgebraicClosure F)))
        have hi : IsEverywhereUnramified F i.M := i.hunr
        have hSup : IsEverywhereUnramified F ↥(i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) :=
          sup_isUnramified (F := F) (K := i.M) (M := Ks) hi hKs
        have hInsert : (i.M ⊔ Ks : IntermediateField F (AlgebraicClosure F)) =
            ⨆ j ∈ insert i s, j.M := by
          simpa [Ks] using (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M)).symm
        exact IsEverywhereUnramified.transport (IntermediateField.equivOfEq hInsert) hSup
  exact hP s

theorem finiteIntermediate_isUnramified (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)] (L : IntermediateField F (maximalUnramifiedProPF F p)) [FiniteDimensional F L] [NumberField L] [IsGalois F L] : IsEverywhereUnramified F L := by
  classical
  let L0 : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift L
  let e : L ≃ₐ[F] L0 := IntermediateField.liftAlgEquiv L
  letI : FiniteDimensional F L0 := e.toLinearEquiv.finiteDimensional
  letI : Module.Finite F L0 := show Module.Finite F L0 from inferInstance
  haveI : NumberField L0 := NumberField.of_module_finite F L0
  letI : IsGalois F L0 := IsGalois.of_algEquiv (IntermediateField.liftAlgEquiv L)
  obtain ⟨s, hs⟩ := finiteIntermediate_lift_le_finsetSup (F := F) (p := p) (L := L)
  let Ms : IntermediateField F (AlgebraicClosure F) := ⨆ i ∈ s, i.M
  have hs' : L0 ≤ Ms := by
    simpa [L0, Ms] using hs
  haveI : FiniteDimensional F Ms := by
    simpa [Ms] using
      (IntermediateField.finiteDimensional_iSup_of_finset'
        (K := F)
        (t := fun i : maximalUnramifiedProPFIndex F p => i.M)
        (s := s)
        (h := fun i _ => i.hfd))
  letI : Module.Finite F Ms := show Module.Finite F Ms from inferInstance
  haveI : NumberField Ms := NumberField.of_module_finite F Ms
  have hMs : IsEverywhereUnramified F Ms :=
    finsetSup_isUnramified (F := F) (p := p) (s := s)
  have hL0 : IsEverywhereUnramified F L0 :=
    subfield_isUnramified_of_le (F := F) (L := L0) (M := Ms) hs' hMs
  exact IsEverywhereUnramified.transport (IntermediateField.liftAlgEquiv L).symm hL0

theorem cft_D2_infiniteQuotientTower (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))
    (_hQ_infinite : Infinite Q.Q) :
    Nonempty (ProPTowerFromQuotient F p Q) := by
  classical
  let K := maximalUnramifiedProPF F p
  haveI : IsGalois F K := MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F p
  obtain ⟨U, hU0, hUmono, hUtendsto⟩ := openNormalChain (Q0 := Q.Q)
  let N : ℕ → Subgroup (Gal(K/F)) := fun j => ((U j : Subgroup Q.Q).comap Q.map)
  have hNnormal : ∀ j, (N j).Normal := by
    intro j
    dsimp [N]
    infer_instance
  have hNopen : ∀ j, IsOpen (N j : Set (Gal(K/F))) := by
    intro j
    let V : OpenSubgroup (Gal(K/F)) := OpenSubgroup.comap Q.map Q.continuous (U j).toOpenSubgroup
    simpa [N, V, OpenSubgroup.toSubgroup_comap] using (V.isOpen)
  let H : ℕ → ClosedSubgroup (Gal(K/F)) := fun j =>
    { toSubgroup := N j
      isClosed' := Subgroup.isClosed_of_isOpen (N j) (hNopen j) }
  let L : ℕ → IntermediateField F K := fun j => IntermediateField.fixedField (((H j : ClosedSubgroup (Gal(K/F))) : Subgroup (Gal(K/F))))
  have hLfix : ∀ j, ((L j).fixingSubgroup : Subgroup (Gal(K/F))) = N j := by
    intro j
    simpa [L, H] using (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) (H j))
  have hLfin_gal : ∀ j, FiniteDimensional F (L j) ∧ IsGalois F (L j) := by
    intro j
    have hopen : IsOpen (((L j).fixingSubgroup : Subgroup (Gal(K/F))) : Set (Gal(K/F))) := by
      rw [hLfix j]
      exact hNopen j
    have hnormal : ((L j).fixingSubgroup : Subgroup (Gal(K/F))).Normal := by
      rw [hLfix j]
      exact hNnormal j
    exact (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := F) (K := K) (L := L j)).1 ⟨hopen, hnormal⟩
  have hLfd : ∀ j, FiniteDimensional F (L j) := fun j => (hLfin_gal j).1
  have hLgalois : ∀ j, IsGalois F (L j) := fun j => (hLfin_gal j).2
  have hLnum : ∀ j, NumberField (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j
    letI : Module.Finite F (L j) := hLfd j
    exact NumberField.of_module_finite F (L j)
  have hphi_surj : ∀ j, Function.Surjective (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map) : Gal(K/F) →* (Q.Q ⧸ (U j : Subgroup Q.Q))) := by
    intro j q
    rcases (QuotientGroup.mk'_surjective (N := (U j : Subgroup Q.Q))) q with ⟨x, rfl⟩
    rcases Q.surjective x with ⟨g, rfl⟩
    exact ⟨g, rfl⟩
  have hNker : ∀ j, N j = (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map) : Gal(K/F) →* (Q.Q ⧸ (U j : Subgroup Q.Q))).ker := by
    intro j
    change ((U j : Subgroup Q.Q).comap Q.map) = (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map)).ker
    rw [← MonoidHom.comap_ker (QuotientGroup.mk' (U j : Subgroup Q.Q)) Q.map, QuotientGroup.ker_mk']
  let hquot_equiv : ∀ j, (Q.Q ⧸ (U j : Subgroup Q.Q)) ≃* (Gal(K/F) ⧸ N j) := by
    intro j
    exact (QuotientGroup.liftEquiv (N j) (hphi_surj j) (hNker j)).symm
  have hq : ∀ j (σ : Gal(K/F)), hquot_equiv j ((Q.map σ : Q.Q) : Q.Q ⧸ (U j : Subgroup Q.Q)) = (σ : Gal(K/F) ⧸ N j) := by
    intro j σ
    apply (MulEquiv.symm_apply_eq (QuotientGroup.liftEquiv (N j) (hphi_surj j) (hNker j))).2
    rfl
  have hLmono : ∀ j, L j ≤ L (j + 1) := by
    intro j
    apply IntermediateField.fixedField_le
    exact Subgroup.comap_mono (hUmono j)
  have hN0 : N 0 = ⊤ := by
    ext σ
    simp [N, hU0]
  have hL0 : L 0 = ⊥ := by
    simpa [L, H, hN0] using (InfiniteGalois.fixedField_bot (k := F) (K := K))
  let hquot_aut_equiv : ∀ j, (Q.Q ⧸ (U j : Subgroup Q.Q)) ≃* ((L j) ≃ₐ[F] (L j)) := by
    intro j
    haveI : (H j).Normal := by
      change (N j).Normal
      exact hNnormal j
    exact (hquot_equiv j).trans (InfiniteGalois.normalAutEquivQuotient (k := F) (K := K) (H j))
  let quotientMap : ∀ j, Q.Q →* ((L j) ≃ₐ[F] (L j)) := fun j =>
    (hquot_aut_equiv j).toMonoidHom.comp (QuotientGroup.mk' (U j : Subgroup Q.Q))
  have hquotientMap_surj : ∀ j, Function.Surjective (quotientMap j) := by
    intro j τ
    rcases (QuotientGroup.mk'_surjective (N := (U j : Subgroup Q.Q)) ((hquot_aut_equiv j).symm τ)) with ⟨x, hx⟩
    refine ⟨x, ?_⟩
    change (hquot_aut_equiv j) ((x : Q.Q ⧸ (U j : Subgroup Q.Q))) = τ
    exact by
      simpa using congrArg (hquot_aut_equiv j) hx
  have hpgroup_gal : ∀ j, IsPGroup p ((L j) ≃ₐ[F] (L j)) := by
    intro j
    have hqpg : IsPGroup p (Q.Q ⧸ (U j : Subgroup Q.Q)) := by
      exact Q.isProP (U j : Subgroup Q.Q) ((U j).toOpenSubgroup.isOpen)
    exact IsPGroup.of_equiv hqpg (hquot_aut_equiv j)
  have hquotientMap_apply : ∀ j (σ : Gal(K/F)), quotientMap j (Q.map σ) = AlgEquiv.restrictNormalHom (L j) σ := by
    intro j σ
    haveI : (H j).Normal := by
      change (N j).Normal
      exact hNnormal j
    change InfiniteGalois.normalAutEquivQuotient (k := F) (K := K) (H j)
        (hquot_equiv j ((Q.map σ : Q.Q) : Q.Q ⧸ (U j : Subgroup Q.Q))) = _
    rw [hq j σ]
    simpa using (InfiniteGalois.normalAutEquivQuotient_apply (k := F) (K := K) (H := H j) σ)
  have hunramified : ∀ j, IsEverywhereUnramified F (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j
    letI : Module.Finite F (L j) := hLfd j
    letI : NumberField (L j) := hLnum j
    letI : IsGalois F (L j) := hLgalois j
    exact finiteIntermediate_isUnramified F p (L j)
  have hbase_iso : Nonempty ((L 0) ≃ₐ[ℚ] F) := by
    refine ⟨((hL0.symm ▸ (IntermediateField.botEquiv F K)) : (L 0) ≃ₐ[F] F).restrictScalars ℚ⟩
  have hstep_compat : ∀ j,
      (((IntermediateField.inclusion (hLmono j)).toRingHom).comp (algebraMap F (L j)) = algebraMap F (L (j + 1))) := by
    intro j
    ext x
    rfl
  have hcard_eq_finrankF : ∀ j, Nat.card (Q.Q ⧸ (U j : Subgroup Q.Q)) = Module.finrank F (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j
    letI : IsGalois F (L j) := hLgalois j
    calc
      Nat.card (Q.Q ⧸ (U j : Subgroup Q.Q)) = Nat.card ((L j) ≃ₐ[F] (L j)) := by
        exact Nat.card_congr (hquot_aut_equiv j).toEquiv
      _ = Module.finrank F (L j) := by
        simpa using (IsGalois.card_aut_eq_finrank F (L j))
  have hdeg_tendsto_F : Filter.Tendsto (fun j => Module.finrank F (L j)) Filter.atTop Filter.atTop := by
    convert hUtendsto using 1
    ext j
    exact (hcard_eq_finrankF j).symm
  have hdegree_tendsto : Filter.Tendsto (fun j => Module.finrank ℚ (L j)) Filter.atTop Filter.atTop := by
    apply Filter.tendsto_atTop_mono (f := fun j => Module.finrank F (L j))
    · intro j
      letI : NumberField (L j) := hLnum j
      exact Module.finrank_top_le_finrank_of_isScalarTower ℚ F (L j)
    · exact hdeg_tendsto_F
  refine ⟨{ L := fun j => L j
            field_L := fun j => inferInstance
            charZero_L := fun j => by
              letI : NumberField (L j) := hLnum j
              infer_instance
            numField_L := hLnum
            algebra_F_L := fun j => inferInstance
            isGalois_F_L := hLgalois
            base_iso := hbase_iso
            step := fun j => (IntermediateField.inclusion (hLmono j)).toRingHom
            step_compat := hstep_compat
            unramified := hunramified
            pgroup_gal := hpgroup_gal
            quotientMap := quotientMap
            quotientMap_surj := hquotientMap_surj
            quotientMap_compat := by
              intro j 𝔭 hp hne
              rw [hquotientMap_apply j (splittingDetectorAt F p 𝔭 hp hne)]
              letI : FiniteDimensional F (L j) := hLfd j
              letI : IsGalois F (L j) := hLgalois j
              letI : NumberField (L j) := hLnum j
              exact (splittingDetectorAt_spec F p 𝔭 hp hne (L j) (hpgroup_gal j))
            degree_tendsto := hdegree_tendsto }⟩

theorem primeOverQ_has_abs_split (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
(Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))
(T : ProPTowerFromQuotient F p Q)
(q : ℕ) (_hq : q.Prime)
(_hq_splits_F :
  (∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F),
      Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
      Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
    ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F)).ncard =
      Module.finrank ℚ F)
(_h_killed :
  ∀ (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥),
    𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F) →
    Q.map (@splittingDetectorAt F _ _ p _ 𝔭 hp hne) = 1)
(j : ℕ) {𝔓 : Ideal (𝓞 (T.L j))}
(h𝔓 : 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 (T.L j))) :
Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
  Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 := by
  let p0 : Ideal ℤ := Ideal.span {(q : ℤ)}
  let 𝔭 : Ideal (𝓞 F) := Ideal.comap (algebraMap (𝓞 F) (𝓞 (T.L j))) 𝔓
  letI : Fact q.Prime := ⟨_hq⟩
  letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
  have hqz : (q : ℤ) ≠ 0 := by
    exact_mod_cast _hq.ne_zero
  have hp0_ne_bot : p0 ≠ ⊥ := by
    intro hp0_bot
    have hspan : Ideal.span {(q : ℤ)} = ⊥ := by
      simpa [p0] using hp0_bot
    exact hqz ((Ideal.span_singleton_eq_bot).mp hspan)
  have h𝔓' : 𝔓 ∈ p0.primesOver (𝓞 (T.L j)) := by
    simpa [p0] using h𝔓
  have hP_prime : 𝔓.IsPrime := h𝔓'.1
  have hP_lies_q : 𝔓.LiesOver p0 := h𝔓'.2
  letI : 𝔓.IsPrime := hP_prime
  letI : 𝔓.LiesOver p0 := hP_lies_q
  have h𝔭_prime : 𝔭.IsPrime := by
    dsimp [𝔭]
    infer_instance
  have h𝔭_lies_q : 𝔭.LiesOver p0 := by
    dsimp [𝔭]
    infer_instance
  letI : 𝔭.IsPrime := h𝔭_prime
  letI : 𝔭.LiesOver p0 := h𝔭_lies_q
  have h𝔭_mem : 𝔭 ∈ p0.primesOver (𝓞 F) := by
    exact ⟨h𝔭_prime, h𝔭_lies_q⟩
  have h𝔭_ne_bot : 𝔭 ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hp0_ne_bot h𝔭_mem
  have hP_mem_rel : 𝔓 ∈ 𝔭.primesOver (𝓞 (T.L j)) := by
    refine ⟨hP_prime, ?_⟩
    dsimp [𝔭]
    infer_instance
  letI : 𝔓.LiesOver 𝔭 := hP_mem_rel.2
  have hram_rel : Ideal.ramificationIdx 𝔭 𝔓 = 1 := by
    exact IsEverywhereUnramified.unramified_at_finite (T.unramified j) 𝔭 𝔓 h𝔭_prime h𝔭_ne_bot hP_mem_rel
  have hkill : Q.map (@splittingDetectorAt F _ _ p _ 𝔭 h𝔭_prime h𝔭_ne_bot) = 1 := by
    exact _h_killed 𝔭 h𝔭_prime h𝔭_ne_bot (by simpa [p0] using h𝔭_mem)
  have hcompat : ∀ 𝔔 ∈ 𝔭.primesOver (𝓞 (T.L j)), Ideal.inertiaDeg 𝔭 𝔔 = 1 := by
    exact (T.quotientMap_compat j 𝔭 h𝔭_prime h𝔭_ne_bot).mp (by rw [hkill, MonoidHom.map_one])
  have hinert_rel : Ideal.inertiaDeg 𝔭 𝔓 = 1 := hcompat 𝔓 hP_mem_rel
  have hbase : Ideal.ramificationIdx p0 𝔭 = 1 ∧ Ideal.inertiaDeg p0 𝔭 = 1 := by
    exact (_hq_splits_F.1) 𝔭 (by simpa [p0] using h𝔭_mem)
  have hram_abs : Ideal.ramificationIdx p0 𝔓 = 1 := by
    have hmap𝔭_ne_bot : Ideal.map (algebraMap (𝓞 F) (𝓞 (T.L j))) 𝔭 ≠ ⊥ :=
      Ideal.map_ne_bot_of_ne_bot h𝔭_ne_bot
    have hmapp0_ne_bot : Ideal.map (algebraMap ℤ (𝓞 (T.L j))) p0 ≠ ⊥ :=
      Ideal.map_ne_bot_of_ne_bot hp0_ne_bot
    have hmap_le : Ideal.map (algebraMap (𝓞 F) (𝓞 (T.L j))) 𝔭 ≤ 𝔓 := by
      rw [Ideal.map_le_iff_le_comap, Ideal.over_def (A := 𝓞 F) (P := 𝔓) (p := 𝔭)]
    rw [Ideal.ramificationIdx_algebra_tower (p := p0) (P := 𝔭) (Q := 𝔓) hmap𝔭_ne_bot hmapp0_ne_bot hmap_le]
    rw [hbase.1, hram_rel]
  have hinert_abs : Ideal.inertiaDeg p0 𝔓 = 1 := by
    letI : 𝔭.IsMaximal := Ideal.isMaximal_of_mem_primesOver h𝔭_mem
    letI : 𝔓.IsMaximal := Ideal.isMaximal_of_mem_primesOver h𝔓'
    rw [Ideal.inertiaDeg_algebra_tower p0 𝔭 𝔓]
    rw [hbase.2, hinert_rel]
  exact ⟨by simpa [p0] using hram_abs, by simpa [p0] using hinert_abs⟩

theorem splitCount_of_primewiseSplit (K : Type) [Field K] [NumberField K] (q : ℕ) (_hq : q.Prime)
(h_split :
  ∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 K),
    Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
    Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) :
((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 K)).ncard =
  Module.finrank ℚ K := by
  let p0 : Ideal ℤ := Ideal.span {(q : ℤ)}
  letI : Fact q.Prime := ⟨_hq⟩
  letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
  have hp0_ne_bot : p0 ≠ ⊥ := by
    simpa [p0, Ideal.span_singleton_eq_bot] using
      (show (q : ℤ) ≠ 0 by exact_mod_cast _hq.ne_zero)
  have hsum :
      ∑ P ∈ primesOverFinset p0 (𝓞 K),
        Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P
        = (primesOverFinset p0 (𝓞 K)).card := by
    calc
      ∑ P ∈ primesOverFinset p0 (𝓞 K),
          Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P
        = ∑ _P ∈ primesOverFinset p0 (𝓞 K), (1 : ℕ) := by
            refine Finset.sum_congr rfl ?_
            intro P hP
            have hPset : P ∈ p0.primesOver (𝓞 K) := by
              simpa only [mem_primesOverFinset_iff hp0_ne_bot (𝓞 K)] using hP
            rcases h_split P hPset with ⟨h1, h2⟩
            change (Ideal.span {(q : ℤ)} : Ideal ℤ).ramificationIdx P *
                (Ideal.span {(q : ℤ)} : Ideal ℤ).inertiaDeg P = 1
            simp only [h1, h2, one_mul]
      _ = (primesOverFinset p0 (𝓞 K)).card := by
            rw [← Finset.card_eq_sum_ones]
  calc
    ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 K)).ncard
      = (primesOverFinset p0 (𝓞 K)).card := by
          change (p0.primesOver (𝓞 K)).ncard = (primesOverFinset p0 (𝓞 K)).card
          rw [← Set.ncard_coe_finset, coe_primesOverFinset hp0_ne_bot (𝓞 K)]
    _ = ∑ P ∈ primesOverFinset p0 (𝓞 K),
          Ideal.ramificationIdx p0 P * Ideal.inertiaDeg p0 P := by
          exact hsum.symm
    _ = Module.finrank ℚ K := by
          exact Ideal.sum_ramification_inertia (S := 𝓞 K) (K := ℚ) (L := K) hp0_ne_bot

theorem cft_D3_killedFrobeniusSplits (F : Type) [Field F] [NumberField F] (p : ℕ) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))
    (T : ProPTowerFromQuotient F p Q)
    (q : ℕ) (_hq : q.Prime)
    (_hq_splits_F :
      (∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
          Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
        ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F)).ncard =
          Module.finrank ℚ F)
    (_h_killed :
      ∀ (𝔭 : Ideal (𝓞 F)) (hp : 𝔭.IsPrime) (hne : 𝔭 ≠ ⊥),
        𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F) →
        Q.map (@splittingDetectorAt F _ _ p _ 𝔭 hp hne) = 1) :
    ∀ j,
      (∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 (T.L j)),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
          Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
        ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 (T.L j))).ncard =
          Module.finrank ℚ (T.L j) := by
  intro j
  refine ⟨?_, ?_⟩
  · intro 𝔓 h𝔓
    exact primeOverQ_has_abs_split F p Q T q _hq _hq_splits_F _h_killed j h𝔓
  · exact splitCount_of_primewiseSplit (K := T.L j) q _hq (fun 𝔓 h𝔓 =>
      primeOverQ_has_abs_split F p Q T q _hq _hq_splits_F _h_killed j h𝔓)


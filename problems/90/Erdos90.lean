    refine вҹЁ?_вҹ©
    intro x hx a
    refine Subgroup.closure_induction
      (p := fun y _ => a * y * aвҒ»В№ вҲҲ Subgroup.closure S)
      ?hmem ?hone ?hmul ?hinv hx
    В· intro y hy
      rcases hy with hy | hy
      В· rcases hy with вҹЁg, rflвҹ©
        exact Subgroup.subset_closure <| Or.inl <| вҹЁa * g * aвҒ»В№, by
          simp
        вҹ©
      В· exact Subgroup.subset_closure <| Or.inr <| (inferInstance : (commutator G).Normal).conj_mem y hy a
    В· simp
    В· intro y z hy hz hy' hz'
      have hm : (a * y * aвҒ»В№) * (a * z * aвҒ»В№) вҲҲ Subgroup.closure S :=
        Subgroup.mul_mem (Subgroup.closure S) hy' hz'
      simpa [mul_assoc] using hm
    В· intro y hy hy'
      have hi : (a * y * aвҒ»В№)вҒ»В№ вҲҲ Subgroup.closure S :=
        Subgroup.inv_mem (Subgroup.closure S) hy'
      simpa [mul_assoc] using hi
  letI : (Subgroup.closure S).Normal := hnormal_closure
  simpa [closedFrattini, S] using (Subgroup.is_normal_topologicalClosure (N := Subgroup.closure S))


      exfalso
      have hlb := concreteSeq.B_k_lower_bound j hj (enumerateB i) hx_in_j
      have hN_mono : concreteSeq.N m ≤ concreteSeq.N (j - 1) := concreteSeq.N_mono_le (by omega)
      have hlo : enumerateB i ≥ concreteSeq.N m + 1 := by
        simp only [NathansonSeq.N] at hlb hN_mono ⊢
        omega
      have hB_upper : ∀ j' ≤ m, j' ≥ 1 → ∀ x ∈ concreteSeq.B_k j', x < concreteSeq.N m + 1 := by
        intro j' hj'_le hj'_ge x hx_in
        have hub := concreteSeq.B_k_upper_bound j' hj'_ge x hx_in
        have hn_mono' : concreteSeq.n j' ≤ concreteSeq.n m := concreteSeq.n_mono_le hj'_le
        have hN_mono' : concreteSeq.N (j' - 1) ≤ concreteSeq.N (m - 1) := concreteSeq.N_mono_le (by omega)
        have hexp := concreteSeq.exponential_growth m hm
        have hn_pos := concreteSeq.n_pos (m - 1)
        simp only [NathansonSeq.N] at hub hN_mono' hexp ⊢
        omega
      have hB_lt_enum : ∀ j' ≤ m, j' ≥ 1 → ∀ x ∈ concreteSeq.B_k j', x < enumerateB i := by
        intro j' hj'_le hj'_ge x hx_in
        have h1 := hB_upper j' hj'_le hj'_ge x hx_in
        omega
      have hcount : ∀ j' ≤ m, j' ≥ 1 → ∀ x ∈ concreteSeq.B_k j', ∃ k, k ≥ 1 ∧ k < i ∧ enumerateB k = x := by
        intro j' hj'_le hj'_ge x hx_in
        have hx_inB : concreteSeq.inB x := ⟨j', hj'_ge, hx_in⟩
        obtain ⟨k, hk_ge, hk_eq⟩ := enumerateB_covers x hx_inB
        refine ⟨k, hk_ge, ?_, hk_eq⟩
        by_contra hk_ge_i
        push_neg at hk_ge_i
        have hlt := hB_lt_enum j' hj'_le hj'_ge x hx_in
        have hmono : enumerateB i ≤ enumerateB k := by
          have hstrictMono : StrictMono enumerateB := strictMono_nat_of_lt_succ enumerateB_mono
          exact hstrictMono.monotone hk_ge_i
        rw [hk_eq] at hmono
        omega
      have hcount_ge : i > K (m + 1) := by
        have hinj : Function.Injective enumerateB := by
          have hstrictMono : StrictMono enumerateB := strictMono_nat_of_lt_succ enumerateB_mono
          exact hstrictMono.injective
        by_contra h_not_gt
        push_neg at h_not_gt
        have hK_pos : K (m + 1) ≥ 1 := by
          have hK2 : K 2 ≥ 1 := by simp [K, cumulativeCount, simpleH]
          have hK_mono' : K 2 ≤ K (m + 1) := by
            have hmono : ∀ a b, a ≤ b → K a ≤ K b := by
              intro a b hab
              induction hab with
              | refl => exact le_refl _
              | @step n _ ih' => exact le_trans ih' (K_mono n)
            exact hmono 2 (m + 1) (by omega)
          omega
        have hK_gt : K (m + 1) > i - 1 := by omega
        by_cases hi1 : i = 1
        · -- i = 1: enumerateB 1 is the smallest element of B
          subst hi1
          have henumB1 := enumerateB_1_lower_bound
          have henumB1_ub : enumerateB 1 ≤ 599 := by
            have h' := enumerateB_early 1 ⟨le_refl 1, by omega⟩
            omega
          have hN_m_lower : concreteSeq.N m ≥ concreteSeq.N 1 := concreteSeq.N_mono_le (by omega)
          have hN1_val : concreteSeq.N 1 = 1601 := by
            simp [NathansonSeq.N, concreteSeq, concreteN]
          omega
        · -- i ≥ 2: use IH on i - 1
          push_neg at hi1
          have hi_ge_2 : i ≥ 2 := by omega
          have hi_sub_1_ge : i - 1 ≥ 1 := by omega
          have hi_sub_1_lt : i - 1 < i := by omega
          have hi_sub_1_le : i - 1 ≤ K (m + 1) := by omega
          have hih := ih (i - 1) hi_sub_1_lt hi_sub_1_ge hi_sub_1_le
          have hexp := concreteSeq.exponential_growth m hm
          have hn_pos := concreteSeq.n_pos (m - 1)
          have henum_prev : enumerateB (i - 1) < concreteSeq.N m + 1 := by
            simp only [NathansonSeq.N] at hih hexp ⊢
            omega
          have heq : enumerateB i = nextInB (enumerateB (i - 1)) := by
            have : i = (i - 1) + 1 := by omega
            rw [this]; rfl
          by_cases heq_max : enumerateB (i - 1) = concreteSeq.n m + concreteSeq.N (m - 1)
          · -- enumerateB (i-1) = n_m + N_{m-1} = max(B_m)
            exfalso
            have hbound : ∀ j', j' ≤ m → j' ≥ 1 → ∀ x ∈ concreteSeq.B_k j', x ≤ enumerateB (i - 1) := by
              intro j' hj'_le hj'_ge x hx_in
              have hub := concreteSeq.B_k_upper_bound j' hj'_ge x hx_in
              have hn_mono : concreteSeq.n j' ≤ concreteSeq.n m := concreteSeq.n_mono_le hj'_le
              have hN_mono : concreteSeq.N (j' - 1) ≤ concreteSeq.N (m - 1) := concreteSeq.N_mono_le (by omega)
              simp only [NathansonSeq.N] at hub hN_mono heq_max ⊢
              omega
            exact stages_contradict_positions m hm i hi_ge_2 hi_le hbound
          · -- enumerateB (i-1) < n_m + N_{m-1}
            push_neg at heq_max
            have hlt : enumerateB (i - 1) < concreteSeq.n m + concreteSeq.N (m - 1) := by
              have h := hih
              omega
            have hnext := enumerateB i
            rw [heq] at hlo
            exfalso
            have hbound : ∀ j', j' ≤ m → j' ≥ 1 → ∀ x ∈ concreteSeq.B_k j', x ≤ enumerateB (i - 1) := by
              intro j' hj'_le hj'_ge x hx_in
              have hub := concreteSeq.B_k_upper_bound j' hj'_ge x hx_in
              have hn_mono : concreteSeq.n j' ≤ concreteSeq.n m := concreteSeq.n_mono_le hj'_le
              have hN_mono : concreteSeq.N (j' - 1) ≤ concreteSeq.N (m - 1) := concreteSeq.N_mono_le (by omega)
              have hexp := concreteSeq.exponential_growth m hm
              have hn_pos := concreteSeq.n_pos (m - 1)
              have hx_lt_Nm : x < concreteSeq.N m + 1 := by
                simp only [NathansonSeq.N] at hub hn_mono hN_mono hexp ⊢
                omega
              by_contra hx_gt
              push_neg at hx_gt
              have hx_inB : inB_concrete x := ⟨j', hj'_ge, hx_in⟩
              have hmin := nextInB_minimal (enumerateB (i - 1)) x hx_gt hx_inB
              omega
            exact stages_contradict_positions m hm i hi_ge_2 hi_le hbound
      omega
/-- Corollary: enumerateB i ≤ 200 * 8^m for i ≤ K(m+1) -/
lemma enumerateB_exp_bound (m : ℕ) (hm : m ≥ 1) (i : ℕ) (hi : 1 ≤ i) (hi_le : i ≤ K (m + 1)) :
    enumerateB i ≤ 200 * 8^m := by
  have h := enumerateB_stage_upper_bound m hm i hi hi_le
  simp only [NathansonSeq.N, concreteSeq, concreteN] at h ⊢
  have hpow : 8^m = 8 * 8^(m-1) := by
    have heq : m = (m - 1) + 1 := by omega
    conv_lhs => rw [heq, pow_succ]
    ring
  have hpow' : 8^(m-1) ≥ 1 := Nat.one_le_pow (m-1) 8 (by omega)
  nlinarith
/-- Polynomial bound: enumerateB i ≤ 1600 * i^3 for i ≥ 1 -/
lemma enumerateB_poly_bound (i : ℕ) (hi : i ≥ 1) : enumerateB i ≤ 1600 * i^3 := by
  by_cases hi1 : i = 1
  · subst hi1
    have h : enumerateB 1 ≤ 599 := by
      have h' := enumerateB_early 1 ⟨le_refl 1, by omega⟩
      omega
    calc enumerateB 1 ≤ 599 := h
      _ ≤ 1600 * 1^3 := by norm_num
  push_neg at hi1
  have hi2 : i ≥ 2 := by omega
  let m := Nat.log 2 i + 1
  have hm : m ≥ 1 := by omega
  have h2m_gt : 2^m > i := by
    simp only [m]
    have hlog : 2^(Nat.log 2 i + 1) > i := Nat.lt_pow_succ_log_self (by omega : 1 < 2) i
    exact hlog
  have hK_ge : K (m + 1) ≥ i := by
    have hK := K_exp_lower m hm
    have h2m_ge : 2^m ≥ i + 1 := h2m_gt
    omega
  have hbound := enumerateB_exp_bound m hm i hi (by omega : i ≤ K (m + 1))
  simp only [m] at hbound
  have hpow : 8^(Nat.log 2 i + 1) = 8 * 8^(Nat.log 2 i) := by ring
  rw [hpow] at hbound
  have h8log : 8^(Nat.log 2 i) ≤ i^3 := by
    have hlog_bound : 2^(Nat.log 2 i) ≤ i := Nat.pow_log_le_self 2 (by omega)
    calc 8^(Nat.log 2 i) = (2^3)^(Nat.log 2 i) := by ring
      _ = 2^(3 * Nat.log 2 i) := by rw [← pow_mul]
      _ = 2^(Nat.log 2 i * 3) := by ring_nf
      _ = (2^(Nat.log 2 i))^3 := by rw [pow_mul]
      _ ≤ i^3 := Nat.pow_le_pow_left hlog_bound 3
  calc enumerateB i ≤ 200 * (8 * 8^(Nat.log 2 i)) := hbound
    _ = 1600 * 8^(Nat.log 2 i) := by ring
    _ ≤ 1600 * i^3 := by nlinarith
/-!
## Step 7: Assemble the GrowingConstruction
-/
/-- Helper: index within stage is valid for nthSubsetOfIcc -/
lemma indexInStage_valid (k : ℕ) (hk : k ≥ 1) :
    indexInStage k < Nat.choose (simpleH (stageAssign k)) (stageAssign k) := by
  have hk_ne : k ≠ 0 := Nat.one_le_iff_ne_zero.mp hk
  simp only [indexInStage, if_neg hk_ne]
  have h := Nat.find_spec (stageAssign.exists_stage k hk)
  have hm_ge : stageAssign k ≥ 1 := stageAssign_pos k hk
  simp only [stageAssign, dif_neg hk_ne] at h ⊢
  have hK : K (Nat.find (stageAssign.exists_stage k hk) + 1) =
      K (Nat.find (stageAssign.exists_stage k hk)) +
      Nat.choose (simpleH (Nat.find (stageAssign.exists_stage k hk))) (Nat.find (stageAssign.exists_stage k hk)) := by
    apply K_succ
    simp only [stageAssign, dif_neg hk_ne] at hm_ge
    exact hm_ge
  omega
/-- F_k has the right cardinality -/
lemma F_card_prop (k : ℕ) (hk : k ≥ 1) : (F k).card = stageAssign k := by
  have hk_ne : k ≠ 0 := Nat.one_le_iff_ne_zero.mp hk
  simp only [F, hk_ne, ↓reduceDIte]
  let m := stageAssign k
  let Hm := simpleH m
  let idx := indexInStage k
  have hidx : idx < Nat.choose Hm m := indexInStage_valid k hk
  have hcard : (nthSubsetOfIcc Hm m idx).card = m := nthSubsetOfIcc_card Hm m idx hidx
  have enumerateB_lt : ∀ i j, i < j → enumerateB i < enumerateB j := by
    intro i j hij
    induction j generalizing i with
    | zero => omega
    | succ j ih =>
      rcases Nat.lt_succ_iff_lt_or_eq.mp hij with hij' | heq'
      · exact Nat.lt_trans (ih i hij') (enumerateB_mono j)
      · subst heq'; exact enumerateB_mono i
  have hinj : ∀ i ∈ nthSubsetOfIcc Hm m idx, ∀ j ∈ nthSubsetOfIcc Hm m idx,
      enumerateB i = enumerateB j → i = j := by
    intro i _ j _ heq
    by_contra hne
    rcases Ne.lt_or_gt hne with hlt | hlt
    · have hlt' := enumerateB_lt i j hlt
      omega
    · have hlt' := enumerateB_lt j i hlt
      omega
  rw [Finset.card_image_of_injOn hinj, hcard]
/-- F_k elements are in the range {a_1, ..., a_{H_m}} -/
lemma F_subset_prop (k : ℕ) (hk : k ≥ 1) (x : ℕ) (hx : x ∈ F k) :
    ∃ i, 1 ≤ i ∧ i ≤ simpleH (stageAssign k) ∧ enumerateB i = x := by
  unfold F at hx
  have hk_ne : k ≠ 0 := Nat.one_le_iff_ne_zero.mp hk
  simp only [hk_ne, ↓reduceDIte, Finset.mem_image] at hx
  obtain ⟨i, hi, rfl⟩ := hx
  use i
  have hidx : indexInStage k < Nat.choose (simpleH (stageAssign k)) (stageAssign k) := indexInStage_valid k hk
  have hbounds := nthSubsetOfIcc_subset (simpleH (stageAssign k)) (stageAssign k) (indexInStage k) hidx i hi
  exact ⟨hbounds.1, hbounds.2, rfl⟩
/-- Key lemma: K_m grows at least as fast as 2m -/
lemma K_lower_bound (m : ℕ) (hm : m ≥ 1) : K (m + 1) ≥ 2 * m := by
  induction m with
  | zero => omega
  | succ m ih =>
    by_cases hm' : m = 0
    · -- m = 0, showing K_2 ≥ 2
      subst hm'
      simp only [K, cumulativeCount, simpleH]
      decide
    · have hm_ge : m ≥ 1 := Nat.one_le_iff_ne_zero.mpr hm'
      have h1 : K (m + 1) ≥ 2 * m := ih hm_ge
      have hK : K (m + 1 + 1) = K (m + 1) + Nat.choose (simpleH (m + 1)) (m + 1) := K_succ _ (by omega)
      have hchoose : Nat.choose (simpleH (m + 1)) (m + 1) ≥ 2 := by
        simp only [simpleH]
        have h1 : m + 1 ≤ 2 * (m + 1) := by omega
        have h2 : Nat.choose (2 * (m + 1)) (m + 1) ≥ 1 := Nat.choose_pos (by omega)
        have h3 : 2 * (m + 1) ≥ m + 1 + 1 := by omega
        have h4 : Nat.choose (2 * (m + 1)) (m + 1) ≥ Nat.choose (m + 1 + 1) (m + 1) := by
          apply Nat.choose_mono
          exact h3
        calc Nat.choose (2 * (m + 1)) (m + 1)
          ≥ Nat.choose (m + 1 + 1) (m + 1) := h4
          _ = m + 2 := Nat.choose_succ_self_right (m + 1)
          _ ≥ 2 := by omega
      calc K (m + 1 + 1) = K (m + 1) + Nat.choose (simpleH (m + 1)) (m + 1) := hK
        _ ≥ 2 * m + 2 := by omega
        _ = 2 * (m + 1) := by ring
/-- K m ≥ m for all m ≥ 2 -/
lemma K_ge_self (m : ℕ) (hm : m ≥ 2) : K m ≥ m := by
  induction m with
  | zero => omega
  | succ n ih =>
    by_cases hn1 : n = 1
    · -- K 2 ≥ 2: K 2 = K 1 + choose(2, 1) = 0 + 2 = 2
      subst hn1
      simp only [K, cumulativeCount, simpleH]
      decide
    · -- n ≥ 2, so we can use ih
      have hn_ge2 : n ≥ 2 := by omega
      have ih' := ih hn_ge2
      have hn_pos : n ≥ 1 := by omega
      have hK_succ : K (n + 1) = K n + Nat.choose (simpleH n) n := K_succ n hn_pos
      have hchoose : Nat.choose (simpleH n) n ≥ 1 := by
        simp only [simpleH]
        exact Nat.choose_pos (by omega : n ≤ 2 * n)
      omega
/-- Stage is bounded by k -/
lemma stage_le_k_prop (k : ℕ) (hk : k ≥ 1) : stageAssign k ≤ k := by
  have hk_ne : k ≠ 0 := Nat.one_le_iff_ne_zero.mp hk
  simp only [stageAssign, dif_neg hk_ne]
  set m := Nat.find (stageAssign.exists_stage k hk) with hm_def
  have h := Nat.find_spec (stageAssign.exists_stage k hk)
  by_cases hm0 : m = 0
  · -- m = 0: need 0 ≤ k
    omega
  · by_cases hm1 : m = 1
    · -- m = 1: need 1 ≤ k, which is hk
      omega
    · -- m ≥ 2 case
      have hm_ge2 : m ≥ 2 := by omega
      have hK_ge_m : K m ≥ m := K_ge_self m hm_ge2
      have hKm_lt_k : K m < k := h.1
      omega
/-- k values grow with stage -/
lemma k_grows_with_stage_prop (m : ℕ) (hm : m ≥ 1) : ∃ k₀, ∀ k, stageAssign k = m → k ≥ k₀ := by
  use K m + 1
  intro k hk_stage
  simp only [stageAssign] at hk_stage
  split_ifs at hk_stage with hk0
  · -- k = 0, but stage 0 = 0 and m ≥ 1
    omega
  · -- stageAssign k = Nat.find ... = m
    have hk_pos : k ≥ 1 := Nat.one_le_iff_ne_zero.mpr hk0
    have h := Nat.find_spec (stageAssign.exists_stage k hk_pos)
    have heq : Nat.find (stageAssign.exists_stage k hk_pos) = m := hk_stage
    rw [heq] at h
    omega
/-- Exhaustiveness of F_k enumeration -/
lemma exhaustive_prop (m : ℕ) (hm : m ≥ 1) (S : Finset ℕ)
    (hS_range : ∀ x ∈ S, ∃ i, 1 ≤ i ∧ i ≤ simpleH m ∧ enumerateB i = x)
    (hS_card : S.card = m) :
    ∃ k, stageAssign k = m ∧ F k = S := by
  have hS_fin : S.Nonempty ∨ S = ∅ := by
    by_cases h : S.Nonempty
    · left; exact h
    · right; exact Finset.not_nonempty_iff_eq_empty.mp h
  have hinj : Function.Injective enumerateB := by
    have hstrictMono : StrictMono enumerateB := strictMono_nat_of_lt_succ enumerateB_mono
    exact hstrictMono.injective
  have hS_preimage : ∀ x ∈ S, ∃! i, 1 ≤ i ∧ i ≤ simpleH m ∧ enumerateB i = x := by
    intro x hx
    obtain ⟨i, hi_ge, hi_le, hi_eq⟩ := hS_range x hx
    use i
    constructor
    · exact ⟨hi_ge, hi_le, hi_eq⟩
    · intro j ⟨_, _, hj_eq⟩
      have heq' : enumerateB j = enumerateB i := by rw [hi_eq, hj_eq]
      exact hinj heq'
  let indices := S.attach.image (fun ⟨x, hx⟩ =>
    Classical.choose (hS_preimage x hx))
  have hindices_card : indices.card = m := by
    have hinj' : ∀ a ∈ S.attach, ∀ b ∈ S.attach,
        Classical.choose (hS_preimage a.1 a.2) = Classical.choose (hS_preimage b.1 b.2) → a = b := by
      intro ⟨a, ha⟩ _ ⟨b, hb⟩ _ heq
      have ha_spec := Classical.choose_spec (hS_preimage a ha)
      have hb_spec := Classical.choose_spec (hS_preimage b hb)
      have ha_eq : enumerateB (Classical.choose (hS_preimage a ha)) = a := ha_spec.1.2.2
      have hb_eq : enumerateB (Classical.choose (hS_preimage b hb)) = b := hb_spec.1.2.2
      have hab : a = b := by rw [← ha_eq, heq, hb_eq]
      simp only [Subtype.mk.injEq]
      exact hab
    rw [Finset.card_image_of_injOn hinj']
    simp [hS_card]
  have hindices_subset : ∀ i ∈ indices, 1 ≤ i ∧ i ≤ simpleH m := by
    intro i hi
    simp only [indices, Finset.mem_image, Finset.mem_attach, true_and, Subtype.exists] at hi
    obtain ⟨x, hx, rfl⟩ := hi
    exact ⟨(Classical.choose_spec (hS_preimage x hx)).1.1,
           (Classical.choose_spec (hS_preimage x hx)).1.2.1⟩
  have hexh := nthSubsetOfIcc_exhaustive (simpleH m) m indices hindices_card hindices_subset
  obtain ⟨idx, hidx, heq_idx⟩ := hexh
  use K m + idx + 1
  constructor
  · -- stageAssign (K m + idx + 1) = m
    simp only [stageAssign]
    have hk_ne_0 : K m + idx + 1 ≠ 0 := by omega
    simp only [dif_neg hk_ne_0]
    have hK_lt : K m < K m + idx + 1 := by omega
    have hK_le : K m + idx + 1 ≤ K (m + 1) := by
      rw [K_succ _ hm]
      omega
    have hk_ge_1 : K m + idx + 1 ≥ 1 := by omega
    have hfind_le : Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1) ≤ m := by
      apply Nat.find_le
      exact ⟨hK_lt, hK_le⟩
    have hfind_ge : Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1) ≥ m := by
      by_contra hlt
      push_neg at hlt
      have hfind := Nat.find_spec (stageAssign.exists_stage (K m + idx + 1) hk_ge_1)
      have hK_le_m : K (Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1) + 1) ≤ K m := by
        have hmono : ∀ a b, a ≤ b → K a ≤ K b := by
          intro a b hab
          induction hab with
          | refl => exact le_refl _
          | @step n _ ih => exact le_trans ih (K_mono n)
        apply hmono
        omega
      omega
    omega
  · -- F (K m + idx + 1) = S
    simp only [F]
    have hk_ne_0 : K m + idx + 1 ≠ 0 := by omega
    simp only [dif_neg hk_ne_0]
    have hk_ge_1' : K m + idx + 1 ≥ 1 := by omega
    have hstage : stageAssign (K m + idx + 1) = m := by
      simp only [stageAssign, dif_neg hk_ne_0]
      have hK_lt : K m < K m + idx + 1 := by omega
      have hK_le : K m + idx + 1 ≤ K (m + 1) := by rw [K_succ _ hm]; omega
      have hfind_le : Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1') ≤ m := Nat.find_le ⟨hK_lt, hK_le⟩
      have hfind_ge : Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1') ≥ m := by
        by_contra hlt
        push_neg at hlt
        have hfind := Nat.find_spec (stageAssign.exists_stage (K m + idx + 1) hk_ge_1')
        have hK_le_m : K (Nat.find (stageAssign.exists_stage (K m + idx + 1) hk_ge_1') + 1) ≤ K m := by
          have hmono : ∀ a b, a ≤ b → K a ≤ K b := by
            intro a b hab
            induction hab with
            | refl => exact le_refl _
            | @step n _ ih => exact le_trans ih (K_mono n)
          apply hmono
          omega
        omega
      omega
    simp only [hstage]
    have hidx_eq : indexInStage (K m + idx + 1) = idx := by
      simp only [indexInStage, if_neg hk_ne_0, hstage]
      omega
    simp only [hidx_eq]
    rw [heq_idx]
    ext x
    constructor
    · intro hx
      simp only [Finset.mem_image] at hx
      obtain ⟨i, hi, rfl⟩ := hx
      simp only [indices, Finset.mem_image, Finset.mem_attach, true_and, Subtype.exists] at hi
      obtain ⟨y, hy, hi_eq⟩ := hi
      have hy_spec := Classical.choose_spec (hS_preimage y hy)
      rw [← hi_eq]
      have heq : enumerateB (Classical.choose (hS_preimage y hy)) = y := hy_spec.1.2.2
      rw [heq]
      exact hy
    · intro hx
      simp only [Finset.mem_image]
      use Classical.choose (hS_preimage x hx)
      constructor
      · simp only [indices, Finset.mem_image, Finset.mem_attach, true_and, Subtype.exists]
        use x, hx
      · exact (Classical.choose_spec (hS_preimage x hx)).1.2.2
/-- F_k elements are < N_{k-1} -/
lemma F_lt_N_prev_prop (k : ℕ) (hk : k ≥ 2) (x : ℕ) (hx : x ∈ F k) : x < concreteSeq.N (k - 1) := by
  obtain ⟨i, hi_ge, hi_le, hi_eq⟩ := F_subset_prop k (by omega : k ≥ 1) x hx
  rw [← hi_eq]
  have hN1 : concreteSeq.N 1 = 1601 := by simp [NathansonSeq.N, concreteSeq, concreteN]
  have hN_mono : concreteSeq.N 1 ≤ concreteSeq.N (k - 1) := concreteSeq.N_mono_le (by omega)
  have hN_lower : 1601 ≤ concreteSeq.N (k - 1) := by omega
  have hK_lower : ∀ m, K (m + 1) ≥ 2 * m := by
    intro m
    induction m with
    | zero => simp [K]
    | succ m ih =>
      calc K (m + 1 + 1) = K (m + 1) + Nat.choose (2 * (m + 1)) (m + 1) := K_succ (m + 1) (by omega)
        _ ≥ 2 * m + 2 := by
            have hchoose : Nat.choose (2 * (m + 1)) (m + 1) ≥ 2 := by
              have h1 : m + 1 + 1 ≤ 2 * (m + 1) := by omega
              have h2 : Nat.choose (m + 1 + 1) (m + 1) ≤ Nat.choose (2 * (m + 1)) (m + 1) :=
                Nat.choose_le_choose (m + 1) h1
              have h3 : Nat.choose (m + 1 + 1) (m + 1) = m + 2 := by simp [Nat.choose_succ_self_right]
              omega
            omega
        _ = 2 * (m + 1) := by ring
  have hk_ge_1 : k ≥ 1 := by omega
  have hstage_upper : stageAssign k ≤ k / 2 + 1 := by
    have hK_lt : K (stageAssign k) < k := by
      have hk_ne : k ≠ 0 := by omega
      have hspec := Nat.find_spec (stageAssign.exists_stage k hk_ge_1)
      have hstage_eq : stageAssign k = Nat.find (stageAssign.exists_stage k hk_ge_1) := by
        simp only [stageAssign, dif_neg hk_ne]
      rw [hstage_eq]
      exact hspec.1
    by_cases hstage_1 : stageAssign k = 1
    · omega
    · have hstage_ge_2 : stageAssign k ≥ 2 := by
        have hpos := stageAssign_pos k (by omega); omega
      have hK' : K (stageAssign k) ≥ 2 * (stageAssign k - 1) := by
        have heq : stageAssign k = (stageAssign k - 1) + 1 := by omega
        rw [heq]; exact hK_lower (stageAssign k - 1)
      omega
  have hi_upper : i ≤ k + 2 := by
    calc i ≤ simpleH (stageAssign k) := hi_le
      _ = 2 * stageAssign k := rfl
      _ ≤ 2 * (k / 2 + 1) := by omega
      _ ≤ k + 2 := by omega
  by_cases hk_small : k ≤ 396
  · have hi_small : i ≤ 398 := by omega
    have hi_early := enumerateB_early i ⟨hi_ge, hi_small⟩
    rw [hi_early]; omega
  · -- For k > 396, we use exponential growth of N
    push_neg at hk_small
    have hN_exp : concreteSeq.N (k - 1) = 2 * concreteN (k - 1) + 1 := rfl
    have hN_value : concreteN (k - 1) = 100 * 8^(k-1) := rfl
    have hN_lower' : concreteSeq.N (k - 1) ≥ 200 * 8^(k-1) := by
      simp only [NathansonSeq.N, concreteSeq, concreteN]; omega
    have h8_dom : ∀ n ≥ 10, 8^n > 10 * n^3 := by
      intro n hn
      induction n with
      | zero => omega
      | succ m ih =>
        by_cases hm : m < 10
        · -- m < 10 means m + 1 ≤ 10, so m + 1 = 10
          have hm9 : m = 9 := by omega
          subst hm9
          decide
        · have hm10 : m ≥ 10 := by omega
          have ih' := ih hm10
          calc 8^(m+1) = 8 * 8^m := by ring
            _ > 8 * 10 * m^3 := by nlinarith
            _ ≥ 10 * (m+1)^3 := by nlinarith [sq_nonneg m]
    have hk_ge_10 : k ≥ 10 := by omega
    have h8_bound := h8_dom k hk_ge_10
    have hstage_log := stageAssign_log_bound k (by omega)
    have hi_log : i ≤ 2 * Nat.log 2 k + 4 := by
      calc i ≤ simpleH (stageAssign k) := hi_le
        _ = 2 * stageAssign k := rfl
        _ ≤ 2 * (Nat.log 2 k + 2) := by omega
        _ = 2 * Nat.log 2 k + 4 := by ring
    by_cases hk_large : k < 2^197
    · -- For k < 2^197: log_2 k ≤ 196, so i ≤ 396 ≤ 398
      have hlog_bound : Nat.log 2 k ≤ 196 := by
        have hk_ne : k ≠ 0 := by omega
        have hlog_lt : Nat.log 2 k < 197 := Nat.log_lt_of_lt_pow hk_ne hk_large
        omega
      have hi_small : i ≤ 398 := by omega
      have hi_early := enumerateB_early i ⟨hi_ge, hi_small⟩
      rw [hi_early]; omega
    · -- For k ≥ 2^197: N_{k-1} is astronomically large
      push_neg at hk_large
      have hi_le_2k : i ≤ 2 * k := by omega  -- since i ≤ k + 2 and k ≥ 2
      have h64k3 : 64 * k^3 < 8^(k-1) := by
        have hk10 : k ≥ 10 := by omega
        by_cases hk12 : k ≤ 12
        · -- Small cases k ∈ {10, 11, 12}
          interval_cases k <;> decide
        · -- k ≥ 13
          push_neg at hk12
          have hk3_ge_10 : k - 3 ≥ 10 := by omega
          have h8_k3 := h8_dom (k - 3) hk3_ge_10
          have hcube : (k - 3)^3 * 4 ≥ k^3 := by
            by_cases hk30 : k ≤ 30
            · interval_cases k <;> decide
            · push_neg at hk30
              have h1 : 10 * (k - 3) ≥ 9 * k := by omega
              have h2 : (10 * (k - 3))^3 ≥ (9 * k)^3 := by
                have hpow : ∀ a b : ℕ, a ≥ b → a^3 ≥ b^3 := by
                  intro a b hab
                  have h1' : a^2 ≥ b^2 := by nlinarith [sq_nonneg (a - b)]
                  nlinarith [sq_nonneg a, sq_nonneg b, sq_nonneg (a - b)]
                exact hpow _ _ h1
              have h3 : (10 * (k - 3))^3 = 1000 * (k - 3)^3 := by ring
              have h4 : (9 * k)^3 = 729 * k^3 := by ring
              have h5 : 1000 * (k - 3)^3 ≥ 729 * k^3 := by rw [← h3, ← h4]; exact h2
              have h6 : 4 * (1000 * (k - 3)^3) ≥ 4 * (729 * k^3) := by omega
              have h7 : 4000 * (k - 3)^3 ≥ 2916 * k^3 := by linarith [h6]
              have h8 : 2916 * k^3 ≥ 1000 * k^3 := by nlinarith [sq_nonneg k]
              have h9 : 4000 * (k - 3)^3 ≥ 1000 * k^3 := by linarith
              have h10 : 4 * (k - 3)^3 * 1000 ≥ k^3 * 1000 := by linarith
              omega
          have h_factor : 10 * (k - 3)^3 > k^3 := by
            by_cases hk30 : k ≤ 30
            · interval_cases k <;> decide
            · push_neg at hk30
              have h1 : 10 * (k - 3) ≥ 9 * k := by omega
              have h2 : (10 * (k - 3))^3 ≥ (9 * k)^3 := by
                have hpow : ∀ a b : ℕ, a ≥ b → a^3 ≥ b^3 := by
                  intro a b hab
                  have h1' : a^2 ≥ b^2 := by nlinarith [sq_nonneg (a - b)]
                  nlinarith [sq_nonneg a, sq_nonneg b, sq_nonneg (a - b)]
                exact hpow _ _ h1
              have h3 : (10 * (k - 3))^3 = 1000 * (k - 3)^3 := by ring
              have h4 : (9 * k)^3 = 729 * k^3 := by ring
              have h5 : 1000 * (k - 3)^3 ≥ 729 * k^3 := by rw [← h3, ← h4]; exact h2
              have h6 : 10 * (k - 3)^3 * 100 ≥ 729 * k^3 := by linarith
              have h7 : 729 * k^3 > 100 * k^3 := by
                have hpos' : k^3 > 0 := by positivity
                nlinarith
              have h8 : 10 * (k - 3)^3 * 100 > 100 * k^3 := by linarith
              omega
          have h_final : 8^(k - 3) > k^3 := by omega
          have heq : 8^(k-1) = 8^(k-3) * 64 := by
            have : k - 1 = k - 3 + 2 := by omega
            rw [this, pow_add]; ring
          omega
      have hN_vs_k3 : 12800 * k^3 < concreteSeq.N (k - 1) := by
        calc 12800 * k^3 = 200 * 64 * k^3 := by ring
          _ < 200 * 8^(k-1) := by nlinarith [h64k3]
          _ ≤ concreteSeq.N (k - 1) := hN_lower'
      have henumB_bound : enumerateB i ≤ 12800 * k^3 := by
        have hpoly := enumerateB_poly_bound i hi_ge
        have hi_cube : i^3 ≤ (2 * k)^3 := by
          have hle : i ≤ 2 * k := hi_le_2k
          have h1 : i^2 ≤ (2*k)^2 := by nlinarith [sq_nonneg (2*k - i)]
          nlinarith [sq_nonneg i, sq_nonneg k, sq_nonneg (2*k - i), h1]
        calc enumerateB i ≤ 1600 * i^3 := hpoly
          _ ≤ 1600 * (2 * k)^3 := by nlinarith [hi_cube]
          _ = 12800 * k^3 := by ring
      omega
/-- The concrete GrowingConstruction instance -/
noncomputable def concreteGC : GrowingConstruction where
  seq := concreteSeq
  a := enumerateB
  H := simpleH
  F := F
  stage := stageAssign
  a_in_B := fun i hi => enumerateB_in_B i hi
  a_mono := enumerateB_mono
  a_covers := fun x hx => enumerateB_covers x hx
  H_mono := simpleH_mono
  H_unbounded := simpleH_unbounded
  F_card := F_card_prop
  F_subset := F_subset_prop
  stage_pos := stageAssign_pos
  stage_unbounded := stageAssign_unbounded
  exhaustive := exhaustive_prop
  F_lt_N_prev := F_lt_N_prev_prop
  k_grows_with_stage := k_grows_with_stage_prop
  stage_le_k := stage_le_k_prop
  stage_zero := stageAssign_zero
  H_linear := simpleH_linear
/-- The existence theorem for GrowingConstruction, proved without axioms.
    This replaces the axiom `GrowingConstruction_exists` in Basic.lean. -/
theorem GrowingConstruction_exists' : Nonempty GrowingConstruction := ⟨concreteGC⟩
/-- Main theorem: Erdős Problem 871 has a negative answer.
    This is the axiom-free version using the concrete construction. -/
theorem erdos_871 :
    ∃ (A : Set ℕ),
      (∀ᶠ n in Filter.atTop, ∃ a ∈ A, ∃ b ∈ A, a + b = n) ∧
      (∀ t, ∀ᶠ n in Filter.atTop, ∃ pairs : Finset (ℕ × ℕ),
        pairs.card ≥ t ∧ ∀ p ∈ pairs, p.1 ∈ A ∧ p.2 ∈ A ∧ p.1 + p.2 = n ∧ p.1 ≤ p.2) ∧
      ¬∃ (B C : Set ℕ),
        (∀ x, x ∈ A ↔ x ∈ B ∨ x ∈ C) ∧
        Disjoint B C ∧
        (∀ᶠ n in Filter.atTop, ∃ a ∈ B, ∃ b ∈ B, a + b = n) ∧
        (∀ᶠ n in Filter.atTop, ∃ a ∈ C, ∃ b ∈ C, a + b = n) := by
  obtain ⟨gc⟩ := GrowingConstruction_exists'
  use {x | gc.inA x}
  refine ⟨?basis, ?rep_unbounded, ?non_decomp⟩
  case basis =>
    rw [Filter.Eventually, Filter.mem_atTop_sets]
    let M := gc.seq.N 2 + 1
    use M
    have hM : ∀ n ≥ M, (∀ k, n ≠ gc.seq.N k) →
        ∃ j ≥ 3, 1 ≤ NathansonSeq.countReps (gc.seq.B_k j ∪ gc.seq.B_k (j - 1) ∪ gc.seq.B_k (j - 2)) n := by
      intro n hn hne
      have hbound : ∃ k, n < gc.seq.N k := gc.seq.N_unbounded n
      let j := Nat.find hbound
      have hj_spec : n < gc.seq.N j := Nat.find_spec hbound
      have hj_min : ∀ i < j, ¬(n < gc.seq.N i) := fun i hi => Nat.find_min hbound hi
      have hj_gt2 : j > 2 := by
        by_contra hle
        push_neg at hle
        have hN_le : gc.seq.N j ≤ gc.seq.N 2 := gc.seq.N_mono_le hle
        omega
      have hj_ge3 : j ≥ 3 := by omega
      have hN_jm1_le : gc.seq.N (j - 1) ≤ n := by
        have hlt : j - 1 < j := Nat.sub_lt (by omega) Nat.one_pos
        exact Nat.not_lt.mp (hj_min (j - 1) hlt)
      have hn_ne_jm1 : n ≠ gc.seq.N (j - 1) := hne (j - 1)
      have hlo : gc.seq.N (j - 1) + 1 ≤ n := by omega
      have hn_ne_j : n ≠ gc.seq.N j := hne j
      have hhi : n ≤ gc.seq.N j - 1 := by omega
      use j
      constructor
      · exact hj_ge3
      · have hreps := gc.seq.lemma3_part2 j hj_ge3 n hlo hhi
        omega
    intro n hn
    by_cases h : ∃ k ≥ 2, n = gc.seq.N k
    · obtain ⟨k, hk, heq⟩ := h
      have hk1 : k ≥ 1 := by omega
      have hstage := gc.stage_pos k hk1
      have hcard : (gc.F k).card ≥ 1 := by rw [gc.F_card k hk1]; exact hstage
      have hF_nonempty : (gc.F k).Nonempty := Finset.card_pos.mp hcard
      obtain ⟨f, hf⟩ := hF_nonempty
      let g := gc.seq.N k - f
      have hg : g ∈ gc.G k := by rw [gc.G_mem]; exact ⟨f, hf, rfl⟩
      have hf_B : gc.seq.inB f := by
        obtain ⟨i, hi_lo, _, hai⟩ := gc.F_subset k hk1 f hf
        rw [← hai]
        exact gc.a_in_B i hi_lo
      have hf_A : gc.inA f := Or.inl hf_B
      have hg_A : gc.inA g := Or.inr ⟨k, hk, hg⟩
      have hf_lt : f < gc.seq.N k := gc.F_lt_N k hk f hf
      have hsum : f + g = gc.seq.N k := Nat.add_sub_cancel' (le_of_lt hf_lt)
      use f
      simp only [Set.mem_setOf_eq]
      constructor
      · exact hf_A
      · use g; constructor; exact hg_A; rw [hsum, ← heq]
    · push_neg at h
      have hne : ∀ k, n ≠ gc.seq.N k := by
        intro k
        by_cases hk2 : k ≥ 2
        · exact h k hk2
        · intro heq
          have hNk_le_N2 : gc.seq.N k ≤ gc.seq.N 2 := gc.seq.N_mono_le (by omega)
          rw [heq] at hn
          omega
      obtain ⟨j, hj, hcount⟩ := hM n hn hne
      unfold NathansonSeq.countReps at hcount
      have hS_nonempty := Finset.card_pos.mp hcount
      obtain ⟨⟨a, b⟩, hab⟩ := hS_nonempty
      rw [Finset.mem_filter] at hab
      obtain ⟨hab_prod, hab_le, hab_sum, ha_in, hb_in⟩ := hab
      rw [Finset.mem_union, Finset.mem_union] at ha_in hb_in
      have hj1 : j ≥ 1 := by omega
      have ha_B : gc.seq.inB a := by
        rcases ha_in with (ha_j | ha_jm1) | ha_jm2
        · exact ⟨j, hj1, ha_j⟩
        · have hjm1 : j - 1 ≥ 1 := by omega
          exact ⟨j - 1, hjm1, ha_jm1⟩
        · have hjm2 : j - 2 ≥ 1 := by omega
          exact ⟨j - 2, hjm2, ha_jm2⟩
      have hb_B : gc.seq.inB b := by
        rcases hb_in with (hb_j | hb_jm1) | hb_jm2
        · exact ⟨j, hj1, hb_j⟩
        · have hjm1 : j - 1 ≥ 1 := by omega
          exact ⟨j - 1, hjm1, hb_jm1⟩
        · have hjm2 : j - 2 ≥ 1 := by omega
          exact ⟨j - 2, hjm2, hb_jm2⟩
      have ha_A : gc.inA a := Or.inl ha_B
      have hb_A : gc.inA b := Or.inl hb_B
      refine ⟨a, ?_, b, ?_, hab_sum⟩
      · simp only [Set.mem_setOf_eq]; exact ha_A
      · simp only [Set.mem_setOf_eq]; exact hb_A
  case rep_unbounded =>
    intro t
    rw [Filter.Eventually, Filter.mem_atTop_sets]
    obtain ⟨M₁, hM₁⟩ := gc.seq.lemma4_part2 t
    obtain ⟨k₀', hk₀'⟩ := gc.stage_unbounded t
    let k₀ := max 2 k₀'
    have hk₀ : ∀ k ≥ k₀, gc.stage k > t := by
      intro k hk
      have hk_ge_k₀' : k ≥ k₀' := Nat.le_trans (le_max_right 2 k₀') hk
      exact hk₀' k hk_ge_k₀'
    have hk₀_ge_2 : k₀ ≥ 2 := le_max_left 2 k₀'
    let M := max M₁ (gc.seq.N k₀)
    use M
    intro n hn
    by_cases h : ∃ k ≥ 2, n = gc.seq.N k
    · obtain ⟨k, hk_ge, heq⟩ := h
      have hk_ge_k₀ : k ≥ k₀ := by
        by_contra hlt
        push_neg at hlt
        have hN_lt : gc.seq.N k < gc.seq.N k₀ := gc.seq.N_strict_mono_lt hlt
        have hM_ge : M ≥ gc.seq.N k₀ := le_max_right M₁ (gc.seq.N k₀)
        omega
      have hstage_gt : gc.stage k > t := hk₀ k hk_ge_k₀
      have hstage_ge : gc.stage k ≥ t := by omega
      let pairs := (gc.F k).image (fun f => if f ≤ gc.seq.N k - f then (f, gc.seq.N k - f)
                                            else (gc.seq.N k - f, f))
      use pairs
      constructor
      · have hinj : (gc.F k).card ≤ pairs.card ∨ pairs.card = (gc.F k).card := by
          right
          rw [Finset.card_image_of_injOn]
          intro f₁ hf₁ f₂ hf₂ heq'
          simp only at heq'
          by_cases h1 : f₁ ≤ gc.seq.N k - f₁ <;> by_cases h2 : f₂ ≤ gc.seq.N k - f₂ <;>
            simp only [h1, h2, ↓reduceIte, Prod.mk.injEq] at heq'
          · exact heq'.1
          · have hsum : f₁ + f₂ = gc.seq.N k := by omega
            have hf1_lt := gc.F_lt_N_prev k hk_ge f₁ hf₁
            have hf2_lt := gc.F_lt_N_prev k hk_ge f₂ hf₂
            have hgap : 2 * gc.seq.N (k - 1) < gc.seq.N k := by
              simp only [NathansonSeq.N]
              have hexp := gc.seq.exponential_growth k (by omega : k ≥ 1)
              have hn_pos := gc.seq.n_pos (k - 1)
              omega
            omega
          · have hsum : f₁ + f₂ = gc.seq.N k := by omega
            have hf1_lt := gc.F_lt_N_prev k hk_ge f₁ hf₁
            have hf2_lt := gc.F_lt_N_prev k hk_ge f₂ hf₂
            have hgap : 2 * gc.seq.N (k - 1) < gc.seq.N k := by
              simp only [NathansonSeq.N]
              have hexp := gc.seq.exponential_growth k (by omega : k ≥ 1)
              have hn_pos := gc.seq.n_pos (k - 1)
              omega
            omega
          · exact heq'.2
        rw [gc.F_card k (by omega : k ≥ 1)] at hinj
        rcases hinj with hle | heq_card <;> omega
      · intro p hp
        simp only [pairs, Finset.mem_image] at hp
        obtain ⟨f, hf, rfl⟩ := hp
        have hf_lt : f < gc.seq.N k := gc.F_lt_N k hk_ge f hf
        have hg_in_G : gc.seq.N k - f ∈ gc.G k := by rw [gc.G_mem]; exact ⟨f, hf, rfl⟩
        obtain ⟨i, hi_lo, _, hai⟩ := gc.F_subset k (by omega : k ≥ 1) f hf
        have hf_B : gc.seq.inB f := by rw [← hai]; exact gc.a_in_B i hi_lo
        have hf_A : gc.inA f := Or.inl hf_B
        have hg_A : gc.inA (gc.seq.N k - f) := Or.inr ⟨k, hk_ge, hg_in_G⟩
        split_ifs with hle
        · simp only [Set.mem_setOf_eq]
          refine ⟨hf_A, hg_A, ?_, hle⟩
          rw [heq]
          exact Nat.add_sub_cancel' (le_of_lt hf_lt)
        · simp only [Set.mem_setOf_eq]
          have hsum' : gc.seq.N k - f + f = gc.seq.N k := Nat.sub_add_cancel (le_of_lt hf_lt)
          refine ⟨hg_A, hf_A, ?_, ?_⟩
          · rw [heq, hsum']
          · omega
    · push_neg at h
      have hne : ∀ k, n ≠ gc.seq.N k := by
        intro k
        by_cases hk2 : k ≥ 2
        · exact h k hk2
        · push_neg at hk2
          intro heq'
          have hNk_lt_Nk0 : gc.seq.N k < gc.seq.N k₀ := by
            have hk_lt_k0 : k < k₀ := by omega
            exact gc.seq.N_strict_mono_lt hk_lt_k0
          have hM_ge : M ≥ gc.seq.N k₀ := le_max_right M₁ (gc.seq.N k₀)
          rw [heq'] at hn
          omega
      have hn_ge_M1 : n ≥ M₁ := Nat.le_trans (le_max_left M₁ _) hn
      obtain ⟨j, hj_ge, hcount⟩ := hM₁ n hn_ge_M1 hne
      unfold NathansonSeq.countReps at hcount
      have hcard_ge := hcount
      let pairSet := Finset.filter (fun p : ℕ × ℕ =>
          p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧
          p.1 ∈ gc.seq.B_k j ∪ gc.seq.B_k (j - 1) ∪ gc.seq.B_k (j - 2) ∧
          p.2 ∈ gc.seq.B_k j ∪ gc.seq.B_k (j - 1) ∪ gc.seq.B_k (j - 2))
        (Finset.product (gc.seq.B_k j ∪ gc.seq.B_k (j - 1) ∪ gc.seq.B_k (j - 2))
                        (gc.seq.B_k j ∪ gc.seq.B_k (j - 1) ∪ gc.seq.B_k (j - 2)))
      obtain ⟨pairs, hpairs_sub, hpairs_card⟩ := Finset.exists_subset_card_eq hcard_ge
      use pairs
      constructor
      · exact le_of_eq hpairs_card.symm
      · intro p hp
        have hp' := hpairs_sub hp
        rw [Finset.mem_filter] at hp'
        obtain ⟨_, hle, hsum, ha_in, hb_in⟩ := hp'
        have hj1 : j ≥ 1 := by omega
        rw [Finset.mem_union, Finset.mem_union] at ha_in hb_in
        have ha_B : gc.seq.inB p.1 := by
          rcases ha_in with (ha_j | ha_jm1) | ha_jm2
          · exact ⟨j, hj1, ha_j⟩
          · have hjm1 : j - 1 ≥ 1 := by omega
            exact ⟨j - 1, hjm1, ha_jm1⟩
          · have hjm2 : j - 2 ≥ 1 := by omega
            exact ⟨j - 2, hjm2, ha_jm2⟩
        have hb_B : gc.seq.inB p.2 := by
          rcases hb_in with (hb_j | hb_jm1) | hb_jm2
          · exact ⟨j, hj1, hb_j⟩
          · have hjm1 : j - 1 ≥ 1 := by omega
            exact ⟨j - 1, hjm1, hb_jm1⟩
          · have hjm2 : j - 2 ≥ 1 := by omega
            exact ⟨j - 2, hjm2, hb_jm2⟩
        have ha_A : gc.inA p.1 := Or.inl ha_B
        have hb_A : gc.inA p.2 := Or.inl hb_B
        simp only [Set.mem_setOf_eq]
        exact ⟨ha_A, hb_A, hsum, hle⟩
  case non_decomp =>
    exact gc.non_decomposable


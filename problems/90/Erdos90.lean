theorem cubic_subfield_prime_ramification_data (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField в„ҡ (CyclotomicField r в„ҡ))
    [IsGalois в„ҡ L] [IsTotallyReal L]
    (hcubic : Module.finrank в„ҡ L = 3) :
    вҲғ P : Ideal (рқ“һ L),
      P вҲҲ (Ideal.span {(r : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L) вҲ§
      ((Ideal.span {(r : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L)).ncard = 1 вҲ§
      Ideal.ramificationIdx (Ideal.span {(r : в„Ө)} : Ideal в„Ө) P = 3 вҲ§
      Ideal.inertiaDeg (Ideal.span {(r : в„Ө)} : Ideal в„Ө) P = 1 вҲ§
      (вҲҖ q : в„•, q.Prime вҶ’ q вү  r вҶ’
        вҲҖ Q вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L),
          Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) Q = 1) := by
  letI : Fact r.Prime := вҹЁhrвҹ©
  let p : Ideal в„Ө := Ideal.span {(r : в„Ө)}
  let E := CyclotomicField r в„ҡ
  letI : IsCyclotomicExtension {r} в„ҡ E :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := r) (K := в„ҡ)
  haveI : IsGalois в„ҡ E := IsCyclotomicExtension.isGalois {r} в„ҡ E
  have hp0 : p вү  вҠҘ := by
    simp [p, hr.ne_zero]
  have hEcard : (p.primesOver (рқ“һ E)).ncard = 1 := by
    simpa [p, E] using (IsCyclotomicExtension.Rat.ncard_primesOver_of_prime (p := r)
      (K := E))
  have hEinertia : p.inertiaDegIn (рқ“һ E) = 1 := by
    simpa [p, E] using (IsCyclotomicExtension.Rat.inertiaDegIn_eq_of_prime (p := r)
      (K := E))
  obtain вҹЁвҹЁP, hPprime, hPoverвҹ©вҹ© := (show Nonempty (p.primesOver (рқ“һ L)) from Ideal.nonempty_primesOver p)
  letI : P.IsMaximal := hPprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hp0 P)
  have hcount := Ideal.ncard_primesOver_mul_ncard_primesOver (P := P) (p := p) (G := Gal(L/в„ҡ))
    (C := рқ“һ E) (GAC := Gal(E/в„ҡ)) (GBC := Gal(E/L)) hp0
  have hLcard : (p.primesOver (рқ“һ L)).ncard = 1 := by
    rw [hEcard] at hcount
    exact Nat.eq_one_of_mul_eq_one_right hcount
  have hcardL : Nat.card Gal(L/в„ҡ) = 3 := by
    rw [IsGalois.card_aut_eq_finrank (F := в„ҡ) (E := L), hcubic]
  have hfund := Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn (p := p)
    (B := рқ“һ L) hp0 Gal(L/в„ҡ)
  have hprod : p.ramificationIdxIn (рқ“һ L) * p.inertiaDegIn (рқ“һ L) = 3 := by
    rw [hLcard, one_mul, hcardL] at hfund
    exact hfund
  have hmulIn := Ideal.inertiaDegIn_mul_inertiaDegIn (p := p) (P := P) (G := Gal(L/в„ҡ))
    (C := рқ“һ E) (GAC := Gal(E/в„ҡ)) (GBC := Gal(E/L))
  have hInertiaL : p.inertiaDegIn (рқ“һ L) = 1 := by
    rw [hEinertia] at hmulIn
    exact Nat.eq_one_of_mul_eq_one_right hmulIn
  have hRamL : p.ramificationIdxIn (рқ“һ L) = 3 := by
    rw [hInertiaL, mul_one] at hprod
    exact hprod
  have hP_ram : Ideal.ramificationIdx p P = 3 := by
    rw [вҶҗ Ideal.ramificationIdxIn_eq_ramificationIdx (p := p) (P := P) Gal(L/в„ҡ), hRamL]
  have hP_inertia : Ideal.inertiaDeg p P = 1 := by
    rw [вҶҗ Ideal.inertiaDegIn_eq_inertiaDeg (p := p) (P := P) Gal(L/в„ҡ), hInertiaL]
  refine вҹЁP, ?_, hLcard, hP_ram, hP_inertia, ?_вҹ©
  В· exact вҹЁhPprime, hPoverвҹ©
  В· intro q hq hqr Q hQ
    let pq : Ideal в„Ө := Ideal.span {(q : в„Ө)}
    have hpq0 : pq вү  вҠҘ := by
      simp [pq, hq.ne_zero]
    have hqnr : В¬ q вҲЈ r := by
      intro hdiv
      exact hqr ((Nat.prime_dvd_prime_iff_eq hq hr).mp hdiv)
    have hQprime : Q.IsPrime := hQ.1
    have hQover : Q.LiesOver pq := hQ.2
    letI : Q.IsPrime := hQprime
    letI : Q.IsMaximal := hQprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hpq0 Q)
    obtain вҹЁвҹЁQ', hQ'prime, hQ'overQвҹ©вҹ© :=
      (show Nonempty (Q.primesOver (рқ“һ E)) from Ideal.nonempty_primesOver Q)
    have hQ'overpq : Q'.LiesOver pq := Ideal.LiesOver.trans (рқ”“ := Q') (P := Q) (p := pq)
    letI : Q'.IsPrime := hQ'prime
    letI : Q'.LiesOver pq := hQ'overpq
    have hQ'ram : Ideal.ramificationIdx pq Q' = 1 := by
      letI : Fact q.Prime := вҹЁhqвҹ©
      simpa [pq, E] using
        (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_not_dvd (p := q) (m := r)
          (K := E) (P := Q') hqnr)
    have hmapQ : Ideal.map (algebraMap (рқ“һ L) (рқ“һ E)) Q вү  вҠҘ := by
      exact Ideal.map_ne_bot_of_ne_bot (Ideal.ne_bot_of_liesOver_of_ne_bot hpq0 Q)
    have hmappq : Ideal.map (algebraMap в„Ө (рқ“һ E)) pq вү  вҠҘ := by
      exact Ideal.map_ne_bot_of_ne_bot hpq0
    have hle : Ideal.map (algebraMap (рқ“һ L) (рқ“һ E)) Q вүӨ Q' := by
      exact Q'.over_def Q в–ё Ideal.map_comap_le
    have htower := Ideal.ramificationIdx_algebra_tower (p := pq) (P := Q) (Q := Q') hmapQ hmappq hle
    rw [hQ'ram] at htower
    exact Nat.eq_one_of_mul_eq_one_right htower.symm

theorem cyclotomicField_prime_discr_natAbs (r : в„•) (hr : r.Prime) (hodd : r вү  2) :
    (NumberField.discr (CyclotomicField r в„ҡ)).natAbs = r ^ (r - 2) := by
  classical
  letI : Fact r.Prime := вҹЁhrвҹ©
  letI : NeZero (r : в„ҡ) := вҹЁby
    exact_mod_cast hr.ne_zeroвҹ©
  letI : IsCyclotomicExtension {r} в„ҡ (CyclotomicField r в„ҡ) :=
    CyclotomicField.isCyclotomicExtension (n := r) (K := в„ҡ)
  rw [IsCyclotomicExtension.Rat.discr_prime (p := r) (K := CyclotomicField r в„ҡ)]
  rw [Int.natAbs_mul, Int.natAbs_pow, Int.natAbs_neg, Int.natAbs_one, one_pow, one_mul]
  simp

theorem differentIdeal_cubic_subfield_eq_prime_sq (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField в„ҡ (CyclotomicField r в„ҡ))
    [IsGalois в„ҡ L] [IsTotallyReal L]
    (hcubic : Module.finrank в„ҡ L = 3) :
    вҲғ P : Ideal (рқ“һ L),
      P вҲҲ (Ideal.span {(r : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L) вҲ§
      differentIdeal в„Ө (рқ“һ L) = P ^ 2 := by
  classical
  let p : Ideal в„Ө := Ideal.span {(r : в„Ө)}
  letI : Fact r.Prime := вҹЁhrвҹ©
  letI : NeZero r := вҹЁhr.ne_zeroвҹ©
  letI : NeZero (r : в„ҡ) := вҹЁby exact_mod_cast hr.ne_zeroвҹ©
  letI : IsCyclotomicExtension {r} в„ҡ (CyclotomicField r в„ҡ) :=
    CyclotomicField.isCyclotomicExtension (n := r) (K := в„ҡ)
  have hr0 : (r : в„Ө) вү  0 := by
    exact_mod_cast hr.ne_zero
  have hp0 : p вү  вҠҘ := by
    simpa [p, Ideal.span_singleton_eq_bot] using hr0
  letI : p.IsMaximal := by
    simpa [p] using (Int.ideal_span_isMaximal_of_prime r)
  rcases cubic_subfield_prime_ramification_data r hr hr3 L hcubic with
    вҹЁP, hPover, hunique, hram, hinert, hunramвҹ©
  letI : P.LiesOver p := hPover.2
  have hPmax : P.IsMaximal := Ideal.isMaximal_of_mem_primesOver (p := p) hPover
  have hPprime : P.IsPrime := Ideal.IsMaximal.isPrime hPmax
  have hPne : P вү  вҠҘ := Ideal.ne_bot_of_mem_primesOver hp0 hPover
  letI : P.IsPrime := hPprime
  have hP2div : P ^ 2 вҲЈ differentIdeal в„Ө (рқ“һ L) := by
    have hP3 : P ^ 3 вҲЈ Ideal.map (algebraMap в„Ө (рқ“һ L)) p := by
      rw [Ideal.dvd_iff_le]
      simpa [p, hram] using
        (show Ideal.map (algebraMap в„Ө (рқ“һ L)) p вүӨ P ^ (Ideal.ramificationIdx p P) from
          Ideal.le_pow_ramificationIdx)
    simpa [p] using (pow_sub_one_dvd_differentIdeal в„Ө P 3 hp0 hP3)
  have hsetP : p.primesOver (рқ“һ L) = {P} := by
    rcases Set.ncard_eq_one.mp hunique with вҹЁP0, hP0вҹ©
    have hPP0 : P = P0 := by
      simpa [hP0] using hPover
    have hP0P : P0 = P := hPP0.symm
    simpa [hP0P] using hP0
  have hsetP' : (Ideal.span {(r : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L) = {P} := by
    simpa [p] using hsetP
  have hDne : differentIdeal в„Ө (рқ“һ L) вү  вҠҘ := differentIdeal_ne_bot (A := в„Ө) (B := рқ“һ L)
  have hfactor_eq_P : вҲҖ {M : Ideal (рқ“һ L)}, M вҲҲ UniqueFactorizationMonoid.normalizedFactors (differentIdeal в„Ө (рқ“һ L)) вҶ’ M = P := by
    intro M hM
    have hMprime : M.IsPrime := (Ideal.mem_normalizedFactors_iff (I := differentIdeal в„Ө (рқ“һ L)) hDne).mp hM |>.1
    have hDleM : differentIdeal в„Ө (рқ“һ L) вүӨ M :=
      (Ideal.mem_normalizedFactors_iff (I := differentIdeal в„Ө (рқ“һ L)) hDne).mp hM |>.2
    letI : M.IsPrime := hMprime
    have hMne : M вү  вҠҘ := by
      intro hMb
      have hDbot : differentIdeal в„Ө (рқ“һ L) вүӨ вҠҘ := by
        simpa [hMb] using hDleM
      exact hDne (le_bot_iff.mp hDbot)
    letI : NeZero M := вҹЁhMneвҹ©
    let q : в„• := Ideal.absNorm (Ideal.under в„Ө M)
    have hqprime : q.Prime := by
      simpa [q] using (Nat.absNorm_under_prime M)
    have hunder : Ideal.under в„Ө M = Ideal.span {(q : в„Ө)} := by
      simp [q]
    have hMliesq : M.LiesOver (Ideal.span {(q : в„Ө)} : Ideal в„Ө) := by
      simpa [hunder] using (Ideal.over_under (A := в„Ө) (P := M))
    have hMmemq : M вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L) := вҹЁhMprime, hMliesqвҹ©
    by_cases hqr : q = r
    В· have hMmemr : M вҲҲ (Ideal.span {(r : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ L) := by
        simpa [hqr] using hMmemq
      rw [hsetP'] at hMmemr
      simpa using hMmemr
    В· exfalso
      have hram1 : Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) M = 1 :=
        hunram q hqprime hqr M hMmemq
      have hram1' : Ideal.ramificationIdx (Ideal.under в„Ө M) M = 1 := by
        simpa [hunder] using hram1
      have hMunram : Algebra.IsUnramifiedAt в„Ө M := by
        exact (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := в„Ө) (S := рқ“һ L) (p := M) hMne).2 hram1'
      have hMvd : M вҲЈ differentIdeal в„Ө (рқ“һ L) := by
        exact Ideal.dvd_iff_le.mpr hDleM
      exact ((dvd_differentIdeal_iff (A := в„Ө) (B := рқ“һ L) (P := M)).1 hMvd) hMunram
  rcases UniqueFactorizationMonoid.exists_associated_prime_pow_of_unique_normalized_factor
      (p := P) (r := differentIdeal в„Ө (рқ“һ L))
      (h := by
        intro m hm
        exact hfactor_eq_P hm) hDne with вҹЁn, hnassocвҹ©
  have hDpow : differentIdeal в„Ө (рқ“һ L) = P ^ n := by
    simpa [eq_comm] using (associated_iff_eq.mp hnassoc)
  have htwo_le_n : 2 вүӨ n := by
    rw [hDpow] at hP2div
    exact (pow_dvd_pow_iff hPne (by
      rw [Ideal.isUnit_iff]
      exact hPmax.ne_top)).mp hP2div
  have hPinert : Ideal.inertiaDeg p P = 1 := by
    simpa [p] using hinert
  have hAbsNormP0 := Ideal.absNorm_eq_pow_inertiaDeg' P hr
  have hAbsNormP : Ideal.absNorm P = r := by
    rw [hPinert, pow_one] at hAbsNormP0
    exact hAbsNormP0
  obtain вҹЁвҹЁQ, hQprime, hQoverPвҹ©вҹ© := Ideal.nonempty_primesOver (S := рқ“һ (CyclotomicField r в„ҡ)) P
  letI : Q.IsPrime := hQprime
  letI : Q.LiesOver P := hQoverP
  letI : Q.LiesOver p := Ideal.LiesOver.trans Q P p
  let m : в„• := (r - 1) / 3
  have hQe_total : Ideal.ramificationIdx p Q = r - 1 := by
    simpa [p] using
      (IsCyclotomicExtension.Rat.ramificationIdx_eq_of_prime (p := r) (K := CyclotomicField r в„ҡ)
        (P := Q))
  have hQf_total : Ideal.inertiaDeg p Q = 1 := by
    simpa [p] using
      (IsCyclotomicExtension.Rat.inertiaDeg_eq_of_prime (p := r) (K := CyclotomicField r в„ҡ)
        (P := Q))
  have hPmap_ne : Ideal.map (algebraMap (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ))) P вү  вҠҘ := by
    exact (Ideal.map_eq_bot_iff_of_injective
      (FaithfulSMul.algebraMap_injective (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ)))).not.mpr hPne
  have hpmapE_ne : Ideal.map (algebraMap в„Ө (рқ“һ (CyclotomicField r в„ҡ))) p вү  вҠҘ := by
    exact (Ideal.map_eq_bot_iff_of_injective
      (FaithfulSMul.algebraMap_injective в„Ө (рқ“һ (CyclotomicField r в„ҡ)))).not.mpr hp0
  have hmapPQ : Ideal.map (algebraMap (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ))) P вүӨ Q := by
    exact Ideal.map_le_iff_le_comap.mpr Ideal.LiesOver.over.le
  have hQe_tower :=
    Ideal.ramificationIdx_algebra_tower (p := p) (P := P) (Q := Q) hPmap_ne hpmapE_ne hmapPQ
  have hQe_rel : Ideal.ramificationIdx P Q = m := by
    dsimp [m]
    rw [hQe_total, hram] at hQe_tower
    omega
  have hQf_tower := Ideal.inertiaDeg_algebra_tower p P Q
  have hQf_rel : Ideal.inertiaDeg P Q = 1 := by
    rw [hQf_total, hinert] at hQf_tower
    omega
  have hAbsNormQ0 := Ideal.absNorm_eq_pow_inertiaDeg_of_liesOver Q P hPprime hPne
  have hAbsNormQ : Ideal.absNorm Q = r := by
    rw [hAbsNormP, hQf_rel, pow_one] at hAbsNormQ0
    exact hAbsNormQ0
  let Drel : Ideal (рқ“һ (CyclotomicField r в„ҡ)) := differentIdeal (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ))
  have hQpow : Q ^ m вҲЈ Ideal.map (algebraMap (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ))) P := by
    rw [Ideal.dvd_iff_le]
    simpa [hQe_rel] using
      (show Ideal.map (algebraMap (рқ“һ L) (рқ“һ (CyclotomicField r в„ҡ))) P вүӨ Q ^ (Ideal.ramificationIdx P Q) from
        Ideal.le_pow_ramificationIdx)
  have hQdivDrel : Q ^ (m - 1) вҲЈ Drel := by
    simpa [Drel, m] using
      (pow_sub_one_dvd_differentIdeal (A := рқ“һ L) (B := рқ“һ (CyclotomicField r в„ҡ)) (p := P) Q
        m hPne hQpow)
  have hDrel_norm_dvd : r ^ (m - 1) вҲЈ Ideal.absNorm Drel := by
    have h := map_dvd Ideal.absNorm hQdivDrel
    simpa [Drel, hAbsNormQ] using h
  have hdiscrL_natAbs : (NumberField.discr L).natAbs = r ^ n := by
    rw [вҶҗ NumberField.absNorm_differentIdeal (K := L) (рқ’Ә := рқ“һ L), hDpow]
    simp [hAbsNormP]
  have hirr : Irreducible (Polynomial.cyclotomic r в„ҡ) :=
    Polynomial.cyclotomic.irreducible_rat (Nat.pos_of_ne_zero hr.ne_zero)
  have hfinrankE : Module.finrank в„ҡ (CyclotomicField r в„ҡ) = r - 1 := by
    simpa [Nat.totient_prime hr] using
      (IsCyclotomicExtension.finrank (n := r) (K := в„ҡ) (L := CyclotomicField r в„ҡ) hirr)
  have hfinrankLE : Module.finrank L (CyclotomicField r в„ҡ) = m := by
    dsimp [m]
    have hmul := Module.finrank_mul_finrank (F := в„ҡ) (K := L) (A := CyclotomicField r в„ҡ)
    rw [hcubic, hfinrankE] at hmul
    omega
  have hodd : r вү  2 := by
    intro hr2
    rw [hr2] at hr3
    norm_num at hr3
  have hdiscE : (NumberField.discr (CyclotomicField r в„ҡ)).natAbs = r ^ (r - 2) :=
    cyclotomicField_prime_discr_natAbs r hr hodd
  have htower_rhs : Ideal.absNorm Drel * (r ^ n) ^ m = r ^ (r - 2) := by
    have htower0 :=
      NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        (K := L) (рқ’Ә := рқ“һ L) (CyclotomicField r в„ҡ) (рқ“һ (CyclotomicField r в„ҡ))
    rw [hdiscE, hdiscrL_natAbs, hfinrankLE] at htower0
    simpa [Drel] using htower0.symm
  have hdiv_total : r ^ ((m - 1) + n * m) вҲЈ r ^ (r - 2) := by
    have hmuldiv : r ^ (m - 1) * (r ^ n) ^ m вҲЈ Ideal.absNorm Drel * (r ^ n) ^ m := by
      exact mul_dvd_mul hDrel_norm_dvd (dvd_rfl)
    rw [htower_rhs] at hmuldiv
    simpa [pow_mul, pow_add, mul_comm, mul_left_comm, mul_assoc] using hmuldiv
  have hr_nonunit : В¬ IsUnit r := by
    rw [Nat.isUnit_iff]
    exact hr.ne_one
  have hupper : (m - 1) + n * m вүӨ r - 2 := by
    exact (pow_dvd_pow_iff hr.ne_zero hr_nonunit).mp hdiv_total
  have hr_div : r = 3 * m + 1 := by
    dsimp [m]
    omega
  have hm_ne_zero : m вү  0 := by
    intro hm0
    rw [hm0] at hr_div
    exact hr.ne_one hr_div
  have hm_pos : 0 < m := Nat.pos_of_ne_zero hm_ne_zero
  have hupper' : (m - 1) + n * m вүӨ 3 * m - 1 := by
    rw [hr_div] at hupper
    simpa using hupper
  have hnm_le : n * m вүӨ 2 * m := by
    omega
  have hn_le_two : n вүӨ 2 := by
    exact le_of_mul_le_mul_right hnm_le hm_pos
  have hn_eq : n = 2 := le_antisymm hn_le_two htwo_le_n
  refine вҹЁP, ?_, ?_вҹ©
  В· exact hPover
  В· simpa [hn_eq] using hDpow

theorem discr_cubic_subfield_of_prime_cyclotomic (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1)
    (L : IntermediateField в„ҡ (CyclotomicField r в„ҡ))
    [IsGalois в„ҡ L] [IsTotallyReal L]
    (hcubic : Module.finrank в„ҡ L = 3) :
    (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let p : Ideal в„Ө := Ideal.span {(r : в„Ө)}
  obtain вҹЁP, hPmem, hcount, hram, hfin, h_unramвҹ© :=
    cubic_subfield_prime_ramification_data r hr hr3 L hcubic
  obtain вҹЁP', hP'mem, hdiffвҹ© :=
    differentIdeal_cubic_subfield_eq_prime_sq r hr hr3 L hcubic
  have hcount' : (p.primesOver (рқ“һ L)).ncard = 1 := by
    simpa [p] using hcount
  have hPmem' : P вҲҲ p.primesOver (рқ“һ L) := by
    simpa [p] using hPmem
  have hP'mem' : P' вҲҲ p.primesOver (рқ“һ L) := by
    simpa [p] using hP'mem
  obtain вҹЁQ, hQsingleвҹ© := Set.ncard_eq_one.mp hcount'
  have hP_eq_Q : P = Q := by
    rw [hQsingle] at hPmem'
    simpa using hPmem'
  have hP'_eq_Q : P' = Q := by
    rw [hQsingle] at hP'mem'
    simpa using hP'mem'
  have hP'eqP : P' = P := hP'_eq_Q.trans hP_eq_Q.symm
  set_option maxHeartbeats 800000 in
  have hnormP : Ideal.absNorm P = r := by
    let PP : p.primesOver (рқ“һ L) := вҹЁP, hPmem'вҹ©
    letI : P.LiesOver p := by
      simpa using (Ideal.primesOver.liesOver p PP)
    rw [Ideal.absNorm_eq_pow_inertiaDeg' P hr, hfin, pow_one]
  calc
    (NumberField.discr L).natAbs = Ideal.absNorm (differentIdeal в„Ө (рқ“һ L)) := by
      rw [вҶҗ NumberField.absNorm_differentIdeal (K := L) (рқ’Ә := рқ“һ L)]
    _ = Ideal.absNorm (P' ^ 2) := by rw [hdiff]
    _ = Ideal.absNorm P' ^ 2 := map_pow Ideal.absNorm P' 2
    _ = Ideal.absNorm P ^ 2 := by rw [hP'eqP]
    _ = r ^ 2 := by rw [hnormP]

theorem cyclic_cubic_subfield_exists (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    вҲғ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois в„ҡ L)
      (_ : Algebra L (CyclotomicField r в„ҡ)),
      Module.finrank в„ҡ L = 3 вҲ§
      (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let E := CyclotomicField r в„ҡ
  letI : Fact r.Prime := вҹЁhrвҹ©
  have hne : r вү  0 := hr.ne_zero
  letI : NeZero (r : в„ҡ) := вҹЁNat.cast_ne_zero.mpr hneвҹ©
  letI : IsCyclotomicExtension ({r} : Set в„•) в„ҡ E := CyclotomicField.isCyclotomicExtension (n := r) (K := в„ҡ)
  letI : IsAbelianGalois в„ҡ E := IsCyclotomicExtension.isAbelianGalois (S := ({r} : Set в„•)) (K := в„ҡ) (L := E)
  letI : IsGalois в„ҡ E := IsCyclotomicExtension.isGalois (S := ({r} : Set в„•)) (K := в„ҡ) (L := E)
  have hirr : Irreducible (Polynomial.cyclotomic r в„ҡ) :=
    Polynomial.cyclotomic.irreducible_rat hr.pos
  let e : (E вүғвӮҗ[в„ҡ] E) вүғ* (ZMod r)ЛЈ := by
    simpa [E] using (galCyclotomicEquivUnitsZMod (n := r) (K := в„ҡ) (L := E) hirr)
  let H' : Subgroup ((ZMod r)ЛЈ) := (powMonoidHom 3).range
  let H : Subgroup (E вүғвӮҗ[в„ҡ] E) := H'.map e.symm.toMonoidHom
  let L : IntermediateField в„ҡ E := IntermediateField.fixedField H
  have hindexH' : H'.index = 3 := by
    have hidx : H'.index = Nat.gcd (Nat.card ((ZMod r)ЛЈ)) 3 := by
      simpa [H'] using (IsCyclic.index_powMonoidHom_range (G := (ZMod r)ЛЈ) 3)
    have hcard : Nat.card ((ZMod r)ЛЈ) = r - 1 := by
      rw [Nat.card_eq_fintype_card, ZMod.card_units r]
    have h3dvd : 3 вҲЈ r - 1 := by
      omega
    have hgcd : Nat.gcd (Nat.card ((ZMod r)ЛЈ)) 3 = 3 := by
      rw [hcard, Nat.gcd_eq_right_iff_dvd]
      exact h3dvd
    rw [hidx, hgcd]
  have hindexH : H.index = 3 := by
    have hm : (H'.map e.symm.toMonoidHom).index = H'.index := by
      simp
    rw [show H = H'.map e.symm.toMonoidHom by rfl, hm, hindexH']
  have hfix : L.fixingSubgroup = H := by
    simpa [L] using (IntermediateField.fixingSubgroup_fixedField (F := в„ҡ) (E := E) H)
  have hfinrankL : Module.finrank в„ҡ L = 3 := by
    rw [IntermediateField.finrank_eq_fixingSubgroup_index (k := в„ҡ) (K := E) L, hfix, hindexH]
  have hgalL : IsGalois в„ҡ L := by
    letI : H.Normal := Subgroup.normal_of_comm H
    exact IsGalois.of_fixedField_normal_subgroup (K := в„ҡ) (L := E) H
  have htrL : IsTotallyReal L := by
    letI : IsUnramifiedAtInfinitePlaces в„ҡ L := by
      apply IsUnramifiedAtInfinitePlaces_of_odd_finrank (k := в„ҡ) (K := L)
      simpa [hfinrankL] using (show Odd (3 : в„•) by decide)
    refine вҹЁfun w => ?_вҹ©
    have hwunr : w.IsUnramified в„ҡ := NumberField.InfinitePlace.isUnramified (k := в„ҡ) w
    have hwq : w.comap (algebraMap в„ҡ L) = Rat.infinitePlace := Subsingleton.elim _ _
    have hbaseReal : (w.comap (algebraMap в„ҡ L)).IsReal := by
      simpa [hwq] using (Rat.isReal_infinitePlace : Rat.infinitePlace.IsReal)
    exact (NumberField.InfinitePlace.isUnramified_iff (k := в„ҡ) (w := w)).mp hwunr |>.resolve_right
      ((NumberField.InfinitePlace.not_isComplex_iff_isReal).2 hbaseReal)
  letI : IsGalois в„ҡ L := hgalL
  letI : IsTotallyReal L := htrL
  refine вҹЁL, inferInstance, inferInstance, inferInstance, htrL, hgalL, inferInstance, ?_вҹ©
  exact вҹЁhfinrankL, discr_cubic_subfield_of_prime_cyclotomic r hr hr3 L hfinrankLвҹ©

theorem elementaryAbelian_mulEquiv (G : Type) [Group G] [Finite G]
    (p k : в„•) [Fact (Nat.Prime p)]
    (_hcard : Nat.card G = p ^ k)
    (_hexp : вҲҖ g : G, g ^ p = 1)
    (_habel : вҲҖ g h : G, g * h = h * g) :
    Nonempty (G вүғ* Multiplicative (Fin k вҶ’ ZMod p)) := by
  classical
  letI : CommGroup G :=
    { вҖ№Group GвҖә with
      mul_comm := _habel }
  have hsmul_zero : вҲҖ a : Additive G, p вҖў a = 0 := by
    intro a
    simpa using congrArg Additive.ofMul (_hexp a.toMul)
  haveI : Module (ZMod p) (Additive G) := AddCommGroup.zmodModule hsmul_zero
  haveI : Finite (Additive G) := inferInstance
  haveI : Module.Finite (ZMod p) (Additive G) :=
    Module.Finite.of_finite (R := ZMod p) (M := Additive G)
  haveI : Module.Free (ZMod p) (Additive G) :=
    Module.Free.of_divisionRing (K := ZMod p) (V := Additive G)
  have hpow : p ^ Module.finrank (ZMod p) (Additive G) = Nat.card (Additive G) := by
    simpa using (FiniteField.pow_finrank_eq_natCard p (Additive G))
  have hpow' : p ^ Module.finrank (ZMod p) (Additive G) = p ^ k := by
    calc
      p ^ Module.finrank (ZMod p) (Additive G) = Nat.card (Additive G) := hpow
      _ = Nat.card G := Nat.card_congr Additive.toMul
      _ = p ^ k := _hcard
  have hfinrank : Module.finrank (ZMod p) (Additive G) = k := by
    exact Nat.pow_right_injective (a := p) (Fact.out : Nat.Prime p).two_le hpow'
  let b : Module.Basis (Fin k) (ZMod p) (Additive G) :=
    Module.finBasisOfFinrankEq (R := ZMod p) (M := Additive G) (n := k) hfinrank
  refine вҹЁAddEquiv.toMultiplicativeRight
    (show Additive G вүғ+ (Fin k вҶ’ ZMod p) from b.equivFun.toAddEquiv)вҹ©

theorem minpoly_iK_eq_X_sq_add_one (рқ’ҹ : AdmissibleDatum) :
    minpoly рқ’ҹ.L рқ’ҹ.i_K = (Polynomial.X ^ 2 + 1 : Polynomial рқ’ҹ.L) := by
  let p : Polynomial рқ’ҹ.L := Polynomial.X ^ 2 + 1
  have hp_monic : p.Monic := by
    dsimp [p]
    simpa using (Polynomial.monic_X_pow_add_C (a := (1 : рқ’ҹ.L)) (n := 2) (by decide))
  have hp_aeval : Polynomial.aeval рқ’ҹ.i_K p = 0 := by
    dsimp [p]
    simp [pow_two, рқ’ҹ.i_K_sq]
  have hi : IsIntegral рқ’ҹ.L рқ’ҹ.i_K := вҹЁp, hp_monic, hp_aevalвҹ©
  let pb : PowerBasis рқ’ҹ.L рқ’ҹ.K := PowerBasis.ofAdjoinEqTop hi рқ’ҹ.adjoin_i_K_eq_top
  have hdim : pb.dim = 2 := by
    rw [вҶҗ PowerBasis.finrank pb]
    exact Algebra.IsQuadraticExtension.finrank_eq_two рқ’ҹ.L рқ’ҹ.K
  have hdeg : (minpoly рқ’ҹ.L рқ’ҹ.i_K).natDegree = 2 := by
    rw [вҶҗ PowerBasis.ofAdjoinEqTop_dim hi рқ’ҹ.adjoin_i_K_eq_top]
    simpa [pb] using hdim
  have hnat_p : p.natDegree = 2 := by
    dsimp [p]
    simpa using (Polynomial.natDegree_X_pow_add_C (n := 2) (r := (1 : рқ’ҹ.L)))
  have hpdeg : p.degree = 2 := by
    simpa using
      (Polynomial.MonicDegreeEq.degree (Polynomial.MonicDegreeEq.mk p hp_monic hnat_p))
  have hmdeg : (minpoly рқ’ҹ.L рқ’ҹ.i_K).degree = 2 := by
    simpa using
      (Polynomial.MonicDegreeEq.degree
        (Polynomial.MonicDegreeEq.mk (minpoly рқ’ҹ.L рқ’ҹ.i_K) (minpoly.monic hi) hdeg))
  have hp_le : p.degree вүӨ (minpoly рқ’ҹ.L рқ’ҹ.i_K).degree := by
    rw [hpdeg, hmdeg]
  have hEq : p = minpoly рқ’ҹ.L рқ’ҹ.i_K := by
    exact minpoly.unique_of_degree_le_degree_minpoly (A := рқ’ҹ.L) (x := рқ’ҹ.i_K) hp_monic hp_aeval hp_le
  simpa [p] using hEq.symm

theorem minpoly_iO_map_eq_X_sq_add_one (рқ’ҹ : AdmissibleDatum) :
    (minpoly (рқ“һ рқ’ҹ.L) (admissibleDatum_iO рқ’ҹ)).map
      (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) = (Polynomial.X ^ 2 + 1 : Polynomial рқ’ҹ.L) := by
  let iO := admissibleDatum_iO рқ’ҹ
  have hIntExt : Algebra.IsIntegral (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) :=
    NumberField.RingOfIntegers.extension_algebra_isIntegral (K := рқ’ҹ.L) (L := рқ’ҹ.K)
  have hiOint : IsIntegral (рқ“һ рқ’ҹ.L) iO :=
    (Algebra.isIntegral_def.mp hIntExt) iO
  rw [вҶҗ minpoly.isIntegrallyClosed_eq_field_fractions (K := рқ’ҹ.L) (L := рқ’ҹ.K) hiOint]
  simp [iO, admissibleDatum_iO, minpoly_iK_eq_X_sq_add_one рқ’ҹ]

theorem q_mod4_exists_sq_eq_neg_one (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) :
    вҲғ a : ZMod (рқ’ҹ.q b), a ^ 2 = (-1 : ZMod (рқ’ҹ.q b)) := by
  letI : Fact (Nat.Prime (рқ’ҹ.q b)) := вҹЁрқ’ҹ.q_prime bвҹ©
  have hsquare : IsSquare (-1 : ZMod (рқ’ҹ.q b)) := by
    rw [ZMod.exists_sq_eq_neg_one_iff]
    have hmod : рқ’ҹ.q b % 4 вү  3 := by
      rw [рқ’ҹ.q_mod4 b]
      decide
    exact hmod
  rcases hsquare with вҹЁa, haвҹ©
  refine вҹЁa, ?_вҹ©
  simpa [sq] using ha.symm

theorem exists_sq_eq_neg_one_residueField_of_prime_over_q (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t)
    (рқ”® : Ideal (рқ“һ рқ’ҹ.L)) (hрқ”®p : рқ”®.IsPrime) (hрқ”®ne : рқ”® вү  вҠҘ)
    (hрқ”®over : рқ”® вҲҲ (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.L)) :
    вҲғ a : рқ“һ рқ’ҹ.L в§ё рқ”®, a ^ 2 = (-1 : рқ“һ рқ’ҹ.L в§ё рқ”®) := by
  classical
  let p : Ideal в„Ө := Ideal.span {((рқ’ҹ.q b : в„Ө))}
  have hpPrime : p.IsPrime := by
    rw [show p = Ideal.span {((рқ’ҹ.q b : в„Ө))} by rfl]
    exact (Ideal.span_singleton_prime (show ((рқ’ҹ.q b : в„Ө)) вү  0 by exact_mod_cast (рқ’ҹ.q_prime b).ne_zero)).2
      ((Nat.prime_iff_prime_int).mp (рқ’ҹ.q_prime b))
  have hp0 : p вү  вҠҘ := by
    rw [show p = Ideal.span {((рқ’ҹ.q b : в„Ө))} by rfl, ne_eq, Ideal.span_singleton_eq_bot]
    exact_mod_cast (рқ’ҹ.q_prime b).ne_zero
  letI : p.IsMaximal := hpPrime.isMaximal hp0
  let Q : p.primesOver (рқ“һ рқ’ҹ.L) := вҹЁрқ”®, hрқ”®overвҹ©
  letI : рқ”®.LiesOver p := by
    simpa using (Ideal.primesOver.liesOver (p := p) Q)
  letI : рқ”®.IsMaximal := Ideal.isMaximal_of_mem_primesOver hрқ”®over
  have hinertia : Ideal.inertiaDeg p рқ”® = 1 := by
    simpa [p] using ((рқ’ҹ.q_splits_in_L b).1 рқ”® hрқ”®over).2
  have hcard_nat : Nat.card (рқ“һ рқ’ҹ.L в§ё рқ”®) = рқ’ҹ.q b := by
    calc
      Nat.card (рқ“һ рқ’ҹ.L в§ё рқ”®) = рқ”®.cardQuot := by
        symm
        exact Submodule.cardQuot_apply рқ”®
      _ = Ideal.absNorm рқ”® := by
        symm
        exact Ideal.absNorm_apply рқ”®
      _ = (рқ’ҹ.q b) ^ (Ideal.inertiaDeg p рқ”®) := by
        exact Ideal.absNorm_eq_pow_inertiaDeg' рқ”® (рқ’ҹ.q_prime b)
      _ = рқ’ҹ.q b := by rw [hinertia, pow_one]
  letI : Finite (рқ“һ рқ’ҹ.L в§ё рқ”®) := Nat.finite_of_card_ne_zero (by
    rw [hcard_nat]
    exact (рқ’ҹ.q_prime b).ne_zero)
  letI : Fintype (рқ“һ рқ’ҹ.L в§ё рқ”®) := Fintype.ofFinite (рқ“һ рқ’ҹ.L в§ё рқ”®)
  have hcard : Fintype.card (рқ“һ рқ’ҹ.L в§ё рқ”®) = рқ’ҹ.q b := by
    rw [Fintype.card_eq_nat_card, hcard_nat]
  let e : ZMod (рқ’ҹ.q b) вүғ+* (рқ“һ рқ’ҹ.L в§ё рқ”®) :=
    ZMod.ringEquivOfPrime (R := рқ“һ рқ’ҹ.L в§ё рқ”®) (рқ’ҹ.q_prime b) hcard
  rcases q_mod4_exists_sq_eq_neg_one рқ’ҹ b with вҹЁa, haвҹ©
  refine вҹЁe a, ?_вҹ©
  simpa [map_pow, map_neg, map_one] using congrArg e ha

theorem q_two_not_mem_prime_over_q (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t)
    (рқ”® : Ideal (рқ“һ рқ’ҹ.L)) (hрқ”®p : рқ”®.IsPrime) (hрқ”®ne : рқ”® вү  вҠҘ)
    (hрқ”®over : рқ”® вҲҲ (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.L)) :
    (2 : рқ“һ рқ’ҹ.L) вҲү рқ”® := by
  let p : Ideal в„Ө := Ideal.span {((рқ’ҹ.q b : в„Ө))}
  intro h2
  have h_lies' : рқ”®.LiesOver (Ideal.span {((рқ’ҹ.q b : в„Ө))}) := by
    exact hрқ”®over.2
  letI : рқ”®.LiesOver p := by
    simpa [p] using h_lies'
  have h2int : (2 : в„Ө) вҲҲ p := by
    exact (Ideal.mem_of_liesOver рқ”® p 2).2 (by simpa using h2)
  have h2int' : (2 : в„Ө) вҲҲ Ideal.span {((рқ’ҹ.q b : в„Ө))} := by
    simpa [p] using h2int
  have hdivz : ((рқ’ҹ.q b : в„Ө)) вҲЈ (2 : в„Ө) := by
    exact Ideal.mem_span_singleton.mp h2int'
  have hdivn : рқ’ҹ.q b вҲЈ 2 := by
    exact Int.ofNat_dvd_natCast.mp hdivz
  have hqeq : рқ’ҹ.q b = 2 := by
    exact (Nat.prime_dvd_prime_iff_eq (рқ’ҹ.q_prime b) Nat.prime_two).mp hdivn
  have hmod : (2 : в„•) % 4 = 1 := by
    simpa [hqeq] using рқ’ҹ.q_mod4 b
  norm_num at hmod

theorem conductor_iO_sup_prime_over_q_eq_top (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t)
    (рқ”® : Ideal (рқ“һ рқ’ҹ.L)) (hрқ”®p : рқ”®.IsPrime) (hрқ”®ne : рқ”® вү  вҠҘ)
    (hрқ”®over : рқ”® вҲҲ (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.L)) :
    (conductor (рқ“һ рқ’ҹ.L) (admissibleDatum_iO рқ’ҹ)).comap
      (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҠ” рқ”® = вҠӨ := by
  let iO := admissibleDatum_iO рқ’ҹ
  have hcoe_iO : (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) iO = рқ’ҹ.i_K := by
    rfl
  have hmap2 : (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) (2 : рқ“һ рқ’ҹ.L) = (2 : рқ“һ рқ’ҹ.K) := by
    simpa using map_natCast (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) 2
  have hmul :
      conductor (рқ“һ рқ’ҹ.L) iO * differentIdeal (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)
        = Ideal.span
            {(Polynomial.aeval iO (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) iO)))} := by
    simpa [iO] using
      (conductor_mul_differentIdeal (A := рқ“һ рқ’ҹ.L) (K := рқ’ҹ.L) (L := рқ’ҹ.K) (x := iO)
        (by simpa [iO] using рқ’ҹ.adjoin_i_K_eq_top))
  have hiO_sq : iO * iO = (-1 : рқ“һ рқ’ҹ.K) := by
    ext
    simp [iO, admissibleDatum_iO, рқ’ҹ.i_K_sq]
  have hiO_unit : IsUnit iO := by
    refine вҹЁвҹЁiO, -iO, ?_, ?_вҹ©, rflвҹ©
    В· calc
        iO * (-iO) = -(iO * iO) := by ring
        _ = -(-1 : рқ“һ рқ’ҹ.K) := by rw [hiO_sq]
        _ = 1 := by ring
    В· calc
        (-iO) * iO = -(iO * iO) := by ring
        _ = -(-1 : рқ“һ рқ’ҹ.K) := by rw [hiO_sq]
        _ = 1 := by ring
  have hcomm :
      (algebraMap рқ’ҹ.L рқ’ҹ.K).comp (algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L) =
        (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K).comp (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) := by
    ext x
    rfl
  have haeval_map :
      (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K)
        (Polynomial.aeval iO (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) iO)))
        = (2 : рқ’ҹ.K) * рқ’ҹ.i_K := by
    rw [Polynomial.map_aeval_eq_aeval_map hcomm]
    rw [вҶҗ Polynomial.derivative_map]
    rw [minpoly_iO_map_eq_X_sq_add_one]
    norm_num [pow_two, рқ’ҹ.i_K_sq]
    rw [hcoe_iO, two_mul]
  have haeval :
      Polynomial.aeval iO (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) iO)) = 2 * iO := by
    ext
    simpa [iO] using haeval_map
  have hspan :
      Ideal.span ({(2 : рқ“һ рқ’ҹ.K)} : Set (рқ“һ рқ’ҹ.K)) =
        conductor (рқ“һ рқ’ҹ.L) iO * differentIdeal (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) := by
    calc
      Ideal.span ({(2 : рқ“һ рқ’ҹ.K)} : Set (рқ“һ рқ’ҹ.K))
          = Ideal.span
              {(Polynomial.aeval iO (Polynomial.derivative (minpoly (рқ“һ рқ’ҹ.L) iO)))} := by
            rw [haeval]
            symm
            exact Ideal.span_singleton_mul_right_unit hiO_unit (2 : рқ“һ рқ’ҹ.K)
      _ = conductor (рқ“һ рқ’ҹ.L) iO * differentIdeal (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) := by
          symm
          exact hmul
  have hspan_le : Ideal.span ({(2 : рқ“һ рқ’ҹ.K)} : Set (рқ“һ рқ’ҹ.K)) вүӨ conductor (рқ“һ рқ’ҹ.L) iO := by
    rw [hspan]
    exact Ideal.mul_le_right
  have h2_mem_cond : (2 : рқ“һ рқ’ҹ.K) вҲҲ conductor (рқ“һ рқ’ҹ.L) iO := by
    exact hspan_le (Ideal.subset_span (by simp))
  have h2_mem_comap :
      (2 : рқ“һ рқ’ҹ.L) вҲҲ (conductor (рқ“һ рқ’ҹ.L) (admissibleDatum_iO рқ’ҹ)).comap
        (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) := by
    rw [Ideal.mem_comap, hmap2]
    simpa [iO] using h2_mem_cond
  have hрқ”®max : рқ”®.IsMaximal := Ideal.IsPrime.isMaximal hрқ”®p hрқ”®ne
  rw [Ideal.isMaximal_iff] at hрқ”®max
  have hone_mem : (1 : рқ“һ рқ’ҹ.L) вҲҲ
      (conductor (рқ“һ рқ’ҹ.L) (admissibleDatum_iO рқ’ҹ)).comap
        (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҠ” рқ”® := by
    exact hрқ”®max.2 _ _ le_sup_right
      (q_two_not_mem_prime_over_q рқ’ҹ b рқ”® hрқ”®p hрқ”®ne hрқ”®over)
      (Ideal.mem_sup_left h2_mem_comap)
  exact top_unique (by
    intro x hx
    exact Ideal.mem_of_one_mem hone_mem x)

theorem q_splits_in_K_local (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t)
    (рқ”® : Ideal (рқ“һ рқ’ҹ.L)) (_hрқ”®p : рқ”®.IsPrime) (_hрқ”®ne : рқ”® вү  вҠҘ)
    (_hрқ”®over : рқ”® вҲҲ (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.L)) :
    вҲғ рқ”“ рқ”“' : Ideal (рқ“һ рқ’ҹ.K),
      рқ”“ вү  рқ”“' вҲ§ рқ”“.IsPrime вҲ§ рқ”“'.IsPrime вҲ§ рқ”“ вү  вҠҘ вҲ§ рқ”“' вү  вҠҘ вҲ§
      рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) = рқ”“ * рқ”“' := by
  classical
  let iO : рқ“һ рқ’ҹ.K := admissibleDatum_iO рқ’ҹ
  have hiOint : IsIntegral (рқ“һ рқ’ҹ.L) iO := by
    have hInt : Algebra.IsIntegral (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K) :=
      NumberField.RingOfIntegers.extension_algebra_isIntegral (K := рқ’ҹ.L) (L := рқ’ҹ.K)
    rw [Algebra.isIntegral_def] at hInt
    exact hInt iO
  have hminO_eq : minpoly (рқ“һ рқ’ҹ.L) iO = (Polynomial.X ^ 2 + 1 : Polynomial (рқ“һ рқ’ҹ.L)) := by
    apply (Polynomial.map_injective (f := algebraMap (рқ“һ рқ’ҹ.L) рқ’ҹ.L)
      (FaithfulSMul.algebraMap_injective (рқ“һ рқ’ҹ.L) рқ’ҹ.L))
    simpa [iO] using minpoly_iO_map_eq_X_sq_add_one рқ’ҹ
  letI : рқ”®.IsMaximal := Ideal.IsPrime.isMaximal _hрқ”®p _hрқ”®ne
  letI := Ideal.Quotient.field рқ”®
  have hcond_sup : (conductor (рқ“һ рқ’ҹ.L) iO).comap (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вҠ” рқ”® = вҠӨ := by
    simpa [iO] using conductor_iO_sup_prime_over_q_eq_top рқ’ҹ b рқ”® _hрқ”®p _hрқ”®ne _hрқ”®over
  obtain вҹЁa, haвҹ© := exists_sq_eq_neg_one_residueField_of_prime_over_q рқ’ҹ b рқ”® _hрқ”®p _hрқ”®ne _hрқ”®over
  let Q : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) := Polynomial.X - Polynomial.C a
  let Q' : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) := Polynomial.X + Polynomial.C a
  have hred : Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO) = Q * Q' := by
    rw [hminO_eq]
    simp [Q, Q']
    ring_nf
    have hC : Polynomial.C a ^ 2 = Polynomial.C (a ^ 2) := by simp [pow_two]
    rw [hC, ha]
    simp [add_comm]
  have htwo_ne_zero : (2 : рқ“һ рқ’ҹ.L в§ё рқ”®) вү  0 := by
    intro hzero
    have hmem : (2 : рқ“һ рқ’ҹ.L) вҲҲ рқ”® := by
      simpa using (Submodule.Quotient.mk_eq_zero (p := рқ”®) (x := (2 : рқ“һ рқ’ҹ.L))).mp hzero
    exact q_two_not_mem_prime_over_q рқ’ҹ b рқ”® _hрқ”®p _hрқ”®ne _hрқ”®over hmem
  have ha_ne_zero : a вү  0 := by
    intro ha0
    have hneg : (-1 : рқ“һ рқ’ҹ.L в§ё рқ”®) = 0 := by simp [ha0] at ha
    have hone : (1 : рқ“һ рқ’ҹ.L в§ё рқ”®) = 0 := by simp at hneg
    exact one_ne_zero hone
  have hQ_ne_Q' : Q вү  Q' := by
    intro hQQ
    have hcoeff := congrArg (fun p : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) => p.coeff 0) hQQ
    have haeq : -a = a := by
      simpa [Q, Q'] using hcoeff
    have haeq' : a = -a := by simpa using haeq.symm
    have h2a : (2 : рқ“һ рқ’ҹ.L в§ё рқ”®) * a = 0 := by
      calc
        (2 : рқ“һ рқ’ҹ.L в§ё рқ”®) * a = a + a := by simp [two_mul]
        _ = a + (-a) := by
          exact congrArg (fun x => a + x) haeq'
        _ = 0 := by simp
    have h2zero : (2 : рқ“һ рқ’ҹ.L в§ё рқ”®) = 0 := by
      exact (mul_eq_zero.mp h2a).resolve_right ha_ne_zero
    exact htwo_ne_zero h2zero
  have hQ_irreducible : Irreducible Q := by
    simpa [Q] using (Polynomial.irreducible_X_sub_C a)
  have hQ'_irreducible : Irreducible Q' := by
    simpa [Q', sub_eq_add_neg] using (Polynomial.irreducible_X_sub_C (-a))
  have hQ_monic : Q.Monic := by
    simpa [Q] using (Polynomial.monic_X_sub_C a)
  have hQ'_monic : Q'.Monic := by
    simpa [Q'] using (Polynomial.monic_X_add_C a)
  have hQ_ne_zero : Q вү  0 := hQ_monic.ne_zero
  have hQ'_ne_zero : Q' вү  0 := hQ'_monic.ne_zero
  have hred_ne_zero : Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO) вү  0 := by
    rw [hred]
    exact mul_ne_zero hQ_ne_zero hQ'_ne_zero
  have hQ_mem : Q вҲҲ UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO)) := by
    rw [Polynomial.mem_normalizedFactors_iff hred_ne_zero]
    refine вҹЁhQ_irreducible, hQ_monic, ?_вҹ©
    rw [hred]
    exact вҹЁQ', by simpвҹ©
  have hQ'_mem : Q' вҲҲ UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO)) := by
    rw [Polynomial.mem_normalizedFactors_iff hred_ne_zero]
    refine вҹЁhQ'_irreducible, hQ'_monic, ?_вҹ©
    rw [hred]
    exact вҹЁQ, by simp [mul_comm]вҹ©
  have hqmap_ne : рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вү  вҠҘ :=
    Ideal.map_ne_bot_of_ne_bot _hрқ”®ne
  let e := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
    (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) (I := рқ”®) (x := iO) (show рқ”®.IsMaximal from inferInstance)
    _hрқ”®ne hcond_sup hiOint
  let Pf := (e.symm вҹЁQ, hQ_memвҹ© : {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))})
  let Pf' := (e.symm вҹЁQ', hQ'_memвҹ© : {J : Ideal (рқ“һ рқ’ҹ.K) | J вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))})
  let рқ”“ : Ideal (рқ“һ рқ’ҹ.K) := Pf
  let рқ”“' : Ideal (рқ“һ рқ’ҹ.K) := Pf'
  have hрқ”“_mem : рқ”“ вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))) := by
    change (вҶ‘Pf) вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))
    exact Pf.prop
  have hрқ”“'_mem : рқ”“' вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))) := by
    change (вҶ‘Pf') вҲҲ UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))
    exact Pf'.prop
  have hnorm_red :
      UniqueFactorizationMonoid.normalizedFactors (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO)) =
        {Q} + {Q'} := by
    rw [hred, UniqueFactorizationMonoid.normalizedFactors_mul hQ_ne_zero hQ'_ne_zero,
      UniqueFactorizationMonoid.normalizedFactors_irreducible hQ_irreducible,
      UniqueFactorizationMonoid.normalizedFactors_irreducible hQ'_irreducible,
      Polynomial.Monic.normalize_eq_self hQ_monic,
      Polynomial.Monic.normalize_eq_self hQ'_monic]
  have hattach_red :
      (UniqueFactorizationMonoid.normalizedFactors
        (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO))).attach =
        ({вҹЁQ, hQ_memвҹ©} + {вҹЁQ', hQ'_memвҹ©} :
          Multiset {d : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) |
            d вҲҲ UniqueFactorizationMonoid.normalizedFactors
              (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO))}) := by
    apply (Multiset.map_injective (f := fun x :
      {d : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) |
        d вҲҲ UniqueFactorizationMonoid.normalizedFactors
          (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO))} => x.1)
      Subtype.val_injective)
    change Multiset.map Subtype.val
        ((UniqueFactorizationMonoid.normalizedFactors
          (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO))).attach) =
      Multiset.map Subtype.val ({вҹЁQ, hQ_memвҹ©} + {вҹЁQ', hQ'_memвҹ©})
    simpa [Multiset.attach_map_val, Multiset.map_add, Multiset.map_singleton] using hnorm_red
  have hnorm_map :
      UniqueFactorizationMonoid.normalizedFactors (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))) =
        {рқ”“} + {рқ”“'} := by
    rw [KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      (R := рқ“һ рқ’ҹ.L) (S := рқ“һ рқ’ҹ.K) (I := рқ”®) (x := iO)
      (show рқ”®.IsMaximal from inferInstance) _hрқ”®ne hcond_sup hiOint,
      hattach_red,
      Multiset.map_add,
      Multiset.map_singleton,
      Multiset.map_singleton]
  have hрқ”“_isPrime : рқ”“.IsPrime := (Ideal.mem_normalizedFactors_iff hqmap_ne).mp hрқ”“_mem |>.1
  have hрқ”“'_isPrime : рқ”“'.IsPrime := (Ideal.mem_normalizedFactors_iff hqmap_ne).mp hрқ”“'_mem |>.1
  have hqmap_le_рқ”“ : рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вүӨ рқ”“ :=
    (Ideal.mem_normalizedFactors_iff hqmap_ne).mp hрқ”“_mem |>.2
  have hqmap_le_рқ”“' : рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вүӨ рқ”“' :=
    (Ideal.mem_normalizedFactors_iff hqmap_ne).mp hрқ”“'_mem |>.2
  have hрқ”“_ne_bot : рқ”“ вү  вҠҘ := by
    intro hрқ”“0
    have hle : рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вүӨ (вҠҘ : Ideal (рқ“һ рқ’ҹ.K)) := by
      simpa [hрқ”“0] using hqmap_le_рқ”“
    exact hqmap_ne (le_antisymm hle bot_le)
  have hрқ”“'_ne_bot : рқ”“' вү  вҠҘ := by
    intro hрқ”“0
    have hle : рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) вүӨ (вҠҘ : Ideal (рқ“һ рқ’ҹ.K)) := by
      simpa [hрқ”“0] using hqmap_le_рқ”“'
    exact hqmap_ne (le_antisymm hle bot_le)
  have hрқ”“_ne_рқ”“' : рқ”“ вү  рқ”“' := by
    intro hPP
    have hPf_eq : Pf = Pf' := by
      apply Subtype.ext
      simpa [рқ”“, рқ”“'] using hPP
    have hQQ' :
        (вҹЁQ, hQ_memвҹ© :
          {d : Polynomial (рқ“һ рқ’ҹ.L в§ё рқ”®) |
            d вҲҲ UniqueFactorizationMonoid.normalizedFactors
              (Polynomial.map (Ideal.Quotient.mk рқ”®) (minpoly (рқ“һ рқ’ҹ.L) iO))}) =
        вҹЁQ', hQ'_memвҹ© := by
      simpa [Pf, Pf'] using congrArg e hPf_eq
    exact hQ_ne_Q' (congrArg Subtype.val hQQ')
  have hfac :
      рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) = рқ”“ * рқ”“' := by
    calc
      рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) =
          (UniqueFactorizationMonoid.normalizedFactors
            (рқ”®.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)))).prod := by
            symm
            exact prod_normalizedFactors_eq_self hqmap_ne
      _ = ({рқ”“} + {рқ”“'} : Multiset (Ideal (рқ“һ рқ’ҹ.K))).prod := by
        rw [hnorm_map]
      _ = рқ”“ * рқ”“' := by simp
  exact вҹЁрқ”“, рқ”“', hрқ”“_ne_рқ”“', hрқ”“_isPrime, hрқ”“'_isPrime, hрқ”“_ne_bot, hрқ”“'_ne_bot, hfacвҹ©

theorem q_splits_in_K_of_split_in_L_and_mod4 (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) :
    (вҲҖ рқ”“ вҲҲ (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.K),
        Ideal.ramificationIdx
          (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө) рқ”“ = 1 вҲ§
        Ideal.inertiaDeg
          (Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө) рқ”“ = 1) вҲ§
      ((Ideal.span {((рқ’ҹ.q b : в„Ө))} : Ideal в„Ө).primesOver (рқ“һ рқ’ҹ.K)).ncard =
        Module.finrank в„ҡ рқ’ҹ.K := by
  classical
  let p : Ideal в„Ө := Ideal.span {((рқ’ҹ.q b : в„Ө))}
  have hqprime : Nat.Prime (рқ’ҹ.q b) := рқ’ҹ.q_prime b
  have hqne0 : ((рқ’ҹ.q b : в„Ө)) вү  0 := by
    exact_mod_cast hqprime.ne_zero
  have hp0 : p вү  вҠҘ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact hqne0
  letI : Fact (Nat.Prime (рқ’ҹ.q b)) := вҹЁhqprimeвҹ©
  letI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime (рқ’ҹ.q b))
  rcases рқ’ҹ.q_splits_in_L b with вҹЁhLsplit, hLcardвҹ©
  have hsplitK : вҲҖ рқ”“ вҲҲ p.primesOver (рқ“һ рқ’ҹ.K),
      Ideal.ramificationIdx p рқ”“ = 1 вҲ§ Ideal.inertiaDeg p рқ”“ = 1 := by
    intro рқ”“ hрқ”“
    have hрқ”“p : рқ”“.IsPrime := hрқ”“.1
    have hрқ”“over : рқ”“.LiesOver p := hрқ”“.2
    let рқ”® : Ideal (рқ“һ рқ’ҹ.L) := рқ”“.under (рқ“һ рқ’ҹ.L)
    have hрқ”®p : рқ”®.IsPrime := by
      dsimp [рқ”®]
      letI : рқ”“.IsPrime := hрқ”“p
      exact Ideal.IsPrime.comap (f := algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K))
    have hрқ”®_lies : рқ”®.LiesOver p := by
      dsimp [рқ”®]
      letI : рқ”“.LiesOver p := hрқ”“over
      exact Ideal.under_liesOver_of_liesOver (B := рқ“һ рқ’ҹ.L) (рқ”“ := рқ”“) (p := p)
    have hрқ”®over : рқ”® вҲҲ p.primesOver (рқ“һ рқ’ҹ.L) := by
      exact вҹЁhрқ”®p, hрқ”®_liesвҹ©
    have hрқ”®ne : рқ”® вү  вҠҘ := by
      have hрқ”®max : рқ”®.IsMaximal := Ideal.isMaximal_of_mem_primesOver hрқ”®over
      exact Ring.ne_bot_of_isMaximal_of_not_isField hрқ”®max
        (NumberField.RingOfIntegers.not_isField (K := рқ’ҹ.L))
    have hрқ”®e : Ideal.ramificationIdx p рқ”® = 1 := (hLsplit рқ”® hрқ”®over).1
    have hрқ”®f : Ideal.inertiaDeg p рқ”® = 1 := (hLsplit рқ”® hрқ”®over).2
    letI : рқ”®.IsMaximal := Ideal.IsPrime.isMaximal hрқ”®p hрқ”®ne
    rcases q_splits_in_K_local рқ’ҹ b рқ”® hрқ”®p hрқ”®ne hрқ”®over with
      вҹЁрқ”“вӮҒ, рқ”“вӮӮ, hne, hрқ”“вӮҒp, hрқ”“вӮӮp, hрқ”“вӮҒne, hрқ”“вӮӮne, hmulвҹ©
    have hрқ”“вӮҒlies : рқ”“вӮҒ.LiesOver рқ”® := by
      have hdiv : рқ”“вӮҒ вҲЈ Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) рқ”® := by
        refine вҹЁрқ”“вӮӮ, ?_вҹ©
        simp [hmul, Ideal.mul_comm]
      exact (Ideal.liesOver_iff_dvd_map (p := рқ”®) (P := рқ”“вӮҒ)
        (Ideal.IsPrime.ne_top hрқ”“вӮҒp)).2 hdiv
    have hрқ”“вӮӮlies : рқ”“вӮӮ.LiesOver рқ”® := by
      have hdiv : рқ”“вӮӮ вҲЈ Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) рқ”® := by
        refine вҹЁрқ”“вӮҒ, ?_вҹ©
        simp [hmul, Ideal.mul_comm]
      exact (Ideal.liesOver_iff_dvd_map (p := рқ”®) (P := рқ”“вӮӮ)
        (Ideal.IsPrime.ne_top hрқ”“вӮӮp)).2 hdiv
    have hрқ”“вӮҒover : рқ”“вӮҒ вҲҲ рқ”®.primesOver (рқ“һ рқ’ҹ.K) := by
      exact вҹЁhрқ”“вӮҒp, hрқ”“вӮҒliesвҹ©
    have hрқ”“вӮӮover : рқ”“вӮӮ вҲҲ рқ”®.primesOver (рқ“һ рқ’ҹ.K) := by
      exact вҹЁhрқ”“вӮӮp, hрқ”“вӮӮliesвҹ©
    have h_nontriv : (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).Nontrivial := by
      exact вҹЁрқ”“вӮҒ, hрқ”“вӮҒover, рқ”“вӮӮ, hрқ”“вӮӮover, hneвҹ©
    have h_two_le : 2 вүӨ (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).ncard := by
      have h_one_lt : 1 < (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).ncard := by
        exact (Set.one_lt_ncard_iff_nontrivial).2 h_nontriv
      omega
    letI : IsGalois рқ’ҹ.L рқ’ҹ.K :=
      Algebra.IsQuadraticExtension.isGalois (F := рқ’ҹ.L) (K := рқ’ҹ.K)
    have hcount_mul :
        (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).ncard *
            (Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) * Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K)) =
          Nat.card (рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K) := by
      exact Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn
        (p := рқ”®) (B := рқ“һ рқ’ҹ.K) (G := рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K) hрқ”®ne
    have hcard_gal : Nat.card (рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K) = Module.finrank рқ’ҹ.L рқ’ҹ.K := by
      simpa using (IsGalois.card_aut_eq_finrank (F := рқ’ҹ.L) (E := рқ’ҹ.K))
    have hcount_mul' :
        (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).ncard *
            (Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) * Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K)) = 2 := by
      rw [hcard_gal, Algebra.IsQuadraticExtension.finrank_eq_two] at hcount_mul
      exact hcount_mul
    have hram_in_ne : Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) вү  0 := by
      exact Ideal.ramificationIdxIn_ne_zero
        (G := рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K) (p := рқ”®) (B := рқ“һ рқ’ҹ.K) hрқ”®ne
    have hiner_in_ne : Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K) вү  0 := by
      exact Ideal.inertiaDegIn_ne_zero
        (G := рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K) (p := рқ”®) (B := рқ“һ рқ’ҹ.K)
    set m : в„• :=
      Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) * Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K)
    have hm_pos : 0 < m := by
      dsimp [m]
      exact Nat.mul_pos (Nat.pos_of_ne_zero hram_in_ne) (Nat.pos_of_ne_zero hiner_in_ne)
    have hm_le_one : m вүӨ 1 := by
      have hmul_le : 2 * m вүӨ (рқ”®.primesOver (рқ“һ рқ’ҹ.K)).ncard * m := by
        exact Nat.mul_le_mul_right m h_two_le
      rw [hcount_mul'] at hmul_le
      omega
    have hm_eq_one : m = 1 := by
      omega
    have hram_in_eq : Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) = 1 := by
      apply Nat.eq_one_of_dvd_one
      rw [вҶҗ hm_eq_one]
      dsimp [m]
      exact dvd_mul_right _ _
    have hiner_in_eq : Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K) = 1 := by
      apply Nat.eq_one_of_dvd_one
      rw [вҶҗ hm_eq_one]
      dsimp [m]
      exact dvd_mul_left _ _
    have hрқ”“overрқ”® : рқ”“.LiesOver рқ”® := by
      dsimp [рқ”®]
      exact Ideal.over_under (A := рқ“һ рқ’ҹ.L) (P := рқ”“)
    have hrel_e : Ideal.ramificationIdx рқ”® рқ”“ = 1 := by
      letI : рқ”“.IsPrime := hрқ”“p
      letI : рқ”“.LiesOver рқ”® := hрқ”“overрқ”®
      calc
        Ideal.ramificationIdx рқ”® рқ”“ = Ideal.ramificationIdxIn рқ”® (рқ“һ рқ’ҹ.K) := by
          symm
          exact Ideal.ramificationIdxIn_eq_ramificationIdx
            (p := рқ”®) (P := рқ”“) (G := рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
        _ = 1 := hram_in_eq
    have hrel_f : Ideal.inertiaDeg рқ”® рқ”“ = 1 := by
      letI : рқ”“.IsPrime := hрқ”“p
      letI : рқ”“.LiesOver рқ”® := hрқ”“overрқ”®
      calc
        Ideal.inertiaDeg рқ”® рқ”“ = Ideal.inertiaDegIn рқ”® (рқ“һ рқ’ҹ.K) := by
          symm
          exact Ideal.inertiaDegIn_eq_inertiaDeg
            (p := рқ”®) (P := рқ”“) (G := рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
        _ = 1 := hiner_in_eq
    have hmapрқ”®_ne : Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) рқ”® вү  вҠҘ := by
      exact Ideal.map_ne_bot_of_ne_bot (I := рқ”®) hрқ”®ne
    have hpmap_ne : Ideal.map (algebraMap в„Ө (рқ“һ рқ’ҹ.K)) p вү  вҠҘ := by
      exact Ideal.map_ne_bot_of_ne_bot (I := p) hp0
    have hmap_le : Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) рқ”® вүӨ рқ”“ := by
      have hdivP : рқ”“ вҲЈ Ideal.map (algebraMap (рқ“һ рқ’ҹ.L) (рқ“һ рқ’ҹ.K)) рқ”® :=
        (Ideal.liesOver_iff_dvd_map (p := рқ”®) (P := рқ”“) (Ideal.IsPrime.ne_top hрқ”“p)).1
          hрқ”“overрқ”®
      rcases hdivP with вҹЁI, hIвҹ©
      rw [hI]
      simpa [Ideal.mul_comm] using (Ideal.mul_le_left : I * рқ”“ вүӨ рқ”“)
    have habs_e : Ideal.ramificationIdx p рқ”“ = 1 := by
      letI : рқ”“.IsPrime := hрқ”“p
      calc
        Ideal.ramificationIdx p рқ”“ =
            Ideal.ramificationIdx p рқ”® * Ideal.ramificationIdx рқ”® рқ”“ := by
          exact Ideal.ramificationIdx_algebra_tower
            (R := в„Ө) (S := рқ“һ рқ’ҹ.L) (T := рқ“һ рқ’ҹ.K)
            (p := p) (P := рқ”®) (Q := рқ”“) hmapрқ”®_ne hpmap_ne hmap_le
        _ = 1 := by rw [hрқ”®e, hrel_e]
    have habs_f : Ideal.inertiaDeg p рқ”“ = 1 := by
      letI : рқ”“.LiesOver рқ”® := hрқ”“overрқ”®
      calc
        Ideal.inertiaDeg p рқ”“ = Ideal.inertiaDeg p рқ”® * Ideal.inertiaDeg рқ”® рқ”“ := by
          exact Ideal.inertiaDeg_algebra_tower
            (R := в„Ө) (S := рқ“һ рқ’ҹ.L) (T := рқ“һ рқ’ҹ.K) p рқ”® рқ”“
        _ = 1 := by rw [hрқ”®f, hrel_f]
    exact вҹЁhabs_e, habs_fвҹ©
  refine вҹЁhsplitK, ?_вҹ©
  have hsummand : вҲҖ рқ”“ вҲҲ primesOverFinset p (рқ“һ рқ’ҹ.K),
      Ideal.ramificationIdx p рқ”“ * Ideal.inertiaDeg p рқ”“ = 1 := by
    intro рқ”“ hрқ”“
    have hрқ”“set : рқ”“ вҲҲ ((primesOverFinset p (рқ“һ рқ’ҹ.K) : Finset (Ideal (рқ“һ рқ’ҹ.K))) : Set (Ideal (рқ“һ рқ’ҹ.K))) := by
      exact hрқ”“
    rw [coe_primesOverFinset (p := p) hp0 (B := рқ“һ рқ’ҹ.K)] at hрқ”“set
    rcases hsplitK рқ”“ hрқ”“set with вҹЁhрқ”“e, hрқ”“fвҹ©
    rw [hрқ”“e, hрқ”“f]
  have hsum :
      вҲ‘ рқ”“ вҲҲ primesOverFinset p (рқ“һ рқ’ҹ.K),
        Ideal.ramificationIdx p рқ”“ * Ideal.inertiaDeg p рқ”“ = Module.finrank в„ҡ рқ’ҹ.K := by
    exact Ideal.sum_ramification_inertia (S := рқ“һ рқ’ҹ.K) (K := в„ҡ) (L := рқ’ҹ.K) (p := p) hp0
  have hcard_finset : (primesOverFinset p (рқ“һ рқ’ҹ.K)).card = Module.finrank в„ҡ рқ’ҹ.K := by
    calc
      (primesOverFinset p (рқ“һ рқ’ҹ.K)).card =
          вҲ‘ рқ”“ вҲҲ primesOverFinset p (рқ“һ рқ’ҹ.K), 1 := by
        exact Finset.card_eq_sum_ones _
      _ = вҲ‘ рқ”“ вҲҲ primesOverFinset p (рқ“һ рқ’ҹ.K),
            Ideal.ramificationIdx p рқ”“ * Ideal.inertiaDeg p рқ”“ := by
        refine Finset.sum_congr rfl ?_
        intro рқ”“ hрқ”“
        symm
        exact hsummand рқ”“ hрқ”“
      _ = Module.finrank в„ҡ рқ’ҹ.K := hsum
  calc
    (p.primesOver (рқ“һ рқ’ҹ.K)).ncard = ((primesOverFinset p (рқ“һ рқ’ҹ.K) : Finset (Ideal (рқ“һ рқ’ҹ.K))) : Set (Ideal (рқ“һ рқ’ҹ.K))).ncard := by
      rw [вҶҗ coe_primesOverFinset (p := p) hp0 (B := рқ“һ рқ’ҹ.K)]
    _ = (primesOverFinset p (рқ“һ рқ’ҹ.K)).card := Set.ncard_coe_finset _
    _ = Module.finrank в„ҡ рқ’ҹ.K := hcard_finset

theorem rootDiscr_eq_of_everywhereUnramified (F L : Type) [Field F] [Field L] [NumberField F] [NumberField L]
    [Algebra F L] (_hunr : IsEverywhereUnramified F L) :
    NumberField.rootDiscr L = NumberField.rootDiscr F := by
  have hdisc_nat := IsEverywhereUnramified.discr_eq _hunr
  have hdisc : ((|NumberField.discr L| : в„Ө) : в„қ) = (((|NumberField.discr F| : в„Ө) : в„қ) ^ Module.finrank F L) := by
    calc
      ((|NumberField.discr L| : в„Ө) : в„қ) = ((NumberField.discr L).natAbs : в„қ) := by
        rw [Nat.cast_natAbs]
      _ = (((NumberField.discr F).natAbs : в„қ) ^ Module.finrank F L) := by
        exact_mod_cast hdisc_nat
      _ = (((|NumberField.discr F| : в„Ө) : в„қ) ^ Module.finrank F L) := by
        rw [Nat.cast_natAbs]
  rw [NumberField.rootDiscr_def, NumberField.rootDiscr_def, hdisc]
  rw [вҶҗ Real.rpow_natCast_mul (by positivity : 0 вүӨ ((|NumberField.discr F| : в„Ө) : в„қ))]
  congr 1
  have hmul : (Module.finrank в„ҡ F : в„қ) * Module.finrank F L = Module.finrank в„ҡ L := by
    exact_mod_cast Module.finrank_mul_finrank в„ҡ F L
  have hF : (Module.finrank в„ҡ F : в„қ) вү  0 := by
    exact Nat.cast_ne_zero.mpr (ne_of_gt (Module.finrank_pos : 0 < Module.finrank в„ҡ F))
  have hFL : (Module.finrank F L : в„қ) вү  0 := by
    exact Nat.cast_ne_zero.mpr (ne_of_gt (Module.finrank_pos : 0 < Module.finrank F L))
  calc
    (Module.finrank F L : в„қ) * (Module.finrank в„ҡ L : в„қ)вҒ»В№ = (Module.finrank F L : в„қ) / Module.finrank в„ҡ L := by
      rw [div_eq_mul_inv]

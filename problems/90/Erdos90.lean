theorem pow_two_partial_sum_avg_succ_lower_bound {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    вҲҖ n : в„•,
      (вҲ‘ k вҲҲ Finset.range (2 ^ n), f k) / (2 ^ (n + 1) : в„қ) вүӨ
        (вҲ‘ k вҲҲ Finset.range (2 ^ (n + 1)), f k) / (2 ^ (n + 1) : в„қ) := by
  intro hnonneg n
  have hsum : вҲ‘ k вҲҲ Finset.range (2 ^ n), f k вүӨ вҲ‘ k вҲҲ Finset.range (2 ^ (n + 1)), f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnonneg
    В· intro k hk
      exact Finset.mem_range.mpr (by
        have hk' : k < 2 ^ n := Finset.mem_range.mp hk
        have hpow : 2 ^ n вүӨ 2 ^ (n + 1) := by
          exact Nat.pow_le_pow_right (by decide) (Nat.le_add_right n 1)
        exact lt_of_lt_of_le hk' hpow)
    В· intro k hk hknmem
      exact hnonneg k
  have hpos : 0 < (2 ^ (n + 1) : в„қ) := by
    positivity
  simpa [div_eq_mul_inv] using
    mul_le_mul_of_nonneg_right hsum (inv_nonneg.mpr (le_of_lt hpos))

theorem pow_two_partial_sum_avg_le_of_le {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    вҲҖ {j n : в„•}, j вүӨ n вҶ’
      (вҲ‘ k вҲҲ Finset.range (2 ^ j), f k) / (2 ^ j : в„қ) вүӨ
        (2 : в„қ) ^ (n - j) * (вҲ‘ k вҲҲ Finset.range (2 ^ n), f k) / (2 ^ n : в„қ) := by
  intro hnonneg j n hjn
  let A : в„• вҶ’ в„қ := fun m => (вҲ‘ k вҲҲ Finset.range (2 ^ m), f k) / (2 ^ m : в„қ)
  have hEq : вҲҖ m : в„•, A m = (2 : в„қ) * ((вҲ‘ k вҲҲ Finset.range (2 ^ m), f k) / (2 ^ (m + 1) : в„қ)) := by
    intro m
    dsimp [A]
    rw [pow_succ]
    field_simp
  have hstep : вҲҖ m : в„•, A m вүӨ (2 : в„қ) * A (m + 1) := by
    intro m
    calc
      A m = (2 : в„қ) * ((вҲ‘ k вҲҲ Finset.range (2 ^ m), f k) / (2 ^ (m + 1) : в„қ)) := hEq m
      _ вүӨ (2 : в„қ) * ((вҲ‘ k вҲҲ Finset.range (2 ^ (m + 1)), f k) / (2 ^ (m + 1) : в„қ)) := by
        exact mul_le_mul_of_nonneg_left (pow_two_partial_sum_avg_succ_lower_bound hnonneg m) (by positivity)
      _ = (2 : в„қ) * A (m + 1) := by rfl
  have hpow : вҲҖ d : в„•, A j вүӨ (2 : в„қ) ^ d * A (j + d) := by
    intro d
    induction d with
    | zero =>
        simpa only [pow_zero, Nat.add_zero, one_mul] using (le_rfl : A j вүӨ A j)
    | succ d ih =>
        have hmul : (2 : в„қ) ^ d * A (j + d) вүӨ (2 : в„қ) ^ d * ((2 : в„қ) * A (j + d + 1)) := by
          exact mul_le_mul_of_nonneg_left (hstep (j + d)) (by positivity)
        calc
          A j вүӨ (2 : в„қ) ^ d * A (j + d) := ih
          _ вүӨ (2 : в„қ) ^ d * ((2 : в„қ) * A (j + d + 1)) := hmul
          _ = ((2 : в„қ) ^ d * (2 : в„қ)) * A (j + d + 1) := by rw [mul_assoc]
          _ = (2 : в„қ) ^ (d + 1) * A (j + d + 1) := by rw [pow_succ]
  have hmain := hpow (n - j)
  have hadd : j + (n - j) = n := Nat.add_sub_of_le hjn
  calc
    (вҲ‘ k вҲҲ Finset.range (2 ^ j), f k) / (2 ^ j : в„қ) = A j := by rfl
    _ вүӨ (2 : в„қ) ^ (n - j) * A (j + (n - j)) := hmain
    _ = (2 : в„қ) ^ (n - j) * A n := by rw [hadd]
    _ = (2 : в„қ) ^ (n - j) * ((вҲ‘ k вҲҲ Finset.range (2 ^ n), f k) / (2 ^ n : в„қ)) := by rfl
    _ = (2 : в„қ) ^ (n - j) * (вҲ‘ k вҲҲ Finset.range (2 ^ n), f k) / (2 ^ n : в„қ) := by
      rw [mul_div_assoc]


theorem h1TrivialCyclesEval_hom (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (N : Subgroup G) [N.Normal] (x : (h1TrivialHomogeneousCochains p G N).cycles 1) : (h1TrivialCyclesEval p G N x) 1 = 0 ∧ ∀ g h : ↥N, h1TrivialCyclesEval p G N x (g * h) = h1TrivialCyclesEval p G N x g + h1TrivialCyclesEval p G N x h := by
  constructor
  · have h1 := h1TrivialCyclesLift_cocycle p G N x (1 : ↥N) (1 : ↥N) (1 : ↥N)
    simpa [h1TrivialCyclesLift_apply_eq_eval] using h1
  · intro g h
    have hgh :
        (h1TrivialCyclesEval p G N x) h - (h1TrivialCyclesEval p G N x) (g * h) +
            (h1TrivialCyclesEval p G N x) g = 0 := by
      simpa [h1TrivialCyclesLift_apply_eq_eval, mul_assoc] using
        h1TrivialCyclesLift_cocycle p G N x (1 : ↥N) g (g * h)
    have hgh' :
        ((h1TrivialCyclesEval p G N x) h + (h1TrivialCyclesEval p G N x) g) -
            (h1TrivialCyclesEval p G N x) (g * h) = 0 := by
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hgh
    have hgh'' :
        (h1TrivialCyclesEval p G N x) h + (h1TrivialCyclesEval p G N x) g =
            (h1TrivialCyclesEval p G N x) (g * h) := sub_eq_zero.mp hgh'
    simpa [add_comm] using hgh''.symm

open CategoryTheory in
theorem h1TrivialCyclesEquiv_exists (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (N : Subgroup G) [N.Normal] : ∃ e_cycles : (h1TrivialHomogeneousCochains p G N).cycles 1 → (↥N →ₜ* Multiplicative (ZMod p)), Function.Injective e_cycles ∧ ∀ (n : G) (x : (h1TrivialHomogeneousCochains p G N).cycles 1) (y : ↥N), e_cycles ((HomologicalComplex.cyclesMap (h1ConjCochainsMap p G N n) 1) x) y = e_cycles x ((MulAut.conjNormal n⁻¹) y) := by
  classical
  let e_cycles : (h1TrivialHomogeneousCochains p G N).cycles 1 → (↥N →ₜ* Multiplicative (ZMod p)) := fun x =>
    { toFun := fun y => Multiplicative.ofAdd (h1TrivialCyclesEval p G N x y)
      map_one' := by
        simpa using (h1TrivialCyclesEval_hom p G N x).1
      map_mul' := by
        intro g h
        simpa using (h1TrivialCyclesEval_hom p G N x).2 g h
      continuous_toFun := (h1TrivialCyclesEval p G N x).continuous_toFun }
  refine ⟨e_cycles, ?_, ?_⟩
  · intro x x' h
    apply h1TrivialCyclesEval_injective p G N
    ext y
    have hy := congrArg (fun f : ↥N →ₜ* Multiplicative (ZMod p) => f y) h
    exact congrArg Multiplicative.toAdd hy
  · intro n x y
    change Multiplicative.ofAdd
        (h1TrivialCyclesEval p G N ((HomologicalComplex.cyclesMap (h1ConjCochainsMap p G N n) 1) x) y) =
      Multiplicative.ofAdd (h1TrivialCyclesEval p G N x ((MulAut.conjNormal n⁻¹) y))
    simpa using h1TrivialCyclesEval_natural p G N n x y

open CategoryTheory in
theorem h1TrivialEquiv_natural (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (N : Subgroup G) [N.Normal] : ∃ e : H1ContsTrivial p G N → (↥N →ₜ* Multiplicative (ZMod p)), Function.Injective e ∧ ∀ (n : G) (x : H1ContsTrivial p G N) (y : ↥N), e ((h1ConjMap p G N n).hom x) y = e x ((MulAut.conjNormal n⁻¹) y) := by
  classical
  let K := h1TrivialHomogeneousCochains p G N
  rcases h1TrivialCyclesEquiv_exists p G N with ⟨e_cycles, heinj_cycles, he_cycles⟩
  let e_homology : H1ContsTrivial p G N ≃ K.cycles 1 :=
    (CategoryTheory.Iso.toContinuousLinearEquiv
      ((HomologicalComplex.isoHomologyπ K 0 1 (CochainComplex.prev_nat_succ 0)
        (h1TrivialHomogeneous_d01_eq_zero p G N)).symm)).toLinearEquiv.toEquiv
  refine ⟨fun x => e_cycles (e_homology x), ?_, ?_⟩
  · intro x x' h
    apply e_homology.injective
    exact heinj_cycles h
  · intro n x y
    have hnat : HomologicalComplex.homologyMap (h1ConjCochainsMap p G N n) 1 ≫
        (HomologicalComplex.isoHomologyπ (h1TrivialHomogeneousCochains p G N) 0 1
          (CochainComplex.prev_nat_succ 0)
          (h1TrivialHomogeneous_d01_eq_zero p G N)).inv =
      (HomologicalComplex.isoHomologyπ (h1TrivialHomogeneousCochains p G N) 0 1
          (CochainComplex.prev_nat_succ 0)
          (h1TrivialHomogeneous_d01_eq_zero p G N)).inv ≫
        HomologicalComplex.cyclesMap (h1ConjCochainsMap p G N n) 1 := by
      simp only [← cancel_epi ((h1TrivialHomogeneousCochains p G N).homologyπ 1),
        HomologicalComplex.homologyπ_naturality_assoc,
        HomologicalComplex.isoHomologyπ_hom_inv_id, Category.comp_id,
        HomologicalComplex.isoHomologyπ_hom_inv_id_assoc]
    have hmap := congrArg (fun f => (TopModuleCat.Hom.hom f) x) hnat
    change e_cycles (e_homology ((h1ConjMap p G N n).hom x)) y = e_cycles (e_homology x) ((MulAut.conjNormal n⁻¹) y)
    rw [show e_homology ((h1ConjMap p G N n).hom x) =
        (HomologicalComplex.cyclesMap (h1ConjCochainsMap p G N n) 1).hom (e_homology x) by
      simpa [e_homology, K, h1ConjMap, h1ConjCochainsMap] using hmap]
    exact he_cycles n (e_homology x) y

open CategoryTheory in
theorem h1ConjMap_eq_id_of_mem (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (N : Subgroup G) [N.Normal] (n : G) (hn : n ∈ N) : h1ConjMap p G N n = 𝟙 (H1ContsTrivial p G N) := by
  rcases h1TrivialEquiv_natural p G N with ⟨e, heinj, he⟩
  ext x
  apply heinj
  ext y
  rw [he n x y]
  exact continuousMonoidHom_innerConj_eq_self p G N n hn (e x) y

open CategoryTheory in
theorem N_acts_trivially (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (N : Subgroup G) [N.Normal] (n : G) (hn : n ∈ N) : h1ConjAction p G N n = LinearEquiv.refl (ZMod p) (H1ContsTrivial p G N) := by
  ext x
  change h1ConjAction p G N n x = x
  rw [h1ConjAction_apply]
  simpa using
    congrArg
      (fun f : H1ContsTrivial p G N ⟶ H1ContsTrivial p G N => f.hom x)
      (h1ConjMap_eq_id_of_mem p G N n hn)

end H1ConjugationInternal

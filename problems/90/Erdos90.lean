theorem pow_two_partial_sum_avg_succ_lower_bound {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    ∀ n : ℕ,
      (∑ k ∈ Finset.range (2 ^ n), f k) / (2 ^ (n + 1) : ℝ) ≤
        (∑ k ∈ Finset.range (2 ^ (n + 1)), f k) / (2 ^ (n + 1) : ℝ) := by
  intro hnonneg n
  have hsum : ∑ k ∈ Finset.range (2 ^ n), f k ≤ ∑ k ∈ Finset.range (2 ^ (n + 1)), f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnonneg
    · intro k hk
      exact Finset.mem_range.mpr (by
        have hk' : k < 2 ^ n := Finset.mem_range.mp hk
        have hpow : 2 ^ n ≤ 2 ^ (n + 1) := by
          exact Nat.pow_le_pow_right (by decide) (Nat.le_add_right n 1)
        exact lt_of_lt_of_le hk' hpow)
    · intro k hk hknmem
      exact hnonneg k
  have hpos : 0 < (2 ^ (n + 1) : ℝ) := by
    positivity
  simpa [div_eq_mul_inv] using
    mul_le_mul_of_nonneg_right hsum (inv_nonneg.mpr (le_of_lt hpos))

theorem pow_two_partial_sum_avg_le_of_le {f : ℕ → ℝ} :
    (∀ n, 0 ≤ f n) →
    ∀ {j n : ℕ}, j ≤ n →
      (∑ k ∈ Finset.range (2 ^ j), f k) / (2 ^ j : ℝ) ≤
        (2 : ℝ) ^ (n - j) * (∑ k ∈ Finset.range (2 ^ n), f k) / (2 ^ n : ℝ) := by
  intro hnonneg j n hjn
  let A : ℕ → ℝ := fun m => (∑ k ∈ Finset.range (2 ^ m), f k) / (2 ^ m : ℝ)
  have hEq : ∀ m : ℕ, A m = (2 : ℝ) * ((∑ k ∈ Finset.range (2 ^ m), f k) / (2 ^ (m + 1) : ℝ)) := by
    intro m
    dsimp [A]
    rw [pow_succ]
    field_simp
  have hstep : ∀ m : ℕ, A m ≤ (2 : ℝ) * A (m + 1) := by
    intro m
    calc
      A m = (2 : ℝ) * ((∑ k ∈ Finset.range (2 ^ m), f k) / (2 ^ (m + 1) : ℝ)) := hEq m
      _ ≤ (2 : ℝ) * ((∑ k ∈ Finset.range (2 ^ (m + 1)), f k) / (2 ^ (m + 1) : ℝ)) := by
        exact mul_le_mul_of_nonneg_left (pow_two_partial_sum_avg_succ_lower_bound hnonneg m) (by positivity)
      _ = (2 : ℝ) * A (m + 1) := by rfl
  have hpow : ∀ d : ℕ, A j ≤ (2 : ℝ) ^ d * A (j + d) := by
    intro d
    induction d with
    | zero =>
        simpa only [pow_zero, Nat.add_zero, one_mul] using (le_rfl : A j ≤ A j)
    | succ d ih =>
        have hmul : (2 : ℝ) ^ d * A (j + d) ≤ (2 : ℝ) ^ d * ((2 : ℝ) * A (j + d + 1)) := by
          exact mul_le_mul_of_nonneg_left (hstep (j + d)) (by positivity)
        calc
          A j ≤ (2 : ℝ) ^ d * A (j + d) := ih
          _ ≤ (2 : ℝ) ^ d * ((2 : ℝ) * A (j + d + 1)) := hmul
          _ = ((2 : ℝ) ^ d * (2 : ℝ)) * A (j + d + 1) := by rw [mul_assoc]
          _ = (2 : ℝ) ^ (d + 1) * A (j + d + 1) := by rw [pow_succ]
  have hmain := hpow (n - j)
  have hadd : j + (n - j) = n := Nat.add_sub_of_le hjn
  calc
    (∑ k ∈ Finset.range (2 ^ j), f k) / (2 ^ j : ℝ) = A j := by rfl
    _ ≤ (2 : ℝ) ^ (n - j) * A (j + (n - j)) := hmain
    _ = (2 : ℝ) ^ (n - j) * A n := by rw [hadd]
    _ = (2 : ℝ) ^ (n - j) * ((∑ k ∈ Finset.range (2 ^ n), f k) / (2 ^ n : ℝ)) := by rfl
    _ = (2 : ℝ) ^ (n - j) * (∑ k ∈ Finset.range (2 ^ n), f k) / (2 ^ n : ℝ) := by
      rw [mul_div_assoc]


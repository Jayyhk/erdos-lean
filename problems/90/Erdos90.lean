theorem prop38_burnside_basis (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : в„•) [Fact (Nat.Prime p)]
    (_hG : IsFinitelyGeneratedProPGroup p G)
    (k : в„•)
    (Q : Type) [AddCommGroup Q] [Module (ZMod p) Q]
    [TopologicalSpace Q] [DiscreteTopology Q]
    (_hQrank : Module.finrank (ZMod p) Q = k)
    (ПҶ : G вҶ’* Multiplicative Q)
    (_hПҶ_surj : Function.Surjective ПҶ)
    (_hПҶ_cont : Continuous ПҶ)
    : k вүӨ generatorRank G := by
  rcases Nat.eq_zero_or_pos k with rfl | hk
  В· exact Nat.zero_le _
  В· rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hk) with вҹЁn, rflвҹ©
    have hfinrank : Module.finrank (ZMod p) Q = n.succ := _hQrank
    haveI : FiniteDimensional (ZMod p) Q := FiniteDimensional.of_finrank_eq_succ hfinrank
    classical
    rw [generatorRank]
    apply le_csInf
    В· rcases _hG.1 with вҹЁS, hSвҹ©
      exact вҹЁS.card, вҹЁS, rfl, hSвҹ©вҹ©
    В· intro m hm
      rcases hm with вҹЁS, rfl, hSвҹ©
      have h_dense : (Subgroup.closure (ПҶ '' (S : Set G))).topologicalClosure = вҠӨ := by
        have hmap := DenseRange.topologicalClosure_map_subgroup (f := ПҶ) _hПҶ_cont (_hПҶ_surj.denseRange) hS
        simpa [MonoidHom.map_closure] using hmap
      have h_closure : Subgroup.closure (ПҶ '' (S : Set G)) = вҠӨ := by
        apply top_unique
        intro x hx
        have : x вҲҲ ((Subgroup.closure (ПҶ '' (S : Set G))).topologicalClosure : Set (Multiplicative Q)) := by
          rw [h_dense]
          simp
        rwa [Subgroup.topologicalClosure_coe, closure_discrete] at this
      let T : Finset Q := S.image fun g => (ПҶ g).toAdd
      have h_span_top : Submodule.span (ZMod p) (T : Set Q) = вҠӨ := by
        apply top_unique
        intro q hq
        let K : Subgroup (Multiplicative Q) :=
          { carrier := {x | x.toAdd вҲҲ Submodule.span (ZMod p) (T : Set Q)}
            one_mem' := by
              change (0 : Q) вҲҲ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.zero_mem _
            mul_mem' := by
              intro x y hx hy
              change x.toAdd + y.toAdd вҲҲ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.add_mem _ hx hy
            inv_mem' := by
              intro x hx
              change -x.toAdd вҲҲ Submodule.span (ZMod p) (T : Set Q)
              exact Submodule.neg_mem _ hx }
        have hK : Subgroup.closure (ПҶ '' (S : Set G)) вүӨ K := by
          rw [Subgroup.closure_le]
          intro x hx
          rcases hx with вҹЁg, hg, rflвҹ©
          change (ПҶ g).toAdd вҲҲ Submodule.span (ZMod p) (T : Set Q)
          apply Submodule.subset_span
          simpa [T] using Finset.mem_image_of_mem (fun g => (ПҶ g).toAdd) hg
        have hqK : Multiplicative.ofAdd q вҲҲ K := by
          have hq_closure : Multiplicative.ofAdd q вҲҲ Subgroup.closure (ПҶ '' (S : Set G)) := by
            rw [h_closure]
            simp
          exact hK hq_closure
        simpa [K] using hqK
      have h_finrank_sub : Module.finrank (ZMod p) (Submodule.span (ZMod p) (T : Set Q)) вүӨ T.card := by
        simpa [T, Set.finrank] using (finrank_span_finset_le_card (R := ZMod p) T)
      have h_finrank_le : Module.finrank (ZMod p) Q вүӨ T.card := by
        rw [вҶҗ finrank_top (R := ZMod p) (M := Q)]
        rw [вҶҗ h_span_top]
        exact h_finrank_sub
      calc
        n.succ = Module.finrank (ZMod p) Q := hfinrank.symm
        _ вүӨ T.card := h_finrank_le
        _ вүӨ S.card := by
          simpa [T] using (Finset.card_image_le (s := S) (f := fun g => (ПҶ g).toAdd))

theorem prop38_killed_frobenius_splits (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))

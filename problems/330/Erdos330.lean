        (show 0 < m a from (Fact.out : Nat.Prime (m a)).pos) hm_pos hM
    _ = (1 : ℝ) / (m a : ℝ) *
          (P.erase a).prod (fun b => 1 - (1 : ℝ) / (m b : ℝ)) := by
      congr 1
      rw [← Finset.prod_subtype (s := P.erase a) (p := fun b => b ∈ P.erase a)
        (f := fun b => 1 - (1 : ℝ) / (m b : ℝ))]

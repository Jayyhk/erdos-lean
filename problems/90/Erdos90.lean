          ∑ 𝔓 ∈ primesOverFinset p (𝓞 𝒟.K), 1 := by
        exact Finset.card_eq_sum_ones _
      _ = ∑ 𝔓 ∈ primesOverFinset p (𝓞 𝒟.K),
            Ideal.ramificationIdx p 𝔓 * Ideal.inertiaDeg p 𝔓 := by
        refine Finset.sum_congr rfl ?_

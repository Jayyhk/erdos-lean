        exact_mod_cast h_block
      rw [← h_block_R, h_count_eq]
      exact h_finset_le_strong
    -- Substitute (M/d)/b = M/(d·b) into h_combine:
    --   (M/(d·b)) · count_Pb ≤ y^{-c}/(2d) · M + M_d.
    -- Multiply both sides by (d·b/M):

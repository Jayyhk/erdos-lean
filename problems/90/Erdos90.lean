    refine intervalIntegral.integral_congr ?_
    intro x hx
    have hx' : x вҲҲ Set.Icc (-1 : в„қ) 0 := by
      simpa [Set.uIcc_of_le (show (-1 : в„қ) вүӨ 0 by norm_num)] using hx
    have hx'' : -1 вүӨ x вҲ§ x вүӨ 0 := by
      simpa [Set.mem_Icc] using hx'
    simp [leftTentKernel, hx'']
  rw [hcongr]
  rw [intervalIntegral.integral_ofReal]
  have hfi1 : IntervalIntegrable (fun u : в„қ => 2 * u) MeasureTheory.volume (-1 : в„қ) 0 := by
    apply Continuous.intervalIntegrable
    continuity
  have hfi2 : IntervalIntegrable (fun _ : в„қ => (2 : в„қ)) MeasureTheory.volume (-1 : в„қ) 0 := by
    apply Continuous.intervalIntegrable
    continuity
  have hcalc : вҲ« u in (-1 : в„қ)..0, (2 * (u + 1) : в„қ) = 1 := by
    calc
      вҲ« u in (-1 : в„қ)..0, (2 * (u + 1) : в„қ)
          = вҲ« u in (-1 : в„қ)..0, (2 * u + 2 : в„қ) := by
              refine intervalIntegral.integral_congr ?_
              intro u hu
              ring
      _ = (вҲ« u in (-1 : в„қ)..0, (2 * u : в„қ)) + вҲ« u in (-1 : в„қ)..0, (2 : в„қ) := by
            rw [intervalIntegral.integral_add hfi1 hfi2]
      _ = 2 * (вҲ« u in (-1 : в„қ)..0, (u : в„қ)) + вҲ« u in (-1 : в„қ)..0, (2 : в„қ) := by
            rw [intervalIntegral.integral_const_mul]
      _ = 2 * (((0 : в„қ) ^ 2 - (-1 : в„қ) ^ 2) / 2) + вҲ« u in (-1 : в„қ)..0, (2 : в„қ) := by
            rw [integral_id]
      _ = 2 * (((0 : в„қ) ^ 2 - (-1 : в„қ) ^ 2) / 2) + ((0 : в„қ) - (-1 : в„қ)) вҖў (2 : в„қ) := by
            rw [intervalIntegral.integral_const]
      _ = 1 := by
            norm_num
  exact_mod_cast hcalc

theorem compactFreqKernel_convolution_leftTent {Оә : в„қ вҶ’ в„Ӯ} :
  CompactFreqKernel Оә вҶ’
  CompactFreqKernel (leftTentConvolution Оә) := by
  intro hОә
  rw [leftTentConvolution_eq_convolution]
  rcases compactFreqKernel_bounded hОә with вҹЁCОә, _, hОәbdвҹ©
  have hBdd : BddAbove (Set.range fun x => вҖ–Оә xвҖ–) := by
    refine вҹЁCОә, ?_вҹ©
    rintro _ вҹЁx, rflвҹ©
    exact hОәbd x
  have h_int :
      MeasureTheory.Integrable
        (MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
          MeasureTheory.volume) := by
    simpa using
      (MeasureTheory.Integrable.integrable_convolution
        (L := ContinuousLinearMap.mul в„Ӯ в„Ӯ) hОә.integrable leftTentKernel_integrable)
  have hmul : Continuous fun p : в„қ Г— в„қ => (LinearMap.mul в„қ в„қ) p.1 p.2 := by
    simpa using (continuous_fst.mul continuous_snd)
  have hphase_conv (w : в„қ) :
      (fun x : в„қ =>
        (Real.fourierChar (-(x * w)) : в„Ӯ) *
          MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
            MeasureTheory.volume x) =
        MeasureTheory.convolution
          (fun t : в„қ => (Real.fourierChar (-(t * w)) : в„Ӯ) * Оә t)
          (fun s : в„қ => (Real.fourierChar (-(s * w)) : в„Ӯ) * leftTentKernel s)
          (ContinuousLinearMap.mul в„Ӯ в„Ӯ) MeasureTheory.volume := by
    ext x
    calc
      (Real.fourierChar (-(x * w)) : в„Ӯ) *
          MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
            MeasureTheory.volume x
        = (Real.fourierChar (-(x * w)) : в„Ӯ) *
            вҲ« t : в„қ, Оә t * leftTentKernel (x - t) := by
              rw [MeasureTheory.convolution_mul]
      _ = вҲ« t : в„қ, (Real.fourierChar (-(x * w)) : в„Ӯ) * (Оә t * leftTentKernel (x - t)) := by
            simpa using
              (MeasureTheory.integral_const_mul
                (Ој := MeasureTheory.volume)
                (r := (Real.fourierChar (-(x * w)) : в„Ӯ))
                (f := fun t : в„қ => Оә t * leftTentKernel (x - t))).symm
      _ = вҲ« t : в„қ,
            ((Real.fourierChar (-(t * w)) : в„Ӯ) * Оә t) *
              (((Real.fourierChar (-((x - t) * w)) : в„Ӯ)) * leftTentKernel (x - t)) := by
            apply MeasureTheory.integral_congr_ae
            filter_upwards with t
            have hphase_circle :
                Real.fourierChar (-(x * w)) =
                  Real.fourierChar (-(t * w)) *
                    Real.fourierChar (-((x - t) * w)) := by
              calc
                Real.fourierChar (-(x * w))
                    = Real.fourierChar (-(t * w) + -((x - t) * w)) := by
                        congr 1
                        ring
                _ = Real.fourierChar (-(t * w)) *
                    Real.fourierChar (-((x - t) * w)) := by
                      simpa using
                        (AddChar.map_add_eq_mul Real.fourierChar (-(t * w))
                          (-((x - t) * w)))
            have hphase :
                (Real.fourierChar (-(x * w)) : в„Ӯ) =
                  (Real.fourierChar (-(t * w)) : в„Ӯ) *
                    (Real.fourierChar (-((x - t) * w)) : в„Ӯ) := by
              simpa using congrArg (fun z : Circle => (z : в„Ӯ)) hphase_circle
            calc
              (Real.fourierChar (-(x * w)) : в„Ӯ) * (Оә t * leftTentKernel (x - t))
                  = ((Real.fourierChar (-(t * w)) : в„Ӯ) *
                      (Real.fourierChar (-((x - t) * w)) : в„Ӯ)) *
                    (Оә t * leftTentKernel (x - t)) := by
                      rw [hphase]
              _ = ((Real.fourierChar (-(t * w)) : в„Ӯ) * Оә t) *
                    (((Real.fourierChar (-((x - t) * w)) : в„Ӯ)) * leftTentKernel (x - t)) := by
                    ring
      _ = MeasureTheory.convolution
            (fun t : в„қ => (Real.fourierChar (-(t * w)) : в„Ӯ) * Оә t)
            (fun s : в„қ => (Real.fourierChar (-(s * w)) : в„Ӯ) * leftTentKernel s)
            (ContinuousLinearMap.mul в„Ӯ в„Ӯ) MeasureTheory.volume x := by
            rw [MeasureTheory.convolution_mul]
  have hFourier_conv :
      FourierTransform.fourier
        (MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
          MeasureTheory.volume) =
        (FourierTransform.fourier Оә) * (FourierTransform.fourier leftTentKernel) := by
    ext w
    have hОәw' :
        MeasureTheory.Integrable
          (fun x : в„қ => Real.fourierChar (-(x * w)) вҖў Оә x) := by
      exact
        (VectorFourier.fourierIntegral_convergent_iff
          (e := Real.fourierChar) (Ој := MeasureTheory.volume) (L := LinearMap.mul в„қ в„қ)
          Real.continuous_fourierChar hmul (f := Оә) w).2 hОә.integrable
    have hОәw : MeasureTheory.Integrable (fun x : в„қ => (Real.fourierChar (-(x * w)) : в„Ӯ) * Оә x) := by
      simpa [Circle.smul_def, smul_eq_mul] using hОәw'
    have htw' :
        MeasureTheory.Integrable
          (fun x : в„қ => Real.fourierChar (-(x * w)) вҖў leftTentKernel x) := by
      exact
        (VectorFourier.fourierIntegral_convergent_iff
          (e := Real.fourierChar) (Ој := MeasureTheory.volume) (L := LinearMap.mul в„қ в„қ)
          Real.continuous_fourierChar hmul (f := leftTentKernel) w).2 leftTentKernel_integrable
    have htw : MeasureTheory.Integrable
        (fun x : в„қ => (Real.fourierChar (-(x * w)) : в„Ӯ) * leftTentKernel x) := by
      simpa [Circle.smul_def, smul_eq_mul] using htw'
    calc
      FourierTransform.fourier
          (MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
            MeasureTheory.volume) w
        = вҲ« x : в„қ, (Real.fourierChar (-(x * w)) : в„Ӯ) *
            MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
              MeasureTheory.volume x := by
              rw [Real.fourier_real_eq]
              apply MeasureTheory.integral_congr_ae
              filter_upwards with x
              simp [Circle.smul_def, smul_eq_mul]
      _ = вҲ« x : в„қ,
            MeasureTheory.convolution
              (fun t : в„қ => (Real.fourierChar (-(t * w)) : в„Ӯ) * Оә t)
              (fun s : в„қ => (Real.fourierChar (-(s * w)) : в„Ӯ) * leftTentKernel s)
              (ContinuousLinearMap.mul в„Ӯ в„Ӯ) MeasureTheory.volume x := by
            apply MeasureTheory.integral_congr_ae
            filter_upwards with x
            exact congrFun (hphase_conv w) x
      _ = FourierTransform.fourier Оә w * FourierTransform.fourier leftTentKernel w := by
            simpa [Real.fourier_real_eq, Circle.smul_def, smul_eq_mul] using
              (MeasureTheory.integral_convolution (L := ContinuousLinearMap.mul в„Ӯ в„Ӯ)
                hОәw htw)
  refine вҹЁ?_, h_int, ?_, ?_, ?_вҹ©
  В· simpa using
      hBdd.continuous_convolution_left_of_integrable
        (L := ContinuousLinearMap.mul в„Ӯ в„Ӯ) (Ој := MeasureTheory.volume)
        hОә.continuous leftTentKernel_integrable
  В· simpa using
      (VectorFourier.fourierIntegral_continuous
        (e := Real.fourierChar) (Ој := MeasureTheory.volume) (L := innerвӮ— в„қ)
        Real.continuous_fourierChar (innerSL в„қ).continuousвӮӮ h_int)
  В· simpa [hFourier_conv] using
      hОә.fourier_compact.mul_right (f' := FourierTransform.fourier leftTentKernel)
  В· calc
      вҲ« u : в„қ,
          MeasureTheory.convolution Оә leftTentKernel (ContinuousLinearMap.mul в„Ӯ в„Ӯ)
            MeasureTheory.volume u
        = (вҲ« u : в„қ, Оә u) * (вҲ« u : в„қ, leftTentKernel u) := by
            simpa using
              (MeasureTheory.integral_convolution (L := ContinuousLinearMap.mul в„Ӯ в„Ӯ)
                hОә.integrable leftTentKernel_integrable)
      _ = 1 := by
            simp [hОә.mass_one, leftTentKernel_mass_one]

theorem leftTentKernel_support_subset: Function.support leftTentKernel вҠҶ Set.Ioc (-1 : в„қ) 0 := by
  intro x hx
  by_cases h : -1 вүӨ x вҲ§ x вүӨ 0
  В· refine вҹЁ?_, h.2вҹ©
    by_contra hxle
    have hxeq : x = -1 := by linarith [h.1, hxle]
    have : leftTentKernel x = 0 := by
      rw [hxeq]
      simp [leftTentKernel]
    exact hx this
  В· exfalso
    exact hx (by simp [leftTentKernel, h])

theorem exists_compactFreqKernel_cutoff_leftTent: вҲғ ПҲ : в„қ вҶ’ в„Ӯ,
    CompactFreqKernel ПҲ вҲ§
    вҲғ О· : в„қ вҶ’ в„Ӯ,
      ContDiff в„қ (вҠӨ : в„•вҲһ) О· вҲ§ HasCompactSupport О· вҲ§ О· 0 = 1 вҲ§
      FourierTransform.fourier ПҲ = fun Оҫ : в„қ => О· Оҫ * FourierTransform.fourier leftTentKernel Оҫ := by
  classical
  have hleft_weighted : вҲҖ n : в„•, MeasureTheory.Integrable (fun v : в„қ => вҖ–vвҖ– ^ n * вҖ–leftTentKernel vвҖ–) := by
    intro n
    let g : в„қ вҶ’ в„қ := fun v => вҖ–vвҖ– ^ n * вҖ–(((2 * (v + 1) : в„қ) : в„Ӯ))вҖ–
    have hg_cont : Continuous g := by
      dsimp [g]
      exact (continuous_norm.pow n).mul ((Complex.ofRealCLM.continuous.comp (continuous_const.mul (continuous_id.add continuous_const))).norm)
    have hg_int : MeasureTheory.IntegrableOn g (Set.Icc (-1 : в„қ) 0) := by
      exact hg_cont.integrableOn_Icc
    have hg_ind : MeasureTheory.Integrable ((Set.Icc (-1 : в„қ) 0).indicator g) := by
      exact hg_int.integrable_indicator measurableSet_Icc
    have h_eq : (fun v : в„қ => вҖ–vвҖ– ^ n * вҖ–leftTentKernel vвҖ–) = (Set.Icc (-1 : в„қ) 0).indicator g := by
      ext v
      by_cases hv : v вҲҲ Set.Icc (-1 : в„қ) 0
      В· have hcond : -1 вүӨ v вҲ§ v вүӨ 0 := by
          simpa [Set.mem_Icc] using hv
        simp [g, leftTentKernel, hv, hcond]
      В· have hcond : В¬ (-1 вүӨ v вҲ§ v вүӨ 0) := by
          simpa [Set.mem_Icc] using hv
        simp [g, leftTentKernel, hv, hcond]
    rw [h_eq]
    exact hg_ind
  have hleft_fourier_smooth : ContDiff в„қ (вҠӨ : в„•вҲһ) (FourierTransform.fourier leftTentKernel) := by
    apply Real.contDiff_fourier
    intro n hn
    exact hleft_weighted n
  have hleft_fourier_zero : FourierTransform.fourier leftTentKernel 0 = 1 := by
    rw [Real.fourier_real_eq]
    simpa using leftTentKernel_mass_one
  obtain вҹЁО·R, hО·R_tsupport, hО·R_cpt, hО·R_smooth, hО·R_range, hО·R_zeroвҹ© :=
    exists_contDiff_tsupport_subset (s := Set.Ioo (-1 : в„қ) 1) (x := (0 : в„қ)) (n := (вҠӨ : в„•вҲһ)) (by
      exact IsOpen.mem_nhds isOpen_Ioo (by constructor <;> norm_num))
  let О· : в„қ вҶ’ в„Ӯ := fun x => (О·R x : в„Ӯ)
  have hО·_smooth : ContDiff в„қ (вҠӨ : в„•вҲһ) О· := by
    simpa [О·] using hО·R_smooth.continuousLinearMap_comp Complex.ofRealCLM
  have hО·_cpt_norm : HasCompactSupport (fun x : в„қ => вҖ–О· xвҖ–) := by
    simpa [О·] using hО·R_cpt.abs
  have hО·_cpt : HasCompactSupport О· := by
    exact hasCompactSupport_norm_iff.mp hО·_cpt_norm
  have hО·_zero : О· 0 = 1 := by
    simpa [О·] using congrArg (fun t : в„қ => (t : в„Ӯ)) hО·R_zero
  let b : в„қ вҶ’ в„Ӯ := fun x => О· x * FourierTransform.fourier leftTentKernel x
  have hb_smooth : ContDiff в„қ (вҠӨ : в„•вҲһ) b := by
    exact hО·_smooth.mul hleft_fourier_smooth
  have hb_cpt : HasCompactSupport b := by
    simpa [b] using hО·_cpt.mul_right (f' := FourierTransform.fourier leftTentKernel)
  have hb_cont : Continuous b := by
    exact hb_smooth.continuous
  have hb_int : MeasureTheory.Integrable b := by
    exact hb_cont.integrable_of_hasCompactSupport hb_cpt
  have hFb_int : MeasureTheory.Integrable (FourierTransform.fourier b) := by
    exact integrable_fourier_of_contDiff_hasCompactSupport b hb_smooth hb_cpt
  have hbneg_smooth : ContDiff в„қ (вҠӨ : в„•вҲһ) (fun x : в„қ => b (-x)) := by
    simpa using hb_smooth.comp (contDiff_const_smul (-1 : в„қ))
  have hbneg_cpt : HasCompactSupport (fun x : в„қ => b (-x)) := by
    simpa using hb_cpt.comp_smul (c := (-1 : в„қ)) (by norm_num)
  have hbneg_cont : Continuous (fun x : в„қ => b (-x)) := by
    exact hbneg_smooth.continuous
  have hbneg_int : MeasureTheory.Integrable (fun x : в„қ => b (-x)) := by
    exact hbneg_cont.integrable_of_hasCompactSupport hbneg_cpt
  let ПҲ : в„қ вҶ’ в„Ӯ := FourierTransform.fourier (fun x : в„қ => b (-x))
  have hПҲ_int : MeasureTheory.Integrable ПҲ := by
    exact integrable_fourier_of_contDiff_hasCompactSupport (fun x : в„қ => b (-x)) hbneg_smooth hbneg_cpt
  have h_inner_cont : Continuous (fun p : в„қ Г— в„қ => ((innerвӮ— в„қ) p.1) p.2) := by
    simpa using (continuous_inner : Continuous (fun p : в„қ Г— в„қ => inner в„қ p.1 p.2))
  have hПҲ_cont : Continuous ПҲ := by
    simpa [ПҲ] using
      (VectorFourier.fourierIntegral_continuous Real.continuous_fourierChar h_inner_cont hbneg_int)
  have hПҲ_eq_inv : ПҲ = FourierTransformInv.fourierInv b := by
    simpa [ПҲ] using (Real.fourierInv_eq_fourier_comp_neg b).symm
  have hПҲ_fourier : FourierTransform.fourier ПҲ = b := by
    rw [hПҲ_eq_inv]
    exact Continuous.fourier_fourierInv_eq hb_cont hb_int hFb_int
  refine вҹЁПҲ, ?_, ?_вҹ©
  В· refine {
      continuous := hПҲ_cont
      integrable := hПҲ_int
      fourier_continuous := ?_
      fourier_compact := ?_
      mass_one := ?_ }
    В· simpa [hПҲ_fourier] using hb_cont
    В· simpa [hПҲ_fourier] using hb_cpt
    В· have hПҲ_fourier_zero : FourierTransform.fourier ПҲ 0 = 1 := by
        calc
          FourierTransform.fourier ПҲ 0 = b 0 := by simpa using congrArg (fun f : в„қ вҶ’ в„Ӯ => f 0) hПҲ_fourier
          _ = О· 0 * FourierTransform.fourier leftTentKernel 0 := by rfl
          _ = 1 := by simp [hО·_zero, hleft_fourier_zero]
      have hfourier_eq_int : FourierTransform.fourier ПҲ 0 = вҲ« u : в„қ, ПҲ u := by
        simpa using (Real.fourier_real_eq ПҲ 0)
      exact hfourier_eq_int.symm.trans hПҲ_fourier_zero
  В· refine вҹЁО·, hО·_smooth, hО·_cpt, hО·_zero, ?_вҹ©
    funext Оҫ
    simpa [b] using congrArg (fun f : в„қ вҶ’ в„Ӯ => f Оҫ) hПҲ_fourier

theorem leftTentKernel_support_subset_Ioi_of_one_le {X : в„қ} (hX : 1 вүӨ X) : Function.support leftTentKernel вҠҶ Set.Ioi (-X) := by
  intro u hu
  have hu' := leftTentKernel_support_subset hu
  have hu_gt : -1 < u := hu'.1
  have hnegX : -X вүӨ -1 := by
    linarith
  exact lt_of_le_of_lt hnegX hu_gt

theorem leftTentKernel_product_support_subset_Ioi_of_one_le {X : в„қ} (hX : 1 вүӨ X) (H : в„қ вҶ’ в„Ӯ) : Function.support (fun u => leftTentKernel u * H u) вҠҶ Set.Ioi (-X) := by
  intro u hu
  have hu' : u вҲҲ Function.support leftTentKernel := by
    rw [Function.mem_support]
    intro h0
    rw [Function.mem_support] at hu
    apply hu
    simp [h0]
  exact leftTentKernel_support_subset_Ioi_of_one_le hX hu'

noncomputable def logRescalePartialSum (f : в„• вҶ’ в„қ) (x : в„қ) : в„қ :=
  if 0 вүӨ x then
    Real.exp (-x) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k)
  else
    0

def HasBoundaryLaplaceExtension (f : в„• вҶ’ в„қ) (b : в„қ) : Prop :=
  вҲғ G : в„Ӯ вҶ’ в„Ӯ,
    ContinuousOn G {z : в„Ӯ | 0 вүӨ z.re} вҲ§
    (вҲҖ z : в„Ӯ, 0 < z.re вҶ’
      MeasureTheory.IntegrableOn
        (fun x : в„қ => (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : в„қ))) вҲ§
    Set.EqOn G
      (fun z : в„Ӯ => вҲ« x in Set.Ioi (0 : в„қ),
        (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
      {z : в„Ӯ | 0 < z.re}

theorem boundary_extension_real_bounded_near_zero {f : в„• вҶ’ в„қ} {b : в„қ} :
  HasBoundaryLaplaceExtension f b вҶ’
  вҲғ Оө M : в„қ, 0 < Оө вҲ§
    вҲҖ Пғ : в„қ, 0 < Пғ вҶ’ Пғ < Оө вҶ’
      Complex.re (вҲ« x in Set.Ioi (0 : в„қ),
        (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-(Пғ : в„Ӯ) * x))) вүӨ M := by
  intro h
  rcases h with вҹЁG, hGcont, hGint, hGeqвҹ©
  let S : Set в„Ӯ := {z : в„Ӯ | 0 вүӨ z.re}
  have h0mem : (0 : в„Ӯ) вҲҲ S := by
    simp [S]
  have hcont0 : ContinuousWithinAt G S 0 := hGcont 0 h0mem
  rcases (Metric.continuousWithinAt_iff.mp hcont0) 1 (by positivity : (0 : в„қ) < 1) with
    вҹЁОө, hОөpos, hОөboundвҹ©
  refine вҹЁОө, вҖ–G 0вҖ– + 1, hОөpos, ?_вҹ©
  intro Пғ hПғpos hПғlt
  have hПғmemS : (Пғ : в„Ӯ) вҲҲ S := by
    simp [S, le_of_lt hПғpos]
  have hПғdist : dist (Пғ : в„Ӯ) 0 < Оө := by
    simpa [dist_eq_norm, RCLike.norm_ofReal, abs_of_pos hПғpos] using hПғlt
  have hGdist : dist (G (Пғ : в„Ӯ)) (G 0) < 1 := hОөbound hПғmemS hПғdist
  have hGnorm : вҖ–G (Пғ : в„Ӯ)вҖ– вүӨ вҖ–G 0вҖ– + 1 := by
    have hdiff : вҖ–G (Пғ : в„Ӯ) - G 0вҖ– < 1 := by
      simpa [dist_eq_norm] using hGdist
    have hdiff' : вҖ–G (Пғ : в„Ӯ) - G 0вҖ– вүӨ 1 := le_of_lt hdiff
    calc
      вҖ–G (Пғ : в„Ӯ)вҖ– = вҖ–(G (Пғ : в„Ӯ) - G 0) + G 0вҖ– := by rw [sub_add_cancel]
      _ вүӨ вҖ–G (Пғ : в„Ӯ) - G 0вҖ– + вҖ–G 0вҖ– := norm_add_le _ _
      _ вүӨ 1 + вҖ–G 0вҖ– := add_le_add hdiff' le_rfl
      _ = вҖ–G 0вҖ– + 1 := by ring
  have hEq :
      G (Пғ : в„Ӯ) = вҲ« x in Set.Ioi (0 : в„қ),
        (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-(Пғ : в„Ӯ) * x)) := by

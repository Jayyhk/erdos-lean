structure CompactFreqKernel (ψ : ℝ → ℂ) : Prop where
  continuous : Continuous ψ
  integrable : MeasureTheory.Integrable ψ
  fourier_continuous : Continuous (FourierTransform.fourier ψ)
  fourier_compact : HasCompactSupport (FourierTransform.fourier ψ)
  mass_one : ∫ u : ℝ, ψ u = 1

noncomputable def centeredTentWeight (t : ℝ) : ℝ :=
  max (0 : ℝ) (2 - 2 * |t - (1 / 2 : ℝ)|)

theorem centeredTentWeight_continuous: Continuous centeredTentWeight := by
  unfold centeredTentWeight
  exact continuous_const.max (by continuity)

theorem centeredTentWeight_le_two (t : ℝ) : centeredTentWeight t ≤ 2 := by
  unfold centeredTentWeight
  refine max_le_iff.mpr ?_
  constructor
  · norm_num
  · have h : 0 ≤ |t - (1 / 2 : ℝ)| := abs_nonneg _
    nlinarith

theorem centeredTentWeight_one_le_on_Icc {t : ℝ} : t ∈ Set.Icc (0 : ℝ) 1 → 1 ≤ centeredTentWeight t := by
  intro ht
  rcases ht with ⟨h0, h1⟩
  have habs : |t - (1 / 2 : ℝ)| ≤ (1 / 2 : ℝ) := by
    rw [abs_le]
    constructor <;> nlinarith
  unfold centeredTentWeight
  have hmain : (1 : ℝ) ≤ 2 - 2 * |t - (1 / 2 : ℝ)| := by
    nlinarith
  exact le_trans hmain (le_max_right _ _)

theorem compactFreqKernel_bounded {κ : ℝ → ℂ} :
  CompactFreqKernel κ →

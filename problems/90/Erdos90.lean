theorem countable_openNormalSubgroup_of_secondCountable {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G] :
    Countable (OpenNormalSubgroup G) := by
  let f : OpenNormalSubgroup G вҶ’ TopologicalSpace.Clopens G := fun H =>
    вҹЁ(H : Set G), OpenSubgroup.isClopen H.toOpenSubgroupвҹ©
  have hclopen : Countable (TopologicalSpace.Clopens G) := by
    simpa using (TopologicalSpace.Clopens.countable_iff_secondCountable (X := G)).2 inferInstance
  have hf : Function.Injective f := by
    intro H K h
    apply OpenNormalSubgroup.toSubgroup_injective
    ext x
    change x вҲҲ ((f H : TopologicalSpace.Clopens G) : Set G) вҶ” x вҲҲ ((f K : TopologicalSpace.Clopens G) : Set G)
    simpa [f] using congrArg (fun s : TopologicalSpace.Clopens G => x вҲҲ (s : Set G)) h
  letI := hclopen
  exact hf.countable

theorem exists_descending_cofinal_openNormalSequence_above {G : Type*} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G] (N : Subgroup G) :
    вҲғ V : в„• вҶ’ OpenNormalSubgroup G,
      (вҲҖ n, N вүӨ (V n : Subgroup G)) вҲ§
      (вҲҖ n, V (n + 1) вүӨ V n) вҲ§
      (вҲҖ U : OpenNormalSubgroup G, N вүӨ (U : Subgroup G) вҶ’ вҲғ n, V n вүӨ U) := by
  classical
  let S : Type _ := {V : OpenNormalSubgroup G // N вүӨ (V : Subgroup G)}
  letI : Countable (OpenNormalSubgroup G) := countable_openNormalSubgroup_of_secondCountable
  letI : Countable S := by
    dsimp [S]
    infer_instance
  let topON : OpenNormalSubgroup G := вҹЁ(вҠӨ : OpenSubgroup G), by
    simp
  вҹ©
  letI : Nonempty S := вҹЁвҹЁtopON, by
    change N вүӨ (вҠӨ : Subgroup G)
    exact le_top
  вҹ©вҹ©
  obtain вҹЁe, hsurjвҹ© := exists_surjective_nat S
  let V : в„• вҶ’ OpenNormalSubgroup G := fun n =>
    Nat.rec (e 0).1 (fun n W => W вҠ“ (e (n + 1)).1) n
  refine вҹЁV, ?_, ?_, ?_вҹ©
  В· intro n
    induction n with
    | zero =>
        exact (e 0).2
    | succ n ihn =>
        intro x hx
        change x вҲҲ (V n вҠ“ (e (n + 1)).1 : OpenNormalSubgroup G)
        exact вҹЁihn hx, (e (n + 1)).2 hxвҹ©
  В· intro n
    change V n вҠ“ (e (n + 1)).1 вүӨ V n
    exact inf_le_left
  В· intro U hNU
    rcases hsurj вҹЁU, hNUвҹ© with вҹЁn, hnвҹ©
    refine вҹЁn, ?_вҹ©
    have hVn : вҲҖ n, V n вүӨ (e n).1 := by
      intro n
      induction n with
      | zero =>
          exact le_rfl
      | succ n ihn =>
          change V n вҠ“ (e (n + 1)).1 вүӨ (e (n + 1)).1
          exact inf_le_right
    simpa [hn] using hVn n

theorem cofinal_openNormalSequence_compatible_family_lift {G X : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [TopologicalSpace X]
    (W : в„• вҶ’ OpenNormalSubgroup G)
    (hWdesc : вҲҖ n, W (n + 1) вүӨ W n)
    (hWcof : вҲҖ U : OpenNormalSubgroup G, вҲғ n, W n вүӨ U)
    (a : вҲҖ n, C(X, G в§ё (W n).toSubgroup))
    (ha : вҲҖ n (x : X),
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + 1)).toSubgroup вүӨ (W n).toSubgroup from hWdesc n)
        (a (n + 1) x) = a n x) :
    вҲғ s : C(X, G), вҲҖ n (x : X),
      QuotientGroup.mk' (W n).toSubgroup (s x) = a n x := by
  classical
  have hWle_add : вҲҖ n k : в„•, (W (n + k)).toSubgroup вүӨ (W n).toSubgroup := by
    intro n k
    induction k with
    | zero =>
        simp
    | succ k ih =>
        have hstep : (W (n + k + 1)).toSubgroup вүӨ (W (n + k)).toSubgroup := by
          simpa [Nat.add_assoc] using (hWdesc (n + k))
        simpa [Nat.add_assoc] using le_trans hstep ih
  have hcompat_add : вҲҖ n k (x : X),
      QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + k)).toSubgroup вүӨ (W n).toSubgroup from hWle_add n k) (a (n + k) x) = a n x := by
    intro n k
    induction k with
    | zero =>
        intro x
        simp
    | succ k ih =>
        intro x
        calc
          QuotientGroup.map (W (n + (k + 1))).toSubgroup (W n).toSubgroup (MonoidHom.id G)
              (show (W (n + (k + 1))).toSubgroup вүӨ (W n).toSubgroup from hWle_add n (k + 1))
              (a (n + (k + 1)) x)
            = QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                (show (W (n + k)).toSubgroup вүӨ (W n).toSubgroup from hWle_add n k)
                (QuotientGroup.map (W (n + (k + 1))).toSubgroup (W (n + k)).toSubgroup (MonoidHom.id G)
                  (show (W (n + (k + 1))).toSubgroup вүӨ (W (n + k)).toSubgroup from by
                    simpa [Nat.add_assoc] using (hWdesc (n + k)))
                  (a (n + (k + 1)) x)) := by
                    symm
                    exact QuotientGroup.map_map (N := (W (n + (k + 1))).toSubgroup)
                      (M := (W (n + k)).toSubgroup) (O := (W n).toSubgroup)
                      (f := MonoidHom.id G) (g := MonoidHom.id G)
                      (hf := show (W (n + (k + 1))).toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) (W (n + k)).toSubgroup from by
                        simpa [Nat.add_assoc] using (hWdesc (n + k)))
                      (hg := show (W (n + k)).toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) (W n).toSubgroup from hWle_add n k)
                      (x := a (n + (k + 1)) x)
          _ = QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                (show (W (n + k)).toSubgroup вүӨ (W n).toSubgroup from hWle_add n k)
                (a (n + k) x) := by
                  simpa [Nat.add_assoc] using congrArg
                    (QuotientGroup.map (W (n + k)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
                      (show (W (n + k)).toSubgroup вүӨ (W n).toSubgroup from hWle_add n k))
                    (ha (n + k) x)
          _ = a n x := ih x
  have hWle : вҲҖ {n m : в„•}, n вүӨ m вҶ’ (W m).toSubgroup вүӨ (W n).toSubgroup := by
    intro n m hnm
    rcases Nat.exists_eq_add_of_le hnm with вҹЁk, rflвҹ©
    exact hWle_add n k
  have hcompat_nat : вҲҖ {n m : в„•} (hnm : n вүӨ m) (x : X),
      QuotientGroup.map (W m).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W m).toSubgroup вүӨ (W n).toSubgroup from hWle hnm) (a m x) = a n x := by
    intro n m hnm x
    rcases Nat.exists_eq_add_of_le hnm with вҹЁk, rflвҹ©
    exact hcompat_add n k x
  let P : ProfiniteGrp := ProfiniteGrp.of G
  let aP : вҲҖ n : в„•, C(X, (ProfiniteGrp.diagram P).obj (W n)) := by
    intro n
    refine { toFun := fun x => a n x, continuous_toFun := ?_ }
    convert (a n).continuous using 1
    В· change (вҠҘ : TopologicalSpace (G в§ё (W n).toSubgroup)) = QuotientGroup.instTopologicalSpace (W n).toSubgroup
      symm
      simpa using (show QuotientGroup.instTopologicalSpace (W n).toSubgroup = (вҠҘ : TopologicalSpace (G в§ё (W n).toSubgroup)) from DiscreteTopology.eq_bot (Оұ := (G в§ё (W n).toSubgroup)))
  have haP_val : вҲҖ n x, aP n x = a n x := by
    intro n x
    rfl
  have hcompat_natP : вҲҖ {n m : в„•} (hnm : n вүӨ m) (x : X),
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hWle hnm)) (aP m x) = aP n x := by
    intro n m hnm x
    change QuotientGroup.map (W m).toSubgroup (W n).toSubgroup (MonoidHom.id G)
      (show (W m).toSubgroup вүӨ (W n).toSubgroup from hWle hnm) (a m x) = a n x
    exact hcompat_nat hnm x
  let nU : OpenNormalSubgroup G вҶ’ в„• := fun U => Classical.choose (hWcof U)
  have hnU : вҲҖ U, (W (nU U)).toSubgroup вүӨ U.toSubgroup := by
    intro U
    exact Classical.choose_spec (hWcof U)
  let coordP : вҲҖ U : OpenNormalSubgroup G, C(X, (ProfiniteGrp.diagram P).obj U) := fun U =>
    (((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U))).hom.toContinuousMap).comp (aP (nU U))
  have hcoordP_from_stage : вҲҖ (U : OpenNormalSubgroup G) {m : в„•} (hm : nU U вүӨ m) (x : X),
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm).trans (hnU U))) (aP m x) = coordP U x := by
    intro U m hm x
    calc
      (ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm).trans (hnU U))) (aP m x)
        = ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U)))
            ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hWle hm)) (aP m x)) := by
              change QuotientGroup.map (W m).toSubgroup U.toSubgroup (MonoidHom.id G)
                (show (W m).toSubgroup вүӨ U.toSubgroup from (hWle hm).trans (hnU U)) (a m x)
                = QuotientGroup.map (W (nU U)).toSubgroup U.toSubgroup (MonoidHom.id G)
                    (show (W (nU U)).toSubgroup вүӨ U.toSubgroup from hnU U)
                    (QuotientGroup.map (W m).toSubgroup (W (nU U)).toSubgroup (MonoidHom.id G)
                      (show (W m).toSubgroup вүӨ (W (nU U)).toSubgroup from hWle hm) (a m x))
              symm
              exact QuotientGroup.map_map (N := (W m).toSubgroup)
                (M := (W (nU U)).toSubgroup) (O := U.toSubgroup)
                (f := MonoidHom.id G) (g := MonoidHom.id G)
                (hf := show (W m).toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) (W (nU U)).toSubgroup from hWle hm)
                (hg := show (W (nU U)).toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) U.toSubgroup from hnU U)
                (x := a m x)
      _ = ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE (hnU U))) (aP (nU U) x) := by
            rw [hcompat_natP hm x]
      _ = coordP U x := by rfl
  have hcoord_compat : вҲҖ x : X, вҲҖ {U1 U2 : OpenNormalSubgroup G} (f : U1 вҹ¶ U2),
      (ProfiniteGrp.diagram P).map f (coordP U1 x) = coordP U2 x := by
    intro x U1 U2 f
    let m := max (nU U1) (nU U2)
    have hm1 : nU U1 вүӨ m := le_max_left _ _
    have hm2 : nU U2 вүӨ m := le_max_right _ _
    calc
      (ProfiniteGrp.diagram P).map f (coordP U1 x)
          = (ProfiniteGrp.diagram P).map f
              ((ProfiniteGrp.diagram P).map (CategoryTheory.homOfLE ((hWle hm1).trans (hnU U1))) (aP m x)) := by
                rw [вҶҗ hcoordP_from_stage U1 hm1 x]
      _ = (ProfiniteGrp.diagram P).map
            (CategoryTheory.homOfLE (((hWle hm1).trans (hnU U1)).trans (CategoryTheory.leOfHom f)))
            (aP m x) := by
              change QuotientGroup.map U1.toSubgroup U2.toSubgroup (MonoidHom.id G)
                (show U1.toSubgroup вүӨ U2.toSubgroup from CategoryTheory.leOfHom f)
                (QuotientGroup.map (W m).toSubgroup U1.toSubgroup (MonoidHom.id G)
                  (show (W m).toSubgroup вүӨ U1.toSubgroup from (hWle hm1).trans (hnU U1)) (a m x))
                = QuotientGroup.map (W m).toSubgroup U2.toSubgroup (MonoidHom.id G)
                    (show (W m).toSubgroup вүӨ U2.toSubgroup from
                      ((hWle hm1).trans (hnU U1)).trans (CategoryTheory.leOfHom f)) (a m x)
              exact QuotientGroup.map_map (N := (W m).toSubgroup)
                (M := U1.toSubgroup) (O := U2.toSubgroup)
                (f := MonoidHom.id G) (g := MonoidHom.id G)
                (hf := show (W m).toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) U1.toSubgroup from (hWle hm1).trans (hnU U1))
                (hg := show U1.toSubgroup вүӨ Subgroup.comap (MonoidHom.id G) U2.toSubgroup from CategoryTheory.leOfHom f)
                (x := a m x)
      _ = coordP U2 x := by
            simpa using hcoordP_from_stage U2 hm2 x
  let Lfun : X вҶ’ ProfiniteGrp.limit (ProfiniteGrp.diagram P) := fun x =>
    вҹЁfun U => coordP U x, by
      intro U1 U2 f
      exact hcoord_compat x fвҹ©
  have hLfun : Continuous Lfun := by
    apply Continuous.subtype_mk
    simpa using (continuous_pi fun U : OpenNormalSubgroup G => (coordP U).continuous)
  let L : C(X, ProfiniteGrp.limit (ProfiniteGrp.diagram P)) := вҹЁLfun, hLfunвҹ©
  let e := ProfiniteGrp.continuousMulEquivLimittoFiniteQuotientFunctor P
  let s : C(X, G) := вҹЁfun x => e.symm (L x), e.symm.continuous_toFun.comp L.continuousвҹ©
  have hs_eq : вҲҖ x, e (s x) = L x := by
    intro x
    exact e.apply_symm_apply (L x)
  have hcoord_W : вҲҖ n x, coordP (W n) x = aP n x := by
    intro n x
    let m := max (nU (W n)) n
    have hm1 : nU (W n) вүӨ m := le_max_left _ _
    have hm2 : n вүӨ m := le_max_right _ _
    have h1 := hcoordP_from_stage (W n) hm1 x
    have h2 := hcompat_natP hm2 x
    exact h1.symm.trans h2
  refine вҹЁs, ?_вҹ©
  intro n x
  have hproj := congrArg (fun y => y.val (W n)) (hs_eq x)
  change QuotientGroup.mk' (W n).toSubgroup (s x) = coordP (W n) x at hproj
  rw [hcoord_W n x] at hproj
  simpa [haP_val n x] using hproj
theorem quotient_eq_of_cofinal_openNormalSequence_sup_eq {G : Type*}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (V : в„• вҶ’ OpenNormalSubgroup G)
    (hcofinal : вҲҖ U : OpenNormalSubgroup G, вҲғ n, V n вүӨ U)
    {g : G} {x : G в§ё N}
    (h : вҲҖ n,
      QuotientGroup.map N (N вҠ” (V n).toSubgroup) (MonoidHom.id G)
        (show N вүӨ N вҠ” (V n).toSubgroup from le_sup_left) x =
      QuotientGroup.mk' (N вҠ” (V n).toSubgroup) g) :
    QuotientGroup.mk' N g = x := by
  apply quotient_eq_of_all_open_superquotients_eq N hN
  intro U
  rcases hcofinal U with вҹЁn, hnвҹ©
  have hvu : (V n).toSubgroup вүӨ U.toSubgroup := hn
  have hsup : N вҠ” (V n).toSubgroup вүӨ N вҠ” U.toSubgroup := sup_le_sup_left hvu N
  have h' := congrArg
    (QuotientGroup.map (N вҠ” (V n).toSubgroup) (N вҠ” U.toSubgroup) (MonoidHom.id G) hsup)
    (h n)
  simpa using h'

theorem profinite_quotient_has_continuous_section (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (_hN : IsClosed (N : Set G)) :
    вҲғ s : C(G в§ё N, G), вҲҖ x : G в§ё N, QuotientGroup.mk' N (s x) = x := by
  classical
  have hN : IsClosed (N : Set G) := _hN
  obtain вҹЁW, hWbot, hWdesc, hWcofвҹ© :=
    exists_descending_cofinal_openNormalSequence_above (G := G) (N := (вҠҘ : Subgroup G))
  have hWcof' : вҲҖ U : OpenNormalSubgroup G, вҲғ n, W n вүӨ U := by
    intro U
    simpa using hWcof U bot_le
  let R : в„• вҶ’ Subgroup G := fun n => N вҠ” (W n).toSubgroup
  have hWle : вҲҖ {n m : в„•}, n вүӨ m вҶ’ W m вүӨ W n := by
    intro n m h
    induction h with
    | refl => exact le_rfl
    | @step m h ih => exact le_trans (hWdesc m) ih
  have hRle : вҲҖ n, R (n + 1) вүӨ R n := by
    intro n
    exact sup_le_sup_left (show (W (n + 1)).toSubgroup вүӨ (W n).toSubgroup from hWdesc n) N
  have hT0 : ОЈ' s : C(G в§ё R 0, G в§ё (W 0).toSubgroup),
      вҲҖ y : G в§ё R 0,
        QuotientGroup.map (W 0).toSubgroup (R 0) (MonoidHom.id G)
          (show (W 0).toSubgroup вүӨ R 0 from le_sup_right) (s y) = y := by
    refine вҹЁClassical.choose (superquotient_map_has_continuous_section (G := G) N (W 0)), ?_вҹ©
    exact Classical.choose_spec (superquotient_map_has_continuous_section (G := G) N (W 0))
  let T : в„• вҶ’ Type _ := fun n =>
    ОЈ' s : C(G в§ё R n, G в§ё (W n).toSubgroup),

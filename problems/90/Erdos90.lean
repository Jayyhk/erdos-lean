theorem towerEval_multiInd_d (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : в„•) (y : HomogTower p G (n + 1)) (t : Fin (n + 2) вҶ’ G) : towerEval p G (n + 2) (((ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1)).app (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).hom y) t = towerEval p G (n + 1) y (Fin.tail t) + ((Finset.univ : Finset (Fin (n + 1))).sum (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : в„•) + 1) вҖў towerEval p G (n + 1) y (j.succ.removeNth t))) := by
  have towerEval_sub : вҲҖ m (a b : HomogTower p G m) (u : Fin m вҶ’ G),
      towerEval p G m (a - b) u = towerEval p G m a u - towerEval p G m b u := by
    intro m
    induction m with
    | zero =>
        intro a b u
        rfl
    | succ m ih =>

      exact Finset.sum_le_sum (fun x hx => hpoint x)) ?_
    exact hcomp.sum_le_tsum u (by
      intro x hx
      exact hg_nonneg _)
  refine вҹЁ?_, ?_вҹ©
  В· simpa [weight] using hweight
  В· exact le_trans htsum_le_comp (by
      simpa [Function.comp, g] using (tsum_comp_le_tsum_of_inj hg hg_nonneg hencode_inj))

theorem tsum_pi_inverse_square_prime_le {Оұ : Type*} (s : Finset Оұ) (p : в„•) (hp : p.Prime) (n : в„•) (hcard : s.card вүӨ n) :
    вҲ‘' ОҪ : (s вҶ’ в„•), (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№ вүӨ
      ((1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№) ^ n := by
  classical
  let a : в„қ := ((p : в„қ) ^ (2 : в„•))вҒ»В№
  let B : в„қ := (1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№
  have hp1 : (1 : в„қ) < p := by
    exact_mod_cast hp.one_lt
  have ha_nonneg : 0 вүӨ a := by
    dsimp [a]
    positivity
  have hp_sq_gt_one : (1 : в„қ) < (p : в„қ) ^ (2 : в„•) := by
    nlinarith [hp1]
  have ha_lt_one : a < 1 := by
    dsimp [a]
    simpa using (inv_lt_one_of_one_ltвӮҖ hp_sq_gt_one)
  have hB_eq : (1 - a)вҒ»В№ = B := by
    dsimp [B, a]
    simp [Real.rpow_natCast]
    rfl
  have hgeom : вҲ‘' k : в„•, a ^ k = B := by
    exact (tsum_geometric_of_lt_one ha_nonneg ha_lt_one).trans hB_eq
  have hB_ge_one : 1 вүӨ B := by
    rw [вҶҗ hB_eq, one_le_inv_iffвӮҖ]
    constructor
    В· exact sub_pos.mpr ha_lt_one
    В· linarith
  have h_nonneg : 0 вүӨ fun ОҪ : s вҶ’ в„• => (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№ := by
    intro ОҪ
    positivity
  have hscard :
      вҲ‘' ОҪ : s вҶ’ в„•, (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№ вүӨ B ^ s.card := by
    refine Real.tsum_le_of_sum_le h_nonneg ?_
    intro u
    let t : s вҶ’ Finset в„• := fun i => u.image fun ОҪ : s вҶ’ в„• => ОҪ i
    have hu : u вҠҶ Fintype.piFinset t := by
      intro ОҪ hОҪ
      rw [Fintype.mem_piFinset]
      intro i
      exact Finset.mem_image.mpr вҹЁОҪ, hОҪ, rflвҹ©
    calc
      вҲ‘ ОҪ вҲҲ u, (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№
          = вҲ‘ ОҪ вҲҲ u, вҲҸ i, a ^ ОҪ i := by
              refine Finset.sum_congr rfl ?_
              intro ОҪ hОҪ
              simp [a, inv_pow]
      _ вүӨ вҲ‘ ОҪ вҲҲ Fintype.piFinset t, вҲҸ i, a ^ ОҪ i := by
            exact Finset.sum_le_sum_of_subset_of_nonneg hu (by
              intro ОҪ hОҪ hnu
              positivity)
      _ = вҲҸ i, вҲ‘ k вҲҲ t i, a ^ k := by
            symm
            exact Finset.prod_univ_sum t (fun i k => a ^ k)
      _ вүӨ вҲҸ i : s, B := by
            simpa using Finset.prod_le_prod
              (s := Finset.univ)
              (f := fun i : s => вҲ‘ k вҲҲ t i, a ^ k)
              (g := fun _ : s => B)
              (fun i hi => Finset.sum_nonneg fun k hk => by positivity)
              (fun i hi => by
                exact (sum_le_hasSum (t i) (fun k hk => by positivity)
                  (hasSum_geometric_of_lt_one ha_nonneg ha_lt_one)).trans_eq hB_eq)
      _ = B ^ s.card := by
            simp [B]
  calc
    вҲ‘' ОҪ : s вҶ’ в„•, (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№ вүӨ B ^ s.card := hscard
    _ вүӨ B ^ n := pow_le_pow_rightвӮҖ hB_ge_one hcard
    _ = ((1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№) ^ n := by rfl

theorem dedekindZetaTwoAF_prime_localFactor_le (K : Type) [Field K] [NumberField K] (p : в„•) (hp : p.Prime) :
    вҲ‘' e : в„•, dedekindZetaTwoAF K (p ^ e) вүӨ
      ((1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№) ^ Module.finrank в„ҡ K := by
  classical
  let pp : Ideal в„Ө := Ideal.span ({(p : в„Ө)} : Set в„Ө)
  let ОІ : в„• вҶ’ Type := fun e => { I : Ideal (рқ“һ K) // Ideal.absNorm I = p ^ e }
  let w : Sigma ОІ вҶ’ в„қ := fun x => 1 / ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•))
  let s : Finset (Ideal (рқ“һ K)) := primesOverFinset pp (рқ“һ K)
  letI : Fact p.Prime := вҹЁhpвҹ©
  letI : pp.IsMaximal := by
    dsimp [pp]
    infer_instance
  have hpp0 : pp вү  вҠҘ := by
    dsimp [pp]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  have hfiber (e : в„•) : HasSum (fun I : ОІ e => w вҹЁe, Iвҹ©) (dedekindZetaTwoAF K (p ^ e)) := by
    classical
    letI : Fintype (ОІ e) := (Ideal.finite_setOf_absNorm_eq (S := рқ“һ K) (p ^ e)).fintype
    have hsum : вҲ‘ I : ОІ e, w вҹЁe, Iвҹ© = dedekindZetaTwoAF K (p ^ e) := by
      calc
        вҲ‘ I : ОІ e, w вҹЁe, Iвҹ© = вҲ‘ I : ОІ e, 1 / (((p ^ e : в„•) : в„қ) ^ (2 : в„•)) := by
          refine Finset.sum_congr rfl ?_
          intro I hI
          dsimp [w, ОІ]
          rw [I.2]
        _ = (Fintype.card (ОІ e) : в„қ) * (1 / (((p ^ e : в„•) : в„қ) ^ (2 : в„•))) := by
          simp
        _ = dedekindZetaTwoAF K (p ^ e) := by
          dsimp [dedekindZetaTwoAF, ОІ]
          rw [Nat.card_eq_fintype_card]
          simp [div_eq_mul_inv]
    simpa [hsum] using (hasSum_fintype (fun I : ОІ e => w вҹЁe, Iвҹ©))
  rcases sigma_weight_summable_le_tuple K p hp with вҹЁhw, hleвҹ©
  have htsum : вҲ‘' e : в„•, dedekindZetaTwoAF K (p ^ e) = вҲ‘' x : Sigma ОІ, w x := by
    exact (hw.hasSum.sigma hfiber).tsum_eq
  rw [htsum]
  refine le_trans hle ?_
  have hcard : s.card вүӨ Module.finrank в„ҡ K := by
    simpa only [s] using
      (Ideal.card_primesOverFinset_le_finrank (S := рқ“һ K) (K := в„ҡ) (L := K) (p := pp) hpp0)
  exact tsum_pi_inverse_square_prime_le s p hp (Module.finrank в„ҡ K) hcard

theorem prime_geometric_tprod_eq_pi_sq_div_six : вҲҸ' p : Nat.Primes, (1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№ = (Real.pi ^ (2 : в„•)) / 6 := by
  let f : в„• вҶ’*вӮҖ в„қ :=
    { toFun := fun n => 1 / (n : в„қ) ^ (2 : в„•)
      map_zero' := by simp
      map_one' := by simp
      map_mul' := by
        intro m n
        by_cases hm : m = 0
        В· simp [hm]
        В· by_cases hn : n = 0
          В· simp [hn]
          В· simp [hm, hn, Nat.cast_mul, mul_pow, one_div, mul_comm, mul_left_comm, mul_assoc] }
  have hs : Summable (fun n : в„• => f n) := by
    simp [f]
  have hf_nonneg : вҲҖ n : в„•, 0 вүӨ f n := by
    intro n
    by_cases hn : n = 0
    В· simp [f, hn]
    В· have : 0 вүӨ 1 / (n : в„қ) ^ (2 : в„•) := by positivity
      simp [f]
  have hf_summable : Summable fun n : в„• => вҖ–f nвҖ– := by
    change Summable fun n : в„• => |f n|
    simpa [abs_of_nonneg, hf_nonneg] using hs
  have hEuler : вҲҸ' p : Nat.Primes, (1 - f p)вҒ»В№ = вҲ‘' n : в„•, f n :=
    EulerProduct.eulerProduct_completely_multiplicative_tprod (f := f) hf_summable
  have hzeta : вҲ‘' n : в„•, f n = (Real.pi ^ (2 : в„•)) / 6 := by
    simpa [f] using hasSum_zeta_two.tsum_eq
  calc
    вҲҸ' p : Nat.Primes, (1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№
        = вҲҸ' p : Nat.Primes, (1 - f p)вҒ»В№ := by
            refine tprod_congr ?_
            intro p
            have hp_eq : f p = (p : в„қ) ^ (-(2 : в„қ)) := by
              change 1 / (p : в„қ) ^ (2 : в„•) = (p : в„қ) ^ (-(2 : в„қ))
              rw [Real.rpow_neg]
              В· simp [one_div]
              В· positivity
            rw [hp_eq]
    _ = вҲ‘' n : в„•, f n := hEuler
    _ = (Real.pi ^ (2 : в„•)) / 6 := hzeta

theorem pi_sq_div_six_lt_two : (Real.pi ^ (2 : в„•)) / (6 : в„қ) < 2 := by
  have hsqrt3_pos : 0 < Real.sqrt 3 := by
    positivity
  have hpi_div_six_lt : Real.pi / 6 < 1 / Real.sqrt 3 := by
    have h1 : 0 < Real.pi / 6 := by
      nlinarith [Real.pi_pos]
    have h2 : Real.pi / 6 < Real.pi / 2 := by
      nlinarith [Real.pi_pos]
    simpa only [Real.tan_pi_div_six] using (Real.lt_tan h1 h2)
  have hmul : Real.pi * Real.sqrt 3 < 6 := by
    have htmp : (Real.pi / 6) * Real.sqrt 3 < 1 := by
      exact (lt_div_iffвӮҖ hsqrt3_pos).mp hpi_div_six_lt
    nlinarith
  have hsq : (Real.pi * Real.sqrt 3) ^ (2 : в„•) < (6 : в„қ) ^ (2 : в„•) := by
    rw [sq_lt_sq]
    have hpos : 0 < Real.pi * Real.sqrt 3 := by
      positivity
    rw [abs_of_pos hpos, abs_of_pos (by norm_num : (0 : в„қ) < 6)]
    exact hmul
  have hsq3 : (Real.sqrt 3) ^ (2 : в„•) = (3 : в„қ) := by
    simpa only [pow_two] using (Real.sq_sqrt (show (0 : в„қ) вүӨ 3 by positivity))
  have hpi_sq_lt_twelve : Real.pi ^ (2 : в„•) < 12 := by
    have h6sq : (6 : в„қ) ^ (2 : в„•) = (36 : в„қ) := by
      norm_num
    rw [mul_pow, hsq3, h6sq] at hsq
    nlinarith
  nlinarith

theorem dedekindZetaTwoReal_le_two_pow_finrank (K : Type) [Field K] [NumberField K] :
    dedekindZetaTwoReal K вүӨ (2 : в„қ) ^ Module.finrank в„ҡ K := by
  classical
  let d := Module.finrank в„ҡ K
  let g : Nat.Primes вҶ’ в„қ := fun p => (1 - (p : в„қ) ^ (-(2 : в„қ)))вҒ»В№
  let loc : Nat.Primes вҶ’ в„қ := fun p => вҲ‘' e : в„•, dedekindZetaTwoAF K (p ^ e)
  have hnonneg : вҲҖ n : в„•, 0 вүӨ dedekindZetaTwoAF K n := by
    intro n
    dsimp [dedekindZetaTwoAF, ArithmeticFunction.coe_mk]
    positivity
  have hsum_norm : Summable (fun n : в„• => вҖ–dedekindZetaTwoAF K nвҖ–) := by
    refine Summable.of_nonneg_of_le (fun _ вҶҰ norm_nonneg _) ?_ (dedekindZetaTwoAF_summable K)
    intro n
    simp [Real.norm_eq_abs, abs_of_nonneg (hnonneg n)]
  have hAF_hasProd : HasProd loc (dedekindZetaTwoReal K) := by
    simpa [loc, dedekindZetaTwoReal] using
      (ArithmeticFunction.IsMultiplicative.eulerProduct_hasProd
        (dedekindZetaTwoAF_isMultiplicative K) hsum_norm)
  have hloc_nonneg : вҲҖ p : Nat.Primes, 0 вүӨ loc p := by
    intro p
    dsimp [loc]
    exact tsum_nonneg (fun e => hnonneg (p ^ e))
  have hzeta_nonneg : 0 вүӨ dedekindZetaTwoReal K := by
    unfold dedekindZetaTwoReal
    exact tsum_nonneg hnonneg
  have hInducing : Topology.IsInducing ((Complex.ofRealHom) : в„қ вҶ’* в„Ӯ) := by
    simpa using Complex.isUniformEmbedding_ofReal.isUniformInducing.isInducing
  have hpoint (p : Nat.Primes) : ((g p : в„қ) : в„Ӯ) = (1 - (p : в„Ӯ) ^ (-(2 : в„Ӯ)))вҒ»В№ := by
    have hp : 0 вүӨ (p : в„қ) := by positivity
    simp [g, Real.rpow_neg hp, Complex.cpow_neg, Complex.cpow_natCast, Complex.ofReal_cpow hp,
      Complex.ofReal_inv, Complex.ofReal_sub]
    rfl
  have hbase_hasProd_complex :

theorem bk_cycles1_linearEquiv_BKContsHom (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    вҲғ e : (BKHomogeneousComplex p G N).cycles 1 вүғвӮ—[ZMod p] BKContsHomSubmodule p G N,
      вҲҖ (g : G) (z : (BKHomogeneousComplex p G N).cycles 1) (y : вҶҘN),
        (e ((HomologicalComplex.cyclesMap
          (ContinuousCohomology.cochainsMapTrivial (ZMod p)
            ((MulAut.conjNormal gвҒ»В№ : вҶҘN вүғ* вҶҘN).toMonoidHom)
            (bk_conjNormal_continuous G N gвҒ»В№)
            (TopModuleCat.of (ZMod p) (ZMod p))) 1).hom z)).1 y =
          (e z).1 вҹЁgвҒ»В№ * (y : G) * g, by
            simpa using (вҖ№N.NormalвҖә.conj_mem (y : G) y.2 gвҒ»В№)вҹ© := by
  let toFun : (BKHomogeneousComplex p G N).cycles 1 вҶ’вӮ—[ZMod p] BKContsHomSubmodule p G N :=
    { toFun := fun z => вҹЁbk_cycles1_eval p G N z, bk_cycles1_eval_mem_BKContsHom p G N zвҹ©
      map_add' := by
        intro z w
        apply Subtype.ext
        ext y
        simpa using bk_cycles1_eval_add p G N z w y
      map_smul' := by
        intro c z
        apply Subtype.ext
        ext y
        simpa using bk_cycles1_eval_smul p G N c z y }
  rcases bk_BKContsHom_to_cycles1 p G N with вҹЁinvFun, hinv_evalвҹ©
  have hcomp_left : invFun.comp toFun = LinearMap.id := by
    ext z
    apply bk_cycles1_cochain_injective p G N
    ext x y
    calc
      bk_cycles1_cochain p G N ((invFun.comp toFun) z) x y
          = (toFun z).1 вҹЁ(x : G)вҒ»В№ * y, by
              simpa using N.mul_mem (N.inv_mem x.2) y.2вҹ© := by
            simpa [LinearMap.comp_apply] using hinv_eval (toFun z) x y
      _ = bk_cycles1_eval p G N z вҹЁ(x : G)вҒ»В№ * y, by
            simpa using N.mul_mem (N.inv_mem x.2) y.2вҹ© := rfl
      _ = bk_cycles1_cochain p G N z 1
            вҹЁ(x : G)вҒ»В№ * y, by
              simpa using N.mul_mem (N.inv_mem x.2) y.2вҹ© := rfl
      _ = bk_cycles1_cochain p G N z x y := by
            symm
            exact bk_cycles1_reconstruct p G N z x y
  have hcomp_right : toFun.comp invFun = LinearMap.id := by
    ext f y
    calc
      ((toFun.comp invFun) f).1 y = bk_cycles1_eval p G N (invFun f) y := rfl
      _ = bk_cycles1_cochain p G N (invFun f) 1 y := rfl
      _ = f.1 вҹЁ((1 : вҶҘN) : G)вҒ»В№ * y, by
            simpвҹ© := by
        simpa using hinv_eval f 1 y
      _ = f.1 y := by
        simp
  refine вҹЁLinearEquiv.ofLinear toFun invFun hcomp_right hcomp_left, ?_вҹ©
  intro g z y
  change bk_cycles1_eval p G N
      ((HomologicalComplex.cyclesMap
        (ContinuousCohomology.cochainsMapTrivial (ZMod p)
          ((MulAut.conjNormal gвҒ»В№ : вҶҘN вүғ* вҶҘN).toMonoidHom)

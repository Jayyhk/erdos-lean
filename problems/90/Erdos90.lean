  have hDE_int : IntervalIntegrable (fun t : в„қ => D t * E t) MeasureTheory.volume (0 : в„қ) X :=
    (hD_int 0 X).mul_continuousOn hE_cont.continuousOn
  have hDQ_expand :
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) = вҲ« t in (0 : в„қ)..X, D t * (1 - E t) := by
    calc
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) = вҲ« t in (0 : в„қ)..X, Пғ * (D t * Q t) := by
        rw [вҶҗ intervalIntegral.integral_const_mul]
      _ = вҲ« t in (0 : в„қ)..X, D t * (1 - E t) := by
        apply intervalIntegral.integral_congr
        intro t ht
        have ht' : t вҲҲ Set.Icc (0 : в„қ) X := by
          simpa [Set.uIcc_of_le hX] using ht

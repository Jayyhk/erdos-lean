          ((((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x)) -
            (((a.re : ℝ) : ℂ) * Complex.exp (-z * x))) := by
          rw [← MeasureTheory.integral_sub hlog_int hconst_int]
    _ = ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x - a.re : ℝ) : ℂ) * Complex.exp (-z * x)) := by
          congr with x
          rw [Complex.ofReal_sub]
          ring_nf


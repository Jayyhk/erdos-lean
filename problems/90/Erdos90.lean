    rw [IsGalois.card_aut_eq_finrank (F := ℚ) (E := L), hdeg] at h
    simpa using h
  set g : ℕ := (pI.primesOver (𝓞 L)).ncard
  set eIn : ℕ := pI.ramificationIdxIn (𝓞 L)
  set fIn : ℕ := pI.inertiaDegIn (𝓞 L)
  have hfund : g * (eIn * fIn) = 3 := by
    simpa [g, eIn, fIn] using hfund0
  have hramIn_ne_one0 : pI.ramificationIdxIn (𝓞 L) ≠ 1 := by
    rw [Ideal.ramificationIdxIn_eq_ramificationIdx (p := pI) (P := P) (B := 𝓞 L) (G := Gal(L/ℚ))]
    exact hramP_ne_one
  have hramIn_ne_one : eIn ≠ 1 := by
    simpa [eIn] using hramIn_ne_one0
  have he_dvd_three : eIn ∣ 3 := by
    refine ⟨g * fIn, ?_⟩
    calc
      3 = g * (eIn * fIn) := hfund.symm
      _ = eIn * (g * fIn) := by ring
  have he_three : eIn = 3 := by
    rcases (Nat.dvd_prime (by decide : Nat.Prime 3)).mp he_dvd_three with h1 | h3
    · exact (hramIn_ne_one h1).elim
    · exact h3
  have hmul : 3 * (g * fIn) = 3 := by
    calc
      3 * (g * fIn) = g * (eIn * fIn) := by rw [he_three]; ring
      _ = 3 := hfund
  have hgf_one : g * fIn = 1 := by
    exact (mul_eq_left₀ (a := 3) (b := g * fIn) (ha := by decide)).mp hmul
  have hg_one : g = 1 := (mul_eq_one.mp hgf_one).1
  have hf_one0 : fIn = 1 := (mul_eq_one.mp hgf_one).2
  have hramIn_three : pI.ramificationIdxIn (𝓞 L) = 3 := by
    simpa [eIn] using he_three
  have hramP_three : pI.ramificationIdx P = 3 := by
    rw [← Ideal.ramificationIdxIn_eq_ramificationIdx (p := pI) (P := P) (B := 𝓞 L) (G := Gal(L/ℚ))]
    exact hramIn_three
  have hP3 : P ^ 3 ∣ Ideal.map (algebraMap ℤ (𝓞 L)) pI := by
    refine Ideal.dvd_iff_le.mpr ?_
    have hle : Ideal.map (algebraMap ℤ (𝓞 L)) pI ≤ P ^ pI.ramificationIdx P := by
      exact Ideal.le_pow_ramificationIdx
    simpa [hramP_three] using hle
  have hP2dvdD : P ^ 2 ∣ D := by
    simpa [D] using (pow_sub_one_dvd_differentIdeal (A := ℤ) (B := 𝓞 L) (P := P) (e := 3) hp0 hP3)
  have hinertiaIn_one : pI.inertiaDegIn (𝓞 L) = 1 := by
    simpa [fIn] using hf_one0
  have hinertiaP_one : pI.inertiaDeg P = 1 := by
    rw [← Ideal.inertiaDegIn_eq_inertiaDeg (p := pI) (P := P) (B := 𝓞 L) (G := Gal(L/ℚ))]
    exact hinertiaIn_one
  have hnormP' : Ideal.absNorm P = r ^ (pI.inertiaDeg P) := by
    simpa [pI] using (Ideal.absNorm_eq_pow_inertiaDeg' (R := 𝓞 L) (P := P) (p := r) hr)
  have hnormP : Ideal.absNorm P = r := by
    rw [hnormP', hinertiaP_one]
    simp
  have hnormP2 : Ideal.absNorm (P ^ 2) = r ^ 2 := by
    rw [map_pow, hnormP]
  have hnorm_dvd : Ideal.absNorm (P ^ 2) ∣ Ideal.absNorm D :=
    Ideal.absNorm_dvd_absNorm_of_le (Ideal.dvd_iff_le.mp hP2dvdD)
  rw [hnormP2, NumberField.absNorm_differentIdeal (K := L) (𝒪 := 𝓞 L)] at hnorm_dvd
  simpa [D] using hnorm_dvd

theorem cube_subgroup_fixedField_discr_upper_bound (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1) :
    (NumberField.discr (cube_subgroup_fixedField r hr)).natAbs ∣ r ^ 2 := by
  let L := cube_subgroup_fixedField r hr
  let E := CyclotomicField r ℚ
  let m := (r - 1) / 3
  have hrel : Module.finrank ↥L E = m := by
    simpa [L, E, m] using cube_subgroup_fixedField_rel_finrank r hr hr3
  have hdiscrE : (NumberField.discr E).natAbs = r ^ (r - 2) := by
    simpa [E] using cyclotomicField_natAbs_discr_prime r hr hr3
  have htower : (NumberField.discr E).natAbs =
      Ideal.absNorm (differentIdeal (𝓞 ↥L) (𝓞 E)) * (NumberField.discr ↥L).natAbs ^ m := by
    simpa [hrel] using
      (NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        (K := ↥L) (𝒪 := 𝓞 ↥L) (L := E) (𝒪' := 𝓞 E))
  have hdvd_int : NumberField.discr ↥L ∣ (r ^ (r - 2) : ℤ) := by
    apply dvd_trans (NumberField.discr_dvd_discr (K := ↥L) (L := E))
    have habsE' : ((NumberField.discr E).natAbs : ℤ) = (r ^ (r - 2) : ℤ) := by
      exact_mod_cast hdiscrE
    have habsE : |NumberField.discr E| = (r ^ (r - 2) : ℤ) := by
      simpa [Int.natCast_natAbs] using habsE'
    rw [← habsE]
    exact (dvd_abs _ _).2 dvd_rfl
  have hdvd_nat : (NumberField.discr ↥L).natAbs ∣ r ^ (r - 2) := by
    exact (Int.dvd_natCast.mp hdvd_int)
  obtain ⟨k, hk_top, hkpow⟩ := (Nat.dvd_prime_pow hr).mp hdvd_nat
  have hdvdpow : (NumberField.discr ↥L).natAbs ^ m ∣ r ^ (r - 2) := by
    refine ⟨Ideal.absNorm (differentIdeal (𝓞 ↥L) (𝓞 E)), ?_⟩
    calc
      r ^ (r - 2) = (NumberField.discr E).natAbs := hdiscrE.symm
      _ = Ideal.absNorm (differentIdeal (𝓞 ↥L) (𝓞 E)) * (NumberField.discr ↥L).natAbs ^ m := htower
      _ = (NumberField.discr ↥L).natAbs ^ m * Ideal.absNorm (differentIdeal (𝓞 ↥L) (𝓞 E)) := by
        rw [Nat.mul_comm]
  have hkm_le : k * m ≤ r - 2 := by
    have hdvdpow' : r ^ (k * m) ∣ r ^ (r - 2) := by
      simpa [hkpow, Nat.pow_mul] using hdvdpow
    rcases (Nat.dvd_prime_pow hr).mp hdvdpow' with ⟨t, htle, ht⟩
    have hkt : k * m = t := by
      exact (Nat.pow_right_injective hr.two_le) ht
    omega
  have hmod : (r - 1) % 3 = 0 := by
    omega
  have hm_three : 3 * m = r - 1 := by
    dsimp [m]
    omega
  have hk_le_two : k ≤ 2 := by
    by_contra hk_gt
    have hk3 : 3 ≤ k := by omega
    have hmul : 3 * m ≤ k * m := Nat.mul_le_mul_right m hk3
    omega
  rw [hkpow]
  refine ⟨r ^ (2 - k), ?_⟩
  rw [← Nat.pow_add, Nat.add_sub_of_le hk_le_two]

theorem cube_subgroup_fixedField_discr (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1) :
    (NumberField.discr (cube_subgroup_fixedField r hr)).natAbs = r ^ 2 := by
  exact Nat.dvd_antisymm
    (cube_subgroup_fixedField_discr_upper_bound r hr hr3)
    (cube_subgroup_fixedField_discr_lower_bound r hr hr3)

theorem cyclic_cubic_subfield_exists_local (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1) :
    ∃ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois ℚ L)
      (_ : Algebra L (CyclotomicField r ℚ)),
      Module.finrank ℚ L = 3 ∧
      (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let E := CyclotomicField r ℚ
  let L : IntermediateField ℚ E := cube_subgroup_fixedField r hr
  letI : Fact r.Prime := ⟨hr⟩
  letI : NeZero r := ⟨hr.ne_zero⟩
  letI : IsCyclotomicExtension {r} ℚ E :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := r) (K := ℚ)
  letI : IsGalois ℚ E := IsCyclotomicExtension.isGalois (S := {r}) (K := ℚ) (L := E)
  let hirr : Irreducible (Polynomial.cyclotomic r ℚ) :=
    Polynomial.cyclotomic.irreducible_rat hr.pos
  let e : (E ≃ₐ[ℚ] E) ≃* (ZMod r)ˣ :=
    IsCyclotomicExtension.autEquivPow (L := E) hirr
  let H0 : Subgroup (ZMod r)ˣ := (powMonoidHom 3 : (ZMod r)ˣ →* (ZMod r)ˣ).range
  let H : Subgroup (E ≃ₐ[ℚ] E) := H0.map e.symm.toMonoidHom
  have hL : L = IntermediateField.fixedField H := by
    unfold L cube_subgroup_fixedField
    simp [E, hirr, e, H0, H]
  have hH0_normal : H0.Normal := by
    infer_instance
  have hH_normal : H.Normal := by
    simpa [H, H0] using hH0_normal.map e.symm.toMonoidHom e.symm.surjective
  letI : H.Normal := hH_normal
  have hGalL : IsGalois ℚ (IntermediateField.fixedField H) :=
    IsGalois.of_fixedField_normal_subgroup (K := ℚ) (L := E) H
  have hGalL' : IsGalois ℚ L := by
    rw [hL]
    infer_instance
  have hfinrank : Module.finrank ℚ L = 3 := by
    calc
      Module.finrank ℚ L = L.fixingSubgroup.index := by
        simpa using IntermediateField.finrank_eq_fixingSubgroup_index (L := L)
      _ = H.index := by rw [hL, IntermediateField.fixingSubgroup_fixedField]
      _ = H0.index := by
        simp [H0, H]
      _ = (Nat.card ((ZMod r)ˣ)).gcd 3 := by
        simpa [H0] using (IsCyclic.index_powMonoidHom_range (G := (ZMod r)ˣ) (d := 3))
      _ = (r - 1).gcd 3 := by rw [Nat.card_eq_fintype_card, ZMod.card_units]
      _ = 3 := by
        have hmod : (r - 1) % 3 = 0 := by
          omega
        have hdiv : 3 ∣ r - 1 := (Nat.modEq_zero_iff_dvd).mp (show r - 1 ≡ 0 [MOD 3] by simpa [Nat.ModEq] using hmod)
        exact (gcd_eq_right_iff (r - 1) 3 rfl).2 hdiv
  let gaut : E ≃ₐ[ℚ] E := e.symm (-1)
  have hg_mem : gaut ∈ H := by
    have hneg : (-1 : (ZMod r)ˣ) ∈ H0 := by
      refine ⟨(-1 : (ZMod r)ˣ), ?_⟩
      exact Odd.neg_one_pow (show Odd 3 by decide)
    simpa [gaut, H] using hneg
  have hg_zeta :
      gaut (IsCyclotomicExtension.zeta r ℚ E) = (IsCyclotomicExtension.zeta r ℚ E) ^ (r - 1) := by
    let hζ := IsCyclotomicExtension.zeta_spec r ℚ E
    have hpow := hζ.autToPow_spec (R := ℚ) gaut
    have heq : hζ.autToPow ℚ gaut = (-1 : (ZMod r)ˣ) := by
      change e gaut = (-1 : (ZMod r)ˣ)
      simp [gaut]
    rw [heq] at hpow
    have hval : (((-1 : (ZMod r)ˣ) : ZMod r).val) = r - 1 := by
      change (- (1 : ZMod r)).val = r - 1
      have h1 : (1 : ZMod r) ≠ 0 := by
        exact zero_ne_one.symm
      letI : NeZero (1 : ZMod r) := ⟨h1⟩
      rw [ZMod.val_neg_of_ne_zero (a := (1 : ZMod r))]
      rw [ZMod.val_one'' hr.ne_one]
    rw [hval] at hpow
    simpa using hpow.symm
  have hle : L.toSubfield ≤ NumberField.maximalRealSubfield E := by
    intro x hx
    rw [NumberField.mem_maximalRealSubfield_iff (K := E)]
    intro φ
    let ψ : E →+* ℂ := NumberField.ComplexEmbedding.conjugate φ
    have hbase : φ.comp (algebraMap ℚ E) = ψ.comp (algebraMap ℚ E) := by
      ext q
      simp [ψ, NumberField.ComplexEmbedding.conjugate]
    obtain ⟨σ, hσ⟩ := NumberField.ComplexEmbedding.exists_comp_symm_eq_of_comp_eq (k := ℚ) (K := E) φ ψ hbase
    have hσ' : NumberField.ComplexEmbedding.IsConj φ σ.symm := by
      dsimp [NumberField.ComplexEmbedding.IsConj, ψ] at *
      simpa using hσ.symm
    have hσeq : σ.symm = gaut := by
      apply IsCyclotomicExtension.algEquiv_eq_of_apply_eq (S := ({r} : Set ℕ)) (A := ℚ) (B := E)
      intro m hm hm0
      have hm' : m = r := by simpa using hm
      subst m
      refine ⟨IsCyclotomicExtension.zeta r ℚ E, IsCyclotomicExtension.zeta_spec r ℚ E, ?_⟩
      apply φ.injective
      let ζ := IsCyclotomicExtension.zeta r ℚ E
      have hζ : IsPrimitiveRoot ζ r := IsCyclotomicExtension.zeta_spec r ℚ E
      have hφζ : IsPrimitiveRoot (φ ζ) r := hζ.map_of_injective φ.injective
      have hconjζ : star (φ ζ) = (φ ζ)⁻¹ := by
        simpa [ζ] using Complex.conj_rootsOfUnity (hζ := (hφζ.toRootsOfUnity).2)
      have hneζ : ζ ≠ 0 := hζ.ne_zero hr.ne_zero
      have hne : φ ζ ≠ 0 := by
        intro hz
        apply hneζ
        have hz' : φ ζ = φ 0 := by simpa using hz
        exact φ.injective hz'
      have hpowinv : (φ ζ) ^ (r - 1) = (φ ζ)⁻¹ := by
        calc
          (φ ζ) ^ (r - 1) = (φ ζ) ^ r * ((φ ζ) ^ 1)⁻¹ := by
            rw [pow_sub₀ _ hne (show 1 ≤ r by omega)]
          _ = 1 * ((φ ζ) ^ 1)⁻¹ := by rw [hφζ.pow_eq_one]
          _ = (φ ζ)⁻¹ := by simp
      calc
        φ (σ.symm ζ) = star (φ ζ) := hσ'.eq _
        _ = (φ ζ)⁻¹ := hconjζ
        _ = (φ ζ) ^ (r - 1) := hpowinv.symm
        _ = φ (gaut ζ) := by rw [hg_zeta, map_pow]
    have hxfix : gaut x = x := by
      have hx' : x ∈ IntermediateField.fixedField H := by simpa [hL] using hx
      exact (IntermediateField.mem_fixedField_iff (H := H) x).1 hx' gaut hg_mem
    have hxconj : φ (gaut x) = star (φ x) := hσeq ▸ hσ'.eq x
    rw [hxfix] at hxconj
    simpa using hxconj.symm
  have htotallyReal : IsTotallyReal L := by
    have htotSub : IsTotallyReal L.toSubfield :=
      (NumberField.isTotallyReal_iff_le_maximalRealSubfield (K := E) (E := L.toSubfield)).2 hle
    simpa using htotSub
  refine ⟨L, inferInstance, inferInstance, inferInstance, htotallyReal, hGalL', inferInstance, ?_⟩
  exact ⟨hfinrank, by simpa [L] using cube_subgroup_fixedField_discr r hr hr3⟩

theorem cyclic_cubic_field_of_prime_mod3 (r : ℕ) (hr : r.Prime) (hr3 : r % 3 = 1) :
    ∃ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois ℚ L)
      (_ : Algebra L (CyclotomicField r ℚ)),
      Module.finrank ℚ L = 3 ∧
      (NumberField.discr L).natAbs = r ^ 2 ∧
      Nonempty ((L ≃ₐ[ℚ] L) ≃* Multiplicative (ZMod 3)) := by
  classical
  rcases cyclic_cubic_subfield_exists_local r hr hr3 with
    ⟨L, _instF, _instCZ, _instNF, _instTR, _instGal, _instAlg, hdeg, hdisc⟩
  refine ⟨L, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, hdeg, hdisc, ?_⟩
  letI : Fact (Nat.Prime 3) := ⟨by decide⟩
  have hcardL : Nat.card (L ≃ₐ[ℚ] L) = 3 := by
    simpa [hdeg] using (IsGalois.card_aut_eq_finrank ℚ L)
  have hcardZ : Nat.card (Multiplicative (ZMod 3)) = 3 := by
    rw [Nat.card_eq_fintype_card, Fintype.card_multiplicative, ZMod.card]
  exact ⟨mulEquivOfPrimeCardEq hcardL hcardZ⟩

theorem discr_eq_of_not_dvd_differentIdeal_at_all_primes (F M : Type) [Field F] [Field M] [NumberField F] [NumberField M]
    [Algebra F M] [FiniteDimensional F M] [IsScalarTower ℚ F M]
    (_hnotdvd : ∀ P : Ideal (𝓞 M), P.IsPrime → ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M)) :
    (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M := by
  let D : Ideal (𝓞 M) := differentIdeal (𝓞 F) (𝓞 M)
  have hDtop : D = ⊤ := by
    by_contra hDne
    rcases Ideal.exists_le_maximal D hDne with ⟨P, hPmax, hPle⟩
    have hPprime : P.IsPrime := hPmax.isPrime
    have hPdvd : P ∣ D := by
      rwa [Ideal.dvd_iff_le]
    exact (_hnotdvd P hPprime) hPdvd
  rw [NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow F (𝓞 F) M (𝓞 M)]
  simp [D, hDtop]

theorem elementary_abelian_three_mulEquiv (n : ℕ) (G : Type) [Group G] [Fintype G]
    (_hpow : ∀ g : G, g ^ 3 = 1)
    (_hcomm : ∀ g h : G, g * h = h * g)
    (_hcard : Nat.card G = 3 ^ n) :
    Nonempty (G ≃* Multiplicative (Fin n → ZMod 3)) := by
  letI : CommGroup G := { ‹Group G› with
    mul_comm := _hcomm }
  let A := Additive G
  have h3smul : ∀ x : A, (3 : ℕ) • x = 0 := by
    intro x
    change x.toMul ^ 3 = 1
    simpa using _hpow x.toMul
  letI : Module (ZMod 3) A := AddCommGroup.zmodModule (n := 3) h3smul
  have hpow_card : 3 ^ Module.finrank (ZMod 3) A = Fintype.card A := by
    simpa using (FiniteField.pow_finrank_eq_card 3 A)
  have hfinrank : Module.finrank (ZMod 3) A = n := by
    have hcardA : Fintype.card A = 3 ^ n := by
      simpa [A] using _hcard
    rw [hcardA] at hpow_card
    exact Nat.pow_right_injective (by decide : 1 < 3) hpow_card
  let e : A ≃ₗ[ZMod 3] (Fin n → ZMod 3) :=
    LinearEquiv.ofFinrankEq (R := ZMod 3) A (Fin n → ZMod 3) (by
      rw [hfinrank, Module.finrank_fin_fun])
  exact ⟨e.toAddEquiv.toMultiplicativeRight⟩

theorem exists_linearMap_eq_one_of_span_top (ℓ : ℕ) (_hℓ : 0 < ℓ) (v : Fin ℓ → (Fin ℓ → ZMod 3))
    (_hspan : Submodule.span (ZMod 3) (Set.range v) = ⊤) :
    ∃ lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3,
      lin ≠ 0 ∧ ∀ i, lin (v i) = 1 := by
  let T : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] (Fin ℓ → ZMod 3) :=
    (Module.piEquiv (Fin ℓ) (ZMod 3) (Fin ℓ → ZMod 3)) v
  have hTsurj : Function.Surjective T := by
    exact (Module.surjective_piEquiv_apply_iff
      (ι := Fin ℓ) (R := ZMod 3) (M := Fin ℓ → ZMod 3) v).2 _hspan
  have hTinj : Function.Injective T := by
    simpa using
      ((LinearMap.injective_iff_surjective : Function.Injective T ↔ Function.Surjective T).2
        hTsurj)
  let eT : (Fin ℓ → ZMod 3) ≃ₗ[ZMod 3] (Fin ℓ → ZMod 3) :=
    T.linearEquivOfInjective hTinj rfl
  let lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3 :=
    (Pi.basisFun (ZMod 3) (Fin ℓ)).sumCoords.comp eT.symm.toLinearMap
  refine ⟨lin, ?_, ?_⟩
  · intro hlin
    let i0 : Fin ℓ := ⟨0, _hℓ⟩
    have hbasis : eT.symm (v i0) = Pi.basisFun (ZMod 3) (Fin ℓ) i0 := by
      apply eT.injective
      rw [eT.apply_symm_apply]
      simp [eT, T, Module.piEquiv]
    have h1 : lin (v i0) = 1 := by
      change (Pi.basisFun (ZMod 3) (Fin ℓ)).sumCoords (eT.symm (v i0)) = 1
      rw [hbasis]
      simp
    have h0 : lin (v i0) = 0 := by
      simp [hlin]
    have h10 : (1 : ZMod 3) = 0 := by
      simp [h1] at h0
    exact (by decide : (1 : ZMod 3) ≠ 0) h10
  · intro i
    have hbasis : eT.symm (v i) = Pi.basisFun (ZMod 3) (Fin ℓ) i := by
      apply eT.injective
      rw [eT.apply_symm_apply]
      simp [eT, T, Module.piEquiv]
    change (Pi.basisFun (ZMod 3) (Fin ℓ)).sumCoords (eT.symm (v i)) = 1
    rw [hbasis]
    simp

theorem fun_zmod3_equiv_pow_three_and_comm (n : ℕ) (G : Type) [Group G]
    (e : G ≃* Multiplicative (Fin n → ZMod 3)) :
    (∀ g : G, g ^ 3 = 1) ∧
    (∀ g h : G, g * h = h * g) := by
  constructor
  · intro g
    apply e.injective
    rw [map_pow, map_one]
    ext i
    simp [pow_succ, pow_two]
    ring_nf
    have h3 : (3 : ZMod 3) = 0 := by
      decide
    simp [h3]
  · intro g h
    apply e.injective
    rw [map_mul, map_mul]
    exact mul_comm (e g) (e h)

theorem cyclic_cubic_subfield_of_surjective_character (ℓ : ℕ) (_hℓ : 0 < ℓ)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (ψ : Multiplicative (Fin ℓ → ZMod 3) →* Multiplicative (ZMod 3))
    (_hψ_surj : Function.Surjective ψ) :
    ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  classical
  let χ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) :=
    ψ.comp (e : (M ≃ₐ[ℚ] M) →* Multiplicative (Fin ℓ → ZMod 3))
  let H : Subgroup (M ≃ₐ[ℚ] M) := χ.ker
  let F : IntermediateField ℚ M := IntermediateField.fixedField H
  letI : H.Normal := by
    dsimp [H, χ]
    infer_instance
  letI : IsGalois ℚ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsGalois F M := IsGalois.tower_top_intermediateField F
  have hχ_surj : Function.Surjective χ := by
    intro z
    rcases _hψ_surj z with ⟨y, rfl⟩
    refine ⟨e.symm y, ?_⟩
    simp [χ]
  have eF : (F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3) :=
    (IsGalois.normalAutEquivQuotient H).symm.trans
      (QuotientGroup.quotientKerEquivOfSurjective (φ := χ) hχ_surj)
  have hcardG : Nat.card (M ≃ₐ[ℚ] M) = 3 ^ ℓ := by
    calc
      Nat.card (M ≃ₐ[ℚ] M) = Nat.card (Multiplicative (Fin ℓ → ZMod 3)) :=
        Nat.card_congr e.toEquiv
      _ = Fintype.card (Multiplicative (Fin ℓ → ZMod 3)) := Nat.card_eq_fintype_card
      _ = Fintype.card (Fin ℓ → ZMod 3) := Fintype.card_multiplicative _
      _ = 3 ^ ℓ := by
        rw [Fintype.card_fun]
        simp [ZMod.card]
  have hcardGalF : Nat.card (F ≃ₐ[ℚ] F) = 3 := by
    calc
      Nat.card (F ≃ₐ[ℚ] F) = Nat.card (Multiplicative (ZMod 3)) := Nat.card_congr eF.toEquiv
      _ = Fintype.card (Multiplicative (ZMod 3)) := Nat.card_eq_fintype_card
      _ = Fintype.card (ZMod 3) := Fintype.card_multiplicative _
      _ = 3 := by simp
  have hcardH : Nat.card H = 3 ^ (ℓ - 1) := by
    have hmul : 3 ^ ℓ = 3 * Nat.card H := by
      calc
        3 ^ ℓ = Nat.card (M ≃ₐ[ℚ] M) := hcardG.symm
        _ = Nat.card ((M ≃ₐ[ℚ] M) ⧸ H) * Nat.card H :=
          Subgroup.card_eq_card_quotient_mul_card_subgroup H
        _ = Nat.card (F ≃ₐ[ℚ] F) * Nat.card H := by
          simpa [F] using
            (Nat.card_congr (IsGalois.normalAutEquivQuotient H).toEquiv :
              Nat.card ((M ≃ₐ[ℚ] M) ⧸ H) =
                Nat.card ((↥(IntermediateField.fixedField H)) ≃ₐ[ℚ] (↥(IntermediateField.fixedField H))))
        _ = 3 * Nat.card H := by rw [hcardGalF]
    have hpow : 3 ^ ℓ = 3 * 3 ^ (ℓ - 1) := by
      calc
        3 ^ ℓ = 3 ^ (ℓ - 1 + 1) := by
          congr
          omega
        _ = 3 ^ (ℓ - 1) * 3 := by rw [pow_succ]
        _ = 3 * 3 ^ (ℓ - 1) := by rw [Nat.mul_comm]
    omega
  have hfinrankF : Module.finrank ℚ F = 3 := by
    exact (IsGalois.card_aut_eq_finrank ℚ F).symm.trans hcardGalF
  have hfinrankFM : Module.finrank F M = 3 ^ (ℓ - 1) := by
    simpa [F] using (IntermediateField.finrank_fixedField_eq_card H).trans hcardH
  have hpowcomm := fun_zmod3_equiv_pow_three_and_comm ℓ (M ≃ₐ[ℚ] M) e
  have hpow_abs : ∀ g : M ≃ₐ[ℚ] M, g ^ 3 = 1 := hpowcomm.1
  have hcomm_abs : ∀ g h : M ≃ₐ[ℚ] M, g * h = h * g := hpowcomm.2
  have hpowH : ∀ h : H, h ^ 3 = 1 := by
    intro h
    ext a
    exact congrArg (fun f : M ≃ₐ[ℚ] M => f a) (hpow_abs h.1)
  have hcommH : ∀ h k : H, h * k = k * h := by
    intro h k
    ext a
    exact congrArg (fun f : M ≃ₐ[ℚ] M => f a) (hcomm_abs h.1 k.1)
  refine ⟨F, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, ?_⟩
  constructor
  · exact hfinrankF
  constructor
  · exact ⟨eF⟩
  constructor
  · exact hfinrankFM
  constructor
  · simpa [hfinrankFM] using (Odd.pow (n := ℓ - 1) (show Odd 3 by decide))
  constructor
  · intro σ
    let hσ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm σ
    have hhσ : hσ ^ 3 = 1 := hpowH hσ
    simpa [hσ] using congrArg (IntermediateField.subgroupEquivAlgEquiv H) hhσ
  · intro σ τ
    let hσ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm σ
    let hτ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm τ
    have hhστ : hσ * hτ = hτ * hσ := hcommH hσ hτ
    simpa [hσ, hτ] using congrArg (IntermediateField.subgroupEquivAlgEquiv H) hhστ

theorem diagonal_cubic_subfield_exists (ℓ : ℕ) (_hℓ : 0 < ℓ)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (_hMgal : Nonempty ((M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))) :
    ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  classical
  rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt _hℓ) with ⟨k, rfl⟩
  rcases _hMgal with ⟨e⟩
  let ψ : Multiplicative (Fin (k + 1) → ZMod 3) →* Multiplicative (ZMod 3) :=
    { toFun := fun f => Multiplicative.ofAdd (Multiplicative.toAdd f 0)
      map_one' := rfl
      map_mul' := by
        intro a b
        rfl }
  let χ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) :=
    ψ.comp (e : (M ≃ₐ[ℚ] M) →* Multiplicative (Fin (k + 1) → ZMod 3))
  have hχ_surj : Function.Surjective χ := by
    intro z
    refine ⟨e.symm (Multiplicative.ofAdd fun _ => Multiplicative.toAdd z), ?_⟩
    simp [χ, ψ]
  let H : Subgroup (M ≃ₐ[ℚ] M) := χ.ker
  let F : IntermediateField ℚ M := IntermediateField.fixedField H
  letI : IsGalois ℚ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsGalois F M := IsGalois.tower_top_intermediateField F
  have hcardG : Nat.card (M ≃ₐ[ℚ] M) = 3 ^ (k + 1) := by
    calc
      Nat.card (M ≃ₐ[ℚ] M) = Nat.card (Multiplicative (Fin (k + 1) → ZMod 3)) :=
        Nat.card_congr e.toEquiv
      _ = Nat.card (Fin (k + 1) → ZMod 3) := by rfl
      _ = Nat.card (ZMod 3) ^ Nat.card (Fin (k + 1)) := Nat.card_fun
      _ = 3 ^ (k + 1) := by rw [Nat.card_zmod, Nat.card_fin]
  have hcardQ : Nat.card ((M ≃ₐ[ℚ] M) ⧸ H) = 3 := by
    calc
      Nat.card ((M ≃ₐ[ℚ] M) ⧸ H) = Nat.card χ.range := by
        simpa [H] using Nat.card_congr (QuotientGroup.quotientKerEquivRange χ).toEquiv
      _ = Nat.card (⊤ : Subgroup (Multiplicative (ZMod 3))) := by
        rw [MonoidHom.range_eq_top_of_surjective χ hχ_surj]
      _ = Nat.card (Multiplicative (ZMod 3)) := Subgroup.card_top
      _ = 3 := by simp
  have hcardH : Nat.card H = 3 ^ k := by
    have hmul := Subgroup.card_eq_card_quotient_mul_card_subgroup H
    rw [hcardG, hcardQ, pow_succ, Nat.mul_comm 3 (Nat.card H)] at hmul
    omega
  have hcardF : Nat.card (F ≃ₐ[ℚ] F) = 3 := by
    calc
      Nat.card (F ≃ₐ[ℚ] F) = Nat.card ((M ≃ₐ[ℚ] M) ⧸ H) := by
        exact Nat.card_congr ((IsGalois.normalAutEquivQuotient H).symm.toEquiv)
      _ = 3 := hcardQ
  have hfinrankF : Module.finrank ℚ F = 3 := by
    exact (IsGalois.card_aut_eq_finrank ℚ F).symm.trans hcardF
  have hfinrankFM : Module.finrank F M = 3 ^ k := by
    simpa [F] using (IntermediateField.finrank_fixedField_eq_card H).trans hcardH
  have hoddFM : Odd (Module.finrank F M) := by
    rw [hfinrankFM]
    exact Odd.pow (n := k) (by decide : Odd 3)
  have habs := fun_zmod3_equiv_pow_three_and_comm (k + 1) (M ≃ₐ[ℚ] M) e
  rcases habs with ⟨hpow_abs, hcomm_abs⟩
  have hpow_rel : ∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1 := by
    intro σ
    let σ' : H := (IntermediateField.subgroupEquivAlgEquiv H).symm σ
    have hσ' : σ' ^ 3 = 1 := by
      apply Subtype.ext
      exact hpow_abs σ'
    have hσ := congrArg (IntermediateField.subgroupEquivAlgEquiv H) hσ'
    simpa [σ'] using hσ
  have hcomm_rel : ∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ := by
    intro σ τ
    let σ' : H := (IntermediateField.subgroupEquivAlgEquiv H).symm σ
    let τ' : H := (IntermediateField.subgroupEquivAlgEquiv H).symm τ
    have hστ : σ' * τ' = τ' * σ' := by
      apply Subtype.ext
      exact hcomm_abs σ' τ'
    have hστ' := congrArg (IntermediateField.subgroupEquivAlgEquiv H) hστ
    simpa [σ', τ'] using hστ'
  letI : Fact (Nat.Prime 3) := ⟨by decide⟩
  have hcyc : Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) := by
    refine ⟨mulEquivOfPrimeCardEq (G := F ≃ₐ[ℚ] F) (G' := Multiplicative (ZMod 3)) hcardF ?_⟩
    simp
  refine ⟨F, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, ?_⟩
  exact ⟨hfinrankF, hcyc, hfinrankFM, hoddFM, hpow_rel, hcomm_rel⟩

noncomputable def linearMapToCharacter (ℓ : ℕ)
    (lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3) :
    Multiplicative (Fin ℓ → ZMod 3) →* Multiplicative (ZMod 3) where
  toFun := fun f => Multiplicative.ofAdd (lin (Multiplicative.toAdd f))
  map_one' := by
    simp
  map_mul' := by
    intro a b
    simp

theorem all_primes_over_ri_not_dvd_differentIdeal_of_nonvanishing (ℓ : ℕ) (r : Fin ℓ → ℕ)
    (M : Type) [Field M] [CharZero M] [NumberField M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (σ : Fin ℓ → (M ≃ₐ[ℚ] M))
    (_hσ_mem : ∀ i, ∃ P : Ideal (𝓞 M),
      P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) ∧
      Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 ∧
      σ i ∈ P.inertia (M ≃ₐ[ℚ] M) ∧
      σ i ≠ 1)
    (lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3)
    (_hlinv : ∀ i, lin (Multiplicative.toAdd (e (σ i))) ≠ 0) :
    let ψ := linearMapToCharacter ℓ lin
    let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
    let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
    let F : IntermediateField ℚ M := IntermediateField.fixedField H
    ∀ i (P : Ideal (𝓞 M)),
      P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) →
      ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M) := by
  classical
  dsimp
  intro i P hP
  let ψ := linearMapToCharacter ℓ lin
  let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
  let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
  let F : IntermediateField ℚ M := IntermediateField.fixedField H
  let p : Ideal ℤ := Ideal.span {(r i : ℤ)}
  have hP' : P ∈ p.primesOver (𝓞 M) := by
    simpa [p] using hP
  have hφσ_ne_one : φ (σ i) ≠ 1 := by
    simpa [φ, ψ, linearMapToCharacter] using _hlinv i
  have hσ_not_mem : σ i ∉ H := by
    simpa [H] using hφσ_ne_one
  rcases _hσ_mem i with ⟨P₀, hP₀mem, hcard₀, hσP₀, hσne1⟩
  have hP₀' : P₀ ∈ p.primesOver (𝓞 M) := by
    simpa [p] using hP₀mem
  letI : IsGaloisGroup (M ≃ₐ[ℚ] M) ℤ (𝓞 M) := inferInstance
  letI : FaithfulSMul (M ≃ₐ[ℚ] M) (𝓞 M) :=
    IsGaloisGroup.faithful (G := (M ≃ₐ[ℚ] M)) (A := ℤ) (B := 𝓞 M)
  have hbot_inertia : (⊥ : Ideal (𝓞 M)).inertia (M ≃ₐ[ℚ] M) = ⊥ := by
    ext g
    constructor
    · intro hg
      change g = 1
      exact (smul_left_injective' : Function.Injective ((· • ·) : (M ≃ₐ[ℚ] M) → 𝓞 M → 𝓞 M)) (by
        funext x
        have hx : g • x - x ∈ (⊥ : Ideal (𝓞 M)) := (AddSubgroup.mem_inertia.mp hg) x
        exact sub_eq_zero.mp (by simpa using hx))
    · intro hg
      have hg' : g = 1 := by simpa using hg
      subst hg'
      rw [AddSubgroup.mem_inertia]
      intro x
      simp
  have hp_ne_bot : p ≠ ⊥ := by
    intro hpbot
    have hP₀_eq_bot : P₀ = ⊥ := by
      rw [hpbot, Ideal.primesOver_bot] at hP₀'
      simpa using hP₀'
    have : σ i ∈ (⊥ : Ideal (𝓞 M)).inertia (M ≃ₐ[ℚ] M) := by
      simpa [hP₀_eq_bot] using hσP₀
    have hσ_eq_one : σ i = 1 := by
      simpa [hbot_inertia] using this
    exact hσne1 hσ_eq_one
  letI : P.IsPrime := Ideal.primesOver.isPrime (Q := ⟨P, hP'⟩)
  letI : P₀.IsPrime := Ideal.primesOver.isPrime (Q := ⟨P₀, hP₀'⟩)
  letI : P.LiesOver p := Ideal.primesOver.liesOver (Q := ⟨P, hP'⟩)
  letI : P₀.LiesOver p := Ideal.primesOver.liesOver (Q := ⟨P₀, hP₀'⟩)
  have hp_prime : p.IsPrime := by
    exact show p.IsPrime from P.over_def p ▸ inferInstance
  letI : p.IsPrime := hp_prime
  letI : p.IsMaximal := hp_prime.isMaximal hp_ne_bot
  letI : P.IsMaximal := Ideal.isMaximal_of_mem_primesOver hP'
  letI : P₀.IsMaximal := Ideal.isMaximal_of_mem_primesOver hP₀'
  letI : MulSemiringAction (M ≃ₐ[ℚ] M) (Ideal (𝓞 M)) := Ideal.pointwiseMulSemiringAction
  obtain ⟨τ, hτ⟩ := Ideal.exists_smul_eq_of_isGaloisGroup p P₀ P (M ≃ₐ[ℚ] M)
  let ρ : M ≃ₐ[ℚ] M := τ * σ i * τ⁻¹
  have hρ_not_mem : ρ ∉ H := by
    have hφρ_ne_one : φ ρ ≠ 1 := by
      dsimp [ρ]
      simp [map_mul, hφσ_ne_one]
    simpa [H] using hφρ_ne_one
  have hρ_inertia : ρ ∈ P.inertia (M ≃ₐ[ℚ] M) := by
    dsimp [ρ]
    simpa using (show τ * σ i * τ⁻¹ ∈ P.inertia (M ≃ₐ[ℚ] M) from by
      rw [AddSubgroup.mem_inertia]
      intro x
      have hx : σ i • (τ⁻¹ • x) - τ⁻¹ • x ∈ P₀ := by
        simpa using (show σ i • (τ⁻¹ • x) - τ⁻¹ • x ∈ P₀ from (AddSubgroup.mem_inertia.mp hσP₀) (τ⁻¹ • x))
      have hx' : τ • (σ i • (τ⁻¹ • x) - τ⁻¹ • x) ∈ τ • P₀ := by
        exact Ideal.smul_mem_pointwise_smul τ _ _ hx
      simpa [hτ, smul_sub, mul_smul, inv_mul_cancel_left] using hx')
  letI : Field (ℤ ⧸ p) := Ideal.Quotient.field p
  letI : Finite (ℤ ⧸ p) := Ideal.finiteQuotientOfFreeOfNeBot p hp_ne_bot
  letI : PerfectField (ℤ ⧸ p) := PerfectField.ofFinite
  letI : Field (𝓞 M ⧸ P) := Ideal.Quotient.field P
  letI : Algebra.IsIntegral (ℤ ⧸ p) (𝓞 M ⧸ P) :=
    Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P) (p := p)
  letI : Algebra.IsAlgebraic (ℤ ⧸ p) (𝓞 M ⧸ P) := by infer_instance
  letI : Algebra.IsSeparable (ℤ ⧸ p) (𝓞 M ⧸ P) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Field (𝓞 M ⧸ P₀) := Ideal.Quotient.field P₀
  letI : Algebra.IsIntegral (ℤ ⧸ p) (𝓞 M ⧸ P₀) :=
    Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P₀) (p := p)
  letI : Algebra.IsAlgebraic (ℤ ⧸ p) (𝓞 M ⧸ P₀) := by infer_instance
  letI : Algebra.IsSeparable (ℤ ⧸ p) (𝓞 M ⧸ P₀) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hram0 : p.ramificationIdxIn (𝓞 M) = 3 := by
    exact (Ideal.card_inertia_eq_ramificationIdxIn (G := (M ≃ₐ[ℚ] M)) p hp_ne_bot P₀).symm.trans hcard₀
  have hcardP : Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 := by
    exact (Ideal.card_inertia_eq_ramificationIdxIn (G := (M ≃ₐ[ℚ] M)) p hp_ne_bot P).trans hram0
  have hrel_inertia_bot : P.inertia H = ⊥ := by
    rcases Subgroup.bot_or_exists_ne_one (P.inertia H) with hbot | ⟨τH, hτHmem, hτHne⟩
    · exact hbot
    · have hτH_inertia : (τH : M ≃ₐ[ℚ] M) ∈ P.inertia (M ≃ₐ[ℚ] M) := by
        rw [AddSubgroup.mem_inertia] at hτHmem ⊢
        intro x
        simpa using (hτHmem x)
      have hτH_ne_one : (τH : M ≃ₐ[ℚ] M) ≠ 1 := by
        simpa using hτHne
      haveI : Fact (Nat.Prime 3) := ⟨by decide⟩
      have hρ_mem_zpowers :
          (⟨ρ, hρ_inertia⟩ : P.inertia (M ≃ₐ[ℚ] M)) ∈
            Subgroup.zpowers (⟨(τH : M ≃ₐ[ℚ] M), hτH_inertia⟩ : P.inertia (M ≃ₐ[ℚ] M)) := by
        exact mem_zpowers_of_prime_card hcardP (by simpa using hτH_ne_one)
      rcases Subgroup.mem_zpowers_iff.mp hρ_mem_zpowers with ⟨k, hk⟩
      have hpow_mem_H : ((τH : M ≃ₐ[ℚ] M) ^ k) ∈ H := by
        exact H.zpow_mem τH.2 k
      have hk' : ((τH : M ≃ₐ[ℚ] M) ^ k) = ρ := by
        exact congrArg Subtype.val hk
      have hρ_mem_H : ρ ∈ H := by
        rwa [hk'] at hpow_mem_H
      exact (hρ_not_mem hρ_mem_H).elim
  letI : Field F := inferInstance
  letI : NumberField F := inferInstance
  letI : IsGaloisGroup H F M := by
    dsimp [F]
    exact IsGaloisGroup.subgroup (G := (M ≃ₐ[ℚ] M)) (K := ℚ) (L := M) H
  let P_F : Ideal (𝓞 F) := P.under (𝓞 F)
  letI : P_F.LiesOver p := by
    dsimp [P_F]
    infer_instance
  have hP_F_ne_bot : P_F ≠ ⊥ := by
    exact Ideal.ne_bot_of_liesOver_of_ne_bot hp_ne_bot P_F
  letI : P_F.IsPrime := by
    dsimp [P_F]
    infer_instance
  letI : P_F.IsMaximal := by
    dsimp [P_F]
    infer_instance
  letI : P.LiesOver P_F := by
    dsimp [P_F]
    infer_instance
  letI : IsGaloisGroup H (𝓞 F) (𝓞 M) :=
    instIsGaloisGroupRingOfIntegersOfNumberField F M H
  letI : Field (𝓞 F ⧸ P_F) := Ideal.Quotient.field P_F
  letI : Finite (𝓞 F ⧸ P_F) := Ideal.finiteQuotientOfFreeOfNeBot P_F hP_F_ne_bot
  letI : PerfectField (𝓞 F ⧸ P_F) := PerfectField.ofFinite
  letI : Algebra.IsIntegral ((𝓞 F) ⧸ P_F) (𝓞 M ⧸ P) :=
    Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P) (p := P_F)
  letI : Algebra.IsAlgebraic ((𝓞 F) ⧸ P_F) (𝓞 M ⧸ P) := by
    infer_instance
  letI : Algebra.IsSeparable ((𝓞 F) ⧸ P_F) (𝓞 M ⧸ P) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hcard_rel : Nat.card (P.inertia H) = 1 := by
    simp [hrel_inertia_bot]
  have hram_relIn : P_F.ramificationIdxIn (𝓞 M) = 1 := by
    exact (Ideal.card_inertia_eq_ramificationIdxIn (G := H) P_F hP_F_ne_bot P).symm.trans hcard_rel
  have hram_rel : Ideal.ramificationIdx P_F P = 1 := by
    exact (Ideal.ramificationIdxIn_eq_ramificationIdx (p := P_F) (P := P) (G := H)).symm.trans hram_relIn
  have hP_ne_bot : P ≠ ⊥ := by
    exact Ideal.ne_bot_of_liesOver_of_ne_bot hp_ne_bot P
  have hunram : Algebra.IsUnramifiedAt (𝓞 F) P := by
    exact (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := 𝓞 F) (S := 𝓞 M) (p := P) hP_ne_bot).2 (by
      simpa [P_F] using hram_rel)
  exact (not_dvd_differentIdeal_iff (A := 𝓞 F) (B := 𝓞 M) (P := P)).2 hunram

theorem linearMapToCharacter_surjective (ℓ : ℕ) (lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3)
    (_hlin : lin ≠ 0) :
    Function.Surjective (linearMapToCharacter ℓ lin) := by
  classical
  have hx0 : ∃ x : Fin ℓ → ZMod 3, lin x ≠ 0 := by
    by_contra h
    apply _hlin
    apply LinearMap.ext
    intro x
    by_contra hx
    exact h ⟨x, hx⟩
  intro y
  rcases hx0 with ⟨x, hx⟩
  refine ⟨Multiplicative.ofAdd (((Multiplicative.toAdd y) * (lin x)⁻¹) • x), ?_⟩
  change lin (((Multiplicative.toAdd y) * (lin x)⁻¹) • x) = Multiplicative.toAdd y
  rw [LinearMap.map_smulₛₗ]
  change (((Multiplicative.toAdd y) * (lin x)⁻¹) * lin x) = Multiplicative.toAdd y
  rw [mul_assoc, inv_mul_cancel₀ hx, mul_one]

theorem nonempty_mulEquiv_transport_autCongr (F K L G : Type) [Field F] [Field K] [Field L] [Algebra F K] [Algebra F L] [Group G]
    (e : K ≃ₐ[F] L) :
    Nonempty ((K ≃ₐ[F] K) ≃* G) →
    Nonempty ((L ≃ₐ[F] L) ≃* G) := by
  intro h
  rcases h with ⟨η⟩
  exact ⟨(AlgEquiv.autCongr e).symm.trans η⟩

theorem proposition_3_2_compositum_and_F_bridge_base (r : Fin 1 → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1) :
    Nonempty (Proposition32BridgeData 1
      ((∏ i, r i) ^ 2)
      ((∏ i, r i) ^ (2 * 3 ^ (1 - 1)))) := by
  classical
  rcases cyclic_cubic_field_of_prime_mod3 (r 0) (_hr_prime 0) (_hr_mod3 0) with
    ⟨L, _instFieldL, _instCharZeroL, _instNumberFieldL, _instTotallyRealL, _instGaloisQL,
      _instAlgLCyclo, hfinrankL, hdiscrL, habsGalL⟩
  let eFin : Multiplicative (ZMod 3) ≃* Multiplicative (Fin 1 → ZMod 3) :=
    { toFun := fun z => Multiplicative.ofAdd (fun _ => Multiplicative.toAdd z)
      invFun := fun f => Multiplicative.ofAdd (Multiplicative.toAdd f 0)
      left_inv := by
        intro z
        rfl
      right_inv := by
        intro f
        change (fun _ => Multiplicative.toAdd f 0) = Multiplicative.toAdd f
        funext i
        fin_cases i
        rfl
      map_mul' := by
        intro a b
        rfl }
  have habsGal1 : Nonempty ((L ≃ₐ[ℚ] L) ≃* Multiplicative (Fin 1 → ZMod 3)) :=
    ⟨(Classical.choice habsGalL).trans eFin⟩
  have hfinrankLL : Module.finrank L L = 1 := Module.finrank_self L
  refine ⟨{
    M := L
    field_M := inferInstance
    charZero_M := inferInstance
    numberField_M := inferInstance
    totallyReal_M := inferInstance
    galoisQM := inferInstance
    F := L
    field_F := inferInstance
    charZero_F := inferInstance
    numberField_F := inferInstance
    totallyReal_F := inferInstance
    galoisQF := inferInstance
    algFM := inferInstance
    tower := inferInstance
    finiteDimensional := inferInstance
    galoisFM := inferInstance
    finrankQM := by
      simpa using hfinrankL
    absGalM := habsGal1
    discrM_eq := by
      simpa using hdiscrL
    finrankQF := by
      simp [hfinrankL]
    absGalF := habsGalL
    finrankFM := by
      simp [hfinrankLL]
    odd_finrankFM := by
      simp
    discrF_eq := by
      simpa using hdiscrL
    pow_rel := by
      intro σ
      have hσ : σ = 1 := by
        ext x
        simpa using σ.commutes x
      simp [hσ]
    comm_rel := by
      intro σ τ
      have hσ : σ = 1 := by
        ext x
        simpa using σ.commutes x
      have hτ : τ = 1 := by
        ext x
        simpa using τ.commutes x
      simp [hσ, hτ]
  }⟩

theorem ramificationIdxIn_dvd_pow_three_of_finrank (ℓ : ℕ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (M : Type) [Field M] [CharZero M] [NumberField M] [IsGalois ℚ M]
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (i : Fin ℓ) :
    ((Ideal.span {(r i : ℤ)} : Ideal ℤ).ramificationIdxIn (𝓞 M)) ∣ 3 ^ ℓ := by
  let p : Ideal ℤ := Ideal.span {(r i : ℤ)}
  have hri_ne_zero : (r i : ℤ) ≠ 0 := by
    exact_mod_cast (_hr_prime i).ne_zero
  have hp_ne_bot : p ≠ ⊥ := by
    simpa [p, Ideal.span_singleton_eq_bot] using hri_ne_zero
  letI : p.IsPrime := by
    dsimp [p]
    exact (Ideal.span_singleton_prime (α := ℤ) (p := (r i : ℤ)) hri_ne_zero).2
      ((Nat.prime_iff_prime_int).1 (_hr_prime i))
  letI : p.IsMaximal := IsPrime.to_maximal_ideal (S := p) hp_ne_bot
  have hcard :=
    Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn
      (p := p) hp_ne_bot (B := 𝓞 M) (G := M ≃ₐ[ℚ] M)
  rw [IsGalois.card_aut_eq_finrank ℚ M, _hfin] at hcard
  refine ⟨(p.primesOver (𝓞 M)).ncard * p.inertiaDegIn (𝓞 M), ?_⟩
  calc
    3 ^ ℓ = (p.primesOver (𝓞 M)).ncard * (p.ramificationIdxIn (𝓞 M) * p.inertiaDegIn (𝓞 M)) := by
      simp [hcard.symm]
    _ = p.ramificationIdxIn (𝓞 M) * ((p.primesOver (𝓞 M)).ncard * p.inertiaDegIn (𝓞 M)) := by
      simp [Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]

theorem ramificationIdxIn_le_three_of_rel_discr (ℓ : ℕ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1)))
    (i : Fin ℓ) :
    ((Ideal.span {(r i : ℤ)} : Ideal ℤ).ramificationIdxIn (𝓞 M)) ≤ 3 := by
  classical
  let p : Ideal ℤ := Ideal.span {(r i : ℤ)}
  let D : Ideal (𝓞 M) := differentIdeal ℤ (𝓞 M)
  let eIn : ℕ := p.ramificationIdxIn (𝓞 M)
  let fIn : ℕ := p.inertiaDegIn (𝓞 M)
  let g : ℕ := (p.primesOver (𝓞 M)).ncard
  have hri_prime : (r i).Prime := _hr_prime i
  have hri_ne_zero : (r i : ℤ) ≠ 0 := by
    exact_mod_cast hri_prime.ne_zero
  have hp_ne_bot : p ≠ ⊥ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact hri_ne_zero
  letI : Fact (Nat.Prime (r i)) := ⟨hri_prime⟩
  haveI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime (r i))
  have hedvd : eIn ∣ 3 ^ ℓ := by
    simpa [p, eIn] using
      ramificationIdxIn_dvd_pow_three_of_finrank ℓ r _hr_prime M _hfin i
  have he_ne_zero : eIn ≠ 0 := by
    simpa [p, eIn] using
      (Ideal.ramificationIdxIn_ne_zero (G := M ≃ₐ[ℚ] M) (p := p) (B := 𝓞 M) hp_ne_bot)
  have he_pos : 0 < eIn := Nat.pos_of_ne_zero he_ne_zero
  have hcard_aut : Nat.card (M ≃ₐ[ℚ] M) = 3 ^ ℓ := by
    calc
      Nat.card (M ≃ₐ[ℚ] M) = Nat.card (Multiplicative (Fin ℓ → ZMod 3)) :=
        Nat.card_congr e.toEquiv
      _ = Nat.card (Fin ℓ → ZMod 3) := rfl
      _ = 3 ^ ℓ := by
        simp
  have hfund : g * (eIn * fIn) = 3 ^ ℓ := by
    calc
      g * (eIn * fIn) = Nat.card (M ≃ₐ[ℚ] M) := by
        simpa [g, eIn, fIn] using
          (Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn
            (p := p) hp_ne_bot (B := 𝓞 M) (G := M ≃ₐ[ℚ] M))
      _ = 3 ^ ℓ := hcard_aut
  have hfactor_dvd (Q : p.primesOver (𝓞 M)) : ((Q : Ideal (𝓞 M)) ^ (eIn - 1)) ∣ D := by
    have hram : p.ramificationIdx (Q : Ideal (𝓞 M)) = eIn := by
      simpa [eIn] using
        (Ideal.ramificationIdxIn_eq_ramificationIdx
          (p := p) (P := (Q : Ideal (𝓞 M))) (B := 𝓞 M) (G := M ≃ₐ[ℚ] M)).symm
    have hpow_map : (Q : Ideal (𝓞 M)) ^ eIn ∣ Ideal.map (algebraMap ℤ (𝓞 M)) p := by
      rw [Ideal.dvd_iff_le, ← hram]
      exact Ideal.le_pow_ramificationIdx
    simpa [D] using
      (pow_sub_one_dvd_differentIdeal (A := ℤ) (B := 𝓞 M)
        (P := (Q : Ideal (𝓞 M))) eIn hp_ne_bot hpow_map)
  have hpair : Pairwise fun Q R : p.primesOver (𝓞 M) =>
      IsCoprime (((Q : Ideal (𝓞 M)) ^ (eIn - 1))) (((R : Ideal (𝓞 M)) ^ (eIn - 1))) := by
    intro Q R hQR
    have hQ_ne_bot : (Q : Ideal (𝓞 M)) ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hp_ne_bot Q.2
    have hR_ne_bot : (R : Ideal (𝓞 M)) ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hp_ne_bot R.2
    have hQ_max : ((Q : Ideal (𝓞 M)).IsMaximal) := Q.2.1.isMaximal hQ_ne_bot
    have hR_max : ((R : Ideal (𝓞 M)).IsMaximal) := R.2.1.isMaximal hR_ne_bot
    have hcop : IsCoprime (Q : Ideal (𝓞 M)) (R : Ideal (𝓞 M)) :=
      Ideal.isCoprime_of_isMaximal (I := (Q : Ideal (𝓞 M))) (J := (R : Ideal (𝓞 M)))
        (Subtype.coe_injective.ne hQR)
    exact Ideal.isCoprime_iff_sup_eq.mpr
      (Ideal.pow_sup_pow_eq_top (m := eIn - 1) (n := eIn - 1) hcop.sup_eq)
  have hprod_dvd : (∏ Q : p.primesOver (𝓞 M), ((Q : Ideal (𝓞 M)) ^ (eIn - 1))) ∣ D := by
    exact Fintype.prod_dvd_of_coprime
      (s := fun Q : p.primesOver (𝓞 M) => ((Q : Ideal (𝓞 M)) ^ (eIn - 1))) hpair hfactor_dvd
  have hnorm_factor (Q : p.primesOver (𝓞 M)) :
      Ideal.absNorm ((Q : Ideal (𝓞 M)) ^ (eIn - 1)) = (r i) ^ (fIn * (eIn - 1)) := by
    rw [map_pow, Ideal.absNorm_eq_pow_inertiaDeg' (P := (Q : Ideal (𝓞 M))) hri_prime]
    rw [← Ideal.inertiaDegIn_eq_inertiaDeg (p := p) (P := (Q : Ideal (𝓞 M))) (B := 𝓞 M)
      (G := M ≃ₐ[ℚ] M)]
    simp [fIn, pow_mul, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
  have hnorm_prod :
      Ideal.absNorm (∏ Q : p.primesOver (𝓞 M), ((Q : Ideal (𝓞 M)) ^ (eIn - 1)))
        = (r i) ^ (g * (fIn * (eIn - 1))) := by
    rw [map_prod]
    simp_rw [hnorm_factor]
    calc
      (∏ Q : p.primesOver (𝓞 M), (r i) ^ (fIn * (eIn - 1))) =
          ((r i) ^ (fIn * (eIn - 1))) ^ Fintype.card (p.primesOver (𝓞 M)) := by
            simp [Finset.prod_const]
      _ = ((r i) ^ (fIn * (eIn - 1))) ^ Nat.card (p.primesOver (𝓞 M)) := by
            rw [Nat.card_eq_fintype_card]
      _ = ((r i) ^ (fIn * (eIn - 1))) ^ g := by
            rw [Nat.card_coe_set_eq]
      _ = (r i) ^ (g * (fIn * (eIn - 1))) := by
            simp [pow_mul, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
  have hnorm_dvd : (r i) ^ (g * (fIn * (eIn - 1))) ∣ Ideal.absNorm D := by
    rw [← hnorm_prod]
    exact Ideal.absNorm_dvd_absNorm_of_le (Ideal.dvd_iff_le.mp hprod_dvd)
  have hprod_ne_zero : ∏ j, r j ≠ 0 := by
    exact Finset.prod_ne_zero_iff.mpr fun j _ => (_hr_prime j).ne_zero
  have hfactor_prod : (∏ j, r j).factorization (r i) = 1 := by
    rw [Nat.factorization_prod_apply (p := r i) (S := Finset.univ) (g := r)]
    · rw [Finset.sum_eq_single i]
      · simpa using Nat.Prime.factorization_self hri_prime
      · intro j _ hji
        apply Nat.factorization_eq_zero_of_not_dvd
        intro hdiv
        have hEq : r i = r j := (Nat.prime_dvd_prime_iff_eq hri_prime (_hr_prime j)).mp hdiv
        exact hji (_hr_inj hEq).symm
      · intro hi
        simp at hi
    · intro j _
      exact (_hr_prime j).ne_zero
  have hnorm_dvd_discr : (r i) ^ (g * (fIn * (eIn - 1))) ∣ (NumberField.discr M).natAbs := by
    simpa [D, NumberField.absNorm_differentIdeal M (𝓞 M)] using hnorm_dvd
  have hbound_exp : g * (fIn * (eIn - 1)) ≤ 2 * 3 ^ (ℓ - 1) := by
    have hpow_dvd : (r i) ^ (g * (fIn * (eIn - 1))) ∣ ((∏ j, r j) ^ (2 * 3 ^ (ℓ - 1))) := by
      simpa [_hdisc] using hnorm_dvd_discr
    have hfac_le :=
      (Nat.Prime.pow_dvd_iff_le_factorization hri_prime (pow_ne_zero _ hprod_ne_zero)).mp hpow_dvd
    rw [Nat.factorization_pow] at hfac_le
    change g * (fIn * (eIn - 1)) ≤
      (2 * 3 ^ (ℓ - 1)) * ((∏ j, r j).factorization (r i)) at hfac_le
    simpa [hfactor_prod] using hfac_le
  have hgf_mul_e : (g * fIn) * eIn = 3 ^ ℓ := by
    simpa [Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using hfund
  have hgf_mul_sub : (g * fIn) * (eIn - 1) ≤ 2 * 3 ^ (ℓ - 1) := by
    simpa [Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using hbound_exp
  have hℓpos : 0 < ℓ := lt_of_le_of_lt (Nat.zero_le _) i.is_lt
  have hpow_succ : 3 ^ ℓ = 3 ^ (ℓ - 1) * 3 := by
    nth_rw 1 [show ℓ = Nat.succ (ℓ - 1) by omega]
    rw [pow_succ]
  have ht_eq : 3 ^ ℓ = (g * fIn) * (eIn - 1) + (g * fIn) := by
    calc
      3 ^ ℓ = (g * fIn) * eIn := hgf_mul_e.symm
      _ = (g * fIn) * ((eIn - 1) + 1) := by
        congr 1
        omega
      _ = (g * fIn) * (eIn - 1) + (g * fIn) := by
        rw [Nat.mul_add, Nat.mul_one]
  have hgf_ge : 3 ^ (ℓ - 1) ≤ g * fIn := by
    have htmp : 3 ^ ℓ ≤ 2 * 3 ^ (ℓ - 1) + (g * fIn) := by
      rw [ht_eq]
      exact Nat.add_le_add_right hgf_mul_sub (g * fIn)
    rw [hpow_succ] at htmp
    omega
  have hmul_le : 3 ^ (ℓ - 1) * eIn ≤ 3 ^ (ℓ - 1) * 3 := by
    calc
      3 ^ (ℓ - 1) * eIn ≤ (g * fIn) * eIn := by
        exact Nat.mul_le_mul_right eIn hgf_ge
      _ = 3 ^ ℓ := hgf_mul_e
      _ = 3 ^ (ℓ - 1) * 3 := hpow_succ
  exact le_of_mul_le_mul_left hmul_le (pow_pos (by decide : 0 < 3) _)

theorem exists_ramified_inertia_generators_rel_discr (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ σ : Fin ℓ → (M ≃ₐ[ℚ] M),
      ∀ i, ∃ P : Ideal (𝓞 M),
        P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) ∧
        Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 ∧
        σ i ∈ P.inertia (M ≃ₐ[ℚ] M) ∧
        σ i ≠ 1 := by
  classical
  have hGcard : Nat.card (M ≃ₐ[ℚ] M) = 3 ^ ℓ := by
    rw [IsGalois.card_aut_eq_finrank ℚ M, _hfin]
  have hExistsFor : ∀ i : Fin ℓ, ∃ σi : (M ≃ₐ[ℚ] M), ∃ P : Ideal (𝓞 M),
      P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) ∧
      Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 ∧
      σi ∈ P.inertia (M ≃ₐ[ℚ] M) ∧ σi ≠ 1 := by
    intro i
    let p : Ideal ℤ := Ideal.span {(r i : ℤ)}
    have hpmax : p.IsMaximal := by
      dsimp [p]
      letI : Fact (Nat.Prime (r i)) := ⟨_hr_prime i⟩
      simpa using (Int.ideal_span_isMaximal_of_prime (r i))
    have hpne : p ≠ ⊥ := by
      intro hp
      have hmem : ((r i : ℤ)) ∈ p := by exact Ideal.subset_span (by simp)
      rw [hp] at hmem
      exact (show (r i : ℤ) ≠ 0 by exact_mod_cast (_hr_prime i).ne_zero) hmem
    obtain ⟨Q⟩ := (Ideal.nonempty_primesOver (R := ℤ) (S := 𝓞 M) p)
    haveI : p.IsMaximal := hpmax
    haveI : p.IsPrime := hpmax.isPrime
    haveI : Q.1.IsMaximal := Ideal.primesOver.isMaximal (p := p) Q
    haveI : Q.1.LiesOver p := Ideal.primesOver.liesOver (p := p) Q
    letI : Field (ℤ ⧸ p) := Ideal.Quotient.field p
    letI : Field ((𝓞 M) ⧸ Q.1) := Ideal.Quotient.field Q.1
    have hQne : Q.1 ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver (S := 𝓞 M) hpne Q.2
    have hsepQ : Algebra.IsSeparable (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) := by
      letI : Algebra (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) := by infer_instance
      let eZ : ℤ ⧸ p ≃+* ZMod (r i) := by simpa [p] using (Int.quotientSpanNatEquivZMod (r i))
      letI : NeZero (r i) := ⟨(_hr_prime i).ne_zero⟩
      letI : Fintype (ZMod (r i)) := inferInstance
      letI : Fintype (ℤ ⧸ p) := Fintype.ofEquiv (ZMod (r i)) eZ.symm.toEquiv
      letI : Finite (ℤ ⧸ p) := Finite.of_fintype (ℤ ⧸ p)
      letI : Finite ((𝓞 M) ⧸ Q.1) := Ideal.finiteQuotientOfFreeOfNeBot Q.1 hQne
      letI : Module.Finite (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) := Module.Finite.of_finite
      letI : PerfectField (ℤ ⧸ p) := PerfectField.ofFinite
      letI : Algebra.IsAlgebraic (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) :=
        Algebra.IsAlgebraic.of_finite (R := ℤ ⧸ p) (A := ((𝓞 M) ⧸ Q.1))
      exact @Algebra.IsAlgebraic.isSeparable_of_perfectField
        (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) _ _ (show Algebra (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) from inferInstance) inferInstance inferInstance
    letI : Algebra.IsSeparable (ℤ ⧸ p) ((𝓞 M) ⧸ Q.1) := hsepQ
    have hcardQ : Nat.card (Q.1.inertia (M ≃ₐ[ℚ] M)) = p.ramificationIdxIn (𝓞 M) := by
      simpa using (Ideal.card_inertia_eq_ramificationIdxIn (G := M ≃ₐ[ℚ] M) p hpne Q.1)
    have hdiv_card : Nat.card (Q.1.inertia (M ≃ₐ[ℚ] M)) ∣ Nat.card (M ≃ₐ[ℚ] M) :=
      Subgroup.card_subgroup_dvd_card (Q.1.inertia (M ≃ₐ[ℚ] M))
    have hdiv_e : p.ramificationIdxIn (𝓞 M) ∣ 3 ^ ℓ := by
      rw [← hcardQ]
      rw [hGcard] at hdiv_card
      exact hdiv_card
    have hle3 : p.ramificationIdxIn (𝓞 M) ≤ 3 := by
      simpa [p] using ramificationIdxIn_le_three_of_rel_discr ℓ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc i
    have hne0 : p.ramificationIdxIn (𝓞 M) ≠ 0 := by
      exact Ideal.ramificationIdxIn_ne_zero (G := M ≃ₐ[ℚ] M) (B := 𝓞 M) (p := p) hpne
    have hodd : Odd (3 ^ ℓ) := by
      exact Odd.pow (by decide : Odd 3)
    have hnot2 : ¬ 2 ∣ 3 ^ ℓ := Odd.not_two_dvd_nat hodd
    have hnot2' : p.ramificationIdxIn (𝓞 M) ≠ 2 := by
      intro h2
      apply hnot2
      have : 2 ∣ p.ramificationIdxIn (𝓞 M) := by
        simp [h2]
      exact dvd_trans this hdiv_e
    have hri_dvd_disc : r i ∣ (NumberField.discr M).natAbs := by
      rw [_hdisc]
      refine dvd_pow ?_ (Nat.mul_ne_zero (by decide) (pow_ne_zero _ (by decide)))
      exact Finset.dvd_prod_of_mem (fun j => r j) (by simp)
    have hri_dvd_diff : r i ∣ Ideal.absNorm (differentIdeal ℤ (𝓞 M)) := by
      rw [NumberField.absNorm_differentIdeal M (𝓞 M)]
      exact hri_dvd_disc
    have hdiff_ne_bot : (differentIdeal ℤ (𝓞 M)) ≠ ⊥ := by
      apply (Ideal.absNorm_eq_zero_iff).not.mp
      rw [NumberField.absNorm_differentIdeal M (𝓞 M)]
      exact Int.natAbs_ne_zero.mpr (NumberField.discr_ne_zero (K := M))
    have hnormFactors : ((UniqueFactorizationMonoid.normalizedFactors (differentIdeal ℤ (𝓞 M))).map Ideal.absNorm).prod = Ideal.absNorm (differentIdeal ℤ (𝓞 M)) := by
      rw [Multiset.prod_hom]
      simp [prod_normalizedFactors_eq_self (I := differentIdeal ℤ (𝓞 M)) hdiff_ne_bot]
    have hri_dvd_normFactors : r i ∣ ((UniqueFactorizationMonoid.normalizedFactors (differentIdeal ℤ (𝓞 M))).map Ideal.absNorm).prod := by
      rw [hnormFactors]
      exact hri_dvd_diff
    have hriPrime : Prime (r i) := Nat.prime_iff.mp (_hr_prime i)
    obtain ⟨Pdiv, hPdiv_mem, hri_dvd_absNormPdiv⟩ := Prime.exists_mem_multiset_map_dvd hriPrime hri_dvd_normFactors
    have hPdiv_prime : Pdiv.IsPrime := (Ideal.mem_normalizedFactors_iff (I := differentIdeal ℤ (𝓞 M)) hdiff_ne_bot).mp hPdiv_mem |>.1
    have hPdiv_le : differentIdeal ℤ (𝓞 M) ≤ Pdiv := (Ideal.mem_normalizedFactors_iff (I := differentIdeal ℤ (𝓞 M)) hdiff_ne_bot).mp hPdiv_mem |>.2
    have hPdiv_dvd : Pdiv ∣ differentIdeal ℤ (𝓞 M) := Ideal.dvd_iff_le.mpr hPdiv_le
    haveI : Pdiv.IsPrime := hPdiv_prime
    haveI : NeZero Pdiv := ⟨UniqueFactorizationMonoid.ne_zero_of_mem_normalizedFactors hPdiv_mem⟩
    have hPdiv_absNorm_under_prime : Nat.Prime (Ideal.absNorm (Ideal.under ℤ Pdiv)) := Nat.absNorm_under_prime Pdiv
    have hPdiv_absNorm_eq_ri : Ideal.absNorm (Ideal.under ℤ Pdiv) = r i := by
      letI : Pdiv.LiesOver (Ideal.span {(Ideal.absNorm (Ideal.under ℤ Pdiv) : ℤ)}) := Int.liesOver_span_absNorm Pdiv
      have hpow : Ideal.absNorm Pdiv = Ideal.absNorm (Ideal.under ℤ Pdiv) ^ ((Ideal.span {(Ideal.absNorm (Ideal.under ℤ Pdiv) : ℤ)}).inertiaDeg Pdiv) := by
        simpa using (Ideal.absNorm_eq_pow_inertiaDeg' (P := Pdiv) (p := Ideal.absNorm (Ideal.under ℤ Pdiv)) hPdiv_absNorm_under_prime)
      have hdivpow : r i ∣ Ideal.absNorm (Ideal.under ℤ Pdiv) ^ ((Ideal.span {(Ideal.absNorm (Ideal.under ℤ Pdiv) : ℤ)}).inertiaDeg Pdiv) := by
        rw [← hpow]
        exact hri_dvd_absNormPdiv
      exact (Nat.prime_eq_prime_of_dvd_pow (_hr_prime i) hPdiv_absNorm_under_prime hdivpow).symm
    have hPdiv_liesOver_p : Pdiv.LiesOver p := by
      simpa [p, hPdiv_absNorm_eq_ri] using (Int.liesOver_span_absNorm Pdiv)
    have hPdiv_ne : Pdiv ≠ ⊥ := UniqueFactorizationMonoid.ne_zero_of_mem_normalizedFactors hPdiv_mem
    have hram_ne_one : p.ramificationIdxIn (𝓞 M) ≠ 1 := by
      intro h1
      have hunr : Algebra.IsUnramifiedAt ℤ Pdiv := by
        rw [Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := ℤ) (S := 𝓞 M) (p := Pdiv) hPdiv_ne]
        rw [← Ideal.over_def (A := ℤ) (P := Pdiv) (p := p)]
        rw [← Ideal.ramificationIdxIn_eq_ramificationIdx (p := p) (P := Pdiv) (G := M ≃ₐ[ℚ] M)]
        exact h1
      exact ((dvd_differentIdeal_iff (A := ℤ) (B := 𝓞 M) (P := Pdiv)).mp hPdiv_dvd) hunr
    have he3 : p.ramificationIdxIn (𝓞 M) = 3 := by
      omega
    have hcardQ3 : Nat.card (Q.1.inertia (M ≃ₐ[ℚ] M)) = 3 := by
      rw [hcardQ, he3]
    have hQinertia_ne_bot : Q.1.inertia (M ≃ₐ[ℚ] M) ≠ ⊥ := by
      intro hbot
      have : Nat.card (Q.1.inertia (M ≃ₐ[ℚ] M)) = 1 := by simp [hbot]
      omega
    rcases (Subgroup.ne_bot_iff_exists_ne_one).mp hQinertia_ne_bot with ⟨σi, hσi_ne⟩
    refine ⟨σi.1, Q.1, Q.2, hcardQ3, σi.2, ?_⟩
    simpa using hσi_ne
  choose σ hσ using hExistsFor
  refine ⟨σ, ?_⟩
  intro i
  rcases hσ i with ⟨P, hPmem, hPcard, hσmem, hσne⟩
  exact ⟨P, hPmem, hPcard, hσmem, hσne⟩

theorem ramification_vectors_span_top_rel_discr (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ σ : Fin ℓ → (M ≃ₐ[ℚ] M),
      (∀ i, ∃ P : Ideal (𝓞 M),
        P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) ∧
        Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 ∧
        σ i ∈ P.inertia (M ≃ₐ[ℚ] M) ∧
        σ i ≠ 1) ∧
      Submodule.span (ZMod 3)
        (Set.range (fun i => Multiplicative.toAdd (e (σ i)))) = ⊤ := by
  classical
  obtain ⟨σ, hσ_mem⟩ :=
    exists_ramified_inertia_generators_rel_discr ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc
  refine ⟨σ, hσ_mem, ?_⟩
  let v : Fin ℓ → (Fin ℓ → ZMod 3) := fun i => Multiplicative.toAdd (e (σ i))
  let W : Submodule (ZMod 3) (Fin ℓ → ZMod 3) := Submodule.span (ZMod 3) (Set.range v)
  by_contra hW
  have hW' : W ≠ ⊤ := hW
  have hWlt : W < ⊤ := lt_of_le_of_ne le_top hW'
  obtain ⟨lin, hlin_ne, hW_le⟩ := Submodule.exists_le_ker_of_lt_top W hWlt
  let ψ := linearMapToCharacter ℓ lin
  have hψ_surj : Function.Surjective ψ := linearMapToCharacter_surjective ℓ lin hlin_ne
  let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
  have hφ_surj : Function.Surjective φ := by
    intro z
    rcases hψ_surj z with ⟨y, hy⟩
    rcases e.surjective y with ⟨x, rfl⟩
    exact ⟨x, hy⟩
  let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
  let F0 : IntermediateField ℚ M := IntermediateField.fixedField H
  haveI : H.Normal := by
    simpa [H] using (MonoidHom.normal_ker φ)
  haveI : IsGalois ℚ F0 := by
    simpa [F0] using (IsGalois.of_fixedField_normal_subgroup (K := ℚ) (L := M) H)
  have hσker : ∀ i, σ i ∈ H := by
    intro i
    change φ (σ i) = 1
    dsimp [H, φ, ψ, linearMapToCharacter]
    apply congrArg Multiplicative.ofAdd
    change lin (v i) = 0
    have hvW : v i ∈ W := by
      exact Submodule.subset_span ⟨i, rfl⟩
    exact hW_le hvW
  have hindex_H : H.index = 3 := by
    calc
      H.index = Nat.card φ.range := by
        simpa [H] using (Subgroup.index_ker φ)
      _ = Nat.card (⊤ : Subgroup (Multiplicative (ZMod 3))) := by
        rw [MonoidHom.range_eq_top.2 hφ_surj]
      _ = Nat.card (Multiplicative (ZMod 3)) := Subgroup.card_top
      _ = Nat.card (ZMod 3) := Nat.card_congr Multiplicative.toAdd
      _ = 3 := Nat.card_zmod 3
  have hfinrank_F0 : Module.finrank ℚ F0 = 3 := by
    calc
      Module.finrank ℚ F0 = F0.fixingSubgroup.index := by
        simpa [F0] using (IntermediateField.finrank_eq_fixingSubgroup_index F0)
      _ = H.index := by
        rw [show F0.fixingSubgroup = H by simpa [F0] using (IntermediateField.fixingSubgroup_fixedField (F := ℚ) (E := M) H)]
      _ = 3 := hindex_H
  have hram_F0 : ∀ i : Fin ℓ,
      Ideal.ramificationIdxIn (Ideal.span {(r i : ℤ)}) (𝓞 F0) = 1 := by
    intro i
    let p : Ideal ℤ := Ideal.span {(r i : ℤ)}
    rcases hσ_mem i with ⟨P, hPmem, hcardI, hσI, hσne⟩
    let P' : p.primesOver (𝓞 M) := ⟨P, hPmem⟩
    haveI : P.IsPrime := by
      simpa using (Ideal.primesOver.isPrime (p := p) (B := 𝓞 M) P')
    haveI : P.LiesOver p := by
      simpa using (Ideal.primesOver.liesOver (p := p) (B := 𝓞 M) P')
    have hp_ne_bot : p ≠ ⊥ := by
      have hri_ne_zero : (r i : ℤ) ≠ 0 := by
        exact_mod_cast (_hr_prime i).ne_zero
      simpa [p, Ideal.span_singleton_eq_bot] using hri_ne_zero
    have hP_ne_bot : P ≠ ⊥ := Ideal.ne_bot_of_mem_primesOver hp_ne_bot hPmem
    haveI : P.IsMaximal := (show P.IsPrime from inferInstance).isMaximal hP_ne_bot
    have hI_le : P.inertia (M ≃ₐ[ℚ] M) ≤ H := by
      intro τ hτ
      have hσne' : (⟨σ i, hσI⟩ : P.inertia (M ≃ₐ[ℚ] M)) ≠ 1 := by
        intro h
        exact hσne (Subtype.ext_iff.mp h)
      have hτzp : (⟨τ, hτ⟩ : P.inertia (M ≃ₐ[ℚ] M)) ∈ Subgroup.zpowers (⟨σ i, hσI⟩ : P.inertia (M ≃ₐ[ℚ] M)) := by
        exact mem_zpowers_of_prime_card (p := 3) hcardI hσne'
      rcases Subgroup.mem_zpowers_iff.mp hτzp with ⟨n, hn⟩
      have hτeq : τ = (σ i) ^ n := by
        have := congrArg Subtype.val hn
        simpa using this.symm
      rw [hτeq]
      exact H.zpow_mem (hσker i) n
    let P0 : Ideal (𝓞 F0) := P.under (𝓞 F0)
    haveI : P.LiesOver P0 := Ideal.over_under (A := 𝓞 F0) (P := P)
    haveI : P0.LiesOver p := by
      simpa [P0] using (Ideal.under_liesOver_of_liesOver (B := 𝓞 F0) (𝔓 := P) (p := p))
    haveI : P0.IsPrime := Ideal.IsPrime.under (A := 𝓞 F0) (P := P)
    have hP0_ne_bot : P0 ≠ ⊥ := Ideal.ne_bot_of_liesOver_of_ne_bot hp_ne_bot P0
    haveI : P0.IsMaximal := (show P0.IsPrime from inferInstance).isMaximal hP0_ne_bot
    have hcardI_H : Nat.card (P.inertia H) = 3 := by
      have hsubeq : (P.inertia (M ≃ₐ[ℚ] M)).subgroupOf H = P.inertia H := by
        simp [Ideal.inertia]
      have hEqv := Subgroup.subgroupOfEquivOfLe hI_le
      calc
        Nat.card (P.inertia H) = Nat.card ((P.inertia (M ≃ₐ[ℚ] M)).subgroupOf H) := by rw [hsubeq]
        _ = Nat.card (P.inertia (M ≃ₐ[ℚ] M)) := Nat.card_congr hEqv.toEquiv
        _ = 3 := hcardI
    haveI : IsGaloisGroup H F0 M := by
      simpa [F0] using (IsGaloisGroup.subgroup (G := M ≃ₐ[ℚ] M) (K := ℚ) (L := M) (H := H))
    haveI : IsGaloisGroup H (𝓞 F0) (𝓞 M) := by
      exact instIsGaloisGroupRingOfIntegersOfNumberField F0 M H
    letI : Field ((𝓞 F0) ⧸ P0) := Ideal.Quotient.field P0
    letI : Field ((𝓞 M) ⧸ P) := Ideal.Quotient.field P
    have hcardQ_ne_zero : Nat.card ((𝓞 F0) ⧸ P0) ≠ 0 := by
      rw [← Submodule.cardQuot_apply, ← Ideal.absNorm_apply]
      exact mt (Ideal.absNorm_eq_zero_iff.mp) hP0_ne_bot
    letI : Finite ((𝓞 F0) ⧸ P0) := Nat.finite_of_card_ne_zero hcardQ_ne_zero
    letI : PerfectField ((𝓞 F0) ⧸ P0) := PerfectField.ofFinite
    letI : Algebra.IsIntegral ((𝓞 F0) ⧸ P0) ((𝓞 M) ⧸ P) :=
      Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P) (p := P0)
    letI : Algebra.IsAlgebraic ((𝓞 F0) ⧸ P0) ((𝓞 M) ⧸ P) :=
      (Algebra.isAlgebraic_iff_isIntegral).2 inferInstance
    letI : Algebra.IsSeparable ((𝓞 F0) ⧸ P0) ((𝓞 M) ⧸ P) :=
      Algebra.IsAlgebraic.isSeparable_of_perfectField
    have hram_M_F0 : Ideal.ramificationIdxIn P0 (𝓞 M) = 3 := by
      calc
        Ideal.ramificationIdxIn P0 (𝓞 M) = Nat.card (P.inertia H) := by
          symm
          simpa [P0] using
            (Ideal.card_inertia_eq_ramificationIdxIn (G := H) (p := P0) (hp := hP0_ne_bot) (P := P))
        _ = 3 := hcardI_H
    letI : Fact (Nat.Prime (r i)) := ⟨_hr_prime i⟩
    haveI : p.IsMaximal := by
      simpa [p] using (Int.ideal_span_isMaximal_of_prime (p := r i))
    letI : Field (ℤ ⧸ p) := Ideal.Quotient.field p
    letI : Fintype (ℤ ⧸ p) :=
      Fintype.ofEquiv (ZMod (r i)) (Int.quotientSpanNatEquivZMod (r i)).symm.toEquiv
    letI : Finite (ℤ ⧸ p) := Finite.of_fintype (ℤ ⧸ p)
    letI : PerfectField (ℤ ⧸ p) := PerfectField.ofFinite
    letI : Algebra.IsIntegral (ℤ ⧸ p) (𝓞 M ⧸ P) :=
      Ideal.Quotient.algebra_isIntegral_of_liesOver (P := P) (p := p)
    letI : Algebra.IsAlgebraic (ℤ ⧸ p) (𝓞 M ⧸ P) :=
      (Algebra.isAlgebraic_iff_isIntegral).2 inferInstance
    letI : Algebra.IsSeparable (ℤ ⧸ p) (𝓞 M ⧸ P) :=
      Algebra.IsAlgebraic.isSeparable_of_perfectField
    have hram_M_Q : Ideal.ramificationIdxIn p (𝓞 M) = 3 := by
      calc
        Ideal.ramificationIdxIn p (𝓞 M) = Nat.card (P.inertia (M ≃ₐ[ℚ] M)) := by
          symm
          simpa [p] using
            (Ideal.card_inertia_eq_ramificationIdxIn (G := M ≃ₐ[ℚ] M) (p := p) (hp := hp_ne_bot) (P := P))
        _ = 3 := hcardI
    haveI : IsGaloisGroup (F0 ≃ₐ[ℚ] F0) ℚ F0 := by infer_instance
    haveI : IsGaloisGroup (F0 ≃ₐ[ℚ] F0) ℤ (𝓞 F0) := by
      exact instIsGaloisGroupIntRingOfIntegersOfRat F0 (F0 ≃ₐ[ℚ] F0)
    haveI : IsGaloisGroup (M ≃ₐ[ℚ] M) ℤ (𝓞 M) := by
      exact instIsGaloisGroupIntRingOfIntegersOfRat M (M ≃ₐ[ℚ] M)
    have hmap_p_ne_bot : Ideal.map (algebraMap ℤ (𝓞 M)) p ≠ ⊥ :=
      Ideal.map_ne_bot_of_ne_bot hp_ne_bot
    have hmap_P0_ne_bot : Ideal.map (algebraMap (𝓞 F0) (𝓞 M)) P0 ≠ ⊥ :=
      Ideal.map_ne_bot_of_ne_bot hP0_ne_bot
    have hmul :=
      Ideal.ramificationIdxIn_mul_ramificationIdxIn (P := P0) (G := F0 ≃ₐ[ℚ] F0)
        (C := 𝓞 M) (GAC := M ≃ₐ[ℚ] M) (GBC := H) hmap_p_ne_bot hmap_P0_ne_bot
    rw [hram_M_F0, hram_M_Q] at hmul
    have hp_ram_pos : 0 < Ideal.ramificationIdxIn p (𝓞 F0) := by
      exact Nat.pos_of_ne_zero (Ideal.ramificationIdxIn_ne_zero (G := F0 ≃ₐ[ℚ] F0) (B := 𝓞 F0) hp_ne_bot)
    have hmul_int : ((Ideal.ramificationIdxIn p (𝓞 F0) : ℤ) * 3 = 3) := by
      exact_mod_cast hmul
    have hp_ram_pos_int : (0 : ℤ) < Ideal.ramificationIdxIn p (𝓞 F0) := by
      exact_mod_cast hp_ram_pos
    have hram_eq_int : (Ideal.ramificationIdxIn p (𝓞 F0) : ℤ) = 1 := by
      omega
    exact_mod_cast hram_eq_int
  haveI : IsGaloisGroup (F0 ≃ₐ[ℚ] F0) ℚ F0 := by infer_instance
  haveI : IsGaloisGroup (F0 ≃ₐ[ℚ] F0) ℤ (𝓞 F0) := by
    exact instIsGaloisGroupIntRingOfIntegersOfRat F0 (F0 ≃ₐ[ℚ] F0)
  have hdiff_top : differentIdeal ℤ (𝓞 F0) = ⊤ := by
    by_contra hdiff
    obtain ⟨Q, hQmax, hdiff_leQ⟩ := Ideal.exists_le_maximal (differentIdeal ℤ (𝓞 F0)) hdiff
    have hQne_bot : Q ≠ ⊥ := by
      exact Ring.ne_bot_of_isMaximal_of_not_isField hQmax (NumberField.RingOfIntegers.not_isField (K := F0))
    haveI : Q.IsPrime := hQmax.isPrime
    haveI : NeZero Q := ⟨hQne_bot⟩
    let p : ℕ := Ideal.absNorm (Ideal.under ℤ Q)
    have hp_prime : p.Prime := by
      simpa [p] using (Nat.absNorm_under_prime Q)
    have hp_dvd_absNormQ : p ∣ Ideal.absNorm Q := by
      simpa [p] using (Int.absNorm_under_dvd_absNorm Q)
    have hQ_dvd_diff : Q ∣ differentIdeal ℤ (𝓞 F0) := by
      exact (Ideal.dvd_iff_le).2 hdiff_leQ
    have hp_dvd_discrF0 : p ∣ (NumberField.discr F0).natAbs := by
      refine dvd_trans hp_dvd_absNormQ ?_
      simpa [NumberField.absNorm_differentIdeal F0 (𝓞 F0)] using
        (Ideal.absNorm_dvd_absNorm_of_le hdiff_leQ)
    have hp_dvd_discrF0_int : (p : ℤ) ∣ NumberField.discr F0 := by
      exact Int.natCast_dvd.mpr hp_dvd_discrF0
    have hp_dvd_discrM_int : (p : ℤ) ∣ NumberField.discr M := by
      exact dvd_trans hp_dvd_discrF0_int (NumberField.discr_dvd_discr (K := F0) (L := M))
    have hp_dvd_discrM : p ∣ (NumberField.discr M).natAbs := by
      exact Int.natCast_dvd.mp hp_dvd_discrM_int
    rw [_hdisc] at hp_dvd_discrM
    have hp_dvd_prod : p ∣ ∏ i, r i := hp_prime.dvd_of_dvd_pow hp_dvd_discrM
    obtain ⟨i, -, hp_dvd_ri⟩ : ∃ i ∈ (Finset.univ : Finset (Fin ℓ)), p ∣ r i := by
      simpa using (Prime.dvd_finset_prod_iff (Nat.prime_iff.mp hp_prime) r).1 hp_dvd_prod
    have hpeq : p = r i := by
      rcases (Nat.dvd_prime (_hr_prime i)).1 hp_dvd_ri with hp1 | hp2
      · exact (hp_prime.ne_one hp1).elim
      · exact hp2
    haveI : Q.LiesOver (Ideal.span {(r i : ℤ)}) := by
      refine ⟨?_⟩
      simpa [p, hpeq] using (Int.ideal_span_absNorm_eq_self (Ideal.under ℤ Q))
    have hram_Q : (Ideal.span {(r i : ℤ)}).ramificationIdx Q = 1 := by
      rw [← Ideal.ramificationIdxIn_eq_ramificationIdx (p := Ideal.span {(r i : ℤ)}) (P := Q)
        (B := 𝓞 F0) (G := F0 ≃ₐ[ℚ] F0)]
      exact hram_F0 i
    have hnot_unram : ¬ Algebra.IsUnramifiedAt ℤ Q := by
      exact (dvd_differentIdeal_iff (A := ℤ) (B := 𝓞 F0) (P := Q)).1 hQ_dvd_diff
    have hQ_unram : Algebra.IsUnramifiedAt ℤ Q := by
      refine (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := ℤ) (S := 𝓞 F0) (p := Q) hQne_bot).2 ?_
      rw [← Ideal.over_def (A := ℤ) (P := Q) (p := Ideal.span {(r i : ℤ)})]
      exact hram_Q
    exact hnot_unram hQ_unram
  have hdiscrF0_one : (NumberField.discr F0).natAbs = 1 := by
    calc
      (NumberField.discr F0).natAbs = Ideal.absNorm (differentIdeal ℤ (𝓞 F0)) := by
        symm
        exact NumberField.absNorm_differentIdeal F0 (𝓞 F0)
      _ = 1 := by simp [hdiff_top]
  have hdeg_gt_one : 1 < Module.finrank ℚ F0 := by
    rw [hfinrank_F0]
    norm_num
  have hgt_two : (2 : ℤ) < |NumberField.discr F0| := NumberField.abs_discr_gt_two (K := F0) hdeg_gt_one
  have habs_one : |NumberField.discr F0| = (1 : ℤ) := by
    have hcast : (((NumberField.discr F0).natAbs : ℕ) : ℤ) = 1 := by
      exact_mod_cast hdiscrF0_one
    simpa [Int.natCast_natAbs] using hcast
  omega

theorem rel_discr_eq_of_nonvanishing_on_inertia (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (σ : Fin ℓ → (M ≃ₐ[ℚ] M))
    (_hσ_mem : ∀ i, ∃ P : Ideal (𝓞 M),
      P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) ∧
      Nat.card (P.inertia (M ≃ₐ[ℚ] M)) = 3 ∧
      σ i ∈ P.inertia (M ≃ₐ[ℚ] M) ∧
      σ i ≠ 1)
    (lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3)
    (_hlinv : ∀ i, lin (Multiplicative.toAdd (e (σ i))) ≠ 0)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    let ψ := linearMapToCharacter ℓ lin
    let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
    let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
    let F : IntermediateField ℚ M := IntermediateField.fixedField H
    (NumberField.discr M).natAbs =
      (NumberField.discr F).natAbs ^ Module.finrank F M := by
  classical
  let ψ := linearMapToCharacter ℓ lin
  let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
  let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
  let F : IntermediateField ℚ M := IntermediateField.fixedField H
  letI : NumberField F := NumberField.of_intermediateField F
  have hlocal : ∀ i (P : Ideal (𝓞 M)),
      P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) →
      ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M) := by
    simpa [ψ, φ, H, F] using
      (all_primes_over_ri_not_dvd_differentIdeal_of_nonvanishing ℓ r M e σ _hσ_mem lin _hlinv)
  have hnotdvd_all : ∀ P : Ideal (𝓞 M), P.IsPrime → ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M) := by
    intro P hPprime
    by_cases hPbot : P = ⊥
    · subst hPbot
      rw [Ideal.dvd_iff_le, le_bot_iff]
      exact differentIdeal_ne_bot (A := 𝓞 F) (B := 𝓞 M)
    · letI : P.IsPrime := hPprime
      letI : NeZero P := ⟨hPbot⟩
      let q : ℕ := Ideal.absNorm (Ideal.under ℤ P)
      have hqprime : q.Prime := by
        dsimp [q]
        simpa using (Nat.absNorm_under_prime P)
      by_cases hq_mem : ∃ i : Fin ℓ, r i = q
      · rcases hq_mem with ⟨i, hriq⟩
        have hPover : P ∈ (Ideal.span {(r i : ℤ)} : Ideal ℤ).primesOver (𝓞 M) := by
          refine ⟨hPprime, ?_⟩
          simpa [q, hriq] using (show P.LiesOver (Ideal.span {(q : ℤ)}) from Int.liesOver_span_absNorm P)
        exact hlocal i P hPover
      · have hq_not_dvd_prod : ¬ q ∣ ∏ i, r i := by
          intro hqdvd
          have hqprime' : Prime q := (Nat.prime_iff).1 hqprime
          rcases Prime.exists_mem_finset_dvd hqprime' (s := Finset.univ) (f := r) hqdvd with ⟨i, _, hqi⟩
          have hEq : q = r i := (Nat.prime_dvd_prime_iff_eq hqprime (_hr_prime i)).1 hqi
          exact hq_mem ⟨i, hEq.symm⟩
        have hq_not_dvd_disc : ¬ q ∣ (NumberField.discr M).natAbs := by
          rw [_hdisc]
          intro hqdvd
          exact hq_not_dvd_prod (hqprime.dvd_of_dvd_pow hqdvd)
        have hP_not_dvd_diffZ : ¬ P ∣ differentIdeal ℤ (𝓞 M) := by
          intro hPdvdZ
          have hle : differentIdeal ℤ (𝓞 M) ≤ P := (Ideal.dvd_iff_le).1 hPdvdZ
          have hPnorm_dvd :
              Ideal.absNorm P ∣ Ideal.absNorm (differentIdeal ℤ (𝓞 M)) :=
            Ideal.absNorm_dvd_absNorm_of_le hle
          have hq_dvd_Pnorm : q ∣ Ideal.absNorm P := by
            dsimp [q]
            exact Int.absNorm_under_dvd_absNorm P
          have hq_dvd_diffnorm : q ∣ Ideal.absNorm (differentIdeal ℤ (𝓞 M)) :=
            dvd_trans hq_dvd_Pnorm hPnorm_dvd
          exact hq_not_dvd_disc (by
            simpa [NumberField.absNorm_differentIdeal (K := M) (𝒪 := 𝓞 M)] using hq_dvd_diffnorm)
        have h_unram_Z : Algebra.IsUnramifiedAt ℤ P :=
          (not_dvd_differentIdeal_iff).1 hP_not_dvd_diffZ
        have h_unram_F : Algebra.IsUnramifiedAt (𝓞 F) P := by
          letI : Algebra.IsUnramifiedAt ℤ P := h_unram_Z
          exact Algebra.IsUnramifiedAt.of_restrictScalars (R := ℤ) (A := 𝓞 F) (B := 𝓞 M) P
        exact (not_dvd_differentIdeal_iff).2 h_unram_F
  have hdisc_eq :
      (NumberField.discr M).natAbs =
        (NumberField.discr F).natAbs ^ Module.finrank F M :=
    discr_eq_of_not_dvd_differentIdeal_at_all_primes F M hnotdvd_all
  simpa [ψ, φ, H, F] using hdisc_eq

theorem exists_good_linear_map_rel_discr (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (e : (M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ lin : (Fin ℓ → ZMod 3) →ₗ[ZMod 3] ZMod 3,
      lin ≠ 0 ∧
      let ψ := linearMapToCharacter ℓ lin
      let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
      let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
      let F : IntermediateField ℚ M := IntermediateField.fixedField H
      (NumberField.discr M).natAbs =
        (NumberField.discr F).natAbs ^ Module.finrank F M := by
  obtain ⟨σ, hσ_mem, hspan⟩ :=
    ramification_vectors_span_top_rel_discr ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc
  let v : Fin ℓ → (Fin ℓ → ZMod 3) := fun i => Multiplicative.toAdd (e (σ i))
  obtain ⟨lin, hlin_ne, hlin_one⟩ :=
    exists_linearMap_eq_one_of_span_top ℓ _hℓ v hspan
  have hlinv : ∀ i, lin (Multiplicative.toAdd (e (σ i))) ≠ 0 := by
    intro i
    change lin (v i) ≠ 0
    rw [hlin_one i]
    exact one_ne_zero
  refine ⟨lin, hlin_ne, ?_⟩
  exact
    rel_discr_eq_of_nonvanishing_on_inertia ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M e σ hσ_mem lin hlinv _hdisc

theorem diagonal_cubic_subfield_exists_rel_discr (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (_hMgal : Nonempty ((M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3)))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  classical
  rcases _hMgal with ⟨e⟩
  obtain ⟨lin, hlin, hdisc_rel⟩ :=
    exists_good_linear_map_rel_discr ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc
  let ψ : Multiplicative (Fin ℓ → ZMod 3) →* Multiplicative (ZMod 3) :=
    linearMapToCharacter ℓ lin
  have hψ_surj : Function.Surjective ψ := linearMapToCharacter_surjective ℓ lin hlin
  let φ : (M ≃ₐ[ℚ] M) →* Multiplicative (ZMod 3) := ψ.comp e
  have hφ_surj : Function.Surjective φ := by
    intro y
    rcases hψ_surj y with ⟨x, hx⟩
    refine ⟨e.symm x, ?_⟩
    simpa [φ] using hx
  let H : Subgroup (M ≃ₐ[ℚ] M) := φ.ker
  let F : IntermediateField ℚ M := IntermediateField.fixedField H
  letI : NumberField F := NumberField.of_intermediateField F
  letI : IsGalois ℚ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsTotallyReal F :=
    NumberField.instIsTotallyRealSubtypeMemIntermediateFieldRatOfIsAlgebraic F
  let eF : (F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3) :=
    (IsGalois.normalAutEquivQuotient H).symm.trans
      (QuotientGroup.quotientKerEquivOfSurjective φ hφ_surj)
  have hfinQF : Module.finrank ℚ F = 3 := by
    rw [← IsGalois.card_aut_eq_finrank ℚ F]
    calc
      Nat.card (F ≃ₐ[ℚ] F) = Nat.card (Multiplicative (ZMod 3)) := Nat.card_congr eF.toEquiv
      _ = Nat.card (ZMod 3) := Nat.card_congr Multiplicative.toAdd
      _ = 3 := Nat.card_zmod 3
  have hfinFM : Module.finrank F M = 3 ^ (ℓ - 1) := by
    have hmul : Module.finrank ℚ F * Module.finrank F M = Module.finrank ℚ M :=
      Module.finrank_mul_finrank ℚ F M
    cases ℓ with
    | zero =>
        cases Nat.not_lt_zero 0 _hℓ
    | succ n =>
        rw [hfinQF, _hfin, pow_succ] at hmul
        have hmul' : 3 * Module.finrank F M = 3 * 3 ^ n := by
          simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
        have hEq : Module.finrank F M = 3 ^ n := by
          omega
        simpa using hEq
  have hodd : Odd (Module.finrank F M) := by
    rw [hfinFM]
    exact Odd.pow (by decide : Odd 3)
  have hpow_all : ∀ g : Multiplicative (Fin ℓ → ZMod 3), g ^ 3 = 1 := by
    intro g
    apply Multiplicative.toAdd.injective
    rw [toAdd_pow, toAdd_one]
    ext i
    have h3 : (3 : ZMod 3) = 0 := by decide
    simp [Pi.smul_apply, nsmul_eq_mul, h3]
  have hcomm_all : ∀ g h : Multiplicative (Fin ℓ → ZMod 3), g * h = h * g := by
    intro g h
    simpa using mul_comm g h
  have hpow : ∀ τ : M ≃ₐ[F] M, τ ^ 3 = 1 := by
    intro τ
    let τ' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm τ
    have hτ' : τ' ^ 3 = 1 := by
      apply Subtype.ext
      change ((τ' : M ≃ₐ[ℚ] M) ^ 3) = 1
      apply e.injective
      simpa [τ'] using hpow_all (e τ'.1)
    simpa [τ'] using congrArg (IntermediateField.fixingSubgroupEquiv F) hτ'
  have hcomm : ∀ τ υ : M ≃ₐ[F] M, τ * υ = υ * τ := by
    intro τ υ
    let τ' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm τ
    let υ' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm υ
    have hτυ : τ' * υ' = υ' * τ' := by
      apply Subtype.ext
      change ((τ' : M ≃ₐ[ℚ] M) * υ') = ((υ' : M ≃ₐ[ℚ] M) * τ')
      apply e.injective
      simpa [τ', υ'] using hcomm_all (e τ'.1) (e υ'.1)
    simpa [τ', υ'] using congrArg (IntermediateField.fixingSubgroupEquiv F) hτυ
  refine ⟨F, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, hfinQF, ⟨eF⟩, hfinFM, hodd, ?_, hpow, hcomm⟩
  simpa [ψ, φ, H, F] using hdisc_rel

theorem diagonal_cubic_subfield_exists_with_discr (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (_hMgal : Nonempty ((M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3)))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      (NumberField.discr F).natAbs = (∏ i, r i) ^ 2 ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  rcases diagonal_cubic_subfield_exists_rel_discr ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M _hMgal _hfin _hdisc with
    ⟨F, instF, instCZ, instNF, instTR, instGalQ, instAlg, instTower, instFD, instGalF,
      hfinQF, hFgal, hfinFM, hoddFM, hrel, hpow3, habel⟩
  refine ⟨F, instF, instCZ, instNF, instTR, instGalQ, instAlg, instTower, instFD, instGalF,
    hfinQF, hFgal, hfinFM, hoddFM, ?_, hpow3, habel⟩
  have hpow : (NumberField.discr F).natAbs ^ (3 ^ (ℓ - 1)) = ((∏ i, r i) ^ 2) ^ (3 ^ (ℓ - 1)) := by
    calc
      (NumberField.discr F).natAbs ^ (3 ^ (ℓ - 1)) = (NumberField.discr M).natAbs := by
        simpa [hfinFM] using hrel.symm
      _ = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1)) := _hdisc
      _ = ((∏ i, r i) ^ 2) ^ (3 ^ (ℓ - 1)) := by
        rw [Nat.pow_mul]
  have hne : 3 ^ (ℓ - 1) ≠ 0 := by
    exact pow_ne_zero _ (by decide)
  exact (Nat.pow_left_injective hne) hpow

theorem diagonal_cubic_subfield_exists_unramified (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois ℚ M]
    (_hMgal : Nonempty ((M ≃ₐ[ℚ] M) ≃* Multiplicative (Fin ℓ → ZMod 3)))
    (_hfin : Module.finrank ℚ M = 3 ^ ℓ)
    (_hdisc : (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1))) :
    ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois ℚ F)
      (_ : Algebra F M) (_ : IsScalarTower ℚ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      Odd (Module.finrank F M) ∧
      IsEverywhereUnramified F M ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  classical
  rcases
      diagonal_cubic_subfield_exists_with_discr ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 M _hMgal _hfin _hdisc with
    ⟨F, hFfield, hFchar, hFnf, hFreal, hFgalois, hAlg, hTower, hFin, hGalFM,
      hdegF, hGalF, hdegFM, hOdd, hdiscF, hpow, hcomm⟩
  letI : Field F := hFfield
  letI : CharZero F := hFchar
  letI : NumberField F := hFnf
  letI : IsTotallyReal F := hFreal
  letI : IsGalois ℚ F := hFgalois
  letI : Algebra F M := hAlg
  letI : IsScalarTower ℚ F M := hTower
  letI : FiniteDimensional F M := hFin
  letI : IsGalois F M := hGalFM
  have hdiscFM :
      (NumberField.discr M).natAbs =
        (NumberField.discr F).natAbs ^ Module.finrank F M := by
    calc
      (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1)) := _hdisc
      _ = ((∏ i, r i) ^ 2) ^ (3 ^ (ℓ - 1)) := by
        rw [pow_mul]
      _ = (NumberField.discr F).natAbs ^ (3 ^ (ℓ - 1)) := by
        rw [hdiscF]
      _ = (NumberField.discr F).natAbs ^ Module.finrank F M := by
        rw [hdegFM]
  have hunram : IsEverywhereUnramified F M :=
    IsEverywhereUnramified_of_discr_eq_and_totally_real_local F M hOdd hdiscFM
  refine ⟨F, hFfield, hFchar, hFnf, hFreal, hFgalois, hAlg, hTower, hFin, hGalFM,
    hdegF, hGalF, hdegFM, hOdd, hunram, hpow, hcomm⟩

theorem restrictNormalHom_pair_eq_one_of_sup_eq_top (F E : Type) [Field F] [Field E] [Algebra F E]
    (K L : IntermediateField F E) [Normal F K] [Normal F L]
    (_hsup : K ⊔ L = ⊤) :
    ∀ τ : E ≃ₐ[F] E,
      AlgEquiv.restrictNormalHom K τ = 1 →
      AlgEquiv.restrictNormalHom L τ = 1 →
      τ = 1 := by
  intro τ hK hL
  have hfixK : τ ∈ K.fixingSubgroup := by
    rw [← IntermediateField.restrictNormalHom_ker (E := K), MonoidHom.mem_ker]
    exact hK
  have hfixL : τ ∈ L.fixingSubgroup := by
    rw [← IntermediateField.restrictNormalHom_ker (E := L), MonoidHom.mem_ker]
    exact hL
  have hfix : τ ∈ (K ⊔ L).fixingSubgroup := by
    rw [IntermediateField.fixingSubgroup_sup, Subgroup.mem_inf]
    exact ⟨hfixK, hfixL⟩
  rw [_hsup, IntermediateField.fixingSubgroup_top, Subgroup.mem_bot] at hfix
  exact hfix

theorem restrictNormalHom_pair_injective_of_sup_eq_top (F E : Type) [Field F] [Field E] [Algebra F E]
    (K L : IntermediateField F E) [Normal F K] [Normal F L]
    (_hsup : K ⊔ L = ⊤) :
    Function.Injective (fun τ : E ≃ₐ[F] E =>
      (AlgEquiv.restrictNormalHom K τ, AlgEquiv.restrictNormalHom L τ)) := by
  intro τ υ h
  let φK : (E ≃ₐ[F] E) →* (K ≃ₐ[F] K) := AlgEquiv.restrictNormalHom K
  let φL : (E ≃ₐ[F] E) →* (L ≃ₐ[F] L) := AlgEquiv.restrictNormalHom L
  have hK : φK τ = φK υ := by
    exact congrArg Prod.fst h
  have hL : φL τ = φL υ := by
    exact congrArg Prod.snd h
  have h1K : φK (τ * υ⁻¹) = 1 := by
    rw [show φK (τ * υ⁻¹) = φK τ * (φK υ)⁻¹ by rw [map_mul, map_inv]]
    rw [hK]
    exact mul_inv_cancel _
  have h1L : φL (τ * υ⁻¹) = 1 := by
    rw [show φL (τ * υ⁻¹) = φL τ * (φL υ)⁻¹ by rw [map_mul, map_inv]]
    rw [hL]
    exact mul_inv_cancel _
  have hunit : τ * υ⁻¹ = 1 :=
    restrictNormalHom_pair_eq_one_of_sup_eq_top F E K L _hsup (τ * υ⁻¹) h1K h1L
  have hτ : τ = υ := by
    apply (mul_right_injective υ)
    simpa [mul_assoc] using congrArg (fun σ : E ≃ₐ[F] E => σ * υ) hunit
  exact hτ


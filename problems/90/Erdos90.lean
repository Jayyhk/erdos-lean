theorem d_two_ofProd_apply (f : C(G × G, ZMod p)) (g : Fin 3 → G) :
    (d p G 2 (ofProd p G f)) g
      = f (g 1, g 2) - f (g 0 * g 1, g 2) + f (g 0, g 1 * g 2) - f (g 0, g 1) := by
  rw [d_apply, dAux.toFun, Fin.sum_univ_three]
  rw [ofProd_apply, ofProd_apply, ofProd_apply, ofProd_apply]
  have h00 : Fin.contractNth 0 (· * ·) g 0 = g 0 * g 1 := by
    rw [Fin.contractNth_apply_of_eq _ _ _ _ rfl]
    simp [Fin.castSucc_zero', Fin.succ_zero_eq_one']
  have h01 : Fin.contractNth 0 (· * ·) g 1 = g 2 := by
    rw [Fin.contractNth_apply_of_gt _ _ _ _ (by decide)]
    simp [Fin.succ_one_eq_two']
  have h10 : Fin.contractNth 1 (· * ·) g 0 = g 0 := by
    rw [Fin.contractNth_apply_of_lt _ _ _ _ (by decide)]
    simp [Fin.castSucc_zero']
  have h11 : Fin.contractNth 1 (· * ·) g 1 = g 1 * g 2 := by
    rw [Fin.contractNth_apply_of_eq _ _ _ _ rfl]
    simp [Fin.succ_one_eq_two']
  have h20 : Fin.contractNth 2 (· * ·) g 0 = g 0 := by
    rw [Fin.contractNth_apply_of_lt _ _ _ _ (by decide)]
    simp [Fin.castSucc_zero']
  have h21 : Fin.contractNth 2 (· * ·) g 1 = g 1 := by
    rw [Fin.contractNth_apply_of_lt _ _ _ _ (by decide)]
    simp
  rw [h00, h01, h10, h11, h20, h21]
  simp [sub_eq_add_neg, Fin.succ_zero_eq_one', Fin.succ_one_eq_two',
    pow_succ' (-1 : ZMod p) 2, neg_sq]
  ac_rfl

def ofIsCocycle2 (f : C(G × G, ZMod p)) (hf : IsCocycle2 p G f) :
    Cocycles p G 2 :=
  ⟨ofProd p G f, by

    rw [Cocycles, LinearMap.mem_ker]
    ext g
    change (d p G 2 (ofProd p G f)) g = (0 : ZMod p)
    rw [d_two_ofProd_apply (p := p) (G := G) (f := f) (g := g)]
    exact hf (g 0) (g 1) (g 2)⟩

def IsCocycle1 (f : C(G, ZMod p)) : Prop :=
  ∀ g h : G, f (g * h) = f g + f h

def ofSingle (f : C(G, ZMod p)) : Cochain p G 1 :=
  f.comp ⟨fun g => g 0, continuous_apply 0⟩

theorem ofSingle_apply (f : C(G, ZMod p)) (g : Fin 1 → G) :
    ofSingle p G f g = f (g 0) := rfl

theorem d_one_ofSingle_apply (f : C(G, ZMod p)) (g : Fin 2 → G) :
    (d p G 1 (ofSingle p G f)) g = f (g 1) - f (g 0 * g 1) + f (g 0) := by
  rw [d_apply, dAux.toFun, Fin.sum_univ_two]
  have hfirst : (ofSingle p G f) (fun i => g i.succ) = f (g 1) := by
    rw [ofSingle_apply]
    rfl
  have h0' : Fin.contractNth 0 (· * ·) g 0 = g 0 * g 1 := by
    rw [Fin.contractNth_apply_of_eq]
    · rfl
    · rfl
  have h0 : (ofSingle p G f) (Fin.contractNth 0 (· * ·) g) = f (g 0 * g 1) := by
    rw [ofSingle_apply, h0']
  have h1' : Fin.contractNth 1 (· * ·) g 0 = g 0 := by
    rw [Fin.contractNth_apply_of_lt]
    · rfl
    · decide
  have h1 : (ofSingle p G f) (Fin.contractNth 1 (· * ·) g) = f (g 0) := by
    rw [ofSingle_apply, h1']
  rw [hfirst, h0, h1]
  simp [sub_eq_add_neg, add_assoc]

def ofIsCocycle1 (f : C(G, ZMod p)) (hf : IsCocycle1 p G f) :
    Cocycles p G 1 :=
  ⟨ofSingle p G f, by

    rw [Cocycles, LinearMap.mem_ker]
    ext g
    change (d p G 1 (ofSingle p G f)) g = (0 : ZMod p)
    rw [d_one_ofSingle_apply (p := p) (G := G) (f := f) (g := g), hf (g 0) (g 1)]
    simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]⟩

def IsCoboundary2 (f : C(G × G, ZMod p)) : Prop :=
  ∃ b : C(G, ZMod p), ∀ g h : G, f (g, h) = b h - b (g * h) + b g

theorem ofProd_mem_coboundaries_of_isCoboundary2 (f : C(G × G, ZMod p))
    (hf : IsCoboundary2 p G f) :
    ofProd p G f ∈ Coboundaries p G 2 := by

  rcases hf with ⟨b, hb⟩
  simpa [Coboundaries] using
    (show ofProd p G f ∈ LinearMap.range (d p G 1) from by
      refine ⟨ofSingle p G b, ?_⟩
      ext g
      rw [d_one_ofSingle_apply (p := p) (G := G) (f := b) (g := g)]
      change b (g 1) - b (g 0 * g 1) + b (g 0) = f (g 0, g 1)
      simpa using (hb (g 0) (g 1)).symm)

end InhomogClassAPI

                  _ = QuotientGroup.map (R (n + 1)) (R n) (MonoidHom.id G)
                      (show R (n + 1) вүӨ R n from hRle n)
                      (QuotientGroup.map N (R (n + 1)) (MonoidHom.id G)
                        (show N вүӨ R (n + 1) from le_sup_left) (QuotientGroup.mk' N g)) := by
                        rw [вҶҗ hx]
                  _ = QuotientGroup.map N (R n) (MonoidHom.id G)
                      (show N вүӨ R n from le_sup_left) (QuotientGroup.mk' N g) := by
                        simp [QuotientGroup.map_comp_map
                            (N := N) (M := R (n + 1)) (O := R n)
                            (f := MonoidHom.id G) (g := MonoidHom.id G)
                            (hf := show N вүӨ (R (n + 1)).comap (MonoidHom.id G) from le_sup_left)

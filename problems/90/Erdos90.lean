      rw [hcount_mul'] at hmul_le
      omega
    have hm_eq_one : m = 1 := by
      omega
    have hram_in_eq : Ideal.ramificationIdxIn 𝔮 (𝓞 𝒟.K) = 1 := by
      apply Nat.eq_one_of_dvd_one
      rw [← hm_eq_one]
      dsimp [m]
      exact dvd_mul_right _ _
    have hiner_in_eq : Ideal.inertiaDegIn 𝔮 (𝓞 𝒟.K) = 1 := by
      apply Nat.eq_one_of_dvd_one
      rw [← hm_eq_one]
      dsimp [m]
      exact dvd_mul_left _ _
    have h𝔓over𝔮 : 𝔓.LiesOver 𝔮 := by
      dsimp [𝔮]
      exact Ideal.over_under (A := 𝓞 𝒟.L) (P := 𝔓)
    have hrel_e : Ideal.ramificationIdx 𝔮 𝔓 = 1 := by
      letI : 𝔓.IsPrime := h𝔓p

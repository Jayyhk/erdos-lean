theorem lseries_eq_logRescalePartialSum_laplace {f : ℕ → ℝ} :
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →
    ∀ z : ℂ, 0 < z.re →
      LSeries (fun n => (f n : ℂ)) (1 + z) =
        (1 + z) * ∫ x in Set.Ioi (0 : ℝ),
          (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x)) := by
  intro hnonneg hsumm z hz
  let r : ℝ := 1 + z.re / 2
  have hr1 : 1 < r := by
    dsimp [r]
    linarith
  obtain ⟨C, hCnonneg, hC⟩ :=
    icc_growth_family_of_LSeriesSummable_nonneg hnonneg hsumm r hr1
  have hr0 : 0 ≤ r := by
    dsimp [r]
    linarith
  have hrs : r < (1 + z).re := by
    dsimp [r]
    simp
    linarith
  have hO : (fun n ↦ ∑ k ∈ Finset.Icc 1 n, f k) =O[Filter.atTop] fun n ↦ (n : ℝ) ^ r := by
    refine Asymptotics.IsBigO.of_bound C ?_
    exact Filter.Eventually.of_forall fun N => by
      rw [Real.norm_of_nonneg (Finset.sum_nonneg fun k hk => hnonneg k),
        Real.norm_of_nonneg (Real.rpow_nonneg (show 0 ≤ (N : ℝ) by positivity) _)]
      exact hC N
  have hexp_image : Real.exp '' Set.Ioi (0 : ℝ) = Set.Ioi (1 : ℝ) := by
    ext t
    constructor
    · rintro ⟨x, hx, rfl⟩
      have hnonnegexp : 0 ≤ Real.exp x := le_of_lt (Real.exp_pos x)
      exact (Real.log_pos_iff hnonnegexp).mp (by simpa using hx)
    · intro ht
      refine ⟨Real.log t, Real.log_pos ht, ?_⟩
      exact Real.exp_log (lt_trans zero_lt_one ht)
  have hmono : MonotoneOn Real.exp (Set.Ioi (0 : ℝ)) := by
    exact (strictMono_of_deriv_pos (f := Real.exp) fun x => by
      simpa [Real.deriv_exp] using (Real.exp_pos x)).monotone.monotoneOn (Set.Ioi (0 : ℝ))
  let g : ℝ → ℂ :=
    fun t => (∑ k ∈ Finset.Icc 1 ⌊t⌋₊, (f k : ℂ)) * t ^ (-(1 + z + 1))
  have hsub :=
    MeasureTheory.integral_image_eq_integral_deriv_smul_of_monotoneOn
      (F := ℂ) (s := Set.Ioi (0 : ℝ)) (f := Real.exp) (f' := Real.exp)
      measurableSet_Ioi
      (fun x hx => (Real.hasDerivAt_exp x).hasDerivWithinAt)
      hmono
      g
  rw [hexp_image] at hsub
  have hInt :
      ∫ x in Set.Ioi (0 : ℝ), Real.exp x • g (Real.exp x) =
        ∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x)) := by
    refine MeasureTheory.setIntegral_congr_ae measurableSet_Ioi ?_
    exact Filter.Eventually.of_forall fun x hx => by
      rw [logRescalePartialSum, if_pos hx.le]
      set S : ℝ := ∑ k ∈ Finset.Icc 1 ⌊Real.exp x⌋₊, f k
      have hxexp_ne : ((Real.exp x : ℝ) : ℂ) ≠ 0 := by
        exact_mod_cast (Real.exp_ne_zero x)
      have hpow : ((Real.exp x : ℂ) ^ (-(1 + z + 1))) =
          Complex.exp ((x : ℂ) * (-(1 + z + 1))) := by
        rw [Complex.cpow_def_of_ne_zero hxexp_ne]
        rw [← Complex.ofReal_log (le_of_lt (Real.exp_pos x)), Real.log_exp]
      have hExp : ((Real.exp x : ℂ)) = Complex.exp (x : ℂ) := by
        simp [Real.exp_eq_exp_ℝ, Complex.exp_eq_exp_ℂ]
      have hExpNeg : ((Real.exp (-x) : ℂ)) = Complex.exp (-x : ℂ) := by
        simp [Real.exp_eq_exp_ℝ, Complex.exp_eq_exp_ℂ]
      have hpow' : Complex.exp (x : ℂ) ^ (-(1 + z + 1)) =
          Complex.exp ((x : ℂ) * (-(1 + z + 1))) := by
        rw [← hExp, hpow]
      have hcore : Complex.exp (x : ℂ) * Complex.exp ((x : ℂ) * (-(1 + z + 1))) =
          ((Real.exp (-x) : ℂ)) * Complex.exp (-z * x) := by
        calc
          Complex.exp (x : ℂ) * Complex.exp ((x : ℂ) * (-(1 + z + 1))) =
              Complex.exp ((x : ℂ) + (x : ℂ) * (-(1 + z + 1))) := by
                rw [← Complex.exp_add]
          _ = Complex.exp ((-x : ℂ) + (-z * x)) := by
                congr 1
                ring
          _ = Complex.exp (-x : ℂ) * Complex.exp (-z * x) := by
                rw [Complex.exp_add]
          _ = ((Real.exp (-x) : ℂ)) * Complex.exp (-z * x) := by
                rw [← hExpNeg]
      calc
        Real.exp x • g (Real.exp x)
            = Complex.exp (x : ℂ) * ((S : ℂ) * Complex.exp (x : ℂ) ^ (-(1 + z + 1))) := by
                simp [g, S, smul_eq_mul, hExp]
        _ = Complex.exp (x : ℂ) * ((S : ℂ) * Complex.exp ((x : ℂ) * (-(1 + z + 1)))) := by
                rw [hpow']
        _ = (S : ℂ) * (Complex.exp (x : ℂ) * Complex.exp ((x : ℂ) * (-(1 + z + 1)))) := by
                ac_rfl
        _ = (S : ℂ) * (((Real.exp (-x) : ℂ)) * Complex.exp (-z * x)) := by
                rw [hcore]
        _ = (((Real.exp (-x) * S : ℝ) : ℂ) * Complex.exp (-z * x)) := by
                simp [S, mul_assoc, mul_left_comm, mul_comm]
  calc
    LSeries (fun n => (f n : ℂ)) (1 + z)
        = (1 + z) * ∫ t in Set.Ioi (1 : ℝ), g t := by
          simpa [g, add_assoc] using
            (LSeries_eq_mul_integral_of_nonneg (f := f) hr0 hrs hO hnonneg)
    _ = (1 + z) * ∫ x in Set.Ioi (0 : ℝ), Real.exp x • g (Real.exp x) := by
      rw [hsub]
      rfl
    _ = (1 + z) * ∫ x in Set.Ioi (0 : ℝ),
          (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x)) := by
      rw [hInt]

theorem centered_logRescalePartialSum_laplace_eq_shift_sub_const_div {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
    (haim : a.im = 0) →
    (hnonneg : ∀ n, 0 ≤ f n) →
    (hsumm : ∀ s : ℂ, 1 < s.re → LSeriesSummable (fun n => (f n : ℂ)) s) →

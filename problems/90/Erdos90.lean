theorem rootDiscr_log_eq (K : Type) [Field K] [NumberField K] :
    Real.log (NumberField.rootDiscr K) =
      Real.log ((NumberField.discr K).natAbs : ℝ) / Module.finrank ℚ K := by
  rw [NumberField.rootDiscr_def, Nat.cast_natAbs]
  have hdiscr : 0 < (↑|NumberField.discr K| : ℝ) := by
    exact_mod_cast (abs_pos.mpr (NumberField.discr_ne_zero (K := K)))

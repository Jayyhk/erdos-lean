  exact вҹЁxвӮҖ, fun x hx => le_of_lt (hxвӮҖ x hx)вҹ©

theorem liminf_logRescalePartialSum_pos_of_LSeries_pole {f : в„• вҶ’ в„қ} {a : в„Ӯ} {g : в„Ӯ вҶ’ в„Ӯ} :

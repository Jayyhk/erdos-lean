    rw [hxr'] at hnatRes_n
    simpa using hnatRes_n.symm
  let ПҶcts : G вҶ’вӮң* Multiplicative (ZMod p) :=
    { toFun := fun g => Multiplicative.ofAdd (ПҲcts (Additive.ofMul g))
      map_one' := by simp [ПҲcts]
      map_mul' := by
        intro a b

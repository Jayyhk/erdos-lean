    simpa [mul_comm, mul_left_comm, mul_assoc] using hmul
  В· refine Filter.Eventually.of_forall ?_
    intro y hyI
    have hExp : Continuous fun w : в„Ӯ => Complex.exp (-w * (y : в„Ӯ)) := by
      exact Complex.continuous_exp.comp ((continuous_id.neg).mul continuous_const)
    have h : Continuous fun w : в„Ӯ => (((logRescalePartialSum f y - b : в„қ) : в„Ӯ)) * Complex.exp (-w * (y : в„Ӯ)) := by
      exact continuous_const.mul hExp

    have hrec : bk_cycles1_cochain p G N z x (x * y) = bk_cycles1_cochain p G N z 1 y := by
      simpa [mul_assoc] using bk_cycles1_reconstruct p G N z x (x * y)
    have hsum :
        bk_cycles1_cochain p G N z 1 x + bk_cycles1_cochain p G N z 1 y -
          bk_cycles1_cochain p G N z 1 (x * y) = 0 := by
      simpa [hrec, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hzero
    rw [sub_eq_zero] at hsum
    simpa [bk_cycles1_eval, add_comm] using hsum.symm
  refine вҹЁhhom, ?_, ?_вҹ©
  В· have h11 := hhom 1 1
    have h11' : bk_cycles1_eval p G N z 1 + bk_cycles1_eval p G N z 1 = bk_cycles1_eval p G N z 1 + 0 := by
      simpa using h11.symm
    exact add_left_cancel h11'
  В· change Continuous (fun y => bk_cycles1_cochain p G N z 1 y)
    exact (bk_cycles1_cochain p G N z 1).continuous

theorem bk_eval_zero_of_normal_generators (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : в„•} (g : Fin k вҶ’ G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure)
    (ПҮ : BKGInvariantHom p G N)
    (hПҮ_zero : вҲҖ i : Fin k,
      вҲғ (hmem : (g i : G) вҲҲ N),
        ПҮ.hom вҹЁg i, hmemвҹ© = 1) :
    вҲҖ x : вҶҘN, ПҮ.hom x = 1 := by
  set K : Subgroup вҶҘN := ПҮ.hom.ker with hK_def
  set K' : Subgroup G := K.map N.subtype with hK'_def
  have hK'_iff : вҲҖ x : G, x вҲҲ K' вҶ”
      вҲғ (hmem : x вҲҲ N), ПҮ.hom вҹЁx, hmemвҹ© = 1 := by
    intro x
    simp only [hK'_def, hK_def, Subgroup.mem_map, MonoidHom.mem_ker, Subgroup.coe_subtype]
    constructor
    В· rintro вҹЁy, hy, rflвҹ©
      exact вҹЁy.2, hyвҹ©
    В· rintro вҹЁhmem, hПҮвҹ©
      exact вҹЁвҹЁx, hmemвҹ©, hПҮ, rflвҹ©
  have hK'_normal : K'.Normal := by
    refine вҹЁfun n hn h => ?_вҹ©
    rcases (hK'_iff n).mp hn with вҹЁhn_mem, hПҮnвҹ©
    refine (hK'_iff _).mpr ?_
    refine вҹЁвҖ№N.NormalвҖә.conj_mem n hn_mem h, ?_вҹ©
    rw [ПҮ.ginv h вҹЁn, hn_memвҹ©]
    exact hПҮn
  have h_gen_le : Set.range g вҠҶ (K' : Set G) := by
    rintro _ вҹЁi, rflвҹ©
    rcases hПҮ_zero i with вҹЁhmem, hПҮвҹ©
    exact (hK'_iff (g i)).mpr вҹЁhmem, hПҮвҹ©
  have h_normalClosure_le : Subgroup.normalClosure (Set.range g) вүӨ K' :=
    Subgroup.normalClosure_le_normal h_gen_le
  have hN_closed : IsClosed (N : Set G) := by
    rw [_hN]
    exact Subgroup.isClosed_topologicalClosure _
  have hK_closed : IsClosed (K : Set вҶҘN) := by
    have : (K : Set вҶҘN) = ПҮ.hom вҒ»В№' {1} := rfl
    rw [this]
    exact (isClosed_singleton).preimage ПҮ.continuous
  have hN_closedMap : IsClosedMap ((вҶ‘) : вҶҘN вҶ’ G) :=
    hN_closed.isClosedMap_subtype_val
  have hK'_closed : IsClosed (K' : Set G) := by
    have h_eq : (K' : Set G) = ((вҶ‘) : вҶҘN вҶ’ G) '' (K : Set вҶҘN) := by
      simp [hK'_def, Subgroup.coe_map]
    rw [h_eq]
    exact hN_closedMap _ hK_closed
  have h_topClosure_le : (Subgroup.normalClosure (Set.range g)).topologicalClosure вүӨ K' :=
    Subgroup.topologicalClosure_minimal _ h_normalClosure_le hK'_closed
  have hN_le_K' : N вүӨ K' := by
    rw [_hN]
    exact h_topClosure_le
  intro x
  have hxG : (x : G) вҲҲ K' := hN_le_K' x.2
  rcases (hK'_iff (x : G)).mp hxG with вҹЁ_, hПҮвҹ©
  exact hПҮ

theorem bk_evalLinearMap_injective_of_normal_generators (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : в„•} (g : Fin k вҶ’ G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure) :
    вҲғ eval : BKGInvariantContsHomSubmodule p G N вҶ’вӮ—[ZMod p] (Fin k вҶ’ ZMod p),
      Function.Injective eval := by
  have hg_mem : вҲҖ i : Fin k, (g i : G) вҲҲ N := by
    intro i
    rw [_hN]
    have hmem_nc : (g i : G) вҲҲ Subgroup.normalClosure (Set.range g) :=
      Subgroup.subset_normalClosure (show (g i : G) вҲҲ Set.range g from вҹЁi, rflвҹ©)
    exact (Subgroup.le_topologicalClosure (Subgroup.normalClosure (Set.range g))) hmem_nc
  let eval : BKGInvariantContsHomSubmodule p G N вҶ’вӮ—[ZMod p] (Fin k вҶ’ ZMod p) :=
    { toFun := fun f i => (f : вҶҘN вҶ’ ZMod p) вҹЁg i, hg_mem iвҹ©
      map_add' := by
        intro f f'
        ext i
        rfl
      map_smul' := by
        intro c f
        ext i
        rfl }
  refine вҹЁeval, ?_вҹ©
  intro f f' hff'
  rcases f.2 with вҹЁhf_hom, hf_one, hf_c, hf_gвҹ©
  rcases f'.2 with вҹЁhf'_hom, hf'_one, hf'_c, hf'_gвҹ©
  let d : вҶҘN вҶ’ ZMod p := fun x => (f : вҶҘN вҶ’ ZMod p) x - (f' : вҶҘN вҶ’ ZMod p) x
  have hd_hom : вҲҖ x y : вҶҘN, d (x * y) = d x + d y := by
    intro x y
    dsimp [d]
    rw [hf_hom x y, hf'_hom x y]
    ring
  have hd_one : d 1 = 0 := by
    dsimp [d]
    simp [hf_one, hf'_one]
  have hd_c : Continuous d := by
    simpa [d] using hf_c.sub hf'_c
  have hd_g : вҲҖ (h : G) (x : вҶҘN),
      d вҹЁh * (x : G) * hвҒ»В№, вҖ№N.NormalвҖә.conj_mem (x : G) x.2 hвҹ© = d x := by
    intro h x
    simp [d, hf_g h x, hf'_g h x]
  let ПҮ : BKGInvariantHom p G N :=
    { hom :=
        { toFun := fun x => Multiplicative.ofAdd (d x)
          map_one' := by
            simpa using congrArg Multiplicative.ofAdd hd_one
          map_mul' := by
            intro x y
            simpa using congrArg Multiplicative.ofAdd (hd_hom x y) }
      continuous := by
        change Continuous d
        exact hd_c
      ginv := by
        intro h x
        simp [hd_g h x] }
  have hПҮ_zero : вҲҖ i : Fin k,
      вҲғ hmem : (g i : G) вҲҲ N,
        ПҮ.hom вҹЁg i, hmemвҹ© = 1 := by
    intro i
    refine вҹЁhg_mem i, ?_вҹ©
    have hi : d вҹЁg i, hg_mem iвҹ© = 0 := by
      dsimp [d]
      exact sub_eq_zero.mpr (by
        have hi := congrFun hff' i
        simpa [eval] using hi)
    dsimp [ПҮ]
    change Multiplicative.ofAdd (d вҹЁg i, hg_mem iвҹ©) = Multiplicative.ofAdd 0
    rw [hi]
  have hПҮ_all : вҲҖ x : вҶҘN, ПҮ.hom x = 1 :=
    bk_eval_zero_of_normal_generators p G g N _hN ПҮ hПҮ_zero
  apply Subtype.ext
  funext x
  have hx := hПҮ_all x
  dsimp [ПҮ, d] at hx
  change (f : вҶҘN вҶ’ ZMod p) x - (f' : вҶҘN вҶ’ ZMod p) x = 0 at hx
  exact sub_eq_zero.mp hx

theorem bk_GInvariantContsHom_finite_and_rank_le (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : в„•} (g : Fin k вҶ’ G)
    (N : Subgroup G) [N.Normal]

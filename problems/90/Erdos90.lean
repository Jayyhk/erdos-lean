  CompactFreqKernel ψ →
  CompactFreqKernel (fun u : ℝ => ψ (-u)) := by
  intro hψ
  have hfourier :
      FourierTransform.fourier (fun u : ℝ => ψ (-u)) =
        fun ξ : ℝ => FourierTransform.fourier ψ (-ξ) := by

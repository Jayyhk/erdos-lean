theorem proposition_3_6_goodPrime_exists_outside
    (hFG : Hyp_FiniteTopologicalRank)
    (F : Type) [Field F] [NumberField F] [IsTotallyReal F]
    (_hcubic : Module.finrank ℚ F = 3)
    (badPrimes : Finset ℕ) :
    ∃ q : ℕ, proposition_3_6_goodPrime F q ∧ q ∉ badPrimes := by
  classical
  obtain ⟨L, hLnum, htransport⟩ := proposition_3_6_aux_extension_exists hFG F _hcubic
  letI : NumberField (L : Type) := hLnum
  letI : FiniteDimensional ℚ (L : Type) :=
    FiniteGaloisIntermediateField.instFiniteDimensionalSubtypeMemIntermediateField
      (k := ℚ) (K := AlgebraicClosure ℚ) L
  letI : IsGalois ℚ (L : Type) :=
    FiniteGaloisIntermediateField.instIsGaloisSubtypeMemIntermediateField
      (k := ℚ) (K := AlgebraicClosure ℚ) L
  obtain ⟨q, hqprime, hqbad, hqsplit, hqcard⟩ :=
    finiteGalois_splitCompletely_primes_exists_outside (L := (L : Type)) badPrimes
  refine ⟨q, ?_, hqbad⟩
  exact htransport q ⟨hqprime, hqsplit, hqcard⟩


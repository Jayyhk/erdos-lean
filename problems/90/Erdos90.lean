theorem summable_div_rpow_of_logRescale_kernel_integrable {f : в„• вҶ’ в„қ} {Пғ' : в„қ} : (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’ 1 < Пғ' вҶ’ MeasureTheory.IntegrableOn (fun x : в„қ => logRescalePartialSum f x * Real.exp (-(Пғ' - 1) * x)) (Set.Ioi (0 : в„қ)) вҶ’ Summable (fun n : в„• => if n = 0 then 0 else f n / (n : в„қ) ^ Пғ') := by
  intro hnonneg hПғ h_int
  let a : в„• вҶ’ в„қ := fun n => if n = 0 then 0 else f n / (n : в„қ) ^ Пғ'
  have ha_nonneg : вҲҖ n, 0 вүӨ a n := by
    intro n
    by_cases h0 : n = 0
    В· simp [a, h0]
    В· simp only [a, h0, if_false]
      exact div_nonneg (hnonneg n) (le_of_lt (Real.rpow_pos_of_pos (by exact_mod_cast Nat.pos_of_ne_zero h0) _))
  let C : в„қ := Пғ' * вҲ« x in Set.Ioi (0 : в„қ), logRescalePartialSum f x * Real.exp (-(Пғ' - 1) * x)
  have hsum_le : вҲҖ N : в„•, вҲ‘ n вҲҲ Finset.Icc 1 N, f n / (n : в„қ) ^ Пғ' вүӨ C := by
    intro N
    simpa only [C] using partial_sum_div_rpow_le_logRescale_kernel_integral hnonneg hПғ h_int N
  have hsum_range_eq : вҲҖ N : в„•, вҲ‘ n вҲҲ Finset.range (N + 1), a n = вҲ‘ n вҲҲ Finset.Icc 1 N, f n / (n : в„қ) ^ Пғ' := by
    intro N
    rw [Nat.range_succ_eq_Icc_zero]
    have hinsert : insert 0 (Finset.Icc 1 N) = Finset.Icc 0 N := by
      simpa using (Finset.insert_Icc_succ_left_eq_Icc (a := 0) (b := N) (Nat.zero_le N))
    rw [вҶҗ hinsert, Finset.sum_insert]
    В· simp only [a, if_pos rfl, zero_add]
      refine Finset.sum_congr rfl ?_
      intro n hn
      have hnpos : 0 < n := by
        exact Nat.succ_le_iff.mp (Finset.mem_Icc.mp hn).1
      have hn0 : n вү  0 := Nat.ne_of_gt hnpos
      simp only [a, hn0, if_false]
    В· simp
  have hsum_range_le : вҲҖ N : в„•, вҲ‘ n вҲҲ Finset.range N, a n вүӨ C := by
    intro N
    cases N with
    | zero =>
        have h0 := hsum_le 0
        simpa using h0
    | succ N =>
        rw [hsum_range_eq N]
        exact hsum_le N
  simpa only [a] using (summable_of_sum_range_le ha_nonneg hsum_range_le)

theorem summable_nterm_of_boundary_extension {f : в„• вҶ’ в„қ} {b : в„қ} : (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’ HasBoundaryLaplaceExtension f b вҶ’ вҲҖ Пғ' : в„қ, 1 < Пғ' вҶ’ Summable (nterm (fun n => (f n : в„Ӯ)) Пғ') := by

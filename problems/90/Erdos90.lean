noncomputable def nterm (f : в„• вҶ’ в„Ӯ) (Пғ' : в„қ) (n : в„•) : в„қ :=
  if n = 0 then 0 else вҖ–f nвҖ– / n ^ Пғ'

def cumsum {E : Type*} [AddCommMonoid E] (u : в„• вҶ’ E) (n : в„•) : E :=
  вҲ‘ i вҲҲ Finset.range n, u i

theorem cumsum_succ {E : Type*} [AddCommMonoid E] (u : в„• вҶ’ E) (n : в„•) :
    cumsum u (n + 1) = cumsum u n + u n := by
  simp [cumsum, Finset.sum_range_succ]

theorem norm_term_eq_nterm_re (f : в„• вҶ’ в„Ӯ) (s : в„Ӯ) (n : в„•) :
    вҖ–LSeries.term f s nвҖ– = nterm f s.re n := by
  simp only [nterm, LSeries.term, apply_ite (вҖ–В·вҖ–), norm_zero, norm_div]
  apply ite_congr rfl (fun _ вҶҰ rfl)
  intro h
  congr
  exact Complex.norm_natCast_cpow_of_pos (Nat.pos_of_ne_zero h) s


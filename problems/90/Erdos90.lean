            refine MeasureTheory.integral_congr_ae ?_
            exact Filter.Eventually.of_forall (fun a => by
              by_cases ha : a ∈ S <;> simp [ha])
      _ = MeasureTheory.volume.real S := by
            simpa using (MeasureTheory.integral_indicator_one (μ := MeasureTheory.volume) (s := S) hS)
  calc
    ∫ a in F, (((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ℝ) ∂MeasureTheory.volume
        = (∫⁻ a in F, (((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ENNReal) ∂MeasureTheory.volume).toReal := by
            simpa using
              (MeasureTheory.integral_toReal (μ := MeasureTheory.volume.restrict F) hmeas_count hfinite_count)
    _ = (∫⁻ a, S.indicator (fun _ => (1 : ENNReal)) a ∂MeasureTheory.volume).toReal := by
          rw [hlin_count, hlin0.symm]
    _ = MeasureTheory.volume.real S := hreal
    _ = MeasureTheory.volume.real { a : 𝒟.V | a ∈ 𝒟.closedPolydisc R ∧ a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R } := by
          rfl

theorem lemma_2_4_volume_closedPolydisc (𝒟 : AdmissibleDatum) (R : ℝ) (hR : 0 ≤ R) : MeasureTheory.volume.real (𝒟.closedPolydisc R) = (𝒟.b R) ^ 𝒟.f := by
  have hEq : 𝒟.closedPolydisc R = Metric.closedBall (0 : 𝒟.V) R := by
    ext z
    simp [AdmissibleDatum.closedPolydisc, Metric.mem_closedBall, dist_eq_norm, supNorm_eq_norm]
  rw [hEq, MeasureTheory.measureReal_def]
  rw [MeasureTheory.volume_pi_closedBall (x := (0 : 𝒟.V)) hR]
  simp [Complex.volume_closedBall, AdmissibleDatum.b, hR, Fin.prod_const, mul_comm, mul_left_comm, mul_assoc]

open scoped BigOperators in
theorem lemma_2_4_integral_N_count (𝒟 : AdmissibleDatum) (R : ℝ) (hR : 0 ≤ R) : ∫ a in lemma_2_4_FD 𝒟, (𝒟.N_count a R : ℝ) ∂MeasureTheory.volume = MeasureTheory.volume.real (𝒟.closedPolydisc R) := by
  let F := lemma_2_4_FD 𝒟
  let B := 𝒟.closedPolydisc R
  let hmcv : MeasurableConstVAdd (↥𝒟.Λ) 𝒟.V :=
    ⟨fun l => by
      change Measurable ((l : 𝒟.V) + · : 𝒟.V → 𝒟.V)
      simpa [vadd_eq_add] using (measurable_const_add (l : 𝒟.V))⟩
  let hvim : MeasureTheory.VAddInvariantMeasure (↥𝒟.Λ) 𝒟.V MeasureTheory.volume :=
    ⟨fun c s hs => by
      change MeasureTheory.volume (((fun x : 𝒟.V => (c : 𝒟.V) + x) ⁻¹' s)) = MeasureTheory.volume s
      simp [vadd_eq_add]⟩
  have hF := lemma_2_4_isAddFundamentalDomain 𝒟
  have hB_eq : B = Metric.closedBall (0 : 𝒟.V) R := by
    ext z
    simp [B, AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm, hR]
  have hB_meas : MeasurableSet B := by
    rw [hB_eq]
    exact measurableSet_closedBall
  have hcount (a : 𝒟.V) :
      (∑' l : 𝒟.Λ, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ a)) = (𝒟.N_count a R : ENNReal) := by
    let s : Set 𝒟.Λ := {l | (l : 𝒟.V) + a ∈ B}
    have hs : s = {l : 𝒟.Λ | a + (l : 𝒟.V) ∈ B} := by
      ext l
      change (((l : 𝒟.V) + a ∈ B) ↔ a + (l : 𝒟.V) ∈ B)
      rw [add_comm]
    calc
      ∑' l : 𝒟.Λ, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ a)
          = ∑' l : 𝒟.Λ, s.indicator (fun _ : 𝒟.Λ => (1 : ENNReal)) l := by
              refine tsum_congr ?_
              intro l
              by_cases hl : (l : 𝒟.V) + a ∈ B
              · have hl' : l +ᵥ a ∈ B := by
                  simpa [vadd_eq_add] using hl
                simp [s, hl, hl']
              · have hl' : l +ᵥ a ∉ B := by
                  simpa [vadd_eq_add] using hl
                simp [s, hl, hl']
      _ = ∑' l : s, (1 : ENNReal) := by
            symm
            exact tsum_subtype (s := s) (f := fun _ : 𝒟.Λ => (1 : ENNReal))
      _ = (s.encard : ENNReal) := by
            simp
      _ = (((𝒟.N_count a R : ℕ∞)) : ENNReal) := by
            rw [hs, lemma_2_4_N_count_eq_lattice_encard]
      _ = (𝒟.N_count a R : ENNReal) := by
            rfl
  have hlin :
      ∫⁻ x, Set.indicator B (fun _ => (1 : ENNReal)) x ∂MeasureTheory.volume =
        ∑' l : 𝒟.Λ, ∫⁻ x in F, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x) ∂MeasureTheory.volume := by
    simpa [F, B] using
      (@MeasureTheory.IsAddFundamentalDomain.lintegral_eq_tsum''
        (↥𝒟.Λ) 𝒟.V _ _ _ F MeasureTheory.volume hmcv hvim inferInstance hF
        (Set.indicator B (fun _ => (1 : ENNReal))))
  have hmeas_indicator : Measurable (Set.indicator B (fun _ : 𝒟.V => (1 : ENNReal))) := by
    exact Measurable.indicator measurable_const hB_meas
  have hmeas_l (l : 𝒟.Λ) : AEMeasurable (fun x : 𝒟.V => Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x)) (MeasureTheory.volume.restrict F) := by
    exact (hmeas_indicator.comp (measurable_const_vadd l)).aemeasurable
  have hlin_count : ∫⁻ x in F, (𝒟.N_count x R : ENNReal) ∂MeasureTheory.volume = MeasureTheory.volume B := by
    calc
      ∫⁻ x in F, (𝒟.N_count x R : ENNReal) ∂MeasureTheory.volume
          = ∫⁻ x in F, ∑' l : 𝒟.Λ, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x) ∂MeasureTheory.volume := by
              refine MeasureTheory.lintegral_congr_ae ?_
              exact Filter.Eventually.of_forall (fun x => (hcount x).symm)
      _ = ∑' l : 𝒟.Λ, ∫⁻ x in F, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x) ∂MeasureTheory.volume := by
            simpa using (MeasureTheory.lintegral_tsum (μ := MeasureTheory.volume.restrict F)
              (f := fun l : 𝒟.Λ => fun x : 𝒟.V => Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x)) hmeas_l)
      _ = ∫⁻ x, Set.indicator B (fun _ => (1 : ENNReal)) x ∂MeasureTheory.volume := hlin.symm
      _ = MeasureTheory.volume B := by
            simp [hB_meas]
  have hmeas_tsum : AEMeasurable
      (fun x : 𝒟.V => ∑' l : 𝒟.Λ, Set.indicator B (fun _ => (1 : ENNReal)) (l +ᵥ x))
      (MeasureTheory.volume.restrict F) := by
    exact AEMeasurable.ennreal_tsum (fun l => hmeas_l l)
  have hmeas_count : AEMeasurable (fun x : 𝒟.V => (𝒟.N_count x R : ENNReal)) (MeasureTheory.volume.restrict F) := by
    exact hmeas_tsum.congr (Filter.Eventually.of_forall hcount)
  have hfinite_count : ∀ᵐ x ∂MeasureTheory.volume.restrict F, (𝒟.N_count x R : ENNReal) < ⊤ := by
    exact Filter.Eventually.of_forall (fun x => by simp)
  have hreal :
      ∫ x in F, (𝒟.N_count x R : ℝ) ∂MeasureTheory.volume =
        (∫⁻ x in F, (𝒟.N_count x R : ENNReal) ∂MeasureTheory.volume).toReal := by
    simpa using (MeasureTheory.integral_toReal (μ := MeasureTheory.volume.restrict F)
      (f := fun x : 𝒟.V => (𝒟.N_count x R : ENNReal)) hmeas_count hfinite_count)
  rw [hreal, hlin_count]
  rfl

theorem lemma_2_4_average_N_count (𝒟 : AdmissibleDatum) (R : ℝ) (hR : 0 ≤ R) : ⨍ a in lemma_2_4_FD 𝒟, (𝒟.N_count a R : ℝ) ∂MeasureTheory.volume = (𝒟.b R) ^ 𝒟.f / ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) := by
  rw [MeasureTheory.setAverage_eq]
  rw [lemma_2_4_integral_N_count 𝒟 R hR]
  rw [lemma_2_4_volume_closedPolydisc 𝒟 R hR]
  have hcov :
      ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) =
        MeasureTheory.volume.real (lemma_2_4_FD 𝒟) := by
    simpa using
      (ZLattice.covolume_eq_measure_fundamentalDomain
        (L := 𝒟.Λ) (F := lemma_2_4_FD 𝒟) (μ := MeasureTheory.volume)
        (h := lemma_2_4_isAddFundamentalDomain 𝒟))
  rw [← hcov]
  simp only [smul_eq_mul, div_eq_mul_inv]
  ring

theorem lemma_2_4_volume_overlap_set (𝒟 : AdmissibleDatum) (R : ℝ) (hR : 0 ≤ R) (u : 𝒟.K) (hu : ∀ σ : 𝒟.K →+* ℂ, ‖σ u‖ = 1) : MeasureTheory.volume.real { a : 𝒟.V | a ∈ 𝒟.closedPolydisc R ∧ a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R } = overlapArea R ^ 𝒟.f := by
  classical
  let s : Fin 𝒟.f → Set ℂ :=
    fun i => Metric.closedBall (0 : ℂ) R ∩ Metric.closedBall (-(adm_σ 𝒟 i u)) R
  have hset :
      { a : 𝒟.V | a ∈ 𝒟.closedPolydisc R ∧ a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R }
        = Set.univ.pi s := by
    ext a
    constructor
    · intro ha
      rw [Set.mem_univ_pi]
      intro i
      rcases ha with ⟨ha1, ha2⟩
      have ha1' : a ∈ Metric.closedBall (0 : 𝒟.V) R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha1
      have ha2' : a + 𝒟.Φ u ∈ Metric.closedBall (0 : 𝒟.V) R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha2
      have ha1pi : a ∈ Set.univ.pi (fun j : Fin 𝒟.f => Metric.closedBall (0 : ℂ) R) := by
        simpa [closedBall_pi (x := (0 : 𝒟.V)) hR] using ha1'
      have ha2pi : a + 𝒟.Φ u ∈ Set.univ.pi (fun j : Fin 𝒟.f => Metric.closedBall (0 : ℂ) R) := by
        simpa [closedBall_pi (x := (0 : 𝒟.V)) hR] using ha2'
      refine ⟨(Set.mem_univ_pi.mp ha1pi i), ?_⟩
      have hi : a i + 𝒟.Φ u i ∈ Metric.closedBall (0 : ℂ) R :=
        Set.mem_univ_pi.mp ha2pi i
      simpa [s, AdmissibleDatum.Φ, Metric.mem_closedBall, dist_eq_norm, sub_eq_add_neg,
        add_assoc, add_left_comm, add_comm] using hi
    · intro ha
      rw [Set.mem_univ_pi] at ha
      have ha1pi : a ∈ Set.univ.pi (fun i : Fin 𝒟.f => Metric.closedBall (0 : ℂ) R) := by
        rw [Set.mem_univ_pi]
        intro i
        exact (ha i).1
      have ha1' : a ∈ Metric.closedBall (0 : 𝒟.V) R := by
        simpa [closedBall_pi (x := (0 : 𝒟.V)) hR] using ha1pi
      have ha1poly : a ∈ 𝒟.closedPolydisc R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha1'
      have ha2pi : a + 𝒟.Φ u ∈ Set.univ.pi (fun i : Fin 𝒟.f => Metric.closedBall (0 : ℂ) R) := by
        rw [Set.mem_univ_pi]
        intro i
        have hi : a i ∈ Metric.closedBall (-(adm_σ 𝒟 i u)) R := (ha i).2
        simpa [AdmissibleDatum.Φ, Metric.mem_closedBall, dist_eq_norm, sub_eq_add_neg,
          add_assoc, add_left_comm, add_comm] using hi
      have ha2' : a + 𝒟.Φ u ∈ Metric.closedBall (0 : 𝒟.V) R := by
        simpa [closedBall_pi (x := (0 : 𝒟.V)) hR] using ha2pi
      have ha2poly : a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha2'
      exact ⟨ha1poly, ha2poly⟩
  rw [hset, MeasureTheory.measureReal_def, MeasureTheory.volume_pi_pi]
  rw [ENNReal.toReal_prod]
  have hfac : ∀ i : Fin 𝒟.f, (MeasureTheory.volume (s i)).toReal = overlapArea R := by
    intro i
    have hσ : ‖adm_σ 𝒟 i u‖ = 1 := hu (adm_σ 𝒟 i)
    simpa [s] using lemma_2_4_closedBall_overlap_volume R (adm_σ 𝒟 i u) hσ
  simp_rw [hfac]
  simp

open scoped Pointwise in
theorem lemma_2_4_average_E_count (𝒟 : AdmissibleDatum) (R : ℝ) (hR : 0 ≤ R) (U : Finset 𝒟.K) (hU_norm : ∀ u ∈ U, 𝒟.IsNormOneIntegral u) : ⨍ a in lemma_2_4_FD 𝒟, (𝒟.E_count a R U : ℝ) ∂MeasureTheory.volume = ((U.card : ℝ) * overlapArea R ^ 𝒟.f) / ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) := by
  classical
  rw [MeasureTheory.setAverage_eq]
  simp_rw [AdmissibleDatum.E_count, Nat.cast_sum]
  have hsum :
      ∫ a in lemma_2_4_FD 𝒟,
          ∑ u ∈ U,
            (((𝒟.X_finset a R).filter
              (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ℝ)
            ∂MeasureTheory.volume
        =
      ∑ u ∈ U,
        ∫ a in lemma_2_4_FD 𝒟,
          (((𝒟.X_finset a R).filter
            (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ℝ)
            ∂MeasureTheory.volume := by
    simpa using
      (MeasureTheory.integral_finset_sum
        (μ := MeasureTheory.volume.restrict (lemma_2_4_FD 𝒟)) U
        (fun u hu =>
          lemma_2_4_integrable_shift_count 𝒟 R u
            (by exact ⟨u, (hU_norm u hu).2.2, rfl⟩)))
  rw [hsum]
  have hsum2 :
      ∑ u ∈ U,
        ∫ a in lemma_2_4_FD 𝒟,
          (((𝒟.X_finset a R).filter
            (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ℝ)
            ∂MeasureTheory.volume
      = ∑ u ∈ U, overlapArea R ^ 𝒟.f := by
    refine Finset.sum_congr rfl ?_
    intro u hu
    have hΛu : 𝒟.Φ u ∈ (𝒟.Λ : Set 𝒟.V) := by
      exact ⟨u, (hU_norm u hu).2.2, rfl⟩
    rw [lemma_2_4_integral_shift_count 𝒟 R hR u hΛu]
    rw [lemma_2_4_volume_overlap_set 𝒟 R hR u ((hU_norm u hu).2.1)]
  rw [hsum2]
  rw [← ZLattice.covolume_eq_measure_fundamentalDomain
    (L := 𝒟.Λ) (μ := MeasureTheory.volume) (h := lemma_2_4_isAddFundamentalDomain 𝒟)]
  simp [Finset.sum_const_nat, smul_eq_mul, div_eq_mul_inv]
  ring

theorem lemma_2_4_gap_average_pos (𝒟 : AdmissibleDatum) (H : ℝ) (hH : 0 < H) (R : ℝ) (hR : 1 / 2 < R) (U : Finset 𝒟.K) (hU_norm : ∀ u ∈ U, 𝒟.IsNormOneIntegral u) (hU_size : (U.card : ℝ) ≥ Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f)) (_hρ_pos : 0 < 𝒟.ρ R) (_hρ : -((𝒟.t * Real.log 2 - Real.log H) / 2) < Real.log (𝒟.ρ R)) : 0 < ⨍ a in lemma_2_4_FD 𝒟, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume := by
  set γ : ℝ := (𝒟.t : ℝ) * Real.log 2 - Real.log H
  let s : Set 𝒟.V := lemma_2_4_FD 𝒟
  let ν : MeasureTheory.Measure 𝒟.V := (MeasureTheory.volume s)⁻¹ • MeasureTheory.volume.restrict s
  have hcov_pos : 0 < ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) := by
    simpa using ZLattice.covolume_pos (L := 𝒟.Λ) (μ := MeasureTheory.volume)
  have hR_pos : 0 < R := by linarith
  have hb_pos : 0 < 𝒟.b R := by
    unfold AdmissibleDatum.b
    positivity
  have hoverlap_eq : overlapArea R = 𝒟.ρ R * 𝒟.b R := by
    calc
      overlapArea R = (overlapArea R / 𝒟.b R) * 𝒟.b R := by
        field_simp [hb_pos.ne']
      _ = 𝒟.ρ R * 𝒟.b R := by rw [AdmissibleDatum.ρ]
  have hoverlap_pos : 0 < overlapArea R := by
    rw [hoverlap_eq]
    exact mul_pos _hρ_pos hb_pos
  have hU_card_pos : 0 < (U.card : ℝ) := by
    exact lt_of_lt_of_le (Real.exp_pos (γ * 𝒟.f)) hU_size
  have havgE := lemma_2_4_average_E_count 𝒟 R hR_pos.le U hU_norm
  have havgN := lemma_2_4_average_N_count 𝒟 R hR_pos.le
  rw [MeasureTheory.setAverage_eq'] at havgE havgN
  have hE_rhs_pos :
      0 < ((U.card : ℝ) * overlapArea R ^ 𝒟.f) /
        ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) := by
    exact div_pos (mul_pos hU_card_pos (pow_pos hoverlap_pos _)) hcov_pos
  have hN_rhs_pos :
      0 < (𝒟.b R) ^ 𝒟.f /
        ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) := by
    exact div_pos (pow_pos hb_pos _) hcov_pos
  have hE_int_ne_zero :
      ∫ a, (𝒟.E_count a R U : ℝ) ∂ν ≠ 0 := by
    rw [havgE]
    exact hE_rhs_pos.ne'
  have hN_int_ne_zero :
      ∫ a, (𝒟.N_count a R : ℝ) ∂ν ≠ 0 := by
    rw [havgN]
    exact hN_rhs_pos.ne'
  have hE_int : MeasureTheory.Integrable (fun a => (𝒟.E_count a R U : ℝ)) ν := by
    by_contra hnot
    rw [MeasureTheory.integral_undef hnot] at hE_int_ne_zero
    exact hE_int_ne_zero rfl
  have hN_int : MeasureTheory.Integrable (fun a => (𝒟.N_count a R : ℝ)) ν := by
    by_contra hnot
    rw [MeasureTheory.integral_undef hnot] at hN_int_ne_zero
    exact hN_int_ne_zero rfl
  have hf_pos : (0 : ℝ) < 𝒟.f := by
    exact_mod_cast 𝒟.f_pos
  have hrho_pow_pos : 0 < (𝒟.ρ R) ^ 𝒟.f := by
    exact pow_pos _hρ_pos _
  have hlogstep : γ / 2 < γ + Real.log (𝒟.ρ R) := by
    linarith [_hρ]
  have hmulstep : (γ / 2) * (𝒟.f : ℝ) < (γ + Real.log (𝒟.ρ R)) * (𝒟.f : ℝ) := by
    exact mul_lt_mul_of_pos_right hlogstep hf_pos
  have hlt_exp : Real.exp (γ * 𝒟.f / 2) < Real.exp (γ * 𝒟.f) * (𝒟.ρ R) ^ 𝒟.f := by
    have htemp : Real.exp ((γ / 2) * (𝒟.f : ℝ)) < Real.exp ((γ + Real.log (𝒟.ρ R)) * (𝒟.f : ℝ)) := by
      exact Real.exp_lt_exp.mpr hmulstep
    have hright :
        Real.exp ((γ + Real.log (𝒟.ρ R)) * (𝒟.f : ℝ)) =
          Real.exp (γ * (𝒟.f : ℝ)) * (𝒟.ρ R) ^ 𝒟.f := by
      calc
        Real.exp ((γ + Real.log (𝒟.ρ R)) * (𝒟.f : ℝ))
            = Real.exp (γ * (𝒟.f : ℝ) + Real.log (𝒟.ρ R) * (𝒟.f : ℝ)) := by
                congr 1
                ring
        _ = Real.exp (γ * (𝒟.f : ℝ)) * Real.exp (Real.log (𝒟.ρ R) * (𝒟.f : ℝ)) := by
              rw [Real.exp_add]
        _ = Real.exp (γ * (𝒟.f : ℝ)) * (𝒟.ρ R) ^ 𝒟.f := by
              congr 1
              calc
                Real.exp (Real.log (𝒟.ρ R) * (𝒟.f : ℝ))
                    = Real.exp (Real.log (𝒟.ρ R)) ^ (𝒟.f : ℝ) := by
                        rw [Real.exp_mul]
                _ = (𝒟.ρ R) ^ (𝒟.f : ℝ) := by rw [Real.exp_log _hρ_pos]
                _ = (𝒟.ρ R) ^ 𝒟.f := by rw [Real.rpow_natCast]
    have hleft : Real.exp ((γ / 2) * (𝒟.f : ℝ)) = Real.exp (γ * 𝒟.f / 2) := by
      congr 1
      ring
    rw [hleft, hright] at htemp
    exact htemp
  have hmul_u : Real.exp (γ * 𝒟.f) * (𝒟.ρ R) ^ 𝒟.f ≤ (U.card : ℝ) * (𝒟.ρ R) ^ 𝒟.f := by
    exact mul_le_mul_of_nonneg_right hU_size hrho_pow_pos.le
  have hC_lt : Real.exp (γ * 𝒟.f / 2) < (U.card : ℝ) * (𝒟.ρ R) ^ 𝒟.f := by
    exact lt_of_lt_of_le hlt_exp hmul_u
  rw [MeasureTheory.setAverage_eq']
  change 0 < ∫ a, lemma_2_4_gap 𝒟 H R U a ∂ν
  dsimp [lemma_2_4_gap]
  rw [MeasureTheory.integral_sub hE_int (hN_int.const_mul _)]
  rw [MeasureTheory.integral_const_mul]
  rw [havgE, havgN]
  have hfinal_eq :
      ((U.card : ℝ) * overlapArea R ^ 𝒟.f) /
            ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume) -
          Real.exp (γ * 𝒟.f / 2) *
            ((𝒟.b R) ^ 𝒟.f /
              ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume)) =
        (((U.card : ℝ) * (𝒟.ρ R) ^ 𝒟.f) - Real.exp (γ * 𝒟.f / 2)) *
          ((𝒟.b R) ^ 𝒟.f /
            ZLattice.covolume (L := 𝒟.Λ) (μ := MeasureTheory.volume)) := by
    rw [hoverlap_eq, mul_pow]
    ring
  rw [hfinal_eq]
  exact mul_pos (sub_pos.mpr hC_lt) hN_rhs_pos

theorem lemma_2_4 (𝒟 : AdmissibleDatum) (H : ℝ) (hH : 0 < H)
    (R : ℝ) (hR : 1 / 2 < R)
    (U : Finset 𝒟.K)
    (hU_norm : ∀ u ∈ U, 𝒟.IsNormOneIntegral u)
    (hU_size : (U.card : ℝ) ≥
      Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f))

    (_hρ_pos : 0 < 𝒟.ρ R)
    (_hρ : -((𝒟.t * Real.log 2 - Real.log H) / 2) < Real.log (𝒟.ρ R)) :
    ∃ a : 𝒟.V,
      0 < 𝒟.N_count a R ∧
      (𝒟.E_count a R U : ℝ) ≥
        Real.exp ((𝒟.t * Real.log 2 - Real.log H) * 𝒟.f / 2) *
          𝒟.N_count a R := by
  have havg :
      0 < ⨍ a in lemma_2_4_FD 𝒟, lemma_2_4_gap 𝒟 H R U a ∂MeasureTheory.volume :=
    lemma_2_4_gap_average_pos 𝒟 H hH R hR U hU_norm hU_size _hρ_pos _hρ
  rcases lemma_2_4_exists_gap_positive 𝒟 H R U havg with ⟨a, _haFD, hgap⟩
  have hNpos : 0 < 𝒟.N_count a R := by
    by_contra hNnonpos
    have hNzero : 𝒟.N_count a R = 0 := by
      linarith
    have hEzero : 𝒟.E_count a R U = 0 :=
      lemma_2_4_E_count_eq_zero_of_N_count_eq_zero 𝒟 a R U hNzero
    unfold lemma_2_4_gap at hgap
    rw [hNzero, hEzero] at hgap
    norm_num at hgap
  refine ⟨a, hNpos, ?_⟩
  have hgap' := hgap
  unfold lemma_2_4_gap at hgap'
  linarith

noncomputable def complexPoint (z : ℂ) : Point :=
  (EuclideanSpace.equiv (Fin 2) ℝ).symm ![z.re, z.im]

theorem complexPoint_dist (z w : ℂ) : dist (complexPoint z) (complexPoint w) = ‖z - w‖ := by
  have hsq : dist (complexPoint z) (complexPoint w) ^ 2 = ‖z - w‖ ^ 2 := by
    calc
      dist (complexPoint z) (complexPoint w) ^ 2
          = ∑ i : Fin 2, dist ((complexPoint z) i) ((complexPoint w) i) ^ 2 := by
            rw [EuclideanSpace.dist_sq_eq]
      _ = (z.re - w.re) ^ 2 + (z.im - w.im) ^ 2 := by
        simp [complexPoint, Real.dist_eq, sq_abs]
      _ = ‖z - w‖ ^ 2 := by
        rw [RCLike.norm_sq_eq_def]
        simp
        ring
  have hnonneg1 : 0 ≤ dist (complexPoint z) (complexPoint w) := dist_nonneg
  have hnonneg2 : 0 ≤ ‖z - w‖ := norm_nonneg _
  nlinarith

theorem complexPoint_injective: Function.Injective complexPoint := by
  intro z w h
  have h' := congrArg (EuclideanSpace.equiv (Fin 2) ℝ) h
  apply Complex.ext
  · simpa [complexPoint] using congrFun h' 0
  · simpa [complexPoint] using congrFun h' 1

theorem lemma_2_5_pi1_injOn (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) : Set.InjOn 𝒟.π1 (𝒟.X a R) := by
  intro x hx y hy hxy
  rcases hx with ⟨hx, _⟩
  rcases hy with ⟨hy, _⟩
  rcases hx with ⟨lx, rfl⟩
  rcases hy with ⟨ly, rfl⟩
  have hlx : ((lx : 𝒟.V) ∈ 𝒟.Λ) := lx.2
  change ∃ u : 𝒟.K,
      (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = (algebraMap (𝓞 𝒟.K) 𝒟.K) x) ∧
        𝒟.Φ u = (lx : 𝒟.V) at hlx
  have hly : ((ly : 𝒟.V) ∈ 𝒟.Λ) := ly.2
  change ∃ u : 𝒟.K,
      (∃ x : 𝓞 𝒟.K, ((𝒟.Q : 𝒟.K) ^ 2) * u = (algebraMap (𝓞 𝒟.K) 𝒟.K) x) ∧
        𝒟.Φ u = (ly : 𝒟.V) at hly
  rcases hlx with ⟨u₁, _, hu₁⟩
  rcases hly with ⟨u₂, _, hu₂⟩
  have hxy' :
      a ⟨0, 𝒟.f_pos⟩ + (lx : 𝒟.V) ⟨0, 𝒟.f_pos⟩ =
        a ⟨0, 𝒟.f_pos⟩ + (ly : 𝒟.V) ⟨0, 𝒟.f_pos⟩ := by
    simpa [AdmissibleDatum.π1] using hxy
  have hxy0 : (lx : 𝒟.V) ⟨0, 𝒟.f_pos⟩ = (ly : 𝒟.V) ⟨0, 𝒟.f_pos⟩ :=
    add_left_cancel hxy'
  have hu : u₁ = u₂ := by
    apply (adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩).injective
    rw [← hu₁, ← hu₂] at hxy0
    simpa [AdmissibleDatum.Φ] using hxy0
  have hl : (lx : 𝒟.V) = (ly : 𝒟.V) := by
    rw [← hu₁, ← hu₂, hu]
  simp [hl]

noncomputable def orderedUnitPairs (P : Finset Point) : Finset (Point × Point) :=
  (P.offDiag).filter (fun xy => dist xy.1 xy.2 = 1)

theorem lemma_2_5_E_count_le_orderedUnitPairs (𝒟 : AdmissibleDatum) (U : Finset 𝒟.K)
    (hU_norm : ∀ u ∈ U, 𝒟.IsNormOneIntegral u)
    (a : 𝒟.V) (R : ℝ)
    (hinj : Set.InjOn 𝒟.π1 (𝒟.X a R)) :
    𝒟.E_count a R U ≤ (orderedUnitPairs (𝒟.P_set a R)).card := by
  classical
  unfold AdmissibleDatum.E_count
  rw [show ∑ u ∈ U, ((𝒟.X_finset a R).filter
        (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card
      = (U.sigma (fun u => (𝒟.X_finset a R).filter
          (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R))).card from
      (Finset.card_sigma _ _).symm]
  set src := U.sigma (fun u => (𝒟.X_finset a R).filter
    (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R))
  let g : (Σ _ : 𝒟.K, 𝒟.V) → Point × Point := fun p =>
    (complexPoint (𝒟.π1 (p.2 + 𝒟.Φ p.1)), complexPoint (𝒟.π1 p.2))
  have hmap : ∀ p ∈ src, g p ∈ orderedUnitPairs (𝒟.P_set a R) := by
    intro ⟨u, x⟩ hp
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp
    rcases hp with ⟨hu, hx, hx'⟩
    have hxP : complexPoint (𝒟.π1 x) ∈ 𝒟.P_set a R := by
      unfold AdmissibleDatum.P_set
      exact Finset.mem_image.mpr ⟨x, hx, by simp [complexPoint]⟩
    have hyP : complexPoint (𝒟.π1 (x + 𝒟.Φ u)) ∈ 𝒟.P_set a R := by
      unfold AdmissibleDatum.P_set
      exact Finset.mem_image.mpr ⟨x + 𝒟.Φ u, hx', by simp [complexPoint]⟩
    have hdist : dist (complexPoint (𝒟.π1 (x + 𝒟.Φ u))) (complexPoint (𝒟.π1 x)) = 1 := by
      rw [complexPoint_dist]
      have hnorm : ‖adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩ u‖ = 1 :=
        (hU_norm u hu).2.1 (adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩)
      simpa [AdmissibleDatum.π1, AdmissibleDatum.Φ] using hnorm
    refine Finset.mem_filter.mpr ?_
    refine ⟨?_, hdist⟩
    rw [Finset.mem_offDiag]
    refine ⟨hyP, hxP, ?_⟩
    intro hEq
    have hEq' : complexPoint (𝒟.π1 (x + 𝒟.Φ u)) = complexPoint (𝒟.π1 x) := by
      simpa [g] using hEq
    have hzero : dist (complexPoint (𝒟.π1 (x + 𝒟.Φ u))) (complexPoint (𝒟.π1 x)) = 0 := by
      rw [hEq']
      exact dist_self _
    rw [hzero] at hdist
    norm_num at hdist
  have hinjg : Set.InjOn g src := by
    intro ⟨u, x⟩ hp ⟨v, y⟩ hq heq
    change Sigma.mk u x ∈ src at hp
    change Sigma.mk v y ∈ src at hq
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp hq
    rcases hp with ⟨hu, hx, hx'⟩
    rcases hq with ⟨hv, hy, hy'⟩
    simp only [g, Prod.mk.injEq] at heq
    rcases heq with ⟨h1, h2⟩
    have hπ1 : 𝒟.π1 x = 𝒟.π1 y := complexPoint_injective h2
    have hxy : x = y := hinj
      (by simpa [AdmissibleDatum.X_finset] using hx)
      (by simpa [AdmissibleDatum.X_finset] using hy)
      hπ1
    have hπ2 : 𝒟.π1 (x + 𝒟.Φ u) = 𝒟.π1 (y + 𝒟.Φ v) := complexPoint_injective h1
    have hxy' : x + 𝒟.Φ u = y + 𝒟.Φ v := hinj
      (by simpa [AdmissibleDatum.X_finset] using hx')
      (by simpa [AdmissibleDatum.X_finset] using hy')
      hπ2
    have hΦ : 𝒟.Φ u = 𝒟.Φ v := by
      rw [hxy] at hxy'
      exact add_left_cancel hxy'
    have huv : u = v := AdmissibleDatum.Φ_injective 𝒟 hΦ
    cases huv
    cases hxy
    rfl
  exact Finset.card_le_card_of_injOn g hmap hinjg

theorem orderedUnitPairs_card_le_two_mul_nu (P : Finset Point) : (orderedUnitPairs P).card ≤ 2 * ν P := by
  classical
  let T : Finset (Point × Point) := orderedUnitPairs P
  let f : Point × Point → Sym2 Point := fun xy => Sym2.mk xy.1 xy.2
  let unitDistSymm : {g : Point → Point → Prop // ∀ a b, g a b = g b a} :=
    ⟨fun a b => dist a b = 1, by
      intro a b
      simp [dist_comm]⟩
  change T.card ≤ 2 * ν P
  have hfiber_le_two : ∀ z ∈ T.image f, ({a ∈ T | f a = z}).card ≤ 2 := by
    intro z hz
    have hnotdiag : ¬ z.IsDiag := by
      rcases Finset.mem_image.mp hz with ⟨xy, hxyT, rfl⟩
      have hxyT' : xy ∈ P.offDiag ∧ dist xy.1 xy.2 = 1 := by
        simpa [T, orderedUnitPairs] using hxyT
      simpa [f] using Finset.not_isDiag_mk_of_mem_offDiag hxyT'.1
    have hcard_le : ({a ∈ T | f a = z}).card ≤ (z.toFinset.offDiag).card := by
      let g : {a // a ∈ {a ∈ T | f a = z}} → {a // a ∈ z.toFinset.offDiag} := by
        intro p
        refine ⟨p.1, ?_⟩
        rcases Finset.mem_filter.mp p.2 with ⟨hpT, hpz⟩
        have hpT' : p.1 ∈ P.offDiag ∧ dist p.1.1 p.1.2 = 1 := by
          simpa [T, orderedUnitPairs] using hpT
        rcases Finset.mem_offDiag.mp hpT'.1 with ⟨_, _, hne⟩
        refine Finset.mem_offDiag.mpr ?_
        refine ⟨?_, ?_, hne⟩
        · have hx : p.1.1 ∈ f p.1 := by
            simp [f]
          exact (Sym2.mem_toFinset).2 (by
            simpa [hpz] using hx)
        · have hy : p.1.2 ∈ f p.1 := by
            simp [f]
          exact (Sym2.mem_toFinset).2 (by
            simpa [hpz] using hy)
      have hg_inj : Function.Injective g := by
        intro a b h
        cases a
        cases b
        cases h
        rfl
      exact Finset.card_le_card_of_injective (f := g) hg_inj
    have hz_card : z.toFinset.card = 2 := Sym2.card_toFinset_of_not_isDiag z hnotdiag
    calc
      ({a ∈ T | f a = z}).card ≤ (z.toFinset.offDiag).card := hcard_le
      _ = z.toFinset.card * z.toFinset.card - z.toFinset.card := by
        simp
      _ = 2 := by
        rw [hz_card]
  have hT_le : T.card ≤ 2 * (T.image f).card := by
    calc
      T.card = ∑ z ∈ T.image f, ({a ∈ T | f a = z}).card :=
        Finset.card_eq_sum_card_image f T
      _ ≤ ∑ z ∈ T.image f, 2 := by
        refine Finset.sum_le_sum ?_
        intro z hz
        exact hfiber_le_two z hz
      _ = 2 * (T.image f).card := by
        simp [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
  have himage_subset :
      T.image f ⊆ P.sym2.filter (fun z : Sym2 Point => ¬ z.IsDiag ∧ Sym2.lift unitDistSymm z) := by
    intro z hz
    rcases Finset.mem_image.mp hz with ⟨xy, hxyT, rfl⟩
    have hxyT' : xy ∈ P.offDiag ∧ dist xy.1 xy.2 = 1 := by
      simpa [T, orderedUnitPairs] using hxyT
    rcases Finset.mem_offDiag.mp hxyT'.1 with ⟨hxP, hyP, _⟩
    refine Finset.mem_filter.mpr ?_
    refine ⟨?_, ?_⟩
    · simpa [f] using (Finset.mk_mem_sym2_iff).2 ⟨hxP, hyP⟩
    · refine ⟨?_, ?_⟩
      · simpa [f] using Finset.not_isDiag_mk_of_mem_offDiag hxyT'.1
      · simpa [f, unitDistSymm] using hxyT'.2
  have himage_le : (T.image f).card ≤ ν P := by
    simpa [ν, unitDistSymm] using Finset.card_le_card himage_subset
  exact le_trans hT_le (Nat.mul_le_mul_left 2 himage_le)

theorem lemma_2_5 (𝒟 : AdmissibleDatum) (U : Finset 𝒟.K)
    (_hU_norm : ∀ u ∈ U, 𝒟.IsNormOneIntegral u)
    (a : 𝒟.V) (R : ℝ) :
    Set.InjOn 𝒟.π1 (𝒟.X a R) ∧
      2 * ν (𝒟.P_set a R) ≥ 𝒟.E_count a R U := by
  constructor
  · exact lemma_2_5_pi1_injOn 𝒟 a R
  · let hinj : Set.InjOn 𝒟.π1 (𝒟.X a R) := lemma_2_5_pi1_injOn 𝒟 a R
    have hE : 𝒟.E_count a R U ≤ (orderedUnitPairs (𝒟.P_set a R)).card :=
      lemma_2_5_E_count_le_orderedUnitPairs 𝒟 U _hU_norm a R hinj
    have hord : (orderedUnitPairs (𝒟.P_set a R)).card ≤ 2 * ν (𝒟.P_set a R) :=
      orderedUnitPairs_card_le_two_mul_nu (𝒟.P_set a R)
    exact le_trans hE hord

theorem P_set_card_eq_N_count (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ)
    (_hinj : Set.InjOn 𝒟.π1 (𝒟.X a R)) :
    (𝒟.P_set a R).card = 𝒟.N_count a R := by
  classical

  have hinj_comp : Set.InjOn
      (fun z : 𝒟.V =>
        (EuclideanSpace.equiv (Fin 2) ℝ).symm ![(𝒟.π1 z).re, (𝒟.π1 z).im])
      (𝒟.X a R) := by
    intro x hx y hy hxy
    have hzw' : (![(𝒟.π1 x).re, (𝒟.π1 x).im] : Fin 2 → ℝ) =
        ![(𝒟.π1 y).re, (𝒟.π1 y).im] :=
      (EuclideanSpace.equiv (Fin 2) ℝ).symm.injective hxy
    have h0 : (𝒟.π1 x).re = (𝒟.π1 y).re :=
      congrArg (fun v : Fin 2 → ℝ => v 0) hzw'
    have h1 : (𝒟.π1 x).im = (𝒟.π1 y).im :=
      congrArg (fun v : Fin 2 → ℝ => v 1) hzw'
    exact _hinj hx hy (Complex.ext h0 h1)

  have hcoe : (𝒟.X_finset a R : Set 𝒟.V) = 𝒟.X a R := by
    simp [AdmissibleDatum.X_finset]

  unfold AdmissibleDatum.P_set AdmissibleDatum.N_count
  apply Finset.card_image_of_injOn
  intro x hx y hy hxy
  exact hinj_comp (by simp [AdmissibleDatum.X_finset] at hx; exact hx)
                  (by simp [AdmissibleDatum.X_finset] at hy; exact hy)
                  hxy

theorem complex_ball_packing (n : ℕ) (s : Finset (Fin n → ℂ)) (R δ : ℝ) : 0 ≤ R → 0 < δ → (∀ z ∈ s, ‖z‖ ≤ R) → (∀ x ∈ s, ∀ y ∈ s, x ≠ y → δ ≤ dist x y) → (s.card : ℝ) ≤ (2 * R / δ + 1) ^ (2 * n) := by
  intro hR hδ hs hsep
  let r : ℝ := δ / 2
  let μ : MeasureTheory.Measure (Fin n → ℂ) := by
    volume_tac
  have hr : 0 < r := by
    dsimp [r]
    linarith
  have hbigr : 0 < R + r := by linarith
  have hpair : Set.PairwiseDisjoint (s : Set (Fin n → ℂ)) (fun x => Metric.ball x r) := by
    intro x hx y hy hxy
    apply Metric.ball_disjoint_ball
    dsimp [r]
    have h := hsep x hx y hy hxy
    linarith
  have hsubset : (⋃ x ∈ s, Metric.ball x r) ⊆ Metric.ball (0 : Fin n → ℂ) (R + r) := by
    intro y hy
    simp only [Set.mem_iUnion] at hy ⊢
    rcases hy with ⟨x, hx, hy⟩
    have hxR := hs x hx
    have hyx : dist y x < r := hy
    have hy_norm : ‖y - x‖ < r := by
      simpa [dist_eq_norm] using hyx
    have hy_lt : ‖y‖ < R + r := by
      calc
        ‖y‖ = ‖(y - x) + x‖ := by
          congr 1
          abel_nf
        _ ≤ ‖y - x‖ + ‖x‖ := norm_add_le _ _
        _ < r + R := add_lt_add_of_lt_of_le hy_norm hxR
        _ = R + r := by ring
    simpa [dist_eq_norm] using hy_lt
  have hsum : ∑ x ∈ s, μ (Metric.ball x r) ≤ μ (Metric.ball (0 : Fin n → ℂ) (R + r)) := by
    have hmono : μ (⋃ x ∈ s, Metric.ball x r) ≤ μ (Metric.ball (0 : Fin n → ℂ) (R + r)) := by
      exact MeasureTheory.measure_mono hsubset
    rw [MeasureTheory.measure_biUnion_finset hpair] at hmono
    · exact hmono
    · intro x hx
      exact Metric.isOpen_ball.measurableSet
  have hvol_small : ∀ x : Fin n → ℂ, μ (Metric.ball x r) = (ENNReal.ofReal r ^ 2 * NNReal.pi) ^ n := by
    intro x
    simpa [μ] using (MeasureTheory.volume_pi_ball x hr)
  have hvol_big : μ (Metric.ball (0 : Fin n → ℂ) (R + r)) = (ENNReal.ofReal (R + r) ^ 2 * NNReal.pi) ^ n := by
    simpa [μ] using (MeasureTheory.volume_pi_ball (0 : Fin n → ℂ) hbigr)
  rw [hvol_big] at hsum
  simp [hvol_small] at hsum
  have hcsmall0 : ENNReal.ofReal r ^ 2 * (NNReal.pi : ENNReal) = ENNReal.ofReal (r ^ 2 * Real.pi) := by
    rw [← ENNReal.ofReal_pow hr.le, ENNReal.coe_nnreal_eq, NNReal.coe_real_pi, ← ENNReal.ofReal_mul]
    positivity
  have hcbig0 : ENNReal.ofReal (R + r) ^ 2 * (NNReal.pi : ENNReal) = ENNReal.ofReal ((R + r) ^ 2 * Real.pi) := by
    rw [← ENNReal.ofReal_pow (show 0 ≤ R + r by linarith), ENNReal.coe_nnreal_eq, NNReal.coe_real_pi, ← ENNReal.ofReal_mul]
    positivity
  have hcsmall : (ENNReal.ofReal r ^ 2 * (NNReal.pi : ENNReal)) ^ n = ENNReal.ofReal ((r ^ 2 * Real.pi) ^ n) := by
    rw [hcsmall0, ← ENNReal.ofReal_pow]
    positivity
  have hcbig : (ENNReal.ofReal (R + r) ^ 2 * (NNReal.pi : ENNReal)) ^ n = ENNReal.ofReal (((R + r) ^ 2 * Real.pi) ^ n) := by
    rw [hcbig0, ← ENNReal.ofReal_pow]
    positivity
  rw [hcsmall, hcbig] at hsum
  rw [← ENNReal.ofReal_natCast s.card, ← ENNReal.ofReal_mul (show 0 ≤ (s.card : ℝ) by positivity)] at hsum
  have hsum' : (s.card : ℝ) * ((r ^ 2 * Real.pi) ^ n) ≤ (((R + r) ^ 2 * Real.pi) ^ n) := by
    exact (ENNReal.ofReal_le_ofReal_iff (by positivity)).mp hsum
  have hratio : (s.card : ℝ) ≤ ((((R + r) ^ 2 * Real.pi) / (r ^ 2 * Real.pi)) ^ n) := by
    have hApos : 0 < (r ^ 2 * Real.pi) ^ n := by positivity
    have := (le_div_iff₀ hApos).2 hsum'
    simpa [div_pow] using this
  have hratio' : (s.card : ℝ) ≤ (((R + r) / r) ^ (2 * n)) := by
    have hdiv : (((R + r) ^ 2 * Real.pi) / (r ^ 2 * Real.pi) : ℝ) = ((R + r) / r) ^ 2 := by
      field_simp [Real.pi_pos.ne', hr.ne']
    rw [hdiv] at hratio
    simpa [pow_mul] using hratio
  have hrw : (R + r) / r = 2 * R / δ + 1 := by
    dsimp [r]
    field_simp [hδ.ne']
  simpa [hrw] using hratio'

theorem lattice_nonzero_norm_ge_inv_denom (𝒟 : AdmissibleDatum) {z : 𝒟.V} : z ∈ (𝒟.Λ : Set 𝒟.V) → z ≠ 0 → (1 / 𝒟.denom : ℝ) ≤ ‖z‖ := by
  intro hz hne
  rcases hz with ⟨u, ⟨x, hx⟩, rfl⟩
  have hu : u ≠ 0 := by
    intro hu0
    apply hne
    ext i
    simp [AdmissibleDatum.Φ, hu0]
  have hxK_ne : (x : 𝒟.K) ≠ 0 := by
    intro hxzero
    have hmul0 : ((𝒟.Q : 𝒟.K) ^ 2) * u = 0 := by
      simpa [hxzero] using hx
    have hQ0 : ((𝒟.Q : 𝒟.K) ^ 2) ≠ 0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr (Nat.ne_of_gt 𝒟.Q_pos))
    exact hu ((mul_eq_zero.mp hmul0).resolve_left hQ0)
  have hx_ne : x ≠ 0 := by
    intro hxzero
    exact hxK_ne (by simpa using hxzero)
  by_contra hlt
  have hlt' : ‖𝒟.Φ u‖ < (1 / 𝒟.denom : ℝ) := by
    simpa using not_le.mp hlt
  have hsupu : 𝒟.supNorm (𝒟.Φ u) < (1 / 𝒟.denom : ℝ) := by
    simpa [supNorm_eq_norm] using hlt'
  have hcoord_le : ∀ i : Fin 𝒟.f, ‖adm_σ 𝒟 i u‖ ≤ 𝒟.supNorm (𝒟.Φ u) := by
    intro i
    unfold AdmissibleDatum.supNorm
    simpa [AdmissibleDatum.Φ] using
      (Finset.le_sup' (s := Finset.univ) (f := fun r : Fin 𝒟.f => ‖𝒟.Φ u r‖)
        (b := i) (by simp))
  have hcoord : ∀ i : Fin 𝒟.f, ‖adm_σ 𝒟 i u‖ < (1 / 𝒟.denom : ℝ) := by
    intro i
    exact lt_of_le_of_lt (hcoord_le i) hsupu
  have hmap : ∀ i : Fin 𝒟.f, (𝒟.denom : ℂ) * adm_σ 𝒟 i u = adm_σ 𝒟 i (x : 𝒟.K) := by
    intro i
    simpa [AdmissibleDatum.denom, map_mul, map_pow, AdmissibleDatum.Q, mul_assoc, mul_left_comm, mul_comm] using congrArg (adm_σ 𝒟 i) hx
  have hnorm : ∀ i : Fin 𝒟.f, ‖adm_σ 𝒟 i (x : 𝒟.K)‖ = (𝒟.denom : ℝ) * ‖adm_σ 𝒟 i u‖ := by
    intro i
    rw [← hmap i, norm_mul]
    simp
  have hxcoord : ∀ i : Fin 𝒟.f, ‖adm_σ 𝒟 i (x : 𝒟.K)‖ < 1 := by
    intro i
    have hdpos : (0 : ℝ) < 𝒟.denom := by exact_mod_cast 𝒟.denom_pos
    have hmul : (𝒟.denom : ℝ) * ‖adm_σ 𝒟 i u‖ < (𝒟.denom : ℝ) * (1 / 𝒟.denom : ℝ) :=
      mul_lt_mul_of_pos_left (hcoord i) hdpos
    rw [hnorm i]
    have hdenom0 : (𝒟.denom : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt 𝒟.denom_pos)
    simpa [hdenom0] using hmul
  have hc_sq : ∀ x : 𝒟.K, 𝒟.c (𝒟.c x) = x := by
    have hext : (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K).comp (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K)
        = AlgHom.id 𝒟.L 𝒟.K := by
      refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
      intro y hy
      have hy_eq : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
      subst hy_eq
      simp [𝒟.c_i_K, map_neg]
    intro x
    have hx := AlgHom.congr_fun hext x
    simpa using hx
  have hc_symm : (𝒟.c).symm = 𝒟.c := by
    ext x
    have := hc_sq ((𝒟.c).symm x)
    simpa using this.symm
  have haut : ∀ σ : 𝒟.K ≃ₐ[𝒟.L] 𝒟.K, σ = 1 ∨ σ = 𝒟.c := by
    intro σ
    have hσ_sq : σ 𝒟.i_K * σ 𝒟.i_K = -1 := by
      have h1 : σ (𝒟.i_K * 𝒟.i_K) = σ (-1) := by rw [𝒟.i_K_sq]
      rw [map_mul, map_neg, map_one] at h1
      exact h1
    have hprod : (σ 𝒟.i_K - 𝒟.i_K) * (σ 𝒟.i_K + 𝒟.i_K) = 0 := by
      have : (σ 𝒟.i_K - 𝒟.i_K) * (σ 𝒟.i_K + 𝒟.i_K)
          = σ 𝒟.i_K * σ 𝒟.i_K - 𝒟.i_K * 𝒟.i_K := by ring
      rw [this, hσ_sq, 𝒟.i_K_sq, sub_self]
    have hσ_cases : σ 𝒟.i_K = 𝒟.i_K ∨ σ 𝒟.i_K = -𝒟.i_K := by
      rcases mul_eq_zero.mp hprod with h | h
      · exact Or.inl (sub_eq_zero.mp h)
      · exact Or.inr (eq_neg_of_add_eq_zero_left h)
    rcases hσ_cases with hid | hc
    · left
      have hext : (σ : 𝒟.K →ₐ[𝒟.L] 𝒟.K) = AlgHom.id 𝒟.L 𝒟.K := by
        refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
        intro y hy
        have : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
        subst this
        simpa using hid
      ext x
      have := AlgHom.congr_fun hext x
      simpa using this
    · right
      have hext : (σ : 𝒟.K →ₐ[𝒟.L] 𝒟.K) = (𝒟.c : 𝒟.K →ₐ[𝒟.L] 𝒟.K) := by
        refine AlgHom.ext_of_adjoin_eq_top (𝒟.adjoin_i_K_eq_top) ?_
        intro y hy
        have hy_eq : y = 𝒟.i_K := Set.mem_singleton_iff.mp hy
        subst hy_eq
        change σ 𝒟.i_K = 𝒟.c 𝒟.i_K
        rw [hc, 𝒟.c_i_K]
      ext x
      have := AlgHom.congr_fun hext x
      simpa using this
  let restr : Fin 𝒟.f → (𝒟.L →+* ℂ) := fun i => (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K)
  have hrestr_inj : Function.Injective restr := by
    intro i j hij
    by_contra hneij
    exact 𝒟.adm_σ_restrict_distinct i j hneij hij
  have hrestr_bij : Function.Bijective restr := by
    refine (Fintype.bijective_iff_injective_and_card restr).2 ?_
    constructor
    · exact hrestr_inj
    · rw [Fintype.card_fin, NumberField.Embeddings.card (K := 𝒟.L) (A := ℂ)]
      rfl
  have hrestr_surj : Function.Surjective restr := hrestr_bij.surjective
  have hall : ∀ σ : 𝒟.K →+* ℂ, ‖σ (x : 𝒟.K)‖ < 1 := by
    intro σ
    let ψ : 𝒟.L →+* ℂ := σ.comp (algebraMap 𝒟.L 𝒟.K)
    obtain ⟨i, hi⟩ := hrestr_surj ψ
    have hcomp : (adm_σ 𝒟 i).comp (algebraMap 𝒟.L 𝒟.K) = ψ := hi
    obtain ⟨τ, hτ⟩ := NumberField.ComplexEmbedding.exists_comp_symm_eq_of_comp_eq
      (adm_σ 𝒟 i) σ (by simpa [ψ] using hcomp)
    rcases haut τ with hτ1 | hτc
    · rw [hτ1] at hτ
      have hEq : adm_σ 𝒟 i = σ := by simpa using hτ
      simpa [hEq] using hxcoord i
    · rw [hτc] at hτ
      have hEq : (adm_σ 𝒟 i).comp 𝒟.c = σ := by simpa [hc_symm] using hτ
      have hEval : σ (x : 𝒟.K) = star ((adm_σ 𝒟 i) (x : 𝒟.K)) := by
        have hEval' := congrArg (fun φ : 𝒟.K →+* ℂ => φ (x : 𝒟.K)) hEq
        change (adm_σ 𝒟 i) (𝒟.c (x : 𝒟.K)) = σ (x : 𝒟.K) at hEval'
        rw [complex_embedding_conjugation_compat 𝒟 (adm_σ 𝒟 i) (x : 𝒟.K)] at hEval'
        simpa using hEval'.symm
      simpa [hEval] using hxcoord i
  have hint : IsIntegral ℤ (x : 𝒟.K) := NumberField.RingOfIntegers.isIntegral_coe x
  have hle : ∀ σ : 𝒟.K →+* ℂ, ‖σ (x : 𝒟.K)‖ ≤ 1 := by
    intro σ
    exact le_of_lt (hall σ)
  rcases NumberField.Embeddings.pow_eq_one_of_norm_le_one (K := 𝒟.K) (A := ℂ) hxK_ne hint hle with ⟨n, hnpos, hpow⟩
  have hpow0 := congrArg (adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩) hpow
  have hx0lt := hxcoord ⟨0, 𝒟.f_pos⟩
  have hpow_eq_one : ‖adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩ (x : 𝒟.K)‖ ^ n = 1 := by
    have := congrArg (fun z : ℂ => ‖z‖) hpow0
    simpa [map_pow, norm_pow] using this
  have hpowlt : ‖adm_σ 𝒟 ⟨0, 𝒟.f_pos⟩ (x : 𝒟.K)‖ ^ n < 1 := by
    exact pow_lt_one₀ (norm_nonneg _) hx0lt (Nat.ne_of_gt hnpos)
  rw [hpow_eq_one] at hpowlt
  linarith

theorem X_separated (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ) {x y : 𝒟.V} : x ∈ 𝒟.X a R → y ∈ 𝒟.X a R → x ≠ y → (1 / 𝒟.denom : ℝ) ≤ dist x y := by
  intro hx hy hxy
  rcases hx with ⟨hx, _⟩
  rcases hy with ⟨hy, _⟩
  rcases hx with ⟨l₁, rfl⟩
  rcases hy with ⟨l₂, rfl⟩
  have hmem : ((l₁ - l₂ : 𝒟.Λ) : 𝒟.V) ∈ (𝒟.Λ : Set 𝒟.V) := by
    exact (l₁ - l₂).property
  have hne : ((l₁ - l₂ : 𝒟.Λ) : 𝒟.V) ≠ 0 := by
    intro h
    apply hxy
    have h' : ((l₁ : 𝒟.V) - (l₂ : 𝒟.V)) = 0 := by
      simpa using h
    have heq : (l₁ : 𝒟.V) = (l₂ : 𝒟.V) := sub_eq_zero.mp h'
    simp [heq]
  have hsep := lattice_nonzero_norm_ge_inv_denom 𝒟 hmem hne
  simpa [dist_eq_norm] using hsep

theorem lemma_2_6 (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ)
    (hR : 1 / 2 < R) :
    (𝒟.N_count a R : ℝ) ≤ (4 * R * 𝒟.denom) ^ (2 * 𝒟.f) := by
  classical
  unfold AdmissibleDatum.N_count
  have hR_nonneg : 0 ≤ R := by
    linarith
  have hdenom_posR : (0 : ℝ) < 𝒟.denom := by
    exact_mod_cast 𝒟.denom_pos
  have hdelta : 0 < (1 / 𝒟.denom : ℝ) := by
    exact one_div_pos.mpr hdenom_posR
  have hnorm : ∀ z ∈ 𝒟.X_finset a R, ‖z‖ ≤ R := by
    intro z hz
    have hzX : z ∈ 𝒟.X a R := by
      simpa [AdmissibleDatum.X_finset] using hz
    have hzB : z ∈ 𝒟.closedPolydisc R := hzX.2
    simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm] using hzB
  have hsep : ∀ x ∈ 𝒟.X_finset a R, ∀ y ∈ 𝒟.X_finset a R, x ≠ y → (1 / 𝒟.denom : ℝ) ≤ dist x y := by
    intro x hx y hy hxy
    have hxX : x ∈ 𝒟.X a R := by
      simpa [AdmissibleDatum.X_finset] using hx
    have hyX : y ∈ 𝒟.X a R := by
      simpa [AdmissibleDatum.X_finset] using hy
    exact X_separated 𝒟 a R hxX hyX hxy
  have hpack : ((𝒟.X_finset a R).card : ℝ) ≤ (2 * R / (1 / 𝒟.denom : ℝ) + 1) ^ (2 * 𝒟.f) := by
    exact complex_ball_packing 𝒟.f (𝒟.X_finset a R) R (1 / 𝒟.denom) hR_nonneg hdelta hnorm hsep
  refine le_trans hpack ?_
  have hdenom_ne : (𝒟.denom : ℝ) ≠ 0 := ne_of_gt hdenom_posR
  have hbase_eq : 2 * R / (1 / 𝒟.denom : ℝ) + 1 = 2 * R * 𝒟.denom + 1 := by
    field_simp [hdenom_ne]
  rw [hbase_eq]
  have hdenom_ge : (1 : ℝ) ≤ 𝒟.denom := by
    exact_mod_cast 𝒟.one_le_denom
  have hbase_ge_one : 1 ≤ 2 * R * 𝒟.denom := by
    nlinarith
  have hbase_nonneg : 0 ≤ 2 * R * 𝒟.denom + 1 := by
    linarith
  have hbase_le : 2 * R * 𝒟.denom + 1 ≤ 4 * R * 𝒟.denom := by
    linarith
  exact pow_le_pow_left₀ hbase_nonneg hbase_le (2 * 𝒟.f)

theorem E_count_le_N_count_sq (𝒟 : AdmissibleDatum) (a : 𝒟.V) (R : ℝ)
    (U : Finset 𝒟.K) :
    𝒟.E_count a R U ≤ 𝒟.N_count a R ^ 2 := by
  classical
  unfold AdmissibleDatum.E_count AdmissibleDatum.N_count

  rw [show ∑ u ∈ U, ((𝒟.X_finset a R).filter
        (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card
      = (U.sigma (fun u => (𝒟.X_finset a R).filter
          (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R))).card from
      (Finset.card_sigma _ _).symm]
  set src := U.sigma (fun u => (𝒟.X_finset a R).filter
    (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R))
  set tgt := (𝒟.X_finset a R) ×ˢ (𝒟.X_finset a R)

  let g : (Σ _ : 𝒟.K, 𝒟.V) → 𝒟.V × 𝒟.V := fun p => (p.2, p.2 + 𝒟.Φ p.1)
  have hmap : ∀ p ∈ src, g p ∈ tgt := by
    intro ⟨u, x⟩ hp
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp
    exact Finset.mem_product.mpr ⟨hp.2.1, hp.2.2⟩
  have hinj : Set.InjOn g src := by
    intro ⟨u, x⟩ _ ⟨v, y⟩ _ heq
    simp only [g, Prod.mk.injEq] at heq
    obtain ⟨hxy, hΦ⟩ := heq
    have huv : 𝒟.Φ u = 𝒟.Φ v := by
      have : x + 𝒟.Φ u = y + 𝒟.Φ v := hΦ
      rw [hxy] at this
      exact add_left_cancel this
    have huv' : u = v := AdmissibleDatum.Φ_injective 𝒟 huv
    subst hxy; subst huv'; rfl
  calc src.card
      ≤ tgt.card := Finset.card_le_card_of_injOn g hmap hinj
    _ = (𝒟.X_finset a R).card * (𝒟.X_finset a R).card := by
        simp [tgt, Finset.card_product]
    _ = (𝒟.X_finset a R).card ^ 2 := by ring

theorem ρ_tends_to_one (𝒟 : AdmissibleDatum) :
    Filter.Tendsto 𝒟.ρ Filter.atTop (nhds 1) := by

  have hA : Filter.Tendsto
      (fun R : ℝ => (2 / Real.pi) * Real.arccos (1 / (2 * R)))
      Filter.atTop (nhds 1) := by
    have h_inv : Filter.Tendsto (fun R : ℝ => 1 / (2 * R)) Filter.atTop (nhds 0) := by
      have h2 : Filter.Tendsto (fun R : ℝ => 2 * R) Filter.atTop Filter.atTop :=
        Filter.Tendsto.const_mul_atTop (by norm_num : (0 : ℝ) < 2) Filter.tendsto_id
      have hinv := h2.inv_tendsto_atTop
      convert hinv using 1
      ext R; rw [one_div, Pi.inv_apply]
    have h_arccos : Filter.Tendsto (fun R : ℝ => Real.arccos (1 / (2 * R)))
        Filter.atTop (nhds (Real.arccos 0)) :=
      Filter.Tendsto.arccos h_inv
    have h_arccos' : Filter.Tendsto (fun R : ℝ => Real.arccos (1 / (2 * R)))
        Filter.atTop (nhds (Real.pi / 2)) := by
      rw [← Real.arccos_zero]; exact h_arccos
    have h := h_arccos'.const_mul (2 / Real.pi)
    have hpi : Real.pi ≠ 0 := Real.pi_pos.ne'
    convert h using 1
    field_simp

  have hB : Filter.Tendsto
      (fun R : ℝ => Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2))
      Filter.atTop (nhds 0) := by

    have h_upper : Filter.Tendsto (fun R : ℝ => 1 / (Real.pi * R)) Filter.atTop (nhds 0) := by
      have hR : Filter.Tendsto (fun R : ℝ => Real.pi * R) Filter.atTop Filter.atTop :=
        Filter.Tendsto.const_mul_atTop Real.pi_pos Filter.tendsto_id
      have hinv := hR.inv_tendsto_atTop
      convert hinv using 1
      ext R; rw [one_div, Pi.inv_apply]
    refine squeeze_zero' (g := fun R => 1 / (Real.pi * R)) ?_ ?_ h_upper
    · filter_upwards [Filter.eventually_ge_atTop (1/2 : ℝ)] with R hR
      have hRpos : 0 < R := by linarith
      have h4R2 : 0 ≤ 4 * R ^ 2 - 1 := by nlinarith
      positivity
    · filter_upwards [Filter.eventually_ge_atTop (1 : ℝ)] with R hR
      have hRpos : 0 < R := by linarith
      have h4R2 : 0 ≤ 4 * R ^ 2 - 1 := by nlinarith

      have h_sqrt_le : Real.sqrt (4 * R ^ 2 - 1) ≤ 2 * R := by
        have h_eq : Real.sqrt (4 * R ^ 2) = 2 * R := by
          rw [show (4 * R ^ 2 : ℝ) = (2 * R) ^ 2 by ring,
              Real.sqrt_sq (by linarith)]
        calc Real.sqrt (4 * R ^ 2 - 1) ≤ Real.sqrt (4 * R ^ 2) :=
              Real.sqrt_le_sqrt (by linarith)
          _ = 2 * R := h_eq
      have hπR : 0 < Real.pi * R := mul_pos Real.pi_pos hRpos
      have h2πR2 : 0 < 2 * Real.pi * R ^ 2 := by positivity
      rw [div_le_div_iff₀ h2πR2 hπR]
      nlinarith [Real.pi_pos, Real.sqrt_nonneg (4 * R ^ 2 - 1)]

  have h_eq : ∀ᶠ R in Filter.atTop, 𝒟.ρ R =
      (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2) := by
    filter_upwards [Filter.eventually_gt_atTop (1/2 : ℝ)] with R hR
    have hRpos : 0 < R := by linarith
    have hπR2 : Real.pi * R ^ 2 ≠ 0 := by positivity
    have h_overlap : overlapArea R =
        2 * R ^ 2 * Real.arccos (1 / (2 * R)) -
          (1 / 2) * Real.sqrt (4 * R ^ 2 - 1) := by
      unfold overlapArea
      rw [if_neg (not_lt.mpr (le_of_lt hR))]
    unfold AdmissibleDatum.ρ AdmissibleDatum.b
    rw [h_overlap]
    field_simp
  have h_sum : Filter.Tendsto
      (fun R : ℝ => (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2))
      Filter.atTop (nhds (1 - 0)) := hA.sub hB
  rw [sub_zero] at h_sum

  have h_eq_sym : (fun R : ℝ =>
      (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2)) =ᶠ[Filter.atTop] 𝒟.ρ := by
    filter_upwards [h_eq] with R hR using hR.symm
  exact h_sum.congr' h_eq_sym

theorem theorem_2_3_absorb_factor_two (n A δ : ℝ) (hn : 0 < n) (hδpos : 0 < δ)
    (hA : (2 : ℝ) ^ (1 / δ) ≤ A) (hAn : A ≤ n) :
    (2 : ℝ) * n ^ (1 + δ) ≤ n ^ (1 + 2 * δ) := by
  have hδnonneg : 0 ≤ δ := le_of_lt hδpos
  have htwo_nonneg : 0 ≤ (2 : ℝ) ^ (1 / δ) := by
    positivity
  have htwo_le_nδ : (2 : ℝ) ≤ n ^ δ := by
    have h := Real.rpow_le_rpow htwo_nonneg (le_trans hA hAn) hδnonneg
    have htwo : ((2 : ℝ) ^ (1 / δ)) ^ δ = (2 : ℝ) := by
      rw [← Real.rpow_mul (by positivity : 0 ≤ (2 : ℝ))]
      have hδmul : (1 / δ) * δ = 1 := by
        field_simp [hδpos.ne']
      rw [hδmul, Real.rpow_one]
    rw [htwo] at h
    exact h
  have hn_pow_nonneg : 0 ≤ n ^ (1 + δ) := by
    positivity
  have hmul : (2 : ℝ) * n ^ (1 + δ) ≤ n ^ δ * n ^ (1 + δ) :=
    mul_le_mul_of_nonneg_right htwo_le_nδ hn_pow_nonneg
  have hrewrite : n ^ δ * n ^ (1 + δ) = n ^ (1 + 2 * δ) := by
    rw [← Real.rpow_add hn δ (1 + δ)]
    have hexp : δ + (1 + δ) = 1 + 2 * δ := by ring
    rw [hexp]
  calc

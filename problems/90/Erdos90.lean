theorem admissibleDatum_differentIdeal_absNorm_le_four_pow_f (𝒟 : AdmissibleDatum) :
  Ideal.absNorm
      (differentIdeal (NumberField.RingOfIntegers 𝒟.L) (NumberField.RingOfIntegers 𝒟.K))
    ≤ 4 ^ (AdmissibleDatum.f 𝒟) := by
  let A := NumberField.RingOfIntegers 𝒟.K
  let I : Ideal A :=
    differentIdeal (NumberField.RingOfIntegers 𝒟.L) A
  have hiO_unit : IsUnit (admissibleDatum_iO 𝒟) := by
    refine ⟨⟨admissibleDatum_iO 𝒟, -admissibleDatum_iO 𝒟, ?_, ?_⟩, rfl⟩
    · ext
      change 𝒟.i_K * (-𝒟.i_K) = 1
      calc
        𝒟.i_K * (-𝒟.i_K) = -(𝒟.i_K * 𝒟.i_K) := by ring
        _ = -(-1) := by rw [𝒟.i_K_sq]
        _ = 1 := by norm_num
    · ext
      change (-𝒟.i_K) * 𝒟.i_K = 1
      calc
        (-𝒟.i_K) * 𝒟.i_K = -(𝒟.i_K * 𝒟.i_K) := by ring
        _ = -(-1) := by rw [𝒟.i_K_sq]
        _ = 1 := by norm_num
  have hspan_le : Ideal.span ({2 * admissibleDatum_iO 𝒟} : Set A) ≤ I := by
    rw [Ideal.span_singleton_le_iff_mem]
    simpa [I, A] using admissibleDatum_two_iO_mem_differentIdeal 𝒟
  have hdiv : Ideal.absNorm I ∣ Ideal.absNorm (Ideal.span ({2 * admissibleDatum_iO 𝒟} : Set A)) := by
    exact Ideal.absNorm_dvd_absNorm_of_le hspan_le
  have hspan_eq : Ideal.span ({2 * admissibleDatum_iO 𝒟} : Set A) = Ideal.span ({(2 : A)} : Set A) := by
    simpa [A, mul_comm] using
      (Ideal.span_singleton_mul_right_unit (a := admissibleDatum_iO 𝒟) hiO_unit (x := (2 : A)))
  have hrank0 : Module.finrank ℤ A = Module.finrank ℚ 𝒟.K := by
    simpa [A] using (IsIntegralClosure.rank ℤ ℚ 𝒟.K A)
  have hfinrankK : Module.finrank ℚ 𝒟.K = 2 * AdmissibleDatum.f 𝒟 := by
    calc
      Module.finrank ℚ 𝒟.K = Module.finrank ℚ 𝒟.L * Module.finrank 𝒟.L 𝒟.K := by
        symm
        exact Module.finrank_mul_finrank ℚ 𝒟.L 𝒟.K
      _ = AdmissibleDatum.f 𝒟 * 2 := by
        rw [AdmissibleDatum.f, Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K]
      _ = 2 * AdmissibleDatum.f 𝒟 := by ring
  have hrank : Module.finrank ℤ A = 2 * AdmissibleDatum.f 𝒟 := by
    rw [hrank0, hfinrankK]
  have hnorm2Q : ((Algebra.norm ℤ (2 : A) : ℤ) : ℚ) = ((2 : ℚ) ^ (2 * AdmissibleDatum.f 𝒟)) := by
    calc
      ((Algebra.norm ℤ (2 : A) : ℤ) : ℚ) = algebraMap ℤ ℚ (Algebra.intNorm ℤ A (2 : A)) := by
        rw [Algebra.intNorm_eq_norm]
        rfl
      _ = Algebra.norm ℚ (((2 : A) : 𝒟.K)) := by
        simpa [A] using (Algebra.algebraMap_intNorm (A := ℤ) (K := ℚ) (L := 𝒟.K) (B := A) (x := (2 : A)))
      _ = Algebra.norm ℚ (2 : 𝒟.K) := by rfl
      _ = (2 : ℚ) ^ Module.finrank ℚ 𝒟.K := by
        simpa using (Algebra.norm_algebraMap (K := ℚ) (L := 𝒟.K) (x := (2 : ℚ)))
      _ = ((2 : ℚ) ^ (2 * AdmissibleDatum.f 𝒟)) := by rw [hfinrankK]
  have hnorm2 : Algebra.norm ℤ (2 : A) = (2 : ℤ) ^ (2 * AdmissibleDatum.f 𝒟) := by
    apply Int.cast_injective (α := ℚ)
    calc
      ((Algebra.norm ℤ (2 : A) : ℤ) : ℚ) = (2 : ℚ) ^ (2 * AdmissibleDatum.f 𝒟) := hnorm2Q
      _ = (((2 : ℤ) ^ (2 * AdmissibleDatum.f 𝒟) : ℤ) : ℚ) := by norm_num
  have hspan_norm : Ideal.absNorm (Ideal.span ({(2 : A)} : Set A)) = 4 ^ AdmissibleDatum.f 𝒟 := by
    rw [Ideal.absNorm_span_singleton, hnorm2]
    norm_num [pow_mul]
  have hdiv' : Ideal.absNorm I ∣ 4 ^ AdmissibleDatum.f 𝒟 := by
    rw [hspan_eq, hspan_norm] at hdiv
    exact hdiv
  exact Nat.le_of_dvd (by positivity) hdiv'

theorem admissibleDatum_natAbs_discr_K_le_four_pow_f_mul_natAbs_discr_L_sq (𝒟 : AdmissibleDatum) :
  (NumberField.discr 𝒟.K).natAbs ≤
    4 ^ (AdmissibleDatum.f 𝒟) * (NumberField.discr 𝒟.L).natAbs ^ 2 := by
  let D := Ideal.absNorm
    (differentIdeal (NumberField.RingOfIntegers 𝒟.L) (NumberField.RingOfIntegers 𝒟.K))
  have hD : D ≤ 4 ^ (AdmissibleDatum.f 𝒟) := by
    simpa [D] using admissibleDatum_differentIdeal_absNorm_le_four_pow_f 𝒟
  have hdisc_nat : (NumberField.discr 𝒟.K).natAbs =
      D * (NumberField.discr 𝒟.L).natAbs ^ 2 := by
    simpa [D, Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K] using
      (NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        𝒟.L (NumberField.RingOfIntegers 𝒟.L) 𝒟.K (NumberField.RingOfIntegers 𝒟.K))
  calc
    (NumberField.discr 𝒟.K).natAbs = D * (NumberField.discr 𝒟.L).natAbs ^ 2 := hdisc_nat
    _ ≤ 4 ^ (AdmissibleDatum.f 𝒟) * (NumberField.discr 𝒟.L).natAbs ^ 2 :=
      Nat.mul_le_mul_right ((NumberField.discr 𝒟.L).natAbs ^ 2) hD

theorem rootDiscr_adjoin_i_bound (𝒟 : AdmissibleDatum) :
  NumberField.rootDiscr 𝒟.K ≤ 2 * NumberField.rootDiscr 𝒟.L := by
  have hdisc : ((NumberField.discr 𝒟.K).natAbs : ℝ) ≤ (4 : ℝ) ^ (AdmissibleDatum.f 𝒟) *
      ((NumberField.discr 𝒟.L).natAbs : ℝ) ^ 2 := by
    exact_mod_cast admissibleDatum_natAbs_discr_K_le_four_pow_f_mul_natAbs_discr_L_sq 𝒟
  let n : ℕ := 2 * AdmissibleDatum.f 𝒟
  have hfinrankK' := by
    letI : Algebra ℚ 𝒟.K := DivisionRing.toRatAlgebra
    show ((Module.finrank ℚ 𝒟.K : ℕ) : ℝ) = (n : ℝ)
    exact_mod_cast admissibleDatum_finrankK_eq_two_mul_f_anyAlg (𝒟 := 𝒟)
  have hfinrankK_inv := by
    letI : Algebra ℚ 𝒟.K := DivisionRing.toRatAlgebra
    show (((Module.finrank ℚ 𝒟.K : ℕ) : ℝ)⁻¹) = ((n : ℝ)⁻¹)
    simpa using congrArg Inv.inv hfinrankK'
  have hrootK : NumberField.rootDiscr 𝒟.K = ((NumberField.discr 𝒟.K).natAbs : ℝ) ^ ((n : ℝ)⁻¹) := by
    rw [NumberField.rootDiscr_def, ← Nat.cast_natAbs]
    exact congrArg (fun t : ℝ => ((NumberField.discr 𝒟.K).natAbs : ℝ) ^ t) hfinrankK_inv
  have hrootL : NumberField.rootDiscr 𝒟.L =
      ((NumberField.discr 𝒟.L).natAbs : ℝ) ^ ((AdmissibleDatum.f 𝒟 : ℝ)⁻¹) := by
    rw [NumberField.rootDiscr_def, AdmissibleDatum.f, ← Nat.cast_natAbs]
  have hn : n ≠ 0 := by
    dsimp [n]
    exact Nat.mul_ne_zero (by decide) (Nat.ne_of_gt 𝒟.f_pos)
  have hexp_nonneg : 0 ≤ ((n : ℝ)⁻¹) := by
    positivity
  have hpow := Real.rpow_le_rpow (by positivity) hdisc hexp_nonneg
  have hpow4 : (4 : ℝ) ^ (AdmissibleDatum.f 𝒟) = (2 : ℝ) ^ n := by
    dsimp [n]
    rw [pow_mul]
    norm_num
  have hfour : ((4 : ℝ) ^ (AdmissibleDatum.f 𝒟)) ^ ((n : ℝ)⁻¹) = 2 := by
    rw [hpow4]
    exact Real.pow_rpow_inv_natCast (by positivity) hn
  have hf_ne : (AdmissibleDatum.f 𝒟 : ℝ) ≠ 0 := by
    exact_mod_cast (Nat.ne_of_gt 𝒟.f_pos)

theorem diagonal_cubic_subfield_exists_unramified (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]

theorem closedFrattini_normal (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : в„•) : (closedFrattini p G).Normal := by
  classical
  let S : Set G := (Set.range fun g : G => g ^ p) вҲӘ (commutator G : Set G)

    have hcardQ3 : Nat.card (Q.1.inertia (M вүғвӮҗ[в„ҡ] M)) = 3 := by
      rw [hcardQ, he3]
    have hQinertia_ne_bot : Q.1.inertia (M вүғвӮҗ[в„ҡ] M) вү  вҠҘ := by

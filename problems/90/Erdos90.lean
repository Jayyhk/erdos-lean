        (Set.Ioi Оҙ))
  have h_base_real : IntervalIntegrable (fun y : в„қ => logRescalePartialSum f y - b) MeasureTheory.volume (0 : в„қ) Оҙ :=
    logRescalePartialSum_intervalIntegrable f b 0 Оҙ

    linarith
  have hscale0 :=
      intervalIntegral.mul_integral_comp_mul_right
        (f := fun x : ℝ => Real.sqrt (R ^ 2 - x ^ 2))
        (a := (1 : ℝ) / (2 * R)) (b := 1) (c := R)

  letI : IsTotallyReal K2 := IsTotallyReal.ofRingEquiv eL.toRingEquiv
  letI : IsGalois в„ҡ K1 := IsGalois.of_algEquiv eM
  letI : IsGalois в„ҡ K2 := IsGalois.of_algEquiv eL
  have hK1_subfield_tot : IsTotallyReal (K1.toSubfield : Subfield (AlgebraicClosure в„ҡ)) := by
    simpa using (show IsTotallyReal K1 from inferInstance)
  have hK2_subfield_tot : IsTotallyReal (K2.toSubfield : Subfield (AlgebraicClosure в„ҡ)) := by
    simpa using (show IsTotallyReal K2 from inferInstance)
  have hM0_subfield_tot :
      IsTotallyReal (K1.toSubfield вҠ” K2.toSubfield : Subfield (AlgebraicClosure в„ҡ)) := by
    letI : Algebra.IsAlgebraic в„ҡ (AlgebraicClosure в„ҡ) := AlgebraicClosure.isAlgebraic (k := в„ҡ)
    letI : IsTotallyReal (K1.toSubfield : Subfield (AlgebraicClosure в„ҡ)) := hK1_subfield_tot
    letI : IsTotallyReal (K2.toSubfield : Subfield (AlgebraicClosure в„ҡ)) := hK2_subfield_tot

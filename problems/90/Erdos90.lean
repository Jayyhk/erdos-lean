    rfl
  have hLmono : вҲҖ j, L j вүӨ L (j + 1) := by
    intro j
    apply IntermediateField.fixedField_le
    exact Subgroup.comap_mono (hUmono j)
  have hN0 : N 0 = вҠӨ := by
    ext Пғ
    simp [N, hU0]
  have hL0 : L 0 = вҠҘ := by
    simpa [L, H, hN0] using (InfiniteGalois.fixedField_bot (k := F) (K := K))
  let hquot_aut_equiv : вҲҖ j, (Q.Q в§ё (U j : Subgroup Q.Q)) вүғ* ((L j) вүғвӮҗ[F] (L j)) := by
    intro j

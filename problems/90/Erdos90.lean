        вҲ‘ n вҲҲ Finset.filter (fun n : в„• => Real.log n < x) (Finset.Icc 1 N), f n
          вүӨ вҲ‘ n вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f n := by

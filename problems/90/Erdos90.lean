noncomputable def wiener_boundary_function (G : в„Ӯ вҶ’ в„Ӯ) (b : в„қ) : в„Ӯ вҶ’ в„Ӯ :=
  fun s => s * G (s - (1 : в„Ӯ)) + (b : в„Ӯ)

theorem wiener_boundary_function_eqOn {f : в„• вҶ’ в„қ} {b : в„қ} {G : в„Ӯ вҶ’ в„Ӯ} :
    (hGint : вҲҖ z : в„Ӯ, 0 < z.re вҶ’
      MeasureTheory.IntegrableOn
        (fun x : в„қ => (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : в„қ))) вҶ’
    (hGeq : Set.EqOn G
      (fun z : в„Ӯ => вҲ« x in Set.Ioi (0 : в„қ),
        (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
      {z : в„Ӯ | 0 < z.re}) вҶ’
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hsumm : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    Set.EqOn (wiener_boundary_function G b)
      (fun s : в„Ӯ => LSeries (fun n => (f n : в„Ӯ)) s - Complex.ofReal b / (s - 1))
      {s : в„Ӯ | 1 < s.re} := by
  intro hGint hGeq hnonneg hsumm s hs
  have hsre : 1 < s.re := hs
  have hz : 0 < (s - (1 : в„Ӯ)).re := by
    simpa [Complex.sub_re] using sub_pos.mpr hsre
  have hG := boundary_extension_complex_identity hGint hGeq hnonneg hsumm (s - (1 : в„Ӯ)) hz
  dsimp [wiener_boundary_function]
  rw [hG]
  have h_one_add_sub : (1 : в„Ӯ) + (s - 1) = s := by ring
  rw [h_one_add_sub]
  have hs_ne : s вү  0 := by
    intro hs0
    have hspos : 0 < s.re := lt_trans zero_lt_one hsre
    simp [hs0] at hspos
  have hsub_ne : s - (1 : в„Ӯ) вү  0 := by
    intro hzero
    have : 0 < (s - (1 : в„Ӯ)).re := hz
    simp [hzero] at this
  field_simp [hs_ne, hsub_ne]
  ring_nf

theorem logRescalePartialSum_tendsto_of_boundary_extension {f : в„• вҶ’ в„қ} {b : в„қ} (hF : HasBoundaryLaplaceExtension f b) (hnonneg : вҲҖ n, 0 вүӨ f n) : Filter.Tendsto (fun x : в„қ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
  have hf : вҲҖ Пғ' : в„қ, 1 < Пғ' вҶ’ Summable (nterm (fun n => (f n : в„Ӯ)) Пғ') :=
    summable_nterm_of_boundary_extension hnonneg hF
  rcases hF with вҹЁG, hGcont, hGint, hGeqвҹ©
  have hsumm : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s :=
    lseries_summable_complex_of_nterm hf
  let W : в„Ӯ вҶ’ в„Ӯ := wiener_boundary_function G b
  have hWcont : ContinuousOn W {s : в„Ӯ | 1 вүӨ s.re} := by
    have hshift : ContinuousOn (fun s : в„Ӯ => s - (1 : в„Ӯ)) {s : в„Ӯ | 1 вүӨ s.re} := by
      simpa using (continuous_id.sub continuous_const).continuousOn
    have hmaps : Set.MapsTo (fun s : в„Ӯ => s - (1 : в„Ӯ)) {s : в„Ӯ | 1 вүӨ s.re} {z : в„Ӯ | 0 вүӨ z.re} := by
      intro s hs
      simpa using hs
    have hGshift : ContinuousOn (fun s : в„Ӯ => G (s - (1 : в„Ӯ))) {s : в„Ӯ | 1 вүӨ s.re} := by
      simpa [Function.comp] using hGcont.comp hshift hmaps

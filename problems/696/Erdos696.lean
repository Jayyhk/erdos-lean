  --   And y_target ≤ exp(y_target^{A-1}) ≤ P (via hP_bound at index k).  So past_cutoff ≤ P.
  have ha_dvd_M : a ∣ M := by
    rw [ha_def, hM_def]
    unfold primorial
    apply Finset.prod_dvd_prod_of_subset
    intro p hp
    rw [Finset.mem_filter, Finset.mem_Iic] at hp ⊢
    refine ⟨?_, hp.2⟩

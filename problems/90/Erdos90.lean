  let T : Set {K : IntermediateField ℚ (AlgebraicClosure F) // FiniteDimensional ℚ K} :=
    {K | haveI : NumberField K := @NumberField.mk _ _ inferInstance K.prop; |NumberField.discr K| ≤ B}

theorem exists_continuousConjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary
    (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (Пү : {Пү : C((G в§ё N) Г— (G в§ё N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G в§ё N) Пү})
    (h1 : вҲҖ q : G в§ё N, Пү.1 (1, q) = 0)
    (h2 : вҲҖ q : G в§ё N, Пү.1 (q, 1) = 0)
    (hinfl : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p G (QPull p G N Пү)) :
    вҲғ ПҮh : Additive вҶҘN вҶ’вӮң+ ZMod p, вҲғ u : C(G в§ё N, ZMod p),
      (вҲҖ g : G, вҲҖ n : вҶҘN,
        ПҮh (Additive.ofMul (MulAut.conjNormal (H := N) g n)) = ПҮh (Additive.ofMul n)) вҲ§
      (вҲҖ x y : G в§ё N,
        Пү.1 (x, y) =
          u y - u (x * y) + u x +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
              (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
              (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
              ПҮh.toAddMonoidHom) (x, y)) := by
  classical
  rcases hinfl with вҹЁb, hbвҹ©
  have hb_one : b 1 = 0 := by
    have h := hb 1 1
    simpa [QPull, h2 (1 : G в§ё N)] using h.symm
  have hb_rightN : вҲҖ g : G, вҲҖ n : вҶҘN, b (g * n) = b n + b g := by
    intro g n
    have hqn : (n : G в§ё N) = 1 := by
      simp
    have hq0 : Пү.1 ((g : G в§ё N), 1) = b n - b (g * n) + b g := by
      simpa [QPull, hqn] using hb g n
    have h0 : 0 = b n - b (g * n) + b g := by
      rw [h2 (g : G в§ё N)] at hq0
      exact hq0
    have h' := congrArg (fun a => a + b (g * n)) h0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h'
  have hb_leftN : вҲҖ n : вҶҘN, вҲҖ g : G, b ((n : G) * g) = b g + b n := by
    intro n g
    have hqn : (n : G в§ё N) = 1 := by
      simp
    have hq0 : Пү.1 (1, (g : G в§ё N)) = b g - b ((n : G) * g) + b n := by
      simpa [QPull, hqn] using hb n g
    have h0 : 0 = b g - b ((n : G) * g) + b n := by
      rw [h1 (g : G в§ё N)] at hq0
      exact hq0
    have h' := congrArg (fun a => a + b ((n : G) * g)) h0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h'
  let ПҮh : Additive вҶҘN вҶ’вӮң+ ZMod p :=
    { toAddMonoidHom :=
        { toFun := fun n => -b (((@Additive.toMul вҶҘN) n : вҶҘN) : G)
          map_zero' := by
            simp [hb_one]
          map_add' := by
            intro nвӮҒ nвӮӮ
            have hmul :
                b (((((@Additive.toMul вҶҘN) nвӮҒ : вҶҘN) : G) * (((@Additive.toMul вҶҘN) nвӮӮ : вҶҘN) : G))) =
                  b (((@Additive.toMul вҶҘN) nвӮӮ : вҶҘN) : G) + b (((@Additive.toMul вҶҘN) nвӮҒ : вҶҘN) : G) := by
              simpa using
                (hb_leftN (n := ((@Additive.toMul вҶҘN) nвӮҒ : вҶҘN))
                  (g := (((@Additive.toMul вҶҘN) nвӮӮ : вҶҘN) : G)))
            have hneg := congrArg (fun a : ZMod p => -a) hmul
            simpa [toMul_add, add_assoc, add_left_comm, add_comm] using hneg }
      continuous_toFun := by
        simpa using (b.continuous.comp continuous_subtype_val).neg }
  let s := _root_.Erdos90.TransgressionContinuous.chosenSection G N hN
  let hs := _root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN
  let u : C(G в§ё N, ZMod p) := b.comp s
  refine вҹЁПҮh, u, ?_, ?_вҹ©
  В· intro g n
    have hgn : b (g * n) = b n + b g := hb_rightN g n
    have hconj : b (g * n) = b g + b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) := by
      simpa [MulAut.conjNormal_apply, mul_assoc] using
        (hb_leftN (n := (MulAut.conjNormal (H := N) g n)) (g := g))
    have hEq : b (n : G) + b g = b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) + b g := by
      calc
        b (n : G) + b g = b (g * n) := by simp [hgn.symm]
        _ = b g + b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) := hconj
        _ = b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) + b g := by abel
    have hbn : b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) = b (n : G) := by
      exact (add_right_cancel hEq).symm
    change -b (((MulAut.conjNormal (H := N) g n : вҶҘN) : G)) = -b (n : G)
    exact congrArg (fun a : ZMod p => -a) hbn
  В· intro x y
    change
      Пү.1 (x, y) =
        u y - u (x * y) + u x +
          (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
            ПҮh.toAddMonoidHom) (x, y)
    let d := _root_.Erdos90.TransgressionContinuousInternal.schreierDefect G N s hs x y
    have hx : QuotientGroup.mk' N (s x) = x := hs x
    have hy : QuotientGroup.mk' N (s y) = y := hs y
    have hxy := hb (s x) (s y)
    have hxy0 :
        Пү.1 ((QuotientGroup.mk' N) (s x), (QuotientGroup.mk' N) (s y)) =
          b (s y) - b (s x * s y) + b (s x) := by
      simpa [QPull] using hxy
    have hxy' : Пү.1 (x, y) = b (s y) - b (s x * s y) + b (s x) := by
      simpa [hx, hy] using hxy0
    have hd : (d : G) * s (x * y) = s x * s y := by
      change (s x * s y * (s (x * y))вҒ»В№) * s (x * y) = s x * s y
      group
    have hmul : b (s x * s y) = b (s (x * y)) + b d := by
      simpa [d, hd] using hb_leftN (n := d) (g := s (x * y))
    have hcont : Continuous (ПҮh.toAddMonoidHom : Additive вҶҘN вҶ’ ZMod p) := ПҮh.continuous_toFun
    have hcont' : Continuous (fun n : Additive вҶҘN => -b (((@Additive.toMul вҶҘN) n : вҶҘN) : G)) := by
      simpa [ПҮh] using hcont
    have hsch :
        (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
          ПҮh.toAddMonoidHom) (x, y) = -b d := by
      simp [_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle, d, ПҮh, hcont']
    calc
      Пү.1 (x, y) = b (s y) - b (s x * s y) + b (s x) := hxy'
      _ = b (s y) - (b (s (x * y)) + b d) + b (s x) := by rw [hmul]
      _ = b (s y) - b (s (x * y)) + b (s x) - b d := by abel
      _ = b (s y) - b (s (x * y)) + b (s x) +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
              ПҮh.toAddMonoidHom) (x, y) := by
            rw [hsch]
            abel
      _ = u y - u (x * y) + u x +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
              ПҮh.toAddMonoidHom) (x, y) := by
            rfl

theorem exists_h1NormalInvariantClass_of_continuousConjInvariantHom (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (ПҮh : Additive вҶҘN вҶ’вӮң+ ZMod p)
    (hПҮinv : вҲҖ g : G, вҲҖ n : вҶҘN,
      ПҮh (Additive.ofMul (MulAut.conjNormal (H := N) g n)) = ПҮh (Additive.ofMul n)) :
    вҲғ ПҮ : вҶҘ(_root_.Erdos90.h1NormalInvariantSubmodule p G N),
      _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN ПҮ.1 =
        ПҮh.toAddMonoidHom := by
  haveI : CompactSpace вҶҘN := isCompact_iff_compactSpace.mp hN.isCompact
  let eN :=
    _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog
      (p := p) (K := вҶҘN)
  let x : _root_.Erdos90.H1ContsTrivial p G N := eN.symm ПҮh
  have hx : eN x = ПҮh := by
    simp [x]
  have hxhom :
      _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN x =
        ПҮh.toAddMonoidHom := by
    change (eN x).toAddMonoidHom = ПҮh.toAddMonoidHom
    exact congrArg (fun f : Additive вҶҘN вҶ’вӮң+ ZMod p => f.toAddMonoidHom) hx
  have hxinv : вҲҖ g : G,
      (_root_.Erdos90.h1ConjMap p G N g).hom x = x := by
    intro g
    have hcont :
        Continuous ((MulAut.conjNormal (H := N) gвҒ»В№ : вҶҘN вүғ* вҶҘN) : вҶҘN вҶ’ вҶҘN) := by
      refine continuous_induced_rng.2 ?_
      have hval : вҲҖ n : вҶҘN,
          ((MulAut.conjNormal (H := N) gвҒ»В№ n : вҶҘN) : G) = gвҒ»В№ * (n : G) * (gвҒ»В№)вҒ»В№ :=
        fun n => MulAut.conjNormal_apply gвҒ»В№ n
      simp only [Function.comp_def, hval]
      exact (continuous_const.mul continuous_subtype_val).mul continuous_const
    let c : Additive вҶҘN вҶ’вӮң+ Additive вҶҘN :=
      { toFun := fun n => Additive.ofMul (((MulAut.conjNormal (H := N) gвҒ»В№).toMonoidHom) n.toMul)
        map_zero' := by simp
        map_add' := by
          intro a b
          simp
        continuous_toFun := by
          simpa using hcont }
    have hnat :
        eN ((_root_.Erdos90.h1ConjMap p G N g).hom x) = (eN x).comp c := by
      simpa [_root_.Erdos90.h1ConjMap, eN, c] using
        _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog_naturality
          (p := p) (G1 := вҶҘN) (G2 := вҶҘN)
          (f := (MulAut.conjNormal (H := N) gвҒ»В№).toMonoidHom)
          (hf := hcont) x
    have hcomp : ПҮh.comp c = ПҮh := by
      ext n
      change
        ПҮh (Additive.ofMul ((MulAut.conjNormal (H := N) gвҒ»В№) n.toMul)) =
          ПҮh (Additive.ofMul n.toMul)
      exact hПҮinv gвҒ»В№ n.toMul
    rw [hx] at hnat
    apply eN.injective
    calc
      eN ((_root_.Erdos90.h1ConjMap p G N g).hom x) = ПҮh.comp c := hnat
      _ = ПҮh := hcomp
      _ = eN x := hx.symm
  refine вҹЁвҹЁx, hxinvвҹ©, ?_вҹ©
  exact hxhom

theorem quotientCocycle_class_eq_transgression_of_sectionCochain_formula (p : в„•) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (Пү : {Пү : C((G в§ё N) Г— (G в§ё N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G в§ё N) Пү})
    (ПҮ : вҶҘ(_root_.Erdos90.h1NormalInvariantSubmodule p G N))
    (u : C(G в§ё N, ZMod p))
    (hПүu : вҲҖ x y : G в§ё N,
      Пү.1 (x, y) =
        u y - u (x * y) + u x +
          (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
            (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
            (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
            (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN ПҮ.1)) (x, y)) :
    QClass p G N hN Пү = transgression p G N hN ПҮ := by

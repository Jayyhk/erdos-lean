theorem bk_cycles1_eval_mem_BKContsHom (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z : (BKHomogeneousComplex p G N).cycles 1) :
    bk_cycles1_eval p G N z вҲҲ BKContsHomSubmodule p G N := by
  let K := BKHomogeneousComplex p G N
  let rep := Action.trivial вҶҘN (TopModuleCat.of (ZMod p) (ZMod p))
  let cz : C(вҶҘN, C(вҶҘN, ZMod p)) := bk_cycles1_cochain p G N z
  have hhom : вҲҖ x y : вҶҘN, bk_cycles1_eval p G N z (x * y) = bk_cycles1_eval p G N z x + bk_cycles1_eval p G N z y := by
    intro x y
    let w : C(вҶҘN, C(вҶҘN, C(вҶҘN, ZMod p))) := ((K.d 1 2).hom ((K.iCycles 1).hom z)).1
    have hz := congrArg (fun f => f.hom z) (K.iCycles_d 1 2)

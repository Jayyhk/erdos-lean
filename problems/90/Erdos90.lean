  have hN1 : Normal в„ҡ вҶҘK1 := by infer_instance
  have hN2 : Normal в„ҡ вҶҘK2 := by infer_instance
  let M0 : IntermediateField в„ҡ (AlgebraicClosure в„ҡ) := K1 вҠ” K2
  letI : FiniteDimensional в„ҡ M0 := by infer_instance
  letI : NumberField M0 := NumberField.of_module_finite в„ҡ M0

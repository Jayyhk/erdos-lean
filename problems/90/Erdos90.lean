theorem primesCongOneMod3_residueClass_nonprime_partial_sum_sublinear (Оө : в„қ) : 0 < Оө вҶ’ вҲғ XвӮҖ : в„•, вҲҖ X : в„•, XвӮҖ вүӨ X вҶ’
    вҲ‘ n вҲҲ Finset.range X,
      (if n.Prime then 0 else primesCongOneMod3_residueClass n) вүӨ Оө * X := by
  intro hОө
  let a : в„• вҶ’ в„қ := fun n => if n.Prime then 0 else primesCongOneMod3_residueClass n
  let g : в„• вҶ’ в„қ := fun n => a n / n
  let G : в„• вҶ’ в„қ := fun X => вҲ‘ n вҲҲ Finset.range X, g n
  let W : в„• вҶ’ в„қ := fun X => вҲ‘ n вҲҲ Finset.range X, (n : в„қ) * g n
  have hg : Summable g := by
    simpa [g, a] using primesCongOneMod3_residueClass_nonprime_div_summable
  have ha0 : a 0 = 0 := by
    simp [a, primesCongOneMod3_residueClass]
  have hg0 : g 0 = 0 := by
    simp [g, a]
  have ha_mul (n : в„•) (hn : n вү  0) : a n = (n : в„қ) * g n := by
    have hnr : (n : в„қ) вү  0 := by exact_mod_cast hn
    by_cases hp : n.Prime
    В· simp [a, g, hp]
    В· dsimp [g, a]
      simp [hp]
      field_simp [hnr]
  have hA_eq_W (X : в„•) : (вҲ‘ n вҲҲ Finset.range X, a n) = W X := by
    unfold W
    refine Finset.sum_congr rfl ?_
    intro n hn
    by_cases hzero : n = 0
    В· subst hzero
      simp [ha0, hg0]
    В· simpa [hzero] using ha_mul n hzero
  let L : в„қ := вҲ‘' n, g n
  have hG : Filter.Tendsto G Filter.atTop (nhds L) := by
    simpa [G, L] using hg.hasSum.tendsto_sum_nat
  have hGsucc : Filter.Tendsto (fun n : в„• => G (n + 1)) Filter.atTop (nhds L) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).2 hG
  have hcesaro : Filter.Tendsto (fun n : в„• => (n : в„қ)вҒ»В№ * вҲ‘ i вҲҲ Finset.range n, G (i + 1)) Filter.atTop (nhds L) := by
    exact Filter.Tendsto.cesaro hGsucc
  have hden_nat : Filter.Tendsto (fun n : в„• => ((n + 1 : в„•) : в„қ)) Filter.atTop Filter.atTop := by
    simpa [Nat.add_comm] using (Filter.tendsto_add_atTop_iff_nat 1).2 (tendsto_natCast_atTop_atTop : Filter.Tendsto ((вҶ‘) : в„• вҶ’ в„қ) Filter.atTop Filter.atTop)
  have hden : Filter.Tendsto (fun n : в„• => (n : в„қ) + 1) Filter.atTop Filter.atTop := by
    simpa [Nat.cast_add, add_comm, add_left_comm, add_assoc] using hden_nat
  have hterm_div : Filter.Tendsto (fun n : в„• => G (n + 1) / (n + 1)) Filter.atTop (nhds 0) := by
    exact Filter.Tendsto.div_atTop hGsucc hden
  have hpaux : Filter.Tendsto (fun n : в„• => ((n : в„қ) / (n + 1)) * G (n + 1)) Filter.atTop (nhds L) := by
    have hEq : (fun n : в„• => ((n : в„қ) / (n + 1)) * G (n + 1)) = fun n : в„• => G (n + 1) - G (n + 1) / (n + 1) := by
      funext n
      have hne : ((n + 1 : в„•) : в„қ) вү  0 := by positivity
      field_simp [hne]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hGsucc.sub hterm_div
  have hcesaro_shift : Filter.Tendsto (fun n : в„• => ((n + 1 : в„•) : в„қ)вҒ»В№ * вҲ‘ i вҲҲ Finset.range (n + 1), G (i + 1)) Filter.atTop (nhds L) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).2 hcesaro
  have hqaux : Filter.Tendsto (fun n : в„• => (вҲ‘ i вҲҲ Finset.range n, G (i + 1)) / (n + 1)) Filter.atTop (nhds L) := by
    have hEq : (fun n : в„• => (вҲ‘ i вҲҲ Finset.range n, G (i + 1)) / (n + 1)) = fun n : в„• =>
      (((n + 1 : в„•) : в„қ)вҒ»В№ * вҲ‘ i вҲҲ Finset.range (n + 1), G (i + 1)) - G (n + 1) / (n + 1) := by
      funext n
      rw [Finset.sum_range_succ]
      have hne : ((n + 1 : в„•) : в„қ) вү  0 := by positivity
      field_simp [hne]
      norm_num [Nat.cast_add]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hcesaro_shift.sub hterm_div
  have hparts (X : в„•) : W X = ((X - 1 : в„•) : в„қ) * G X - вҲ‘ i вҲҲ Finset.range (X - 1), G (i + 1) := by
    simpa [W, G] using (Finset.sum_range_by_parts (fun n => (n : в„қ)) g X)
  have hWaux : Filter.Tendsto (fun n : в„• => W (n + 1) / (n + 1)) Filter.atTop (nhds 0) := by
    have hEq : (fun n : в„• => W (n + 1) / (n + 1)) = fun n : в„• => ((n : в„қ) / (n + 1)) * G (n + 1) - (вҲ‘ i вҲҲ Finset.range n, G (i + 1)) / (n + 1) := by
      funext n
      rw [hparts (n + 1)]
      have hne : ((n + 1 : в„•) : в„қ) вү  0 := by positivity
      field_simp [hne]
      norm_num [Nat.cast_add]
      ring
    rw [hEq]
    simpa [sub_eq_add_neg] using hpaux.sub hqaux
  have hWdiv : Filter.Tendsto (fun X : в„• => W X / X) Filter.atTop (nhds 0) := by
    exact (Filter.tendsto_add_atTop_iff_nat 1).1 (by simpa using hWaux)
  have h_event : вҲҖб¶  X : в„• in Filter.atTop, W X / X < Оө := by
    exact hWdiv (Iio_mem_nhds hОө)
  rcases Filter.eventually_atTop.1 h_event with вҹЁXвӮҖ, hXвӮҖвҹ©
  refine вҹЁXвӮҖ, ?_вҹ©
  intro X hX
  have hlt : W X / X < Оө := hXвӮҖ X hX
  by_cases hzero : X = 0
  В· subst hzero
    simp [hA_eq_W]
  В· have hXpos : (0 : в„қ) < X := by
      exact_mod_cast Nat.pos_of_ne_zero hzero
    have hmul : W X < Оө * X := (div_lt_iffвӮҖ hXpos).1 hlt
    have : вҲ‘ n вҲҲ Finset.range X, a n < Оө * X := by
      simpa [hA_eq_W X] using hmul
    exact le_of_lt this

theorem primesCongOneMod3_residueClass_prime_div_nonsummable: В¬ Summable fun n : в„• => (if n.Prime then primesCongOneMod3_residueClass n else 0) / n := by

theorem activated_helper_of_old_residue_lift {st : StageState} {b p : ℕ}
    (hp : FreshPrimeData st p)
    (Ω : Finset (ZMod (activatedM st b p)))
    (hchoose : ∀ γ : ZMod (activatedM st b p), ∃ ρ ∈ st.D, ∀ u : ℕ,

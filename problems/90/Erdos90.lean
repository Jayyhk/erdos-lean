  have hDQ_split :
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) =
        (вҲ« t in (0 : в„қ)..X, D t) - (вҲ« t in (0 : в„қ)..X, D t * E t) := by
    calc
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) = вҲ« t in (0 : в„қ)..X, D t * (1 - E t) := hDQ_expand
      _ = вҲ« t in (0 : в„қ)..X, (D t - D t * E t) := by
            apply intervalIntegral.integral_congr
            intro t ht
            ring
      _ = (вҲ« t in (0 : в„қ)..X, D t) - (вҲ« t in (0 : в„қ)..X, D t * E t) := by
            simpa using
              (intervalIntegral.integral_sub (Ој := MeasureTheory.volume) (a := (0 : в„қ)) (b := X)

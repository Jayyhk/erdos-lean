theorem theorem_2_3_rpow_control (C γ δ n : ℝ) (f : ℕ)
    (hC : 1 < C) (hn : 0 < n) (hδpos : 0 < δ)
    (hδ : δ = γ / (8 * Real.log C))
    (hn_upper : n ≤ C ^ (2 * f)) :
    n ^ (2 * δ) ≤ Real.exp ((γ / 2) * f) := by
  have hCpos : 0 < C := lt_trans zero_lt_one hC
  have hlogCpos : 0 < Real.log C := Real.log_pos hC
  have hδ_nonneg : 0 ≤ 2 * δ := by
    positivity
  have hlogn : Real.log n ≤ Real.log (C ^ (2 * f)) := by
    exact Real.log_le_log hn hn_upper
  rw [← Real.rpow_natCast C (2 * f), Real.log_rpow hCpos ((2 * f : ℕ) : ℝ)] at hlogn
  norm_num [Nat.cast_mul] at hlogn
  have hmul : (2 * δ) * Real.log n ≤ (2 * δ) * (((2 : ℝ) * f) * Real.log C) := by
    exact mul_le_mul_of_nonneg_left hlogn hδ_nonneg
  apply (Real.rpow_le_iff_le_log hn (Real.exp_pos _)).2
  rw [Real.log_exp]
  have hcoeff : (2 * δ) * (((2 : ℝ) * f) * Real.log C) = (γ / 2) * f := by
    rw [hδ]
    field_simp [hlogCpos.ne']
    ring
  calc
    (2 * δ) * Real.log n ≤ (2 * δ) * (((2 : ℝ) * f) * Real.log C) := hmul
    _ = (γ / 2) * f := hcoeff

theorem theorem_2_3_large_example (t : ℕ) (q : Fin t → ℕ)
    (𝒟 : ℕ → AdmissibleDatum)
    (sameT : ∀ j, (𝒟 j).t = t)
    (sameQ : ∀ j (b : Fin t),
      (𝒟 j).q (Fin.cast (sameT j).symm b) = q b)
    (H : ℝ) (hH : 0 < H)
    (hClass : ∀ j, (NumberField.classNumber (𝒟 j).K : ℝ) ≤ H ^ (𝒟 j).f)
    (R : ℝ) (hR : 1 / 2 < R)
    (hρ0_pos : 0 < (𝒟 0).ρ R)
    (hρ0 : -(theorem_2_3_gamma t H / 2) < Real.log ((𝒟 0).ρ R))
    (δ : ℝ) (hδpos : 0 < δ)
    (hδ :
      δ = theorem_2_3_gamma t H /
        (8 * Real.log (4 * R * theorem_2_3_denConst t q)))
    (A : ℝ)
    (hA : (2 : ℝ) ^ (1 / δ) ≤ A)
    (j : ℕ)
    (hlarge : A ≤ Real.exp ((theorem_2_3_gamma t H / 2) * (𝒟 j).f)) :
    ∃ n : ℕ, 0 < n ∧ A ≤ (n : ℝ) ∧ (νn n : ℝ) ≥ (n : ℝ) ^ (1 + δ) := by
  set γ : ℝ := theorem_2_3_gamma t H
  set D : ℝ := theorem_2_3_denConst t q
  set C : ℝ := 4 * R * D
  rcases theorem_2_3_example_bounds t q 𝒟 sameT sameQ H hH hClass R hR hρ0_pos hρ0 j with
    ⟨n, hnpos, hExpLe, hn_upper, hν⟩
  have hδ' : δ = γ / (8 * Real.log C) := by
    simpa [γ, D, C] using hδ
  have hlarge' : A ≤ Real.exp ((γ / 2) * (𝒟 j).f) := by
    simpa [γ] using hlarge
  have hExpLe' : Real.exp ((γ / 2) * (𝒟 j).f) ≤ (n : ℝ) := by
    simpa [γ] using hExpLe
  have hn_upper' : (n : ℝ) ≤ C ^ (2 * (𝒟 j).f) := by
    simpa [C, D] using hn_upper
  have hν' : (2 : ℝ) * (νn n : ℝ) ≥ Real.exp ((γ / 2) * (𝒟 j).f) * (n : ℝ) := by
    simpa [γ] using hν
  have hA_le_n : A ≤ (n : ℝ) := le_trans hlarge' hExpLe'
  have hD_one : 1 ≤ D := by
    simpa [D] using theorem_2_3_denConst_one_le t q 𝒟 sameT sameQ
  have hC_gt_one : 1 < C := by
    nlinarith
  have hn_pos_real : 0 < (n : ℝ) := by
    exact_mod_cast hnpos
  have hn_rpow_le : (n : ℝ) ^ (2 * δ) ≤ Real.exp ((γ / 2) * (𝒟 j).f) := by
    exact theorem_2_3_rpow_control C γ δ (n : ℝ) (𝒟 j).f hC_gt_one hn_pos_real hδpos hδ' hn_upper'
  have hexp1 : (1 + 2 * δ : ℝ) = (2 * δ) + 1 := by
    ring
  have hν_ge_pow : (n : ℝ) ^ (1 + 2 * δ) ≤ (2 : ℝ) * (νn n : ℝ) := by
    have hmul : (n : ℝ) ^ (2 * δ) * (n : ℝ) ≤ Real.exp ((γ / 2) * (𝒟 j).f) * (n : ℝ) := by
      exact mul_le_mul_of_nonneg_right hn_rpow_le (by positivity)

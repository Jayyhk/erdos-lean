      constructor
      · rintro ⟨T, hT_admissible, hT_dvd⟩
        refine ⟨T, hT_admissible, ?_⟩
        -- ∏ T ∣ r' from ∏ T ∣ r and r ≡ r' [MOD b], where ∏ T ∣ b.

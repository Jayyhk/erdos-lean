    have hsq : (k : ℝ) ^ (2 : ℕ) ≤ x ^ (2 : ℕ) := by
      nlinarith
    have hratio : (1 : ℝ) ≤ x ^ (2 : ℕ) / (k : ℝ) ^ (2 : ℕ) := by
      have hk_sq_pos : 0 < (k : ℝ) ^ (2 : ℕ) := by
        positivity
      exact (le_div_iff₀ hk_sq_pos).2 (by simpa using hsq)
    calc
      a k = a k * 1 := by ring
      _ ≤ a k * (x ^ (2 : ℕ) / (k : ℝ) ^ (2 : ℕ)) := by
        gcongr
      _ = x ^ (2 : ℕ) * g k := by
        simp [g]
        ring
  have hx2_nonneg : 0 ≤ x ^ (2 : ℕ) := by
    positivity
  calc
    (idealsUpToNormCount K x : ℝ) = ∑ k ∈ Finset.Icc 1 N, a k := hcount_sum
    _ ≤ ∑ k ∈ Finset.Icc 1 N, x ^ (2 : ℕ) * g k := by
      exact Finset.sum_le_sum fun k hk ↦ hterm k hk
    _ = x ^ (2 : ℕ) * ∑ k ∈ Finset.Icc 1 N, g k := by
      rw [Finset.mul_sum]
    _ ≤ x ^ (2 : ℕ) * ∑' n : ℕ, g n := by
      exact mul_le_mul_of_nonneg_left hsum_tsum hx2_nonneg
    _ = dedekindZetaTwoReal K * x ^ (2 : ℕ) := by
      rw [dedekindZetaTwoReal, mul_comm]

noncomputable def dedekindZetaTwoAF
    (K : Type) [Field K] [NumberField K] : ArithmeticFunction ℝ :=
  ⟨fun n ↦ (Nat.card {I : Ideal (𝓞 K) // Ideal.absNorm I = n} : ℝ) /
      (n : ℝ) ^ (2 : ℕ), by
    simp [Ideal.absNorm_eq_zero_iff]⟩

theorem dedekindZetaTwoAF_summable (K : Type) [Field K] [NumberField K] :
    Summable (fun n : ℕ => dedekindZetaTwoAF K n) := by
  let a : ℕ → ℝ := fun n ↦ Nat.card {I : Ideal (𝓞 K) // Ideal.absNorm I = n}
  let c : ℝ :=
    (2 ^ nrRealPlaces K * (2 * Real.pi) ^ nrComplexPlaces K * NumberField.Units.regulator K *
        NumberField.classNumber K) /
      (NumberField.Units.torsionOrder K * Real.sqrt |NumberField.discr K|)
  have hlim₁ :
      Filter.Tendsto ((fun s : ℝ ↦ (idealsUpToNormCount K s : ℝ) / s) ∘ Nat.cast)
        Filter.atTop (nhds c) := by
    simpa [c, idealsUpToNormCount] using
      (NumberField.Ideal.tendsto_norm_le_div_atTop₀ K).comp tendsto_natCast_atTop_atTop
  have hlim₁' :
      Filter.Tendsto (fun n : ℕ ↦ (idealsUpToNormCount K (n : ℝ) : ℝ) / (n : ℝ))
        Filter.atTop (nhds c) := by
    simpa [Function.comp] using hlim₁
  have hEq :
      (fun n : ℕ ↦ (idealsUpToNormCount K (n : ℝ) : ℝ) / (n : ℝ)) =
        fun n : ℕ ↦ (∑ k ∈ Finset.Icc 1 n, a k) / (n : ℝ) := by
    funext n
    rw [idealsUpToNormCount_nat_eq_sum_normFibers]
    simp [a]
  have hlim₂ :
      Filter.Tendsto (fun n : ℕ ↦ (∑ k ∈ Finset.Icc 1 n, a k) / (n : ℝ))
        Filter.atTop (nhds c) := by
    rw [← hEq]
    exact hlim₁'
  have hBigO :
      (fun n : ℕ ↦ ∑ k ∈ Finset.Icc 1 n, a k) =O[Filter.atTop] fun n ↦ (n : ℝ) ^ (1 : ℝ) := by
    exact Asymptotics.isBigO_atTop_natCast_rpow_of_tendsto_div_rpow <| by
      simpa [Real.rpow_natCast] using hlim₂
  have hnonneg : ∀ n : ℕ, 0 ≤ a n := fun n ↦ Nat.cast_nonneg _
  have hL : LSeriesSummable (fun n ↦ a n) ((((3 : ℝ) / 2 : ℝ) : ℂ)) := by
    refine LSeriesSummable_of_sum_norm_bigO_and_nonneg hBigO hnonneg ?_ ?_
    · norm_num
    · norm_num
  have hsumm' : Summable (fun n : ℕ ↦ a n / (n : ℝ) ^ (2 : ℝ)) := by
    refine LSeries.summable_real_of_abscissaOfAbsConv_lt ?_
    exact lt_of_le_of_lt hL.abscissaOfAbsConv_le (by norm_num)
  have hsumm : Summable (fun n : ℕ ↦ a n / (n : ℝ) ^ (2 : ℕ)) := by
    simpa [Real.rpow_natCast] using hsumm'
  simpa [dedekindZetaTwoAF, a] using hsumm

theorem ideal_normFiber_mul_equiv (K : Type) [Field K] [NumberField K] (m n : ℕ) (hcop : m.Coprime n) :
    Nonempty ({I : Ideal (𝓞 K) // Ideal.absNorm I = m * n} ≃
      ({J : Ideal (𝓞 K) // Ideal.absNorm J = m} ×
        {L : Ideal (𝓞 K) // Ideal.absNorm L = n})) := by
  classical
  by_cases hm0 : m = 0
  · have hn1 : n = 1 := by
      simpa [hm0] using hcop
    subst hm0
    subst hn1
    let F : {I : Ideal (𝓞 K) // Ideal.absNorm I = 0 * 1} →
        ({J : Ideal (𝓞 K) // Ideal.absNorm J = 0} × {L : Ideal (𝓞 K) // Ideal.absNorm L = 1}) :=
      fun I => ⟨⟨I.1, by simpa using I.2⟩, ⟨⊤, by simp⟩⟩
    let G : ({J : Ideal (𝓞 K) // Ideal.absNorm J = 0} × {L : Ideal (𝓞 K) // Ideal.absNorm L = 1}) →
        {I : Ideal (𝓞 K) // Ideal.absNorm I = 0 * 1} :=
      fun JL => ⟨JL.1.1, by simpa using JL.1.2⟩
    have hFG : Function.LeftInverse G F := by
      intro I
      apply Subtype.ext
      rfl
    have hGF : Function.RightInverse G F := by
      rintro ⟨J, L⟩
      apply Prod.ext
      · apply Subtype.ext
        rfl
      · apply Subtype.ext
        exact (Ideal.absNorm_eq_one_iff.mp L.2).symm
    exact ⟨⟨F, G, hFG, hGF⟩⟩
  · by_cases hn0 : n = 0
    · have hm1 : m = 1 := by
        simpa [hn0] using hcop
      subst hn0
      subst hm1
      let F : {I : Ideal (𝓞 K) // Ideal.absNorm I = 1 * 0} →
          ({J : Ideal (𝓞 K) // Ideal.absNorm J = 1} × {L : Ideal (𝓞 K) // Ideal.absNorm L = 0}) :=
        fun I => ⟨⟨⊤, by simp⟩, ⟨I.1, by simpa using I.2⟩⟩
      let G : ({J : Ideal (𝓞 K) // Ideal.absNorm J = 1} × {L : Ideal (𝓞 K) // Ideal.absNorm L = 0}) →
          {I : Ideal (𝓞 K) // Ideal.absNorm I = 1 * 0} :=
        fun JL => ⟨JL.2.1, by simpa using JL.2.2⟩
      have hFG : Function.LeftInverse G F := by
        intro I
        apply Subtype.ext
        rfl
      have hGF : Function.RightInverse G F := by
        rintro ⟨J, L⟩
        apply Prod.ext
        · apply Subtype.ext
          exact (Ideal.absNorm_eq_one_iff.mp J.2).symm
        · apply Subtype.ext
          rfl
      exact ⟨⟨F, G, hFG, hGF⟩⟩
    · have helper {A : Ideal (𝓞 K)} (hA0 : Ideal.absNorm A ≠ 0) {t u : ℕ}
          (ht : (t : 𝓞 K) ∈ A) (hcop_tu : t.Coprime u) : (Ideal.absNorm A).Coprime u := by
          have hAfinite : Finite ((𝓞 K) ⧸ A) := (Ideal.absNorm_ne_zero_iff A).mp hA0
          let _ : Fintype ((𝓞 K) ⧸ A) := Fintype.ofFinite ((𝓞 K) ⧸ A)
          refine Nat.coprime_of_dvd fun p hp hpA hpU => ?_
          obtain ⟨x, hxord⟩ := by
            let _ : Fact p.Prime := ⟨hp⟩
            simpa [Nat.card_eq_fintype_card, Ideal.absNorm_apply] using
              (exists_prime_addOrderOf_dvd_card' (G := (𝓞 K) ⧸ A) p hpA)
          rcases (Nat.Coprime.cast (R := 𝓞 K) hcop_tu) with ⟨a, b, hab⟩
          have ht0 : Ideal.Quotient.mk A (t : 𝓞 K) = 0 := Ideal.Quotient.eq_zero_iff_mem.mpr ht
          have hu_inv : Ideal.Quotient.mk A b * (u : (𝓞 K ⧸ A)) = 1 := by
            have hbez := congrArg (Ideal.Quotient.mk A) hab
            simpa [map_add, map_mul, ht0, mul_assoc, mul_comm, mul_left_comm] using hbez
          have hu_zero : u • x = 0 := by
            rw [← addOrderOf_dvd_iff_nsmul_eq_zero, hxord]
            exact hpU
          have hx_zero : x = 0 := by
            have hux : (u : (𝓞 K ⧸ A)) * x = 0 := by
              simpa [nsmul_eq_mul] using hu_zero
            have h1 := congrArg (fun z => Ideal.Quotient.mk A b * z) hux
            have h2 : ((Ideal.Quotient.mk A b * (u : (𝓞 K ⧸ A))) * x) = 0 := by
              simpa [mul_assoc] using h1
            have h3 : (1 : (𝓞 K ⧸ A)) * x = 0 := by simpa [hu_inv] using h2
            simpa using h3
          have : p = 1 := by
            simpa [hx_zero] using hxord.symm
          exact hp.ne_one this
      let M : Ideal (𝓞 K) := Ideal.span ({(m : 𝓞 K)} : Set (𝓞 K))
      let N : Ideal (𝓞 K) := Ideal.span ({(n : 𝓞 K)} : Set (𝓞 K))
      have hMNcop : IsCoprime M N := by
        rw [Ideal.isCoprime_iff_exists]
        rcases (Nat.Coprime.cast (R := 𝓞 K) hcop) with ⟨a, b, hab⟩
        refine ⟨a * m, ?_, b * n, ?_, ?_⟩
        · exact Ideal.mul_mem_left _ _ (Ideal.subset_span (by simp))
        · exact Ideal.mul_mem_left _ _ (Ideal.subset_span (by simp))
        · simpa [mul_assoc, mul_comm, mul_left_comm] using hab
      let F : {I : Ideal (𝓞 K) // Ideal.absNorm I = m * n} →
          ({J : Ideal (𝓞 K) // Ideal.absNorm J = m} ×
            {L : Ideal (𝓞 K) // Ideal.absNorm L = n}) := fun I => by
        let I0 : Ideal (𝓞 K) := I.1
        let J : Ideal (𝓞 K) := I0 ⊔ M
        let L : Ideal (𝓞 K) := I0 ⊔ N
        have hMNtop : M ⊔ N = ⊤ := hMNcop.sup_eq
        have hsup : J ⊔ L = ⊤ := by
          calc
            J ⊔ L = I0 ⊔ (M ⊔ N) := by
              simp [J, L, sup_assoc, sup_left_comm, sup_comm]
            _ = ⊤ := by simp [hMNtop]
        have hmnem : ((m * n : ℕ) : 𝓞 K) ∈ I0 := by
          have hmem : ↑(Ideal.absNorm I0) ∈ I0 := Ideal.absNorm_mem I0
          rw [I.2] at hmem
          simpa [Nat.cast_mul] using hmem
        have hmulle : M * N ≤ I0 := by
          rw [Ideal.span_singleton_mul_span_singleton]
          exact (Ideal.span_singleton_le_iff_mem I0).2 (by simpa [Nat.cast_mul] using hmnem)
        have hmul_le : J * L ≤ I0 := by
          change (I0 ⊔ M) * (I0 ⊔ N) ≤ I0
          rw [Ideal.mul_sup, Ideal.sup_mul, Ideal.sup_mul]
          refine sup_le ?_ ?_
          · refine sup_le ?_ ?_
            · exact Ideal.mul_le_left
            · exact Ideal.mul_le_left
          · refine sup_le ?_ ?_
            · exact Ideal.mul_le_right
            · exact hmulle
        have hIle : I0 ≤ J * L := by
          calc
            I0 = I0 * ⊤ := by rw [Ideal.mul_top]
            _ = I0 * (J ⊔ L) := by rw [hsup]
            _ = I0 * J ⊔ I0 * L := by rw [Ideal.mul_sup]
            _ ≤ J * L := by
              refine sup_le ?_ ?_
              · have h1 : I0 * J ≤ L * J := Ideal.mul_mono_left (K := J) (show I0 ≤ L by exact le_sup_left)
                simpa [Ideal.mul_comm] using h1
              · have h2 : I0 * L ≤ J * L := Ideal.mul_mono_left (K := L) (show I0 ≤ J by exact le_sup_left)
                simpa using h2
        have hmul : J * L = I0 := le_antisymm hmul_le hIle
        have hnorm_mul : Ideal.absNorm J * Ideal.absNorm L = m * n := by
          calc
            Ideal.absNorm J * Ideal.absNorm L = Ideal.absNorm (J * L) := by rw [map_mul]
            _ = m * n := by rw [hmul, I.2]
        have hJ0 : Ideal.absNorm J ≠ 0 := by
          intro h0
          rw [h0, zero_mul] at hnorm_mul
          exact (Nat.mul_ne_zero hm0 hn0) hnorm_mul.symm
        have hL0 : Ideal.absNorm L ≠ 0 := by
          intro h0
          rw [h0, mul_zero] at hnorm_mul
          exact (Nat.mul_ne_zero hm0 hn0) hnorm_mul.symm
        have hm_mem_J : (m : 𝓞 K) ∈ J := by
          exact (show M ≤ J from le_sup_right) (Ideal.subset_span (by simp))
        have hn_mem_L : (n : 𝓞 K) ∈ L := by
          exact (show N ≤ L from le_sup_right) (Ideal.subset_span (by simp))
        have hJcop : (Ideal.absNorm J).Coprime n := helper hJ0 hm_mem_J hcop
        have hLcop : (Ideal.absNorm L).Coprime m := helper hL0 hn_mem_L hcop.symm
        have hJdvdm : Ideal.absNorm J ∣ m := by
          apply hJcop.dvd_of_dvd_mul_right
          rw [← hnorm_mul]
          exact dvd_mul_of_dvd_left (dvd_refl _) _
        have hLdvdn : Ideal.absNorm L ∣ n := by
          apply hLcop.dvd_of_dvd_mul_left
          rw [← hnorm_mul]
          exact dvd_mul_of_dvd_right (dvd_refl _) _
        have hJle : Ideal.absNorm J ≤ m := Nat.le_of_dvd (Nat.pos_of_ne_zero hm0) hJdvdm
        have hLle : Ideal.absNorm L ≤ n := Nat.le_of_dvd (Nat.pos_of_ne_zero hn0) hLdvdn
        have hJL : Ideal.absNorm J = m ∧ Ideal.absNorm L = n :=
          (mul_eq_mul_iff_eq_and_eq_of_pos' hJle hLle (Nat.pos_of_ne_zero hm0) (Nat.pos_of_ne_zero hL0)).mp hnorm_mul
        exact ⟨⟨J, hJL.1⟩, ⟨L, hJL.2⟩⟩
      let G : ({J : Ideal (𝓞 K) // Ideal.absNorm J = m} × {L : Ideal (𝓞 K) // Ideal.absNorm L = n}) →
          {I : Ideal (𝓞 K) // Ideal.absNorm I = m * n} := fun JL => by
        exact ⟨JL.1.1 * JL.2.1, by rw [map_mul, JL.1.2, JL.2.2]⟩
      have hFG : Function.LeftInverse G F := by
        intro I
        let I0 : Ideal (𝓞 K) := I.1
        let J : Ideal (𝓞 K) := I0 ⊔ M
        let L : Ideal (𝓞 K) := I0 ⊔ N
        have hMNtop : M ⊔ N = ⊤ := hMNcop.sup_eq
        have hsup : J ⊔ L = ⊤ := by
          calc
            J ⊔ L = I0 ⊔ (M ⊔ N) := by
              simp [J, L, sup_assoc, sup_left_comm, sup_comm]
            _ = ⊤ := by simp [hMNtop]
        have hmnem : ((m * n : ℕ) : 𝓞 K) ∈ I0 := by
          have hmem : ↑(Ideal.absNorm I0) ∈ I0 := Ideal.absNorm_mem I0
          rw [I.2] at hmem
          simpa [Nat.cast_mul] using hmem
        have hmulle : M * N ≤ I0 := by
          rw [Ideal.span_singleton_mul_span_singleton]
          exact (Ideal.span_singleton_le_iff_mem I0).2 (by simpa [Nat.cast_mul] using hmnem)
        have hmul_le : J * L ≤ I0 := by
          change (I0 ⊔ M) * (I0 ⊔ N) ≤ I0
          rw [Ideal.mul_sup, Ideal.sup_mul, Ideal.sup_mul]
          refine sup_le ?_ ?_
          · refine sup_le ?_ ?_
            · exact Ideal.mul_le_left
            · exact Ideal.mul_le_left
          · refine sup_le ?_ ?_
            · exact Ideal.mul_le_right
            · exact hmulle
        have hIle : I0 ≤ J * L := by
          calc
            I0 = I0 * ⊤ := by rw [Ideal.mul_top]
            _ = I0 * (J ⊔ L) := by rw [hsup]
            _ = I0 * J ⊔ I0 * L := by rw [Ideal.mul_sup]
            _ ≤ J * L := by
              refine sup_le ?_ ?_
              · have h1 : I0 * J ≤ L * J := Ideal.mul_mono_left (K := J) (show I0 ≤ L by exact le_sup_left)
                simpa [Ideal.mul_comm] using h1
              · have h2 : I0 * L ≤ J * L := Ideal.mul_mono_left (K := L) (show I0 ≤ J by exact le_sup_left)
                simpa using h2
        have hmul : J * L = I0 := le_antisymm hmul_le hIle
        apply Subtype.ext
        simpa [F, G, I0, J, L]
      have hGF : Function.RightInverse G F := by
        intro JL
        rcases JL with ⟨⟨J0, hJ0n⟩, ⟨L0, hL0n⟩⟩
        have hm_mem_J0 : (m : 𝓞 K) ∈ J0 := by
          have hmem : ↑(Ideal.absNorm J0) ∈ J0 := Ideal.absNorm_mem J0
          rw [hJ0n] at hmem
          simpa using hmem
        have hn_mem_L0 : (n : 𝓞 K) ∈ L0 := by
          have hmem : ↑(Ideal.absNorm L0) ∈ L0 := Ideal.absNorm_mem L0
          rw [hL0n] at hmem
          simpa using hmem
        have hsupnorm : Ideal.absNorm (J0 ⊔ L0) = 1 := by
          have hdivm : Ideal.absNorm (J0 ⊔ L0) ∣ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 ≤ J0 ⊔ L0 by exact le_sup_left)
          have hdivn : Ideal.absNorm (J0 ⊔ L0) ∣ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 ≤ J0 ⊔ L0 by exact le_sup_right)
          have hdiv1 : Ideal.absNorm (J0 ⊔ L0) ∣ 1 := by
            rw [← hcop.gcd_eq_one]
            exact Nat.dvd_gcd hdivm hdivn
          exact Nat.dvd_one.mp hdiv1
        have hJLcop : IsCoprime J0 L0 := Ideal.isCoprime_iff_sup_eq.mpr (Ideal.absNorm_eq_one_iff.mp hsupnorm)
        have hMleJ0 : M ≤ J0 := (Ideal.span_singleton_le_iff_mem J0).2 hm_mem_J0
        have hNleL0 : N ≤ L0 := (Ideal.span_singleton_le_iff_mem L0).2 hn_mem_L0
        have hLM0 : Ideal.absNorm (L0 ⊔ M) ≠ 0 := by
          intro h0
          have hdiv : Ideal.absNorm (L0 ⊔ M) ∣ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 ≤ L0 ⊔ M by exact le_sup_left)
          rw [h0] at hdiv
          exact hn0 (Nat.zero_dvd.mp hdiv)
        have hJN0 : Ideal.absNorm (J0 ⊔ N) ≠ 0 := by
          intro h0
          have hdiv : Ideal.absNorm (J0 ⊔ N) ∣ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 ≤ J0 ⊔ N by exact le_sup_left)
          rw [h0] at hdiv
          exact hm0 (Nat.zero_dvd.mp hdiv)
        have hLMcop : (Ideal.absNorm (L0 ⊔ M)).Coprime n := by
          have hm_mem : (m : 𝓞 K) ∈ L0 ⊔ M := (show M ≤ L0 ⊔ M from le_sup_right) (Ideal.subset_span (by simp))
          exact helper hLM0 hm_mem hcop
        have hJNcop : (Ideal.absNorm (J0 ⊔ N)).Coprime m := by
          have hn_mem : (n : 𝓞 K) ∈ J0 ⊔ N := (show N ≤ J0 ⊔ N from le_sup_right) (Ideal.subset_span (by simp))
          exact helper hJN0 hn_mem hcop.symm
        have hLMtop : L0 ⊔ M = ⊤ := by
          have hdiv : Ideal.absNorm (L0 ⊔ M) ∣ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 ≤ L0 ⊔ M by exact le_sup_left)
          have hdiv1 : Ideal.absNorm (L0 ⊔ M) ∣ 1 := by
            rw [← hLMcop.gcd_eq_one]
            exact Nat.dvd_gcd dvd_rfl hdiv
          exact Ideal.absNorm_eq_one_iff.mp (Nat.dvd_one.mp hdiv1)
        have hJNtop : J0 ⊔ N = ⊤ := by
          have hdiv : Ideal.absNorm (J0 ⊔ N) ∣ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 ≤ J0 ⊔ N by exact le_sup_left)
          have hdiv1 : Ideal.absNorm (J0 ⊔ N) ∣ 1 := by
            rw [← hJNcop.gcd_eq_one]
            exact Nat.dvd_gcd dvd_rfl hdiv
          exact Ideal.absNorm_eq_one_iff.mp (Nat.dvd_one.mp hdiv1)
        have hJM : (J0 * L0) ⊔ M = J0 := by
          calc
            (J0 * L0) ⊔ M = M ⊔ J0 * L0 := by rw [sup_comm]
            _ = M ⊔ J0 := by
              simpa [Ideal.mul_comm] using (Ideal.sup_mul_eq_of_coprime_right (I := M) (J := J0) (K := L0) (by simpa [sup_comm] using hLMtop))
            _ = J0 := sup_eq_right.mpr hMleJ0
        have hLN : (J0 * L0) ⊔ N = L0 := by
          calc
            (J0 * L0) ⊔ N = N ⊔ J0 * L0 := by rw [sup_comm]
            _ = N ⊔ L0 := by
              simpa [Ideal.mul_comm] using (Ideal.sup_mul_eq_of_coprime_left (I := N) (J := J0) (K := L0) (by simpa [sup_comm] using hJNtop))
            _ = L0 := sup_eq_right.mpr hNleL0
        apply Prod.ext
        · apply Subtype.ext
          simpa [F, G, M, N] using hJM
        · apply Subtype.ext
          simpa [F, G, M, N] using hLN
      exact ⟨⟨F, G, hFG, hGF⟩⟩

theorem dedekindZetaTwoAF_isMultiplicative (K : Type) [Field K] [NumberField K] :
    (dedekindZetaTwoAF K).IsMultiplicative := by
  classical
  refine ArithmeticFunction.IsMultiplicative.iff_ne_zero.2 ?_
  constructor
  · simp [dedekindZetaTwoAF, Ideal.absNorm_eq_one_iff]
  · intro m n hm hn hcop
    obtain ⟨e⟩ := ideal_normFiber_mul_equiv K m n hcop
    have hcard := Nat.card_congr e
    rw [Nat.card_prod] at hcard
    dsimp [dedekindZetaTwoAF]
    rw [hcard, Nat.cast_mul, Nat.cast_mul]
    have hpow : ((m : ℝ) * (n : ℝ)) ^ (2 : ℕ) = (m : ℝ) ^ (2 : ℕ) * (n : ℝ) ^ (2 : ℕ) := by
      simpa using (mul_pow (m : ℝ) (n : ℝ) (2 : ℕ))
    rw [hpow]
    have hmR : (m : ℝ) ^ (2 : ℕ) ≠ 0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr hm)
    have hnR : (n : ℝ) ^ (2 : ℕ) ≠ 0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr hn)
    rw [div_eq_mul_inv, div_eq_mul_inv, div_eq_mul_inv]
    field_simp [hmR, hnR]

theorem normalizedFactor_mem_primesOverFinset_of_absNorm_eq_primePow (K : Type) [Field K] [NumberField K] (p : ℕ) (hp : p.Prime)
    {I P : Ideal (𝓞 K)} {e : ℕ}
    (hI : Ideal.absNorm I = p ^ e) (hP : P ∈ normalizedFactors I) :
    P ∈ primesOverFinset (Ideal.span ({(p : ℤ)} : Set ℤ)) (𝓞 K) := by
  classical
  let pp : Ideal ℤ := Ideal.span ({(p : ℤ)} : Set ℤ)
  have hIabs0 : Ideal.absNorm I ≠ 0 := by
    rw [hI]
    exact pow_ne_zero _ hp.ne_zero
  have hI0 : I ≠ ⊥ := by
    intro hbot
    apply hIabs0
    simp [hbot]
  rcases (Ideal.mem_normalizedFactors_iff hI0).1 hP with ⟨hPprime, hIP⟩
  have hP0 : P ≠ (0 : Ideal (𝓞 K)) := UniqueFactorizationMonoid.ne_zero_of_mem_normalizedFactors hP
  let q : ℕ := Ideal.absNorm (Ideal.under ℤ P)
  have hqprime : q.Prime := by
    letI : P.IsPrime := hPprime
    letI : NeZero P := ⟨hP0⟩
    dsimp [q]
    simpa using Nat.absNorm_under_prime P
  have hqdvdIunder : q ∣ Ideal.absNorm (Ideal.under ℤ I) := by
    dsimp [q]
    exact Ideal.absNorm_dvd_absNorm_of_le (Ideal.comap_mono hIP)
  have hIunderdvd : Ideal.absNorm (Ideal.under ℤ I) ∣ Ideal.absNorm I :=
    Int.absNorm_under_dvd_absNorm I
  have hqdpowe : q ∣ p ^ e := by
    have hqdnormI : q ∣ Ideal.absNorm I := dvd_trans hqdvdIunder hIunderdvd
    simpa [hI] using hqdnormI
  have hqp : q = p := Nat.prime_eq_prime_of_dvd_pow hqprime hp hqdpowe
  have hL : P.LiesOver pp := by
    letI : P.LiesOver (Ideal.span ({(q : ℤ)} : Set ℤ)) := by
      simpa [q] using (Int.liesOver_span_absNorm (I := P))
    have hUnder : Ideal.span ({(q : ℤ)} : Set ℤ) = Ideal.under ℤ P :=
      Ideal.over_def (A := ℤ) (P := P) (p := Ideal.span ({(q : ℤ)} : Set ℤ))
    refine ⟨?_⟩
    simpa [pp, hqp] using hUnder
  have hpp_ne_bot : pp ≠ ⊥ := by
    dsimp [pp]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  letI : Fact p.Prime := ⟨hp⟩
  haveI : pp.IsMaximal := by
    simpa [pp] using (Int.ideal_span_isMaximal_of_prime p)
  rw [mem_primesOverFinset_iff (B := 𝓞 K) hpp_ne_bot]
  change P.IsPrime ∧ P.LiesOver pp
  exact ⟨hPprime, hL⟩

theorem summable_pi_inverse_square_prime {α : Type*} (s : Finset α) (p : ℕ) (hp : p.Prime) :
    Summable (fun ν : (s → ℕ) => (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹) := by
  classical
  let a : ℝ := ((p : ℝ) ^ (2 : ℕ))⁻¹
  have ha0 : 0 ≤ a := by
    dsimp [a]
    positivity
  have hp1 : (1 : ℝ) < p := by
    exact_mod_cast hp.one_lt
  have hpow : 1 < (p : ℝ) ^ (2 : ℕ) := by
    nlinarith
  have ha1 : a < 1 := by
    dsimp [a]
    simpa using (inv_lt_one_of_one_lt₀ hpow)
  let f : (s → ℕ) → ℝ := fun ν => ∏ i, a ^ ν i
  have hf_eq : (fun ν : (s → ℕ) => (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹) = f := by
    funext ν
    simp [f, a, inv_pow]
  rw [hf_eq]
  have hf_nonneg : ∀ ν : s → ℕ, 0 ≤ f ν := by
    intro ν
    exact Finset.prod_nonneg fun i hi => pow_nonneg ha0 _
  refine summable_of_sum_le (c := ∏ i : s, (1 - a)⁻¹) hf_nonneg ?_
  intro u
  let t : s → Finset ℕ := fun i => u.image fun ν : s → ℕ => ν i
  have hsubset : u ⊆ Fintype.piFinset t := by
    intro ν hν
    rw [Fintype.mem_piFinset]
    intro i
    exact Finset.mem_image_of_mem (fun ν : s → ℕ => ν i) hν
  have hsum_le : ∀ i : s, ∑ k ∈ t i, a ^ k ≤ (1 - a)⁻¹ := by
    intro i
    exact sum_le_hasSum (t i) (fun k hk => pow_nonneg ha0 k) (hasSum_geometric_of_lt_one ha0 ha1)
  calc
    ∑ ν ∈ u, f ν ≤ ∑ ν ∈ Fintype.piFinset t, f ν := by
      exact Finset.sum_le_sum_of_subset_of_nonneg hsubset (fun ν hν1 hν2 => hf_nonneg ν)
    _ = ∏ i, ∑ k ∈ t i, a ^ k := by
      simp [f]
      symm
      exact Finset.prod_univ_sum t (fun i k => a ^ k)
    _ ≤ ∏ i : s, (1 - a)⁻¹ := by
      refine Finset.prod_le_prod ?_ ?_
      · intro i hi
        exact Finset.sum_nonneg fun k hk => pow_nonneg ha0 _
      · intro i hi
        exact hsum_le i

theorem sigma_weight_summable_le_tuple (K : Type) [Field K] [NumberField K] (p : ℕ) (hp : p.Prime) :
    let pp : Ideal ℤ := Ideal.span ({(p : ℤ)} : Set ℤ)
    let β : ℕ → Type := fun e => { I : Ideal (𝓞 K) // Ideal.absNorm I = p ^ e }
    let s : Finset (Ideal (𝓞 K)) := primesOverFinset pp (𝓞 K)
    Summable (fun x : Sigma β => 1 / ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ))) ∧
      ∑' x : Sigma β, 1 / ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ)) ≤
        ∑' ν : (s → ℕ), (∏ P, ((((p : ℝ) ^ (2 : ℕ)) ^ ν P)))⁻¹ := by
  classical
  dsimp
  let pp : Ideal ℤ := Ideal.span ({(p : ℤ)} : Set ℤ)
  let β : ℕ → Type := fun e => { I : Ideal (𝓞 K) // Ideal.absNorm I = p ^ e }
  let s : Finset (Ideal (𝓞 K)) := primesOverFinset pp (𝓞 K)
  let weight : Sigma β → ℝ := fun x => 1 / ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ))
  let g : (s → ℕ) → ℝ := fun ν => (∏ P, ((((p : ℝ) ^ (2 : ℕ)) ^ ν P)))⁻¹
  let encode : Sigma β → (s → ℕ) := fun x P => Multiset.count P.1 (normalizedFactors x.2.1)
  have hsigma_of_ideal_eq : ∀ {x y : Sigma β}, x.2.1 = y.2.1 → x = y := by
    intro x y hI
    refine Sigma.subtype_ext ?_ ?_
    · exact (Nat.pow_right_injective hp.two_le) (by simpa [x.2.2, y.2.2] using congrArg Ideal.absNorm hI)
    · exact hI
  have hweight_nonneg : ∀ x : Sigma β, 0 ≤ weight x := by
    intro x
    positivity
  have hg_nonneg : ∀ ν : (s → ℕ), 0 ≤ g ν := by
    intro ν
    positivity
  have hg : Summable g := by
    simpa [g] using summable_pi_inverse_square_prime s p hp
  have hencode_support : ∀ (x : Sigma β) {P : Ideal (𝓞 K)}, P ∈ normalizedFactors x.2.1 → P ∈ s := by
    intro x P hP
    exact normalizedFactor_mem_primesOverFinset_of_absNorm_eq_primePow K p hp x.2.2 hP
  have hnot_bot : ∀ x : Sigma β, x.2.1 ≠ ⊥ := by
    intro x
    have hpos : 0 < Ideal.absNorm x.2.1 := by simpa [x.2.2] using pow_pos hp.pos x.1
    intro hxbot
    simpa [hxbot] using hpos.ne'
  have hpp0 : pp ≠ ⊥ := by
    refine mt (Ideal.span_singleton_eq_bot.mp) ?_
    exact_mod_cast hp.ne_zero
  letI : Fact p.Prime := ⟨hp⟩
  letI : pp.IsMaximal := by
    simpa [pp] using (Int.ideal_span_isMaximal_of_prime p)
  have hnorm_ge_p : ∀ {P : Ideal (𝓞 K)}, P ∈ s → (p : ℝ) ≤ Ideal.absNorm P := by
    intro P hP
    have hP' : P ∈ Ideal.primesOver pp (𝓞 K) := (mem_primesOverFinset_iff (p := pp) (hpb := hpp0) (B := 𝓞 K)).1 hP
    let Q : Ideal.primesOver pp (𝓞 K) := ⟨P, hP'⟩
    letI : P.LiesOver pp := Q.2.2
    have hpow : Ideal.absNorm P = p ^ (pp.inertiaDeg P) := Ideal.absNorm_eq_pow_inertiaDeg' (P := P) hp
    have hpos : 0 < pp.inertiaDeg P := Ideal.inertiaDeg_pos (p := pp) (P := P)
    have hone : 1 ≤ pp.inertiaDeg P := Nat.succ_le_of_lt hpos
    have hge_nat : p ≤ Ideal.absNorm P := by
      rw [hpow]
      simpa [pow_one] using (pow_le_pow_right' hp.one_lt.le hone)
    exact_mod_cast hge_nat
  have hencode_inj : Function.Injective encode := by
    intro x y hxy
    apply hsigma_of_ideal_eq
    have hnf : normalizedFactors x.2.1 = normalizedFactors y.2.1 := by
      apply (Multiset.ext).2
      intro P
      by_cases hP : P ∈ s
      · have := congrArg (fun ν => ν ⟨P, hP⟩) hxy
        simpa [encode] using this
      · have hx0 : Multiset.count P (normalizedFactors x.2.1) = 0 := by
          apply Multiset.count_eq_zero_of_notMem
          intro hxP
          exact hP (hencode_support x hxP)
        have hy0 : Multiset.count P (normalizedFactors y.2.1) = 0 := by
          apply Multiset.count_eq_zero_of_notMem
          intro hyP
          exact hP (hencode_support y hyP)
        rw [hx0, hy0]
    calc
      x.2.1 = (normalizedFactors x.2.1).prod := (prod_normalizedFactors_eq_self (hnot_bot x)).symm
      _ = (normalizedFactors y.2.1).prod := by simp [hnf]
      _ = y.2.1 := prod_normalizedFactors_eq_self (hnot_bot y)
  have hcomp : Summable (g ∘ encode) := by
    exact hg.comp_injective hencode_inj
  have hpoint : ∀ x : Sigma β, weight x ≤ g (encode x) := by
    intro x
    let m : Multiset (Ideal (𝓞 K)) := normalizedFactors x.2.1
    have hs : m.toFinset ⊆ s := by
      intro P hP
      exact hencode_support x (by simpa [m] using hP)
    have hnorm_prod : (Ideal.absNorm x.2.1 : ℝ) = ∏ P ∈ s, (Ideal.absNorm P : ℝ) ^ m.count P := by
      calc
        (Ideal.absNorm x.2.1 : ℝ) = (Ideal.absNorm m.prod : ℝ) := by
          simpa [m] using congrArg (fun I : Ideal (𝓞 K) => (Ideal.absNorm I : ℝ)) ((prod_normalizedFactors_eq_self (hnot_bot x)).symm)
        _ = ∏ P ∈ s, (Ideal.absNorm P : ℝ) ^ m.count P := by
          rw [show m.prod = ∏ P ∈ s, P ^ m.count P by exact Finset.prod_multiset_count_of_subset m s hs]
          simp
    have hprod_le : ∏ P ∈ s, (p : ℝ) ^ m.count P ≤ (Ideal.absNorm x.2.1 : ℝ) := by
      rw [hnorm_prod]
      refine Finset.prod_le_prod ?_ ?_
      · intro P hP
        positivity
      · intro P hP
        exact pow_le_pow_left₀ (by positivity) (hnorm_ge_p hP) _
    have h1 :
        ∏ P : s, (((p : ℝ) ^ (2 : ℕ)) ^ encode x P) = ∏ P ∈ s.attach, (((p : ℝ) ^ (2 : ℕ)) ^ m.count P.1) := by
      simp [encode, m]
    have hmid :
        ∏ P ∈ s.attach, (((p : ℝ) ^ (2 : ℕ)) ^ m.count P.1) = ∏ P ∈ s.attach, (((p : ℝ) ^ m.count P.1) ^ (2 : ℕ)) := by
      refine Finset.prod_congr rfl ?_
      intro P hP
      rw [← pow_mul, ← pow_mul, Nat.mul_comm]
    have h2 :
        (∏ P ∈ s.attach, ((p : ℝ) ^ m.count P.1)) ^ (2 : ℕ) = (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := by
      have hattach : ∏ P ∈ s.attach, ((p : ℝ) ^ m.count P.1) = ∏ P ∈ s, (p : ℝ) ^ m.count P := by
        simpa using (Finset.prod_attach (s := s) (f := fun P => ((p : ℝ) ^ m.count P)))
      exact congrArg (fun t : ℝ => t ^ (2 : ℕ)) hattach
    have hg_den : ∏ P : s, (((p : ℝ) ^ (2 : ℕ)) ^ encode x P) = (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := by
      calc
        ∏ P : s, (((p : ℝ) ^ (2 : ℕ)) ^ encode x P) = ∏ P ∈ s.attach, (((p : ℝ) ^ (2 : ℕ)) ^ m.count P.1) := h1
        _ = ∏ P ∈ s.attach, (((p : ℝ) ^ m.count P.1) ^ (2 : ℕ)) := hmid
        _ = (∏ P ∈ s.attach, ((p : ℝ) ^ m.count P.1)) ^ (2 : ℕ) := by
          simpa using (Finset.prod_pow s.attach (2 : ℕ) (fun P => (p : ℝ) ^ m.count P.1))
        _ = (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := h2
    have hg_eq : g (encode x) = 1 / (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := by
      simpa [g, one_div] using congrArg Inv.inv hg_den
    have hsq : (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) ≤ ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ)) := by
      exact pow_le_pow_left₀ (by positivity) hprod_le _
    have hprod_pos : 0 < ∏ P ∈ s, (p : ℝ) ^ m.count P := by
      refine Finset.prod_pos ?_
      intro P hP
      exact pow_pos (by exact_mod_cast hp.pos) _
    have hpos : 0 < (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := by
      exact pow_pos hprod_pos _
    calc
      weight x = 1 / ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ)) := by rfl
      _ ≤ 1 / (∏ P ∈ s, (p : ℝ) ^ m.count P) ^ (2 : ℕ) := by
        exact one_div_le_one_div_of_le hpos hsq
      _ = g (encode x) := by rw [hg_eq]
  have hweight : Summable weight := by
    exact Summable.of_nonneg_of_le hweight_nonneg hpoint hcomp
  have htsum_le_comp : ∑' x : Sigma β, weight x ≤ ∑' x : Sigma β, g (encode x) := by
    refine Real.tsum_le_of_sum_le hweight_nonneg ?_
    intro u
    refine le_trans (show ∑ x ∈ u, weight x ≤ ∑ x ∈ u, g (encode x) by
      exact Finset.sum_le_sum (fun x hx => hpoint x)) ?_
    exact hcomp.sum_le_tsum u (by
      intro x hx
      exact hg_nonneg _)
  refine ⟨?_, ?_⟩
  · simpa [weight] using hweight
  · exact le_trans htsum_le_comp (by
      simpa [Function.comp, g] using (tsum_comp_le_tsum_of_inj hg hg_nonneg hencode_inj))

theorem tsum_pi_inverse_square_prime_le {α : Type*} (s : Finset α) (p : ℕ) (hp : p.Prime) (n : ℕ) (hcard : s.card ≤ n) :
    ∑' ν : (s → ℕ), (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹ ≤
      ((1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹) ^ n := by
  classical
  let a : ℝ := ((p : ℝ) ^ (2 : ℕ))⁻¹
  let B : ℝ := (1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹
  have hp1 : (1 : ℝ) < p := by
    exact_mod_cast hp.one_lt
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    positivity
  have hp_sq_gt_one : (1 : ℝ) < (p : ℝ) ^ (2 : ℕ) := by
    nlinarith [hp1]
  have ha_lt_one : a < 1 := by
    dsimp [a]
    simpa using (inv_lt_one_of_one_lt₀ hp_sq_gt_one)
  have hB_eq : (1 - a)⁻¹ = B := by
    dsimp [B, a]
    simp [Real.rpow_natCast]
    rfl
  have hgeom : ∑' k : ℕ, a ^ k = B := by
    exact (tsum_geometric_of_lt_one ha_nonneg ha_lt_one).trans hB_eq
  have hB_ge_one : 1 ≤ B := by
    rw [← hB_eq, one_le_inv_iff₀]
    constructor
    · exact sub_pos.mpr ha_lt_one
    · linarith
  have h_nonneg : 0 ≤ fun ν : s → ℕ => (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹ := by
    intro ν
    positivity
  have hscard :
      ∑' ν : s → ℕ, (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹ ≤ B ^ s.card := by
    refine Real.tsum_le_of_sum_le h_nonneg ?_
    intro u
    let t : s → Finset ℕ := fun i => u.image fun ν : s → ℕ => ν i
    have hu : u ⊆ Fintype.piFinset t := by
      intro ν hν
      rw [Fintype.mem_piFinset]
      intro i
      exact Finset.mem_image.mpr ⟨ν, hν, rfl⟩
    calc
      ∑ ν ∈ u, (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹
          = ∑ ν ∈ u, ∏ i, a ^ ν i := by
              refine Finset.sum_congr rfl ?_
              intro ν hν
              simp [a, inv_pow]
      _ ≤ ∑ ν ∈ Fintype.piFinset t, ∏ i, a ^ ν i := by
            exact Finset.sum_le_sum_of_subset_of_nonneg hu (by
              intro ν hν hnu
              positivity)
      _ = ∏ i, ∑ k ∈ t i, a ^ k := by
            symm
            exact Finset.prod_univ_sum t (fun i k => a ^ k)
      _ ≤ ∏ i : s, B := by
            simpa using Finset.prod_le_prod
              (s := Finset.univ)
              (f := fun i : s => ∑ k ∈ t i, a ^ k)
              (g := fun _ : s => B)
              (fun i hi => Finset.sum_nonneg fun k hk => by positivity)
              (fun i hi => by
                exact (sum_le_hasSum (t i) (fun k hk => by positivity)
                  (hasSum_geometric_of_lt_one ha_nonneg ha_lt_one)).trans_eq hB_eq)
      _ = B ^ s.card := by
            simp [B]
  calc
    ∑' ν : s → ℕ, (∏ i, ((((p : ℝ) ^ (2 : ℕ)) ^ ν i)))⁻¹ ≤ B ^ s.card := hscard
    _ ≤ B ^ n := pow_le_pow_right₀ hB_ge_one hcard
    _ = ((1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹) ^ n := by rfl

theorem dedekindZetaTwoAF_prime_localFactor_le (K : Type) [Field K] [NumberField K] (p : ℕ) (hp : p.Prime) :
    ∑' e : ℕ, dedekindZetaTwoAF K (p ^ e) ≤
      ((1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹) ^ Module.finrank ℚ K := by
  classical
  let pp : Ideal ℤ := Ideal.span ({(p : ℤ)} : Set ℤ)
  let β : ℕ → Type := fun e => { I : Ideal (𝓞 K) // Ideal.absNorm I = p ^ e }
  let w : Sigma β → ℝ := fun x => 1 / ((Ideal.absNorm x.2.1 : ℝ) ^ (2 : ℕ))
  let s : Finset (Ideal (𝓞 K)) := primesOverFinset pp (𝓞 K)
  letI : Fact p.Prime := ⟨hp⟩
  letI : pp.IsMaximal := by
    dsimp [pp]
    infer_instance
  have hpp0 : pp ≠ ⊥ := by
    dsimp [pp]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  have hfiber (e : ℕ) : HasSum (fun I : β e => w ⟨e, I⟩) (dedekindZetaTwoAF K (p ^ e)) := by
    classical
    letI : Fintype (β e) := (Ideal.finite_setOf_absNorm_eq (S := 𝓞 K) (p ^ e)).fintype
    have hsum : ∑ I : β e, w ⟨e, I⟩ = dedekindZetaTwoAF K (p ^ e) := by
      calc
        ∑ I : β e, w ⟨e, I⟩ = ∑ I : β e, 1 / (((p ^ e : ℕ) : ℝ) ^ (2 : ℕ)) := by
          refine Finset.sum_congr rfl ?_
          intro I hI
          dsimp [w, β]
          rw [I.2]
        _ = (Fintype.card (β e) : ℝ) * (1 / (((p ^ e : ℕ) : ℝ) ^ (2 : ℕ))) := by
          simp
        _ = dedekindZetaTwoAF K (p ^ e) := by
          dsimp [dedekindZetaTwoAF, β]
          rw [Nat.card_eq_fintype_card]
          simp [div_eq_mul_inv]
    simpa [hsum] using (hasSum_fintype (fun I : β e => w ⟨e, I⟩))
  rcases sigma_weight_summable_le_tuple K p hp with ⟨hw, hle⟩
  have htsum : ∑' e : ℕ, dedekindZetaTwoAF K (p ^ e) = ∑' x : Sigma β, w x := by
    exact (hw.hasSum.sigma hfiber).tsum_eq
  rw [htsum]
  refine le_trans hle ?_
  have hcard : s.card ≤ Module.finrank ℚ K := by
    simpa only [s] using
      (Ideal.card_primesOverFinset_le_finrank (S := 𝓞 K) (K := ℚ) (L := K) (p := pp) hpp0)
  exact tsum_pi_inverse_square_prime_le s p hp (Module.finrank ℚ K) hcard

theorem prime_geometric_tprod_eq_pi_sq_div_six : ∏' p : Nat.Primes, (1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹ = (Real.pi ^ (2 : ℕ)) / 6 := by
  let f : ℕ →*₀ ℝ :=
    { toFun := fun n => 1 / (n : ℝ) ^ (2 : ℕ)
      map_zero' := by simp
      map_one' := by simp
      map_mul' := by
        intro m n
        by_cases hm : m = 0
        · simp [hm]
        · by_cases hn : n = 0
          · simp [hn]
          · simp [hm, hn, Nat.cast_mul, mul_pow, one_div, mul_comm, mul_left_comm, mul_assoc] }
  have hs : Summable (fun n : ℕ => f n) := by
    simp [f]
  have hf_nonneg : ∀ n : ℕ, 0 ≤ f n := by
    intro n
    by_cases hn : n = 0
    · simp [f, hn]
    · have : 0 ≤ 1 / (n : ℝ) ^ (2 : ℕ) := by positivity
      simp [f]
  have hf_summable : Summable fun n : ℕ => ‖f n‖ := by
    change Summable fun n : ℕ => |f n|
    simpa [abs_of_nonneg, hf_nonneg] using hs
  have hEuler : ∏' p : Nat.Primes, (1 - f p)⁻¹ = ∑' n : ℕ, f n :=
    EulerProduct.eulerProduct_completely_multiplicative_tprod (f := f) hf_summable
  have hzeta : ∑' n : ℕ, f n = (Real.pi ^ (2 : ℕ)) / 6 := by
    simpa [f] using hasSum_zeta_two.tsum_eq
  calc
    ∏' p : Nat.Primes, (1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹
        = ∏' p : Nat.Primes, (1 - f p)⁻¹ := by
            refine tprod_congr ?_
            intro p
            have hp_eq : f p = (p : ℝ) ^ (-(2 : ℝ)) := by
              change 1 / (p : ℝ) ^ (2 : ℕ) = (p : ℝ) ^ (-(2 : ℝ))
              rw [Real.rpow_neg]
              · simp [one_div]
              · positivity
            rw [hp_eq]
    _ = ∑' n : ℕ, f n := hEuler
    _ = (Real.pi ^ (2 : ℕ)) / 6 := hzeta

theorem pi_sq_div_six_lt_two : (Real.pi ^ (2 : ℕ)) / (6 : ℝ) < 2 := by
  have hsqrt3_pos : 0 < Real.sqrt 3 := by
    positivity
  have hpi_div_six_lt : Real.pi / 6 < 1 / Real.sqrt 3 := by
    have h1 : 0 < Real.pi / 6 := by
      nlinarith [Real.pi_pos]
    have h2 : Real.pi / 6 < Real.pi / 2 := by
      nlinarith [Real.pi_pos]
    simpa only [Real.tan_pi_div_six] using (Real.lt_tan h1 h2)
  have hmul : Real.pi * Real.sqrt 3 < 6 := by
    have htmp : (Real.pi / 6) * Real.sqrt 3 < 1 := by
      exact (lt_div_iff₀ hsqrt3_pos).mp hpi_div_six_lt
    nlinarith
  have hsq : (Real.pi * Real.sqrt 3) ^ (2 : ℕ) < (6 : ℝ) ^ (2 : ℕ) := by
    rw [sq_lt_sq]
    have hpos : 0 < Real.pi * Real.sqrt 3 := by
      positivity
    rw [abs_of_pos hpos, abs_of_pos (by norm_num : (0 : ℝ) < 6)]
    exact hmul
  have hsq3 : (Real.sqrt 3) ^ (2 : ℕ) = (3 : ℝ) := by
    simpa only [pow_two] using (Real.sq_sqrt (show (0 : ℝ) ≤ 3 by positivity))
  have hpi_sq_lt_twelve : Real.pi ^ (2 : ℕ) < 12 := by
    have h6sq : (6 : ℝ) ^ (2 : ℕ) = (36 : ℝ) := by
      norm_num
    rw [mul_pow, hsq3, h6sq] at hsq
    nlinarith
  nlinarith

theorem dedekindZetaTwoReal_le_two_pow_finrank (K : Type) [Field K] [NumberField K] :
    dedekindZetaTwoReal K ≤ (2 : ℝ) ^ Module.finrank ℚ K := by
  classical
  let d := Module.finrank ℚ K
  let g : Nat.Primes → ℝ := fun p => (1 - (p : ℝ) ^ (-(2 : ℝ)))⁻¹
  let loc : Nat.Primes → ℝ := fun p => ∑' e : ℕ, dedekindZetaTwoAF K (p ^ e)
  have hnonneg : ∀ n : ℕ, 0 ≤ dedekindZetaTwoAF K n := by
    intro n
    dsimp [dedekindZetaTwoAF, ArithmeticFunction.coe_mk]
    positivity
  have hsum_norm : Summable (fun n : ℕ => ‖dedekindZetaTwoAF K n‖) := by
    refine Summable.of_nonneg_of_le (fun _ ↦ norm_nonneg _) ?_ (dedekindZetaTwoAF_summable K)
    intro n
    simp [Real.norm_eq_abs, abs_of_nonneg (hnonneg n)]
  have hAF_hasProd : HasProd loc (dedekindZetaTwoReal K) := by
    simpa [loc, dedekindZetaTwoReal] using
      (ArithmeticFunction.IsMultiplicative.eulerProduct_hasProd
        (dedekindZetaTwoAF_isMultiplicative K) hsum_norm)
  have hloc_nonneg : ∀ p : Nat.Primes, 0 ≤ loc p := by
    intro p
    dsimp [loc]
    exact tsum_nonneg (fun e => hnonneg (p ^ e))
  have hzeta_nonneg : 0 ≤ dedekindZetaTwoReal K := by
    unfold dedekindZetaTwoReal
    exact tsum_nonneg hnonneg
  have hInducing : Topology.IsInducing ((Complex.ofRealHom) : ℝ →* ℂ) := by
    simpa using Complex.isUniformEmbedding_ofReal.isUniformInducing.isInducing
  have hpoint (p : Nat.Primes) : ((g p : ℝ) : ℂ) = (1 - (p : ℂ) ^ (-(2 : ℂ)))⁻¹ := by
    have hp : 0 ≤ (p : ℝ) := by positivity
    simp [g, Real.rpow_neg hp, Complex.cpow_neg, Complex.cpow_natCast, Complex.ofReal_cpow hp,
      Complex.ofReal_inv, Complex.ofReal_sub]
    rfl
  have hbase_hasProd_complex :
      HasProd (fun p : Nat.Primes => ((g p : ℝ) : ℂ)) (((Real.pi ^ 2) / 6 : ℝ) : ℂ) := by
    have hs : 1 < ((2 : ℂ)).re := by norm_num
    rw [show (fun p : Nat.Primes => ((g p : ℝ) : ℂ)) = fun p : Nat.Primes => (1 - (p : ℂ) ^ (-(2 : ℂ)))⁻¹ from funext hpoint]
    simpa [riemannZeta_two] using (riemannZeta_eulerProduct_hasProd (s := (2 : ℂ)) hs)
  have hbase_hasProd : HasProd g (Real.pi ^ 2 / 6) := by
    exact (hInducing.hasProd_iff g (Real.pi ^ 2 / 6)).mp hbase_hasProd_complex
  have hpow_hasProd : ∀ n : ℕ, HasProd (fun p : Nat.Primes => g p ^ n) ((Real.pi ^ 2 / 6) ^ n) := by
    intro n
    induction n with
    | zero =>
        simp
    | succ n ih =>
        have hmul :
            HasProd (fun p : Nat.Primes => (g p ^ n) * g p)
              (((Real.pi ^ 2 / 6) ^ n) * (Real.pi ^ 2 / 6)) :=
          ih.mul hbase_hasProd
        simpa [pow_succ] using hmul
  have h_one_le_g : ∀ p : Nat.Primes, 1 ≤ g p := by
    intro p
    have hp1 : (1 : ℝ) < p := by
      exact_mod_cast p.2.one_lt
    have hpow_lt : (p : ℝ) ^ (-(2 : ℝ)) < 1 := by
      exact Real.rpow_lt_one_of_one_lt_of_neg hp1 (by norm_num)
    have hpow_nonneg : 0 ≤ (p : ℝ) ^ (-(2 : ℝ)) := by
      positivity
    have hden_pos : 0 < 1 - (p : ℝ) ^ (-(2 : ℝ)) := by
      linarith
    have hden_le : 1 - (p : ℝ) ^ (-(2 : ℝ)) ≤ 1 := by
      linarith
    exact (one_le_inv₀ hden_pos).2 hden_le
  have hgpow_nonneg : ∀ n : ℕ, ∀ p : Nat.Primes, 0 ≤ g p ^ n := by
    intro n p
    exact pow_nonneg (le_trans zero_le_one (h_one_le_g p)) _
  have hbase_pow_nonneg : ∀ n : ℕ, 0 ≤ (Real.pi ^ 2 / 6) ^ n := by
    intro n
    positivity
  have hNNInducing : Topology.IsInducing (NNReal.toRealHom : NNReal →* ℝ) := by
    simpa [NNReal.coe_toRealHom] using NNReal.isEmbedding_coe.isInducing
  have hAF_hasProd_nn :
      HasProd (fun p : Nat.Primes => Real.toNNReal (loc p))
        (Real.toNNReal (dedekindZetaTwoReal K)) := by
    have hreal :
        HasProd (fun p : Nat.Primes => (NNReal.toRealHom (Real.toNNReal (loc p)) : ℝ))
          (NNReal.toRealHom (Real.toNNReal (dedekindZetaTwoReal K))) := by
      simpa [NNReal.coe_toRealHom, Real.coe_toNNReal, hloc_nonneg, hzeta_nonneg] using hAF_hasProd
    exact (hNNInducing.hasProd_iff (fun p : Nat.Primes => Real.toNNReal (loc p))
      (Real.toNNReal (dedekindZetaTwoReal K))).mp hreal
  have hpow_hasProd_d_nn :
      HasProd (fun p : Nat.Primes => Real.toNNReal (g p ^ d))
        (Real.toNNReal ((Real.pi ^ 2 / 6) ^ d)) := by
    have hreal :
        HasProd (fun p : Nat.Primes => (NNReal.toRealHom (Real.toNNReal (g p ^ d)) : ℝ))
          (NNReal.toRealHom (Real.toNNReal ((Real.pi ^ 2 / 6) ^ d))) := by
      simpa [NNReal.coe_toRealHom, Real.coe_toNNReal, hgpow_nonneg, hbase_pow_nonneg] using hpow_hasProd d
    exact (hNNInducing.hasProd_iff (fun p : Nat.Primes => Real.toNNReal (g p ^ d))
      (Real.toNNReal ((Real.pi ^ 2 / 6) ^ d))).mp hreal
  have hle_local_nn :
      ∏' p : Nat.Primes, Real.toNNReal (loc p) ≤
        ∏' p : Nat.Primes, Real.toNNReal (g p ^ d) := by
    exact Multipliable.tprod_le_tprod
      (fun p => Real.toNNReal_le_toNNReal (by
        simpa [loc, g, d] using dedekindZetaTwoAF_prime_localFactor_le K p p.2))
      hAF_hasProd_nn.multipliable
      hpow_hasProd_d_nn.multipliable
  have hloc_tprod_coe :
      ((∏' p : Nat.Primes, Real.toNNReal (loc p) : NNReal) : ℝ) =
        ∏' p : Nat.Primes, loc p := by
    calc
      ((∏' p : Nat.Primes, Real.toNNReal (loc p) : NNReal) : ℝ)
          = ∏' p : Nat.Primes, (((Real.toNNReal (loc p) : NNReal) : ℝ)) := by
              simpa [NNReal.coe_toRealHom] using
                ((hAF_hasProd_nn.multipliable).map_tprod NNReal.toRealHom NNReal.continuous_coe)
      _ = ∏' p : Nat.Primes, loc p := by
            congr with p
            exact Real.coe_toNNReal (loc p) (hloc_nonneg p)
  have hgpow_tprod_coe :
      ((∏' p : Nat.Primes, Real.toNNReal (g p ^ d) : NNReal) : ℝ) =
        ∏' p : Nat.Primes, g p ^ d := by
    calc
      ((∏' p : Nat.Primes, Real.toNNReal (g p ^ d) : NNReal) : ℝ)
          = ∏' p : Nat.Primes, (((Real.toNNReal (g p ^ d) : NNReal) : ℝ)) := by
              simpa [NNReal.coe_toRealHom] using
                ((hpow_hasProd_d_nn.multipliable).map_tprod NNReal.toRealHom NNReal.continuous_coe)
      _ = ∏' p : Nat.Primes, g p ^ d := by
            congr with p
            exact Real.coe_toNNReal (g p ^ d) (hgpow_nonneg d p)
  have hle_local :
      ∏' p : Nat.Primes, loc p ≤ ∏' p : Nat.Primes, g p ^ d := by
    have hle_local_real :
        ((∏' p : Nat.Primes, Real.toNNReal (loc p) : NNReal) : ℝ) ≤
          ((∏' p : Nat.Primes, Real.toNNReal (g p ^ d) : NNReal) : ℝ) := by
      exact_mod_cast hle_local_nn
    calc
      ∏' p : Nat.Primes, loc p = ((∏' p : Nat.Primes, Real.toNNReal (loc p) : NNReal) : ℝ) := by
        symm
        exact hloc_tprod_coe
      _ ≤ ((∏' p : Nat.Primes, Real.toNNReal (g p ^ d) : NNReal) : ℝ) := hle_local_real
      _ = ∏' p : Nat.Primes, g p ^ d := hgpow_tprod_coe
  calc
    dedekindZetaTwoReal K = ∏' p : Nat.Primes, loc p := hAF_hasProd.tprod_eq.symm
    _ ≤ ∏' p : Nat.Primes, g p ^ d := hle_local
    _ = (Real.pi ^ 2 / 6) ^ d := (hpow_hasProd d).tprod_eq
    _ ≤ (2 : ℝ) ^ d := by
      exact pow_le_pow_left₀ (by positivity) pi_sq_div_six_lt_two.le d

theorem two_pow_mul_minkowskiAuxBound_sq_le_rootDiscr_pow_four (K : Type) [Field K] [NumberField K] :
    (2 : ℝ) ^ Module.finrank ℚ K * (minkowskiAuxBound K) ^ (2 : ℕ) ≤
      max 2 (NumberField.rootDiscr K) ^ ((4 : ℝ) * Module.finrank ℚ K) := by
  set n : ℕ := Module.finrank ℚ K
  set D : ℝ := |(NumberField.discr K : ℝ)|
  have hn : 0 < n := by
    simpa [n] using (Module.finrank_pos (R := ℚ) (M := K))
  have hn0 : (n : ℝ) ≠ 0 := by
    exact_mod_cast (ne_of_gt hn)
  have hD_nonneg : 0 ≤ D := by
    simp [D]
  have hrd_def : NumberField.rootDiscr K = D ^ ((n : ℝ)⁻¹) := by
    rw [NumberField.rootDiscr_def]
    simp [D, n]
  have hrd_nonneg : 0 ≤ NumberField.rootDiscr K := by
    rw [hrd_def]
    positivity
  have hrd_pow : (NumberField.rootDiscr K) ^ (n : ℝ) = D := by
    rw [hrd_def]
    calc
      (D ^ ((n : ℝ)⁻¹)) ^ (n : ℝ) = D ^ (((n : ℝ)⁻¹) * (n : ℝ)) := by
        symm
        exact Real.rpow_mul hD_nonneg ((n : ℝ)⁻¹) (n : ℝ)
      _ = D := by
        rw [inv_mul_cancel₀ hn0, Real.rpow_one]
  have hsig : NumberField.InfinitePlace.nrRealPlaces K
      + 2 * NumberField.InfinitePlace.nrComplexPlaces K = n := by
    simpa [n] using NumberField.InfinitePlace.card_add_two_mul_card_eq_rank (K := K)
  have hcomplex_le_n : NumberField.InfinitePlace.nrComplexPlaces K ≤ n := by
    omega
  have hpi : (4 / Real.pi : ℝ) ≤ 2 := by
    rw [div_le_iff₀ Real.pi_pos]
    nlinarith [Real.pi_gt_three]
  have hpow_complex : (4 / Real.pi : ℝ) ^ NumberField.InfinitePlace.nrComplexPlaces K ≤ (2 : ℝ) ^ n := by
    calc
      (4 / Real.pi : ℝ) ^ NumberField.InfinitePlace.nrComplexPlaces K
          ≤ (2 : ℝ) ^ NumberField.InfinitePlace.nrComplexPlaces K := by
            exact pow_le_pow_left₀ (by positivity) hpi _
      _ ≤ (2 : ℝ) ^ n := by
            exact pow_le_pow_right₀ (by norm_num : (1 : ℝ) ≤ 2) hcomplex_le_n
  have hfac_le : ((n.factorial : ℝ)) ≤ (n : ℝ) ^ n := by
    exact_mod_cast Nat.factorial_le_pow n
  have hpow_n_pos : 0 < (n : ℝ) ^ n := by
    positivity
  have hfac_div_le : ((n.factorial : ℝ) / (n : ℝ) ^ n) ≤ 1 := by
    rw [div_le_iff₀ hpow_n_pos]
    simpa using hfac_le
  have hmink_le : minkowskiAuxBound K ≤ (2 : ℝ) ^ n * Real.sqrt D := by
    unfold minkowskiAuxBound
    calc
      (4 / Real.pi) ^ NumberField.InfinitePlace.nrComplexPlaces K *
          (((Module.finrank ℚ K).factorial : ℝ) / (Module.finrank ℚ K : ℝ) ^ Module.finrank ℚ K *
            Real.sqrt |(NumberField.discr K : ℝ)|)
          ≤ (2 : ℝ) ^ n *
              (((Module.finrank ℚ K).factorial : ℝ) / (Module.finrank ℚ K : ℝ) ^ Module.finrank ℚ K *
                Real.sqrt |(NumberField.discr K : ℝ)|) := by
            gcongr
      _ ≤ (2 : ℝ) ^ n * (1 * Real.sqrt D) := by
            gcongr
      _ = (2 : ℝ) ^ n * Real.sqrt D := by ring
  have hmink_nonneg : 0 ≤ minkowskiAuxBound K := by
    unfold minkowskiAuxBound
    positivity
  have hmink_sq' : (minkowskiAuxBound K) ^ (2 : ℕ) ≤ ((2 : ℝ) ^ n * Real.sqrt D) ^ (2 : ℕ) := by
    nlinarith [hmink_nonneg, hmink_le]
  have hsq_eq : ((2 : ℝ) ^ n * Real.sqrt D) ^ (2 : ℕ) = ((2 : ℝ) ^ n) ^ (2 : ℕ) * D := by
    nlinarith [Real.sq_sqrt hD_nonneg]
  have hmink_sq : (minkowskiAuxBound K) ^ (2 : ℕ) ≤ ((2 : ℝ) ^ n) ^ (2 : ℕ) * D := by
    calc
      (minkowskiAuxBound K) ^ (2 : ℕ) ≤ ((2 : ℝ) ^ n * Real.sqrt D) ^ (2 : ℕ) := hmink_sq'
      _ = ((2 : ℝ) ^ n) ^ (2 : ℕ) * D := hsq_eq
  by_cases hroot : NumberField.rootDiscr K ≤ 2
  · rw [max_eq_left hroot]
    have hD_le : D ≤ (2 : ℝ) ^ n := by
      calc
        D = (NumberField.rootDiscr K) ^ (n : ℝ) := by symm; exact hrd_pow
        _ ≤ (2 : ℝ) ^ (n : ℝ) := by
          exact Real.rpow_le_rpow hrd_nonneg hroot (by positivity)
        _ = (2 : ℝ) ^ n := by rw [Real.rpow_natCast]
    have hpow_four : (2 : ℝ) ^ ((4 : ℝ) * n) = ((2 : ℝ) ^ n) ^ (4 : ℕ) := by
      calc
        (2 : ℝ) ^ ((4 : ℝ) * n) = (2 : ℝ) ^ ((n : ℝ) * 4) := by congr 1; ring
        _ = ((2 : ℝ) ^ (n : ℝ)) ^ (4 : ℝ) := by
              exact Real.rpow_mul (by norm_num : (0 : ℝ) ≤ 2) (n : ℝ) 4
        _ = ((2 : ℝ) ^ (n : ℝ)) ^ (4 : ℕ) := by
              simp
        _ = ((2 : ℝ) ^ n) ^ (4 : ℕ) := by rw [Real.rpow_natCast]
    let a : ℝ := (2 : ℝ) ^ n
    have ha_nonneg : 0 ≤ a := by
      positivity
    have hD_le_a : D ≤ a := by
      simpa [a] using hD_le
    have hmink_sq_a : (minkowskiAuxBound K) ^ (2 : ℕ) ≤ a ^ (2 : ℕ) * D := by
      simpa [a] using hmink_sq
    have hmul1 : a * (minkowskiAuxBound K) ^ (2 : ℕ) ≤ a * (a ^ (2 : ℕ) * D) := by
      exact mul_le_mul_of_nonneg_left hmink_sq_a ha_nonneg
    have hmul2 : a * (a ^ (2 : ℕ) * D) ≤ a ^ (4 : ℕ) := by
      calc
        a * (a ^ (2 : ℕ) * D) = a ^ (3 : ℕ) * D := by ring
        _ ≤ a ^ (3 : ℕ) * a := by
              exact mul_le_mul_of_nonneg_left hD_le_a (by positivity : 0 ≤ a ^ (3 : ℕ))
        _ = a ^ (4 : ℕ) := by ring
    calc
      (2 : ℝ) ^ n * (minkowskiAuxBound K) ^ (2 : ℕ) = a * (minkowskiAuxBound K) ^ (2 : ℕ) := by
        simp [a]
      _ ≤ a * (a ^ (2 : ℕ) * D) := hmul1
      _ ≤ a ^ (4 : ℕ) := hmul2
      _ = (2 : ℝ) ^ ((4 : ℝ) * n) := by
        symm
        exact hpow_four
  · have hroot' : 2 ≤ NumberField.rootDiscr K := le_of_not_ge hroot
    rw [max_eq_right hroot']
    have hpow_le_D : (2 : ℝ) ^ n ≤ D := by
      calc
        (2 : ℝ) ^ n = (2 : ℝ) ^ (n : ℝ) := by
          symm
          exact Real.rpow_natCast (2 : ℝ) n
        _ ≤ (NumberField.rootDiscr K) ^ (n : ℝ) := by
          exact Real.rpow_le_rpow (by norm_num : (0 : ℝ) ≤ 2) hroot' (by positivity)
        _ = D := hrd_pow
    have hpow_four : (NumberField.rootDiscr K) ^ ((4 : ℝ) * n) = D ^ (4 : ℕ) := by
      calc
        (NumberField.rootDiscr K) ^ ((4 : ℝ) * n)
            = (NumberField.rootDiscr K) ^ ((n : ℝ) * 4) := by congr 1; ring
        _ = ((NumberField.rootDiscr K) ^ (n : ℝ)) ^ (4 : ℝ) := by
              exact Real.rpow_mul hrd_nonneg (n : ℝ) 4
        _ = ((NumberField.rootDiscr K) ^ (n : ℝ)) ^ (4 : ℕ) := by
              simp
        _ = D ^ (4 : ℕ) := by rw [hrd_pow]
    let a : ℝ := (2 : ℝ) ^ n
    have ha_nonneg : 0 ≤ a := by
      positivity
    have ha_le_D : a ≤ D := by
      simpa [a] using hpow_le_D
    have hmink_sq_a : (minkowskiAuxBound K) ^ (2 : ℕ) ≤ a ^ (2 : ℕ) * D := by
      simpa [a] using hmink_sq
    have hmul1 : a * (minkowskiAuxBound K) ^ (2 : ℕ) ≤ a * (a ^ (2 : ℕ) * D) := by
      exact mul_le_mul_of_nonneg_left hmink_sq_a ha_nonneg
    have hpow3 : a ^ (3 : ℕ) ≤ D ^ (3 : ℕ) := by
      exact pow_le_pow_left₀ ha_nonneg ha_le_D _
    have hmul2 : a * (a ^ (2 : ℕ) * D) ≤ D ^ (4 : ℕ) := by
      calc
        a * (a ^ (2 : ℕ) * D) = a ^ (3 : ℕ) * D := by ring
        _ ≤ D ^ (3 : ℕ) * D := by
              exact mul_le_mul_of_nonneg_right hpow3 hD_nonneg
        _ = D ^ (4 : ℕ) := by ring
    calc
      (2 : ℝ) ^ n * (minkowskiAuxBound K) ^ (2 : ℕ) = a * (minkowskiAuxBound K) ^ (2 : ℕ) := by
        simp [a]
      _ ≤ a * (a ^ (2 : ℕ) * D) := hmul1
      _ ≤ D ^ (4 : ℕ) := hmul2
      _ = (NumberField.rootDiscr K) ^ ((4 : ℝ) * n) := by
        symm
        exact hpow_four

theorem minkowski_class_number_bound_explicit (K : Type) [Field K] [NumberField K] :
    (NumberField.classNumber K : ℝ) ≤
      max 2 (NumberField.rootDiscr K) ^ ((4 : ℝ) * Module.finrank ℚ K) := by
  have hclass : (NumberField.classNumber K : ℝ) ≤ idealsUpToNormCount K (minkowskiAuxBound K) := by
    exact_mod_cast classNumber_le_idealsUpToNormCount_minkowskiAuxBound K
  have hfin_nat : 0 < Module.finrank ℚ K := Module.finrank_pos (R := ℚ) (M := K)
  have hfin : 0 < (Module.finrank ℚ K : ℝ) := by
    exact_mod_cast hfin_nat
  have hnonneg : 0 ≤ minkowskiAuxBound K := by
    unfold minkowskiAuxBound
    positivity
  have hideals : (idealsUpToNormCount K (minkowskiAuxBound K) : ℝ) ≤
      dedekindZetaTwoReal K * (minkowskiAuxBound K) ^ (2 : ℕ) := by
    exact idealsUpToNormCount_le_dedekindZetaTwoReal_mul_sq K (minkowskiAuxBound K) hnonneg
  have hzeta : dedekindZetaTwoReal K * (minkowskiAuxBound K) ^ (2 : ℕ) ≤
      (2 : ℝ) ^ Module.finrank ℚ K * (minkowskiAuxBound K) ^ (2 : ℕ) := by
    gcongr
    exact dedekindZetaTwoReal_le_two_pow_finrank K
  calc
    (NumberField.classNumber K : ℝ) ≤ idealsUpToNormCount K (minkowskiAuxBound K) := hclass
    _ ≤ dedekindZetaTwoReal K * (minkowskiAuxBound K) ^ (2 : ℕ) := hideals

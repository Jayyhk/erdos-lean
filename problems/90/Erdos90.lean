theorem succSucc_removeNth_eq_cons_removeNth_tail (Оұ : Type) (n : в„•) (t : Fin (n + 3) вҶ’ Оұ) (j : Fin (n + 1)) : j.succ.succ.removeNth t = Fin.cons (t 0) (j.succ.removeNth (Fin.tail t)) := by

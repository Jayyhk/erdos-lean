theorem isProP_of_frattini_quotient
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    {k : ℕ} (g : Fin k → G) (_hg : ∀ i, g i ∈ closedFrattini p G) :
    ∀ (H : Subgroup (G ⧸ closedNormalClosureRange g)) [H.Normal],
      IsOpen (H : Set (G ⧸ closedNormalClosureRange g)) →
        IsPGroup p ((G ⧸ closedNormalClosureRange g) ⧸ H) := by
  intro H _ hH
  set N : Subgroup G := closedNormalClosureRange g with hN_def
  set π : G →* G ⧸ N := QuotientGroup.mk' N with hπ_def
  set M : Subgroup G := H.comap π with hM_def
  haveI : M.Normal := H.normal_comap π
  have hN_le_M : N ≤ M := by
    intro x hx
    change π x ∈ H
    have hπx : π x = 1 := (QuotientGroup.eq_one_iff x).mpr hx
    simp [hπx]
  have hM_open : IsOpen (M : Set G) := by
    change IsOpen (π ⁻¹' (H : Set _))
    exact QuotientGroup.continuous_mk.isOpen_preimage _ hH
  have hM_pgrp : IsPGroup p (G ⧸ M) := hG.isPGroup_quotient M hM_open
  have hMmap : M.map (QuotientGroup.mk' N) = H :=
    Subgroup.map_comap_eq_self_of_surjective (QuotientGroup.mk'_surjective _) H
  haveI : (M.map (QuotientGroup.mk' N)).Normal := inferInstance
  have iso : ((G ⧸ N) ⧸ H) ≃* (G ⧸ M) :=
    (QuotientGroup.quotientMulEquivOfEq hMmap.symm).trans
      (QuotientGroup.quotientQuotientEquivQuotient N M hN_le_M)
  exact IsPGroup.of_equiv hM_pgrp iso.symm

noncomputable def proPQuotientOfFrattiniElements
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    {k : ℕ} (g : Fin k → G) (hg : ∀ i, g i ∈ closedFrattini p G) :
    ProPQuotient p G :=
  let N : Subgroup G := closedNormalClosureRange g
  haveI : N.Normal := closedNormalClosureRange.instNormal g
  haveI hNclosed : IsClosed (N : Set G) := closedNormalClosureRange.isClosed g
  { Q := G ⧸ N
    group := inferInstance
    topSpace := inferInstance
    topGroup := inferInstance
    t2 := by

      haveI : T1Space (G ⧸ N) := QuotientGroup.instT1Space
      haveI : T3Space (G ⧸ N) := inferInstance
      infer_instance
    compact := compactSpace_of_frattini_quotient G p hG g hg
    totallyDisconnected := totallyDisconnected_of_frattini_quotient G p hG g hg
    map := QuotientGroup.mk' N
    surjective := QuotientGroup.mk'_surjective N
    continuous := continuous_quotient_mk'
    isProP := isProP_of_frattini_quotient G p hG g hg }

theorem closedFrattini_normal (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) : (closedFrattini p G).Normal := by
  classical
  let S : Set G := (Set.range fun g : G => g ^ p) ∪ (commutator G : Set G)
  have hnormal_closure : (Subgroup.closure S).Normal := by
    refine ⟨?_⟩
    intro x hx a
    refine Subgroup.closure_induction
      (p := fun y _ => a * y * a⁻¹ ∈ Subgroup.closure S)
      ?hmem ?hone ?hmul ?hinv hx
    · intro y hy
      rcases hy with hy | hy
      · rcases hy with ⟨g, rfl⟩
        exact Subgroup.subset_closure <| Or.inl <| ⟨a * g * a⁻¹, by
          simp
        ⟩
      · exact Subgroup.subset_closure <| Or.inr <| (inferInstance : (commutator G).Normal).conj_mem y hy a
    · simp
    · intro y z hy hz hy' hz'
      have hm : (a * y * a⁻¹) * (a * z * a⁻¹) ∈ Subgroup.closure S :=
        Subgroup.mul_mem (Subgroup.closure S) hy' hz'
      simpa [mul_assoc] using hm
    · intro y hy hy'
      have hi : (a * y * a⁻¹)⁻¹ ∈ Subgroup.closure S :=
        Subgroup.inv_mem (Subgroup.closure S) hy'
      simpa [mul_assoc] using hi
  letI : (Subgroup.closure S).Normal := hnormal_closure
  simpa [closedFrattini, S] using (Subgroup.is_normal_topologicalClosure (N := Subgroup.closure S))

theorem closedNormalClosureRange_le_closedFrattini (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) {k : ℕ} (g : Fin k → G) (hg : ∀ i, g i ∈ closedFrattini p G) : closedNormalClosureRange g ≤ closedFrattini p G := by
  letI : (closedFrattini p G).Normal := closedFrattini_normal G p
  refine Subgroup.topologicalClosure_minimal (s := Subgroup.normalClosure (Set.range g)) ?_ ?_
  · exact Subgroup.normalClosure_le_normal (by
      intro x hx
      rcases hx with ⟨i, rfl⟩
      exact hg i)
  · simp [closedFrattini]

theorem generatorRank_le_of_generating_finset (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (S : Finset G) (hS : (Subgroup.closure (S : Set G)).topologicalClosure = ⊤) : generatorRank G ≤ S.card := by
  unfold generatorRank
  apply Nat.sInf_le
  exact ⟨S, rfl, hS⟩

theorem generatorRank_quotient_le_of_closed_normal (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (N : Subgroup G) [N.Normal] : generatorRank (G ⧸ N) ≤ generatorRank G := by
  classical
  rcases generatorRank_spec hG with ⟨S, hS_card, hS_top⟩
  let π : G →* G ⧸ N := QuotientGroup.mk' N
  let T : Finset (G ⧸ N) := S.image π
  have hT_top : (Subgroup.closure ((T : Finset (G ⧸ N)) : Set (G ⧸ N))).topologicalClosure = ⊤ := by
    have htop : ((Subgroup.closure (S : Set G)).map π).topologicalClosure = (⊤ : Subgroup (G ⧸ N)) := by
      simpa using
        (DenseRange.topologicalClosure_map_subgroup (f := π)
          continuous_quotient_mk' (QuotientGroup.mk'_surjective N).denseRange hS_top :
          ((Subgroup.closure (S : Set G)).map π).topologicalClosure =
            (⊤ : Subgroup (G ⧸ N)))
    rw [MonoidHom.map_closure] at htop
    simpa [T, π, Finset.coe_image] using htop
  calc
    generatorRank (G ⧸ N) ≤ T.card := generatorRank_le_of_generating_finset (G := G ⧸ N) T hT_top
    _ ≤ S.card := Finset.card_image_le
    _ = generatorRank G := hS_card

theorem generatorRank_spec_of_exists_generating_finset (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (hex : ∃ S : Finset G, (Subgroup.closure (S : Set G)).topologicalClosure = ⊤) : ∃ S : Finset G, S.card = generatorRank G ∧ (Subgroup.closure (S : Set G)).topologicalClosure = ⊤ := by
  classical
  unfold generatorRank
  let A : Set ℕ := {k : ℕ | ∃ S : Finset G, S.card = k ∧ (Subgroup.closure (S : Set G)).topologicalClosure = ⊤}
  have hA_nonempty : A.Nonempty := by
    rcases hex with ⟨S, hS⟩
    exact ⟨S.card, ⟨S, rfl, hS⟩⟩
  have hsInf_mem : sInf A ∈ A := Nat.sInf_mem hA_nonempty
  rcases hsInf_mem with ⟨S, hcard, hS⟩
  refine ⟨S, ?_, hS⟩
  simpa [A] using hcard

theorem powers_commutator_le_frattini_of_finite_pgroup (Q : Type) [Group Q] [Finite Q] (p : ℕ) [Fact (Nat.Prime p)] (hQ : IsPGroup p Q) : Subgroup.closure ((Set.range (fun q : Q => q ^ p)) ∪ (commutator Q : Set Q)) ≤ frattini Q := by
  classical
  rw [frattini, Order.radical]
  refine le_iInf ?_
  intro M
  refine le_iInf ?_
  intro hM
  have hp : Nat.Prime p := Fact.out
  letI : Group.IsNilpotent Q := hQ.isNilpotent
  have hnc : NormalizerCondition Q := normalizerCondition_of_isNilpotent (G := Q)
  letI : M.Normal := Subgroup.NormalizerCondition.normal_of_coatom (H := M) hnc hM
  have hquot_bot_or_top : ∀ H : Subgroup (Q ⧸ M), H = ⊥ ∨ H = ⊤ := by
    intro H
    by_cases hH : H = ⊥
    · exact Or.inl hH
    · right
      obtain ⟨x, hxH, hx1⟩ := (Subgroup.bot_or_exists_ne_one H).resolve_left hH
      obtain ⟨q, rfl⟩ := QuotientGroup.mk'_surjective M x
      have hq_not_mem : q ∉ M := by
        intro hqM
        apply hx1
        exact (QuotientGroup.eq_one_iff q).2 hqM
      have hM_le_comap : M ≤ H.comap (QuotientGroup.mk' M) := by
        intro y hy
        change QuotientGroup.mk' M y ∈ H
        simp [(QuotientGroup.eq_one_iff y).2 hy]
      have hne : M ≠ H.comap (QuotientGroup.mk' M) := by
        intro hEq
        apply hq_not_mem
        have hq : q ∈ H.comap (QuotientGroup.mk' M) := by
          change QuotientGroup.mk' M q ∈ H
          exact hxH
        simpa [hEq] using hq
      have hcomap_top : H.comap (QuotientGroup.mk' M) = ⊤ :=
        hM.2 _ (lt_iff_le_and_ne.2 ⟨hM_le_comap, hne⟩)
      have hEq : H.comap (QuotientGroup.mk' M) = (⊤ : Subgroup (Q ⧸ M)).comap (QuotientGroup.mk' M) := by
        simpa using hcomap_top
      exact (Subgroup.comap_injective (QuotientGroup.mk'_surjective M)) hEq
  haveI : Nontrivial (Q ⧸ M) := (QuotientGroup.nontrivial_iff).2 hM.1
  have hcenter_ne_bot : (Subgroup.center (Q ⧸ M)) ≠ ⊥ := by
    haveI : Nontrivial (Subgroup.center (Q ⧸ M)) := (hQ.to_quotient M).center_nontrivial
    exact (Subgroup.nontrivial_iff_ne_bot _).1 inferInstance
  have hcenter_top : Subgroup.center (Q ⧸ M) = ⊤ := (hquot_bot_or_top _).resolve_left hcenter_ne_bot
  letI : CommGroup (Q ⧸ M) := Group.commGroupOfCenterEqTop hcenter_top
  have hsimple : IsSimpleGroup (Q ⧸ M) := by
    rw [isSimpleGroup_iff]
    constructor
    · infer_instance
    · intro H hH
      exact hquot_bot_or_top H
  have hprimecard : Nat.Prime (Nat.card (Q ⧸ M)) := (CommGroup.is_simple_iff_prime_card).1 hsimple
  have hcard_ne_one : Nat.card (Q ⧸ M) ≠ 1 := by
    exact ne_of_gt (Finite.one_lt_card_iff_nontrivial.mpr inferInstance)
  have hdiv : p ∣ Nat.card (Q ⧸ M) := (hQ.to_quotient M).card_eq_or_dvd.resolve_left hcard_ne_one
  have hcard_eq_p : Nat.card (Q ⧸ M) = p := ((Nat.prime_dvd_prime_iff_eq hp hprimecard).1 hdiv).symm
  have hcomm : commutator Q ≤ M := by
    have hmulComm : Std.Commutative (fun a b : Q ⧸ M => a * b) := by
      refine ⟨?_⟩
      intro a b
      exact mul_comm a b
    exact (Subgroup.Normal.quotient_commutative_iff_commutator_le (N := M)).1 hmulComm
  exact (Subgroup.closure_le (K := M)).2 <| by
    intro x hx
    rcases hx with hx | hx
    · rcases hx with ⟨q, rfl⟩
      have hpowindex : q ^ M.index ∈ M := Subgroup.pow_index_mem M q
      simpa [Subgroup.index_eq_card, hcard_eq_p] using hpowindex
    · exact hcomm hx

theorem closedFrattini_le_comap_frattini_of_open_normal (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (N : Subgroup G) [N.Normal] (hNopen : IsOpen (N : Set G)) : closedFrattini p G ≤ (frattini (G ⧸ N)).comap (QuotientGroup.mk' N) := by
  classical
  let π : G →* G ⧸ N := QuotientGroup.mk' N
  haveI : CompactSpace G := hG.compactSpace
  haveI : Finite (G ⧸ N) := Subgroup.quotient_finite_of_isOpen N hNopen
  haveI : DiscreteTopology (G ⧸ N) := QuotientGroup.discreteTopology (N := N) hNopen
  have hQp : IsPGroup p (G ⧸ N) := hG.isPGroup_quotient N hNopen
  have hpowcomm :
      Subgroup.closure ((Set.range (fun q : G ⧸ N => q ^ p)) ∪
        (commutator (G ⧸ N) : Set (G ⧸ N))) ≤ frattini (G ⧸ N) :=
    powers_commutator_le_frattini_of_finite_pgroup (G ⧸ N) p hQp
  have hcomm_map : (commutator G).map π = commutator (G ⧸ N) := by
    rw [map_commutator_eq,
      MonoidHom.range_eq_top_of_surjective π (QuotientGroup.mk'_surjective N)]
    rfl
  have halg :
      Subgroup.closure ((Set.range (fun g : G => g ^ p)) ∪ (commutator G : Set G)) ≤
        (frattini (G ⧸ N)).comap π := by
    refine (Subgroup.closure_le ((frattini (G ⧸ N)).comap π)).2 ?_
    intro x hx
    change x ∈ (frattini (G ⧸ N)).comap π
    rw [Subgroup.mem_comap]
    rcases hx with hx | hx
    · rcases hx with ⟨g, rfl⟩
      rw [MonoidHom.map_pow]
      exact hpowcomm (Subgroup.subset_closure (Or.inl ⟨π g, rfl⟩))
    · have hxmap : π x ∈ (commutator G).map π :=
        Subgroup.mem_map_of_mem π hx
      rw [hcomm_map] at hxmap
      exact hpowcomm (Subgroup.subset_closure (Or.inr hxmap))
  have hclosed : IsClosed (((frattini (G ⧸ N)).comap π : Subgroup G) : Set G) := by
    change IsClosed (π ⁻¹' (frattini (G ⧸ N) : Set (G ⧸ N)))
    have hfrclosed : IsClosed (frattini (G ⧸ N) : Set (G ⧸ N)) :=
      isClosed_discrete _
    exact hfrclosed.preimage (by
      simpa only [π, QuotientGroup.coe_mk' N] using (QuotientGroup.continuous_mk (N := N)))
  simpa only [closedFrattini] using
    (Subgroup.topologicalClosure_minimal
      (Subgroup.closure ((Set.range (fun g : G => g ^ p)) ∪ (commutator G : Set G)))
      halg hclosed)

theorem closedFrattini_nongenerating (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (K : Subgroup G) (hKclosed : IsClosed (K : Set G)) (hK : K ⊔ closedFrattini p G = ⊤) : K = ⊤ := by
  classical
  haveI := hG.compactSpace
  haveI := hG.t2Space
  haveI := hG.totallyDisconnectedSpace
  by_contra hKtop
  have hnotall : ¬ ∀ x : G, x ∈ K := by
    intro hAll
    apply hKtop
    ext y
    constructor
    · intro _
      trivial
    · intro _
      exact hAll y
  obtain ⟨x, hxK⟩ : ∃ x : G, x ∉ K := not_forall.mp hnotall
  let U : Set G := ((Homeomorph.mulLeft x) '' (K : Set G))ᶜ
  have hUopen : IsOpen U := by
    dsimp [U]
    exact ((Homeomorph.mulLeft x).isClosedMap _ hKclosed).isOpen_compl
  have hU1 : (1 : G) ∈ U := by
    refine Set.mem_compl ?_
    rintro ⟨l, hl, hxl⟩
    have hxl' : x * l = 1 := by simpa using hxl
    rw [← inv_eq_iff_mul_eq_one] at hxl'
    exact hxK <| inv_mem_iff.mp (hxl' ▸ hl)
  obtain ⟨N, hNsubU⟩ :=
    ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hUopen hU1
  have hxNK : x ∉ (N : Subgroup G) ⊔ K := by
    intro hxNK
    rcases Subgroup.mem_sup_of_normal_left.mp hxNK with ⟨y, hy, z, hz, hyz⟩
    rw [← eq_mul_inv_iff_mul_eq] at hyz
    have hximage : x * z⁻¹ ∈ (Homeomorph.mulLeft x) '' (K : Set G) := by
      refine ⟨z⁻¹, inv_mem_iff.mpr hz, rfl⟩
    exact hNsubU (hyz ▸ hy) hximage
  let π : G →* G ⧸ (N : Subgroup G) := QuotientGroup.mk' (N : Subgroup G)
  let H : Subgroup (G ⧸ (N : Subgroup G)) := K.map π
  haveI : Finite (G ⧸ (N : Subgroup G)) :=
    Subgroup.quotient_finite_of_isOpen (U := (N : Subgroup G)) N.isOpen
  haveI : IsCoatomic (Subgroup (G ⧸ (N : Subgroup G))) := Finite.to_isCoatomic
  have hcf : closedFrattini p G ≤ (frattini (G ⧸ (N : Subgroup G))).comap π :=
    closedFrattini_le_comap_frattini_of_open_normal (G := G) (p := p) hG (N := (N : Subgroup G))
      (hNopen := N.isOpen)
  have hcfmap : (closedFrattini p G).map π ≤ frattini (G ⧸ (N : Subgroup G)) :=
    (Subgroup.map_le_iff_le_comap).2 hcf
  have hHsup : H ⊔ frattini (G ⧸ (N : Subgroup G)) = ⊤ := by
    apply top_unique
    calc
      (⊤ : Subgroup (G ⧸ (N : Subgroup G))) = (K ⊔ closedFrattini p G).map π := by
        rw [hK, Subgroup.map_top_of_surjective π QuotientGroup.mk_surjective]
      _ = H ⊔ (closedFrattini p G).map π := by
        rw [Subgroup.map_sup]
      _ ≤ H ⊔ frattini (G ⧸ (N : Subgroup G)) := by
        exact sup_le_sup le_rfl hcfmap
  have hHtop : H = ⊤ := frattini_nongenerating (K := H) hHsup
  have hKNtop : K ⊔ (N : Subgroup G) = ⊤ := by
    have hmap_eq : K.map π = (⊤ : Subgroup G).map π := by
      calc
        K.map π = H := by rfl
        _ = ⊤ := hHtop
        _ = (⊤ : Subgroup G).map π := by
          symm
          exact Subgroup.map_top_of_surjective π QuotientGroup.mk_surjective
    have hsupker : K ⊔ π.ker = ⊤ ⊔ π.ker :=
      (Subgroup.map_eq_map_iff (f := π) (H := K) (K := ⊤)).mp hmap_eq
    simpa [π, QuotientGroup.ker_mk'] using hsupker
  have hxTop : x ∈ (⊤ : Subgroup G) := by trivial
  have hxKN' : x ∈ K ⊔ (N : Subgroup G) := by
    simp [hKNtop]
  exact hxNK (by simpa [sup_comm] using hxKN')

theorem generatorRank_eq_of_closed_normal_le_closedFrattini (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : ℕ) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (N : Subgroup G) [N.Normal] (hNclosed : IsClosed (N : Set G)) (hNphi : N ≤ closedFrattini p G) : generatorRank (G ⧸ N) = generatorRank G := by
  classical
  apply le_antisymm
  · exact generatorRank_quotient_le_of_closed_normal G p hG N
  · rcases generatorRank_spec hG with ⟨S₀, hS₀_card, hS₀_top⟩
    let T₀ : Finset (G ⧸ N) := S₀.image (QuotientGroup.mk' N)
    have hT₀_top : (Subgroup.closure (T₀ : Set (G ⧸ N))).topologicalClosure = ⊤ := by
      have htop : ((Subgroup.closure (S₀ : Set G)).map (QuotientGroup.mk' N)).topologicalClosure =
          (⊤ : Subgroup (G ⧸ N)) := by
        simpa using
          (DenseRange.topologicalClosure_map_subgroup
            (f := QuotientGroup.mk' N) continuous_quotient_mk'
            (QuotientGroup.mk'_surjective N).denseRange hS₀_top)
      rw [MonoidHom.map_closure] at htop
      simpa [T₀, Finset.coe_image] using htop
    rcases generatorRank_spec_of_exists_generating_finset (G := G ⧸ N) ⟨T₀, hT₀_top⟩ with
      ⟨T, hT_card, hT_top⟩
    let lift : G ⧸ N → G := fun q => Classical.choose (QuotientGroup.mk'_surjective N q)
    have hlift : ∀ q : G ⧸ N, QuotientGroup.mk' N (lift q) = q := by
      intro q
      exact Classical.choose_spec (QuotientGroup.mk'_surjective N q)
    let S : Finset G := T.image lift
    let K : Subgroup G := (Subgroup.closure (S : Set G)).topologicalClosure
    have hKclosed : IsClosed (K : Set G) := by
      dsimp [K]
      exact Subgroup.isClosed_topologicalClosure _
    haveI : CompactSpace G := hG.compactSpace
    haveI : IsClosed (N : Set G) := hNclosed
    haveI : T2Space (G ⧸ N) := by
      haveI : T1Space (G ⧸ N) := QuotientGroup.instT1Space
      infer_instance
    have hKmap_closed : IsClosed (K.map (QuotientGroup.mk' N) : Set (G ⧸ N)) := by
      have hKcompact : IsCompact (K : Set G) := hKclosed.isCompact
      have hcompact : IsCompact (K.map (QuotientGroup.mk' N) : Set (G ⧸ N)) := by
        simpa [Subgroup.coe_map] using hKcompact.image continuous_quotient_mk'
      exact hcompact.isClosed
    have hTsub : (T : Set (G ⧸ N)) ⊆ K.map (QuotientGroup.mk' N) := by
      intro t ht
      have hmemS : lift t ∈ S := by
        exact Finset.mem_image.mpr ⟨t, ht, rfl⟩
      have hmemClosure : lift t ∈ Subgroup.closure (S : Set G) :=
        Subgroup.subset_closure hmemS
      have hmemK : lift t ∈ K :=
        Subgroup.le_topologicalClosure _ hmemClosure
      have hmapmem : QuotientGroup.mk' N (lift t) ∈ K.map (QuotientGroup.mk' N) :=
        Subgroup.mem_map_of_mem (QuotientGroup.mk' N) hmemK
      simpa [hlift t] using hmapmem
    have hTclosure_le : (Subgroup.closure (T : Set (G ⧸ N))).topologicalClosure ≤
        K.map (QuotientGroup.mk' N) := by
      apply Subgroup.topologicalClosure_minimal
      · exact (Subgroup.closure_le (K := K.map (QuotientGroup.mk' N))).2 hTsub
      · exact hKmap_closed
    have hKmap_top : K.map (QuotientGroup.mk' N) = ⊤ := by
      apply top_unique
      rw [← hT_top]
      exact hTclosure_le
    have hKN_top : K ⊔ N = ⊤ := by
      rw [sup_comm, ← QuotientGroup.comap_map_mk' N K, hKmap_top, Subgroup.comap_top]
    have hKphi : K ⊔ closedFrattini p G = ⊤ := by
      apply top_unique
      calc
        ⊤ = K ⊔ N := by symm; exact hKN_top
        _ ≤ K ⊔ closedFrattini p G := sup_le_sup le_rfl hNphi
    have hKtop : K = ⊤ :=
      closedFrattini_nongenerating G p hG K hKclosed hKphi
    have hGle : generatorRank G ≤ S.card := by
      exact generatorRank_le_of_generating_finset G S (by simpa [K] using hKtop)
    have hScard : S.card ≤ T.card := by
      simpa [S] using (Finset.card_image_le (s := T) (f := lift))
    calc
      generatorRank G ≤ S.card := hGle
      _ ≤ T.card := hScard
      _ = generatorRank (G ⧸ N) := hT_card

theorem frattini_quotient_generator_rank (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    {k : ℕ} (g : Fin k → G) (hg : ∀ i, g i ∈ closedFrattini p G) :
    generatorRank (proPQuotientOfFrattiniElements G p hG g hg).Q
      = generatorRank G := by
  simpa [proPQuotientOfFrattiniElements] using
    (generatorRank_eq_of_closed_normal_le_closedFrattini G p hG (closedNormalClosureRange g)
      (closedNormalClosureRange.isClosed g)
      (closedNormalClosureRange_le_closedFrattini G p g hg))

theorem proPQuotientOfFrattiniElements_relationRank_bound
    (h5term : _root_.Erdos90.Hyp_FiveTermRelationBound)
    (hBurnside : _root_.Erdos90.Hyp_NormallyGenH1InvariantBound)
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    (hH2G : _root_.Erdos90.H2Finite p G)
    {k : ℕ} (g : Fin k → G) (hg : ∀ i, g i ∈ closedFrattini p G) :
    _root_.Erdos90.H2Finite p (proPQuotientOfFrattiniElements G p hG g hg).Q ∧
      relationRank p (proPQuotientOfFrattiniElements G p hG g hg).Q
        ≤ relationRank p G + k := by
  haveI : T2Space G := hG.t2Space
  haveI : CompactSpace G := hG.compactSpace
  haveI : TotallyDisconnectedSpace G := hG.totallyDisconnectedSpace
  let N : Subgroup G := (Subgroup.normalClosure (Set.range g)).topologicalClosure
  haveI : N.Normal :=
    Subgroup.is_normal_topologicalClosure (N := Subgroup.normalClosure (Set.range g))
  have hClosed : IsClosed (N : Set G) := Subgroup.isClosed_topologicalClosure _
  obtain ⟨hH1Fin, hh1⟩ := hBurnside p G hG k g

  obtain ⟨hH2quot, hrel⟩ := h5term p G hG hH2G N hClosed hH1Fin
  refine ⟨?_, ?_⟩
  · simpa [proPQuotientOfFrattiniElements, closedNormalClosureRange, N] using hH2quot
  · have hh1' : _root_.Erdos90.h1NormalInvariantRank p G N ≤ k := hh1
    have hcombine : relationRank p (G ⧸ N) ≤ relationRank p G + k := by
      refine le_trans hrel ?_; omega
    simpa [proPQuotientOfFrattiniElements, closedNormalClosureRange, N] using hcombine

theorem frattini_quotient_lemma
    (h5term : _root_.Erdos90.Hyp_FiveTermRelationBound)
    (hBurnside : _root_.Erdos90.Hyp_NormallyGenH1InvariantBound)
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    (hH2G : _root_.Erdos90.H2Finite p G)
    (k : ℕ) (g : Fin k → G) (hg : ∀ i, g i ∈ closedFrattini p G) :
    ∃ Q : ProPQuotient p G,
      (∀ i, Q.map (g i) = 1) ∧
      generatorRank Q.Q = generatorRank G ∧
      _root_.Erdos90.H2Finite p Q.Q ∧
      relationRank p Q.Q ≤ relationRank p G + k := by
  obtain ⟨hH2Q, hrelQ⟩ :=
    proPQuotientOfFrattiniElements_relationRank_bound h5term hBurnside G p hG hH2G g hg
  refine ⟨proPQuotientOfFrattiniElements G p hG g hg, ?_, ?_, hH2Q, hrelQ⟩
  · intro i
    change QuotientGroup.mk' (closedNormalClosureRange g) (g i) = 1
    rw [QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]
    exact closedNormalClosureRange.mem g i
  · exact frattini_quotient_generator_rank G p hG g hg


  rw [← List.toFinset_card_of_nodup hnodup]
  have hsub : ds.toFinset ⊆ Finset.Icc 1 n := by
    intro d hd
    rw [List.mem_toFinset] at hd
    simpa [Finset.mem_Icc] using

  have hdegree_tendsto : Filter.Tendsto (fun j => Module.finrank в„ҡ (L j)) Filter.atTop Filter.atTop := by
    apply Filter.tendsto_atTop_mono (f := fun j => Module.finrank F (L j))
    В· intro j
      letI : NumberField (L j) := hLnum j
      exact Module.finrank_top_le_finrank_of_isScalarTower в„ҡ F (L j)
    В· exact hdeg_tendsto_F
  refine вҹЁ{ L := fun j => L j
            field_L := fun j => inferInstance

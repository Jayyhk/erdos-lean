noncomputable def leftTentAverage (f : в„• вҶ’ в„қ) (X : в„қ) : в„қ :=
  вҲ« t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t

theorem eventual_pos_of_quasi_monotone_and_leftTentAverage {f : в„• вҶ’ в„қ} {b : в„қ} :
    (hb : 0 < b) вҶ’
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hqm : вҲҖ {x y : в„қ}, 0 вүӨ x вҶ’ 0 вүӨ y вҶ’
      logRescalePartialSum f x вүӨ Real.exp y * logRescalePartialSum f (x + y)) вҶ’
    (havg : Filter.Tendsto (fun X : в„қ => leftTentAverage f X)
      Filter.atTop (nhds b)) вҶ’
    вҲғ c : в„қ, 0 < c вҲ§ вҲғ xвӮҖ : в„қ, вҲҖ x : в„қ, xвӮҖ вүӨ x вҶ’ c вүӨ logRescalePartialSum f x := by
  intro hb hnonneg hqm havg
  let U : в„қ вҶ’ в„қ := logRescalePartialSum f
  have hU_nonneg : вҲҖ x : в„қ, 0 вүӨ U x := by
    intro x
    by_cases hx : 0 вүӨ x
    В· dsimp [U, logRescalePartialSum]
      rw [if_pos hx]
      refine mul_nonneg (le_of_lt (Real.exp_pos (-x))) ?_
      exact Finset.sum_nonneg (by
        intro n hn
        exact hnonneg n)
    В· dsimp [U, logRescalePartialSum]
      rw [if_neg hx]
  have havg_pos : вҲҖб¶  X in Filter.atTop, b / 2 < leftTentAverage f X := by
    have hb2ltb : b / 2 < b := by linarith
    have hmem : Set.Ioi (b / 2) вҲҲ nhds b := Ioi_mem_nhds hb2ltb
    have hpre : вҲҖб¶  X in Filter.atTop, leftTentAverage f X вҲҲ Set.Ioi (b / 2) := havg hmem
    simpa [Set.mem_Ioi] using hpre
  rcases Filter.eventually_atTop.1 havg_pos with вҹЁXвӮҖ, hXвӮҖвҹ©
  refine вҹЁb / (2 * Real.exp 1), ?_, max XвӮҖ 1, ?_вҹ©
  В· have hexp : 0 < Real.exp 1 := Real.exp_pos 1
    positivity
  В· intro X hX
    have hXвӮҖX : XвӮҖ вүӨ X := le_trans (le_max_left _ _) hX
    have hX1 : 1 вүӨ X := le_trans (le_max_right _ _) hX
    have hhalf_lt : b / 2 < leftTentAverage f X := hXвӮҖ X hXвӮҖX
    have hb2pos : 0 < b / 2 := by linarith
    have hleft_ne_zero : leftTentAverage f X вү  0 := by
      intro hzero
      rw [hzero] at hhalf_lt
      linarith
    have hfi : IntervalIntegrable (fun t : в„қ => (2 * (t - (X - 1))) * U t) MeasureTheory.volume (X - 1) X := by
      apply intervalIntegral.intervalIntegrable_of_integral_ne_zero
      simpa [leftTentAverage, U] using hleft_ne_zero
    have hgi_base : IntervalIntegrable (fun t : в„қ => 2 * (t - (X - 1))) MeasureTheory.volume (X - 1) X := by
      exact (by continuity : Continuous (fun t : в„қ => 2 * (t - (X - 1)))).intervalIntegrable (X - 1) X
    have hgi : IntervalIntegrable (fun t : в„қ => (2 * (t - (X - 1))) * (Real.exp 1 * U X)) MeasureTheory.volume (X - 1) X := by
      simpa using hgi_base.mul_const (Real.exp 1 * U X)
    have havg_le : leftTentAverage f X вүӨ Real.exp 1 * U X := by
      unfold leftTentAverage
      change вҲ« t in X - 1..X, (2 * (t - (X - 1))) * U t вүӨ Real.exp 1 * U X
      calc
        вҲ« t in X - 1..X, (2 * (t - (X - 1))) * U t
          вүӨ вҲ« t in X - 1..X, (2 * (t - (X - 1))) * (Real.exp 1 * U X) := by
              apply intervalIntegral.integral_mono_on
              В· linarith
              В· exact hfi
              В· exact hgi
              В· intro t ht
                have hw_nonneg : 0 вүӨ 2 * (t - (X - 1)) := by nlinarith [ht.1]
                have ht_nonneg : 0 вүӨ t := by linarith [hX1, ht.1]
                have hXt_nonneg : 0 вүӨ X - t := by linarith [ht.2]
                have hsum : t + (X - t) = X := by ring
                have hU_le : U t вүӨ Real.exp (X - t) * U X := by
                  simpa [hsum] using hqm (x := t) (y := X - t) ht_nonneg hXt_nonneg
                have hXt_le_one : X - t вүӨ 1 := by linarith [ht.1]
                have hExp_le : Real.exp (X - t) вүӨ Real.exp 1 := Real.exp_monotone hXt_le_one
                have hU_le' : U t вүӨ Real.exp 1 * U X := by
                  calc
                    U t вүӨ Real.exp (X - t) * U X := hU_le
                    _ вүӨ Real.exp 1 * U X := mul_le_mul_of_nonneg_right hExp_le (hU_nonneg X)
                exact mul_le_mul_of_nonneg_left hU_le' hw_nonneg
        _ = Real.exp 1 * U X := by
              have hweight : вҲ« t in X - 1..X, (2 * (t - (X - 1)) : в„қ) = 1 := by
                have hshift : (вҲ« t in X - 1..X, (2 : в„қ) * (t - (X - 1))) = вҲ« u in (0 : в„қ)..1, (2 : в„қ) * u := by
                  simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
                    (intervalIntegral.integral_comp_sub_right (f := fun u : в„қ => (2 : в„қ) * u) (a := X - 1) (b := X) (d := X - 1))
                calc
                  вҲ« t in X - 1..X, (2 * (t - (X - 1)) : в„қ)
                      = вҲ« u in (0 : в„қ)..1, (2 : в„қ) * u := by simpa [mul_comm] using hshift
                  _ = (2 : в„қ) * вҲ« u in (0 : в„қ)..1, u := by rw [intervalIntegral.integral_const_mul]
                  _ = (2 : в„қ) * ((1 ^ 2 - (0 : в„қ) ^ 2) / 2) := by rw [integral_id]
                  _ = 1 := by norm_num
              rw [intervalIntegral.integral_mul_const, hweight, one_mul]
    have hmul_lt : b / 2 < Real.exp 1 * U X := lt_of_lt_of_le hhalf_lt havg_le
    have hden_pos : 0 < 2 * Real.exp 1 := by positivity
    have hc_lt : b / (2 * Real.exp 1) < U X := by
      rw [div_lt_iffвӮҖ hden_pos]
      have hmul2 : b < 2 * (Real.exp 1 * U X) := by linarith
      simpa [mul_assoc, mul_comm, mul_left_comm] using hmul2
    exact hc_lt.le

theorem leftTent_reflect_pairing_eq_shift_comp_sub {f : в„• вҶ’ в„қ} {b X : в„қ} :
  вҲ« t in (0 : в„қ)..1,
      (leftTentKernel ((1 / 2 : в„қ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
    =
      вҲ« t in (0 : в„қ)..1,
        (leftTentKernel (t - (1 / 2 : в„қ))).re *
          (logRescalePartialSum f (X + 1 - t) - b) := by
  convert
    (intervalIntegral.integral_comp_sub_left
      (f := fun s : в„қ =>
        (leftTentKernel (s - (1 / 2 : в„қ))).re *
          (logRescalePartialSum f (X + 1 - s) - b))
      (a := (0 : в„қ)) (b := (1 : в„қ)) (d := (1 : в„қ))) using 1
  В· congr with t
    ring
  В· ring_nf

theorem logRescalePartialSum_le_sum_floor_exp_bound {f : в„• вҶ’ в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’
  вҲҖ {x B : в„қ}, 0 вүӨ x вҶ’ x вүӨ B вҶ’
    logRescalePartialSum f x вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp BвҢӢвӮҠ, f k := by
  intro hnonneg x B hx0 hxB
  unfold logRescalePartialSum
  rw [if_pos hx0]
  have hsum_nonneg : 0 вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k := by
    exact Finset.sum_nonneg (by
      intro k hk
      exact hnonneg k)
  have hexp_le_one : Real.exp (-x) вүӨ 1 := by
    have hneg : -x вүӨ 0 := by linarith
    simpa using Real.exp_le_one_iff.mpr hneg
  have hfloor_le : вҢҠReal.exp xвҢӢвӮҠ вүӨ вҢҠReal.exp BвҢӢвӮҠ := by
    exact Nat.floor_le_floor (by
      gcongr)
  have hsum_le :
      вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp BвҢӢвӮҠ, f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnon
    В· intro k hk
      rw [Finset.mem_Icc] at hk вҠў
      exact вҹЁhk.1, le_trans hk.2 hfloor_leвҹ©
    В· intro k hk1 hk2
      exact hnonneg k
  have hmul_le :
      Real.exp (-x) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k) вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k := by
    nlinarith [mul_le_mul_of_nonneg_right hexp_le_one hsum_nonneg]
  exact le_trans hmul_le hsum_le

theorem logRescalePartialSum_nonneg {f : в„• вҶ’ в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’ вҲҖ x : в„қ, 0 вүӨ logRescalePartialSum f x := by
  intro hnonneg x
  by_cases hx : 0 вүӨ x
  В· simp [logRescalePartialSum, hx]
    exact mul_nonneg (Real.exp_nonneg (-x)) (Finset.sum_nonneg (by
      intro n hn
      exact hnonneg n))
  В· simp [logRescalePartialSum, hx]

theorem logRescalePartialSum_quasi_monotone {f : в„• вҶ’ в„қ} :
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    вҲҖ {x y : в„қ}, 0 вүӨ x вҶ’ 0 вүӨ y вҶ’
      logRescalePartialSum f x вүӨ Real.exp y * logRescalePartialSum f (x + y) := by
  intro hnonneg x y hx hy
  have hxy : 0 вүӨ x + y := add_nonneg hx hy
  simp only [logRescalePartialSum, if_pos hx, if_pos hxy]
  have hfloor : вҢҠReal.exp xвҢӢвӮҠ вүӨ вҢҠReal.exp (x + y)вҢӢвӮҠ := by
    apply Nat.floor_mono
    exact Real.exp_le_exp.mpr (le_add_of_nonneg_right hy)
  have hsum : вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp (x + y)вҢӢвӮҠ, f k := by
    refine Finset.sum_le_sum_of_subset_of_nonneg ?hsub ?hnn
    В· intro k hk
      exact Finset.mem_Icc.mpr вҹЁ(Finset.mem_Icc.mp hk).1, le_trans (Finset.mem_Icc.mp hk).2 hfloorвҹ©
    В· intro k hk hkn
      exact hnonneg k
  have hexp : Real.exp (-x) = Real.exp y * Real.exp (-(x + y)) := by
    calc
      Real.exp (-x) = Real.exp (y + (-(x + y))) := by
        congr 1
        ring
      _ = Real.exp y * Real.exp (-(x + y)) := by
        rw [Real.exp_add]
  rw [hexp, mul_assoc]
  exact mul_le_mul_of_nonneg_left
    (mul_le_mul_of_nonneg_left hsum (by positivity))
    (by positivity)

theorem measurable_logRescalePartialSum {f : в„• вҶ’ в„қ} : Measurable (logRescalePartialSum f) := by
  classical
  unfold logRescalePartialSum
  let F : в„• вҶ’ в„қ := fun n => вҲ‘ k вҲҲ Finset.Icc 1 n, f k
  have hF : Measurable F := by
    simpa [F] using (measurable_from_nat : Measurable F)
  have hfloor : Measurable fun x : в„қ => вҢҠReal.exp xвҢӢвӮҠ :=
    Measurable.nat_floor Real.measurable_exp
  have hsum : Measurable fun x : в„қ => F вҢҠReal.exp xвҢӢвӮҠ := hF.comp hfloor
  have hexpneg : Measurable fun x : в„қ => Real.exp (-x) :=
    Real.measurable_exp.comp measurable_neg
  refine Measurable.ite ?_ ?_ measurable_const
  В· exact measurableSet_Ici
  В· simpa [F] using hexpneg.mul hsum

theorem centered_leftTentAverage_eq_convolution_leftTentKernel {f : в„• вҶ’ в„қ} {b : в„қ} (X : в„қ) :
      (((leftTentAverage f X - b : в„қ) : в„Ӯ)) =
        вҲ« u : в„қ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) := by
  let N : в„• := вҢҠReal.exp (|X| + 1)вҢӢвӮҠ
  have hlog_bound :
      вҲҖ t вҲҲ Set.Icc (X - 1) X,
        |logRescalePartialSum f t| вүӨ
          Real.exp (|X| + 1) * вҲ‘ k вҲҲ Finset.Icc 1 N, |f k| := by
    intro t ht
    have ht_upper : t вүӨ |X| + 1 := by
      have h1 : t вүӨ X := ht.2
      have h2 : X вүӨ |X| := le_abs_self X
      linarith
    by_cases ht0 : 0 вүӨ t
    В· unfold logRescalePartialSum
      rw [if_pos ht0]
      have hfloor : вҢҠReal.exp tвҢӢвӮҠ вүӨ N := by
        apply Nat.floor_le_floor
        simpa [N] using Real.exp_le_exp.mpr ht_upper
      have hsum_abs :
          |вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, f k|
            вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, |f k| := by
        simpa using
          (Finset.abs_sum_le_sum_abs (fun k : в„• => f k) (Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ))
      have hsubset : Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ вҠҶ Finset.Icc 1 N := by
        intro k hk
        simp [Finset.mem_Icc] at hk вҠў
        exact вҹЁhk.1, le_trans hk.2 hfloorвҹ©
      have hsum_mono :
          вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, |f k|
            вүӨ вҲ‘ k вҲҲ Finset.Icc 1 N, |f k| := by
        exact Finset.sum_le_sum_of_subset_of_nonneg hsubset (by
          intro k hk hknot
          positivity)
      have hneg_t : -t вүӨ |X| + 1 := by
        have hmin : X - 1 вүӨ t := ht.1
        have hnegX : -X вүӨ |X| := by
          simpa [abs_neg] using (le_abs_self (-X))
        linarith
      have hexp : Real.exp (-t) вүӨ Real.exp (|X| + 1) := by
        exact Real.exp_le_exp.mpr hneg_t
      have hsum_nonneg : 0 вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, |f k| := by
        positivity
      calc
        |Real.exp (-t) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, f k)|
            = Real.exp (-t) * |вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, f k| := by
                rw [abs_mul, abs_of_nonneg (le_of_lt (Real.exp_pos _))]
        _ вүӨ Real.exp (-t) * вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp tвҢӢвӮҠ, |f k| := by
                gcongr
        _ вүӨ Real.exp (|X| + 1) * вҲ‘ k вҲҲ Finset.Icc 1 N, |f k| := by
                exact mul_le_mul hexp hsum_mono hsum_nonneg (by positivity)
    В· unfold logRescalePartialSum
      rw [if_neg ht0]
      have hC : 0 вүӨ Real.exp (|X| + 1) * вҲ‘ k вҲҲ Finset.Icc 1 N, |f k| := by
        positivity
      simpa using hC
  have hlog_on :
      MeasureTheory.IntegrableOn (logRescalePartialSum f) (Set.Icc (X - 1) X) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound (s := Set.Icc (X - 1) X) ?_ ?_
      (Real.exp (|X| + 1) * вҲ‘ k вҲҲ Finset.Icc 1 N, |f k|) ?_
    В· simp
    В· exact measurable_logRescalePartialSum.aestronglyMeasurable
    В· rw [MeasureTheory.ae_restrict_iff' measurableSet_Icc]
      exact Filter.Eventually.of_forall (fun t ht => by simpa using hlog_bound t ht)
  have hlog_int : IntervalIntegrable (logRescalePartialSum f) MeasureTheory.volume (X - 1) X := by
    apply MeasureTheory.IntegrableOn.intervalIntegrable
    simpa [Set.uIcc_of_le (by linarith : X - 1 вүӨ X)] using hlog_on
  have hweight_cont :
      ContinuousOn (fun t : в„қ => 2 * (t - (X - 1))) (Set.uIcc (X - 1) X) := by
    exact (continuous_const.mul (continuous_id.sub continuous_const)).continuousOn
  have hweighted_int :
      IntervalIntegrable (fun t : в„қ => (2 * (t - (X - 1))) * logRescalePartialSum f t)
        MeasureTheory.volume (X - 1) X := by
    exact hlog_int.continuousOn_mul hweight_cont
  have hb_int :
      IntervalIntegrable (fun t : в„қ => (2 * (t - (X - 1))) * b)
        MeasureTheory.volume (X - 1) X := by
    exact ((continuous_const.mul (continuous_id.sub continuous_const)).mul continuous_const).intervalIntegrable _ _
  have hweight_mass : вҲ« t in X - 1..X, (2 * (t - (X - 1)) : в„қ) = 1 := by
    rw [intervalIntegral.integral_const_mul]
    rw [intervalIntegral.integral_sub intervalIntegral.intervalIntegrable_id intervalIntegral.intervalIntegrable_const]
    rw [integral_id, intervalIntegral.integral_const]
    simp [one_smul]
    ring_nf
  have hb_eval : вҲ« t in X - 1..X, (2 * (t - (X - 1))) * b = b := by
    rw [intervalIntegral.integral_mul_const, hweight_mass]
    ring
  have hcenter_real :
      leftTentAverage f X - b =
        вҲ« t in X - 1..X, (2 * (t - (X - 1))) * (logRescalePartialSum f t - b) := by
    rw [leftTentAverage]
    calc
      (вҲ« t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t) - b
          = (вҲ« t in X - 1..X, (2 * (t - (X - 1))) * logRescalePartialSum f t) -
              вҲ« t in X - 1..X, (2 * (t - (X - 1))) * b := by rw [hb_eval]
      _ = вҲ« t in X - 1..X,
            ((2 * (t - (X - 1))) * logRescalePartialSum f t - (2 * (t - (X - 1))) * b) := by
          symm
          exact intervalIntegral.integral_sub hweighted_int hb_int
      _ = вҲ« t in X - 1..X, (2 * (t - (X - 1))) * (logRescalePartialSum f t - b) := by
          apply intervalIntegral.integral_congr
          intro t ht
          ring
  have hrhs :
      вҲ« u : в„қ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) =
        вҲ« t in X - 1..X, (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : в„қ) : в„Ӯ) := by
    have hsupport :
        Function.support (fun u : в„қ => leftTentKernel u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ))) вҠҶ
          Set.Ioc (-1 : в„қ) 0 := by
      exact Set.Subset.trans (Function.support_mul_subset_left _ _) leftTentKernel_support_subset
    rw [вҶҗ intervalIntegral.integral_eq_integral_of_support_subset hsupport]
    trans вҲ« u in (-1 : в„қ)..0, (((2 * (u + 1)) * (logRescalePartialSum f (X + u) - b) : в„қ) : в„Ӯ)
    В· apply intervalIntegral.integral_congr
      intro u hu
      have hu' : -1 вүӨ u вҲ§ u вүӨ 0 := by
        simpa [Set.uIcc_of_le (by norm_num : (-1 : в„қ) вүӨ 0)] using hu
      simp [leftTentKernel, hu', mul_assoc]
    В· let F : в„қ вҶ’ в„Ӯ := fun t =>
          (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : в„қ) : в„Ӯ)
      convert (intervalIntegral.integral_comp_add_left (f := F) (a := (-1 : в„қ)) (b := 0) X) using 1
      В· apply intervalIntegral.integral_congr
        intro u hu
        simp [F]
      В· rw [show X + (-1 : в„қ) = X - 1 by ring, show X + (0 : в„қ) = X by ring]
  calc
    (((leftTentAverage f X - b : в„қ) : в„Ӯ)) =
        вҲ« t in X - 1..X, (((2 * (t - (X - 1))) * (logRescalePartialSum f t - b) : в„қ) : в„Ӯ) := by
          rw [hcenter_real, вҶҗ intervalIntegral.integral_ofReal]
    _ = вҲ« u : в„қ, leftTentKernel u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) := by
          symm
          exact hrhs

theorem leftTent_reflect_pairing_intervalIntegrable {f : в„• вҶ’ в„қ} {b : в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’
  вҲҖ X : в„қ,
    IntervalIntegrable
      (fun t : в„қ =>
        (leftTentKernel ((1 / 2 : в„қ) - t)).re *
          (logRescalePartialSum f (X + t) - b))
      MeasureTheory.volume (0 : в„қ) 1 := by
  intro hf X
  classical
  let M : в„қ := вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp (max 0 (X + 1))вҢӢвӮҠ, f k
  have hM_nonneg : 0 вүӨ M := by
    dsimp [M]
    exact Finset.sum_nonneg (by intro n hn; exact hf n)
  have hkernel_bound : вҲҖ t : в„қ, |(leftTentKernel ((1 / 2 : в„қ) - t)).re| вүӨ 2 := by
    intro t
    by_cases hcond : -1 вүӨ (1 / 2 : в„қ) - t вҲ§ (1 / 2 : в„қ) - t вүӨ 0
    В· rw [leftTentKernel, if_pos hcond]
      simp only [Complex.ofReal_re]
      have hnonneg : 0 вүӨ 2 * (((1 / 2 : в„қ) - t) + 1) := by
        nlinarith [hcond.1]
      rw [abs_of_nonneg hnonneg]
      nlinarith [hcond.2]
    В· rw [leftTentKernel, if_neg hcond]
      norm_num
  have hlog_bound : вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1, |logRescalePartialSum f (X + t)| вүӨ M := by
    intro t ht
    rcases ht with вҹЁht0, ht1вҹ©
    by_cases hXt : 0 вүӨ X + t
    В· have hupper : X + t вүӨ max 0 (X + 1) := by
        have hleX1 : X + t вүӨ X + 1 := by linarith
        exact le_trans hleX1 (le_max_right 0 (X + 1))
      have hle := logRescalePartialSum_le_sum_floor_exp_bound hf hXt hupper
      have hnonneg := logRescalePartialSum_nonneg hf (X + t)
      rw [abs_of_nonneg hnonneg]
      simpa [M] using hle
    В· rw [logRescalePartialSum, if_neg hXt]
      simpa using hM_nonneg
  have hdiff_bound : вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1, |logRescalePartialSum f (X + t) - b| вүӨ M + |b| := by
    intro t ht
    have h1 : |logRescalePartialSum f (X + t) - b| вүӨ |logRescalePartialSum f (X + t)| + |b| := by
      simpa [Real.norm_eq_abs] using norm_sub_le (logRescalePartialSum f (X + t)) b
    have h2 := hlog_bound t ht
    nlinarith
  have hbound : вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1,
      вҖ–(leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b)вҖ– вүӨ
        2 * (M + |b|) := by
    intro t ht
    rw [Real.norm_eq_abs, abs_mul]
    have hk := hkernel_bound t
    have hd := hdiff_bound t ht
    have hk_nonneg : 0 вүӨ |(leftTentKernel ((1 / 2 : в„қ) - t)).re| := abs_nonneg _
    have hd_nonneg : 0 вүӨ |logRescalePartialSum f (X + t) - b| := abs_nonneg _
    have hC_nonneg : 0 вүӨ M + |b| := by
      nlinarith [hM_nonneg, abs_nonneg b]
    nlinarith
  have h_meas_kernel_complex : Measurable (fun t : в„қ => leftTentKernel ((1 / 2 : в„қ) - t)) := by
    unfold leftTentKernel
    refine Measurable.ite ?_ ?_ measurable_const
    В· let hshift : Measurable fun t : в„қ => (1 / 2 : в„қ) - t := measurable_const.sub measurable_id
      exact (measurableSet_le measurable_const hshift).inter (measurableSet_le hshift measurable_const)
    В· have hreal : Measurable fun t : в„қ => 2 * (((1 / 2 : в„қ) - t) + 1) := by
        let hshift : Measurable fun t : в„қ => (1 / 2 : в„қ) - t := measurable_const.sub measurable_id
        exact measurable_const.mul (hshift.add measurable_const)
      simpa using hreal.complex_ofReal
  have h_meas_kernel : Measurable (fun t : в„қ => (leftTentKernel ((1 / 2 : в„қ) - t)).re) :=
    h_meas_kernel_complex.re
  have h_meas_log : Measurable (fun t : в„қ => logRescalePartialSum f (X + t)) := by
    simpa using measurable_logRescalePartialSum.comp (measurable_const.add measurable_id)
  have h_meas_integrand : Measurable (fun t : в„қ =>
      (leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b)) := by
    exact h_meas_kernel.mul (h_meas_log.sub measurable_const)
  have h_ae : MeasureTheory.AEStronglyMeasurable
      (fun t : в„қ => (leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b))
      (MeasureTheory.volume.restrict (Set.Icc (0 : в„қ) 1)) :=
    h_meas_integrand.aestronglyMeasurable.restrict
  have h_ae_bound :
      вҲҖбөҗ t вҲӮMeasureTheory.volume.restrict (Set.Icc (0 : в„қ) 1),
        вҖ–(leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b)вҖ– вүӨ
          2 * (M + |b|) := by
    refine MeasureTheory.ae_restrict_of_forall_mem measurableSet_Icc ?_
    intro t ht
    exact hbound t ht
  have hInt : MeasureTheory.IntegrableOn
      (fun t : в„қ => (leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b))
      (Set.Icc (0 : в„қ) 1) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound ?_ h_ae (2 * (M + |b|)) h_ae_bound
    simp
  apply MeasureTheory.IntegrableOn.intervalIntegrable
  simpa [Set.uIcc_of_le] using hInt

theorem leftTent_reflect_pairing_eq_negativeShift {f : в„• вҶ’ в„қ} {b : в„қ} :
  (hf : вҲҖ n, 0 вүӨ f n) вҶ’ вҲҖ X : в„қ,
    вҲ« t in (0 : в„қ)..1,
      (leftTentKernel ((1 / 2 : в„қ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
    =
      вҲ« t in (-(1 / 2 : в„қ))..0,
        (1 - 2 * t) *
          (logRescalePartialSum f (X + 1 + t) - b) := by
  intro hf X
  let F : в„қ вҶ’ в„қ := fun t =>
    (leftTentKernel ((1 / 2 : в„қ) - t)).re * (logRescalePartialSum f (X + t) - b)
  have hInt : IntervalIntegrable F MeasureTheory.volume (0 : в„қ) 1 := by
    simpa [F] using leftTent_reflect_pairing_intervalIntegrable (f := f) (b := b) hf X
  have hmid : (1 / 2 : в„қ) вҲҲ Set.uIcc (0 : в„қ) (1 : в„қ) := by
    exact Set.mem_uIcc_of_le (by norm_num) (by norm_num)
  have hsplit :
      IntervalIntegrable F MeasureTheory.volume (0 : в„қ) (1 / 2 : в„қ) вҲ§
        IntervalIntegrable F MeasureTheory.volume (1 / 2 : в„қ) 1 := by
    exact
      (IntervalIntegrable.trans_iff (f := F) (Ој := MeasureTheory.volume)
        (a := (0 : в„қ)) (b := (1 / 2 : в„қ)) (c := (1 : в„қ)) hmid).mp hInt
  have hzero_ae :
      F =бөҗ[MeasureTheory.volume.restrict (Set.uIoc (0 : в„қ) (1 / 2 : в„қ))] fun _ => (0 : в„қ) := by
    rw [Set.uIoc_of_le (show (0 : в„қ) вүӨ (1 / 2 : в„қ) by norm_num)]
    rw [вҶҗ MeasureTheory.restrict_Ioo_eq_restrict_Ioc (Ој := MeasureTheory.volume)
      (a := (0 : в„қ)) (b := (1 / 2 : в„қ))]
    change вҲҖбөҗ x вҲӮMeasureTheory.volume.restrict (Set.Ioo (0 : в„қ) (1 / 2 : в„қ)), F x = 0
    rw [MeasureTheory.ae_restrict_iff' (Ој := MeasureTheory.volume)
      (s := Set.Ioo (0 : в„қ) (1 / 2 : в„қ)) measurableSet_Ioo]
    refine Filter.Eventually.of_forall ?_
    intro t ht
    have hnot : В¬ (-1 вүӨ (1 / 2 : в„қ) - t вҲ§ (1 / 2 : в„қ) - t вүӨ 0) := by
      intro hcond
      linarith [ht.2]
    unfold F
    rw [leftTentKernel, if_neg hnot]
    simp
  have hzero : вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t = 0 := by
    calc
      вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t
          = вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), (0 : в„қ) := by
              exact intervalIntegral.integral_congr_ae_restrict hzero_ae
      _ = 0 := by
            simp
  have hright_congr :
      вҲ« t in (1 / 2 : в„қ)..1, F t =
        вҲ« t in (1 / 2 : в„қ)..1,
          (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) := by
    apply intervalIntegral.integral_congr
    intro t ht
    have ht' : (1 / 2 : в„қ) вүӨ t вҲ§ t вүӨ 1 вҲЁ 1 вүӨ t вҲ§ t вүӨ (1 / 2 : в„қ) := by
      simpa using (Set.mem_uIcc.mp ht)
    have ht1 : (1 / 2 : в„қ) вүӨ t := by
      rcases ht' with h | h
      В· exact h.1
      В· linarith
    have ht2 : t вүӨ 1 := by
      rcases ht' with h | h
      В· exact h.2
      В· linarith
    have hcond : -1 вүӨ (1 / 2 : в„қ) - t вҲ§ (1 / 2 : в„қ) - t вүӨ 0 := by
      constructor <;> linarith
    have hker : (leftTentKernel ((1 / 2 : в„қ) - t)).re = 3 - 2 * t := by
      rw [leftTentKernel, if_pos hcond]
      simp
      ring_nf
    unfold F
    rw [hker]
  have hshift :
      вҲ« t in (1 / 2 : в„қ)..1,
        (3 - 2 * t) * (logRescalePartialSum f (X + t) - b)
      =
      вҲ« t in (-(1 / 2 : в„қ))..0,
        (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
    calc
      вҲ« t in (1 / 2 : в„қ)..1,
        (3 - 2 * t) * (logRescalePartialSum f (X + t) - b)
        = вҲ« t in (1 / 2 : в„қ)..1,
            (fun u : в„қ =>
              (1 - 2 * u) * (logRescalePartialSum f (X + 1 + u) - b)) (t - 1) := by
              apply intervalIntegral.integral_congr
              intro t ht
              change
                (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) =
                  (1 - 2 * (t - 1)) *
                    (logRescalePartialSum f (X + 1 + (t - 1)) - b)
              have h1 : (1 - 2 * (t - 1) : в„қ) = 3 - 2 * t := by ring
              have h2 : X + 1 + (t - 1) = X + t := by ring
              rw [h1, h2]
      _ = вҲ« t in ((1 / 2 : в„қ) - 1)..0,
            (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
              simpa using
                (intervalIntegral.integral_comp_sub_right
                  (f := fun u : в„қ =>
                    (1 - 2 * u) * (logRescalePartialSum f (X + 1 + u) - b))
                  (a := (1 / 2 : в„қ)) (b := (1 : в„қ)) (d := (1 : в„қ)))
      _ = вҲ« t in (-(1 / 2 : в„қ))..0,
            (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := by
              have hhalf : ((1 / 2 : в„қ) - 1) = -(1 / 2 : в„қ) := by ring
              rw [hhalf]
  have hadd :
      (вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t) + вҲ« t in (1 / 2 : в„қ)..1, F t
        = вҲ« t in (0 : в„қ)..1, F t := by
    exact intervalIntegral.integral_add_adjacent_intervals hsplit.1 hsplit.2
  calc
    вҲ« t in (0 : в„қ)..1,
      (leftTentKernel ((1 / 2 : в„қ) - t)).re *
        (logRescalePartialSum f (X + t) - b)
      = вҲ« t in (0 : в„қ)..1, F t := by
          rfl
    _ = (вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t) + вҲ« t in (1 / 2 : в„қ)..1, F t := by
          symm
          exact hadd
    _ = 0 + вҲ« t in (1 / 2 : в„қ)..1, F t := by rw [hzero]
    _ = вҲ« t in (1 / 2 : в„қ)..1, F t := by
          simp
    _ = вҲ« t in (1 / 2 : в„қ)..1,
          (3 - 2 * t) * (logRescalePartialSum f (X + t) - b) := hright_congr
    _ = вҲ« t in (-(1 / 2 : в„қ))..0,
          (1 - 2 * t) * (logRescalePartialSum f (X + 1 + t) - b) := hshift

theorem leftTent_shift_pairing_intervalIntegrable {f : в„• вҶ’ в„қ} {b : в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’
  вҲҖ X : в„қ,
    IntervalIntegrable
      (fun t : в„қ =>
        (leftTentKernel (t - (1 / 2 : в„қ))).re *
          (logRescalePartialSum f (X + t) - b))
      MeasureTheory.volume (0 : в„қ) 1 := by
  classical
  intro hf X
  let g : в„қ вҶ’ в„қ := fun t => logRescalePartialSum f (X + t) - b
  have hlog_meas : Measurable fun t : в„қ => logRescalePartialSum f (X + t) := by
    exact (measurable_logRescalePartialSum (f := f)).comp (measurable_const.add measurable_id)
  have hg_meas : Measurable g := by
    simpa [g] using hlog_meas.sub measurable_const
  let M : в„қ := вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp (max 0 (X + 1))вҢӢвӮҠ, f k
  have hM_nonneg : 0 вүӨ M := by
    unfold M
    exact Finset.sum_nonneg fun n hn => hf n
  have hg_bound : вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1, вҖ–g tвҖ– вүӨ M + |b| := by
    intro t ht
    rcases ht with вҹЁht0, ht1вҹ©
    by_cases hXt : 0 вүӨ X + t
    В· have hXt_le : X + t вүӨ max 0 (X + 1) := by
        have h1 : X + t вүӨ X + 1 := by linarith
        exact le_trans h1 (le_max_right 0 (X + 1))
      have hle := logRescalePartialSum_le_sum_floor_exp_bound (f := f) hf hXt hXt_le
      have hnonneg := logRescalePartialSum_nonneg (f := f) hf (X + t)
      unfold g
      rw [Real.norm_eq_abs]
      have htri : |logRescalePartialSum f (X + t) - b| вүӨ |logRescalePartialSum f (X + t)| + |b| := by
        simpa [Real.norm_eq_abs] using norm_sub_le (logRescalePartialSum f (X + t)) b
      rw [abs_of_nonneg hnonneg] at htri
      exact le_trans htri (by linarith)
    В· have hneg : X + t < 0 := by linarith
      have hzero : logRescalePartialSum f (X + t) = 0 := by
        simp [logRescalePartialSum, not_le_of_gt hneg]
      unfold g
      rw [Real.norm_eq_abs, hzero, zero_sub, abs_neg]
      linarith
  have hker_meas : Measurable fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re := by
    have hker_eqfun :
        (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re) =
          fun t : в„қ =>
            if -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0 then
              2 * (t - (1 / 2 : в„қ) + 1)
            else 0 := by
      funext t
      unfold leftTentKernel
      split_ifs <;> norm_num
    rw [hker_eqfun]
    have hset : MeasurableSet {t : в„қ | -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0} := by
      refine (measurableSet_le measurable_const (measurable_id.sub measurable_const)).inter ?_
      exact measurableSet_le (measurable_id.sub measurable_const) measurable_const
    have hbranch : Measurable fun t : в„қ => 2 * (t - (1 / 2 : в„қ) + 1) := by
      exact measurable_const.mul ((measurable_id.sub measurable_const).add measurable_const)
    exact Measurable.ite
      (p := fun t : в„қ => -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0)
      hset hbranch measurable_const
  have hker_bound : вҲҖ t : в„қ, вҖ–(leftTentKernel (t - (1 / 2 : в„қ))).reвҖ– вүӨ (2 : в„қ) := by
    intro t
    by_cases h : -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0
    В· have hnonneg : 0 вүӨ 2 * (t - (1 / 2 : в„қ) + 1) := by linarith [h.1, h.2]
      have hle2 : 2 * (t - (1 / 2 : в„қ) + 1) вүӨ 2 := by linarith [h.1, h.2]
      have hker_eq : (leftTentKernel (t - (1 / 2 : в„қ))).re = 2 * (t - (1 / 2 : в„қ) + 1) := by
        unfold leftTentKernel
        rw [if_pos h]
        norm_num
      rw [hker_eq, Real.norm_eq_abs, abs_of_nonneg hnonneg]
      exact hle2
    В· have hker_eq : (leftTentKernel (t - (1 / 2 : в„қ))).re = 0 := by
        unfold leftTentKernel
        rw [if_neg h]
        norm_num
      rw [hker_eq, Real.norm_eq_abs]
      norm_num
  have hprod_meas : Measurable fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re * g t := by
    exact hker_meas.mul hg_meas
  have hbound : вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1,
      вҖ–(leftTentKernel (t - (1 / 2 : в„қ))).re * g tвҖ– вүӨ 2 * (M + |b|) := by
    intro t ht
    have hk := hker_bound t
    have hg := hg_bound t ht
    rw [norm_mul]
    exact mul_le_mul hk hg (norm_nonneg _) (by positivity : 0 вүӨ (2 : в„қ))
  have h_int_on : MeasureTheory.IntegrableOn
      (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re * g t)
      (Set.Icc (0 : в„қ) 1) MeasureTheory.volume := by
    refine MeasureTheory.IntegrableOn.of_bound ?_ hprod_meas.aestronglyMeasurable (2 * (M + |b|)) ?_
    В· exact measure_Icc_lt_top
    В· exact MeasureTheory.ae_restrict_of_forall_mem measurableSet_Icc hbound
  have h_int_on_uIcc : MeasureTheory.IntegrableOn
      (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re * g t)
      (Set.uIcc (0 : в„қ) 1) MeasureTheory.volume := by
    simpa [Set.uIcc_of_le (show (0 : в„қ) вүӨ 1 by positivity)] using h_int_on
  simpa [g] using h_int_on_uIcc.intervalIntegrable

theorem leftTent_shift_pairing_eq_negativeShift {f : в„• вҶ’ в„қ} {b : в„қ} :
  (hf : вҲҖ n, 0 вүӨ f n) вҶ’ вҲҖ X : в„қ,
    вҲ« t in (0 : в„қ)..1,
      (leftTentKernel (t - (1 / 2 : в„қ))).re *
        (logRescalePartialSum f (X + t) - b)
    =
      вҲ« t in (-(1 / 2 : в„қ))..0,
        ((2 * (t + 1) : в„қ)) *
          (logRescalePartialSum f (X + (1 / 2 : в„қ) + t) - b) := by
  intro hf X
  let F : в„қ вҶ’ в„қ := fun t =>
    (leftTentKernel (t - (1 / 2 : в„қ))).re *
      (logRescalePartialSum f (X + t) - b)
  have hFint : IntervalIntegrable F MeasureTheory.volume (0 : в„қ) 1 := by
    simpa [F] using leftTent_shift_pairing_intervalIntegrable (f := f) (b := b) hf X
  have hmid : (1 / 2 : в„қ) вҲҲ Set.uIcc (0 : в„қ) 1 := by
    exact Set.mem_uIcc_of_le (by norm_num) (by norm_num)
  have hFsplit :=
    (IntervalIntegrable.trans_iff
      (f := F) (Ој := MeasureTheory.volume)
      (a := (0 : в„қ)) (b := (1 / 2 : в„қ)) (c := (1 : в„қ)) hmid).1 hFint
  have hF01 : IntervalIntegrable F MeasureTheory.volume (0 : в„қ) (1 / 2 : в„қ) := hFsplit.1
  have hF12 : IntervalIntegrable F MeasureTheory.volume (1 / 2 : в„қ) 1 := hFsplit.2
  have hsplit :
      вҲ« t in (0 : в„қ)..1, F t
        = (вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t) + вҲ« t in (1 / 2 : в„қ)..1, F t := by
    simpa using (intervalIntegral.integral_add_adjacent_intervals hF01 hF12).symm
  have hright_zero : вҲ« t in (1 / 2 : в„қ)..1, F t = 0 := by
    apply intervalIntegral.integral_zero_ae
    refine Filter.Eventually.of_forall ?_
    intro t ht
    rw [Set.mem_uIoc] at ht
    rcases ht with ht | ht
    В· have hkernel : leftTentKernel (t - (1 / 2 : в„қ)) = 0 := by
        rw [leftTentKernel]
        apply if_neg
        intro h
        linarith [h.2, ht.1]
      change (leftTentKernel (t - (1 / 2 : в„қ))).re * (logRescalePartialSum f (X + t) - b) = 0
      rw [hkernel]
      simp
    В· linarith
  have hleft_explicit :
      вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t
        = вҲ« t in (0 : в„қ)..(1 / 2 : в„қ),
            ((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) *
              (logRescalePartialSum f (X + t) - b) := by
    apply intervalIntegral.integral_congr
    intro t ht
    have ht' : t вҲҲ Set.Icc (0 : в„қ) (1 / 2 : в„қ) := by
      simpa [Set.uIcc_of_le (show (0 : в„қ) вүӨ (1 / 2 : в„қ) by norm_num)] using ht
    have hcond : -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0 := by
      constructor <;> linarith [ht'.1, ht'.2]
    have hkernel :
        leftTentKernel (t - (1 / 2 : в„қ)) =
          (((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) : в„Ӯ) := by
      rw [leftTentKernel]
      rw [if_pos hcond]
    change (leftTentKernel (t - (1 / 2 : в„қ))).re * (logRescalePartialSum f (X + t) - b) =
      ((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) * (logRescalePartialSum f (X + t) - b)
    rw [hkernel]
    simp
  let G : в„қ вҶ’ в„қ := fun t =>
    ((2 * (t + 1) : в„қ)) *
      (logRescalePartialSum f (X + (1 / 2 : в„қ) + t) - b)
  have hleft_shift :
      вҲ« t in (0 : в„қ)..(1 / 2 : в„қ),
        ((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) *
          (logRescalePartialSum f (X + t) - b)
      = вҲ« t in (-(1 / 2 : в„қ))..0, G t := by
    simpa [G, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
      (intervalIntegral.integral_comp_sub_right
        (f := G) (a := (0 : в„қ)) (b := (1 / 2 : в„қ)) (d := (1 / 2 : в„қ)))
  calc
    вҲ« t in (0 : в„қ)..1,
        (leftTentKernel (t - (1 / 2 : в„қ))).re *
          (logRescalePartialSum f (X + t) - b)
      = вҲ« t in (0 : в„қ)..1, F t := by
          rfl
    _ = (вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t) + вҲ« t in (1 / 2 : в„қ)..1, F t := hsplit
    _ = (вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t) + 0 := by rw [hright_zero]
    _ = вҲ« t in (0 : в„қ)..(1 / 2 : в„қ), F t := by
          simp
    _ = вҲ« t in (0 : в„қ)..(1 / 2 : в„қ),
          ((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) *
            (logRescalePartialSum f (X + t) - b) := hleft_explicit
    _ = вҲ« t in (-(1 / 2 : в„қ))..0, G t := hleft_shift
    _ = вҲ« t in (-(1 / 2 : в„қ))..0,
          ((2 * (t + 1) : в„қ)) *
            (logRescalePartialSum f (X + (1 / 2 : в„қ) + t) - b) := by
          rfl

theorem logRescalePartialSum_intervalIntegrable (f : в„• вҶ’ в„қ) (b a d : в„қ) :
  IntervalIntegrable
    (fun y : в„қ => logRescalePartialSum f y - b)
    MeasureTheory.volume a d := by
  rw [intervalIntegrable_iff]
  let N : в„• := вҢҠReal.exp (max a d)вҢӢвӮҠ
  let C : в„қ := вҲ‘ k вҲҲ Finset.Icc 1 N, вҖ–f kвҖ–
  refine MeasureTheory.Measure.integrableOn_of_bounded ?_ ?_ (M := C + вҖ–bвҖ–) ?_
  В· rw [Real.volume_uIoc]
    exact ENNReal.ofReal_ne_top
  В· exact (measurable_logRescalePartialSum.sub measurable_const).aestronglyMeasurable
  В· rw [MeasureTheory.ae_restrict_iff' measurableSet_uIoc]
    refine Filter.Eventually.of_forall ?_
    intro y hy
    have hy' : y вүӨ max a d := by
      rcases (Set.mem_uIoc.mp hy) with h | h
      В· exact le_max_of_le_right h.2
      В· exact le_max_of_le_left h.2
    have hfloor : вҢҠReal.exp yвҢӢвӮҠ вүӨ N := by
      dsimp [N]
      gcongr
    have hsum : вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, f kвҖ– вүӨ C := by
      calc
        вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, f kвҖ– вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, вҖ–f kвҖ– := by
          simpa using (norm_sum_le (Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ) fun k => f k)
        _ вүӨ вҲ‘ k вҲҲ Finset.Icc 1 N, вҖ–f kвҖ– := by
          dsimp [C]
          refine Finset.sum_le_sum_of_subset_of_nonneg (Finset.Icc_subset_Icc le_rfl hfloor) ?_
          intro x hx hx'
          positivity
    have hlog : вҖ–logRescalePartialSum f yвҖ– вүӨ C := by
      by_cases hy0 : 0 вүӨ y
      В· rw [logRescalePartialSum, if_pos hy0]
        calc
          вҖ–Real.exp (-y) * вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, f kвҖ–
              = Real.exp (-y) * вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, f kвҖ– := by
                  rw [norm_mul, Real.norm_of_nonneg (by positivity)]
          _ вүӨ 1 * вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp yвҢӢвӮҠ, f kвҖ– := by
                gcongr
                have : -y вүӨ 0 := by linarith
                have hexp : Real.exp (-y) вүӨ Real.exp 0 := by gcongr
                simpa using hexp
          _ вүӨ 1 * C := by gcongr
          _ = C := by ring
      В· rw [logRescalePartialSum, if_neg hy0]
        dsimp [C]
        have : 0 вүӨ C := by positivity
        simpa [norm_zero] using this
    calc

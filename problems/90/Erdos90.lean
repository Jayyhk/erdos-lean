theorem unitIntervalAverage_tendsto_of_tendsto_sum_div {f : в„• вҶ’ в„қ} {b : в„қ} :
  (hsumdiv : Filter.Tendsto (fun n : в„• => (вҲ‘ k вҲҲ Finset.Icc 1 n, f k) / (n : в„қ))
      Filter.atTop (nhds b)) вҶ’
  Filter.Tendsto (fun X : в„қ => вҲ« t in X - 1..X, logRescalePartialSum f t)
    Filter.atTop (nhds b) := by
  intro hsumdiv
  have hsumdiv_floor :
      Filter.Tendsto
        (fun x : в„қ => (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k) / (вҢҠReal.exp xвҢӢвӮҠ : в„қ))
        Filter.atTop (nhds b) := by
    exact hsumdiv.comp (tendsto_nat_floor_atTop.comp Real.tendsto_exp_atTop)
  have hfloor_div :
      Filter.Tendsto (fun x : в„қ => (вҢҠReal.exp xвҢӢвӮҠ : в„қ) / Real.exp x) Filter.atTop (nhds 1) := by
    exact tendsto_nat_floor_div_atTop.comp Real.tendsto_exp_atTop
  have hprod :
      Filter.Tendsto
        (fun x : в„қ =>
          ((вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k) / (вҢҠReal.exp xвҢӢвӮҠ : в„қ)) *
            ((вҢҠReal.exp xвҢӢвӮҠ : в„қ) / Real.exp x))
        Filter.atTop (nhds b) := by
    simpa using hsumdiv_floor.mul hfloor_div
  have hlog : Filter.Tendsto (fun x : в„қ => logRescalePartialSum f x) Filter.atTop (nhds b) := by
    refine Filter.Tendsto.congr' ?_ hprod
    filter_upwards [Filter.eventually_ge_atTop (0 : в„қ)] with x hx
    rw [logRescalePartialSum, if_pos hx, Real.exp_neg]
    have hxexp : 1 вүӨ Real.exp x := by
      rw [вҶҗ Real.exp_zero]
      exact (Real.exp_le_exp).2 hx
    have hfloor_pos : 0 < вҢҠReal.exp xвҢӢвӮҠ := Nat.floor_pos.2 hxexp
    have hfloor_ne : (вҢҠReal.exp xвҢӢвӮҠ : в„қ) вү  0 := by
      exact_mod_cast (Nat.ne_of_gt hfloor_pos)
    field_simp [hfloor_ne, Real.exp_ne_zero]
  have hA : Measurable (fun n : в„• => вҲ‘ k вҲҲ Finset.Icc 1 n, f k) := measurable_from_nat
  have hsum_meas :
      Measurable fun x : в„қ => вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k := by
    exact hA.comp ((Real.measurable_exp).nat_floor)
  have hmeas : Measurable (logRescalePartialSum f) := by
    unfold logRescalePartialSum
    refine Measurable.ite measurableSet_Ici ?_ measurable_const
    exact (Real.measurable_exp.comp measurable_id.neg).mul hsum_meas
  refine Metric.tendsto_atTop.2 ?_
  intro Оө hОө
  have hОө2 : 0 < Оө / 2 := by positivity
  rcases (Metric.tendsto_atTop.1 hlog) (Оө / 2) hОө2 with вҹЁR, hRвҹ©
  refine вҹЁR + 1, ?_вҹ©
  intro X hX
  have hXle : X - 1 вүӨ X := by linarith
  have hXR : R вүӨ X - 1 := by linarith
  have hbound_Ioc : вҲҖ t вҲҲ Set.Ioc (X - 1) X, вҖ–logRescalePartialSum f t - bвҖ– вүӨ Оө / 2 := by
    intro t ht
    have htR : R вүӨ t := by linarith [ht.1, hXR]
    have htОө : dist (logRescalePartialSum f t) b < Оө / 2 := hR t htR
    simpa [dist_eq_norm] using le_of_lt htОө
  have hbound_uIoc : вҲҖ t вҲҲ Set.uIoc (X - 1) X, вҖ–logRescalePartialSum f t - bвҖ– вүӨ Оө / 2 := by
    intro t ht
    have ht' : t вҲҲ Set.Ioc (X - 1) X := by
      simpa [Set.uIoc_of_le hXle] using ht
    exact hbound_Ioc t ht'
  have hbound_norm : вҲҖ t вҲҲ Set.Ioc (X - 1) X, вҖ–logRescalePartialSum f tвҖ– вүӨ Оө / 2 + вҖ–bвҖ– := by
    intro t ht
    calc
      вҖ–logRescalePartialSum f tвҖ– = вҖ–(logRescalePartialSum f t - b) + bвҖ– := by ring_nf
      _ вүӨ вҖ–logRescalePartialSum f t - bвҖ– + вҖ–bвҖ– := norm_add_le _ _
      _ вүӨ Оө / 2 + вҖ–bвҖ– := add_le_add (hbound_Ioc t ht) le_rfl
  have hlog_int_on :
      MeasureTheory.IntegrableOn (logRescalePartialSum f) (Set.Ioc (X - 1) X)
        MeasureTheory.MeasureSpace.volume := by
    refine MeasureTheory.Measure.integrableOn_of_bounded
      (Ој := MeasureTheory.MeasureSpace.volume) (s := Set.Ioc (X - 1) X)
      (M := Оө / 2 + вҖ–bвҖ–) ?_ hmeas.aestronglyMeasurable ?_
    В· simp [Real.volume_Ioc]
    В· rw [MeasureTheory.ae_restrict_iff' measurableSet_Ioc]
      filter_upwards with t ht
      exact hbound_norm t ht
  have hlog_int :
      IntervalIntegrable (logRescalePartialSum f) MeasureTheory.MeasureSpace.volume (X - 1) X := by
    exact (intervalIntegrable_iff_integrableOn_Ioc_of_le hXle).2 hlog_int_on
  have hconst : вҲ« t in X - 1..X, b = b := by
    simp
  have hsub :
      (вҲ« t in X - 1..X, logRescalePartialSum f t) - b =
        вҲ« t in X - 1..X, (logRescalePartialSum f t - b) := by
    calc
      (вҲ« t in X - 1..X, logRescalePartialSum f t) - b
          = (вҲ« t in X - 1..X, logRescalePartialSum f t) - вҲ« t in X - 1..X, b := by rw [hconst]
      _ = вҲ« t in X - 1..X, (logRescalePartialSum f t - b) := by
        symm
        exact intervalIntegral.integral_sub hlog_int intervalIntegral.intervalIntegrable_const
  have hlen' : X - (X - 1) = 1 := by ring
  have hlen : |X - (X - 1)| = 1 := by
    rw [hlen']
    norm_num
  have hnorm : вҖ–(вҲ« t in X - 1..X, logRescalePartialSum f t) - bвҖ– вүӨ Оө / 2 := by
    rw [hsub]
    have htmp :=
      intervalIntegral.norm_integral_le_of_norm_le_const
        (a := X - 1) (b := X) (C := Оө / 2)
        (f := fun t : в„қ => logRescalePartialSum f t - b) hbound_uIoc
    simpa [hlen] using htmp
  have hlt : Оө / 2 < Оө := by linarith
  simpa [dist_eq_norm] using lt_of_le_of_lt hnorm hlt

theorem weighted_dirichlet_series_monotone {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    Monotone (fun m : в„• =>
      if m = 0 then 0 else вҲ‘' k, f k / (k : в„қ) ^ (1 + (m : в„қ)вҒ»В№)) := by
  intro hf hsum m n hmn
  by_cases hm : m = 0
  В· subst hm
    by_cases hn : n = 0
    В· simp [hn]
    В· simp [hn]
      have hq_pos : 0 < (1 + (n : в„қ)вҒ»В№ : в„қ) := by
        have hnpos : (0 : в„қ) < (n : в„қ) := by
          exact_mod_cast Nat.pos_of_ne_zero hn
        have hinv : 0 < (n : в„қ)вҒ»В№ := inv_pos.mpr hnpos
        linarith
      have h_eq :
          (вҲ‘' k, f k / (k : в„қ) ^ (1 + (n : в„қ)вҒ»В№)) =
            вҲ‘' k, (if k = 0 then 0 else f k / (k : в„қ) ^ (1 + (n : в„қ)вҒ»В№)) := by
        apply tsum_congr
        intro k
        by_cases hk : k = 0
        В· subst hk
          simp [Real.zero_rpow (ne_of_gt hq_pos)]
        В· simp [hk]
      rw [h_eq]
      exact tsum_nonneg (fun k => by
        by_cases hk : k = 0
        В· simp [hk]
        В· simp [hk]
          have hkpos : (0 : в„қ) < (k : в„қ) := by
            exact_mod_cast Nat.pos_of_ne_zero hk
          exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _)))
  В· have hn : n вү  0 := by
      intro h0
      apply hm
      exact Nat.eq_zero_of_le_zero (by simpa [h0] using hmn)
    have hmpos : (0 : в„қ) < (m : в„қ) := by
      exact_mod_cast Nat.pos_of_ne_zero hm
    have hnpos : (0 : в„қ) < (n : в„қ) := by
      exact_mod_cast Nat.pos_of_ne_zero hn
    let qm : в„қ := 1 + (m : в„қ)вҒ»В№
    let qn : в„қ := 1 + (n : в„қ)вҒ»В№
    have hqm_pos : 0 < qm := by
      dsimp [qm]
      have h : 0 < (m : в„қ)вҒ»В№ := inv_pos.mpr hmpos
      linarith
    have hqn_pos : 0 < qn := by
      dsimp [qn]
      have h : 0 < (n : в„қ)вҒ»В№ := inv_pos.mpr hnpos
      linarith
    have hqn_gt1 : 1 < qn := by
      dsimp [qn]
      have h : 0 < (n : в„қ)вҒ»В№ := inv_pos.mpr hnpos
      linarith
    have hqle : qn вүӨ qm := by
      dsimp [qn, qm]
      have hmn' : (m : в„қ) вүӨ (n : в„қ) := by
        exact_mod_cast hmn
      have hinv : (n : в„қ)вҒ»В№ вүӨ (m : в„қ)вҒ»В№ := by
        simpa [one_div] using one_div_le_one_div_of_le hmpos hmn'
      linarith
    let a : в„• вҶ’ в„қ := fun k => if k = 0 then 0 else f k / (k : в„қ) ^ qm
    let b : в„• вҶ’ в„қ := fun k => if k = 0 then 0 else f k / (k : в„қ) ^ qn
    have ha_nonneg : вҲҖ k, 0 вүӨ a k := by
      intro k
      by_cases hk : k = 0
      В· simp [a, hk]
      В· simp [a, hk]
        have hkpos : (0 : в„қ) < (k : в„қ) := by
          exact_mod_cast Nat.pos_of_ne_zero hk
        exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _))
    have hb_nonneg : вҲҖ k, 0 вүӨ b k := by
      intro k
      by_cases hk : k = 0
      В· simp [b, hk]
      В· simp [b, hk]
        have hkpos : (0 : в„қ) < (k : в„қ) := by
          exact_mod_cast Nat.pos_of_ne_zero hk
        exact div_nonneg (hf k) (le_of_lt (Real.rpow_pos_of_pos hkpos _))
    have hab : вҲҖ k, a k вүӨ b k := by
      intro k
      by_cases hk : k = 0
      В· simp [a, b, hk]
      В· simp [a, b, hk]
        have hkpos_nat : 0 < k := Nat.pos_of_ne_zero hk
        have hkpos : (0 : в„қ) < (k : в„қ) := by
          exact_mod_cast hkpos_nat
        have hkone : (1 : в„қ) вүӨ (k : в„қ) := by
          exact_mod_cast Nat.succ_le_of_lt hkpos_nat
        have hpow : (k : в„қ) ^ qn вүӨ (k : в„қ) ^ qm := by
          exact Real.rpow_le_rpow_of_exponent_le hkone hqle
        have hpowpos : 0 < (k : в„қ) ^ qn := Real.rpow_pos_of_pos hkpos _
        exact div_le_div_of_nonneg_left (hf k) hpowpos hpow
    have hls : LSeriesSummable (fun n => (f n : в„Ӯ)) (qn : в„Ӯ) := by
      exact hsum (qn : в„Ӯ) (by simpa using hqn_gt1)
    have hsummable_b_norm : Summable (fun k => вҖ–LSeries.term (fun n => (f n : в„Ӯ)) (qn : в„Ӯ) kвҖ–) := by
      rw [LSeriesSummable, вҶҗ summable_norm_iff] at hls
      exact hls
    have hsummable_b : Summable b := by
      simpa [b, qn, LSeries.norm_term_eq, Real.norm_eq_abs, abs_of_nonneg, hf] using hsummable_b_norm
    have htsum_a :
        (вҲ‘' k, f k / (k : в„қ) ^ qm) = вҲ‘' k, a k := by
      apply tsum_congr
      intro k
      by_cases hk : k = 0
      В· subst hk
        simp [a, Real.zero_rpow (ne_of_gt hqm_pos)]
      В· simp [a, hk]
    have htsum_b :
        (вҲ‘' k, f k / (k : в„қ) ^ qn) = вҲ‘' k, b k := by
      apply tsum_congr
      intro k
      by_cases hk : k = 0
      В· subst hk
        simp [b, Real.zero_rpow (ne_of_gt hqn_pos)]
      В· simp [b, hk]
    simp [hm, hn]
    change (вҲ‘' k, f k / (k : в„қ) ^ qm) вүӨ вҲ‘' k, f k / (k : в„қ) ^ qn
    rw [htsum_a, htsum_b]

        have hm_mem_J : (m : рқ“һ K) вҲҲ J := by
          exact (show M вүӨ J from le_sup_right) (Ideal.subset_span (by simp))
        have hn_mem_L : (n : рқ“һ K) вҲҲ L := by
          exact (show N вүӨ L from le_sup_right) (Ideal.subset_span (by simp))
        have hJcop : (Ideal.absNorm J).Coprime n := helper hJ0 hm_mem_J hcop
        have hLcop : (Ideal.absNorm L).Coprime m := helper hL0 hn_mem_L hcop.symm
        have hJdvdm : Ideal.absNorm J вҲЈ m := by
          apply hJcop.dvd_of_dvd_mul_right

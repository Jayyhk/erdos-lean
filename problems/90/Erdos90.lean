theorem finiteGalois_splitCompletely_primes_exists_outside (L : Type) [Field L] [NumberField L] [Algebra ℚ L]
    [FiniteDimensional ℚ L] [IsGalois ℚ L]
    (badPrimes : Finset ℕ) :
    ∃ q : ℕ, q.Prime ∧ q ∉ badPrimes ∧
      (∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧

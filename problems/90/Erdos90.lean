    _ = 1 := hram

theorem IsEverywhereUnramified.transport_real {F M N : Type}
    [Field F] [Field M] [Field N] [NumberField F] [NumberField M] [NumberField N]
    [Algebra F M] [Algebra F N] (e : M ≃ₐ[F] N) (h : IsEverywhereUnramified F M) :
    ∀ w : NumberField.InfinitePlace F, w.IsReal →
      ∀ w' : NumberField.InfinitePlace N,
        w'.comap (algebraMap F N) = w → w'.IsReal := by
  intro w hw w' hw'
  let v : NumberField.InfinitePlace M := w'.comap (e : M →+* N)
  have hvcomap : v.comap (algebraMap F M) = w := by
    dsimp [v]
    rw [← NumberField.InfinitePlace.comap_comp]
    change w'.comap ((e.toAlgHom : M →+* N).comp (algebraMap F M)) = w
    rw [AlgHom.comp_algebraMap]
    exact hw'
  have hvreal : v.IsReal := h.real_lifts_real w hw v hvcomap
  exact (NumberField.InfinitePlace.isReal_comap_iff e.toRingEquiv).mp hvreal

theorem IsEverywhereUnramified.transport {F M N : Type}
    [Field F] [Field M] [Field N] [NumberField F] [NumberField M] [NumberField N]
    [Algebra F M] [Algebra F N] (e : M ≃ₐ[F] N) (h : IsEverywhereUnramified F M) :
    IsEverywhereUnramified F N :=
  IsEverywhereUnramified.of_local F N (IsEverywhereUnramified.transport_finite e h)
    (IsEverywhereUnramified.transport_real e h)

theorem IsEverywhereUnramified.descend
    {F : Type} [Field F] [NumberField F]
    {M : Type} [Field M] [NumberField M] [Algebra F M]
    {L : Type} [Field L] [NumberField L] [Algebra F L]
    [Algebra L M] [IsScalarTower F L M]
    (hM : IsEverywhereUnramified F M) :
    IsEverywhereUnramified F L := by
  rcases hM with ⟨hfinM, hinfM⟩
  refine IsEverywhereUnramified.of_local F L ?_ ?_
  ·
    intro 𝔭 𝔓 hp hne hP
    letI : 𝔭.IsPrime := hp
    let P' : 𝔭.primesOver (𝓞 L) := ⟨𝔓, hP⟩
    letI : 𝔓.IsPrime := Ideal.primesOver.isPrime 𝔭 P'
    letI : 𝔓.LiesOver 𝔭 := Ideal.primesOver.liesOver 𝔭 P'
    obtain ⟨Q⟩ := Ideal.nonempty_primesOver (R := 𝓞 L) (S := 𝓞 M) 𝔓
    letI : (Q : Ideal (𝓞 M)).LiesOver 𝔓 := Ideal.primesOver.liesOver 𝔓 Q
    letI : (Q : Ideal (𝓞 M)).LiesOver 𝔭 :=
      Ideal.LiesOver.trans (𝔓 := (Q : Ideal (𝓞 M))) (P := 𝔓) (p := 𝔭)
    have hQmem : (Q : Ideal (𝓞 M)) ∈ 𝔭.primesOver (𝓞 M) :=
      (Ideal.primesOver.mk 𝔭 (Q : Ideal (𝓞 M))).2
    have hQe : Ideal.ramificationIdx 𝔭 (Q : Ideal (𝓞 M)) = 1 :=
      hfinM 𝔭 (Q : Ideal (𝓞 M)) hp hne hQmem
    have hQne : (Q : Ideal (𝓞 M)) ≠ ⊥ :=
      Ideal.ne_bot_of_liesOver_of_ne_bot hne (Q : Ideal (𝓞 M))
    rw [Ideal.over_def (A := 𝓞 F) (P := (Q : Ideal (𝓞 M))) (p := 𝔭)] at hQe
    have hQunram : Algebra.IsUnramifiedAt (𝓞 F) (Q : Ideal (𝓞 M)) :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := 𝓞 F) (S := 𝓞 M) (p := (Q : Ideal (𝓞 M))) hQne).2 hQe
    have hPunram : Algebra.IsUnramifiedAt (𝓞 F) 𝔓 :=
      Algebra.IsUnramifiedAt.of_liesOver (R := 𝓞 F) (p := 𝔓) (P := (Q : Ideal (𝓞 M)))
    have hPe : Ideal.ramificationIdx (Ideal.under (𝓞 F) 𝔓) 𝔓 = 1 :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := 𝓞 F) (S := 𝓞 L) (p := 𝔓)
        (Ideal.ne_bot_of_liesOver_of_ne_bot hne 𝔓)).1 hPunram
    simpa [Ideal.over_def (A := 𝓞 F) (P := 𝔓) (p := 𝔭)] using hPe
  ·
    intro w hw w' hw'
    obtain ⟨w'', hw''⟩ :=
      NumberField.InfinitePlace.comap_surjective (k := L) (K := M) w'
    have hw''F : (w''.comap (algebraMap L M)).comap (algebraMap F L) =
        w'.comap (algebraMap F L) := by
      simpa using congrArg (fun x => x.comap (algebraMap F L)) hw''
    have hwM : w''.comap (algebraMap F M) = w := by
      calc
        w''.comap (algebraMap F M)
            = w''.comap ((algebraMap L M).comp (algebraMap F L)) := by
              rw [IsScalarTower.algebraMap_eq F L M]
        _ = (w''.comap (algebraMap L M)).comap (algebraMap F L) := by
              rw [NumberField.InfinitePlace.comap_comp]
        _ = w'.comap (algebraMap F L) := hw''F
        _ = w := hw'
    have hw''real : w''.IsReal := hinfM w hw w'' hwM
    have hw'real : (w''.comap (algebraMap L M)).IsReal :=
      NumberField.InfinitePlace.IsReal.comap (algebraMap L M) hw''real
    simpa [hw''] using hw'real

theorem IsEverywhereUnramified.descend_intermediateField
    {F : Type} [Field F] [NumberField F]
    {A : Type} [Field A] [Algebra F A]
    {L M : IntermediateField F A}
    [NumberField L] [NumberField M]
    (hLM : L ≤ M)
    (hM : IsEverywhereUnramified F M) :
    IsEverywhereUnramified F L := by
  letI : Algebra L M := (IntermediateField.inclusion hLM).toAlgebra
  haveI : IsScalarTower F L M := IsScalarTower.of_algebraMap_eq' rfl
  exact IsEverywhereUnramified.descend (L := (L : Type _)) (M := (M : Type _)) hM


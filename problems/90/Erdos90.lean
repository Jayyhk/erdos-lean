theorem primesCongOneMod3_weighted_prime_series_avg_lower_bound: вҲғ c : в„қ, 0 < c вҲ§ вҲғ MвӮҖ : в„•, вҲҖ M : в„•, MвӮҖ вүӨ M вҶ’
    c * (M : в„қ) вүӨ
      вҲ‘' n : в„•,
        (if n.Prime вҲ§ n % 3 = 1 then Real.log (n : в„қ) else 0) /
          (n : в„қ) ^ (1 + (M : в„қ)вҒ»В№) := by
  rcases primesCongOneMod3_prime_series_lower_bound with вҹЁC, hCвҹ©
  refine вҹЁ(1 : в„қ) / 4, by norm_num, ?_вҹ©
  let MвӮҖ : в„• := max 1 (Nat.ceil (4 * max C 0))
  refine вҹЁMвӮҖ, ?_вҹ©
  intro M hM
  have hM' : max 1 (Nat.ceil (4 * max C 0)) вүӨ M := by
    simpa [MвӮҖ] using hM
  let x : в„қ := 1 + (M : в„қ)вҒ»В№
  have hM1 : 1 вүӨ M := le_trans (le_max_left 1 (Nat.ceil (4 * max C 0))) hM'
  have hM0_nat : 0 < M := lt_of_lt_of_le (by decide : 0 < 1) hM1
  have hMpos : 0 < (M : в„қ) := by
    exact_mod_cast hM0_nat
  have hMinv_le_one : (M : в„қ)вҒ»В№ вүӨ 1 := by
    have hMge1 : (1 : в„қ) вүӨ (M : в„қ) := by exact_mod_cast hM1
    simpa [one_div] using
      (one_div_le_one_div_of_le (show (0 : в„қ) < 1 by norm_num) hMge1)
  have hx_mem : x вҲҲ Set.Ioc 1 2 := by
    constructor
    В· dsimp [x]
      have hInvPos : 0 < (M : в„қ)вҒ»В№ := by positivity
      linarith
    В· dsimp [x]
      linarith
  have hmain := hC hx_mem
  have htot_nat : Nat.totient 3 = 2 := by
    simpa using Nat.totient_prime (by norm_num : Nat.Prime 3)
  have htot : (Nat.totient 3 : в„қ) = 2 := by
    exact_mod_cast htot_nat
  have hxsub : x - 1 = (M : в„қ)вҒ»В№ := by
    dsimp [x]
    ring
  rw [htot, hxsub] at hmain
  have hEq : ((2 : в„қ)вҒ»В№ / (M : в„қ)вҒ»В№ - C) = ((1 : в„қ) / 2) * (M : в„қ) - C := by
    have hMne : (M : в„қ) вү  0 := by positivity
    field_simp [hMne, two_ne_zero]
  rw [hEq] at hmain
  have hceil_nat_le_M : Nat.ceil (4 * max C 0) вүӨ M :=
    le_trans (le_max_right 1 (Nat.ceil (4 * max C 0))) hM'
  have hceil : 4 * max C 0 вүӨ (Nat.ceil (4 * max C 0) : в„қ) := Nat.le_ceil _
  have hceil_le_M : (Nat.ceil (4 * max C 0) : в„қ) вүӨ (M : в„қ) := by
    exact_mod_cast hceil_nat_le_M
  have h4max_le_M : 4 * max C 0 вүӨ (M : в„қ) := le_trans hceil hceil_le_M
  have hC_le_quarterM : C вүӨ (1 : в„қ) / 4 * (M : в„қ) := by
    have hC_le_max : C вүӨ max C 0 := le_max_left _ _
    have hmax_le_quarterM : max C 0 вүӨ (1 : в„қ) / 4 * (M : в„қ) := by
      nlinarith
    exact le_trans hC_le_max hmax_le_quarterM
  have hquarterM_le : (1 : в„қ) / 4 * (M : в„қ) вүӨ ((1 : в„қ) / 2) * (M : в„қ) - C := by
    nlinarith
  have hfinal : (1 : в„қ) / 4 * (M : в„қ) вүӨ
      вҲ‘' n : в„•, (if n.Prime вҲ§ n % 3 = 1 then Real.log (n : в„қ) else 0) / (n : в„қ) ^ x := by
    exact le_trans hquarterM_le hmain
  simpa [x, add_comm, add_left_comm, add_assoc] using hfinal

theorem residue_im_eq_zero_of_continuous_eqOn {f : в„• вҶ’ в„қ} {a : в„Ӯ} {g : в„Ӯ вҶ’ в„Ӯ} :
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    ContinuousOn g {s : в„Ӯ | 1 вүӨ s.re} вҶ’
    Set.EqOn g
      (fun s : в„Ӯ => LSeries (fun n => (f n : в„Ӯ)) s - a / (s - 1))
      {s : в„Ӯ | 1 < s.re} вҶ’
    a.im = 0 := by
  intro hsumm hcont heq
  have hL_real_im : вҲҖ y : в„қ, 1 < y вҶ’ (LSeries (fun n => (f n : в„Ӯ)) y).im = 0 := by
    intro y hy
    have hs : LSeriesSummable (fun n => (f n : в„Ӯ)) y := hsumm y (by simpa using hy)
    rw [LSeries, Complex.im_tsum hs]
    have hterm : (fun n => (LSeries.term (fun n => (f n : в„Ӯ)) y n).im) = 0 := by
      funext n
      rcases eq_or_ne n 0 with rfl | hn
      В· simp
      В· rw [LSeries.term_of_ne_zero hn]
        have hpow : (n : в„Ӯ) ^ (y : в„Ӯ) = (((n : в„қ) ^ y : в„қ) : в„Ӯ) := by
          simpa using (Complex.ofReal_cpow n.cast_nonneg y).symm
        rw [hpow]
        simp
    rw [hterm]
    exact tsum_zero
  let x : в„• вҶ’ в„қ := fun n => 1 + 1 / (n + 1 : в„қ)
  let u : в„• вҶ’ в„Ӯ := fun n => (x n : в„Ӯ)
  have hu_mem : вҲҖ n, u n вҲҲ {s : в„Ӯ | 1 вүӨ s.re} := by
    intro n
    change 1 вүӨ x n
    dsimp [x]
    have hnonneg : 0 вүӨ 1 / (n + 1 : в„қ) := by positivity
    linarith
  have hu_gt : вҲҖ n, 1 < (u n).re := by
    intro n
    change 1 < x n
    dsimp [x]
    have hpos : 0 < 1 / (n + 1 : в„қ) := by positivity
    linarith
  have hzero : Filter.Tendsto (fun n : в„• => 1 / ((n : в„қ) + 1)) Filter.atTop (nhds 0) := by
    simpa using (tendsto_one_div_add_atTop_nhds_zero_nat : Filter.Tendsto (fun n : в„• => 1 / ((n : в„қ) + 1)) Filter.atTop (nhds 0))

      (n : ℝ) ^ (1 + 2 * δ) = (n : ℝ) ^ ((2 * δ) + 1) := by rw [hexp1]
      _ = (n : ℝ) ^ (2 * δ) * (n : ℝ) ^ (1 : ℝ) := by
        rw [Real.rpow_add hn_pos_real]
      _ = (n : ℝ) ^ (2 * δ) * (n : ℝ) := by rw [Real.rpow_one]

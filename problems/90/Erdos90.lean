  have h_exp_cont : ContinuousOn (fun y : в„қ => Complex.exp (-z * y)) (Set.uIcc (0 : в„қ) Оҙ) := by
    fun_prop
  have h_interval : IntervalIntegrable U MeasureTheory.volume (0 : в„қ) Оҙ := by
    simpa [U] using h_base_complex.mul_continuousOn h_exp_cont
  have hU_tail : MeasureTheory.IntegrableOn U (Set.Ioi Оҙ) := by
    exact hU_integrable.mono_set (by
      intro x hx
      have hx' : Оҙ < x := by simpa [Set.mem_Ioi] using hx
      simpa [Set.mem_Ioi] using lt_trans hОҙ hx')
  have h_split := intervalIntegral.integral_interval_add_Ioi' h_interval hU_tail
  have h_tail_eq :
      вҲ« y in Set.Ioi Оҙ, U y =

      simpa [pow_two] using
        (RCLike.norm_sq_eq_def (z := ({ re := x, im := y } : ℂ) - ((1 : ℂ) / 2)))
    rw [hnorm]
  have hauto (x y : ℝ) (hx : 0 < x)
      (hleft : (x + (1 : ℝ) / 2) ^ 2 + y ^ 2 < R ^ 2) :
      (x - (1 : ℝ) / 2) ^ 2 + y ^ 2 < R ^ 2 := by
    have hcomp : (x - (1 : ℝ) / 2) ^ 2 ≤ (x + (1 : ℝ) / 2) ^ 2 := by
      nlinarith
    nlinarith
  have hs : s = regionBetween f g (Set.Ioc (0 : ℝ) b) := by
    ext p
    constructor
    · intro hp
      rcases hp with ⟨hp, hx⟩
      rcases hp with ⟨hleft, hright⟩
      have hleft' := (hdist_left p.1 p.2).1 hleft
      have hxb : p.1 ≤ b := by
        dsimp [b]
        nlinarith [hleft', sq_nonneg p.2]
      have hy2 : p.2 ^ 2 < R ^ 2 - (p.1 + (1 : ℝ) / 2) ^ 2 := by
        nlinarith [hleft']
      have hy := (Real.sq_lt).1 hy2
      exact ⟨⟨hx, hxb⟩, hy⟩
    · intro hp
      rcases hp with ⟨⟨hx, hxb⟩, hy⟩
      have hy2 : p.2 ^ 2 < R ^ 2 - (p.1 + (1 : ℝ) / 2) ^ 2 := by
        exact (Real.sq_lt).2 hy
      have hleft' : (p.1 + (1 : ℝ) / 2) ^ 2 + p.2 ^ 2 < R ^ 2 := by
        nlinarith
      have hleft := (hdist_left p.1 p.2).2 hleft'
      have hright' := hauto p.1 p.2 hx hleft'
      have hright := (hdist_right p.1 p.2).2 hright'
      exact ⟨⟨hleft, hright⟩, hx⟩
  have hvol : MeasureTheory.volume s = MeasureTheory.volume (overlapSymmetricLensRight R) := by
    simpa [s, e] using
      (MeasureTheory.MeasurePreserving.measure_preimage_equiv
        (MeasureTheory.MeasurePreserving.symm Complex.measurableEquivRealProd
          Complex.volume_preserving_equiv_real_prod)
        (overlapSymmetricLensRight R))
  have hfcont : Continuous f := by
    dsimp [f]
    continuity
  have hgcont : Continuous g := by
    dsimp [g]
    continuity
  have hfint : MeasureTheory.IntegrableOn f (Set.Ioc (0 : ℝ) b) :=
    hfcont.integrableOn_Ioc
  have hgint : MeasureTheory.IntegrableOn g (Set.Ioc (0 : ℝ) b) :=
    hgcont.integrableOn_Ioc
  have hfg : ∀ x ∈ Set.Ioc (0 : ℝ) b, f x ≤ g x := by
    intro x hx
    dsimp [f, g]
    nlinarith [Real.sqrt_nonneg (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)]
  have hregion : MeasureTheory.volume (regionBetween f g (Set.Ioc (0 : ℝ) b)) =
      ENNReal.ofReal (2 * ∫ x in (0 : ℝ)..b, Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)) := by
    rw [MeasureTheory.Measure.volume_eq_prod]
    rw [volume_regionBetween_eq_integral hfint hgint measurableSet_Ioc hfg]
    congr 1
    calc
      ∫ x in Set.Ioc (0 : ℝ) b, (g - f) x =
          ∫ x in Set.Ioc (0 : ℝ) b, (2 * Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)) := by
            apply MeasureTheory.integral_congr_ae
            filter_upwards with x
            simp [f, g, two_mul]
      _ = ∫ x in (0 : ℝ)..b, (2 * Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)) := by
            symm
            exact intervalIntegral.integral_of_le hb0
      _ = 2 * ∫ x in (0 : ℝ)..b, Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2) := by
            rw [intervalIntegral.integral_const_mul]
  have hmain : MeasureTheory.volume (overlapSymmetricLensRight R) =
      ENNReal.ofReal (2 * ∫ x in (0 : ℝ)..b, Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)) := by
    calc
      MeasureTheory.volume (overlapSymmetricLensRight R) = MeasureTheory.volume s := by
        symm
        exact hvol
      _ = MeasureTheory.volume (regionBetween f g (Set.Ioc (0 : ℝ) b)) := by rw [hs]
      _ = ENNReal.ofReal (2 * ∫ x in (0 : ℝ)..b, Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2)) :=
        hregion
  have hint_nonneg : 0 ≤ ∫ x in (0 : ℝ)..b, Real.sqrt (R ^ 2 - (x + (1 : ℝ) / 2) ^ 2) := by
    apply intervalIntegral.integral_nonneg hb0
    intro x hx
    exact Real.sqrt_nonneg _
  have hmain_real := congrArg ENNReal.toReal hmain
  rw [ENNReal.toReal_ofReal (by nlinarith [hint_nonneg])] at hmain_real
  simpa [b] using hmain_real

theorem overlapSymmetricLens_midline_volume_zero (R : ℝ) :
  MeasureTheory.volume (overlapSymmetricLens R ∩ {w : ℂ | w.re = 0}) = 0 := by
  have h_axis : MeasureTheory.volume ({w : ℂ | w.re = 0} : Set ℂ) = 0 := by
    let s : Set (Fin 2 → ℝ) := {p | p 0 = 0}
    have hs : MeasureTheory.volume s = 0 := by
      rw [MeasureTheory.volume_pi]
      simpa [s] using
        (MeasureTheory.Measure.pi_hyperplane
          (μ := fun _ : Fin 2 => (MeasureTheory.volume : MeasureTheory.Measure ℝ))
          (i := (0 : Fin 2)) (x := (0 : ℝ)))
    have hpre :
        Complex.measurableEquivPi ⁻¹' s = ({w : ℂ | w.re = 0} : Set ℂ) := by
      ext w
      simp [s, Complex.measurableEquivPi_apply]
    calc
      MeasureTheory.volume ({w : ℂ | w.re = 0} : Set ℂ)
          = MeasureTheory.volume (Complex.measurableEquivPi ⁻¹' s) := by rw [hpre.symm]
      _ = MeasureTheory.volume s := by
        simpa using
          (MeasureTheory.MeasurePreserving.measure_preimage_equiv
            (hf := Complex.volume_preserving_equiv_pi) s)
      _ = 0 := hs
  refine MeasureTheory.measure_mono_null (s := overlapSymmetricLens R ∩ {w : ℂ | w.re = 0}) (t := {w : ℂ | w.re = 0}) ?_ h_axis
  intro w hw
  exact hw.2

theorem overlapSymmetricLens_volume_eq_two_right (R : ℝ) :
  (MeasureTheory.volume (overlapSymmetricLens R)).toReal =
    2 * (MeasureTheory.volume (overlapSymmetricLensRight R)).toReal := by
  classical
  let L : Set ℂ := overlapSymmetricLens R
  let Lp : Set ℂ := overlapSymmetricLensRight R
  let Lm : Set ℂ := L ∩ {w : ℂ | w.re < 0}
  let L0 : Set ℂ := L ∩ {w : ℂ | w.re = 0}
  have hmeas_ball_left : MeasurableSet (Metric.ball (-((1 : ℂ) / 2)) R) :=
    Metric.isOpen_ball.measurableSet
  have hmeas_ball_right : MeasurableSet (Metric.ball (((1 : ℂ) / 2)) R) :=
    Metric.isOpen_ball.measurableSet
  have hmeasL : MeasurableSet L := by
    simpa [L, overlapSymmetricLens] using hmeas_ball_left.inter hmeas_ball_right
  have hmeas_pos : MeasurableSet {w : ℂ | 0 < w.re} := by
    simpa using measurableSet_lt measurable_const Complex.measurable_re
  have hmeas_neg : MeasurableSet {w : ℂ | w.re < 0} := by
    simpa using measurableSet_lt Complex.measurable_re measurable_const
  have hmeas_zero : MeasurableSet {w : ℂ | w.re = 0} := by
    simpa using
      (measurableSet_eq_fun
        (f := fun w : ℂ => w.re) (g := fun _ : ℂ => (0 : ℝ))
        Complex.measurable_re measurable_const)
  have hmeasLp : MeasurableSet Lp := by
    simpa [Lp, overlapSymmetricLensRight] using hmeasL.inter hmeas_pos
  have hmeasLm : MeasurableSet Lm := by
    simpa [Lm] using hmeasL.inter hmeas_neg
  have hmeasL0 : MeasurableSet L0 := by
    simpa [L0] using hmeasL.inter hmeas_zero
  have hsplit : L = Lp ∪ (Lm ∪ L0) := by
    ext w
    constructor
    · intro hw
      rcases lt_trichotomy w.re 0 with hneg | hzero | hpos
      · exact Or.inr (Or.inl ⟨hw, hneg⟩)
      · exact Or.inr (Or.inr ⟨hw, hzero⟩)
      · exact Or.inl ⟨hw, hpos⟩
    · intro hw
      rcases hw with hw | hw
      · exact hw.1
      · rcases hw with hw | hw
        · exact hw.1
        · exact hw.1
  have hdisj_p_rest : Disjoint Lp (Lm ∪ L0) := by
    rw [Set.disjoint_left]
    intro w hw1 hw2
    rcases hw2 with hw2 | hw2
    · have hpos : 0 < w.re := by
        simpa [Lp, overlapSymmetricLensRight] using hw1.2
      have hneg : w.re < 0 := by
        simpa [Lm] using hw2.2
      linarith
    · have hpos : 0 < w.re := by
        simpa [Lp, overlapSymmetricLensRight] using hw1.2
      have hzero : w.re = 0 := by
        simpa [L0] using hw2.2
      linarith
  have hdisj_m0 : Disjoint Lm L0 := by
    rw [Set.disjoint_left]
    intro w hw1 hw2
    have hneg : w.re < 0 := by
      simpa [Lm] using hw1.2
    have hzero : w.re = 0 := by
      simpa [L0] using hw2.2
    linarith
  have hneg_mem_L : ∀ w : ℂ, -w ∈ L ↔ w ∈ L := by
    intro w
    constructor <;> intro hw
    · have hw' : ‖-w + (1 / 2 : ℂ)‖ < R ∧ ‖-w + (-(1 / 2 : ℂ))‖ < R := by
        simpa [L, overlapSymmetricLens, Metric.mem_ball, dist_eq_norm, sub_eq_add_neg] using hw
      have hEq1 : -w + (-(1 / 2 : ℂ)) = -(w + (1 / 2 : ℂ)) := by
        ring
      have hEq2 : -w + (1 / 2 : ℂ) = -(w + (-(1 / 2 : ℂ))) := by
        ring
      have htmp1 := hw'.2
      have htmp2 := hw'.1
      have h1 : ‖w + (1 / 2 : ℂ)‖ < R := by
        rwa [hEq1, norm_neg] at htmp1
      have h2 : ‖w + (-(1 / 2 : ℂ))‖ < R := by
        rwa [hEq2, norm_neg] at htmp2
      simpa [L, overlapSymmetricLens, Metric.mem_ball, dist_eq_norm, sub_eq_add_neg] using And.intro h1 h2
    · have hw' : ‖w + (1 / 2 : ℂ)‖ < R ∧ ‖w + (-(1 / 2 : ℂ))‖ < R := by
        simpa [L, overlapSymmetricLens, Metric.mem_ball, dist_eq_norm, sub_eq_add_neg] using hw
      have hEq1 : w + (-(1 / 2 : ℂ)) = -(-w + (1 / 2 : ℂ)) := by
        ring
      have hEq2 : w + (1 / 2 : ℂ) = -(-w + (-(1 / 2 : ℂ))) := by
        ring
      have htmp1 := hw'.2
      have htmp2 := hw'.1
      have h1 : ‖-w + (1 / 2 : ℂ)‖ < R := by
        rwa [hEq1, norm_neg] at htmp1
      have h2 : ‖-w + (-(1 / 2 : ℂ))‖ < R := by
        rwa [hEq2, norm_neg] at htmp2
      simpa [L, overlapSymmetricLens, Metric.mem_ball, dist_eq_norm, sub_eq_add_neg] using And.intro h1 h2
  have hpreLm : (fun w : ℂ => -w) ⁻¹' Lm = Lp := by
    ext w
    constructor
    · intro hw
      have hwL : w ∈ L := (hneg_mem_L w).1 hw.1
      have hneg' : (-w).re < 0 := hw.2
      have hpos : 0 < w.re := by
        have : -w.re < 0 := by simpa [Complex.neg_re] using hneg'
        linarith
      exact ⟨hwL, hpos⟩
    · intro hw
      have hwL : -w ∈ L := (hneg_mem_L w).2 hw.1
      have hpos : 0 < w.re := hw.2
      have hneg' : (-w).re < 0 := by
        have : -w.re < 0 := by linarith
        simpa [Complex.neg_re] using this
      exact ⟨hwL, hneg'⟩
  have hneg_pres : MeasureTheory.MeasurePreserving (fun w : ℂ => -w) MeasureTheory.volume MeasureTheory.volume := by
    simpa using (LinearIsometryEquiv.neg ℝ : ℂ ≃ₗᵢ[ℝ] ℂ).measurePreserving
  have hvol_eq : MeasureTheory.volume Lp = MeasureTheory.volume Lm := by
    calc
      MeasureTheory.volume Lp = MeasureTheory.volume ((fun w : ℂ => -w) ⁻¹' Lm) := by
        rw [hpreLm]
      _ = MeasureTheory.volume Lm := by
        simp
  have hzero_null : MeasureTheory.volume L0 = 0 := by
    simpa [L0, L] using overlapSymmetricLens_midline_volume_zero R
  have hvol_split : MeasureTheory.volume L = MeasureTheory.volume Lp + MeasureTheory.volume Lm := by
    calc
      MeasureTheory.volume L = MeasureTheory.volume (Lp ∪ (Lm ∪ L0)) := by rw [hsplit]
      _ = MeasureTheory.volume Lp + MeasureTheory.volume (Lm ∪ L0) := by
        rw [MeasureTheory.measure_union hdisj_p_rest (hmeasLm.union hmeasL0)]
      _ = MeasureTheory.volume Lp + (MeasureTheory.volume Lm + MeasureTheory.volume L0) := by
        rw [MeasureTheory.measure_union hdisj_m0 hmeasL0]
      _ = MeasureTheory.volume Lp + MeasureTheory.volume Lm := by rw [hzero_null, add_zero]
  have hsub_ball : Lp ⊆ Metric.ball (((1 : ℂ) / 2)) R := by
    intro w hw
    exact hw.1.2
  have hfinp : MeasureTheory.volume Lp ≠ ⊤ := by
    exact ne_of_lt <|
      lt_of_le_of_lt
        (MeasureTheory.measure_mono hsub_ball)
        (MeasureTheory.measure_ball_lt_top (μ := MeasureTheory.volume) (x := ((1 : ℂ) / 2)) (r := R))
  change (MeasureTheory.volume L).toReal = 2 * (MeasureTheory.volume Lp).toReal
  calc
    (MeasureTheory.volume L).toReal = (MeasureTheory.volume Lp + MeasureTheory.volume Lm).toReal := by
      rw [hvol_split]
    _ = (MeasureTheory.volume Lp + MeasureTheory.volume Lp).toReal := by rw [hvol_eq]
    _ = (MeasureTheory.volume Lp).toReal + (MeasureTheory.volume Lp).toReal := by
      rw [ENNReal.toReal_add hfinp hfinp]
    _ = 2 * (MeasureTheory.volume Lp).toReal := by ring

theorem overlapSymmetricLens_volume_ge_half (R : ℝ) (hR : (1 : ℝ) / 2 ≤ R) :
  (MeasureTheory.volume (overlapSymmetricLens R)).toReal =
  overlapLensIntegral R := by
  rw [overlapSymmetricLens_volume_eq_two_right]
  rw [overlapSymmetricLensRight_volume R hR]
  unfold overlapLensIntegral
  let f : ℝ → ℝ := fun u => Real.sqrt (R ^ 2 - u ^ 2)
  have hshift :
      ∫ x in (0 : ℝ)..(R - (1 : ℝ) / 2), f (x + (1 : ℝ) / 2)
        = ∫ u in ((1 : ℝ) / 2)..R, f u := by
      simpa [f, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using
        (intervalIntegral.integral_comp_add_right (f := f) (a := (0 : ℝ))
          (b := R - (1 : ℝ) / 2) ((1 : ℝ) / 2))
  rw [hshift]
  ring

theorem overlapSymmetricLens_volume_lt_half (R : ℝ) (hR : R < (1 : ℝ) / 2) :
  (MeasureTheory.volume (overlapSymmetricLens R)).toReal = 0 := by
  have h_empty : overlapSymmetricLens R = ∅ := by
    ext z
    simp only [overlapSymmetricLens, Set.mem_inter_iff, Set.mem_empty_iff_false, Metric.mem_ball]
    constructor
    · intro hz
      rcases hz with ⟨hz1, hz2⟩
      have htri : dist (-((1 : ℂ) / 2)) (((1 : ℂ) / 2)) ≤
          dist (-((1 : ℂ) / 2)) z + dist z (((1 : ℂ) / 2)) := by
        simpa using dist_triangle (-((1 : ℂ) / 2)) z (((1 : ℂ) / 2))
      have hlt : dist (-((1 : ℂ) / 2)) z + dist z (((1 : ℂ) / 2)) < R + R := by
        exact add_lt_add (by simpa [dist_comm] using hz1) hz2
      have hcenter : dist (-((1 : ℂ) / 2)) (((1 : ℂ) / 2)) < R + R := lt_of_le_of_lt htri hlt
      have hdist : dist (-((1 : ℂ) / 2)) (((1 : ℂ) / 2)) = 1 := by
        rw [dist_eq_norm]
        norm_num
      have hR' : R + R < 1 := by linarith
      linarith
    · intro hz
      cases hz
  rw [h_empty]
  simp

theorem overlapArea_eq_volume (R : ℝ) (z : ℂ) (_hz : ‖z‖ = 1) :
  (MeasureTheory.volume
    (Metric.ball (0 : ℂ) R ∩ Metric.ball (-z) R)).toReal =
  overlapArea R := by
  rw [overlapArea_eq_volume_rotate R z _hz]
  by_cases hR : R < (1 : ℝ) / 2
  · rw [overlapSymmetricLens_volume_lt_half R hR]
    unfold overlapArea
    rw [if_pos hR]
  · have hR' : (1 : ℝ) / 2 ≤ R := not_lt.mp hR
    rw [overlapSymmetricLens_volume_ge_half R hR']
    rw [overlapLensIntegral_eq_formula R hR']
    unfold overlapArea
    rw [if_neg hR]


theorem primesCongOneMod3_dyadic_count_lower_bound: ∃ B : ℕ, 0 < B ∧ ∃ K₀ : ℕ, ∀ k : ℕ, K₀ ≤ k →
    2 ^ k ≤ Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) := by
  rcases primesCongOneMod3_count_power_lower_bound with ⟨δ, hδpos, X₀, hX⟩
  let B : ℕ := Nat.ceil (1 / δ)
  have hBpos : 0 < B := by
    have hpos : 0 < 1 / δ := by positivity
    exact Nat.ceil_pos.mpr hpos
  have hBδ : 1 ≤ (B : ℝ) * δ := by
    have hceil : 1 / δ ≤ (B : ℝ) := Nat.le_ceil (1 / δ)
    have hmul : (1 / δ) * δ ≤ (B : ℝ) * δ :=
      mul_le_mul_of_nonneg_right hceil (le_of_lt hδpos)
    have hδne : δ ≠ 0 := ne_of_gt hδpos
    simpa [B, one_div, hδne, mul_comm, mul_left_comm, mul_assoc] using hmul
  refine ⟨B, hBpos, Nat.clog 2 X₀, ?_⟩
  intro k hk
  have hclog : X₀ ≤ 2 ^ Nat.clog 2 X₀ := Nat.le_pow_clog (by decide : 1 < 2) X₀
  have hk' : Nat.clog 2 X₀ ≤ B * k := by
    have h1 : k ≤ B * k := by
      calc
        k = 1 * k := by rw [one_mul]
        _ ≤ B * k := Nat.mul_le_mul_right k (Nat.succ_le_of_lt hBpos)
    exact le_trans hk h1
  have hX0le : X₀ ≤ 2 ^ (B * k) := by
    exact le_trans hclog (pow_le_pow_right₀ (by decide : 1 ≤ 2) hk')
  have hcount : (((2 ^ (B * k) : ℕ) : ℝ) ^ δ) ≤
      (Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) : ℝ) := by
    exact hX (2 ^ (B * k)) hX0le
  have hbase : (1 : ℝ) ≤ ((2 ^ k : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_le_of_lt (pow_pos (by decide : 0 < 2) k)
  have hpowmono : ((2 ^ k : ℕ) : ℝ) ^ (1 : ℝ) ≤ ((2 ^ k : ℕ) : ℝ) ^ ((B : ℝ) * δ) := by
    exact (Real.monotone_rpow_of_base_ge_one hbase) hBδ
  have hcount' : ((2 ^ k : ℕ) : ℝ) ^ ((B : ℝ) * δ) ≤
      (Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) : ℝ) := by
    calc
      ((2 ^ k : ℕ) : ℝ) ^ ((B : ℝ) * δ)
          = ((((2 ^ k : ℕ) : ℝ) ^ B) : ℝ) ^ δ := by
              rw [Real.rpow_natCast_mul (by positivity)]
      _ = ((((2 ^ k : ℕ) ^ B : ℕ) : ℝ)) ^ δ := by
            rw [← Nat.cast_pow]
      _ = (((2 ^ (k * B) : ℕ) : ℝ)) ^ δ := by
            rw [← pow_mul]
      _ = (((2 ^ (B * k) : ℕ) : ℝ)) ^ δ := by rw [Nat.mul_comm]
      _ ≤ (Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) : ℝ) := hcount
  have hfinal_real : ((2 ^ k : ℕ) : ℝ) ≤
      (Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) : ℝ) := by
    calc
      ((2 ^ k : ℕ) : ℝ) = ((2 ^ k : ℕ) : ℝ) ^ (1 : ℝ) := by rw [Real.rpow_one]
      _ ≤ ((2 ^ k : ℕ) : ℝ) ^ ((B : ℝ) * δ) := hpowmono
      _ ≤ (Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) : ℝ) := hcount'
  exact_mod_cast hfinal_real

theorem primesCongOneMod3_nth_poly_bound: ∃ A : ℝ, 0 < A ∧ ∀ i : ℕ, (primesCongOneMod3 i : ℝ) ≤ (max 2 i : ℝ) ^ A := by
  obtain ⟨B, hBpos, K₀, hcount⟩ := primesCongOneMod3_dyadic_count_lower_bound
  let A : ℕ := B * (K₀ + 2)
  refine ⟨(A : ℝ), ?_, ?_⟩
  · dsimp [A]
    positivity
  · intro i
    let m : ℕ := max 2 i
    let l : ℕ := Nat.log 2 m
    let k : ℕ := max K₀ l.succ
    have hm_ge_two : 2 ≤ m := by
      dsimp [m]
      exact le_max_left 2 i
    have hi_le_m : i ≤ m := by
      dsimp [m]
      exact le_max_right 2 i
    have hm_ne_zero : m ≠ 0 := by
      omega
    have hk_ge_K₀ : K₀ ≤ k := by
      dsimp [k]
      exact le_max_left K₀ l.succ
    have hk_ge_lsucc : l.succ ≤ k := by
      dsimp [k]
      exact le_max_right K₀ l.succ
    have hi_lt_two_pow_lsucc : i < 2 ^ l.succ := by
      exact lt_of_le_of_lt hi_le_m (Nat.lt_pow_succ_log_self (by decide) m)
    have hi_lt_two_pow_k : i < 2 ^ k := by
      have hmono := pow_right_monotone (show (1 : ℕ) ≤ 2 by decide)
      exact lt_of_lt_of_le hi_lt_two_pow_lsucc (hmono hk_ge_lsucc)
    have hi_lt_count : i < Nat.count (fun n => n.Prime ∧ n % 3 = 1) (2 ^ (B * k)) := by
      exact lt_of_lt_of_le hi_lt_two_pow_k (hcount k hk_ge_K₀)
    have hnth_lt : primesCongOneMod3 i < 2 ^ (B * k) := by
      simpa [primesCongOneMod3] using
        (Nat.nth_lt_of_lt_count (p := fun n => n.Prime ∧ n % 3 = 1) hi_lt_count)
    have hk_le : k ≤ K₀ + l.succ := by
      have h1 : K₀ ≤ K₀ + l.succ := by omega
      have h2 : l.succ ≤ K₀ + l.succ := by omega
      exact max_le h1 h2
    have hpow_log_le : 2 ^ l ≤ m := by
      exact Nat.pow_le_of_le_log hm_ne_zero le_rfl
    have hsucc_le : 2 ^ l.succ ≤ m ^ 2 := by
      calc
        2 ^ l.succ = 2 ^ l * 2 := by rw [pow_succ]
        _ ≤ m * 2 := Nat.mul_le_mul_right 2 hpow_log_le
        _ ≤ m * m := Nat.mul_le_mul_left m hm_ge_two
        _ = m ^ 2 := by rw [pow_two]
    have hbase : 2 ^ (K₀ + l.succ) ≤ m ^ (K₀ + 2) := by
      calc
        2 ^ (K₀ + l.succ) = 2 ^ K₀ * 2 ^ l.succ := by rw [pow_add]
        _ ≤ m ^ K₀ * m ^ 2 := by
          gcongr
        _ = m ^ (K₀ + 2) := by rw [← pow_add]
    have hpow_bound_nat : 2 ^ (B * k) ≤ m ^ A := by
      have hmono := pow_right_monotone (show (1 : ℕ) ≤ 2 by decide)
      calc
        2 ^ (B * k) ≤ 2 ^ (B * (K₀ + l.succ)) := by
          exact hmono (Nat.mul_le_mul_left B hk_le)
        _ = (2 ^ (K₀ + l.succ)) ^ B := by rw [Nat.mul_comm, pow_mul]
        _ ≤ (m ^ (K₀ + 2)) ^ B := by
          exact pow_le_pow_left' hbase B
        _ = m ^ ((K₀ + 2) * B) := by rw [← pow_mul]
        _ = m ^ A := by
          dsimp [A]
          rw [Nat.mul_comm]
    have hnat : primesCongOneMod3 i ≤ m ^ A := by
      exact le_trans (Nat.le_of_lt hnth_lt) hpow_bound_nat
    have hreal_nat : (primesCongOneMod3 i : ℝ) ≤ (m : ℝ) ^ A := by
      exact_mod_cast hnat
    have hcast_max : (m : ℝ) = (max 2 i : ℝ) := by
      dsimp [m]
      exact (Nat.cast_max (α := ℝ) 2 i)
    have hreal_nat' : (primesCongOneMod3 i : ℝ) ≤ (max 2 i : ℝ) ^ A := by
      simpa [hcast_max] using hreal_nat
    simpa only [Real.rpow_natCast] using hreal_nat'

theorem primesCongOneMod3_log_pointwise_bound: ∃ A : ℝ, 0 < A ∧ ∀ i : ℕ, Real.log (primesCongOneMod3 i : ℝ) ≤ A * Real.log (max 2 i : ℝ) := by
  rcases primesCongOneMod3_nth_poly_bound with ⟨A, hApos, hpoly⟩
  refine ⟨A, hApos, ?_⟩
  intro i
  have hpi_pos : (0 : ℝ) < primesCongOneMod3 i := by
    exact_mod_cast (Nat.Prime.pos (primesCongOneMod3_prime i))
  have hbase_pos : (0 : ℝ) < (max 2 i : ℝ) := by
    exact_mod_cast (lt_of_lt_of_le (by decide : 0 < 2) (le_max_left 2 i))
  have hlog := Real.log_le_log hpi_pos (hpoly i)
  simpa [Real.log_rpow, hbase_pos.le] using hlog

theorem primesCongOneMod3_log_sum_bound: ∃ C : ℝ, 0 < C ∧
      ∀ ℓ : ℕ, ∑ i ∈ Finset.range ℓ, Real.log (primesCongOneMod3 i : ℝ)
        ≤ C * ℓ * Real.log (max 2 ℓ) := by
  rcases primesCongOneMod3_log_pointwise_bound with ⟨A, hApos, hA⟩
  refine ⟨A, hApos, ?_⟩
  intro ℓ
  calc
    ∑ i ∈ Finset.range ℓ, Real.log (primesCongOneMod3 i : ℝ)
        ≤ ∑ i ∈ Finset.range ℓ, A * Real.log (max 2 i : ℝ) := by
          exact Finset.sum_le_sum (fun i hi => hA i)
    _ ≤ ∑ i ∈ Finset.range ℓ, A * Real.log (max 2 ℓ : ℝ) := by
          refine Finset.sum_le_sum ?_
          intro i hi
          have hiℓ : i ≤ ℓ := Nat.le_of_lt (Finset.mem_range.mp hi)
          have hmax : max 2 i ≤ max 2 ℓ := max_le_max le_rfl hiℓ
          have hpos : (0 : ℝ) < (max 2 i : ℝ) := by
            have hpos_nat : 0 < max 2 i := lt_of_lt_of_le (by decide : 0 < 2) (le_max_left 2 i)
            exact_mod_cast hpos_nat
          have hlog : Real.log (max 2 i : ℝ) ≤ Real.log (max 2 ℓ : ℝ) := by
            exact Real.log_le_log hpos (by exact_mod_cast hmax)
          nlinarith
    _ = A * ℓ * Real.log (max 2 ℓ : ℝ) := by
          simp [mul_assoc, mul_left_comm, mul_comm]


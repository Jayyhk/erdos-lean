    rcases Ideal.exists_le_maximal D hDne with вҹЁP, hPmax, hPleвҹ©
    have hPprime : P.IsPrime := hPmax.isPrime
    have hPdvd : P вҲЈ D := by
      rwa [Ideal.dvd_iff_le]
    exact (_hnotdvd P hPprime) hPdvd
  rw [NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow F (рқ“һ F) M (рқ“һ M)]
  simp [D, hDtop]

theorem elementary_abelian_three_mulEquiv (n : в„•) (G : Type) [Group G] [Fintype G]
    (_hpow : вҲҖ g : G, g ^ 3 = 1)
    (_hcomm : вҲҖ g h : G, g * h = h * g)
    (_hcard : Nat.card G = 3 ^ n) :
    Nonempty (G вүғ* Multiplicative (Fin n вҶ’ ZMod 3)) := by
  letI : CommGroup G := { вҖ№Group GвҖә with
    mul_comm := _hcomm }
  let A := Additive G
  have h3smul : вҲҖ x : A, (3 : в„•) вҖў x = 0 := by
    intro x
    change x.toMul ^ 3 = 1
    simpa using _hpow x.toMul
  letI : Module (ZMod 3) A := AddCommGroup.zmodModule (n := 3) h3smul
  have hpow_card : 3 ^ Module.finrank (ZMod 3) A = Fintype.card A := by
    simpa using (FiniteField.pow_finrank_eq_card 3 A)
  have hfinrank : Module.finrank (ZMod 3) A = n := by
    have hcardA : Fintype.card A = 3 ^ n := by
      simpa [A] using _hcard
    rw [hcardA] at hpow_card
    exact Nat.pow_right_injective (by decide : 1 < 3) hpow_card
  let e : A вүғвӮ—[ZMod 3] (Fin n вҶ’ ZMod 3) :=
    LinearEquiv.ofFinrankEq (R := ZMod 3) A (Fin n вҶ’ ZMod 3) (by
      rw [hfinrank, Module.finrank_fin_fun])
  exact вҹЁe.toAddEquiv.toMultiplicativeRightвҹ©

theorem exists_linearMap_eq_one_of_span_top (в„“ : в„•) (_hв„“ : 0 < в„“) (v : Fin в„“ вҶ’ (Fin в„“ вҶ’ ZMod 3))
    (_hspan : Submodule.span (ZMod 3) (Set.range v) = вҠӨ) :
    вҲғ lin : (Fin в„“ вҶ’ ZMod 3) вҶ’вӮ—[ZMod 3] ZMod 3,
      lin вү  0 вҲ§ вҲҖ i, lin (v i) = 1 := by
  let T : (Fin в„“ вҶ’ ZMod 3) вҶ’вӮ—[ZMod 3] (Fin в„“ вҶ’ ZMod 3) :=
    (Module.piEquiv (Fin в„“) (ZMod 3) (Fin в„“ вҶ’ ZMod 3)) v

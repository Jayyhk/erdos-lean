    MeasureTheory.IntegrableOn
      (fun x : в„қ => (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
      (Set.Ioi (0 : в„қ)) := by
  intro hnonneg hsumm z hz
  have h1 :
      MeasureTheory.IntegrableOn
        (fun x : в„қ => (((logRescalePartialSum f x : в„қ) : в„Ӯ) * Complex.exp (-z * x)))

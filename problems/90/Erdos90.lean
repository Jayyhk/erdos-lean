theorem tendsto_lSeries_eval_one_add_inv_floor_pow_of_real_pole_bound {f : в„• вҶ’ в„қ} {a : в„қ} :
    (вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ {x : в„қ}, x вҲҲ Set.Ioc 1 2 вҶ’
      abs ((вҲ‘' n, f n / (n : в„қ) ^ x) - a / (x - 1)) вүӨ C) вҶ’
    вҲҖ c : в„қ, 1 < c вҶ’
      Filter.Tendsto
        (fun n : в„• =>
          (вҲ‘' k, f k / (k : в„қ) ^ (1 + (вҢҠc ^ nвҢӢвӮҠ : в„қ)вҒ»В№)) / (вҢҠc ^ nвҢӢвӮҠ : в„қ))

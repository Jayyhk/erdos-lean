theorem towerCurry_data (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] : вҲғ cur : вҲҖ n : в„•, C(Fin n вҶ’ G, ZMod p) вҶ’ HomogTower p G n, вҲҖ (n : в„•) (f : C(Fin n вҶ’ G, ZMod p)) (g : Fin n вҶ’ G), towerEval p G n (cur n f) g = f g := by
  have hcur :
      вҲҖ n : в„•,
        вҲғ cur_n : C(Fin n вҶ’ G, ZMod p) вҶ’ HomogTower p G n,
          (вҲҖ (f : C(Fin n вҶ’ G, ZMod p)) (g : Fin n вҶ’ G),
            towerEval p G n (cur_n f) g = f g) вҲ§
          (вҲҖ {X : Type} [TopologicalSpace X] (F : X вҶ’ C(Fin n вҶ’ G, ZMod p)),
            Continuous (fun q : X Г— (Fin n вҶ’ G) => F q.1 q.2) вҶ’
              Continuous fun x => cur_n (F x)) := by
    intro n
    induction n with
    | zero =>
        let g0 : Fin 0 вҶ’ G := finZeroElim
        refine вҹЁfun f => f g0, ?_вҹ©
        constructor
        В· intro f g
          have hg : g = g0 := Subsingleton.elim _ _
          simp [towerEval, g0, hg]
        В· intro X _ F hF
          have hFc : Continuous F := by
            refine ContinuousMap.continuous_of_continuous_uncurry F ?_
            simpa [Function.uncurry] using hF
          simpa [g0] using hFc.eval_const g0
    | succ n ih =>
        rcases ih with вҹЁcur_n, hspec_n, hcont_nвҹ©
        have hcons_a (a : G) : Continuous fun g : Fin n вҶ’ G =>
            (Fin.cons a g : Fin (n + 1) вҶ’ G) := by
          simpa using
            (Continuous.finCons
              (A := fun _ : Fin (n + 1) => G)
              (f := fun _ : Fin n вҶ’ G => a)
              (g := fun g : Fin n вҶ’ G => g)
              continuous_const continuous_id)
        let consCM : G вҶ’ C(Fin n вҶ’ G, Fin (n + 1) вҶ’ G) := fun a =>
          { toFun := fun g => (Fin.cons a g : Fin (n + 1) вҶ’ G)
            continuous_toFun := hcons_a a }
        have hcons_pair : Continuous fun q : G Г— (Fin n вҶ’ G) =>
            (Fin.cons q.1 q.2 : Fin (n + 1) вҶ’ G) := by
          simpa using
            (Continuous.finCons
              (A := fun _ : Fin (n + 1) => G)
              (f := fun q : G Г— (Fin n вҶ’ G) => q.1)
              (g := fun q : G Г— (Fin n вҶ’ G) => q.2)
              continuous_fst continuous_snd)
        let cur_succ : C(Fin (n + 1) вҶ’ G, ZMod p) вҶ’ HomogTower p G (n + 1) := fun f => by
          change C(G, HomogTower p G n)
          refine
            { toFun := fun a => cur_n (f.comp (consCM a))
              continuous_toFun := ?_ }
          have hunc : Continuous fun q : G Г— (Fin n вҶ’ G) => (f.comp (consCM q.1)) q.2 := by
            change Continuous fun q : G Г— (Fin n вҶ’ G) => f (Fin.cons q.1 q.2)
            simpa [consCM] using f.continuous.comp hcons_pair
          exact hcont_n (F := fun a => f.comp (consCM a)) hunc
        refine вҹЁcur_succ, ?_вҹ©
        constructor
        В· intro f g
          have htower (a : G) : (towerAsC p G n (cur_succ f)) a = cur_n (f.comp (consCM a)) := by
            cases n <;> rfl
          simp [towerEval, htower]
          simpa [consCM] using hspec_n (f.comp (consCM (g 0))) (Fin.tail g)
        В· intro X _ F hF
          refine
            ContinuousMap.continuous_of_continuous_uncurry
              (f := fun x => (cur_succ (F x) : C(G, HomogTower p G n))) ?_
          change Continuous fun q : X Г— G => cur_n ((F q.1).comp (consCM q.2))
          have hunc : Continuous fun r : (X Г— G) Г— (Fin n вҶ’ G) =>
              ((F r.1.1).comp (consCM r.1.2)) r.2 := by
            change Continuous fun r : (X Г— G) Г— (Fin n вҶ’ G) =>
              F r.1.1 (Fin.cons r.1.2 r.2)
            have hcons_second : Continuous fun r : (X Г— G) Г— (Fin n вҶ’ G) =>
                (Fin.cons r.1.2 r.2 : Fin (n + 1) вҶ’ G) := by
              simpa using
                (Continuous.finCons
                  (A := fun _ : Fin (n + 1) => G)
                  (f := fun r : (X Г— G) Г— (Fin n вҶ’ G) => r.1.2)
                  (g := fun r : (X Г— G) Г— (Fin n вҶ’ G) => r.2)
                  continuous_fst.snd continuous_snd)
            have hmap : Continuous fun r : (X Г— G) Г— (Fin n вҶ’ G) =>
                (r.1.1, (Fin.cons r.1.2 r.2 : Fin (n + 1) вҶ’ G)) :=
              continuous_fst.fst.prodMk hcons_second
            simpa using hF.comp hmap
          exact hcont_n (F := fun q : X Г— G => (F q.1).comp (consCM q.2)) hunc
  classical
  refine вҹЁfun n => Classical.choose (hcur n), ?_вҹ©
  intro n f g
  exact (Classical.choose_spec (hcur n)).1 f g

theorem inhomogToHomog_aux_data (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] : вҲғ ih : вҲҖ n : в„•, _root_.Erdos90.InhomogContsCochains.Cochain p G n вҶ’вӮ—[ZMod p] HomogObjType p G n, вҲҖ (n : в„•) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) вҶ’ G), towerEval p G (n + 1) (ih n f).1 g = f (consecutiveDifferencesTuple G n g) := by
  classical
  obtain вҹЁcur, hcurвҹ© := towerCurry_data p G
  let raw : вҲҖ n : в„•, _root_.Erdos90.InhomogContsCochains.Cochain p G n вҶ’ HomogTower p G (n + 1) :=
    fun n f =>
      cur (n + 1) (f.comp вҹЁconsecutiveDifferencesTuple G n, continuous_consecutiveDifferencesTuple G nвҹ©)
  have raw_spec :
      вҲҖ (n : в„•) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) вҶ’ G),
        towerEval p G (n + 1) (raw n f) g = f (consecutiveDifferencesTuple G n g) := by
    intro n f g
    simpa [raw] using hcur (n + 1) (f.comp вҹЁconsecutiveDifferencesTuple G n, continuous_consecutiveDifferencesTuple G nвҹ©) g
  have hdiff (n : в„•) (a : G) (g : Fin (n + 1) вҶ’ G) :
      consecutiveDifferencesTuple G n (fun k => aвҒ»В№ * g k) = consecutiveDifferencesTuple G n g := by
    funext k
    have h := congrFun (consecutiveDifferences_leftMul G n aвҒ»В№ g) k
    simp [consecutiveDifferencesTuple]
  have towerAsC_inj :
      вҲҖ (n : в„•) {x y : HomogTower p G (n + 1)},
        towerAsC p G n x = towerAsC p G n y вҶ’ x = y := by
    intro n x y h
    cases n <;> exact h
  have towerAsC_add :
      вҲҖ (n : в„•) (x y : HomogTower p G (n + 1)),
        towerAsC p G n (x + y) = towerAsC p G n x + towerAsC p G n y := by
    intro n x y
    cases n <;> rfl
  have towerAsC_smul :
      вҲҖ (n : в„•) (a : ZMod p) (x : HomogTower p G (n + 1)),
        towerAsC p G n (a вҖў x) = a вҖў towerAsC p G n x := by
    intro n a x
    cases n <;> rfl
  have towerEval_ext :
      вҲҖ (n : в„•) (x y : HomogTower p G n),
        (вҲҖ g : Fin n вҶ’ G, towerEval p G n x g = towerEval p G n y g) вҶ’ x = y := by
    intro n
    induction n with
    | zero =>
        intro x y h
        simpa [towerEval] using h Fin.elim0
    | succ n ih =>
        intro x y h
        apply towerAsC_inj n
        apply DFunLike.ext
        intro a
        apply ih
        intro g
        simpa [towerEval] using h (Fin.cons a g)
  have towerEval_add :
      вҲҖ (n : в„•) (x y : HomogTower p G n) (g : Fin n вҶ’ G),
        towerEval p G n (x + y) g = towerEval p G n x g + towerEval p G n y g := by
    intro n
    induction n with
    | zero =>
        intro x y g
        rfl
    | succ n ih =>
        intro x y g
        rw [towerEval, towerAsC_add]
        simpa using ih ((towerAsC p G n x) (g 0)) ((towerAsC p G n y) (g 0)) (Fin.tail g)
  have towerEval_smul :
      вҲҖ (n : в„•) (a : ZMod p) (x : HomogTower p G n) (g : Fin n вҶ’ G),
        towerEval p G n (a вҖў x) g = a вҖў towerEval p G n x g := by
    intro n
    induction n with
    | zero =>
        intro a x g
        rfl
    | succ n ih =>
        intro a x g
        rw [towerEval, towerAsC_smul]
        simpa using ih a ((towerAsC p G n x) (g 0)) (Fin.tail g)
  let ih : вҲҖ n : в„•, _root_.Erdos90.InhomogContsCochains.Cochain p G n вҶ’вӮ—[ZMod p] HomogObjType p G n :=
    fun n =>
      { toFun := fun f => вҹЁraw n f, by
          change вҲҖ a : G,
            (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
                (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ПҒ a).hom (raw n f) = raw n f
          intro a
          apply towerEval_ext (n + 1)
          intro g
          rw [towerEval_action, raw_spec, raw_spec]
          rw [hdiff]
        вҹ©
        map_add' := by
          intro f g
          apply Subtype.ext
          change raw n (f + g) = raw n f + raw n g
          apply towerEval_ext (n + 1)
          intro x
          rw [raw_spec, towerEval_add, raw_spec, raw_spec]
          rfl
        map_smul' := by
          intro a f
          apply Subtype.ext
          change raw n (a вҖў f) = a вҖў raw n f
          apply towerEval_ext (n + 1)
          intro x
          rw [raw_spec, towerEval_smul, raw_spec]
          rfl }
  refine вҹЁih, ?_вҹ©
  intro n f g
  simpa [ih] using raw_spec n f g

theorem selectedInhomogToHomog_aux_apply (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : в„•) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) вҶ’ G) : towerEval p G (n + 1) (selectedInhomogToHomog_aux p G n f).1 g = f (consecutiveDifferencesTuple G n g) := by

theorem continuous_consecutiveDifferencesTuple (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) : Continuous (consecutiveDifferencesTuple G n) := by
  classical
  refine continuous_pi ?_
  intro k
  simpa [consecutiveDifferencesTuple] using (((continuous_apply (Fin.castSucc k)).inv).mul (continuous_apply k.succ))

theorem consecutiveDifferences_leftMul (G : Type) [Group G] (n : ℕ) (a : G) (g : Fin (n + 1) → G) : (fun k : Fin n => ((a * g (Fin.castSucc k))⁻¹ * (a * g k.succ))) = fun k : Fin n => (g (Fin.castSucc k))⁻¹ * g k.succ := by
  funext k
  simp [mul_assoc]

theorem towerEval_action (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (a : G) (x : HomogTower p G n) (g : Fin n → G) : towerEval p G n ((((ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ a).hom x) g = towerEval p G n x (fun k : Fin n => a⁻¹ * g k) := by
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      let rep :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj
          (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))
      have hhead :
          (towerAsC p G n ((((ContinuousCohomology.I (ZMod p) G).obj rep).ρ a).hom x)) (g 0) =
            ((rep.ρ a).hom ((towerAsC p G n x) (a⁻¹ * g 0))) := by
        cases n <;> rfl
      have hhead' :
          (towerAsC p G n
              ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
                    (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ a).hom x))
              (g 0) =
            ((rep.ρ a).hom ((towerAsC p G n x) (a⁻¹ * g 0))) := by
        simpa [rep, ContinuousCohomology.MultiInd.functor] using hhead
      rw [towerEval, towerEval, hhead']
      simpa [rep] using ih ((towerAsC p G n x) (a⁻¹ * g 0)) (Fin.tail g)

theorem towerCurry_data (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] : ∃ cur : ∀ n : ℕ, C(Fin n → G, ZMod p) → HomogTower p G n, ∀ (n : ℕ) (f : C(Fin n → G, ZMod p)) (g : Fin n → G), towerEval p G n (cur n f) g = f g := by
  have hcur :
      ∀ n : ℕ,
        ∃ cur_n : C(Fin n → G, ZMod p) → HomogTower p G n,
          (∀ (f : C(Fin n → G, ZMod p)) (g : Fin n → G),
            towerEval p G n (cur_n f) g = f g) ∧
          (∀ {X : Type} [TopologicalSpace X] (F : X → C(Fin n → G, ZMod p)),
            Continuous (fun q : X × (Fin n → G) => F q.1 q.2) →
              Continuous fun x => cur_n (F x)) := by
    intro n
    induction n with
    | zero =>
        let g0 : Fin 0 → G := finZeroElim
        refine ⟨fun f => f g0, ?_⟩
        constructor
        · intro f g
          have hg : g = g0 := Subsingleton.elim _ _
          simp [towerEval, g0, hg]
        · intro X _ F hF
          have hFc : Continuous F := by
            refine ContinuousMap.continuous_of_continuous_uncurry F ?_
            simpa [Function.uncurry] using hF
          simpa [g0] using hFc.eval_const g0
    | succ n ih =>
        rcases ih with ⟨cur_n, hspec_n, hcont_n⟩
        have hcons_a (a : G) : Continuous fun g : Fin n → G =>
            (Fin.cons a g : Fin (n + 1) → G) := by
          simpa using
            (Continuous.finCons
              (A := fun _ : Fin (n + 1) => G)
              (f := fun _ : Fin n → G => a)
              (g := fun g : Fin n → G => g)
              continuous_const continuous_id)
        let consCM : G → C(Fin n → G, Fin (n + 1) → G) := fun a =>
          { toFun := fun g => (Fin.cons a g : Fin (n + 1) → G)
            continuous_toFun := hcons_a a }
        have hcons_pair : Continuous fun q : G × (Fin n → G) =>
            (Fin.cons q.1 q.2 : Fin (n + 1) → G) := by
          simpa using
            (Continuous.finCons
              (A := fun _ : Fin (n + 1) => G)
              (f := fun q : G × (Fin n → G) => q.1)
              (g := fun q : G × (Fin n → G) => q.2)
              continuous_fst continuous_snd)
        let cur_succ : C(Fin (n + 1) → G, ZMod p) → HomogTower p G (n + 1) := fun f => by
          change C(G, HomogTower p G n)
          refine
            { toFun := fun a => cur_n (f.comp (consCM a))
              continuous_toFun := ?_ }
          have hunc : Continuous fun q : G × (Fin n → G) => (f.comp (consCM q.1)) q.2 := by
            change Continuous fun q : G × (Fin n → G) => f (Fin.cons q.1 q.2)
            simpa [consCM] using f.continuous.comp hcons_pair
          exact hcont_n (F := fun a => f.comp (consCM a)) hunc
        refine ⟨cur_succ, ?_⟩
        constructor
        · intro f g
          have htower (a : G) : (towerAsC p G n (cur_succ f)) a = cur_n (f.comp (consCM a)) := by
            cases n <;> rfl
          simp [towerEval, htower]
          simpa [consCM] using hspec_n (f.comp (consCM (g 0))) (Fin.tail g)
        · intro X _ F hF
          refine
            ContinuousMap.continuous_of_continuous_uncurry
              (f := fun x => (cur_succ (F x) : C(G, HomogTower p G n))) ?_
          change Continuous fun q : X × G => cur_n ((F q.1).comp (consCM q.2))
          have hunc : Continuous fun r : (X × G) × (Fin n → G) =>
              ((F r.1.1).comp (consCM r.1.2)) r.2 := by
            change Continuous fun r : (X × G) × (Fin n → G) =>
              F r.1.1 (Fin.cons r.1.2 r.2)
            have hcons_second : Continuous fun r : (X × G) × (Fin n → G) =>
                (Fin.cons r.1.2 r.2 : Fin (n + 1) → G) := by
              simpa using
                (Continuous.finCons
                  (A := fun _ : Fin (n + 1) => G)
                  (f := fun r : (X × G) × (Fin n → G) => r.1.2)
                  (g := fun r : (X × G) × (Fin n → G) => r.2)
                  continuous_fst.snd continuous_snd)
            have hmap : Continuous fun r : (X × G) × (Fin n → G) =>
                (r.1.1, (Fin.cons r.1.2 r.2 : Fin (n + 1) → G)) :=
              continuous_fst.fst.prodMk hcons_second
            simpa using hF.comp hmap
          exact hcont_n (F := fun q : X × G => (F q.1).comp (consCM q.2)) hunc
  classical
  refine ⟨fun n => Classical.choose (hcur n), ?_⟩
  intro n f g
  exact (Classical.choose_spec (hcur n)).1 f g

theorem inhomogToHomog_aux_data (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] : ∃ ih : ∀ n : ℕ, _root_.Erdos90.InhomogContsCochains.Cochain p G n →ₗ[ZMod p] HomogObjType p G n, ∀ (n : ℕ) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) → G), towerEval p G (n + 1) (ih n f).1 g = f (consecutiveDifferencesTuple G n g) := by
  classical
  obtain ⟨cur, hcur⟩ := towerCurry_data p G
  let raw : ∀ n : ℕ, _root_.Erdos90.InhomogContsCochains.Cochain p G n → HomogTower p G (n + 1) :=
    fun n f =>
      cur (n + 1) (f.comp ⟨consecutiveDifferencesTuple G n, continuous_consecutiveDifferencesTuple G n⟩)
  have raw_spec :
      ∀ (n : ℕ) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) → G),
        towerEval p G (n + 1) (raw n f) g = f (consecutiveDifferencesTuple G n g) := by
    intro n f g
    simpa [raw] using hcur (n + 1) (f.comp ⟨consecutiveDifferencesTuple G n, continuous_consecutiveDifferencesTuple G n⟩) g
  have hdiff (n : ℕ) (a : G) (g : Fin (n + 1) → G) :
      consecutiveDifferencesTuple G n (fun k => a⁻¹ * g k) = consecutiveDifferencesTuple G n g := by
    funext k
    have h := congrFun (consecutiveDifferences_leftMul G n a⁻¹ g) k
    simp [consecutiveDifferencesTuple]
  have towerAsC_inj :
      ∀ (n : ℕ) {x y : HomogTower p G (n + 1)},
        towerAsC p G n x = towerAsC p G n y → x = y := by
    intro n x y h
    cases n <;> exact h
  have towerAsC_add :
      ∀ (n : ℕ) (x y : HomogTower p G (n + 1)),
        towerAsC p G n (x + y) = towerAsC p G n x + towerAsC p G n y := by
    intro n x y
    cases n <;> rfl
  have towerAsC_smul :
      ∀ (n : ℕ) (a : ZMod p) (x : HomogTower p G (n + 1)),
        towerAsC p G n (a • x) = a • towerAsC p G n x := by
    intro n a x
    cases n <;> rfl
  have towerEval_ext :
      ∀ (n : ℕ) (x y : HomogTower p G n),
        (∀ g : Fin n → G, towerEval p G n x g = towerEval p G n y g) → x = y := by
    intro n
    induction n with
    | zero =>
        intro x y h
        simpa [towerEval] using h Fin.elim0
    | succ n ih =>
        intro x y h
        apply towerAsC_inj n
        apply DFunLike.ext
        intro a
        apply ih
        intro g
        simpa [towerEval] using h (Fin.cons a g)
  have towerEval_add :
      ∀ (n : ℕ) (x y : HomogTower p G n) (g : Fin n → G),
        towerEval p G n (x + y) g = towerEval p G n x g + towerEval p G n y g := by
    intro n
    induction n with
    | zero =>
        intro x y g
        rfl
    | succ n ih =>
        intro x y g
        rw [towerEval, towerAsC_add]
        simpa using ih ((towerAsC p G n x) (g 0)) ((towerAsC p G n y) (g 0)) (Fin.tail g)
  have towerEval_smul :
      ∀ (n : ℕ) (a : ZMod p) (x : HomogTower p G n) (g : Fin n → G),
        towerEval p G n (a • x) g = a • towerEval p G n x g := by
    intro n
    induction n with
    | zero =>
        intro a x g
        rfl
    | succ n ih =>
        intro a x g
        rw [towerEval, towerAsC_smul]
        simpa using ih a ((towerAsC p G n x) (g 0)) (Fin.tail g)
  let ih : ∀ n : ℕ, _root_.Erdos90.InhomogContsCochains.Cochain p G n →ₗ[ZMod p] HomogObjType p G n :=
    fun n =>
      { toFun := fun f => ⟨raw n f, by
          change ∀ a : G,
            (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
                (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ a).hom (raw n f) = raw n f
          intro a
          apply towerEval_ext (n + 1)
          intro g
          rw [towerEval_action, raw_spec, raw_spec]
          rw [hdiff]
        ⟩
        map_add' := by
          intro f g
          apply Subtype.ext
          change raw n (f + g) = raw n f + raw n g
          apply towerEval_ext (n + 1)
          intro x
          rw [raw_spec, towerEval_add, raw_spec, raw_spec]
          rfl
        map_smul' := by
          intro a f
          apply Subtype.ext
          change raw n (a • f) = a • raw n f
          apply towerEval_ext (n + 1)
          intro x
          rw [raw_spec, towerEval_smul, raw_spec]
          rfl }
  refine ⟨ih, ?_⟩
  intro n f g
  simpa [ih] using raw_spec n f g

theorem selectedInhomogToHomog_aux_apply (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (f : _root_.Erdos90.InhomogContsCochains.Cochain p G n) (g : Fin (n + 1) → G) : towerEval p G (n + 1) (selectedInhomogToHomog_aux p G n f).1 g = f (consecutiveDifferencesTuple G n g) := by
  classical
  have h := inhomogToHomog_aux_data p G
  unfold selectedInhomogToHomog_aux
  simp only [dif_pos h]
  exact Classical.choose_spec h n f g

theorem continuous_prefixProdTuple (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) : Continuous (prefixProdTuple G n) := by
  refine continuous_pi ?_
  intro i
  refine Fin.inductionOn i ?_ ?_
  · simpa [prefixProdTuple] using (continuous_const : Continuous fun _ : (Fin n → G) => (1 : G))
  · intro i ih
    simpa [prefixProdTuple, Fin.partialProd_succ] using ih.mul (continuous_apply i)

theorem prefixProdTuple_cons (G : Type) [Group G] (n : ℕ) (a : G) (g : Fin n → G) : prefixProdTuple G (n + 1) (Fin.cons a g) = Fin.cons (1 : G) (fun i : Fin (n + 1) => a * prefixProdTuple G n g i) := by
  ext i
  cases i using Fin.cases with
  | zero =>
      rfl
  | succ i =>
      simp [prefixProdTuple, Fin.partialProd_succ']

theorem towerAsC_action_apply (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (b x : G) (y : HomogTower p G (n + 2)) : (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom ((towerAsC p G (n + 1) y) x) = (towerAsC p G (n + 1) ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom y)) (b * x) := by
  let rep :=
    ((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
      (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))))
  simpa [rep, HomogTower, towerAsC, ContinuousCohomology.MultiInd.functor, mul_assoc] using
    (ContinuousCohomology.Iobj_ρ_apply (R := ZMod p) (G := G) rep b
      (towerAsC p G (n + 1) y) (b * x)).symm

theorem partialTower_equivariant_eval_one (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (n : ℕ) (y : C(A, HomogTower p G (n + 2))) (hy : ∀ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y a) = y (b • a)) (q : A × G) : (towerAsC p G (n + 1) (y (q.2⁻¹ • q.1))) (q.2⁻¹) = (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ q.2⁻¹).hom ((towerAsC p G (n + 1) (y q.1)) (1 : G)) := by
  rw [← hy q.1 q.2⁻¹]
  rw [towerAsC_action_apply (p := p) (G := G) (n := n) (b := q.2⁻¹) (x := (1 : G)) (y := y q.1)]
  simp

theorem continuous_inv_smul_prod (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] : Continuous (fun q : A × G => q.2⁻¹ • q.1) := by
  simpa using (continuous_snd.inv.smul continuous_fst : Continuous (fun q : A × G => q.2⁻¹ • q.1))

theorem continuous_partialTower_equivariant (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (n : ℕ) (y : C(A, HomogTower p G (n + 2))) (_hy : ∀ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y a) = y (b • a)) : Continuous (fun q : A × G => (towerAsC p G (n + 1) (y (q.2⁻¹ • q.1))) (q.2⁻¹)) := by
  have hσ : Continuous (fun q : A × G => q.2⁻¹ • q.1) := continuous_inv_smul_prod G A
  have hycont : Continuous (fun q : A × G => y (q.2⁻¹ • q.1)) := y.continuous.comp hσ
  have hF : Continuous (fun q : A × G => towerAsC p G (n + 1) (y (q.2⁻¹ • q.1))) := by
    simpa [towerAsC] using hycont
  simpa using Continuous.eval hF continuous_snd.inv

theorem continuous_partialTower_equivariant_zero (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (y : C(A, HomogTower p G 2)) (hy : ∀ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G 2).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y a) = y (b • a)) : Continuous (fun q : A × G => (towerAsC p G 1 (y (q.2⁻¹ • q.1))) (q.2⁻¹)) := by
  simpa using continuous_partialTower_equivariant (p := p) (G := G) (A := A) (n := 0) y hy

theorem continuous_towerEval_prefixProd_equivariant (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (A : Type) [TopologicalSpace A] [MulAction G A] [ContinuousSMul G A] (n : ℕ) (y : C(A, HomogTower p G (n + 1))) (hy : ∀ (a : A) (b : G), (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y a) = y (b • a)) : Continuous (fun z : A × (Fin n → G) => towerEval p G (n + 1) (y z.1) (prefixProdTuple G n z.2)) := by
  induction n generalizing A with
  | zero =>
      change Continuous (fun z : A × (Fin 0 → G) => ((show C(G, ZMod p) from y z.1) (1 : G)))
      have hy0 : Continuous (fun z : A × (Fin 0 → G) => (show C(G, ZMod p) from y z.1)) := by
        simpa using y.continuous.comp continuous_fst
      simpa using hy0.eval_const (1 : G)
  | succ n ih =>
      letI : SMul G (A × G) := ⟨fun c q => (q.1, q.2 * c⁻¹)⟩
      letI : MulAction G (A × G) :=
        { smul := fun c q => (q.1, q.2 * c⁻¹)
          one_smul := by
            intro q
            change (q.1, q.2 * (1 : G)⁻¹) = q
            simp
          mul_smul := by
            intro a b q
            change (q.1, q.2 * (a * b)⁻¹) = (q.1, (q.2 * b⁻¹) * a⁻¹)
            simp [mul_assoc] }
      letI : ContinuousSMul G (A × G) := by
        refine ⟨?_⟩
        change Continuous (fun p : G × (A × G) => (p.2.1, p.2.2 * p.1⁻¹))
        exact Continuous.prodMk continuous_snd.fst (continuous_snd.snd.mul continuous_fst.inv)
      let y' : C(A × G, HomogTower p G (n + 1)) :=
        ⟨fun q : A × G => (towerAsC p G (n + 1) (y (q.2⁻¹ • q.1))) (q.2⁻¹),
          continuous_partialTower_equivariant p G A n y hy⟩
      have hy' : ∀ (a : A × G) (b : G),
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y' a) =
            y' (b • a) := by
        intro a b
        have hrhs :
            y' (b • a) =
              (towerAsC p G (n + 1)
                ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                    (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom
                  (y (a.2⁻¹ • a.1))))
                (b * a.2⁻¹) := by
          calc
            y' (b • a)
                = (towerAsC p G (n + 1) (y ((b * a.2⁻¹) • a.1))) (b * a.2⁻¹) := by
                    change (towerAsC p G (n + 1) (y (((a.2 * b⁻¹)⁻¹) • a.1))) (((a.2 * b⁻¹)⁻¹)) =
                      (towerAsC p G (n + 1) (y ((b * a.2⁻¹) • a.1))) (b * a.2⁻¹)
                    simp [mul_assoc]
            _ = (towerAsC p G (n + 1) (y (b • (a.2⁻¹ • a.1)))) (b * a.2⁻¹) := by
                  simp [mul_smul]
            _ = (towerAsC p G (n + 1)
                  ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                      (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom
                    (y (a.2⁻¹ • a.1))))
                  (b * a.2⁻¹) := by
                    rw [← hy (a.2⁻¹ • a.1) b]
        rw [hrhs]
        change
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom
              ((towerAsC p G (n + 1) (y (a.2⁻¹ • a.1))) (a.2⁻¹)) =
            (towerAsC p G (n + 1)
              ((((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).obj
                  (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom
                (y (a.2⁻¹ • a.1))))
              (b * a.2⁻¹)
        convert (ContinuousCohomology.Iobj_ρ_apply (R := ZMod p) (G := G)
          (rep := ((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
            (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))))
          (g := b)
          (f := towerAsC p G (n + 1) (y (a.2⁻¹ • a.1)))
          (x := b * a.2⁻¹)).symm using 1
        simp [mul_assoc]
      let decomp : A × (Fin (n + 1) → G) → (A × G) × (Fin n → G) :=
        fun z => ((z.1, z.2 0), Fin.tail z.2)
      have hcont : Continuous (fun z : (A × G) × (Fin n → G) =>
          towerEval p G (n + 1) (y' z.1) (prefixProdTuple G n z.2)) :=
        ih (A := A × G) y' hy'
      have hdecomp : Continuous decomp := by
        have hfst : Continuous (fun z : A × (Fin (n + 1) → G) => (z.1, z.2 0)) :=
          Continuous.prodMk continuous_fst ((continuous_apply 0).comp continuous_snd)
        have htail : Continuous (fun z : A × (Fin (n + 1) → G) => Fin.tail z.2) :=
          continuous_snd.finTail
        exact Continuous.prodMk hfst htail
      have hcomp : Continuous (fun z : A × (Fin (n + 1) → G) =>
          towerEval p G (n + 1) (y' (z.1, z.2 0)) (prefixProdTuple G n (Fin.tail z.2))) := by
        simpa [decomp] using hcont.comp hdecomp
      convert hcomp using 1
      funext z
      have hsmul : (z.2 0) • (z.1, z.2 0) = (z.1, (1 : G)) := by
        change (z.1, z.2 0 * (z.2 0)⁻¹) = (z.1, (1 : G))
        simp
      have hρ :
          (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
              (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ (z.2 0)).hom
              (y' (z.1, z.2 0)) =
            (towerAsC p G (n + 1) (y z.1)) (1 : G) := by
        rw [hy' (z.1, z.2 0) (z.2 0), hsmul]
        simp [y']
      rw [show z.2 = Fin.cons (z.2 0) (Fin.tail z.2) by
        simp]
      rw [prefixProdTuple_cons]
      change towerEval p G (n + 1) ((towerAsC p G (n + 1) (y z.1)) (1 : G))
          (fun i : Fin (n + 1) => z.2 0 * prefixProdTuple G n (Fin.tail z.2) i) =
        towerEval p G (n + 1) (y' (z.1, z.2 0)) (prefixProdTuple G n (Fin.tail z.2))
      rw [← hρ]
      rw [towerEval_action]
      simp [mul_assoc]

theorem continuous_homogObj_prefixEval (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) (x : HomogObjType p G n) : Continuous (fun g : Fin n → G => towerEval p G (n + 1) x.1 (prefixProdTuple G n g)) := by
  let y : C(PUnit, HomogTower p G (n + 1)) := ContinuousMap.const _ x.1
  have hy :
      ∀ (a : PUnit) (b : G),
        (((ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 1)).obj
            (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).ρ b).hom (y a) = y (b • a) := by
    intro a b
    have hx := x.2 b
    simp only [y] at hx ⊢
    exact hx
  have hcont := continuous_towerEval_prefixProd_equivariant p G PUnit n y hy
  have hpre : Continuous (fun g : Fin n → G => (PUnit.unit, g)) := by
    continuity
  exact hcont.comp hpre

theorem homogToInhomog_aux_data (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] : ∃ hi : ∀ n : ℕ, HomogObjType p G n →ₗ[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n, ∀ (n : ℕ) (x : HomogObjType p G n) (g : Fin n → G), (hi n x) g = towerEval p G (n + 1) x.1 (prefixProdTuple G n g) := by
  classical
  have h_eval_add :
      ∀ m (u v : HomogTower p G (m + 1)) (g0 : G),
        (towerAsC p G m (u + v)) g0 = (towerAsC p G m u) g0 + (towerAsC p G m v) g0 := by
    intro m u v g0
    cases m <;> rfl
  have h_eval_smul :
      ∀ m (a : ZMod p) (u : HomogTower p G (m + 1)) (g0 : G),
        (towerAsC p G m (a • u)) g0 = a • (towerAsC p G m u) g0 := by
    intro m a u g0
    cases m <;> rfl
  have towerEval_add :
      ∀ m (u v : HomogTower p G m) (g : Fin m → G),
        towerEval p G m (u + v) g = towerEval p G m u g + towerEval p G m v g := by
    intro m
    induction m with
    | zero =>
        intro u v g
        rfl
    | succ m ih =>
        intro u v g
        simp only [towerEval]
        rw [h_eval_add m u v (g 0)]
        exact ih _ _ _
  have towerEval_smul :
      ∀ m (a : ZMod p) (u : HomogTower p G m) (g : Fin m → G),
        towerEval p G m (a • u) g = a • towerEval p G m u g := by
    intro m
    induction m with
    | zero =>
        intro a u g
        rfl
    | succ m ih =>
        intro a u g
        simp only [towerEval]
        rw [h_eval_smul m a u (g 0)]
        exact ih _ _ _
  refine ⟨?_, ?_⟩
  intro n
  refine
    { toFun := fun x =>
        { toFun := fun g => towerEval p G (n + 1) x.1 (prefixProdTuple G n g)
          continuous_toFun := continuous_homogObj_prefixEval p G n x }
      map_add' := ?_
      map_smul' := ?_ }
  · intro x y
    ext g
    simpa using towerEval_add (n + 1) x.1 y.1 (prefixProdTuple G n g)
  · intro a x
    ext g
    simpa using towerEval_smul (n + 1) a x.1 (prefixProdTuple G n g)
  · intro n x g
    rfl

theorem selectedHomogToInhomog_aux_apply (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) (x : HomogObjType p G n) (g : Fin n → G) : (selectedHomogToInhomog_aux p G n x) g = towerEval p G (n + 1) x.1 (prefixProdTuple G n g) := by
  classical
  have h := homogToInhomog_aux_data p G
  unfold selectedHomogToInhomog_aux
  simp only [dif_pos h]
  exact Classical.choose_spec h n x g

theorem partialProd_consecutiveDifferences (G : Type) [Group G] (n : ℕ) (g : Fin (n + 1) → G) : Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))⁻¹ * g k.succ) = fun i : Fin (n + 1) => (g 0)⁻¹ * g i := by
  ext i
  have h := congrArg (fun h : Fin (n + 1) → G => h i) (Fin.partialProd_left_inv g)
  simp only [Pi.smul_apply, smul_eq_mul] at h
  calc
    Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))⁻¹ * g k.succ) i =
        (g 0)⁻¹ * (g 0 * Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))⁻¹ * g k.succ) i) := by
          symm
          exact inv_mul_cancel_left (g 0) (Fin.partialProd (fun k : Fin n => (g (Fin.castSucc k))⁻¹ * g k.succ) i)
    _ = (g 0)⁻¹ * g i := by rw [h]

theorem homogObj_towerEval_leftMul (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (x : HomogObjType p G n) (a : G) (g : Fin (n + 1) → G) : towerEval p G (n + 1) x.1 (fun i : Fin (n + 1) => a * g i) = towerEval p G (n + 1) x.1 g := by
  let rep : ℕ → Action (TopModuleCat (ZMod p)) G
      | n => (ContinuousCohomology.MultiInd.functor (ZMod p) G n).obj
          (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))
  have haux : ∀ n : ℕ, ∀ y : HomogTower p G n, ∀ a : G, ∀ g : Fin n → G,
      towerEval p G n ((((rep n).ρ a).hom) y) (fun i : Fin n => a * g i) = towerEval p G n y g := by
    intro n
    induction n with
    | zero =>
        intro y a g
        rfl
    | succ n ih =>
        intro y a g
        simp only [towerEval]
        have hhead : (towerAsC p G n ((((rep (n + 1)).ρ a).hom) y)) (a * g 0) =
            (((rep n).ρ a).hom) ((towerAsC p G n y) (g 0)) := by
          cases n with
          | zero =>
              change ((ContinuousCohomology.Iobj (rep 0)).ρ a).hom y (a * g 0) =
                  (((rep 0).ρ a).hom) ((towerAsC p G 0 y) (g 0))
              rw [ContinuousCohomology.Iobj_ρ_apply]
              simp only [mul_assoc, inv_mul_cancel_left]
              rfl
          | succ n =>
              change ((ContinuousCohomology.Iobj (rep (n + 1))).ρ a).hom y (a * g 0) =
                  (((rep (n + 1)).ρ a).hom) ((towerAsC p G (n + 1) y) (g 0))
              rw [ContinuousCohomology.Iobj_ρ_apply]
              simp only [mul_assoc, inv_mul_cancel_left]
              rfl
        rw [hhead]
        exact ih _ a (Fin.tail g)
  have hfixed : (((rep (n + 1)).ρ a).hom) x.1 = x.1 := x.2 a
  simpa [rep, hfixed] using haux (n + 1) x.1 a g

theorem selectedInhomogToHomog_homogToInhomog_aux (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (selectedInhomogToHomog_aux p G n).comp (selectedHomogToInhomog_aux p G n) = (LinearMap.id : HomogObjType p G n →ₗ[ZMod p] HomogObjType p G n) := by
  have towerEval_ext :
      ∀ m (u v : HomogTower p G m),
        (∀ g : Fin m → G, towerEval p G m u g = towerEval p G m v g) → u = v := by
    intro m
    induction m with
    | zero =>
        intro u v h
        exact h (fun i => Fin.elim0 i)
    | succ m ih =>
        intro u v h
        have h' : towerAsC p G m u = towerAsC p G m v := by
          apply ContinuousMap.ext
          intro a
          apply ih
          intro g
          simpa using h (Fin.cons a g)
        cases m with
        | zero =>
            simpa [towerAsC] using h'
        | succ m =>
            simpa [towerAsC] using h'
  ext x
  apply Subtype.ext
  refine towerEval_ext (n + 1) _ _ ?_
  intro g
  rw [LinearMap.comp_apply, LinearMap.id_apply]
  rw [selectedInhomogToHomog_aux_apply]
  rw [selectedHomogToInhomog_aux_apply]
  have hprefix :
      prefixProdTuple G n (consecutiveDifferencesTuple G n g) =
        fun i : Fin (n + 1) => (g 0)⁻¹ * g i := by
    simpa [prefixProdTuple, consecutiveDifferencesTuple] using
      (partialProd_consecutiveDifferences G n g)
  rw [hprefix]
  simpa using homogObj_towerEval_leftMul p G n x (g 0)⁻¹ g

theorem inhomogToHomog_homogToInhomog (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (inhomogToHomog p G n).comp (homogToInhomog p G n) = (LinearMap.id : HomogObjType p G n →ₗ[ZMod p] HomogObjType p G n) := by
  simpa [inhomogToHomog, homogToInhomog] using selectedInhomogToHomog_homogToInhomog_aux p G n

theorem consecutiveDifferences_partialProd (G : Type) [Group G] (n : ℕ) (g : Fin n → G) : (fun k : Fin n => ((Fin.partialProd g) (Fin.castSucc k))⁻¹ * (Fin.partialProd g) k.succ) = g := by
  funext k
  rw [Fin.partialProd_succ]
  simp

theorem selectedHomogToInhomog_inhomogToHomog_aux (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (selectedHomogToInhomog_aux p G n).comp (selectedInhomogToHomog_aux p G n) = (LinearMap.id : _root_.Erdos90.InhomogContsCochains.Cochain p G n →ₗ[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n) := by
  ext f g
  simp only [LinearMap.comp_apply, LinearMap.id_apply]
  rw [selectedHomogToInhomog_aux_apply, selectedInhomogToHomog_aux_apply]
  simpa [consecutiveDifferencesTuple, prefixProdTuple] using congrArg f (consecutiveDifferences_partialProd G n g)

theorem homogToInhomog_inhomogToHomog (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (homogToInhomog p G n).comp (inhomogToHomog p G n) = (LinearMap.id : _root_.Erdos90.InhomogContsCochains.Cochain p G n →ₗ[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n) := by
  simpa only [homogToInhomog, inhomogToHomog] using
    selectedHomogToInhomog_inhomogToHomog_aux p G n

theorem consecutiveDifferences_succRemoveNth_prefixProd (G : Type) [Group G] (n : ℕ) (g : Fin (n + 1) → G) (j : Fin (n + 1)) : consecutiveDifferencesTuple G n (j.succ.removeNth (prefixProdTuple G (n + 1) g)) = Fin.contractNth j (· * ·) g := by
  ext k
  simpa [consecutiveDifferencesTuple, prefixProdTuple, Fin.removeNth] using Fin.inv_partialProd_mul_eq_contractNth g j k

theorem homogObjDiff_val_eq (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (x : HomogObjType p G n) : (homogObjDiff p G n x).1 = (((ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1)).app (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).hom x.1) := by
  simp [homogObjDiff, HomogObjType, ContinuousCohomology.homogeneousCochains,
    ContinuousCohomology.MultiInd.complex, CochainComplex.of_d,
    ContinuousCohomology.invariants]
  rfl

theorem neg_alternating_sum_shift (p : ℕ) [Fact p.Prime] (n : ℕ) (f : Fin n → ZMod p) : -((Finset.univ : Finset (Fin n)).sum (fun j : Fin n => (-1 : ZMod p) ^ ((j : ℕ) + 1) * f j)) = (Finset.univ : Finset (Fin n)).sum (fun j : Fin n => (-1 : ZMod p) ^ ((j : ℕ) + 1 + 1) * f j) := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      rw [Fin.sum_univ_succ, Fin.sum_univ_succ]
      simp [pow_succ, mul_assoc, add_assoc, add_left_comm, add_comm]

theorem succSucc_removeNth_eq_cons_removeNth_tail (α : Type) (n : ℕ) (t : Fin (n + 3) → α) (j : Fin (n + 1)) : j.succ.succ.removeNth t = Fin.cons (t 0) (j.succ.removeNth (Fin.tail t)) := by
  have hins :
      Fin.insertNth j.succ.succ (t (j.succ.succ))
        (Fin.cons (t 0) (j.succ.removeNth (Fin.tail t))) = t := by
    rw [Fin.insertNth_succ_cons, ← Fin.cons_self_tail t]
    simp
  exact
    ((Fin.eq_insertNth_iff
        (p := j.succ.succ)
        (a := t (j.succ.succ))
        (f := Fin.cons (t 0) (j.succ.removeNth (Fin.tail t)))
        (g := t)).1 hins.symm).2

theorem towerEval_multiInd_d (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (y : HomogTower p G (n + 1)) (t : Fin (n + 2) → G) : towerEval p G (n + 2) (((ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1)).app (Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p)))).hom y) t = towerEval p G (n + 1) y (Fin.tail t) + ((Finset.univ : Finset (Fin (n + 1))).sum (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : ℕ) + 1) • towerEval p G (n + 1) y (j.succ.removeNth t))) := by
  have towerEval_sub : ∀ m (a b : HomogTower p G m) (u : Fin m → G),
      towerEval p G m (a - b) u = towerEval p G m a u - towerEval p G m b u := by
    intro m
    induction m with
    | zero =>
        intro a b u
        rfl
    | succ m ih =>
        cases m with
        | zero =>
            intro a b u
            rfl
        | succ m =>
            intro a b u
            simpa [towerEval, towerAsC] using
              ih (((towerAsC p G (m + 1) a) (u 0))) (((towerAsC p G (m + 1) b) (u 0))) (Fin.tail u)
  induction n with
  | zero =>
      change C(G, ZMod p) at y
      rw [ContinuousCohomology.MultiInd.d_succ, ContinuousCohomology.MultiInd.d_zero]
      let X : Action (TopModuleCat (ZMod p)) G :=
        Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))
      let A :
          ContinuousCohomology.MultiInd.functor (ZMod p) G 1 ⟶
            ContinuousCohomology.MultiInd.functor (ZMod p) G 2 :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G 1).whiskerLeft
          (ContinuousCohomology.const (ZMod p) G)
      let B :
          ContinuousCohomology.MultiInd.functor (ZMod p) G 1 ⟶
            ContinuousCohomology.MultiInd.functor (ZMod p) G 2 :=
        CategoryTheory.Functor.whiskerRight (ContinuousCohomology.const (ZMod p) G)
          (ContinuousCohomology.I (ZMod p) G)
      change towerEval p G 2 (((A - B).app X).hom y) t =
        towerEval p G 1 y (Fin.tail t) +
          ((Finset.univ : Finset (Fin 1)).sum (fun j : Fin 1 =>
            (-1 : ZMod p) ^ ((j : ℕ) + 1) • towerEval p G 1 y (j.succ.removeNth t)))
      have hy : ((A - B).app X).hom y = (A.app X).hom y - (B.app X).hom y := by
        simp [Action.sub_hom, TopModuleCat.hom_sub, ContinuousLinearMap.sub_apply]
      have hsub : towerEval p G 2 (((A - B).app X).hom y) t =
          towerEval p G 2 ((A.app X).hom y) t - towerEval p G 2 ((B.app X).hom y) t := by
        rw [hy, towerEval_sub]
      have hA : towerEval p G 2 ((A.app X).hom y) t = y (Fin.tail t 0) := by
        rfl
      have hB : towerEval p G 2 ((B.app X).hom y) t = y (Fin.removeNth 1 t 0) := by
        rfl
      rw [hsub, hA, hB, Fin.sum_univ_one]
      simp [Fin.removeNth_zero, sub_eq_add_neg, towerEval, towerAsC]
      rfl
  | succ n ih =>
      let X : Action (TopModuleCat (ZMod p)) G :=
        Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))
      rw [ContinuousCohomology.MultiInd.d_succ]
      let A :
          ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2) ⟶
            ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 3) :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).whiskerLeft
          (ContinuousCohomology.const (ZMod p) G)
      let B :
          ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2) ⟶
            ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 3) :=
        CategoryTheory.Functor.whiskerRight
          (ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1))
          (ContinuousCohomology.I (ZMod p) G)
      let y0 : HomogTower p G (n + 1) := (towerAsC p G (n + 1) y) (t 0)
      change towerEval p G (n + 3) (((A - B).app X).hom y) t =
        towerEval p G (n + 2) y (Fin.tail t) +
          ((Finset.univ : Finset (Fin (n + 2))).sum (fun j : Fin (n + 2) =>
            (-1 : ZMod p) ^ ((j : ℕ) + 1) • towerEval p G (n + 2) y (j.succ.removeNth t)))
      have hy : ((A - B).app X).hom y = (A.app X).hom y - (B.app X).hom y := by
        simp [Action.sub_hom, TopModuleCat.hom_sub, ContinuousLinearMap.sub_apply]
      have hsub : towerEval p G (n + 3) (((A - B).app X).hom y) t =
          towerEval p G (n + 3) ((A.app X).hom y) t - towerEval p G (n + 3) ((B.app X).hom y) t := by
        rw [hy, towerEval_sub]
      have hA : towerEval p G (n + 3) ((A.app X).hom y) t = towerEval p G (n + 2) y (Fin.tail t) := by
        rfl
      have hB0 : towerEval p G (n + 3) ((B.app X).hom y) t =
          towerEval p G (n + 2)
            (((ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1)).app X).hom y0)
            (Fin.tail t) := by
        rfl
      have hih := ih y0 (Fin.tail t)
      have hremove1 : towerEval p G (n + 2) y ((0 : Fin (n + 2)).succ.removeNth t) =
          towerEval p G (n + 1) y0 (Fin.tail (Fin.tail t)) := by
        rfl
      have hshift (j : Fin (n + 1)) :
          towerEval p G (n + 2) y (j.succ.succ.removeNth t) =
            towerEval p G (n + 1) y0 (j.succ.removeNth (Fin.tail t)) := by
        rw [succSucc_removeNth_eq_cons_removeNth_tail]
        rfl
      let f : Fin (n + 1) → ZMod p := fun j =>
        towerEval p G (n + 1) y0 (j.succ.removeNth (Fin.tail t))
      have hs :
          -((Finset.univ : Finset (Fin (n + 1))).sum
              (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : ℕ) + 1) • f j)) =
            (Finset.univ : Finset (Fin (n + 1))).sum
              (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : ℕ) + 1 + 1) • f j) := by
        simpa [f, smul_eq_mul] using neg_alternating_sum_shift p (n + 1) f
      rw [hsub, hA, hB0, hih, sub_eq_add_neg, neg_add]
      conv_rhs => rw [Fin.sum_univ_succ]
      rw [hs]
      congr 1
      rw [hremove1]
      simp [pow_one]
      apply Finset.sum_congr rfl
      intro i hi
      rw [hshift]

theorem towerEval_homogObjDiff_prefixProd (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) (x : HomogObjType p G n) (g : Fin (n + 1) → G) : towerEval p G (n + 2) ((homogObjDiff p G n x).1) (prefixProdTuple G (n + 1) g) = towerEval p G (n + 1) x.1 (Fin.tail (prefixProdTuple G (n + 1) g)) + ((Finset.univ : Finset (Fin (n + 1))).sum (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : ℕ) + 1) • towerEval p G (n + 1) x.1 (j.succ.removeNth (prefixProdTuple G (n + 1) g)))) := by
  rw [homogObjDiff_val_eq p G n x]
  simpa using towerEval_multiInd_d p G n x.1 (prefixProdTuple G (n + 1) g)

theorem selectedInhomogToHomog_comm_d_aux (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (homogObjDiff p G n).comp (selectedInhomogToHomog_aux p G n) = (selectedInhomogToHomog_aux p G (n + 1)).comp (_root_.Erdos90.InhomogContsCochains.d p G n) := by
  classical
  have hT :
      (selectedHomogToInhomog_aux p G (n + 1)).comp
          ((homogObjDiff p G n).comp (selectedInhomogToHomog_aux p G n)) =
        (selectedHomogToInhomog_aux p G (n + 1)).comp
          ((selectedInhomogToHomog_aux p G (n + 1)).comp
            (_root_.Erdos90.InhomogContsCochains.d p G n)) := by
    ext f g
    simp only [LinearMap.comp_apply]
    conv_lhs =>
      rw [selectedHomogToInhomog_aux_apply]
      rw [towerEval_homogObjDiff_prefixProd]
    have hcp :
        consecutiveDifferencesTuple G (n + 1) (prefixProdTuple G (n + 1) g) = g := by
      simpa [consecutiveDifferencesTuple, prefixProdTuple] using
        (consecutiveDifferences_partialProd G (n + 1) g)
    conv_rhs =>
      rw [selectedHomogToInhomog_aux_apply]
      rw [selectedInhomogToHomog_aux_apply]
      rw [hcp]
    have htail :
        Fin.tail (prefixProdTuple G (n + 1) g) =
          fun i : Fin (n + 1) => g 0 * prefixProdTuple G n (Fin.tail g) i := by
      funext i
      simpa [prefixProdTuple] using (Fin.partialProd_succ' g i)
    have hhead :
        towerEval p G (n + 1) ((selectedInhomogToHomog_aux p G n f).1)
            (Fin.tail (prefixProdTuple G (n + 1) g)) =
          f (Fin.tail g) := by
      rw [htail]
      rw [homogObj_towerEval_leftMul]
      rw [← selectedHomogToInhomog_aux_apply]
      change
        (((selectedHomogToInhomog_aux p G n).comp (selectedInhomogToHomog_aux p G n)) f)
            (Fin.tail g) = f (Fin.tail g)
      rw [selectedHomogToInhomog_inhomogToHomog_aux]
      rfl
    rw [hhead]
    have hsum :
        ∀ j : Fin (n + 1),
          towerEval p G (n + 1) ((selectedInhomogToHomog_aux p G n f).1)
              (j.succ.removeNth (prefixProdTuple G (n + 1) g)) =
            f (Fin.contractNth j (· * ·) g) := by
      intro j
      rw [selectedInhomogToHomog_aux_apply]
      rw [consecutiveDifferences_succRemoveNth_prefixProd]
    rw [_root_.Erdos90.InhomogContsCochains.d_apply,
      _root_.Erdos90.InhomogContsCochains.dAux.toFun]
    simp [hsum]
    rfl
  have h := congrArg (fun L => (selectedInhomogToHomog_aux p G (n + 1)).comp L) hT
  dsimp only at h
  repeat rw [← LinearMap.comp_assoc] at h
  rw [selectedInhomogToHomog_homogToInhomog_aux] at h
  simp only [LinearMap.id_comp] at h
  exact h

theorem inhomogToHomog_comm_d (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : ℕ) : (homogObjDiff p G n).comp (inhomogToHomog p G n) = (inhomogToHomog p G (n + 1)).comp (_root_.Erdos90.InhomogContsCochains.d p G n) := by
  simpa [inhomogToHomog] using selectedInhomogToHomog_comm_d_aux p G n

noncomputable def inhomogCohomology_complexHomologyEquiv (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) :
    _root_.Erdos90.InhomogClassAPI.Cohomology p G n ≃ₗ[ZMod p] (((_root_.Erdos90.InhomogContsCochains.complex p G).homology n) : Type) := by
  classical
  let B : Submodule (ZMod p) (_root_.Erdos90.InhomogContsCochains.Cochain p G n) :=
    LinearMap.ker (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).g.hom)
  have hker : B = _root_.Erdos90.InhomogClassAPI.Cocycles p G n := by
    change (ModuleCat.Hom.hom ((_root_.Erdos90.InhomogContsCochains.complex p G).d n ((ComplexShape.up ℕ).next n))).ker =
      (_root_.Erdos90.InhomogContsCochains.d p G n).ker
    rw [CochainComplex.next]
    simp [_root_.Erdos90.InhomogContsCochains.complex]
    rfl

  refine intervalIntegral.continuousWithinAt_of_dominated_interval ?_ ?_ h_bound_int ?_
  В· refine Filter.Eventually.of_forall ?_
    intro w
    have hUreal : Measurable fun y : в„қ => logRescalePartialSum f y - b :=
      measurable_logRescalePartialSum.sub_const b
    have hU : Measurable fun y : в„қ => (((logRescalePartialSum f y - b : в„қ) : в„Ӯ)) :=
      hUreal.complex_ofReal
    have hExp : Measurable fun y : в„қ => Complex.exp (-w * (y : в„Ӯ)) := by

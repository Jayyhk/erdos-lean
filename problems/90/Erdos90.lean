theorem closedFrattini_le_comap_frattini_of_open_normal (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : в„•) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (N : Subgroup G) [N.Normal] (hNopen : IsOpen (N : Set G)) : closedFrattini p G вүӨ (frattini (G в§ё N)).comap (QuotientGroup.mk' N) := by
  classical
  let ПҖ : G вҶ’* G в§ё N := QuotientGroup.mk' N
  haveI : CompactSpace G := hG.compactSpace
  haveI : Finite (G в§ё N) := Subgroup.quotient_finite_of_isOpen N hNopen
  haveI : DiscreteTopology (G в§ё N) := QuotientGroup.discreteTopology (N := N) hNopen
  have hQp : IsPGroup p (G в§ё N) := hG.isPGroup_quotient N hNopen
  have hpowcomm :
      Subgroup.closure ((Set.range (fun q : G в§ё N => q ^ p)) вҲӘ
        (commutator (G в§ё N) : Set (G в§ё N))) вүӨ frattini (G в§ё N) :=
    powers_commutator_le_frattini_of_finite_pgroup (G в§ё N) p hQp
  have hcomm_map : (commutator G).map ПҖ = commutator (G в§ё N) := by
    rw [map_commutator_eq,
      MonoidHom.range_eq_top_of_surjective ПҖ (QuotientGroup.mk'_surjective N)]
    rfl
  have halg :
      Subgroup.closure ((Set.range (fun g : G => g ^ p)) вҲӘ (commutator G : Set G)) вүӨ
        (frattini (G в§ё N)).comap ПҖ := by
    refine (Subgroup.closure_le ((frattini (G в§ё N)).comap ПҖ)).2 ?_
    intro x hx
    change x вҲҲ (frattini (G в§ё N)).comap ПҖ
    rw [Subgroup.mem_comap]
    rcases hx with hx | hx
    В· rcases hx with вҹЁg, rflвҹ©
      rw [MonoidHom.map_pow]
      exact hpowcomm (Subgroup.subset_closure (Or.inl вҹЁПҖ g, rflвҹ©))
    В· have hxmap : ПҖ x вҲҲ (commutator G).map ПҖ :=
        Subgroup.mem_map_of_mem ПҖ hx
      rw [hcomm_map] at hxmap
      exact hpowcomm (Subgroup.subset_closure (Or.inr hxmap))
  have hclosed : IsClosed (((frattini (G в§ё N)).comap ПҖ : Subgroup G) : Set G) := by
    change IsClosed (ПҖ вҒ»В№' (frattini (G в§ё N) : Set (G в§ё N)))
    have hfrclosed : IsClosed (frattini (G в§ё N) : Set (G в§ё N)) :=
      isClosed_discrete _
    exact hfrclosed.preimage (by
      simpa only [ПҖ, QuotientGroup.coe_mk' N] using (QuotientGroup.continuous_mk (N := N)))
  simpa only [closedFrattini] using
    (Subgroup.topologicalClosure_minimal
      (Subgroup.closure ((Set.range (fun g : G => g ^ p)) вҲӘ (commutator G : Set G)))
      halg hclosed)

theorem closedFrattini_nongenerating (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : в„•) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (K : Subgroup G) (hKclosed : IsClosed (K : Set G)) (hK : K вҠ” closedFrattini p G = вҠӨ) : K = вҠӨ := by
  classical
  haveI := hG.compactSpace
  haveI := hG.t2Space
  haveI := hG.totallyDisconnectedSpace
  by_contra hKtop
  have hnotall : В¬ вҲҖ x : G, x вҲҲ K := by
    intro hAll
    apply hKtop
    ext y
    constructor
    В· intro _
      trivial
    В· intro _
      exact hAll y
  obtain вҹЁx, hxKвҹ© : вҲғ x : G, x вҲү K := not_forall.mp hnotall
  let U : Set G := ((Homeomorph.mulLeft x) '' (K : Set G))б¶ң
  have hUopen : IsOpen U := by
    dsimp [U]
    exact ((Homeomorph.mulLeft x).isClosedMap _ hKclosed).isOpen_compl
  have hU1 : (1 : G) вҲҲ U := by
    refine Set.mem_compl ?_
    rintro вҹЁl, hl, hxlвҹ©
    have hxl' : x * l = 1 := by simpa using hxl
    rw [вҶҗ inv_eq_iff_mul_eq_one] at hxl'
    exact hxK <| inv_mem_iff.mp (hxl' в–ё hl)
  obtain вҹЁN, hNsubUвҹ© :=
    ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one (G := G) hUopen hU1
  have hxNK : x вҲү (N : Subgroup G) вҠ” K := by
    intro hxNK
    rcases Subgroup.mem_sup_of_normal_left.mp hxNK with вҹЁy, hy, z, hz, hyzвҹ©
    rw [вҶҗ eq_mul_inv_iff_mul_eq] at hyz
    have hximage : x * zвҒ»В№ вҲҲ (Homeomorph.mulLeft x) '' (K : Set G) := by
      refine вҹЁzвҒ»В№, inv_mem_iff.mpr hz, rflвҹ©
    exact hNsubU (hyz в–ё hy) hximage
  let ПҖ : G вҶ’* G в§ё (N : Subgroup G) := QuotientGroup.mk' (N : Subgroup G)
  let H : Subgroup (G в§ё (N : Subgroup G)) := K.map ПҖ
  haveI : Finite (G в§ё (N : Subgroup G)) :=
    Subgroup.quotient_finite_of_isOpen (U := (N : Subgroup G)) N.isOpen
  haveI : IsCoatomic (Subgroup (G в§ё (N : Subgroup G))) := Finite.to_isCoatomic
  have hcf : closedFrattini p G вүӨ (frattini (G в§ё (N : Subgroup G))).comap ПҖ :=
    closedFrattini_le_comap_frattini_of_open_normal (G := G) (p := p) hG (N := (N : Subgroup G))
      (hNopen := N.isOpen)
  have hcfmap : (closedFrattini p G).map ПҖ вүӨ frattini (G в§ё (N : Subgroup G)) :=
    (Subgroup.map_le_iff_le_comap).2 hcf
  have hHsup : H вҠ” frattini (G в§ё (N : Subgroup G)) = вҠӨ := by
    apply top_unique
    calc
      (вҠӨ : Subgroup (G в§ё (N : Subgroup G))) = (K вҠ” closedFrattini p G).map ПҖ := by
        rw [hK, Subgroup.map_top_of_surjective ПҖ QuotientGroup.mk_surjective]
      _ = H вҠ” (closedFrattini p G).map ПҖ := by
        rw [Subgroup.map_sup]
      _ вүӨ H вҠ” frattini (G в§ё (N : Subgroup G)) := by
        exact sup_le_sup le_rfl hcfmap
  have hHtop : H = вҠӨ := frattini_nongenerating (K := H) hHsup
  have hKNtop : K вҠ” (N : Subgroup G) = вҠӨ := by
    have hmap_eq : K.map ПҖ = (вҠӨ : Subgroup G).map ПҖ := by
      calc
        K.map ПҖ = H := by rfl
        _ = вҠӨ := hHtop
        _ = (вҠӨ : Subgroup G).map ПҖ := by
          symm
          exact Subgroup.map_top_of_surjective ПҖ QuotientGroup.mk_surjective
    have hsupker : K вҠ” ПҖ.ker = вҠӨ вҠ” ПҖ.ker :=
      (Subgroup.map_eq_map_iff (f := ПҖ) (H := K) (K := вҠӨ)).mp hmap_eq
    simpa [ПҖ, QuotientGroup.ker_mk'] using hsupker
  have hxTop : x вҲҲ (вҠӨ : Subgroup G) := by trivial
  have hxKN' : x вҲҲ K вҠ” (N : Subgroup G) := by
    simp [hKNtop]
  exact hxNK (by simpa [sup_comm] using hxKN')

theorem generatorRank_eq_of_closed_normal_le_closedFrattini (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (p : в„•) [Fact (Nat.Prime p)] (hG : IsFinitelyGeneratedProPGroup p G) (N : Subgroup G) [N.Normal] (hNclosed : IsClosed (N : Set G)) (hNphi : N вүӨ closedFrattini p G) : generatorRank (G в§ё N) = generatorRank G := by
  classical
  apply le_antisymm
  В· exact generatorRank_quotient_le_of_closed_normal G p hG N
  В· rcases generatorRank_spec hG with вҹЁSвӮҖ, hSвӮҖ_card, hSвӮҖ_topвҹ©
    let TвӮҖ : Finset (G в§ё N) := SвӮҖ.image (QuotientGroup.mk' N)
    have hTвӮҖ_top : (Subgroup.closure (TвӮҖ : Set (G в§ё N))).topologicalClosure = вҠӨ := by
      have htop : ((Subgroup.closure (SвӮҖ : Set G)).map (QuotientGroup.mk' N)).topologicalClosure =
          (вҠӨ : Subgroup (G в§ё N)) := by
        simpa using
          (DenseRange.topologicalClosure_map_subgroup
            (f := QuotientGroup.mk' N) continuous_quotient_mk'
            (QuotientGroup.mk'_surjective N).denseRange hSвӮҖ_top)
      rw [MonoidHom.map_closure] at htop
      simpa [TвӮҖ, Finset.coe_image] using htop
    rcases generatorRank_spec_of_exists_generating_finset (G := G в§ё N) вҹЁTвӮҖ, hTвӮҖ_topвҹ© with
      вҹЁT, hT_card, hT_topвҹ©
    let lift : G в§ё N вҶ’ G := fun q => Classical.choose (QuotientGroup.mk'_surjective N q)
    have hlift : вҲҖ q : G в§ё N, QuotientGroup.mk' N (lift q) = q := by
      intro q
      exact Classical.choose_spec (QuotientGroup.mk'_surjective N q)
    let S : Finset G := T.image lift
    let K : Subgroup G := (Subgroup.closure (S : Set G)).topologicalClosure
    have hKclosed : IsClosed (K : Set G) := by
      dsimp [K]
      exact Subgroup.isClosed_topologicalClosure _
    haveI : CompactSpace G := hG.compactSpace
    haveI : IsClosed (N : Set G) := hNclosed
    haveI : T2Space (G в§ё N) := by
      haveI : T1Space (G в§ё N) := QuotientGroup.instT1Space
      infer_instance
    have hKmap_closed : IsClosed (K.map (QuotientGroup.mk' N) : Set (G в§ё N)) := by
      have hKcompact : IsCompact (K : Set G) := hKclosed.isCompact
      have hcompact : IsCompact (K.map (QuotientGroup.mk' N) : Set (G в§ё N)) := by
        simpa [Subgroup.coe_map] using hKcompact.image continuous_quotient_mk'
      exact hcompact.isClosed
    have hTsub : (T : Set (G в§ё N)) вҠҶ K.map (QuotientGroup.mk' N) := by
      intro t ht
      have hmemS : lift t вҲҲ S := by
        exact Finset.mem_image.mpr вҹЁt, ht, rflвҹ©
      have hmemClosure : lift t вҲҲ Subgroup.closure (S : Set G) :=
        Subgroup.subset_closure hmemS
      have hmemK : lift t вҲҲ K :=
        Subgroup.le_topologicalClosure _ hmemClosure
      have hmapmem : QuotientGroup.mk' N (lift t) вҲҲ K.map (QuotientGroup.mk' N) :=
        Subgroup.mem_map_of_mem (QuotientGroup.mk' N) hmemK
      simpa [hlift t] using hmapmem
    have hTclosure_le : (Subgroup.closure (T : Set (G в§ё N))).topologicalClosure вүӨ
        K.map (QuotientGroup.mk' N) := by
      apply Subgroup.topologicalClosure_minimal
      В· exact (Subgroup.closure_le (K := K.map (QuotientGroup.mk' N))).2 hTsub
      В· exact hKmap_closed
    have hKmap_top : K.map (QuotientGroup.mk' N) = вҠӨ := by
      apply top_unique
      rw [вҶҗ hT_top]
      exact hTclosure_le
    have hKN_top : K вҠ” N = вҠӨ := by
      rw [sup_comm, вҶҗ QuotientGroup.comap_map_mk' N K, hKmap_top, Subgroup.comap_top]
    have hKphi : K вҠ” closedFrattini p G = вҠӨ := by
      apply top_unique
      calc
        вҠӨ = K вҠ” N := by symm; exact hKN_top
        _ вүӨ K вҠ” closedFrattini p G := sup_le_sup le_rfl hNphi
    have hKtop : K = вҠӨ :=
      closedFrattini_nongenerating G p hG K hKclosed hKphi
    have hGle : generatorRank G вүӨ S.card := by
      exact generatorRank_le_of_generating_finset G S (by simpa [K] using hKtop)
    have hScard : S.card вүӨ T.card := by
      simpa [S] using (Finset.card_image_le (s := T) (f := lift))
    calc
      generatorRank G вүӨ S.card := hGle
      _ вүӨ T.card := hScard
      _ = generatorRank (G в§ё N) := hT_card

theorem frattini_quotient_generator_rank (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : в„•) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    {k : в„•} (g : Fin k вҶ’ G) (hg : вҲҖ i, g i вҲҲ closedFrattini p G) :
    generatorRank (proPQuotientOfFrattiniElements G p hG g hg).Q
      = generatorRank G := by
  simpa [proPQuotientOfFrattiniElements] using
    (generatorRank_eq_of_closed_normal_le_closedFrattini G p hG (closedNormalClosureRange g)
      (closedNormalClosureRange.isClosed g)
      (closedNormalClosureRange_le_closedFrattini G p g hg))

theorem proPQuotientOfFrattiniElements_relationRank_bound
    (h5term : _root_.Erdos90.Hyp_FiveTermRelationBound)
    (hBurnside : _root_.Erdos90.Hyp_NormallyGenH1InvariantBound)
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : в„•) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    (hH2G : _root_.Erdos90.H2Finite p G)
    {k : в„•} (g : Fin k вҶ’ G) (hg : вҲҖ i, g i вҲҲ closedFrattini p G) :
    _root_.Erdos90.H2Finite p (proPQuotientOfFrattiniElements G p hG g hg).Q вҲ§
      relationRank p (proPQuotientOfFrattiniElements G p hG g hg).Q
        вүӨ relationRank p G + k := by
  haveI : T2Space G := hG.t2Space
  haveI : CompactSpace G := hG.compactSpace
  haveI : TotallyDisconnectedSpace G := hG.totallyDisconnectedSpace
  let N : Subgroup G := (Subgroup.normalClosure (Set.range g)).topologicalClosure
  haveI : N.Normal :=
    Subgroup.is_normal_topologicalClosure (N := Subgroup.normalClosure (Set.range g))
  have hClosed : IsClosed (N : Set G) := Subgroup.isClosed_topologicalClosure _
  obtain вҹЁhH1Fin, hh1вҹ© := hBurnside p G hG k g

  obtain вҹЁhH2quot, hrelвҹ© := h5term p G hG hH2G N hClosed hH1Fin
  refine вҹЁ?_, ?_вҹ©
  В· simpa [proPQuotientOfFrattiniElements, closedNormalClosureRange, N] using hH2quot
  В· have hh1' : _root_.Erdos90.h1NormalInvariantRank p G N вүӨ k := hh1
    have hcombine : relationRank p (G в§ё N) вүӨ relationRank p G + k := by
      refine le_trans hrel ?_; omega
    simpa [proPQuotientOfFrattiniElements, closedNormalClosureRange, N] using hcombine

theorem frattini_quotient_lemma
    (h5term : _root_.Erdos90.Hyp_FiveTermRelationBound)
    (hBurnside : _root_.Erdos90.Hyp_NormallyGenH1InvariantBound)
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : в„•) [Fact (Nat.Prime p)]
    (hG : IsFinitelyGeneratedProPGroup p G)
    (hH2G : _root_.Erdos90.H2Finite p G)
    (k : в„•) (g : Fin k вҶ’ G) (hg : вҲҖ i, g i вҲҲ closedFrattini p G) :
    вҲғ Q : ProPQuotient p G,

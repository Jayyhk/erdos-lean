    abel_nf at hПү0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hПү0.symm

  have hПҮcont' : Continuous (ПҮh : Additive вҶҘN вҶ’ ZMod p) := hПҮcont
  simpa [inflatedSchreier2Cocycle, ПҮh, r, Оҙ,
    _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle, hПҮcont',
    sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hПү


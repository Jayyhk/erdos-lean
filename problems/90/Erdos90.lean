theorem boundary_extension_shifted_laplace_eq {f : в„• вҶ’ в„қ} {b Оҙ : в„қ} :
  HasBoundaryLaplaceExtension f b вҶ’ 0 < Оҙ вҶ’
  вҲҖ z : в„Ӯ, 0 < z.re вҶ’
    вҲ« x in Set.Ioi (0 : в„қ),
      ((((logRescalePartialSum f (x + Оҙ) - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
    = Complex.exp (z * Оҙ) *
        ((вҲ« x in Set.Ioi (0 : в„қ),
            (((logRescalePartialSum f x - b : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
          - вҲ« y in (0 : в„қ)..Оҙ,

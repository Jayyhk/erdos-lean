    hDplus h u1 u2 hTbase hcore (densityNumerator := 1)
    (densityDenominator := params.protectedEndpoint + 1)
    (by omega) hlohi hlo_private hhi_private hlo_sum hhi_sum
    (params.protectedSubblock_density_arithmetic

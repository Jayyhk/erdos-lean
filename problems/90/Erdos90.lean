theorem inflation_restriction_H1_injective_zmod (p : ℕ) (G : Type) [Group G] (N : Subgroup G) [N.Normal] : Function.Injective ((groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).f) := by

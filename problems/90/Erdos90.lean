    burnside_span_top_of_group_generators p Q T hT
  have hle : Module.finrank (ZMod p) (Submodule.span (ZMod p) (T : Set Q)) ≤ T.card := by
    simpa [Set.finrank] using (finrank_span_finset_le_card (R := ZMod p) T)
  rw [hspan, finrank_top] at hle
  exact hle

theorem burnside_basis (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (p : ℕ) [Fact (Nat.Prime p)]
    (_hG : _root_.Erdos90.IsFinitelyGeneratedProPGroup p G)
    (k : ℕ)
    (Q : Type) [AddCommGroup Q] [Module (ZMod p) Q]
    [TopologicalSpace Q] [DiscreteTopology Q]
    (_hQrank : Module.finrank (ZMod p) Q = k)
    (φ : G →* Multiplicative Q)
    (_hφ_surj : Function.Surjective φ)
    (_hφ_cont : Continuous φ)
    : k ≤ _root_.Erdos90.generatorRank G := by
  classical
  rw [← _hQrank]
  rcases _root_.Erdos90.generatorRank_spec _hG with ⟨S, hS_card, hS_top⟩
  let T : Finset Q := S.image (fun g => (φ g).toAdd)
  have hTgen : Subgroup.closure (Multiplicative.ofAdd '' (T : Set Q)) = (⊤ : Subgroup (Multiplicative Q)) := by
    simpa [T, Finset.coe_image, Set.image_image, ofAdd_toAdd]
      using burnside_image_generates G Q φ _hφ_surj _hφ_cont S hS_top
  have hfin : Module.finrank (ZMod p) Q ≤ T.card :=

theorem theorem_2_3 (t : в„•) (_ht_pos : 0 < t) (q : Fin t вҶ’ в„•)
    (рқ’ҹ : в„• вҶ’ AdmissibleDatum)
    (sameT : вҲҖ j, (рқ’ҹ j).t = t)
    (_sameQ : вҲҖ j (b : Fin t),
        (рқ’ҹ j).q (Fin.cast (sameT j).symm b) = q b)
    (H : в„қ) (hH : 0 < H)
    (_hClass : вҲҖ j, (NumberField.classNumber (рқ’ҹ j).K : в„қ) вүӨ H ^ (рқ’ҹ j).f)
    (_degsUnbounded : вҲҖ N, вҲғ j, N вүӨ (рқ’ҹ j).f)

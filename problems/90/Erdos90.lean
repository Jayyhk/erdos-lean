    simpa [hD_eq] using h
  have hD_one : 1 вүӨ D := by
    have h : (1 : в„қ) вүӨ ((рқ’ҹ 0).denom : в„қ) := by
      exact_mod_cast (Nat.succ_le_of_lt (рқ’ҹ 0).denom_pos)
    simpa [hD_eq] using h
  have h4R : 2 < 4 * R := by
    nlinarith [hR]
  have h4R_nonneg : 0 вүӨ 4 * R := by
    nlinarith [hR]
  have hmul : 4 * R вүӨ 4 * R * D := by
    have := mul_le_mul_of_nonneg_left hD_one h4R_nonneg
    simpa [mul_assoc] using this
  have h4RD_gt_two : 2 < 4 * R * D := by
    exact lt_of_lt_of_le h4R hmul

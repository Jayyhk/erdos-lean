  вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ x : в„қ, вҖ–Оә xвҖ– вүӨ C := by
  intro hОә
  let g : в„қ вҶ’ в„Ӯ := FourierTransform.fourier Оә
  have hg_int : MeasureTheory.Integrable g := by
    simpa [g] using hОә.fourier_continuous.integrable_of_hasCompactSupport hОә.fourier_compact
  refine вҹЁвҲ« y : в„қ, вҖ–g yвҖ–, ?_, ?_вҹ©
  В· exact MeasureTheory.integral_nonneg fun y => norm_nonneg _
  В· intro x
    have hx : FourierTransformInv.fourierInv g x = Оә x := by
      simpa [g] using
        MeasureTheory.Integrable.fourierInv_fourier_eq hОә.integrable hg_int
          (hОә.continuous.continuousAt)
    rw [вҶҗ hx, Real.fourierInv_eq]
    calc
      вҖ–вҲ« v : в„қ, Real.fourierChar (inner в„қ v x) вҖў g vвҖ– вүӨ вҲ« v : в„қ, вҖ–Real.fourierChar (inner в„қ v x) вҖў g vвҖ– :=
        MeasureTheory.norm_integral_le_integral_norm _
      _ = вҲ« v : в„қ, вҖ–g vвҖ– := by
        congr with v
        simp

theorem compactFreqKernel_frequency_tendsto {ПҲ : в„қ вҶ’ в„Ӯ} {G : в„Ӯ вҶ’ в„Ӯ} :
    (hПҲ : CompactFreqKernel ПҲ) вҶ’
    (hGcont : ContinuousOn G {z : в„Ӯ | 0 вүӨ z.re}) вҶ’
    вҲҖ X : в„қ,
      Filter.Tendsto
        (fun Пғ : в„қ =>
          FourierTransform.fourier
            (fun Оҫ : в„қ => (FourierTransform.fourier ПҲ Оҫ) *
              G ((Пғ : в„Ӯ) + (((( -2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)))) X)
        (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)))
        (nhds
          (FourierTransform.fourier
            (fun Оҫ : в„қ => (FourierTransform.fourier ПҲ Оҫ) *
              G (((( -2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I))) X)) := by
  intro hПҲ hGcont X
  let s : Set в„қ := Set.Ici (0 : в„қ)
  let k : Set в„қ := tsupport (FourierTransform.fourier ПҲ)
  have hk : IsCompact k := hПҲ.fourier_compact.isCompact
  have hcont_aff : Continuous fun p : в„қ Г— в„қ =>
      ((p.1 : в„Ӯ) + ((((-2 * Real.pi * p.2 : в„қ) : в„Ӯ) * Complex.I))) := by
    fun_prop
  have hmap : Set.MapsTo
      (fun p : в„қ Г— в„қ => ((p.1 : в„Ӯ) + ((((-2 * Real.pi * p.2 : в„қ) : в„Ӯ) * Complex.I))))
      (s Г—Лў Set.univ) {z : в„Ӯ | 0 вүӨ z.re} := by
    intro p hp
    rcases hp with вҹЁhp, hp_univвҹ©
    show 0 вүӨ (((p.1 : в„Ӯ) + ((((-2 * Real.pi * p.2 : в„қ) : в„Ӯ) * Complex.I))).re)
    simpa [s]
  have hGpair : ContinuousOn
      (fun p : в„қ Г—в„қ => G ((p.1 : в„Ӯ) + ((((-2 * Real.pi * p.2 : в„қ) : в„Ӯ) * Complex.I))))
      (s Г—Лў Set.univ) := by
    exact hGcont.comp hcont_aff.continuousOn hmap
  have hfourierpair : ContinuousOn
      (fun p : в„қ Г— в„қ => FourierTransform.fourier ПҲ p.2)
      (s Г—Лў Set.univ) := by
    exact (hПҲ.fourier_continuous.comp continuous_snd).continuousOn
  have hphase : Continuous fun Оҫ : в„қ => Complex.exp (вҶ‘(-2 * Real.pi * Оҫ * X) * Complex.I) := by
    fun_prop
  have hphasepair : ContinuousOn
      (fun p : в„қ Г— в„қ => Complex.exp (вҶ‘(-2 * Real.pi * p.2 * X) * Complex.I))
      (s Г—Лў Set.univ) := by
    exact (hphase.comp continuous_snd).continuousOn
  have hcont : ContinuousOn
      (fun p : в„қ Г— в„қ =>
        Complex.exp (вҶ‘(-2 * Real.pi * p.2 * X) * Complex.I) *
          ((FourierTransform.fourier ПҲ p.2) *
            G ((p.1 : в„Ӯ) + ((((-2 * Real.pi * p.2 : в„қ) : в„Ӯ) * Complex.I)))))
      (s Г—Лў Set.univ) := by
    exact hphasepair.mul (hfourierpair.mul hGpair)
  have hzero : вҲҖ p x, p вҲҲ s вҶ’ x вҲү k вҶ’
      Complex.exp (вҶ‘(-2 * Real.pi * x * X) * Complex.I) *
        ((FourierTransform.fourier ПҲ x) *
          G ((p : в„Ӯ) + ((((-2 * Real.pi * x : в„қ) : в„Ӯ) * Complex.I)))) = 0 := by
    intro p x hp hx
    simp [k, image_eq_zero_of_notMem_tsupport, hx]
  have hcontInt : ContinuousOn
      (fun Пғ : в„қ =>
        вҲ« Оҫ : в„қ,
          Complex.exp (вҶ‘(-2 * Real.pi * Оҫ * X) * Complex.I) *
            ((FourierTransform.fourier ПҲ Оҫ) *
              G ((Пғ : в„Ӯ) + ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)))) )
      s := by
    simpa using continuousOn_integral_of_compact_support (Ој := MeasureTheory.volume) hk hcont hzero
  have hПғ : ContinuousWithinAt
      (fun Пғ : в„қ =>
        вҲ« Оҫ : в„қ,
          Complex.exp (вҶ‘(-2 * Real.pi * Оҫ * X) * Complex.I) *
            ((FourierTransform.fourier ПҲ Оҫ) *
              G ((Пғ : в„Ӯ) + ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)))) )
      s 0 := hcontInt.continuousWithinAt (by simp [s])
  have hmain := hПғ.tendsto
  have hsubset : Set.Ioi (0 : в„қ) вҠҶ s := by
    intro x hx
    have hx' : 0 < x := by simpa using hx
    exact hx'.le
  have hmain' := hmain.mono_left (nhdsWithin_mono 0 hsubset)
  convert hmain' using 1
  В· ext Пғ
    rw [Real.fourier_real_eq_integral_exp_smul]
    simp only [smul_eq_mul, mul_assoc]
  В· rw [Real.fourier_real_eq_integral_exp_smul]
    simp only [smul_eq_mul, mul_assoc]
    apply congrArg nhds
    apply MeasureTheory.integral_congr_ae
    filter_upwards with Оҫ
    rw [show ((0 : в„қ) : в„Ӯ) = 0 by norm_num, zero_add]

theorem compactFreqKernel_negativeTail_tendsto_zero {ПҲ : в„қ вҶ’ в„Ӯ} {c : в„Ӯ} :
    (hПҲ : CompactFreqKernel ПҲ) вҶ’
    Filter.Tendsto (fun X : в„қ => вҲ« u in Set.Iic (-X), ПҲ u * c) Filter.atTop (nhds 0) := by
  intro hПҲ
  let g : в„қ вҶ’ в„Ӯ := fun u => ПҲ u * c
  have hg : MeasureTheory.Integrable g := by
    simpa [g] using hПҲ.integrable.mul_const c
  have hneg : Filter.Tendsto (fun X : в„қ => -X) Filter.atTop Filter.atBot := by
    refine Filter.tendsto_atTop_atBot_of_antitone ?_ ?_
    В· intro a b hab
      linarith
    В· intro b
      refine вҹЁ-b, by simpвҹ©
  have hinterval :
      Filter.Tendsto (fun X : в„қ => вҲ« u in (-X)..0, g u) Filter.atTop
        (nhds (вҲ« u in Set.Iic 0, g u)) := by
    simpa using
      (MeasureTheory.intervalIntegral_tendsto_integral_Iic (Ој := MeasureTheory.volume)
        (a := fun X : в„қ => -X) (f := g) 0 hg.integrableOn hneg)
  have hsub :
      Filter.Tendsto
        (fun X : в„қ => (вҲ« u in Set.Iic 0, g u) - вҲ« u in Set.Iic (-X), g u)
        Filter.atTop (nhds (вҲ« u in Set.Iic 0, g u)) := by
    have hEq :
        (fun X : в„қ => (вҲ« u in Set.Iic 0, g u) - вҲ« u in Set.Iic (-X), g u) =
          fun X : в„қ => вҲ« u in (-X)..0, g u := by
      funext X
      simpa using
        (intervalIntegral.integral_Iic_sub_Iic (Ој := MeasureTheory.volume)
          (f := g) (a := -X) (b := 0) hg.integrableOn hg.integrableOn)
    rw [hEq]
    exact hinterval
  have hconst :
      Filter.Tendsto (fun _ : в„қ => вҲ« u in Set.Iic 0, g u) Filter.atTop
        (nhds (вҲ« u in Set.Iic 0, g u)) :=
    tendsto_const_nhds
  have hzero :
      Filter.Tendsto
        (fun X : в„қ => (вҲ« u in Set.Iic 0, g u) - ((вҲ« u in Set.Iic 0, g u) - вҲ« u in Set.Iic (-X), g u))
        Filter.atTop (nhds ((вҲ« u in Set.Iic 0, g u) - вҲ« u in Set.Iic 0, g u)) := by
    exact hconst.sub hsub
  simpa [g, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hzero

theorem compactFreqKernel_reflect {ПҲ : в„қ вҶ’ в„Ӯ} :
  CompactFreqKernel ПҲ вҶ’
  CompactFreqKernel (fun u : в„қ => ПҲ (-u)) := by
  intro hПҲ
  have hfourier :
      FourierTransform.fourier (fun u : в„қ => ПҲ (-u)) =
        fun Оҫ : в„қ => FourierTransform.fourier ПҲ (-Оҫ) := by
    funext Оҫ
    simpa [Function.comp] using
      (Real.fourier_comp_linearIsometry
        (A := (LinearIsometryEquiv.neg в„қ : в„қ вүғвӮ—бөў[в„қ] в„қ)) (f := ПҲ) (w := Оҫ))
  refine CompactFreqKernel.mk ?_ ?_ ?_ ?_ ?_
  В· exact hПҲ.continuous.comp continuous_neg
  В· simpa using hПҲ.integrable.comp_mul_left' (show (-1 : в„қ) вү  0 by norm_num)
  В· rw [hfourier]
    simpa [Function.comp] using hПҲ.fourier_continuous.comp continuous_neg
  В· rw [hfourier]
    simpa [Function.comp] using
      hПҲ.fourier_compact.comp_homeomorph (Homeomorph.neg в„қ)
  В· have hmass : (вҲ« u : в„қ, ПҲ (-u)) = вҲ« u : в„қ, ПҲ u := by
      simpa using (MeasureTheory.Measure.integral_comp_mul_left (g := ПҲ) (-1 : в„қ))
    exact hmass.trans hПҲ.mass_one

theorem compactFreqKernel_translate {ПҲ : в„қ вҶ’ в„Ӯ} (a : в„қ) :
  CompactFreqKernel ПҲ вҶ’
  CompactFreqKernel (fun u : в„қ => ПҲ (u - a)) := by
  intro hПҲ
  have hfourier :
      FourierTransform.fourier (fun u : в„қ => ПҲ (u - a)) =
        fun Оҫ : в„қ => Real.fourierChar (-inner в„қ a Оҫ) вҖў FourierTransform.fourier ПҲ Оҫ := by
    simpa [FourierTransform.fourier, sub_eq_add_neg] using
      (VectorFourier.fourierIntegral_comp_add_right Real.fourierChar MeasureTheory.volume (innerвӮ— в„қ) ПҲ (-a))
  refine вҹЁ?_, ?_, ?_, ?_, ?_вҹ©
  В· simpa using hПҲ.continuous.comp (continuous_id.sub continuous_const)
  В· simpa using hПҲ.integrable.comp_sub_right a
  В· rw [hfourier]
    exact (Real.continuous_fourierChar.comp ((continuous_const.inner continuous_id).neg)).smul
      hПҲ.fourier_continuous
  В· rw [hfourier]
    simpa using
      (HasCompactSupport.smul_left
        (f := fun Оҫ : в„қ => Real.fourierChar (-inner в„қ a Оҫ)) hПҲ.fourier_compact)
  В·
    simpa using
      (MeasureTheory.integral_sub_right_eq_self (f := ПҲ) a).trans hПҲ.mass_one

theorem continuousOn_shift_sub_const_div_one_add {g : в„Ӯ вҶ’ в„Ӯ} {c : в„Ӯ} :
    ContinuousOn g {s : в„Ӯ | 1 вүӨ s.re} вҶ’
    ContinuousOn (fun z : в„Ӯ => (g (1 + z) - c) / (1 + z)) {z : в„Ӯ | 0 вүӨ z.re} := by
  intro hg
  have hden : ContinuousOn (fun z : в„Ӯ => 1 + z) {z : в„Ӯ | 0 вүӨ z.re} :=
    (continuous_const.add continuous_id).continuousOn
  have hcomp : ContinuousOn (fun z : в„Ӯ => g (1 + z)) {z : в„Ӯ | 0 вүӨ z.re} := by
    refine hg.comp hden ?_
    intro z hz
    have hzre : 0 вүӨ z.re := hz
    simpa [Complex.add_re] using add_le_add_left hzre 1
  have hnum : ContinuousOn (fun z : в„Ӯ => g (1 + z) - c) {z : в„Ӯ | 0 вүӨ z.re} :=
    hcomp.sub continuousOn_const
  refine hnum.div hden ?_
  intro z hz
  have hzre : 0 вүӨ z.re := hz
  have hz' : 1 вүӨ (1 + z).re := by
    simpa [Complex.add_re] using add_le_add_left hzre 1
  intro h0
  have h0re : (1 + z).re = 0 := by
    simpa using congrArg Complex.re h0
  linarith

theorem eventually_mul_le_of_eventually_floor_pow_mul_le {f : в„• вҶ’ в„қ} {c : в„қ} :
    1 < c вҶ’
    (вҲҖ n, 0 вүӨ f n) вҶ’
    (вҲғ b : в„қ, 0 < b вҲ§ вҲғ nвӮҖ : в„•, вҲҖ n : в„•, nвӮҖ вүӨ n вҶ’
      b * (вҢҠc ^ nвҢӢвӮҠ : в„қ) вүӨ вҲ‘ k вҲҲ Finset.range вҢҠc ^ nвҢӢвӮҠ, f k) вҶ’
    вҲғ d : в„қ, 0 < d вҲ§ вҲғ XвӮҖ : в„•, вҲҖ X : в„•, XвӮҖ вүӨ X вҶ’
      d * X вүӨ вҲ‘ k вҲҲ Finset.range X, f k := by
  intro hc hnonneg hgeom
  rcases hgeom with вҹЁb, hb, nвӮҖ, hnвӮҖвҹ©
  have hc0 : 0 < c := lt_trans zero_lt_one hc
  let A : в„• вҶ’ в„қ := fun X => вҲ‘ k вҲҲ Finset.range X, f k
  have hAmono : Monotone A := by
    apply monotone_nat_of_le_succ
    intro X
    dsimp [A]
    rw [Finset.range_add_one, Finset.sum_insert Finset.notMem_range_self]
    linarith [hnonneg X]
  refine вҹЁb / (2 * c), ?_, ?_вҹ©
  В· positivity
  В· refine вҹЁmax вҢҠc ^ nвӮҖвҢӢвӮҠ (вҢҠ2 * cвҢӢвӮҠ + 1), ?_вҹ©
    intro X hX
    have hXgeom : вҢҠc ^ nвӮҖвҢӢвӮҠ вүӨ X := le_trans (le_max_left _ _) hX
    have hP : вҲғ m : в„•, X < вҢҠc ^ (m + nвӮҖ + 1)вҢӢвӮҠ := by
      have hpow_pos : 0 < c ^ (nвӮҖ + 1) := by positivity
      rcases pow_unbounded_of_one_lt (((X : в„қ) + 1) / c ^ (nвӮҖ + 1)) hc with вҹЁm, hmвҹ©
      have hm' : (X : в„қ) + 1 < c ^ (m + nвӮҖ + 1) := by
        have hm'' : (X : в„қ) + 1 < c ^ m * c ^ (nвӮҖ + 1) := by
          exact (div_lt_iffвӮҖ hpow_pos).1 hm
        simpa [pow_add, Nat.add_assoc, mul_comm, mul_left_comm, mul_assoc] using hm''
      have hfloor : X + 1 вүӨ вҢҠc ^ (m + nвӮҖ + 1)вҢӢвӮҠ := by
        have hm_le : ((X + 1 : в„•) : в„қ) вүӨ c ^ (m + nвӮҖ + 1) := by
          exact le_of_lt (by simpa using hm')
        exact (Nat.le_floor_iff (pow_nonneg (le_of_lt hc0) _)).2 hm_le
      exact вҹЁm, by omegaвҹ©
    have hchoose : вҲғ n : в„•, nвӮҖ вүӨ n вҲ§ вҢҠc ^ nвҢӢвӮҠ вүӨ X вҲ§ X < вҢҠc ^ (n + 1)вҢӢвӮҠ := by
      rcases Nat.findX hP with вҹЁN, hupperN, hminNвҹ©
      cases N with
      | zero =>
          refine вҹЁnвӮҖ, le_rfl, hXgeom, ?_вҹ©
          simpa [Nat.zero_add, Nat.add_assoc] using hupperN
      | succ N' =>
          refine вҹЁN' + nвӮҖ + 1, by omega, ?_, ?_вҹ©
          В· have hnot : В¬ X < вҢҠc ^ (N' + nвӮҖ + 1)вҢӢвӮҠ := by
              exact hminN N' (Nat.lt_succ_self N')
            omega
          В· simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hupperN
    rcases hchoose with вҹЁn, hnge, hlower, hupperвҹ©
    have hpow_nonneg : 0 вүӨ c ^ n := pow_nonneg (le_of_lt hc0) n
    have hpow_ge_one_all : вҲҖ m : в„•, (1 : в„қ) вүӨ c ^ m := by
      intro m
      induction m with
      | zero =>
          norm_num
      | succ m ih =>
          have hpow_nonneg_m : 0 вүӨ c ^ m := pow_nonneg (le_of_lt hc0) m
          have hstep : c ^ m вүӨ c ^ m * c := by
            simpa using mul_le_mul_of_nonneg_left (show (1 : в„қ) вүӨ c by linarith) hpow_nonneg_m
          calc
            (1 : в„қ) вүӨ c ^ m := ih
            _ вүӨ c ^ m * c := hstep
            _ = c ^ (m + 1) := by rw [pow_succ]
    have hpow_ge_one : (1 : в„қ) вүӨ c ^ n := hpow_ge_one_all n
    have hfloor_one : 1 вүӨ вҢҠc ^ nвҢӢвӮҠ := by
      exact (Nat.one_le_floor_iff (c ^ n)).2 hpow_ge_one
    have hfloor_one' : (1 : в„қ) вүӨ (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
      exact_mod_cast hfloor_one
    have hpow_lt : c ^ n < (вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1 := by
      simpa using (Nat.floor_lt hpow_nonneg).1 (Nat.lt_succ_self (вҢҠc ^ nвҢӢвӮҠ))
    have hXlt : (X : в„қ) < c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1) := by
      have hmul : c * c ^ n < c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1) := by
        exact mul_lt_mul_of_pos_left hpow_lt hc0
      calc
        (X : в„қ) < c ^ (n + 1) := Nat.lt_of_lt_floor hupper
        _ = c * c ^ n := by rw [pow_succ, mul_comm]
        _ < c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1) := hmul
    have hXlt' : (X : в„қ) < (2 * c) * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
      have hadd : (вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1 вүӨ (вҢҠc ^ nвҢӢвӮҠ : в„қ) + (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
        linarith
      have hbound : c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1) вүӨ (2 * c) * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
        calc
          c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + 1) вүӨ c * ((вҢҠc ^ nвҢӢвӮҠ : в„қ) + (вҢҠc ^ nвҢӢвӮҠ : в„қ)) := by
            exact mul_le_mul_of_nonneg_left hadd (le_of_lt hc0)
          _ = (2 * c) * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by ring
      exact lt_of_lt_of_le hXlt hbound
    have h2c0 : (2 * c) вү  0 := by nlinarith
    have hdX : (b / (2 * c)) * (X : в„қ) < b * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
      have hdpos : 0 < b / (2 * c) := by positivity
      calc
        (b / (2 * c)) * (X : в„қ) < (b / (2 * c)) * ((2 * c) * (вҢҠc ^ nвҢӢвӮҠ : в„қ)) := by
          exact mul_lt_mul_of_pos_left hXlt' hdpos
        _ = b * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := by
          field_simp [h2c0]
    calc
      (b / (2 * c)) * (X : в„қ) вүӨ b * (вҢҠc ^ nвҢӢвӮҠ : в„қ) := le_of_lt hdX
      _ вүӨ A (вҢҠc ^ nвҢӢвӮҠ) := by simpa [A] using hnвӮҖ n hnge
      _ вүӨ A X := hAmono hlower

theorem eventually_mul_le_of_tendsto_sum_range_div_pos {f : в„• вҶ’ в„қ} {a : в„қ} :
    0 < a вҶ’
    Filter.Tendsto
      (fun X : в„• => (вҲ‘ k вҲҲ Finset.range X, f k) / (X : в„қ))
      Filter.atTop (nhds a) вҶ’
    вҲғ c : в„қ, 0 < c вҲ§ вҲғ XвӮҖ : в„•, вҲҖ X : в„•, XвӮҖ вүӨ X вҶ’
      c * X вүӨ вҲ‘ k вҲҲ Finset.range X, f k := by
  intro ha hT
  let c : в„қ := a / 2
  refine вҹЁc, ?_, ?_вҹ©

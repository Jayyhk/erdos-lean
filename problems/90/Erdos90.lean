theorem consecutiveDifferences_partialProd (G : Type) [Group G] (n : в„•) (g : Fin n вҶ’ G) : (fun k : Fin n => ((Fin.partialProd g) (Fin.castSucc k))вҒ»В№ * (Fin.partialProd g) k.succ) = g := by

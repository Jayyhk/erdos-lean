/-!
# Lemma 2: Interval representation counting
Let I = [a, b] and J = [c, d], where b ≤ c. Let k ≥ 1.
- If m ∈ [a+c+k-1, b+d-k+1], then m has at least k representations m = x + y
  with x ∈ I, y ∈ J, x ≤ y.
-/
section Lemma2
/-- The set of k shifted pairs: {(x-i, y+i) | i = 0, ..., k-1} -/
def shiftedPairs (x y k : ℕ) : Finset (ℕ × ℕ) :=
  Finset.image (fun i => (x - i, y + i)) (Finset.range k)
/-- All shifted pairs sum to x + y when i ≤ x -/
lemma shiftedPairs_sum (x y k : ℕ) (hx : k ≤ x) :
    ∀ p ∈ shiftedPairs x y k, p.1 + p.2 = x + y := by
  intro p hp
  simp only [shiftedPairs, Finset.mem_image, Finset.mem_range] at hp
  obtain ⟨i, hi, rfl⟩ := hp
  omega
/-- Shifted pairs are distinct when k ≤ x -/
lemma shiftedPairs_card (x y k : ℕ) (hx : k ≤ x) :
    (shiftedPairs x y k).card = k := by
  rw [shiftedPairs]
  rw [Finset.card_image_of_injective]
  · exact Finset.card_range k
  · intro i j hij
    simp only [Prod.mk.injEq] at hij
    omega
/-- Shifted pairs satisfy x - i ≤ y + i when x ≤ y -/
lemma shiftedPairs_ordered (x y k : ℕ) (hxy : x ≤ y) :
    ∀ p ∈ shiftedPairs x y k, p.1 ≤ p.2 := by
  intro p hp
  simp only [shiftedPairs, Finset.mem_image, Finset.mem_range] at hp
  obtain ⟨i, _, rfl⟩ := hp
  omega
/-- Shifted pairs are bounded: x - i ≥ x - (k-1) for i < k -/
lemma shiftedPairs_fst_ge (x y k : ℕ) (hk : k ≥ 1) :
    ∀ p ∈ shiftedPairs x y k, p.1 ≥ x - (k - 1) := by
  intro p hp
  simp only [shiftedPairs, Finset.mem_image, Finset.mem_range] at hp
  obtain ⟨i, hi, rfl⟩ := hp
  omega
/-- Shifted pairs are bounded: y + i ≤ y + (k-1) for i < k -/
lemma shiftedPairs_snd_le (x y k : ℕ) (hk : k ≥ 1) :
    ∀ p ∈ shiftedPairs x y k, p.2 ≤ y + (k - 1) := by
  intro p hp
  simp only [shiftedPairs, Finset.mem_image, Finset.mem_range] at hp
  obtain ⟨i, hi, rfl⟩ := hp
  omega
end Lemma2
/-- Count representations of n in a finset S (standalone version) -/
def countRepsGen (S : Finset ℕ) (n : ℕ) : ℕ :=
  Finset.card (Finset.filter (fun p : ℕ × ℕ =>
    p.1 ≤ p.2 ∧ p.1 + p.2 = n ∧ p.1 ∈ S ∧ p.2 ∈ S)
    (Finset.product S S))
/-- If shiftedPairs are all in S × S, then countRepsGen(S, x+y) ≥ k -/
lemma countRepsGen_ge_of_shiftedPairs (S : Finset ℕ) (x y k : ℕ)
    (hk : k ≥ 1) (hx : k ≤ x) (hxy : x ≤ y)
    (hfst : ∀ p ∈ shiftedPairs x y k, p.1 ∈ S)
    (hsnd : ∀ p ∈ shiftedPairs x y k, p.2 ∈ S) :
    k ≤ countRepsGen S (x + y) := by
  unfold countRepsGen
  have hsub : shiftedPairs x y k ⊆ Finset.filter (fun p =>
      p.1 ≤ p.2 ∧ p.1 + p.2 = x + y ∧ p.1 ∈ S ∧ p.2 ∈ S)
      (Finset.product S S) := by
    intro p hp
    simp only [Finset.mem_filter]
    constructor
    · exact Finset.mem_product.mpr ⟨hfst p hp, hsnd p hp⟩
    · exact ⟨shiftedPairs_ordered x y k hxy p hp,
             shiftedPairs_sum x y k hx p hp,
             hfst p hp, hsnd p hp⟩
  calc k = (shiftedPairs x y k).card := (shiftedPairs_card x y k hx).symm
    _ ≤ (Finset.filter _ _).card := Finset.card_le_card hsub

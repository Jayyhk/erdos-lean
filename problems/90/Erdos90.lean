        (NumberField.discr F).natAbs ^ Module.finrank F M := by
  obtain вҹЁПғ, hПғ_mem, hspanвҹ© :=
    ramification_vectors_span_top_rel_discr в„“ _hв„“ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc
  let v : Fin в„“ вҶ’ (Fin в„“ вҶ’ ZMod 3) := fun i => Multiplicative.toAdd (e (Пғ i))
  obtain вҹЁlin, hlin_ne, hlin_oneвҹ© :=

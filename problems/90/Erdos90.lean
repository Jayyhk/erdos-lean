    (_h_killed :
      вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ),
        рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ F) вҶ’
        Q.map (@splittingDetectorAt F _ _ p _ рқ”ӯ hp hne) = 1) :
    вҲҖ j,
      (вҲҖ рқ”ӯ вҲҲ (Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ (T.L j)),
          Ideal.ramificationIdx (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1 вҲ§
          Ideal.inertiaDeg (Ideal.span {(q : в„Ө)} : Ideal в„Ө) рқ”ӯ = 1) вҲ§
        ((Ideal.span {(q : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ (T.L j))).ncard =
          Module.finrank в„ҡ (T.L j) := by
  intro j
  refine вҹЁ?_, ?_вҹ©
  В· intro рқ”“ hрқ”“
    exact primeOverQ_has_abs_split F p Q T q _hq _hq_splits_F _h_killed j hрқ”“
  В· exact splitCount_of_primewiseSplit (K := T.L j) q _hq (fun рқ”“ hрқ”“ =>
      primeOverQ_has_abs_split F p Q T q _hq _hq_splits_F _h_killed j hрқ”“)

theorem cft_D4_isFGProP
    (h : Hyp_FiniteTopologicalRank)

theorem h1NormalInvariantRank_le_normalGenerators (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (_hG : _root_.Erdos90.IsFinitelyGeneratedProPGroup p G)

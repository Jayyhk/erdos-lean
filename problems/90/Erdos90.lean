      ((NumberField.discr 𝒟.L).natAbs : ℝ) ^ ((AdmissibleDatum.f 𝒟 : ℝ)⁻¹) := by
    rw [← Real.rpow_natCast_mul
      (show 0 ≤ ((NumberField.discr 𝒟.L).natAbs : ℝ) by positivity) 2 ((n : ℝ)⁻¹)]
    have hmul : (2 : ℝ) * ((n : ℝ)⁻¹) = (AdmissibleDatum.f 𝒟 : ℝ)⁻¹ := by
      rw [hn_cast]

theorem restrictNormalHom_pair_eq_one_of_sup_eq_top (F E : Type) [Field F] [Field E] [Algebra F E]
    (K L : IntermediateField F E) [Normal F K] [Normal F L]
    (_hsup : K вҠ” L = вҠӨ) :
    вҲҖ П„ : E вүғвӮҗ[F] E,
      AlgEquiv.restrictNormalHom K П„ = 1 вҶ’
      AlgEquiv.restrictNormalHom L П„ = 1 вҶ’
      П„ = 1 := by
  intro П„ hK hL
  have hfixK : П„ вҲҲ K.fixingSubgroup := by
    rw [вҶҗ IntermediateField.restrictNormalHom_ker (E := K), MonoidHom.mem_ker]
    exact hK
  have hfixL : П„ вҲҲ L.fixingSubgroup := by
    rw [вҶҗ IntermediateField.restrictNormalHom_ker (E := L), MonoidHom.mem_ker]
    exact hL
  have hfix : П„ вҲҲ (K вҠ” L).fixingSubgroup := by
    rw [IntermediateField.fixingSubgroup_sup, Subgroup.mem_inf]
    exact вҹЁhfixK, hfixLвҹ©
  rw [_hsup, IntermediateField.fixingSubgroup_top, Subgroup.mem_bot] at hfix
  exact hfix

theorem restrictNormalHom_pair_injective_of_sup_eq_top (F E : Type) [Field F] [Field E] [Algebra F E]
    (K L : IntermediateField F E) [Normal F K] [Normal F L]
    (_hsup : K вҠ” L = вҠӨ) :
    Function.Injective (fun П„ : E вүғвӮҗ[F] E =>
      (AlgEquiv.restrictNormalHom K П„, AlgEquiv.restrictNormalHom L П„)) := by
  intro П„ П… h
  let ПҶK : (E вүғвӮҗ[F] E) вҶ’* (K вүғвӮҗ[F] K) := AlgEquiv.restrictNormalHom K
  let ПҶL : (E вүғвӮҗ[F] E) вҶ’* (L вүғвӮҗ[F] L) := AlgEquiv.restrictNormalHom L
  have hK : ПҶK П„ = ПҶK П… := by
    exact congrArg Prod.fst h
  have hL : ПҶL П„ = ПҶL П… := by
    exact congrArg Prod.snd h
  have h1K : ПҶK (П„ * П…вҒ»В№) = 1 := by
    rw [show ПҶK (П„ * П…вҒ»В№) = ПҶK П„ * (ПҶK П…)вҒ»В№ by rw [map_mul, map_inv]]
    rw [hK]
    exact mul_inv_cancel _
  have h1L : ПҶL (П„ * П…вҒ»В№) = 1 := by
    rw [show ПҶL (П„ * П…вҒ»В№) = ПҶL П„ * (ПҶL П…)вҒ»В№ by rw [map_mul, map_inv]]
    rw [hL]
    exact mul_inv_cancel _
  have hunit : П„ * П…вҒ»В№ = 1 :=
    restrictNormalHom_pair_eq_one_of_sup_eq_top F E K L _hsup (П„ * П…вҒ»В№) h1K h1L
  have hП„ : П„ = П… := by
    apply (mul_right_injective П…)
    simpa [mul_assoc] using congrArg (fun Пғ : E вүғвӮҗ[F] E => Пғ * П…) hunit
  exact hП„


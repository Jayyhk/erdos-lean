    change z.1 ![g 0, g 1] = z.1 g
    congr 1
    ext i
    fin_cases i <;> rfl
  have hzero :
      _root_.Erdos90.InhomogClassAPI.classMap p (G в§ё N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) Пүfun hПү -
          _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G в§ё N) f hf) = 0 := by

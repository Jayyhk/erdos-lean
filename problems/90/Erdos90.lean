        Module.finrank (ZMod p) ↥(LinearMap.range inf) := by
    rw [← hMEquiv.finrank_eq, Module.finrank_prod, hCEquivQuot.finrank_eq,
      hQuotRange.finrank_eq]
  change relationRank p (G ⧸ N) ≤ relationRank p G + h1NormalInvariantRank p G N
  calc relationRank p (G ⧸ N)
      = Module.finrank (ZMod p) (H p 2 (G ⧸ N) : Type) := rfl
    _ = Module.finrank (ZMod p) ↥(LinearMap.ker inf) +
          Module.finrank (ZMod p) ↥(LinearMap.range inf) := hFinrankM
    _ ≤ h1NormalInvariantRank p G N + relationRank p G :=
          Nat.add_le_add hKerLe hRangeLe
    _ = relationRank p G + h1NormalInvariantRank p G N := by ring

end FiveTerm

          simpa using (MeasureTheory.integral_const_mul (Ој := MeasureTheory.Measure.restrict MeasureTheory.volume (Set.Ioi (Real.log n))) (f n) (fun x : в„қ => Real.exp (-Пғ' * x)))]
    rw [integral_exp_mul_Ioi (show -Пғ' < 0 by linarith) (Real.log n)]

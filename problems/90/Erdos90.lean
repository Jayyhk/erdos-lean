def admissibleDatum_iO (𝒟 : AdmissibleDatum) : NumberField.RingOfIntegers 𝒟.K :=
  ⟨𝒟.i_K, by
    refine ⟨(Polynomial.X ^ 2 + Polynomial.C (1 : ℤ) : Polynomial ℤ), ?_, ?_⟩
    · simpa using
        (Polynomial.monic_X_pow_add_C (a := (1 : ℤ)) (n := 2) (by decide))
    · rw [Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
      simp [pow_two, 𝒟.i_K_sq]⟩

theorem admissibleDatum_iO_field_minpoly_eq (𝒟 : AdmissibleDatum) :
  minpoly 𝒟.L (((admissibleDatum_iO 𝒟 : NumberField.RingOfIntegers 𝒟.K) : 𝒟.K)) =
    Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
  classical
  let x : 𝒟.K := ((admissibleDatum_iO 𝒟 : NumberField.RingOfIntegers 𝒟.K) : 𝒟.K)
  change minpoly 𝒟.L x = Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)
  have hx : x = 𝒟.i_K := by
    rfl
  have hx_int : IsIntegral 𝒟.L x := by
    letI : Algebra.IsIntegral 𝒟.L 𝒟.K := Algebra.IsIntegral.of_finite 𝒟.L 𝒟.K
    exact (Algebra.isIntegral_def.mp inferInstance) x
  have hnat : (minpoly 𝒟.L x).natDegree = 2 := by
    have hadjoin : Algebra.adjoin 𝒟.L ({x} : Set 𝒟.K) = ⊤ := by
      simpa [admissibleDatum_iO] using 𝒟.adjoin_i_K_eq_top
    have hprim : IntermediateField.adjoin 𝒟.L ({x} : Set 𝒟.K) = ⊤ :=
      IntermediateField.adjoin_eq_top_of_algebra (F := 𝒟.L) (S := ({x} : Set 𝒟.K)) hadjoin
    simpa [Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K] using
      (Field.primitive_element_iff_minpoly_natDegree_eq (F := 𝒟.L) (E := 𝒟.K) x).1 (by simpa using hprim)
  have hdiv : minpoly 𝒟.L x ∣ Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
    refine minpoly.dvd (A := 𝒟.L) (x := x) ?_
    rw [Polynomial.aeval_def, Polynomial.eval₂_add, Polynomial.eval₂_X_pow, Polynomial.eval₂_C]
    have hsq : x ^ 2 = (-1 : 𝒟.K) := by
      simpa [hx, pow_two] using 𝒟.i_K_sq
    rw [hsq]
    simp
  have hmonic_min : (minpoly 𝒟.L x).Monic := minpoly.monic hx_int
  have hmonic_poly : (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)).Monic := by
    simpa using (Polynomial.monic_X_pow_add_C (a := (1 : 𝒟.L)) (n := 2) (by decide))
  have hdeg_poly : (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)).natDegree = 2 := by
    simpa using (Polynomial.natDegree_X_pow_add_C (R := 𝒟.L) (n := 2) (r := (1 : 𝒟.L)))
  have hne_poly : (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)) ≠ 0 := by
    exact hmonic_poly.ne_zero
  have hassoc : Associated (minpoly 𝒟.L x) (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)) := by
    apply Polynomial.associated_of_dvd_of_natDegree_le hdiv hne_poly
    rw [hdeg_poly, hnat]
  have hnorm : normalize (minpoly 𝒟.L x) = normalize (Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L)) :=
    (normalize_eq_normalize_iff_associated).2 hassoc
  rw [hmonic_min.normalize_eq_self] at hnorm
  rw [hmonic_poly.normalize_eq_self] at hnorm
  exact hnorm

theorem admissibleDatum_iO_minpoly_eq (𝒟 : AdmissibleDatum) :
  minpoly (NumberField.RingOfIntegers 𝒟.L) (admissibleDatum_iO 𝒟) =
    Polynomial.X ^ 2 + Polynomial.C (1 : NumberField.RingOfIntegers 𝒟.L) := by
  classical

    have hn1 : 1 вүӨ n := (Finset.mem_Icc.mp hn).1
    have hn0 : 0 < (n : в„қ) := by exact_mod_cast (lt_of_lt_of_le (show 0 < (1:в„•) by decide) hn1)
    rw [show (вҲ« x in Set.Ioi (Real.log n), f n * Real.exp (-Пғ' * x))

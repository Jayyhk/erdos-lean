theorem ramificationIdxIn_dvd_pow_three_of_finrank (в„“ : в„•) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (M : Type) [Field M] [CharZero M] [NumberField M] [IsGalois в„ҡ M]
    (_hfin : Module.finrank в„ҡ M = 3 ^ в„“)

          rw [htow_target_def]; exact le_max_right _ _
        have h_y_target_ge_exp_c2 : Real.exp (c + 2) ≤ y_target := by
          rw [hy_target_def]
          apply Real.exp_le_exp.mpr
          rw [le_div_iff₀ hB_pos]; linarith

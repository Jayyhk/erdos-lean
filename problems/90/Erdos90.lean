  obtain вҹЁU, hU0, hUmono, hUtendstoвҹ© := openNormalChain (Q0 := Q.Q)
  let N : в„• вҶ’ Subgroup (Gal(K/F)) := fun j => ((U j : Subgroup Q.Q).comap Q.map)
  have hNnormal : вҲҖ j, (N j).Normal := by
    intro j

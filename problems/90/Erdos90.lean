theorem partialSum_Icc_le_const_mul_rpow_of_LSeriesSummable_nonneg {f : в„• вҶ’ в„қ} {r : в„қ} :
    1 < r вҶ’
    (вҲҖ n, 0 вүӨ f n) вҶ’
    LSeriesSummable (fun n => (f n : в„Ӯ)) (r : в„Ӯ) вҶ’
    вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ N : в„•,
      вҲ‘ k вҲҲ Finset.Icc 1 N, f k вүӨ C * (N : в„қ) ^ r := by
  intro hr h_nonneg hL
  have hr0 : 0 вүӨ r := le_trans zero_le_one hr.le
  let g : в„• вҶ’ в„қ := fun n => вҖ–LSeries.term (fun m => (f m : в„Ӯ)) (r : в„Ӯ) nвҖ–
  have hsum : Summable g := hL.norm
  have hsum_le (N : в„•) : вҲ‘ k вҲҲ Finset.Icc 1 N, g k вүӨ вҲ‘' n, g n := by
    refine Summable.sum_le_tsum (Finset.Icc 1 N) ?_ hsum
    intro k hk
    exact norm_nonneg _
  refine вҹЁвҲ‘' n, g n, ?_, ?_вҹ©
  В· exact tsum_nonneg (fun n => norm_nonneg _)
  В· intro N
    have hpowN_nonneg : 0 вүӨ (N : в„қ) ^ r := Real.rpow_nonneg (Nat.cast_nonneg N) _
    calc
      вҲ‘ k вҲҲ Finset.Icc 1 N, f k вүӨ вҲ‘ k вҲҲ Finset.Icc 1 N, (N : в„қ) ^ r * g k := by
        refine Finset.sum_le_sum ?_
        intro k hk
        have hk_mem : k вҲҲ Finset.Icc 1 N := hk
        have hk_nat_pos : 0 < k := Nat.succ_le_iff.mp (Finset.mem_Icc.mp hk_mem).1
        have hk_nat_ne : k вү  0 := hk_nat_pos.ne'
        have hk_pos : 0 < (k : в„қ) := Nat.cast_pos.mpr hk_nat_pos
        have hk_nonneg : 0 вүӨ (k : в„қ) := hk_pos.le
        have hk_le_N : (k : в„қ) вүӨ (N : в„қ) := by
          exact_mod_cast (Finset.mem_Icc.mp hk_mem).2
        have hpow_le : (k : в„қ) ^ r вүӨ (N : в„қ) ^ r := by
          exact Real.rpow_le_rpow hk_nonneg hk_le_N hr0
        have hkr_pos : 0 < (k : в„қ) ^ r := Real.rpow_pos_of_pos hk_pos _
        have hratio_nonneg : 0 вүӨ f k / (k : в„қ) ^ r := by
          exact div_nonneg (h_nonneg k) (Real.rpow_nonneg hk_nonneg _)
        have hgk : g k = f k / (k : в„қ) ^ r := by
          dsimp [g]
          rw [LSeries.norm_term_eq]
          simp [hk_nat_ne]
          rw [abs_of_nonneg (h_nonneg k)]
        calc
          f k = (f k / (k : в„қ) ^ r) * (k : в„қ) ^ r := by
            rw [div_eq_mul_inv, mul_assoc, inv_mul_cancelвӮҖ hkr_pos.ne', mul_one]
          _ вүӨ (f k / (k : в„қ) ^ r) * (N : в„қ) ^ r := by
            exact mul_le_mul_of_nonneg_left hpow_le hratio_nonneg
          _ = (N : в„қ) ^ r * g k := by rw [hgk, mul_comm]
      _ = (N : в„қ) ^ r * вҲ‘ k вҲҲ Finset.Icc 1 N, g k := by
        rw [Finset.mul_sum]
      _ вүӨ (N : в„қ) ^ r * вҲ‘' n, g n := by
        exact mul_le_mul_of_nonneg_left (hsum_le N) hpowN_nonneg
      _ = (вҲ‘' n, g n) * (N : в„қ) ^ r := by ring

theorem icc_growth_family_of_LSeriesSummable_nonneg {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    вҲҖ r : в„қ, 1 < r вҶ’ вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ N : в„•,
      вҲ‘ k вҲҲ Finset.Icc 1 N, f k вүӨ C * (N : в„қ) ^ r := by
  intro hnonneg hsumm_family r hr
  have hsumm : LSeriesSummable (fun n => (f n : в„Ӯ)) (r : в„Ӯ) := by
    simpa using hsumm_family (r : в„Ӯ) hr
  simpa using
    partialSum_Icc_le_const_mul_rpow_of_LSeriesSummable_nonneg (r := r) hr hnonneg hsumm

theorem icc_growth_family_sub_const {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    вҲҖ B r : в„қ, 1 < r вҶ’
      вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ N : в„•,
        |вҲ‘ k вҲҲ Finset.Icc 1 N, (f k - B)| вүӨ C * (N : в„қ) ^ r := by
  intro hnonneg hsumm B r hr
  rcases icc_growth_family_of_LSeriesSummable_nonneg hnonneg hsumm r hr with вҹЁC1, hC1_nonneg, hC1вҹ©
  refine вҹЁC1 + |B|, add_nonneg hC1_nonneg (abs_nonneg B), ?_вҹ©
  intro N
  cases N with
  | zero =>
      have hpow_nonneg : 0 вүӨ (((0 : в„•) : в„қ) ^ r) := by
        positivity
      have hmul_nonneg : 0 вүӨ (C1 + |B|) * (((0 : в„•) : в„қ) ^ r) := by
        exact mul_nonneg (add_nonneg hC1_nonneg (abs_nonneg B)) hpow_nonneg
      simpa using hmul_nonneg
  | succ n =>
      have hsum_nonneg : 0 вүӨ вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k := by
        exact Finset.sum_nonneg (by
          intro k hk
          exact hnonneg k)
      have hbase : (1 : в„қ) вүӨ ((Nat.succ n : в„•) : в„қ) := by
        exact_mod_cast Nat.succ_le_succ (Nat.zero_le n)
      have hN_le_pow : ((Nat.succ n : в„•) : в„қ) вүӨ ((Nat.succ n : в„•) : в„қ) ^ r := by
        exact Real.self_le_rpow_of_one_le hbase hr.le
      have hBmul : |B| * ((Nat.succ n : в„•) : в„қ) вүӨ |B| * ((Nat.succ n : в„•) : в„қ) ^ r := by
        exact mul_le_mul_of_nonneg_left hN_le_pow (abs_nonneg B)
      have hconst : вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), B = B * ((Nat.succ n : в„•) : в„қ) := by
        calc
          вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), B = ((Finset.Icc 1 (Nat.succ n)).card : в„қ) * B := by
            simp [nsmul_eq_mul]
          _ = B * ((Nat.succ n : в„•) : в„қ) := by
            rw [Nat.card_Icc]
            norm_num
            ring
      have hsum_eq :
          вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), (f k - B)
            = (вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k) - B * ((Nat.succ n : в„•) : в„қ) := by
        rw [Finset.sum_sub_distrib, hconst]
      rw [hsum_eq]
      calc
        |(вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k) - B * ((Nat.succ n : в„•) : в„қ)|
            вүӨ |вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k| + |B * ((Nat.succ n : в„•) : в„қ)| := by
              simpa using (AbsoluteValue.sub_le_add (abv := AbsoluteValue.abs)
                (вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k) (B * ((Nat.succ n : в„•) : в„қ)))
        _ = (вҲ‘ k вҲҲ Finset.Icc 1 (Nat.succ n), f k) + |B| * ((Nat.succ n : в„•) : в„қ) := by
              rw [abs_of_nonneg hsum_nonneg, abs_mul, abs_of_nonneg (show 0 вүӨ ((Nat.succ n : в„•) : в„қ) by positivity)]
        _ вүӨ C1 * ((Nat.succ n : в„•) : в„қ) ^ r + |B| * ((Nat.succ n : в„•) : в„қ) := by
              gcongr
              exact hC1 (Nat.succ n)
        _ вүӨ C1 * ((Nat.succ n : в„•) : в„қ) ^ r + |B| * ((Nat.succ n : в„•) : в„қ) ^ r := by
              gcongr
        _ = (C1 + |B|) * ((Nat.succ n : в„•) : в„қ) ^ r := by ring

theorem integrableOn_logRescalePartialSum_kernel {f : в„• вҶ’ в„қ} :
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hsumm : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’
    вҲҖ z : в„Ӯ, 0 < z.re вҶ’
      MeasureTheory.IntegrableOn
        (fun x : в„қ => (((logRescalePartialSum f x : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : в„қ)) := by
  intro hnonneg hsumm z hz
  have hr_pos : 0 < z.re / 2 := by linarith
  let r : в„қ := 1 + z.re / 2
  have hr1 : 1 < r := by
    dsimp [r]
    linarith
  have hr_nonneg : 0 вүӨ r := by linarith
  obtain вҹЁC, hCnonneg, hCвҹ© := icc_growth_family_of_LSeriesSummable_nonneg hnonneg hsumm r hr1
  let a : в„қ := (-(z + 1 + 1)).re
  have hkernel :
      MeasureTheory.IntegrableOn
        (fun t : в„қ =>
          (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)))
        (Set.Ioi (1 : в„қ)) := by
    have hlocal :
        MeasureTheory.LocallyIntegrableOn
          (fun t : в„қ =>
            (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)))
          (Set.Ici (1 : в„қ)) := by
      refine locallyIntegrableOn_mul_sum_Icc (c := fun n вҶҰ (f n : в„Ӯ)) (m := 1) zero_le_one ?_
      refine ContinuousOn.locallyIntegrableOn (fun t ht вҶҰ ?_) measurableSet_Ici
      exact
        (Complex.continuousAt_ofReal_cpow_const t (-(z + 1 + 1))
          (Or.inr ((zero_lt_one.trans_le ht).ne'))).continuousWithinAt
    have hbigO :
        (fun t : в„қ =>
          (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ))) =O[Filter.atTop]
          (fun t : в„қ => t ^ (a + r)) := by
      refine Asymptotics.IsBigO.of_bound C ?_
      filter_upwards [Filter.eventually_gt_atTop (1 : в„қ)] with t ht
      have ht0 : 0 < t := zero_lt_one.trans ht
      have hsum_nonneg : 0 вүӨ вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, f k := by
        exact Finset.sum_nonneg fun n _ вҶҰ hnonneg n
      have hfloor_le : ((вҢҠtвҢӢвӮҠ : в„•) : в„қ) вүӨ t := Nat.floor_le ht0.le
      have hfloorpow_le : ((вҢҠtвҢӢвӮҠ : в„•) : в„қ) ^ r вүӨ t ^ r := by
        exact (Real.monotoneOn_rpow_Ici_of_exponent_nonneg hr_nonneg)
          (show 0 вүӨ ((вҢҠtвҢӢвӮҠ : в„•) : в„қ) by exact Nat.cast_nonneg _)
          ht0.le hfloor_le
      have hpow_nonneg : 0 вүӨ t ^ a := Real.rpow_nonneg ht0.le _
      have hnorm_sum :
          вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)вҖ– = вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, f k := by
        simpa [abs_of_nonneg hsum_nonneg] using
          (RCLike.norm_ofReal (K := в„Ӯ) (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, f k))
      have hnorm_cpow : вҖ–(t : в„Ӯ) ^ (-(z + 1 + 1))вҖ– = t ^ a := by
        simpa [a] using Complex.norm_cpow_eq_rpow_re_of_pos ht0 (-(z + 1 + 1))
      calc
        вҖ–(t : в„Ӯ) ^ (-(z + 1 + 1)) * вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)вҖ–
            = вҖ–(t : в„Ӯ) ^ (-(z + 1 + 1))вҖ– * вҖ–вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)вҖ– := by
                rw [norm_mul]
        _ = t ^ a * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, f k) := by rw [hnorm_cpow, hnorm_sum]
        _ вүӨ t ^ a * (C * (((вҢҠtвҢӢвӮҠ : в„•) : в„қ) ^ r)) := by
              gcongr
              exact hC _
        _ вүӨ t ^ a * (C * (t ^ r)) := by
              gcongr
        _ = C * (t ^ a * t ^ r) := by ring
        _ = C * t ^ (a + r) := by
              rw [вҶҗ Real.rpow_add ht0]
        _ = C * вҖ–t ^ (a + r)вҖ– := by
              rw [Real.norm_eq_abs, abs_of_nonneg (Real.rpow_nonneg ht0.le _)]
    have hexp : a + r < -1 := by
      dsimp [a, r]
      linarith
    have hIci :
        MeasureTheory.IntegrableOn
          (fun t : в„қ =>
            (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)))
          (Set.Ici (1 : в„қ)) := by
      refine hlocal.integrableOn_of_isBigO_atTop hbigO ?_
      exact (integrableAtFilter_rpow_atTop_iff).2 hexp
    exact hIci.mono_set Set.Ioi_subset_Ici_self
  have hexp_deriv : вҲҖ x вҲҲ Set.Ioi (0 : в„қ), HasDerivWithinAt Real.exp (Real.exp x) (Set.Ioi (0 : в„қ)) x := by
    intro x hx
    exact (Real.hasDerivAt_exp x).hasDerivWithinAt
  have hexp_mono : MonotoneOn Real.exp (Set.Ioi (0 : в„қ)) := by
    intro x hx y hy hxy
    exact Real.exp_le_exp.mpr hxy
  have himage : Real.exp '' Set.Ioi (0 : в„қ) = Set.Ioi (1 : в„қ) := by
    ext y
    constructor
    В· rintro вҹЁx, hx, rflвҹ©
      simpa using (Real.exp_lt_exp.mpr hx)
    В· intro hy
      refine вҹЁReal.log y, ?_, ?_вҹ©
      В· have hy' : 1 < y := hy
        exact (Real.log_pos_iff (show 0 вүӨ y by linarith)).2 hy'
      В· exact Real.exp_log (lt_trans zero_lt_one hy)
  have htarget_aux :
      MeasureTheory.IntegrableOn
        (fun x : в„қ =>
          Real.exp x вҖў
            ((Real.exp x : в„Ӯ) ^ (-(z + 1 + 1)) *
              (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, (f k : в„Ӯ))))
        (Set.Ioi (0 : в„қ)) := by
    have hchange :=
      (MeasureTheory.integrableOn_image_iff_integrableOn_deriv_smul_of_monotoneOn
        measurableSet_Ioi hexp_deriv hexp_mono
        (fun t : в„қ =>
          (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ))))
    have hkernel' :
        MeasureTheory.IntegrableOn
          (fun t : в„қ =>
            (t : в„Ӯ) ^ (-(z + 1 + 1)) * (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠtвҢӢвӮҠ, (f k : в„Ӯ)))
          (Real.exp '' Set.Ioi (0 : в„қ)) := by
      simpa [himage] using hkernel
    exact (hchange.mp hkernel')
  have h_eq :
      Set.EqOn
        (fun x : в„қ =>
          Real.exp x вҖў
            ((Real.exp x : в„Ӯ) ^ (-(z + 1 + 1)) *
              (вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, (f k : в„Ӯ))))
        (fun x : в„қ => (((logRescalePartialSum f x : в„қ) : в„Ӯ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : в„қ)) := by
    intro x hx
    have hx0 : 0 < x := hx
    have hexpx_ne : ((Real.exp x : в„қ) : в„Ӯ) вү  0 := by
      exact Complex.ofReal_ne_zero.mpr (Real.exp_pos x).ne'
    have h_ofReal_exp : ((Real.exp x : в„қ) : в„Ӯ) = Complex.exp x := by
      simp [Real.exp_eq_exp_в„қ, Complex.exp_eq_exp_в„Ӯ]
    have h_ofReal_exp_neg : ((Real.exp (-x) : в„қ) : в„Ӯ) = Complex.exp (-x) := by
      simp [Real.exp_eq_exp_в„қ, Complex.exp_eq_exp_в„Ӯ]
    simp [logRescalePartialSum, hx0.le, Complex.real_smul, Complex.cpow_def_of_ne_zero hexpx_ne,
      вҶҗ Complex.ofReal_log (Real.exp_nonneg x), Real.log_exp, h_ofReal_exp, h_ofReal_exp_neg]
    set S : в„Ӯ := вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, (f k : в„Ӯ)
    change Complex.exp x * (Complex.exp x ^ (-1 + (-1 + -z)) * S) = (Complex.exp (-x) * S) * Complex.exp (-(z * x))
    have hcpow : Complex.exp x ^ (-1 + (-1 + -z)) = Complex.exp ((x : в„Ӯ) * (-1 + (-1 + -z))) := by
      rw [Complex.cpow_def_of_ne_zero (Complex.exp_ne_zero _),
        Complex.log_exp (by simpa using neg_lt_zero.mpr Real.pi_pos) (by simpa using Real.pi_pos.le)]
    rw [hcpow]
    calc
      Complex.exp x * (Complex.exp ((x : в„Ӯ) * (-1 + (-1 + -z))) * S)
          = S * (Complex.exp x * Complex.exp ((x : в„Ӯ) * (-1 + (-1 + -z)))) := by ac_rfl
      _ = S * (Complex.exp (-x) * Complex.exp (-(z * x))) := by
          congr 1
          rw [вҶҗ Complex.exp_add, вҶҗ Complex.exp_add]
          congr 1
          ring
      _ = (Complex.exp (-x) * S) * Complex.exp (-(z * x)) := by ac_rfl
  exact htarget_aux.congr_fun h_eq measurableSet_Ioi

theorem integrableOn_centered_logRescalePartialSum_kernel {f : в„• вҶ’ в„қ} {b : в„қ} :
  (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
  (hsumm : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’

    simp

theorem cube_subgroup_fixedField_discr_lower_bound (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    r ^ 2 вҲЈ (NumberField.discr (cube_subgroup_fixedField r hr)).natAbs := by
  let L := cube_subgroup_fixedField r hr
  let E := CyclotomicField r в„ҡ
  letI : Fact r.Prime := вҹЁhrвҹ©
  have hdeg : Module.finrank в„ҡ L = 3 := cube_subgroup_fixedField_abs_finrank r hr hr3
  have hgal : IsGalois в„ҡ L := by
    change IsGalois в„ҡ (cube_subgroup_fixedField r hr)
    unfold cube_subgroup_fixedField
    classical
    let E := CyclotomicField r в„ҡ
    letI : Fact r.Prime := вҹЁhrвҹ©
    letI : NeZero r := вҹЁhr.ne_zeroвҹ©
    letI : IsCyclotomicExtension {r} в„ҡ E :=
      CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := r) (K := в„ҡ)
    letI : IsGalois в„ҡ E := IsCyclotomicExtension.isGalois (S := {r}) (K := в„ҡ) (L := E)
    let hirr : Irreducible (Polynomial.cyclotomic r в„ҡ) :=
      Polynomial.cyclotomic.irreducible_rat hr.pos
    let e : (E вүғвӮҗ[в„ҡ] E) вүғ* (ZMod r)ЛЈ :=
      IsCyclotomicExtension.autEquivPow (L := E) hirr
    let H : Subgroup (E вүғвӮҗ[в„ҡ] E) :=
      ((powMonoidHom 3 : (ZMod r)ЛЈ вҶ’* (ZMod r)ЛЈ).range).map e.symm.toMonoidHom
    letI : H.Normal := by
      refine (Subgroup.normal_of_comm ((powMonoidHom 3 : (ZMod r)ЛЈ вҶ’* (ZMod r)ЛЈ).range)).map e.symm.toMonoidHom ?_
      exact e.symm.surjective
    simpa [H] using (IsGalois.of_fixedField_normal_subgroup (K := в„ҡ) (L := E) H)
  letI : IsGalois в„ҡ L := hgal
  let pI : Ideal в„Ө := Ideal.span ({(r : в„Ө)} : Set в„Ө)
  letI : pI.IsMaximal := by
    dsimp [pI]
    exact Int.ideal_span_isMaximal_of_prime r
  letI : pI.IsPrime := Ideal.IsMaximal.isPrime (show pI.IsMaximal from inferInstance)
  have hp0 : pI вү  вҠҘ := by
    dsimp [pI]
    simp [hr.ne_zero]
  let D : Ideal (рқ“һ L) := differentIdeal в„Ө (рқ“һ L)
  have hdiscr_dvd : (NumberField.discr L).natAbs вҲЈ r ^ (r - 2) := by
    have hdiv : NumberField.discr L вҲЈ NumberField.discr E :=
      NumberField.discr_dvd_discr (K := L) (L := E)
    have hdiv' : ((NumberField.discr L).natAbs : в„Ө) вҲЈ NumberField.discr E := by
      rw [Int.natCast_natAbs, abs_dvd]
      simpa [E] using hdiv
    have hnat : (NumberField.discr L).natAbs вҲЈ (NumberField.discr E).natAbs :=
      Int.natCast_dvd.mp hdiv'
    simpa [E, cyclotomicField_natAbs_discr_prime r hr hr3] using hnat
  rcases (Nat.dvd_prime_pow hr).mp hdiscr_dvd with вҹЁk, hk_le, hk_eqвҹ©
  have hdiscr_nat_gt_two : 2 < (NumberField.discr L).natAbs := by
    have h := NumberField.abs_discr_gt_two (K := L) (by omega)
    rw [Int.abs_eq_natAbs] at h
    exact_mod_cast h
  have hD_ne_top : D вү  вҠӨ := by
    intro hD
    have : Ideal.absNorm D = 1 := by simp [hD]
    rw [NumberField.absNorm_differentIdeal (K := L) (рқ’Ә := рқ“һ L)] at this
    omega
  obtain вҹЁP, hPmax, hDPвҹ© := Ideal.exists_le_maximal D hD_ne_top
  letI : P.IsPrime := hPmax.isPrime
  have hP_under_max : (P.under в„Ө).IsMaximal := Ideal.IsMaximal.under (A := в„Ө) P
  have hrpow_mem_P : (algebraMap в„Ө (рқ“һ L) (r : в„Ө)) ^ k вҲҲ P := by
    have hmemD : ((Ideal.absNorm D : в„•) : рқ“һ L) вҲҲ D := Ideal.absNorm_mem D
    have hmemP : ((Ideal.absNorm D : в„•) : рқ“һ L) вҲҲ P := hDP hmemD
    rw [NumberField.absNorm_differentIdeal (K := L) (рқ’Ә := рқ“һ L), hk_eq] at hmemP
    simpa using hmemP
  have hr_mem_P : algebraMap в„Ө (рқ“һ L) (r : в„Ө) вҲҲ P := by
    exact hPmax.isPrime.mem_of_pow_mem k hrpow_mem_P
  have hp_le_under : pI вүӨ P.under в„Ө := by
    dsimp [pI]
    rw [Ideal.span_singleton_le_iff_mem]
    simpa [Ideal.under_def] using hr_mem_P
  have hunder_eq : P.under в„Ө = pI := by
    rcases (Ideal.isMaximal_def.mp (show pI.IsMaximal from inferInstance)) with вҹЁ_, hpI_coatomвҹ©
    by_contra hne
    have hlt : pI < P.under в„Ө := lt_of_le_of_ne hp_le_under (by simpa [eq_comm] using hne)
    exact hP_under_max.ne_top (hpI_coatom _ hlt)
  letI : P.LiesOver pI := by
    simpa [hunder_eq] using (Ideal.over_under (A := в„Ө) (P := P))
  have hP0 : P вү  вҠҘ := Ideal.ne_bot_of_liesOver_of_ne_bot hp0 P
  have hP_dvd_D : P вҲЈ D := Ideal.dvd_iff_le.mpr hDP
  have hnot_unram : В¬ Algebra.IsUnramifiedAt в„Ө P := by
    exact (dvd_differentIdeal_iff (A := в„Ө) (B := рқ“һ L) (P := P)).mp hP_dvd_D
  have hramP_ne_one : pI.ramificationIdx P вү  1 := by
    intro hram
    have hunram : Algebra.IsUnramifiedAt в„Ө P := by
      have hiff := Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := в„Ө) (S := рқ“һ L) (p := P) hP0
      rw [hunder_eq] at hiff
      exact hiff.2 hram
    exact hnot_unram hunram
  have hfund0 : (pI.primesOver (рқ“һ L)).ncard * (pI.ramificationIdxIn (рқ“һ L) * pI.inertiaDegIn (рқ“һ L)) = 3 := by
    have h := Ideal.ncard_primesOver_mul_ramificationIdxIn_mul_inertiaDegIn (p := pI) hp0 (B := рқ“һ L) (G := Gal(L/в„ҡ))
    rw [IsGalois.card_aut_eq_finrank (F := в„ҡ) (E := L), hdeg] at h
    simpa using h
  set g : в„• := (pI.primesOver (рқ“һ L)).ncard
  set eIn : в„• := pI.ramificationIdxIn (рқ“һ L)
  set fIn : в„• := pI.inertiaDegIn (рқ“һ L)
  have hfund : g * (eIn * fIn) = 3 := by
    simpa [g, eIn, fIn] using hfund0
  have hramIn_ne_one0 : pI.ramificationIdxIn (рқ“һ L) вү  1 := by
    rw [Ideal.ramificationIdxIn_eq_ramificationIdx (p := pI) (P := P) (B := рқ“һ L) (G := Gal(L/в„ҡ))]
    exact hramP_ne_one
  have hramIn_ne_one : eIn вү  1 := by
    simpa [eIn] using hramIn_ne_one0
  have he_dvd_three : eIn вҲЈ 3 := by
    refine вҹЁg * fIn, ?_вҹ©
    calc
      3 = g * (eIn * fIn) := hfund.symm
      _ = eIn * (g * fIn) := by ring
  have he_three : eIn = 3 := by
    rcases (Nat.dvd_prime (by decide : Nat.Prime 3)).mp he_dvd_three with h1 | h3
    В· exact (hramIn_ne_one h1).elim
    В· exact h3
  have hmul : 3 * (g * fIn) = 3 := by
    calc
      3 * (g * fIn) = g * (eIn * fIn) := by rw [he_three]; ring
      _ = 3 := hfund
  have hgf_one : g * fIn = 1 := by
    exact (mul_eq_leftвӮҖ (a := 3) (b := g * fIn) (ha := by decide)).mp hmul
  have hg_one : g = 1 := (mul_eq_one.mp hgf_one).1
  have hf_one0 : fIn = 1 := (mul_eq_one.mp hgf_one).2
  have hramIn_three : pI.ramificationIdxIn (рқ“һ L) = 3 := by
    simpa [eIn] using he_three
  have hramP_three : pI.ramificationIdx P = 3 := by
    rw [вҶҗ Ideal.ramificationIdxIn_eq_ramificationIdx (p := pI) (P := P) (B := рқ“һ L) (G := Gal(L/в„ҡ))]
    exact hramIn_three
  have hP3 : P ^ 3 вҲЈ Ideal.map (algebraMap в„Ө (рқ“һ L)) pI := by
    refine Ideal.dvd_iff_le.mpr ?_
    have hle : Ideal.map (algebraMap в„Ө (рқ“һ L)) pI вүӨ P ^ pI.ramificationIdx P := by
      exact Ideal.le_pow_ramificationIdx
    simpa [hramP_three] using hle
  have hP2dvdD : P ^ 2 вҲЈ D := by
    simpa [D] using (pow_sub_one_dvd_differentIdeal (A := в„Ө) (B := рқ“һ L) (P := P) (e := 3) hp0 hP3)
  have hinertiaIn_one : pI.inertiaDegIn (рқ“һ L) = 1 := by
    simpa [fIn] using hf_one0
  have hinertiaP_one : pI.inertiaDeg P = 1 := by
    rw [вҶҗ Ideal.inertiaDegIn_eq_inertiaDeg (p := pI) (P := P) (B := рқ“һ L) (G := Gal(L/в„ҡ))]
    exact hinertiaIn_one
  have hnormP' : Ideal.absNorm P = r ^ (pI.inertiaDeg P) := by
    simpa [pI] using (Ideal.absNorm_eq_pow_inertiaDeg' (R := рқ“һ L) (P := P) (p := r) hr)
  have hnormP : Ideal.absNorm P = r := by
    rw [hnormP', hinertiaP_one]
    simp
  have hnormP2 : Ideal.absNorm (P ^ 2) = r ^ 2 := by
    rw [map_pow, hnormP]
  have hnorm_dvd : Ideal.absNorm (P ^ 2) вҲЈ Ideal.absNorm D :=
    Ideal.absNorm_dvd_absNorm_of_le (Ideal.dvd_iff_le.mp hP2dvdD)
  rw [hnormP2, NumberField.absNorm_differentIdeal (K := L) (рқ’Ә := рқ“һ L)] at hnorm_dvd
  simpa [D] using hnorm_dvd

theorem cube_subgroup_fixedField_discr_upper_bound (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    (NumberField.discr (cube_subgroup_fixedField r hr)).natAbs вҲЈ r ^ 2 := by
  let L := cube_subgroup_fixedField r hr
  let E := CyclotomicField r в„ҡ
  let m := (r - 1) / 3
  have hrel : Module.finrank вҶҘL E = m := by
    simpa [L, E, m] using cube_subgroup_fixedField_rel_finrank r hr hr3
  have hdiscrE : (NumberField.discr E).natAbs = r ^ (r - 2) := by
    simpa [E] using cyclotomicField_natAbs_discr_prime r hr hr3
  have htower : (NumberField.discr E).natAbs =
      Ideal.absNorm (differentIdeal (рқ“һ вҶҘL) (рқ“һ E)) * (NumberField.discr вҶҘL).natAbs ^ m := by
    simpa [hrel] using
      (NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        (K := вҶҘL) (рқ’Ә := рқ“һ вҶҘL) (L := E) (рқ’Ә' := рқ“һ E))
  have hdvd_int : NumberField.discr вҶҘL вҲЈ (r ^ (r - 2) : в„Ө) := by
    apply dvd_trans (NumberField.discr_dvd_discr (K := вҶҘL) (L := E))
    have habsE' : ((NumberField.discr E).natAbs : в„Ө) = (r ^ (r - 2) : в„Ө) := by
      exact_mod_cast hdiscrE
    have habsE : |NumberField.discr E| = (r ^ (r - 2) : в„Ө) := by
      simpa [Int.natCast_natAbs] using habsE'
    rw [вҶҗ habsE]
    exact (dvd_abs _ _).2 dvd_rfl
  have hdvd_nat : (NumberField.discr вҶҘL).natAbs вҲЈ r ^ (r - 2) := by
    exact (Int.dvd_natCast.mp hdvd_int)
  obtain вҹЁk, hk_top, hkpowвҹ© := (Nat.dvd_prime_pow hr).mp hdvd_nat
  have hdvdpow : (NumberField.discr вҶҘL).natAbs ^ m вҲЈ r ^ (r - 2) := by
    refine вҹЁIdeal.absNorm (differentIdeal (рқ“һ вҶҘL) (рқ“һ E)), ?_вҹ©
    calc
      r ^ (r - 2) = (NumberField.discr E).natAbs := hdiscrE.symm
      _ = Ideal.absNorm (differentIdeal (рқ“һ вҶҘL) (рқ“һ E)) * (NumberField.discr вҶҘL).natAbs ^ m := htower
      _ = (NumberField.discr вҶҘL).natAbs ^ m * Ideal.absNorm (differentIdeal (рқ“һ вҶҘL) (рқ“һ E)) := by
        rw [Nat.mul_comm]
  have hkm_le : k * m вүӨ r - 2 := by
    have hdvdpow' : r ^ (k * m) вҲЈ r ^ (r - 2) := by
      simpa [hkpow, Nat.pow_mul] using hdvdpow
    rcases (Nat.dvd_prime_pow hr).mp hdvdpow' with вҹЁt, htle, htвҹ©
    have hkt : k * m = t := by
      exact (Nat.pow_right_injective hr.two_le) ht
    omega
  have hmod : (r - 1) % 3 = 0 := by
    omega
  have hm_three : 3 * m = r - 1 := by
    dsimp [m]
    omega
  have hk_le_two : k вүӨ 2 := by
    by_contra hk_gt
    have hk3 : 3 вүӨ k := by omega
    have hmul : 3 * m вүӨ k * m := Nat.mul_le_mul_right m hk3
    omega
  rw [hkpow]
  refine вҹЁr ^ (2 - k), ?_вҹ©
  rw [вҶҗ Nat.pow_add, Nat.add_sub_of_le hk_le_two]

theorem cube_subgroup_fixedField_discr (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    (NumberField.discr (cube_subgroup_fixedField r hr)).natAbs = r ^ 2 := by
  exact Nat.dvd_antisymm
    (cube_subgroup_fixedField_discr_upper_bound r hr hr3)
    (cube_subgroup_fixedField_discr_lower_bound r hr hr3)

theorem cyclic_cubic_subfield_exists_local (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    вҲғ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois в„ҡ L)
      (_ : Algebra L (CyclotomicField r в„ҡ)),
      Module.finrank в„ҡ L = 3 вҲ§
      (NumberField.discr L).natAbs = r ^ 2 := by
  classical
  let E := CyclotomicField r в„ҡ
  let L : IntermediateField в„ҡ E := cube_subgroup_fixedField r hr
  letI : Fact r.Prime := вҹЁhrвҹ©
  letI : NeZero r := вҹЁhr.ne_zeroвҹ©
  letI : IsCyclotomicExtension {r} в„ҡ E :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero (n := r) (K := в„ҡ)
  letI : IsGalois в„ҡ E := IsCyclotomicExtension.isGalois (S := {r}) (K := в„ҡ) (L := E)
  let hirr : Irreducible (Polynomial.cyclotomic r в„ҡ) :=
    Polynomial.cyclotomic.irreducible_rat hr.pos
  let e : (E вүғвӮҗ[в„ҡ] E) вүғ* (ZMod r)ЛЈ :=
    IsCyclotomicExtension.autEquivPow (L := E) hirr
  let H0 : Subgroup (ZMod r)ЛЈ := (powMonoidHom 3 : (ZMod r)ЛЈ вҶ’* (ZMod r)ЛЈ).range
  let H : Subgroup (E вүғвӮҗ[в„ҡ] E) := H0.map e.symm.toMonoidHom
  have hL : L = IntermediateField.fixedField H := by
    unfold L cube_subgroup_fixedField
    simp [E, hirr, e, H0, H]
  have hH0_normal : H0.Normal := by
    infer_instance
  have hH_normal : H.Normal := by
    simpa [H, H0] using hH0_normal.map e.symm.toMonoidHom e.symm.surjective
  letI : H.Normal := hH_normal
  have hGalL : IsGalois в„ҡ (IntermediateField.fixedField H) :=
    IsGalois.of_fixedField_normal_subgroup (K := в„ҡ) (L := E) H
  have hGalL' : IsGalois в„ҡ L := by
    rw [hL]
    infer_instance
  have hfinrank : Module.finrank в„ҡ L = 3 := by
    calc
      Module.finrank в„ҡ L = L.fixingSubgroup.index := by
        simpa using IntermediateField.finrank_eq_fixingSubgroup_index (L := L)
      _ = H.index := by rw [hL, IntermediateField.fixingSubgroup_fixedField]
      _ = H0.index := by
        simp [H0, H]
      _ = (Nat.card ((ZMod r)ЛЈ)).gcd 3 := by
        simpa [H0] using (IsCyclic.index_powMonoidHom_range (G := (ZMod r)ЛЈ) (d := 3))
      _ = (r - 1).gcd 3 := by rw [Nat.card_eq_fintype_card, ZMod.card_units]
      _ = 3 := by
        have hmod : (r - 1) % 3 = 0 := by
          omega
        have hdiv : 3 вҲЈ r - 1 := (Nat.modEq_zero_iff_dvd).mp (show r - 1 вүЎ 0 [MOD 3] by simpa [Nat.ModEq] using hmod)
        exact (gcd_eq_right_iff (r - 1) 3 rfl).2 hdiv
  let gaut : E вүғвӮҗ[в„ҡ] E := e.symm (-1)
  have hg_mem : gaut вҲҲ H := by
    have hneg : (-1 : (ZMod r)ЛЈ) вҲҲ H0 := by
      refine вҹЁ(-1 : (ZMod r)ЛЈ), ?_вҹ©
      exact Odd.neg_one_pow (show Odd 3 by decide)
    simpa [gaut, H] using hneg
  have hg_zeta :
      gaut (IsCyclotomicExtension.zeta r в„ҡ E) = (IsCyclotomicExtension.zeta r в„ҡ E) ^ (r - 1) := by
    let hО¶ := IsCyclotomicExtension.zeta_spec r в„ҡ E
    have hpow := hО¶.autToPow_spec (R := в„ҡ) gaut
    have heq : hО¶.autToPow в„ҡ gaut = (-1 : (ZMod r)ЛЈ) := by
      change e gaut = (-1 : (ZMod r)ЛЈ)
      simp [gaut]
    rw [heq] at hpow
    have hval : (((-1 : (ZMod r)ЛЈ) : ZMod r).val) = r - 1 := by
      change (- (1 : ZMod r)).val = r - 1
      have h1 : (1 : ZMod r) вү  0 := by
        exact zero_ne_one.symm
      letI : NeZero (1 : ZMod r) := вҹЁh1вҹ©
      rw [ZMod.val_neg_of_ne_zero (a := (1 : ZMod r))]
      rw [ZMod.val_one'' hr.ne_one]
    rw [hval] at hpow
    simpa using hpow.symm
  have hle : L.toSubfield вүӨ NumberField.maximalRealSubfield E := by
    intro x hx
    rw [NumberField.mem_maximalRealSubfield_iff (K := E)]
    intro ПҶ
    let ПҲ : E вҶ’+* в„Ӯ := NumberField.ComplexEmbedding.conjugate ПҶ
    have hbase : ПҶ.comp (algebraMap в„ҡ E) = ПҲ.comp (algebraMap в„ҡ E) := by
      ext q
      simp [ПҲ, NumberField.ComplexEmbedding.conjugate]
    obtain вҹЁПғ, hПғвҹ© := NumberField.ComplexEmbedding.exists_comp_symm_eq_of_comp_eq (k := в„ҡ) (K := E) ПҶ ПҲ hbase
    have hПғ' : NumberField.ComplexEmbedding.IsConj ПҶ Пғ.symm := by
      dsimp [NumberField.ComplexEmbedding.IsConj, ПҲ] at *
      simpa using hПғ.symm
    have hПғeq : Пғ.symm = gaut := by
      apply IsCyclotomicExtension.algEquiv_eq_of_apply_eq (S := ({r} : Set в„•)) (A := в„ҡ) (B := E)
      intro m hm hm0
      have hm' : m = r := by simpa using hm
      subst m
      refine вҹЁIsCyclotomicExtension.zeta r в„ҡ E, IsCyclotomicExtension.zeta_spec r в„ҡ E, ?_вҹ©
      apply ПҶ.injective
      let О¶ := IsCyclotomicExtension.zeta r в„ҡ E
      have hО¶ : IsPrimitiveRoot О¶ r := IsCyclotomicExtension.zeta_spec r в„ҡ E
      have hПҶО¶ : IsPrimitiveRoot (ПҶ О¶) r := hО¶.map_of_injective ПҶ.injective
      have hconjО¶ : star (ПҶ О¶) = (ПҶ О¶)вҒ»В№ := by
        simpa [О¶] using Complex.conj_rootsOfUnity (hО¶ := (hПҶО¶.toRootsOfUnity).2)
      have hneО¶ : О¶ вү  0 := hО¶.ne_zero hr.ne_zero
      have hne : ПҶ О¶ вү  0 := by
        intro hz
        apply hneО¶
        have hz' : ПҶ О¶ = ПҶ 0 := by simpa using hz
        exact ПҶ.injective hz'
      have hpowinv : (ПҶ О¶) ^ (r - 1) = (ПҶ О¶)вҒ»В№ := by
        calc
          (ПҶ О¶) ^ (r - 1) = (ПҶ О¶) ^ r * ((ПҶ О¶) ^ 1)вҒ»В№ := by
            rw [pow_subвӮҖ _ hne (show 1 вүӨ r by omega)]
          _ = 1 * ((ПҶ О¶) ^ 1)вҒ»В№ := by rw [hПҶО¶.pow_eq_one]
          _ = (ПҶ О¶)вҒ»В№ := by simp
      calc
        ПҶ (Пғ.symm О¶) = star (ПҶ О¶) := hПғ'.eq _
        _ = (ПҶ О¶)вҒ»В№ := hconjО¶
        _ = (ПҶ О¶) ^ (r - 1) := hpowinv.symm
        _ = ПҶ (gaut О¶) := by rw [hg_zeta, map_pow]
    have hxfix : gaut x = x := by
      have hx' : x вҲҲ IntermediateField.fixedField H := by simpa [hL] using hx
      exact (IntermediateField.mem_fixedField_iff (H := H) x).1 hx' gaut hg_mem
    have hxconj : ПҶ (gaut x) = star (ПҶ x) := hПғeq в–ё hПғ'.eq x
    rw [hxfix] at hxconj
    simpa using hxconj.symm
  have htotallyReal : IsTotallyReal L := by
    have htotSub : IsTotallyReal L.toSubfield :=
      (NumberField.isTotallyReal_iff_le_maximalRealSubfield (K := E) (E := L.toSubfield)).2 hle
    simpa using htotSub
  refine вҹЁL, inferInstance, inferInstance, inferInstance, htotallyReal, hGalL', inferInstance, ?_вҹ©
  exact вҹЁhfinrank, by simpa [L] using cube_subgroup_fixedField_discr r hr hr3вҹ©

theorem cyclic_cubic_field_of_prime_mod3 (r : в„•) (hr : r.Prime) (hr3 : r % 3 = 1) :
    вҲғ (L : Type) (_ : Field L) (_ : CharZero L) (_ : NumberField L)
      (_ : IsTotallyReal L) (_ : IsGalois в„ҡ L)
      (_ : Algebra L (CyclotomicField r в„ҡ)),
      Module.finrank в„ҡ L = 3 вҲ§
      (NumberField.discr L).natAbs = r ^ 2 вҲ§
      Nonempty ((L вүғвӮҗ[в„ҡ] L) вүғ* Multiplicative (ZMod 3)) := by
  classical

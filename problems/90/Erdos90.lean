  intro x hx
  simp only [LinearMap.mem_ker] at hx
  haveI : CompactSpace вҶҘN := isCompact_iff_compactSpace.mp hN.isCompact
  haveI : TotallyDisconnectedSpace (G в§ё N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  haveI hClosed : IsClosed ((N : Set G)) := hN
  haveI : T2Space (G в§ё N) :=
    have : T1Space (G в§ё N) := QuotientGroup.instT1Space
    inferInstance
  rcases continuousH1TrivialAddEquivContinuousAddHom_package (p := p) with вҹЁe, he_natвҹ©
  let ПҲcts : Additive G вҶ’вӮң+ ZMod p := e G x
  have hxr : (restriction p G N 1).hom x = 0 := by simpa using hx
  have hvanish : вҲҖ n : N, ПҲcts (Additive.ofMul (n : G)) = 0 := by

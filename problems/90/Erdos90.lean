    NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
      F (рқ“һ F) M (рқ“һ M)

  have h_diff_top : differentIdeal (рқ“һ F) (рқ“һ M) = вҠӨ := by
    by_contra h_ne_top

    obtain вҹЁP, hPmax, hPleвҹ© :=
      Ideal.exists_le_maximal (differentIdeal (рқ“һ F) (рқ“һ M)) h_ne_top
    have hPdvd : P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M) := Ideal.dvd_iff_le.mpr hPle

    have hPprime : P.IsPrime := hPmax.isPrime
    have hPne_bot : P вү  вҠҘ :=
      Ring.ne_bot_of_isMaximal_of_not_isField hPmax (RingOfIntegers.not_isField M)

    have hUne_bot : P.under (рқ“һ F) вү  вҠҘ := Ideal.under_ne_bot (рқ“һ F) hPne_bot
    have hUprime : (P.under (рқ“һ F)).IsPrime := Ideal.IsPrime.under (рқ“һ F) P

    have hLies : P.LiesOver (P.under (рқ“һ F)) := Ideal.over_under _

    have hPmem : P вҲҲ (P.under (рқ“һ F)).primesOver (рқ“һ M) := вҹЁhPprime, hLiesвҹ©

    have h_ram_one :
        Ideal.ramificationIdx (P.under (рқ“һ F)) P = 1 :=
      _h_finite (P.under (рқ“һ F)) P hUprime hUne_bot hPmem

    have h_unram : Algebra.IsUnramifiedAt (рқ“һ F) P := by
      rw [Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := рқ“һ F) hPne_bot]

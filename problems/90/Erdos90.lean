      (NumberField.discr F).natAbs = (вҲҸ i, r i) ^ 2 вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) := by
  exact proposition_3_2_compositum_and_F_bridge в„“ _hв„“ r _hr_prime _hr_inj _hr_mod3

theorem proposition_3_2 (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1) :
    вҲғ (F M : Type)
      (_ : Field F) (_ : Field M)
      (_ : CharZero F) (_ : CharZero M)
      (_ : NumberField F) (_ : NumberField M)
      (_ : IsTotallyReal F) (_ : IsTotallyReal M)
      (_ : IsGalois в„ҡ F) (_ : IsGalois в„ҡ M)
      (_ : Algebra F M) (_ : IsGalois F M),
      Module.finrank в„ҡ F = 3 вҲ§
      Module.finrank F M = 3 ^ (в„“ - 1) вҲ§
      (NumberField.discr F).natAbs = (вҲҸ i, r i) ^ 2 вҲ§
      (NumberField.discr M).natAbs = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1)) вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[в„ҡ] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[в„ҡ] M, Пғ * П„ = П„ * Пғ) вҲ§
      Nat.card (M вүғвӮҗ[F] M) = 3 ^ (в„“ - 1) вҲ§
      Nonempty ((M вүғвӮҗ[F] M) вүғ*
        Multiplicative (Fin (в„“ - 1) вҶ’ ZMod 3)) вҲ§
      IsPGroup 3 (M вүғвӮҗ[F] M) вҲ§
      IsEverywhereUnramified F M := by
  rcases proposition_3_2_compositum_and_F_local в„“ _hв„“ r _hr_prime _hr_inj _hr_mod3 with
    вҹЁM, _instFieldM, _instCharZeroM, _instNumberFieldM, _instTotallyRealM, _instGaloisQM,
      F, _instFieldF, _instCharZeroF, _instNumberFieldF, _instTotallyRealF, _instGaloisQF,
      _instAlgFM, _instTower, _instFiniteDimensional, _instGaloisFM,
      hfinQM, habs, hdiscM, hfinQF, hFabs, hfinFM, hodd, hdiscF, hpowRel, hcommRelвҹ©
  let hpowAbs := (fun_zmod3_equiv_pow_three_and_comm в„“ (M вүғвӮҗ[в„ҡ] M) (Classical.choice habs)).1
  let hcommAbs := (fun_zmod3_equiv_pow_three_and_comm в„“ (M вүғвӮҗ[в„ҡ] M) (Classical.choice habs)).2
  have hcard : Nat.card (M вүғвӮҗ[F] M) = 3 ^ (в„“ - 1) := by
    rw [IsGalois.card_aut_eq_finrank F M, hfinFM]
  have hmulEquiv : Nonempty ((M вүғвӮҗ[F] M) вүғ* Multiplicative (Fin (в„“ - 1) вҶ’ ZMod 3)) := by
    exact elementary_abelian_three_mulEquiv (в„“ - 1) (M вүғвӮҗ[F] M) hpowRel hcommRel hcard
  have hPGroup : IsPGroup 3 (M вүғвӮҗ[F] M) := by
    rw [IsPGroup.iff_card]
    exact вҹЁв„“ - 1, hcardвҹ©
  have hdiscTower : (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M := by
    rw [hdiscM, hdiscF, hfinFM]
    rw [pow_mul]
  have hunram : IsEverywhereUnramified F M :=
    IsEverywhereUnramified_of_discr_eq_and_totally_real_local F M hodd hdiscTower
  refine вҹЁF, M, _instFieldF, _instFieldM, _instCharZeroF, _instCharZeroM, _instNumberFieldF, _instNumberFieldM,
    _instTotallyRealF, _instTotallyRealM, _instGaloisQF, _instGaloisQM, _instAlgFM, _instGaloisFM, ?_вҹ©
  exact вҹЁhfinQF, hfinFM, hdiscF, hdiscM, hpowRel, hpowAbs, hcommRel, hcommAbs, hcard, hmulEquiv, hPGroup, hunramвҹ©


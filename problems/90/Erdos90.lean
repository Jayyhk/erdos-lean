    exact one_ne_zero
  refine вҹЁlin, hlin_ne, ?_вҹ©
  exact
    rel_discr_eq_of_nonvanishing_on_inertia в„“ _hв„“ r _hr_prime _hr_inj _hr_mod3 M e Пғ hПғ_mem lin hlinv _hdisc

theorem diagonal_cubic_subfield_exists_rel_discr (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (_hMgal : Nonempty ((M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3)))
    (_hfin : Module.finrank в„ҡ M = 3 ^ в„“)
    (_hdisc : (NumberField.discr M).natAbs = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1))) :
    вҲғ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois в„ҡ F)
      (_ : Algebra F M) (_ : IsScalarTower в„ҡ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank в„ҡ F = 3 вҲ§
      Nonempty ((F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3)) вҲ§
      Module.finrank F M = 3 ^ (в„“ - 1) вҲ§
      Odd (Module.finrank F M) вҲ§
      (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) := by
  classical
  rcases _hMgal with вҹЁeвҹ©
  obtain вҹЁlin, hlin, hdisc_relвҹ© :=
    exists_good_linear_map_rel_discr в„“ _hв„“ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc
  let ПҲ : Multiplicative (Fin в„“ вҶ’ ZMod 3) вҶ’* Multiplicative (ZMod 3) :=
    linearMapToCharacter в„“ lin
  have hПҲ_surj : Function.Surjective ПҲ := linearMapToCharacter_surjective в„“ lin hlin
  let ПҶ : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (ZMod 3) := ПҲ.comp e
  have hПҶ_surj : Function.Surjective ПҶ := by
    intro y
    rcases hПҲ_surj y with вҹЁx, hxвҹ©
    refine вҹЁe.symm x, ?_вҹ©
    simpa [ПҶ] using hx
  let H : Subgroup (M вүғвӮҗ[в„ҡ] M) := ПҶ.ker
  let F : IntermediateField в„ҡ M := IntermediateField.fixedField H
  letI : NumberField F := NumberField.of_intermediateField F
  letI : IsGalois в„ҡ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsTotallyReal F :=
    NumberField.instIsTotallyRealSubtypeMemIntermediateFieldRatOfIsAlgebraic F
  let eF : (F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3) :=
    (IsGalois.normalAutEquivQuotient H).symm.trans
      (QuotientGroup.quotientKerEquivOfSurjective ПҶ hПҶ_surj)
  have hfinQF : Module.finrank в„ҡ F = 3 := by
    rw [вҶҗ IsGalois.card_aut_eq_finrank в„ҡ F]
    calc
      Nat.card (F вүғвӮҗ[в„ҡ] F) = Nat.card (Multiplicative (ZMod 3)) := Nat.card_congr eF.toEquiv
      _ = Nat.card (ZMod 3) := Nat.card_congr Multiplicative.toAdd
      _ = 3 := Nat.card_zmod 3
  have hfinFM : Module.finrank F M = 3 ^ (в„“ - 1) := by
    have hmul : Module.finrank в„ҡ F * Module.finrank F M = Module.finrank в„ҡ M :=
      Module.finrank_mul_finrank в„ҡ F M
    cases в„“ with
    | zero =>
        cases Nat.not_lt_zero 0 _hв„“
    | succ n =>
        rw [hfinQF, _hfin, pow_succ] at hmul
        have hmul' : 3 * Module.finrank F M = 3 * 3 ^ n := by
          simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
        have hEq : Module.finrank F M = 3 ^ n := by
          omega
        simpa using hEq
  have hodd : Odd (Module.finrank F M) := by
    rw [hfinFM]
    exact Odd.pow (by decide : Odd 3)
  have hpow_all : вҲҖ g : Multiplicative (Fin в„“ вҶ’ ZMod 3), g ^ 3 = 1 := by
    intro g
    apply Multiplicative.toAdd.injective
    rw [toAdd_pow, toAdd_one]
    ext i
    have h3 : (3 : ZMod 3) = 0 := by decide
    simp [Pi.smul_apply, nsmul_eq_mul, h3]
  have hcomm_all : вҲҖ g h : Multiplicative (Fin в„“ вҶ’ ZMod 3), g * h = h * g := by
    intro g h
    simpa using mul_comm g h
  have hpow : вҲҖ П„ : M вүғвӮҗ[F] M, П„ ^ 3 = 1 := by
    intro П„
    let П„' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm П„
    have hП„' : П„' ^ 3 = 1 := by
      apply Subtype.ext
      change ((П„' : M вүғвӮҗ[в„ҡ] M) ^ 3) = 1
      apply e.injective
      simpa [П„'] using hpow_all (e П„'.1)
    simpa [П„'] using congrArg (IntermediateField.fixingSubgroupEquiv F) hП„'
  have hcomm : вҲҖ П„ П… : M вүғвӮҗ[F] M, П„ * П… = П… * П„ := by
    intro П„ П…
    let П„' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm П„
    let П…' : F.fixingSubgroup := (IntermediateField.fixingSubgroupEquiv F).symm П…
    have hП„П… : П„' * П…' = П…' * П„' := by
      apply Subtype.ext
      change ((П„' : M вүғвӮҗ[в„ҡ] M) * П…') = ((П…' : M вүғвӮҗ[в„ҡ] M) * П„')
      apply e.injective
      simpa [П„', П…'] using hcomm_all (e П„'.1) (e П…'.1)
    simpa [П„', П…'] using congrArg (IntermediateField.fixingSubgroupEquiv F) hП„П…
  refine вҹЁF, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, hfinQF, вҹЁeFвҹ©, hfinFM, hodd, ?_, hpow, hcommвҹ©
  simpa [ПҲ, ПҶ, H, F] using hdisc_rel

theorem diagonal_cubic_subfield_exists_with_discr (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (_hMgal : Nonempty ((M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3)))

theorem ker_transgression_le_restriction_range_comap (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    LinearMap.ker (transgression p G N hN) ≤
      ((LinearMap.range (restriction p G N 1).hom.toLinearMap).comap
        (_root_.Erdos90.h1NormalInvariantSubmodule p G N).subtype) := by
  intro χ hχ
  rw [LinearMap.mem_ker] at hχ
  change χ.1 ∈ LinearMap.range (restriction p G N 1).hom.toLinearMap
  classical
  haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
  let e := continuousH1TrivialAddEquivContinuousAddHom (p := p)
  rcases zero_transgression_exists_continuous_hom_lift (p := p) (G := G) (N := N) hN χ hχ with ⟨ψ, hψ⟩
  refine ⟨(e G).symm ψ, ?_⟩
  apply (e ↥N).injective
  have henat :=
    _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog_naturality
      (p := p) (G1 := ↥N) (G2 := G) N.subtype continuous_subtype_val ((e G).symm ψ)
  have hleft :
      (e ↥N) ((restriction p G N 1).hom ((e G).symm ψ)) =
        ψ.comp (additiveSubtypeContinuousHom G N) := by
    simpa [e, restriction, additiveSubtypeContinuousHom,
      continuousH1TrivialAddEquivContinuousAddHom] using henat
  have hψ_add :
      (ψ.comp (additiveSubtypeContinuousHom G N)).toAddMonoidHom =
        ((e ↥N) χ.1).toAddMonoidHom := by
    rw [← h1ToHom_eq_package (p := p) (G := G) (N := N) (hN := hN) (x := χ.1)]
    simpa [additiveSubtypeContinuousHom] using hψ
  have hψ' :
      ψ.comp (additiveSubtypeContinuousHom G N) = (e ↥N) χ.1 := by
    ext n
    change (ψ.comp (additiveSubtypeContinuousHom G N)).toAddMonoidHom n =
      ((e ↥N) χ.1).toAddMonoidHom n
    exact DFunLike.congr_fun hψ_add n
  exact hleft.trans hψ'

theorem exact_at_H1N_invariants (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    LinearMap.ker (transgression p G N hN) =
      ((LinearMap.range (restriction p G N 1).hom.toLinearMap).comap

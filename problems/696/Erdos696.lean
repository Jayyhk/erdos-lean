      -- d * b ∣ M (from d ∣ a, b ∣ M, gcd(d, b) = 1 via gcd(a, b) = 1 + d ∣ a).
      -- M = d * b * k for k > 0 (M > 0).  So M/d = b * k, (M/d)/b = k > 0.

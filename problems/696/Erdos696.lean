  have ha_pos : 0 < a := by
    rw [ha_def]
    unfold primorial
    apply Finset.prod_pos
    intro p hp
    rw [Finset.mem_filter] at hp
    exact hp.2.pos
  -- a ∣ M: every prime in a is ≤ past_cutoff ≤ exp(y_k^{A-1}).

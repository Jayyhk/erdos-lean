          rfl

theorem boundary_extension_translate_difference_abel_identity {f : в„• вҶ’ в„қ} {b Оҙ Пғ X : в„қ} :
  0 < Пғ вҶ’
  0 вүӨ X вҶ’
  вҲ« t in (0 : в„қ)..X,
    (((logRescalePartialSum f (t + Оҙ) - b) - (logRescalePartialSum f t - b)) * Real.exp (-Пғ * t))
  =
    Real.exp (-Пғ * X) *
      (вҲ« s in (0 : в„қ)..X,
        ((logRescalePartialSum f (s + Оҙ) - b) - (logRescalePartialSum f s - b)))
    + Пғ *
      (вҲ« t in (0 : в„қ)..X,
        (вҲ« s in (0 : в„қ)..t,
          ((logRescalePartialSum f (s + Оҙ) - b) - (logRescalePartialSum f s - b))) *
          Real.exp (-Пғ * t)) := by
  intro hПғ hX
  let D : в„қ вҶ’ в„қ := fun t => (logRescalePartialSum f (t + Оҙ) - b) - (logRescalePartialSum f t - b)
  let E : в„қ вҶ’ в„қ := fun t => Real.exp (-(Пғ * t))
  let P : в„қ вҶ’ в„қ := fun t => вҲ« s in (0 : в„қ)..t, D s
  let Q : в„қ вҶ’ в„қ := fun t => вҲ« s in (0 : в„қ)..t, E s
  have hD_int : вҲҖ a d : в„қ, IntervalIntegrable D MeasureTheory.volume a d := by
    intro a d
    have hshift : IntervalIntegrable (fun y : в„қ => logRescalePartialSum f (y + Оҙ) - b) MeasureTheory.volume a d := by
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
        (logRescalePartialSum_intervalIntegrable f b (a + Оҙ) (d + Оҙ)).comp_add_right Оҙ
    simpa [D] using hshift.sub (logRescalePartialSum_intervalIntegrable f b a d)
  have hE_cont : Continuous E := by
    simpa [E] using (Real.continuous_exp.comp ((continuous_const.mul continuous_id).neg))
  have hE_int : IntervalIntegrable E MeasureTheory.volume (0 : в„қ) X :=
    hE_cont.intervalIntegrable 0 X
  have hP_ac : AbsolutelyContinuousOnInterval P 0 X := by
    simpa [P] using (hD_int 0 X).absolutelyContinuousOnInterval_intervalIntegral (c := 0)
      (by simpa [Set.uIcc_of_le hX])
  have hQ_ac : AbsolutelyContinuousOnInterval Q 0 X := by
    simpa [Q] using hE_int.absolutelyContinuousOnInterval_intervalIntegral (c := 0)
      (by simpa [Set.uIcc_of_le hX])
  have hderivP_eq :
      вҲҖбөҗ t вҲӮMeasureTheory.volume, t вҲҲ Set.uIoc (0 : в„қ) X вҶ’ deriv P t = D t := by
    filter_upwards [(hD_int 0 X).ae_hasDerivAt_integral] with t ht htmem
    exact (ht (Set.uIoc_subset_uIcc htmem) 0 (by simpa [Set.uIcc_of_le hX])).deriv
  have hderivQ_eq :
      вҲҖбөҗ t вҲӮMeasureTheory.volume, t вҲҲ Set.uIoc (0 : в„қ) X вҶ’ deriv Q t = E t := by
    filter_upwards [hE_int.ae_hasDerivAt_integral] with t ht htmem
    exact (ht (Set.uIoc_subset_uIcc htmem) 0 (by simpa [Set.uIcc_of_le hX])).deriv
  have hparts' :
      (вҲ« t in (0 : в„қ)..X, D t * Q t) =
        Q X * P X - Q 0 * P 0 - (вҲ« t in (0 : в„қ)..X, P t * E t) := by
    calc
      (вҲ« t in (0 : в„қ)..X, D t * Q t) = вҲ« t in (0 : в„қ)..X, deriv P t * Q t := by
        apply intervalIntegral.integral_congr_ae
        filter_upwards [hderivP_eq] with t ht htmem
        rw [ht htmem]
      _ = вҲ« t in (0 : в„қ)..X, Q t * deriv P t := by
        apply intervalIntegral.integral_congr
        intro t ht
        ring
      _ = Q X * P X - Q 0 * P 0 - (вҲ« t in (0 : в„қ)..X, deriv Q t * P t) := by
        simpa [mul_comm, mul_left_comm, mul_assoc] using
          (AbsolutelyContinuousOnInterval.integral_mul_deriv_eq_deriv_mul hQ_ac hP_ac)
      _ = Q X * P X - Q 0 * P 0 - (вҲ« t in (0 : в„қ)..X, P t * E t) := by
        congr 1
        calc
          (вҲ« t in (0 : в„қ)..X, deriv Q t * P t) = вҲ« t in (0 : в„қ)..X, E t * P t := by
            apply intervalIntegral.integral_congr_ae
            filter_upwards [hderivQ_eq] with t ht htmem
            rw [ht htmem]
          _ = вҲ« t in (0 : в„қ)..X, P t * E t := by
            apply intervalIntegral.integral_congr
            intro t ht
            ring
  have hQ_formula : вҲҖ t вҲҲ Set.Icc (0 : в„қ) X, Q t = (1 - E t) / Пғ := by
    intro t ht
    have hПғ0 : (-Пғ) вү  0 := neg_ne_zero.mpr hПғ.ne'
    change вҲ« x in (0 : в„қ)..t, Real.exp (-(Пғ * x)) = (1 - Real.exp (-(Пғ * t))) / Пғ
    calc
      вҲ« x in (0 : в„қ)..t, Real.exp (-(Пғ * x))
          = (-Пғ)вҒ»В№ вҖў вҲ« x in (-Пғ) * (0 : в„қ)..(-Пғ) * t, Real.exp x := by
              simpa [neg_mul] using
                (intervalIntegral.integral_comp_mul_left (f := Real.exp) (a := (0 : в„қ))
                  (b := t) (c := -Пғ) hПғ0)
      _ = (-Пғ)вҒ»В№ * (Real.exp ((-Пғ) * t) - Real.exp 0) := by
            rw [smul_eq_mul, integral_exp]

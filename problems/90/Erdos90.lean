  let Пүfun : C((G в§ё N) Г— (G в§ё N), ZMod p) :=
    вҹЁfun gh => f gh - c, by
      exact f.continuous.sub continuous_constвҹ©
  have hПү : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G в§ё N) Пүfun := by
    intro g h k
    have hf' := hf g h k

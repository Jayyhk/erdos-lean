    rw [map_pow, Ideal.absNorm_eq_pow_inertiaDeg' (P := (Q : Ideal (рқ“һ M))) hri_prime]
    rw [вҶҗ Ideal.inertiaDegIn_eq_inertiaDeg (p := p) (P := (Q : Ideal (рқ“һ M))) (B := рқ“һ M)
      (G := M вүғвӮҗ[в„ҡ] M)]
    simp [fIn, pow_mul, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
  have hnorm_prod :
      Ideal.absNorm (вҲҸ Q : p.primesOver (рқ“һ M), ((Q : Ideal (рқ“һ M)) ^ (eIn - 1)))
        = (r i) ^ (g * (fIn * (eIn - 1))) := by

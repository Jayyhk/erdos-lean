    have hperiodic := composite_successor_bad_count_le_periodic
      (A := 20) (y := y_target) (d := d) hd_pos hy_target_ge_1 hM_real_nn
    -- Combine: count{BadSet at M} ≤ ρ · M + M_d ≤ y^{-c}/(2d) · M + M_d.

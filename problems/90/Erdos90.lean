      decide
    simp [h3]
  В· intro g h
    apply e.injective
    rw [map_mul, map_mul]
    exact mul_comm (e g) (e h)

theorem cyclic_cubic_subfield_of_surjective_character (в„“ : в„•) (_hв„“ : 0 < в„“)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (e : (M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3))
    (ПҲ : Multiplicative (Fin в„“ вҶ’ ZMod 3) вҶ’* Multiplicative (ZMod 3))
    (_hПҲ_surj : Function.Surjective ПҲ) :
    вҲғ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois в„ҡ F)
      (_ : Algebra F M) (_ : IsScalarTower в„ҡ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank в„ҡ F = 3 вҲ§
      Nonempty ((F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3)) вҲ§
      Module.finrank F M = 3 ^ (в„“ - 1) вҲ§
      Odd (Module.finrank F M) вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) := by
  classical
  let ПҮ : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (ZMod 3) :=
    ПҲ.comp (e : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (Fin в„“ вҶ’ ZMod 3))
  let H : Subgroup (M вүғвӮҗ[в„ҡ] M) := ПҮ.ker
  let F : IntermediateField в„ҡ M := IntermediateField.fixedField H
  letI : H.Normal := by
    dsimp [H, ПҮ]
    infer_instance
  letI : IsGalois в„ҡ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsGalois F M := IsGalois.tower_top_intermediateField F
  have hПҮ_surj : Function.Surjective ПҮ := by
    intro z
    rcases _hПҲ_surj z with вҹЁy, rflвҹ©
    refine вҹЁe.symm y, ?_вҹ©
    simp [ПҮ]
  have eF : (F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3) :=
    (IsGalois.normalAutEquivQuotient H).symm.trans
      (QuotientGroup.quotientKerEquivOfSurjective (ПҶ := ПҮ) hПҮ_surj)
  have hcardG : Nat.card (M вүғвӮҗ[в„ҡ] M) = 3 ^ в„“ := by
    calc
      Nat.card (M вүғвӮҗ[в„ҡ] M) = Nat.card (Multiplicative (Fin в„“ вҶ’ ZMod 3)) :=
        Nat.card_congr e.toEquiv
      _ = Fintype.card (Multiplicative (Fin в„“ вҶ’ ZMod 3)) := Nat.card_eq_fintype_card
      _ = Fintype.card (Fin в„“ вҶ’ ZMod 3) := Fintype.card_multiplicative _
      _ = 3 ^ в„“ := by
        rw [Fintype.card_fun]
        simp [ZMod.card]
  have hcardGalF : Nat.card (F вүғвӮҗ[в„ҡ] F) = 3 := by
    calc
      Nat.card (F вүғвӮҗ[в„ҡ] F) = Nat.card (Multiplicative (ZMod 3)) := Nat.card_congr eF.toEquiv
      _ = Fintype.card (Multiplicative (ZMod 3)) := Nat.card_eq_fintype_card
      _ = Fintype.card (ZMod 3) := Fintype.card_multiplicative _
      _ = 3 := by simp
  have hcardH : Nat.card H = 3 ^ (в„“ - 1) := by
    have hmul : 3 ^ в„“ = 3 * Nat.card H := by
      calc
        3 ^ в„“ = Nat.card (M вүғвӮҗ[в„ҡ] M) := hcardG.symm
        _ = Nat.card ((M вүғвӮҗ[в„ҡ] M) в§ё H) * Nat.card H :=
          Subgroup.card_eq_card_quotient_mul_card_subgroup H
        _ = Nat.card (F вүғвӮҗ[в„ҡ] F) * Nat.card H := by
          simpa [F] using
            (Nat.card_congr (IsGalois.normalAutEquivQuotient H).toEquiv :
              Nat.card ((M вүғвӮҗ[в„ҡ] M) в§ё H) =
                Nat.card ((вҶҘ(IntermediateField.fixedField H)) вүғвӮҗ[в„ҡ] (вҶҘ(IntermediateField.fixedField H))))
        _ = 3 * Nat.card H := by rw [hcardGalF]
    have hpow : 3 ^ в„“ = 3 * 3 ^ (в„“ - 1) := by
      calc
        3 ^ в„“ = 3 ^ (в„“ - 1 + 1) := by
          congr
          omega
        _ = 3 ^ (в„“ - 1) * 3 := by rw [pow_succ]
        _ = 3 * 3 ^ (в„“ - 1) := by rw [Nat.mul_comm]
    omega
  have hfinrankF : Module.finrank в„ҡ F = 3 := by
    exact (IsGalois.card_aut_eq_finrank в„ҡ F).symm.trans hcardGalF
  have hfinrankFM : Module.finrank F M = 3 ^ (в„“ - 1) := by
    simpa [F] using (IntermediateField.finrank_fixedField_eq_card H).trans hcardH
  have hpowcomm := fun_zmod3_equiv_pow_three_and_comm в„“ (M вүғвӮҗ[в„ҡ] M) e
  have hpow_abs : вҲҖ g : M вүғвӮҗ[в„ҡ] M, g ^ 3 = 1 := hpowcomm.1
  have hcomm_abs : вҲҖ g h : M вүғвӮҗ[в„ҡ] M, g * h = h * g := hpowcomm.2
  have hpowH : вҲҖ h : H, h ^ 3 = 1 := by
    intro h
    ext a
    exact congrArg (fun f : M вүғвӮҗ[в„ҡ] M => f a) (hpow_abs h.1)
  have hcommH : вҲҖ h k : H, h * k = k * h := by
    intro h k
    ext a
    exact congrArg (fun f : M вүғвӮҗ[в„ҡ] M => f a) (hcomm_abs h.1 k.1)
  refine вҹЁF, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, inferInstance, inferInstance, ?_вҹ©
  constructor
  В· exact hfinrankF
  constructor
  В· exact вҹЁeFвҹ©
  constructor
  В· exact hfinrankFM
  constructor
  В· simpa [hfinrankFM] using (Odd.pow (n := в„“ - 1) (show Odd 3 by decide))
  constructor
  В· intro Пғ
    let hПғ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm Пғ
    have hhПғ : hПғ ^ 3 = 1 := hpowH hПғ
    simpa [hПғ] using congrArg (IntermediateField.subgroupEquivAlgEquiv H) hhПғ
  В· intro Пғ П„
    let hПғ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm Пғ
    let hП„ : H := (IntermediateField.subgroupEquivAlgEquiv H).symm П„
    have hhПғП„ : hПғ * hП„ = hП„ * hПғ := hcommH hПғ hП„
    simpa [hПғ, hП„] using congrArg (IntermediateField.subgroupEquivAlgEquiv H) hhПғП„

theorem diagonal_cubic_subfield_exists (в„“ : в„•) (_hв„“ : 0 < в„“)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (_hMgal : Nonempty ((M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3))) :
    вҲғ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
      (_ : IsTotallyReal F) (_ : IsGalois в„ҡ F)
      (_ : Algebra F M) (_ : IsScalarTower в„ҡ F M)
      (_ : FiniteDimensional F M) (_ : IsGalois F M),
      Module.finrank в„ҡ F = 3 вҲ§
      Nonempty ((F вүғвӮҗ[в„ҡ] F) вүғ* Multiplicative (ZMod 3)) вҲ§
      Module.finrank F M = 3 ^ (в„“ - 1) вҲ§
      Odd (Module.finrank F M) вҲ§
      (вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1) вҲ§
      (вҲҖ Пғ П„ : M вүғвӮҗ[F] M, Пғ * П„ = П„ * Пғ) := by
  classical
  rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt _hв„“) with вҹЁk, rflвҹ©
  rcases _hMgal with вҹЁeвҹ©
  let ПҲ : Multiplicative (Fin (k + 1) вҶ’ ZMod 3) вҶ’* Multiplicative (ZMod 3) :=
    { toFun := fun f => Multiplicative.ofAdd (Multiplicative.toAdd f 0)
      map_one' := rfl
      map_mul' := by
        intro a b
        rfl }
  let ПҮ : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (ZMod 3) :=
    ПҲ.comp (e : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (Fin (k + 1) вҶ’ ZMod 3))
  have hПҮ_surj : Function.Surjective ПҮ := by
    intro z
    refine вҹЁe.symm (Multiplicative.ofAdd fun _ => Multiplicative.toAdd z), ?_вҹ©
    simp [ПҮ, ПҲ]
  let H : Subgroup (M вүғвӮҗ[в„ҡ] M) := ПҮ.ker
  let F : IntermediateField в„ҡ M := IntermediateField.fixedField H
  letI : IsGalois в„ҡ F := IsGalois.of_fixedField_normal_subgroup H
  letI : IsGalois F M := IsGalois.tower_top_intermediateField F
  have hcardG : Nat.card (M вүғвӮҗ[в„ҡ] M) = 3 ^ (k + 1) := by
    calc
      Nat.card (M вүғвӮҗ[в„ҡ] M) = Nat.card (Multiplicative (Fin (k + 1) вҶ’ ZMod 3)) :=
        Nat.card_congr e.toEquiv
      _ = Nat.card (Fin (k + 1) вҶ’ ZMod 3) := by rfl
      _ = Nat.card (ZMod 3) ^ Nat.card (Fin (k + 1)) := Nat.card_fun
      _ = 3 ^ (k + 1) := by rw [Nat.card_zmod, Nat.card_fin]
  have hcardQ : Nat.card ((M вүғвӮҗ[в„ҡ] M) в§ё H) = 3 := by
    calc
      Nat.card ((M вүғвӮҗ[в„ҡ] M) в§ё H) = Nat.card ПҮ.range := by
        simpa [H] using Nat.card_congr (QuotientGroup.quotientKerEquivRange ПҮ).toEquiv
      _ = Nat.card (вҠӨ : Subgroup (Multiplicative (ZMod 3))) := by
        rw [MonoidHom.range_eq_top_of_surjective ПҮ hПҮ_surj]

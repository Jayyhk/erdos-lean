/-- Upper bound on enumerateB: for i ≤ K(m+1) with m ≥ 1, enumerateB i ≤ n_m + N_{m-1} -/
lemma enumerateB_stage_upper_bound (m : ℕ) (hm : m ≥ 1) (i : ℕ) (hi : 1 ≤ i) (hi_le : i ≤ K (m + 1)) :
    enumerateB i ≤ concreteSeq.n m + concreteSeq.N (m - 1) := by
  induction i using Nat.strong_induction_on with
  | _ i ih =>
    have hi_in_B := enumerateB_in_B i hi
    obtain ⟨j, hj, hx_in_j⟩ := hi_in_B
    by_cases hj_le_m : j ≤ m
    · -- j ≤ m: enumerateB i ∈ B_j, so enumerateB i ≤ n_j + N_{j-1} ≤ n_m + N_{m-1}
      have hub := concreteSeq.B_k_upper_bound j hj (enumerateB i) hx_in_j
      have hN_mono : concreteSeq.N (j - 1) ≤ concreteSeq.N (m - 1) := concreteSeq.N_mono_le (by omega)

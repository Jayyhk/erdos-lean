      Set.EqOn G
        (fun z : ℂ => ∫ x in Set.Ioi (0 : ℝ),
          (((logRescalePartialSum f x - a.re : ℝ) : ℂ) * Complex.exp (-z * x)))
        {z : ℂ | 0 < z.re} := by
  intro haim hnonneg hsumm hcont heq
  refine ⟨fun z : ℂ => (g (1 + z) - ((a.re : ℝ) : ℂ)) / (1 + z), ?_, ?_⟩
  · exact continuousOn_shift_sub_const_div_one_add (g := g) (c := ((a.re : ℝ) : ℂ)) hcont
  · exact centered_logRescalePartialSum_laplace_eq_shift_sub_const_div (f := f) (a := a) (g := g) haim hnonneg hsumm heq

theorem hasBoundaryLaplaceExtension_of_eqOn {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :
  (haim : a.im = 0) →

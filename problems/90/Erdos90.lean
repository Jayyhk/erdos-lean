  let eQ :
      (B ⧸ LinearMap.range (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatToCycles)) ≃ₗ[ZMod p]
        _root_.Erdos90.InhomogClassAPI.Cohomology p G n :=
    Submodule.Quotient.equiv
      (LinearMap.range (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatToCycles))

  letI : P.IsPrime := Ideal.primesOver.isPrime (Q := вҹЁP, hP'вҹ©)
  letI : PвӮҖ.IsPrime := Ideal.primesOver.isPrime (Q := вҹЁPвӮҖ, hPвӮҖ'вҹ©)
  letI : P.LiesOver p := Ideal.primesOver.liesOver (Q := вҹЁP, hP'вҹ©)
  letI : PвӮҖ.LiesOver p := Ideal.primesOver.liesOver (Q := вҹЁPвӮҖ, hPвӮҖ'вҹ©)

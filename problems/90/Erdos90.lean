theorem quotientCocycle_class_eq_transgression_of_sectionCochain_formula (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (ω : {ω : C((G ⧸ N) × (G ⧸ N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω})
    (χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N))
    (u : C(G ⧸ N, ZMod p))
    (hωu : ∀ x y : G ⧸ N,
      ω.1 (x, y) =
        u y - u (x * y) + u x +
          (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
            (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
            (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
            (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1)) (x, y)) :
    QClass p G N hN ω = transgression p G N hN χ := by
  classical
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  let s : C(G ⧸ N, G) :=
    _root_.Erdos90.TransgressionContinuous.chosenSection G N hN
  let hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x :=
    _root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN
  let χh : Additive ↥N →+ ZMod p :=
    _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1
  let ωχ : C((G ⧸ N) × (G ⧸ N), ZMod p) :=
    _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs χh
  let hωχ : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ωχ :=
    _root_.Erdos90.TransgressionContinuousInternal.schreier_isCocycle p G N s hs χh
      (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit_conjugation_invariant
        p G N hN χ)
  let corr : C((G ⧸ N) × (G ⧸ N), ZMod p) :=
    (u.comp ⟨fun xy : (G ⧸ N) × (G ⧸ N) => xy.2, continuous_snd⟩) -
      (u.comp ⟨fun xy : (G ⧸ N) × (G ⧸ N) => xy.1 * xy.2, continuous_fst.mul continuous_snd⟩) +
      (u.comp ⟨fun xy : (G ⧸ N) × (G ⧸ N) => xy.1, continuous_fst⟩)
  have hcorr : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p (G ⧸ N) corr := by
    refine ⟨u, ?_⟩
    intro x y
    rfl
  let zω : _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2 :=
    _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ω.1 ω.2
  let zχ : _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2 :=
    _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωχ hωχ
  have hsub : (((zω - zχ : _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
      _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2) =
      _root_.Erdos90.InhomogClassAPI.ofProd p (G ⧸ N) corr) := by
    ext g
    change ω.1 (g 0, g 1) - ωχ (g 0, g 1) = corr (g 0, g 1)
    rw [hωu (g 0) (g 1)]
    simp [corr, ωχ, χh, s, hs]
  have hmem :
      (((zω - zχ : _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
        _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2) ∈
        _root_.Erdos90.InhomogClassAPI.Coboundaries p (G ⧸ N) 2) := by
    rw [hsub]
    exact _root_.Erdos90.InhomogClassAPI.ofProd_mem_coboundaries_of_isCoboundary2
      p (G ⧸ N) corr hcorr
  have hclass_sub :
      _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2 (zω - zχ) = 0 := by
    exact (_root_.Erdos90.InhomogClassAPI.classMap_eq_zero_iff p (G ⧸ N) 2 (zω - zχ)).2 hmem
  have hclass_eq :
      _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2 zω =
        _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2 zχ := by
    apply sub_eq_zero.mp
    simpa [map_sub] using hclass_sub
  have hpack := congrArg ((_root_.Erdos90.InhomogHomogIso.cohomologyIso p (G ⧸ N) 2)) hclass_eq
  simpa [QClass, transgression, _root_.Erdos90.TransgressionContinuous.transgressionContinuous,
    _root_.Erdos90.TransgressionContinuousInternal.transgressionContinuous,
    zω, zχ, ωχ, hωχ, s, hs, χh] using hpack

theorem normalized_quotientCocycle_class_eq_transgression_of_inflated_coboundary (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (ω : {ω : C((G ⧸ N) × (G ⧸ N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω})
    (h1 : ∀ q : G ⧸ N, ω.1 (1, q) = 0)
    (h2 : ∀ q : G ⧸ N, ω.1 (q, 1) = 0)
    (hinfl : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p G (QPull p G N ω)) :

  have hq : вҲҖ j (Пғ : Gal(K/F)), hquot_equiv j ((Q.map Пғ : Q.Q) : Q.Q в§ё (U j : Subgroup Q.Q)) = (Пғ : Gal(K/F) в§ё N j) := by
    intro j Пғ

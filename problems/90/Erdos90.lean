      _ вүӨ Оҙ := hОҙ
  have hCKsmall : вҲ« u in (-(1 / 2 : в„қ))..(1 / 2 : в„қ), C * K u вүӨ C * Оҙ := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left hKsmall hC0
  have hpiece1' :
      |(вҲ« t in (0 : в„қ)..1, (leftTentKernel (t - (1 / 2 : в„қ))).re * g t) -
        (вҲ« t in (0 : в„қ)..1, (ПҲ (t - (1 / 2 : в„қ))).re * g t)| вүӨ C * Оҙ := by
    calc

    have hnlo : st.H + params.K + 3 * st.M ≤ n := by
      omega
    have hnhi : n + 3 * st.M ≤ st.X + params.K + params.LZ := by omega
    simpa [StageParams.tailBlock, StageParams.nextX, StageParams.Mplus] using

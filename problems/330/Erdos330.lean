theorem activatedShiftedQRDelete_mem_of_stage (st : StageState) {a b p n : ℕ}
    (ha : a ∈ st.P) (hbDormant : b ∉ st.P) (hp : FreshPrimeData st p)
    (h u1 u2 : ZMod (st.m a)) :

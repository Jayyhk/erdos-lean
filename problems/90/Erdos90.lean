theorem selectedHomogToInhomog_inhomogToHomog_aux (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) : (selectedHomogToInhomog_aux p G n).comp (selectedInhomogToHomog_aux p G n) = (LinearMap.id : _root_.Erdos90.InhomogContsCochains.Cochain p G n вҶ’вӮ—[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G n) := by

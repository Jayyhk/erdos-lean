variable (p : ℕ) [Fact p.Prime]
variable (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]

structure GInvariantHom (N : Subgroup G) [N.Normal] where

  hom : ↥N →* Multiplicative (ZMod p)

  continuous : Continuous hom

  ginv : ∀ (g : G) (x : ↥N),
    hom ⟨g * (x : G) * g⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 g⟩ = hom x

namespace GInvariantHom

variable {p G}

theorem vanish_conj
    {N : Subgroup G} [N.Normal] (χ : GInvariantHom p G N)
    (g : G) (x : ↥N) (hx : χ.hom x = 1) :
    χ.hom ⟨g * (x : G) * g⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 g⟩ = 1 := by
  rw [χ.ginv g x, hx]

end GInvariantHom

theorem evaluation_injective_of_normal_generators
    {k : ℕ} (g : Fin k → G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure)
    (χ : GInvariantHom p G N)
    (hχ_zero : ∀ i : Fin k,
      ∃ (hmem : (g i : G) ∈ N),
        χ.hom ⟨g i, hmem⟩ = 1) :
    ∀ x : ↥N, χ.hom x = 1 := by

  set K : Subgroup ↥N := χ.hom.ker with hK_def

  set K' : Subgroup G := K.map N.subtype with hK'_def

  have hK'_iff : ∀ x : G, x ∈ K' ↔
      ∃ (hmem : x ∈ N), χ.hom ⟨x, hmem⟩ = 1 := by
    intro x
    simp only [hK'_def, hK_def, Subgroup.mem_map, MonoidHom.mem_ker, Subgroup.coe_subtype]
    constructor
    · rintro ⟨y, hy, rfl⟩
      exact ⟨y.2, hy⟩
    · rintro ⟨hmem, hχ⟩
      exact ⟨⟨x, hmem⟩, hχ, rfl⟩

  have hK'_normal : K'.Normal := by
    refine ⟨fun n hn h => ?_⟩
    rcases (hK'_iff n).mp hn with ⟨hn_mem, hχn⟩
    refine (hK'_iff _).mpr ?_
    refine ⟨‹N.Normal›.conj_mem n hn_mem h, ?_⟩
    exact χ.vanish_conj h ⟨n, hn_mem⟩ hχn

  have h_gen_le : Set.range g ⊆ (K' : Set G) := by
    rintro _ ⟨i, rfl⟩
    rcases hχ_zero i with ⟨hmem, hχ⟩
    exact (hK'_iff (g i)).mpr ⟨hmem, hχ⟩

  have h_normalClosure_le : Subgroup.normalClosure (Set.range g) ≤ K' :=
    Subgroup.normalClosure_le_normal h_gen_le

  have hN_closed : IsClosed (N : Set G) := by
    rw [_hN]
    exact Subgroup.isClosed_topologicalClosure _

  have hK_closed : IsClosed (K : Set ↥N) := by
    have : (K : Set ↥N) = χ.hom ⁻¹' {1} := rfl
    rw [this]
    exact (isClosed_singleton).preimage χ.continuous

  have hN_closedMap : IsClosedMap ((↑) : ↥N → G) :=
    hN_closed.isClosedMap_subtype_val

  have hK'_closed : IsClosed (K' : Set G) := by
    have h_eq : (K' : Set G) = ((↑) : ↥N → G) '' (K : Set ↥N) := by
      simp [hK'_def, Subgroup.coe_map]
    rw [h_eq]
    exact hN_closedMap _ hK_closed

  have h_topClosure_le : (Subgroup.normalClosure (Set.range g)).topologicalClosure ≤ K' :=
    Subgroup.topologicalClosure_minimal _ h_normalClosure_le hK'_closed

  have hN_le_K' : N ≤ K' := by rw [_hN]; exact h_topClosure_le

  intro x
  have hxG : (x : G) ∈ K' := hN_le_K' x.2
  rcases (hK'_iff (x : G)).mp hxG with ⟨_, hχ⟩

  exact hχ

noncomputable def GInvariantContsHomSubmodule (N : Subgroup G) [N.Normal] :
    Submodule (ZMod p) (↥N → ZMod p) where
  carrier :=
    { f |
      (∀ x y : ↥N, f (x * y) = f x + f y) ∧
        f 1 = 0 ∧
        Continuous f ∧
        ∀ (h : G) (x : ↥N),
          f ⟨h * (x : G) * h⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 h⟩ = f x }
  zero_mem' :=
    ⟨by intros; simp, rfl, continuous_const, by intros; simp⟩
  add_mem' := by
    rintro f g ⟨hf_hom, hf_one, hf_c, hf_g⟩ ⟨hg_hom, hg_one, hg_c, hg_g⟩
    refine ⟨?_, ?_, hf_c.add hg_c, ?_⟩
    · intro x y; simp [hf_hom, hg_hom, Pi.add_apply]; ring
    · simp [hf_one, hg_one, Pi.add_apply]
    · intro h x
      simp [Pi.add_apply, hf_g h x, hg_g h x]
  smul_mem' := by
    rintro c f ⟨hf_hom, hf_one, hf_c, hf_g⟩
    refine ⟨?_, ?_, ?_, ?_⟩
    · intro x y; simp [Pi.smul_apply, hf_hom, mul_add]
    · simp [Pi.smul_apply, hf_one]
    · change Continuous (fun x => c • f x); exact hf_c.const_smul c
    · intro h x
      simp [Pi.smul_apply, hf_g h x]

theorem dim_GInvariantHom_le
    {k : ℕ} (g : Fin k → G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure) :
    Module.finrank (ZMod p) (GInvariantContsHomSubmodule p G N) ≤ k := by

  have hg_mem : ∀ i : Fin k, (g i : G) ∈ N := by
    intro i
    have h1 : (g i : G) ∈ Subgroup.normalClosure (Set.range g) :=
      Subgroup.subset_normalClosure ⟨i, rfl⟩
    have h2 : Subgroup.normalClosure (Set.range g) ≤
        (Subgroup.normalClosure (Set.range g)).topologicalClosure :=
      Subgroup.le_topologicalClosure _
    have : (g i : G) ∈ (Subgroup.normalClosure (Set.range g)).topologicalClosure := h2 h1
    rwa [← _hN] at this

  let eval : GInvariantContsHomSubmodule p G N →ₗ[ZMod p] (Fin k → ZMod p) :=
    { toFun := fun f i => (f : ↥N → ZMod p) ⟨g i, hg_mem i⟩
      map_add' := by
        intro f f'
        funext i
        rfl
      map_smul' := by
        intro c f
        funext i
        rfl }

  have heval_inj : Function.Injective eval := by
    intro f f' hff'

    obtain ⟨f, hf_hom, hf_one, hf_c, hf_g⟩ := f
    obtain ⟨f', hf'_hom, hf'_one, hf'_c, hf'_g⟩ := f'

    set d : ↥N → ZMod p := f - f' with hd_def
    have hd_hom : ∀ x y : ↥N, d (x * y) = d x + d y := by
      intro x y
      simp [hd_def, hf_hom, hf'_hom]; ring
    have hd_one : d 1 = 0 := by simp [hd_def, hf_one, hf'_one]
    have hd_c : Continuous d := hf_c.sub hf'_c
    have hd_g : ∀ (h : G) (x : ↥N),
        d ⟨h * (x : G) * h⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 h⟩ = d x := by
      intro h x
      simp [hd_def, hf_g h x, hf'_g h x]

    let dhom : ↥N →* Multiplicative (ZMod p) :=
      { toFun := fun x => Multiplicative.ofAdd (d x)
        map_one' := by simp [hd_one]
        map_mul' := by intro x y; simp [hd_hom] }
    have hdhom_c : Continuous dhom := by

      change Continuous (fun x => Multiplicative.ofAdd (d x))
      exact hd_c
    have hdhom_ginv : ∀ (h : G) (x : ↥N),
        dhom ⟨h * (x : G) * h⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 h⟩ = dhom x := by
      intro h x
      change Multiplicative.ofAdd _ = Multiplicative.ofAdd _
      exact congrArg Multiplicative.ofAdd (hd_g h x)
    let χ : GInvariantHom p G N :=
      { hom := dhom, continuous := hdhom_c, ginv := hdhom_ginv }

    have hχ_zero : ∀ i : Fin k,
        ∃ (hmem : (g i : G) ∈ N), χ.hom ⟨g i, hmem⟩ = 1 := by
      intro i
      refine ⟨hg_mem i, ?_⟩
      change Multiplicative.ofAdd (d ⟨g i, hg_mem i⟩) = Multiplicative.ofAdd 0
      apply congrArg
      have hi := congrFun hff' i

      change d ⟨g i, hg_mem i⟩ = 0
      simp only [hd_def, Pi.sub_apply, sub_eq_zero]
      exact hi

    have hd_zero : ∀ x : ↥N, d x = 0 := by
      intro x
      have hχx : χ.hom x = 1 :=
        evaluation_injective_of_normal_generators p G g N _hN χ hχ_zero x

      have : Multiplicative.ofAdd (d x) = Multiplicative.ofAdd (0 : ZMod p) := hχx
      simpa using this

    apply Subtype.ext
    funext x
    have hx : d x = 0 := hd_zero x
    have : (f - f') x = 0 := by simpa [hd_def] using hx
    simpa [Pi.sub_apply, sub_eq_zero] using this

  have h := LinearMap.finrank_le_finrank_of_injective heval_inj
  simpa [Module.finrank_fin_fun] using h

theorem h1NormalInvariantRank_le_normalGenerators
    (_hG : IsFinitelyGeneratedProPGroup p G)
    {k : ℕ} (g : Fin k → G) :
    haveI : (Subgroup.normalClosure (Set.range g)).topologicalClosure.Normal :=
      Subgroup.is_normal_topologicalClosure (Subgroup.normalClosure (Set.range g))
    H1NormalInvariantFinite p G
        ((Subgroup.normalClosure (Set.range g)).topologicalClosure) ∧
      h1NormalInvariantRank p G
        ((Subgroup.normalClosure (Set.range g)).topologicalClosure) ≤ k := by


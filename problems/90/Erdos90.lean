theorem proposition_3_8_package_tower (ℓ : ℕ)
    (F : Type) [Field F] [CharZero F] [NumberField F] [IsTotallyReal F] [IsGalois ℚ F]
    (hcubic : Module.finrank ℚ F = 3)
    (isCyclic_F : Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)))
    (Q : ProPQuotient 3 (MaxUnramifiedProPGaloisGroup F 3))
    (T0 : ProPTowerFromQuotient F 3 Q)
    (hstep_comp : ∀ j, (T0.step j).comp (algebraMap F (T0.L j)) = algebraMap F (T0.L (j + 1)))
    (q : Fin ((ℓ - 1) ^ 2 / 100) → ℕ)
    (hq_inj : Function.Injective q)
    (hq_prime : ∀ b, (q b).Prime)
    (hq_mod4 : ∀ b, q b % 4 = 1)
    (hq_split_layers :
      ∀ j b,
        (∀ 𝔭 ∈ (Ideal.span {(q b : ℤ)} : Ideal ℤ).primesOver (𝓞 (T0.L j)),
            Ideal.ramificationIdx (Ideal.span {(q b : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
            Ideal.inertiaDeg (Ideal.span {(q b : ℤ)} : Ideal ℤ) 𝔭 = 1) ∧
          ((Ideal.span {(q b : ℤ)} : Ideal ℤ).primesOver (𝓞 (T0.L j))).ncard =
            Module.finrank ℚ (T0.L j))
    (hγ : 0 <
      ((((ℓ - 1) ^ 2 / 100 : ℕ) : ℝ) * Real.log 2 -
        Real.log (2 * (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant)))) :
    ∃ T : FieldTower ℓ,
      T.t = (ℓ - 1) ^ 2 / 100 ∧
      (letI : Field T.F := T.field_F
       letI : NumberField T.F := T.numberField_F
       Real.log (NumberField.rootDiscr T.F) = Real.log (NumberField.rootDiscr F)) ∧
      Real.log T.H ≤
        Real.log (2 * (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant)) := by
  classical
  let t : ℕ := (ℓ - 1) ^ 2 / 100
  let H : ℝ := 2 * (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant)
  have hH_pos : 1 ≤ H := by
    dsimp [H]
    have hmax : (1 : ℝ) ≤ max 1 (2 * NumberField.rootDiscr F) := le_max_left _ _
    have hC_nonneg : 0 ≤ 2 * classNumberConstant := by
      nlinarith [classNumberConstant_pos]
    have hpow : (1 : ℝ) ≤ (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant) := by
      exact Real.one_le_rpow hmax hC_nonneg
    nlinarith
  have hγ' : 0 < (t : ℝ) * Real.log 2 - Real.log H := by
    simpa [t, H] using hγ
  have ht : 0 < t := by
    by_contra hnot
    have ht0 : t = 0 := Nat.eq_zero_of_not_pos hnot
    have hlogH : 0 ≤ Real.log H := Real.log_nonneg hH_pos
    rw [ht0, Nat.cast_zero, zero_mul] at hγ'
    linarith
  let mkDatum : ∀ j : ℕ,
      ∃ 𝒟 : AdmissibleDatum,
        Nonempty (𝒟.L ≃ₐ[ℚ] T0.L j) ∧
        ∃ ht_eq : 𝒟.t = t,
          ∀ b : Fin t, 𝒟.q (Fin.cast ht_eq.symm b) = q b := by
    intro j
    letI : IsTotallyReal (T0.L j) :=
      prop38_totallyReal_odd_unramified F (T0.L j) 3 (by decide) (by decide)
        (T0.unramified j) (T0.pgroup_gal j)
    exact prop38_mkAdmissibleDatum (L := T0.L j) t ht q hq_prime hq_inj hq_mod4
      (hq_split_layers j)
  let 𝒟 : ℕ → AdmissibleDatum := fun j => Classical.choose (mkDatum j)
  let eQ : ∀ j, (𝒟 j).L ≃ₐ[ℚ] T0.L j :=
    fun j => Classical.choice ((Classical.choose_spec (mkDatum j)).1)
  let sameT : ∀ j, (𝒟 j).t = t :=
    fun j => Classical.choose ((Classical.choose_spec (mkDatum j)).2)
  let sameQ : ∀ j (b : Fin t), (𝒟 j).q (Fin.cast (sameT j).symm b) = q b :=
    fun j => Classical.choose_spec ((Classical.choose_spec (mkDatum j)).2)
  let algebraMap_F : ∀ j, F →+* (𝒟 j).L :=
    fun j => (eQ j).symm.toRingHom.comp (algebraMap F (T0.L j))
  let eF : ∀ j,
      letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
      (𝒟 j).L ≃ₐ[F] T0.L j := by
    intro j
    letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
    refine { (eQ j) with commutes' := ?_ }
    intro x
    change (eQ j) ((eQ j).symm ((algebraMap F (T0.L j)) x)) = (algebraMap F (T0.L j)) x
    exact (eQ j).apply_symm_apply ((algebraMap F (T0.L j)) x)
  have hGaloisD : ∀ j,
      letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
      IsGalois F (𝒟 j).L := by
    intro j
    letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
    exact IsGalois.of_algEquiv (eF j).symm
  have hUnrD : ∀ j,
      letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
      IsEverywhereUnramified F (𝒟 j).L := by
    intro j
    letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
    exact IsEverywhereUnramified.transport (eF j).symm (T0.unramified j)
  have hPGroupD : ∀ j,
      letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
      IsPGroup 3 ((𝒟 j).L ≃ₐ[F] (𝒟 j).L) := by
    intro j
    letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
    exact IsPGroup.of_equiv (T0.pgroup_gal j) ((AlgEquiv.autCongr (eF j)).symm)
  have hRdEq : ∀ j, NumberField.rootDiscr (𝒟 j).L = NumberField.rootDiscr F := by
    intro j
    letI : Algebra F (𝒟 j).L := (algebraMap_F j).toAlgebra
    exact prop38_rootDiscr_eq_unramified F ((𝒟 j).L) (hUnrD j)
  have hRdKBound : ∀ j, NumberField.rootDiscr (𝒟 j).K ≤ 2 * NumberField.rootDiscr F := by
    intro j
    calc
      NumberField.rootDiscr (𝒟 j).K ≤ 2 * NumberField.rootDiscr (𝒟 j).L := prop38_rootDiscr_adjoin_i (𝒟 j)
      _ = 2 * NumberField.rootDiscr F := by rw [hRdEq j]
  have hRdF_ge1 : (1 : ℝ) ≤ NumberField.rootDiscr F := by
    rw [NumberField.rootDiscr_def]
    have hdiscr_ge_nat : 1 ≤ (NumberField.discr F).natAbs := by
      exact Nat.succ_le_of_lt (Int.natAbs_pos.mpr (NumberField.discr_ne_zero (K := F)))
    have hdiscr_ge1 : (1 : ℝ) ≤ (((NumberField.discr F).natAbs : ℕ) : ℝ) := by
      exact_mod_cast hdiscr_ge_nat
    have hexp_nonneg : 0 ≤ (((Module.finrank ℚ F : ℕ) : ℝ)⁻¹) := by positivity
    simpa using Real.one_le_rpow hdiscr_ge1 hexp_nonneg
  refine ⟨
    { t := t
      q := q
      𝒟 := 𝒟
      sameT := sameT
      sameQ := sameQ
      H := H
      H_pos := hH_pos
      class_bound := by
        intro j
        have hfinK : Module.finrank ℚ (𝒟 j).K = 2 * (𝒟 j).f := by
          simpa [AdmissibleDatum.f] using prop38_adm_finrankK (𝒟 j)
        have hMink :
            (NumberField.classNumber (𝒟 j).K : ℝ) ≤
              (max 2 (NumberField.rootDiscr (𝒟 j).K)) ^
                (classNumberConstant * Module.finrank ℚ (𝒟 j).K) := by
          let M1 : Module ℚ (𝒟 j).K := @Algebra.toModule ℚ (𝒟 j).K _ _ DivisionRing.toRatAlgebra
          have hMink0 :
              (NumberField.classNumber (𝒟 j).K : ℝ) ≤
                (max 2 (NumberField.rootDiscr (𝒟 j).K)) ^
                  (classNumberConstant * (letI : Module ℚ (𝒟 j).K := M1; Module.finrank ℚ (𝒟 j).K)) := by
            letI : Algebra ℚ (𝒟 j).K := DivisionRing.toRatAlgebra
            letI : Module ℚ (𝒟 j).K := M1

            simpa using proposition_3_7 ((𝒟 j).K)
          have hfinrat :
              @Module.finrank ℚ (𝒟 j).K _ _ M1 =
                @Module.finrank ℚ (𝒟 j).K _ _ (@Algebra.toModule ℚ (𝒟 j).K _ _ (𝒟 j).algebra_ℚK) := by
            have hM : M1 = @Algebra.toModule ℚ (𝒟 j).K _ _ (𝒟 j).algebra_ℚK := by
              exact Subsingleton.elim _ _
            rw [hM]
          rw [hfinrat] at hMink0
          exact hMink0
        have hC_nonneg : 0 ≤ 2 * classNumberConstant := by
          nlinarith [classNumberConstant_pos]
        have hM_ge : (2 : ℝ) ≤ max 1 (2 * NumberField.rootDiscr F) := by
          have htwo_le : (2 : ℝ) ≤ 2 * NumberField.rootDiscr F := by nlinarith
          exact le_trans htwo_le (le_max_right _ _)
        have hR_le : NumberField.rootDiscr (𝒟 j).K ≤ max 1 (2 * NumberField.rootDiscr F) := by
          exact le_trans (hRdKBound j) (le_max_right _ _)
        have hmax_le : max 2 (NumberField.rootDiscr (𝒟 j).K) ≤ max 1 (2 * NumberField.rootDiscr F) := by
          rw [max_le_iff]
          exact ⟨hM_ge, hR_le⟩
        have hM_nonneg : 0 ≤ max 1 (2 * NumberField.rootDiscr F) := by
          exact le_trans (by norm_num) (le_max_left _ _)
        have hbase_nonneg : 0 ≤ max 2 (NumberField.rootDiscr (𝒟 j).K) := by
          exact le_trans (by norm_num) (le_max_left _ _)
        have hpow_le :
            (max 2 (NumberField.rootDiscr (𝒟 j).K)) ^ (2 * classNumberConstant) ≤
              (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant) := by
          exact Real.rpow_le_rpow hbase_nonneg hmax_le hC_nonneg
        have hpow_nat :
            ((max 2 (NumberField.rootDiscr (𝒟 j).K)) ^ (2 * classNumberConstant)) ^ (𝒟 j).f ≤
              ((max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant)) ^ (𝒟 j).f := by
          have hbase2_nonneg : 0 ≤ (max 2 (NumberField.rootDiscr (𝒟 j).K)) ^ (2 * classNumberConstant) := by
            exact Real.rpow_nonneg hbase_nonneg _
          exact pow_le_pow_left₀ hbase2_nonneg hpow_le _
        have hHbase_nonneg : 0 ≤ (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant) := by
          exact Real.rpow_nonneg hM_nonneg _
        have hHbase_le :
            (max 1 (2 * NumberField.rootDiscr F)) ^ (2 * classNumberConstant) ≤ H := by
          dsimp [H]

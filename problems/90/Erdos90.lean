theorem h1ToHom_explicit_conjugation_invariant
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N)) :
    ∀ g : G, (h1ToHom_explicit p G N hN χ.1).comp
        (MonoidHom.toAdditive
          ((MulAut.conjNormal (H := N) g).toMonoidHom)) =
      h1ToHom_explicit p G N hN χ.1 := by

  intro g
  haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
  let f : ↥N →* ↥N := (MulAut.conjNormal (H := N) g).toMonoidHom
  have hcont : Continuous f := by
    refine continuous_induced_rng.2 ?_
    change Continuous (fun x : ↥N => g * (x : G) * g⁻¹)
    simpa [f, MulAut.conjNormal_apply, mul_assoc] using
      (continuous_const.mul continuous_subtype_val).mul
        (continuous_const : Continuous fun _ : ↥N => (g⁻¹ : G))
  have hχ :
      ((ContinuousCohomology.cohomologyMapTrivial (ZMod p) f hcont
        (TopModuleCat.of (ZMod p) (ZMod p)) 1).hom χ.1) = χ.1 := by
    simpa [f, _root_.Erdos90.h1ConjMap] using χ.2 (g⁻¹)
  let F : Additive ↥N →ₜ+ Additive ↥N :=
    { toFun := fun a => Additive.ofMul (f a.toMul)
      map_zero' := by simp [f]
      map_add' := by
        intro a b
        simp [f]
      continuous_toFun := by simpa [f] using hcont }
  have hnat :=
    continuousH1TrivialAddEquivContinuousAddHom_inhomog_naturality p ↥N ↥N f hcont χ.1
  have hχ' :
      continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N
          (((ContinuousCohomology.cohomologyMapTrivial (ZMod p) f hcont
            (TopModuleCat.of (ZMod p) (ZMod p)) 1).hom χ.1)) =
        continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N χ.1 :=
    congrArg (continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N) hχ
  have hnat' :
      continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N χ.1 =
        (continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N χ.1).comp F := by
    calc
      continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N χ.1 =
          continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N
            (((ContinuousCohomology.cohomologyMapTrivial (ZMod p) f hcont
              (TopModuleCat.of (ZMod p) (ZMod p)) 1).hom χ.1)) := by
            symm
            exact hχ'
      _ = (continuousH1TrivialAddEquivContinuousAddHom_inhomog p ↥N χ.1).comp F := by
            simpa [F, f] using hnat
  simpa [h1ToHom_explicit_eq_inhomog_toAddMonoidHom, F, f] using
    congrArg ContinuousAddMonoidHom.toAddMonoidHom hnat'.symm

noncomputable def transgressionContinuous
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N) →ₗ[ZMod p]
      ((continuousCohomology (ZMod p) (G ⧸ N) 2).obj
        (Action.trivial (G ⧸ N) (TopModuleCat.of (ZMod p) (ZMod p))) : Type) := by
  classical
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  let s : ContinuousMap (G ⧸ N) G :=
    Classical.choose (profinite_quotient_has_continuous_section G N hN)
  let hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x :=
    Classical.choose_spec (profinite_quotient_has_continuous_section G N hN)
  let pack : _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2 →
      ((continuousCohomology (ZMod p) (G ⧸ N) 2).obj
        (Action.trivial (G ⧸ N) (TopModuleCat.of (ZMod p) (ZMod p))) : Type) :=
    fun z =>
      (_root_.Erdos90.InhomogHomogIso.cohomologyIso p (G ⧸ N) 2)
        (_root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2 z)
  let F : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N) →
      ((continuousCohomology (ZMod p) (G ⧸ N) 2).obj
        (Action.trivial (G ⧸ N) (TopModuleCat.of (ZMod p) (ZMod p))) : Type) :=
    fun χ =>
      let χh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN χ.1
      let ω := schreier2Cocycle p G N s hs χh
      let hω := schreier_isCocycle p G N s hs χh
        (h1ToHom_explicit_conjugation_invariant p G N hN χ)
      pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ω hω)
  refine
    { toFun := F
      map_add' := ?_
      map_smul' := ?_ }
  · intro χ ψ
    change F (χ + ψ) = F χ + F ψ
    let χh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN χ.1
    let ψh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN ψ.1
    let χψh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN (χ + ψ).1
    let ωχ := schreier2Cocycle p G N s hs χh
    let ωψ := schreier2Cocycle p G N s hs ψh
    let ωχψ := schreier2Cocycle p G N s hs χψh
    let hωχ := schreier_isCocycle p G N s hs χh
      (h1ToHom_explicit_conjugation_invariant p G N hN χ)
    let hωψ := schreier_isCocycle p G N s hs ψh
      (h1ToHom_explicit_conjugation_invariant p G N hN ψ)
    let hωχψ := schreier_isCocycle p G N s hs χψh
      (h1ToHom_explicit_conjugation_invariant p G N hN (χ + ψ))
    have hlin : χψh = χh + ψh := by
      simp [χh, ψh, χψh]
    have hχcont : Continuous χh := by
      simpa [χh] using (h1ToHom_explicit_continuous p G N hN χ.1)
    have hψcont : Continuous ψh := by
      simpa [ψh] using (h1ToHom_explicit_continuous p G N hN ψ.1)
    have hadd : schreier2Cocycle p G N s hs (χh + ψh) = ωχ + ωψ := by
      simpa [ωχ, ωψ] using
        (schreier2Cocycle_add_of_continuous p G N s hs χh ψh hχcont hψcont)
    have hχψinv :
        ∀ g : G,
          (χh + ψh).comp
              (MonoidHom.toAdditive
                ((MulAut.conjNormal (H := N) g).toMonoidHom)) =
            χh + ψh := by
      simpa [hlin] using
        (h1ToHom_explicit_conjugation_invariant p G N hN (χ + ψ))
    have hωadd : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) (ωχ + ωψ) := by
      simpa [ωχ, ωψ, hadd] using
        (schreier_isCocycle p G N s hs (χh + ψh) hχψinv)
    have hωeq : ωχψ = ωχ + ωψ := by
      calc
        ωχψ = schreier2Cocycle p G N s hs (χh + ψh) := by simp [ωχψ, hlin]
        _ = ωχ + ωψ := hadd
    have hpack :
        pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωχψ hωχψ) =
          pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) (ωχ + ωψ) hωadd) := by
      apply congrArg pack
      ext x
      simp [hωeq]
    calc
      F (χ + ψ)
          = pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) (ωχ + ωψ) hωadd) := by
              simpa [F, χψh, ωχψ, hωχψ] using hpack
      _ = pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωχ hωχ) +
            pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωψ hωψ) := by
              dsimp [pack]
              rw [ofIsCocycle2_add p (G ⧸ N) ωχ ωψ hωχ hωψ hωadd, map_add, map_add]
      _ = F χ + F ψ := by
            simp [F, χh, ψh, ωχ, ωψ, hωχ, hωψ]
  · intro a χ
    change F (a • χ) = a • F χ
    let χh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN χ.1
    let aχh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN (a • χ).1
    let ωχ := schreier2Cocycle p G N s hs χh
    let ωaχ := schreier2Cocycle p G N s hs aχh
    let hωχ := schreier_isCocycle p G N s hs χh
      (h1ToHom_explicit_conjugation_invariant p G N hN χ)
    let hωaχ := schreier_isCocycle p G N s hs aχh
      (h1ToHom_explicit_conjugation_invariant p G N hN (a • χ))
    have hlin : aχh = a • χh := by
      simp [χh, aχh]
    have hχcont : Continuous χh := by
      simpa [χh] using (h1ToHom_explicit_continuous p G N hN χ.1)
    have hsmul : schreier2Cocycle p G N s hs (a • χh) = a • ωχ := by
      simpa [ωχ] using
        (schreier2Cocycle_smul_of_continuous p G N s hs a χh hχcont)
    have haχinv :
        ∀ g : G,
          (a • χh).comp
              (MonoidHom.toAdditive
                ((MulAut.conjNormal (H := N) g).toMonoidHom)) =
            a • χh := by
      simpa [hlin] using
        (h1ToHom_explicit_conjugation_invariant p G N hN (a • χ))
    have hωsmul : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) (a • ωχ) := by
      simpa [ωχ, hsmul] using
        (schreier_isCocycle p G N s hs (a • χh) haχinv)
    have hωeq : ωaχ = a • ωχ := by
      calc
        ωaχ = schreier2Cocycle p G N s hs (a • χh) := by simp [ωaχ, hlin]
        _ = a • ωχ := hsmul
    have hpack :
        pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωaχ hωaχ) =
          pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) (a • ωχ) hωsmul) := by
      apply congrArg pack
      ext x
      simp [hωeq]
    calc
      F (a • χ)
          = pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) (a • ωχ) hωsmul) := by
              simpa [F, aχh, ωaχ, hωaχ] using hpack
      _ = a • pack (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωχ hωχ) := by
              dsimp [pack]
              rw [ofIsCocycle2_smul p (G ⧸ N) a ωχ hωχ hωsmul, map_smul, map_smul]
      _ = a • F χ := by
            simp [F, χh, ωχ, hωχ]

noncomputable def transgressionContinuousRaw
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N) →
      ((continuousCohomology (ZMod p) (G ⧸ N) 2).obj
        (Action.trivial (G ⧸ N) (TopModuleCat.of (ZMod p) (ZMod p))) : Type) :=
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  fun χ =>
    let s : ContinuousMap (G ⧸ N) G :=
      Classical.choose (profinite_quotient_has_continuous_section G N hN)
    let hs : ∀ x : G ⧸ N, QuotientGroup.mk' N (s x) = x :=
      Classical.choose_spec (profinite_quotient_has_continuous_section G N hN)
    let χh : Additive ↥N →+ ZMod p := h1ToHom_explicit p G N hN χ.1
    (_root_.Erdos90.InhomogHomogIso.cohomologyIso p (G ⧸ N) 2)
      (_root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N)
          (schreier2Cocycle p G N s hs χh)
          (schreier_isCocycle p G N s hs χh
            (h1ToHom_explicit_conjugation_invariant p G N hN χ))))


        change LinearMap.range (0 : _root_.Erdos90.InhomogContsCochains.Cochain p G 0 →ₗ[ZMod p] _root_.Erdos90.InhomogContsCochains.Cochain p G 0) = ⊥
        exact LinearMap.range_zero
    | succ m =>
        change LinearMap.range (ModuleCat.Hom.hom ((_root_.Erdos90.InhomogContsCochains.complex p G).d ((ComplexShape.up ℕ).prev (m + 1)) (m + 1))) =
          LinearMap.range (_root_.Erdos90.InhomogContsCochains.d p G m)
        rw [CochainComplex.prev_nat_succ]
        simp [_root_.Erdos90.InhomogContsCochains.complex]
        rfl
  have hbnd1 :
      LinearMap.range (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatToCycles) =
        (_root_.Erdos90.InhomogClassAPI.Coboundaries p G n).comap B.subtype := by
    change LinearMap.range (((((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).f.hom).codRestrict B ?_)) =
      (_root_.Erdos90.InhomogClassAPI.Coboundaries p G n).comap B.subtype
    rw [LinearMap.range_codRestrict]

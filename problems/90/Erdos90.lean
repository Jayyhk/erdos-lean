    simpa [g] using hκ.fourier_continuous.integrable_of_hasCompactSupport hκ.fourier_compact
  refine ⟨∫ y : ℝ, ‖g y‖, ?_, ?_⟩
  · exact MeasureTheory.integral_nonneg fun y => norm_nonneg _
  · intro x
    have hx : FourierTransformInv.fourierInv g x = κ x := by
      simpa [g] using
        MeasureTheory.Integrable.fourierInv_fourier_eq hκ.integrable hg_int
          (hκ.continuous.continuousAt)
    rw [← hx, Real.fourierInv_eq]
    calc
      ‖∫ v : ℝ, Real.fourierChar (inner ℝ v x) • g v‖ ≤ ∫ v : ℝ, ‖Real.fourierChar (inner ℝ v x) • g v‖ :=
        MeasureTheory.norm_integral_le_integral_norm _
      _ = ∫ v : ℝ, ‖g v‖ := by
        congr with v
        simp


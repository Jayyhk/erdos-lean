    simp [hvanish вҹЁn, hnвҹ©]
  let ПҶq : G в§ё N вҶ’* Multiplicative (ZMod p) := QuotientGroup.lift N ПҶcts.toMonoidHom hNker
  have hcont_comp : Continuous (ПҶq вҲҳ QuotientGroup.mk) := by
    simpa [ПҶq, Function.comp] using ПҶcts.continuous_toFun
  have hcont_q : Continuous ПҶq := by
    exact (QuotientGroup.isOpenQuotientMap_mk (N := N)).continuous_comp_iff.mp hcont_comp
  let ПҲbar : Additive (G в§ё N) вҶ’вӮң+ ZMod p :=
    { toFun := fun q => (ПҶq q.toMul).toAdd
      map_zero' := by simp [ПҶq]
      map_add' := by
        intro a b
        simp [ПҶq.map_mul]
      continuous_toFun := by
        exact hcont_q }
  let y : (H p 1 (G в§ё N) : Type) := (e (G в§ё N)).symm ПҲbar
  let qAdd : Additive G вҶ’вӮң+ Additive (G в§ё N) :=
    { toFun := fun g => Additive.ofMul ((QuotientGroup.mk' N) g.toMul)
      map_zero' := by simp
      map_add' := by intro a b; simp
      continuous_toFun := by
        change Continuous (fun g : G => Additive.ofMul ((QuotientGroup.mk' N) g))
        simpa using QuotientGroup.continuous_mk }
  have hcompq : ПҲbar.comp qAdd = ПҲcts := by
    ext g
    change (ПҶq ((QuotientGroup.mk' N) g.toMul)).toAdd = ПҲcts g
    simp [ПҶq, QuotientGroup.lift_mk, ПҶcts]
  have hE : e G ((inflation p G N 1).hom y) = ПҲcts := by
    have hnatInf :=
      he_nat (G1 := G) (G2 := G в§ё N) (QuotientGroup.mk' N) QuotientGroup.continuous_mk y
    rw [show e (G в§ё N) y = ПҲbar by simp [y]] at hnatInf
    simpa [inflation, qAdd] using hnatInf.trans hcompq
  have hy : (inflation p G N 1).hom y = x := by
    exact (e G).injective (by simpa [ПҲcts] using hE)
  simp only [LinearMap.mem_range]
  exact вҹЁy, hyвҹ©


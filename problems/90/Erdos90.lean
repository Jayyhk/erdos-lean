theorem exists_ramified_inertia_generators_rel_discr (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (e : (M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3))
    (_hfin : Module.finrank в„ҡ M = 3 ^ в„“)
    (_hdisc : (NumberField.discr M).natAbs = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1))) :
    вҲғ Пғ : Fin в„“ вҶ’ (M вүғвӮҗ[в„ҡ] M),
      вҲҖ i, вҲғ P : Ideal (рқ“һ M),
        P вҲҲ (Ideal.span {(r i : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M) вҲ§
        Nat.card (P.inertia (M вүғвӮҗ[в„ҡ] M)) = 3 вҲ§
        Пғ i вҲҲ P.inertia (M вүғвӮҗ[в„ҡ] M) вҲ§
        Пғ i вү  1 := by
  classical
  have hGcard : Nat.card (M вүғвӮҗ[в„ҡ] M) = 3 ^ в„“ := by
    rw [IsGalois.card_aut_eq_finrank в„ҡ M, _hfin]
  have hExistsFor : вҲҖ i : Fin в„“, вҲғ Пғi : (M вүғвӮҗ[в„ҡ] M), вҲғ P : Ideal (рқ“һ M),
      P вҲҲ (Ideal.span {(r i : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M) вҲ§
      Nat.card (P.inertia (M вүғвӮҗ[в„ҡ] M)) = 3 вҲ§
      Пғi вҲҲ P.inertia (M вүғвӮҗ[в„ҡ] M) вҲ§ Пғi вү  1 := by
    intro i
    let p : Ideal в„Ө := Ideal.span {(r i : в„Ө)}
    have hpmax : p.IsMaximal := by
      dsimp [p]
      letI : Fact (Nat.Prime (r i)) := вҹЁ_hr_prime iвҹ©

      _ = вҲ« u in (-(1 / 2 : в„қ))..(1 / 2 : в„қ), C * K u := by
            convert (intervalIntegral.integral_comp_sub_left (f := fun u : в„қ => C * K u)
              (a := (0 : в„қ)) (b := 1) (d := (1 / 2 : в„қ))) using 1

      change e' (((AlgEquiv.autCongr e'.symm) (ПҲ Пғ)) x) = (ПҲ Пғ) (e' x)
      simp [AlgEquiv.trans_apply]
    change N'.val (e' ((ПҶ Пғ : M вүғвӮҗ[F] M) x)) =
        (show (maximalUnramifiedProPF F p) вүғвӮҗ[F] (maximalUnramifiedProPF F p) from Пғ)
          (N'.val (e' x))
    rw [hconj]
    simpa [ПҲ] using
      (AlgEquiv.restrictNormalHom_apply (F := F) (KвӮҒ := maximalUnramifiedProPF F p) N' Пғ (e' x))

theorem finiteIntermediate_lift_le_finsetSup (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)] (L : IntermediateField F (maximalUnramifiedProPF F p)) [FiniteDimensional F L] : вҲғ s : Finset (maximalUnramifiedProPFIndex F p), IntermediateField.lift L вүӨ (вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  let I := maximalUnramifiedProPFIndex F p
  have hFG : L.FG := by
    simpa using
      (IntermediateField.essFiniteType_iff (F := F) (E := maximalUnramifiedProPF F p)
        (K := L)).mp (inferInstance : Algebra.EssFiniteType F L)
  have hx_all :
      вҲҖ x : maximalUnramifiedProPF F p,
        вҲғ t : Finset I,
          (x : AlgebraicClosure F) вҲҲ
            (вЁҶ i вҲҲ t, i.M : IntermediateField F (AlgebraicClosure F)) := by
    intro x
    have hx :
        (x : AlgebraicClosure F) вҲҲ
          (вЁҶ i : I, i.M : IntermediateField F (AlgebraicClosure F)) := by
      simpa [MaxUnramifiedProPGaloisGroup.maximalUnramifiedProPF_eq_iSup_index
        (F := F) (p := p)] using x.2
    exact IntermediateField.exists_finset_of_mem_iSup hx
  choose t ht using hx_all
  obtain вҹЁu, huвҹ© := hFG
  refine вҹЁu.biUnion t, ?_вҹ©
  rw [вҶҗ hu, IntermediateField.lift_adjoin]
  rw [IntermediateField.adjoin_le_iff]
  rintro _ вҹЁx, hx, rflвҹ©
  exact SetLike.le_def.mp
    (iSupвӮӮ_le fun i hi => le_iSup_of_le i <| le_iSup_of_le ((Finset.subset_biUnion_of_mem t hx) hi) le_rfl)
    (ht x)

theorem finsetSup_isGalois (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)] (s : Finset (maximalUnramifiedProPFIndex F p)) : IsGalois F вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  refine Finset.induction_on s ?_ ?_
  В· by_cases h : Nonempty (maximalUnramifiedProPFIndex F p)
    В· haveI := h
      have hempty : (вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = вҠҘ := by
        simp only [Finset.notMem_empty, iSup_false, iSup_const]
      rw [hempty]
      simpa using (isGalois_bot (F := F) (E := AlgebraicClosure F))
    В· haveI : IsEmpty (maximalUnramifiedProPFIndex F p) := not_nonempty_iff.mp h
      have hempty : (вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = вҠҘ := by
        rw [show (вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)), i.M : IntermediateField F (AlgebraicClosure F)) = вЁҶ i : maximalUnramifiedProPFIndex F p, вЁҶ _ : i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)), i.M by rfl]
        rw [iSup_of_empty]
      rw [hempty]
      simpa using (isGalois_bot (F := F) (E := AlgebraicClosure F))
  В· intro i s his ih
    rw [Finset.iSup_insert]
    let Ks : IntermediateField F (AlgebraicClosure F) := вЁҶ j вҲҲ s, j.M
    haveI : IsGalois F вҶҘKs := by
      simpa [Ks] using ih
    haveI : IsGalois F вҶҘi.M := i.hg
    simpa [Ks] using (inferInstance : IsGalois F вҶҘ(i.M вҠ” Ks))

theorem fixedField_openNormal_finiteGalois (k : Type) [Field k] (K : Type) [Field K] [Algebra k K] [IsGalois k K] (N : OpenNormalSubgroup (Gal(K/k))) : FiniteDimensional k (IntermediateField.fixedField (N : Subgroup Gal(K/k))) вҲ§ IsGalois k (IntermediateField.fixedField (N : Subgroup Gal(K/k))) := by
  let H : ClosedSubgroup (Gal(K/k)) :=
    { toSubgroup := (N : Subgroup Gal(K/k))
      isClosed' := by
        simpa using N.isClosed }
  let L := IntermediateField.fixedField (H : Subgroup Gal(K/k))
  have hfix : L.fixingSubgroup = (N : Subgroup Gal(K/k)) := by
    simpa [L] using InfiniteGalois.fixingSubgroup_fixedField (k := k) (K := K) H
  have hopen : IsOpen (L.fixingSubgroup : Set (Gal(K/k))) := by
    simpa [hfix] using N.toOpenSubgroup.isOpen
  have hnormal : (L.fixingSubgroup : Subgroup Gal(K/k)).Normal := by
    simpa [hfix] using (show (N : Subgroup Gal(K/k)).Normal from inferInstance)
  have h :=
    (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := k) (K := K) (L := L)).mp
      вҹЁhopen, hnormalвҹ©
  simpa [L] using h

theorem localUnramified_diffTop (F M : Type) [Field F] [Field M] [NumberField F] [NumberField M] [Algebra F M] (hfin : вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (рқ”“ : Ideal (рқ“һ M)), рқ”ӯ.IsPrime вҶ’ рқ”ӯ вү  вҠҘ вҶ’ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ M) вҶ’ Ideal.ramificationIdx рқ”ӯ рқ”“ = 1) : differentIdeal (рқ“һ F) (рқ“һ M) = (вҠӨ : Ideal (рқ“һ M)) := by
  by_contra htop
  obtain вҹЁP, hPmax, hleвҹ© := Ideal.exists_le_maximal (differentIdeal (рқ“һ F) (рқ“һ M)) htop
  letI : P.IsMaximal := hPmax
  letI : P.IsPrime := hPmax.isPrime
  have hpmax : (P.under (рқ“һ F)).IsMaximal :=
    Ideal.isMaximal_comap_of_isIntegral_of_isMaximal (R := рқ“һ F) (S := рқ“һ M) P
  have hpne : (P.under (рқ“һ F)) вү  вҠҘ :=
    Ring.ne_bot_of_isMaximal_of_not_isField hpmax (NumberField.RingOfIntegers.not_isField F)
  have hP_over : P вҲҲ (P.under (рқ“һ F)).primesOver (рқ“һ M) := by
    exact вҹЁinferInstance, inferInstanceвҹ©
  have he : Ideal.ramificationIdx (P.under (рқ“һ F)) P = 1 :=
    hfin (P.under (рқ“һ F)) P (Ideal.IsMaximal.isPrime hpmax) hpne hP_over
  have hPne : P вү  вҠҘ :=
    Ring.ne_bot_of_isMaximal_of_not_isField hPmax (NumberField.RingOfIntegers.not_isField M)
  have hunram : Algebra.IsUnramifiedAt (рқ“һ F) P :=
    (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := рқ“һ F) (S := рқ“һ M) (p := P) hPne).2 <| by
      simpa using he
  have hnotdvd : В¬ P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M) :=
    (not_dvd_differentIdeal_iff (A := рқ“һ F) (B := рқ“һ M) (P := P)).2 hunram
  have hdvd : P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M) := by
    simpa [Ideal.dvd_iff_le] using hle
  exact hnotdvd hdvd

theorem openNormalChain (Q0 : Type) [Group Q0] [TopologicalSpace Q0] [IsTopologicalGroup Q0] [T2Space Q0] [CompactSpace Q0] [TotallyDisconnectedSpace Q0] [Infinite Q0] : вҲғ U : в„• вҶ’ OpenNormalSubgroup Q0, ((U 0 : Subgroup Q0) = вҠӨ) вҲ§ (вҲҖ j, U (j + 1) вүӨ U j) вҲ§ Filter.Tendsto (fun j => Nat.card (Q0 в§ё (U j).toSubgroup)) Filter.atTop Filter.atTop := by
  classical
  let e : в„• вҶӘ Q0 := Infinite.natEmbedding Q0
  let bad : в„• вҶ’ Finset Q0 := fun n =>
    ((((Finset.univ : Finset (Fin (n + 1))).product Finset.univ).filter
      (fun p : Fin (n + 1) Г— Fin (n + 1) => p.1 вү  p.2)).image
      (fun p => (e p.1)вҒ»В№ * e p.2))
  have hbad_one : вҲҖ n, (1 : Q0) вҲү bad n := by
    intro n h1
    rcases Finset.mem_image.mp h1 with вҹЁp, hp, hp1вҹ©
    have hpne : p.1 вү  p.2 := (Finset.mem_filter.mp hp).2
    have heq : e p.1 = e p.2 := by
      exact inv_mul_eq_one.mp hp1
    exact hpne (Fin.ext (e.injective heq))
  let H : в„• вҶ’ OpenNormalSubgroup Q0 := fun n =>
    Classical.choose <|
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one
        (U := (bad n : Set Q0)б¶ң)
        ((bad n).isClosed.isOpen_compl)
        (by
          change (1 : Q0) вҲү bad n
          exact hbad_one n)
  have hHsub : вҲҖ n, ((H n : Set Q0) вҠҶ (bad n : Set Q0)б¶ң) := by
    intro n
    exact Classical.choose_spec <|
      ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one
        (U := (bad n : Set Q0)б¶ң)
        ((bad n).isClosed.isOpen_compl)
        (by
          change (1 : Q0) вҲү bad n
          exact hbad_one n)
  let topON : OpenNormalSubgroup Q0 :=
    { toOpenSubgroup := вҠӨ
      isNormal' := Subgroup.normal_top }
  let U : в„• вҶ’ OpenNormalSubgroup Q0 := Nat.rec topON (fun n Un => Un вҠ“ H n)
  have hsize : вҲҖ n, n + 1 вүӨ Nat.card (Q0 в§ё (U (n + 1)).toSubgroup) := by
    intro n
    let f : Fin (n + 1) вҶ’ Q0 в§ё (U (n + 1)).toSubgroup := fun i => QuotientGroup.mk (e i)
    have hf : Function.Injective f := by
      intro i j hij
      by_contra hne
      have hmemU : (e i)вҒ»В№ * e j вҲҲ (U (n + 1) : Subgroup Q0) := by
        exact QuotientGroup.eq.mp hij
      have hmemH : (e i)вҒ»В№ * e j вҲҲ (H n : Subgroup Q0) := by
        have hle : U (n + 1) вүӨ H n := by
          change Nat.rec topON (fun n Un => Un вҠ“ H n) n вҠ“ H n вүӨ H n
          exact inf_le_right
        exact hle hmemU
      have hnotbad : (e i)вҒ»В№ * e j вҲү bad n := by
        simpa using hHsub n hmemH
      have hbadmem : (e i)вҒ»В№ * e j вҲҲ bad n := by
        apply Finset.mem_image.mpr
        refine вҹЁ(i, j), ?_, rflвҹ©
        exact Finset.mem_filter.mpr вҹЁby simp, hneвҹ©
      exact hnotbad hbadmem
    simpa [f, Nat.card_fin] using (Nat.card_le_card_of_injective f hf)
  have hbound : вҲҖ j, j вүӨ Nat.card (Q0 в§ё (U j).toSubgroup) := by
    intro j
    cases j with
    | zero => exact Nat.zero_le _
    | succ n => exact hsize n
  refine вҹЁU, ?_, ?_, ?_вҹ©
  В· change (topON : Subgroup Q0) = вҠӨ
    rfl
  В· intro j
    cases j with
    | zero =>
        change topON вҠ“ H 0 вүӨ topON
        exact inf_le_left
    | succ n =>
        change (Nat.rec topON (fun n Un => Un вҠ“ H n) (n + 1) вҠ“ H (n + 1)) вүӨ
          Nat.rec topON (fun n Un => Un вҠ“ H n) (n + 1)
        exact inf_le_left
  В· rw [Filter.tendsto_atTop_atTop]
    intro b
    refine вҹЁb, ?_вҹ©
    intro a ha
    exact le_trans ha (hbound a)

theorem restrict_mem_inertia (F : Type) [Field F] [NumberField F] (N : Type) [Field N] [Algebra F N] [NumberField N] [IsGalois F N] (K : IntermediateField F N) [NumberField K] [IsGalois F K] (рқ”“ : Ideal (рқ“һ N)) [рқ”“.IsPrime] (Пғ : Gal(N/F)) : Пғ вҲҲ Ideal.inertia (Gal(N/F)) рқ”“ вҶ’ AlgEquiv.restrictNormalHom K Пғ вҲҲ Ideal.inertia (Gal(K/F)) (рқ”“.comap (NumberField.RingOfIntegers.mapAlgHom K.val)) := by
  intro hПғ
  rw [AddSubgroup.mem_inertia] at hПғ вҠў
  intro x
  change NumberField.RingOfIntegers.mapAlgHom K.val (((AlgEquiv.restrictNormalHom K Пғ) вҖў x) - x) вҲҲ рқ”“
  rw [map_sub]
  have hcomm :
      NumberField.RingOfIntegers.mapAlgHom K.val (((AlgEquiv.restrictNormalHom K Пғ) вҖў x)) =
        Пғ вҖў (NumberField.RingOfIntegers.mapAlgHom K.val x) := by
    ext
    change K.val ((((AlgEquiv.restrictNormalHom K Пғ) вҖў x : рқ“һ K)) : K) =
      Пғ (K.val (x : K))
    simpa using AlgEquiv.restrictNormalHom_apply K Пғ (x : K)
  simpa [hcomm] using hПғ ((NumberField.RingOfIntegers.mapAlgHom K.val) x)

theorem subfield_isUnramified_of_le (F : Type) [Field F] [NumberField F] (L M : IntermediateField F (AlgebraicClosure F)) [NumberField L] [NumberField M] [IsGalois F L] (hLM : L вүӨ M) (hM : IsEverywhereUnramified F M) : IsEverywhereUnramified F L := by
  letI : Algebra L M := (IntermediateField.inclusion hLM).toAlgebra
  rcases hM with вҹЁhfinM, hinfMвҹ©
  have hfinL :
      вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (рқ”“ : Ideal (рқ“һ L)),
        рқ”ӯ.IsPrime вҶ’ рқ”ӯ вү  вҠҘ вҶ’ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ L) вҶ’ рқ”ӯ.ramificationIdx рқ”“ = 1 := by
    intro рқ”ӯ рқ”“ hp hne hP
    letI : рқ”ӯ.IsPrime := hp
    let P' : рқ”ӯ.primesOver (рқ“һ L) := вҹЁрқ”“, hPвҹ©
    letI : рқ”“.IsPrime := Ideal.primesOver.isPrime рқ”ӯ P'
    letI : рқ”“.LiesOver рқ”ӯ := Ideal.primesOver.liesOver рқ”ӯ P'
    obtain вҹЁQвҹ© := Ideal.nonempty_primesOver (R := рқ“һ L) (S := рқ“һ M) рқ”“
    letI : (Q : Ideal (рқ“һ M)).LiesOver рқ”“ := Ideal.primesOver.liesOver рқ”“ Q
    letI : (Q : Ideal (рқ“һ M)).LiesOver рқ”ӯ := Ideal.LiesOver.trans (рқ”“ := (Q : Ideal (рқ“һ M))) (P := рқ”“) (p := рқ”ӯ)
    have hQmem : (Q : Ideal (рқ“һ M)) вҲҲ рқ”ӯ.primesOver (рқ“һ M) :=
      (Ideal.primesOver.mk рқ”ӯ (Q : Ideal (рқ“һ M))).2
    have hQe : Ideal.ramificationIdx рқ”ӯ (Q : Ideal (рқ“һ M)) = 1 :=
      hfinM рқ”ӯ (Q : Ideal (рқ“һ M)) hp hne hQmem
    have hQne : (Q : Ideal (рқ“һ M)) вү  вҠҘ :=
      Ideal.ne_bot_of_liesOver_of_ne_bot hne (Q : Ideal (рқ“һ M))
    rw [Ideal.over_def (A := рқ“һ F) (P := (Q : Ideal (рқ“һ M))) (p := рқ”ӯ)] at hQe
    have hQunram : Algebra.IsUnramifiedAt (рқ“һ F) (Q : Ideal (рқ“һ M)) :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := рқ“һ F) (S := рқ“һ M) (p := (Q : Ideal (рқ“һ M))) hQne).2 hQe
    have hPunram : Algebra.IsUnramifiedAt (рқ“һ F) рқ”“ :=
      Algebra.IsUnramifiedAt.of_liesOver (R := рқ“һ F) (p := рқ”“) (P := (Q : Ideal (рқ“һ M)))
    have hPe : Ideal.ramificationIdx (Ideal.under (рқ“һ F) рқ”“) рқ”“ = 1 :=
      (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
        (R := рқ“һ F) (S := рқ“һ L) (p := рқ”“) (Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ”“)).1 hPunram
    simpa [Ideal.over_def (A := рқ“һ F) (P := рқ”“) (p := рқ”ӯ)] using hPe
  have hinfL :
      вҲҖ (w : InfinitePlace F), w.IsReal вҶ’
        вҲҖ (w' : InfinitePlace L), w'.comap (algebraMap F L) = w вҶ’ w'.IsReal := by
    intro w hw w' hw'
    obtain вҹЁw'', hw''вҹ© := InfinitePlace.comap_surjective (k := L) (K := M) w'
    have hw''F : (w''.comap (algebraMap L M)).comap (algebraMap F L) = w'.comap (algebraMap F L) := by
      simpa using congrArg (fun x => x.comap (algebraMap F L)) hw''
    have hwM : w''.comap (algebraMap F M) = w := by
      calc
        w''.comap (algebraMap F M) = w''.comap ((algebraMap L M).comp (algebraMap F L)) := by
          rw [IsScalarTower.algebraMap_eq F L M]
        _ = (w''.comap (algebraMap L M)).comap (algebraMap F L) := by
          rw [InfinitePlace.comap_comp]
        _ = w'.comap (algebraMap F L) := hw''F
        _ = w := hw'
    have hw''real : w''.IsReal := hinfM w hw w'' hwM
    have hw'real : (w''.comap (algebraMap L M)).IsReal :=
      NumberField.InfinitePlace.IsReal.comap (algebraMap L M) hw''real
    simpa [hw''] using hw'real
  exact IsEverywhereUnramified.of_local F L hfinL hinfL

theorem sup_real_lifts_real (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField вҶҘ(K вҠ” M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : вҲҖ (w : InfinitePlace F), w.IsReal вҶ’ вҲҖ (w' : InfinitePlace вҶҘ(K вҠ” M)), w'.comap (algebraMap F вҶҘ(K вҠ” M)) = w вҶ’ w'.IsReal := by
  set_option maxHeartbeats 600000 in
  intro w hw w' hw'
  let N : IntermediateField F (AlgebraicClosure F) := K вҠ” M
  let S : Set (AlgebraicClosure F) := (K вҲӘ M : Set (AlgebraicClosure F))
  have hN : N = IntermediateField.adjoin F S := by
    simpa [N, S] using (IntermediateField.sup_def K M)
  letI : Algebra K вҶҘN :=
    (IntermediateField.inclusion (show K вүӨ N by
      simp [N])).toAlgebra
  letI : IsScalarTower F K вҶҘN := IsScalarTower.of_algebraMap_eq' rfl
  letI : Algebra M вҶҘN :=
    (IntermediateField.inclusion (show M вүӨ N by
      simp [N])).toAlgebra
  letI : IsScalarTower F M вҶҘN := IsScalarTower.of_algebraMap_eq' rfl
  let vK : InfinitePlace K := w'.comap (algebraMap K вҶҘN)
  let vM : InfinitePlace M := w'.comap (algebraMap M вҶҘN)
  have hvKcomap : vK.comap (algebraMap F K) = w := by
    simpa [vK, N, IsScalarTower.algebraMap_eq F K вҶҘN] using hw'
  have hvMcomap : vM.comap (algebraMap F M) = w := by
    simpa [vM, N, IsScalarTower.algebraMap_eq F M вҶҘN] using hw'
  have hvKreal : vK.IsReal := hK.real_lifts_real w hw vK hvKcomap
  have hvMreal : vM.IsReal := hM.real_lifts_real w hw vM hvMcomap
  letI : Algebra F в„Ӯ := w.embedding.toAlgebra
  have hbase : w'.embedding.comp (algebraMap F вҶҘN) = w.embedding := by
    symm
    simpa [N, hw'] using
      (NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap F вҶҘN) (w := w')
        (by simpa [N, hw'] using hw))
  let ПҶ : вҶҘN вҶ’вӮҗ[F] в„Ӯ :=
    { toRingHom := w'.embedding
      commutes' := by
        intro x
        exact congrArg (fun f => f x) hbase }
  let ПҲ : вҶҘN вҶ’вӮҗ[F] в„Ӯ :=
    { toRingHom := NumberField.ComplexEmbedding.conjugate w'.embedding
      commutes' := by
        intro x
        have hbase_conj : (NumberField.ComplexEmbedding.conjugate w'.embedding).comp
            (algebraMap F вҶҘN) = w.embedding := by
          calc
            (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap F вҶҘN)
                = NumberField.ComplexEmbedding.conjugate (w'.embedding.comp (algebraMap F вҶҘN)) := by
                    rw [NumberField.ComplexEmbedding.conjugate_comp]
            _ = NumberField.ComplexEmbedding.conjugate w.embedding := by rw [hbase]
            _ = w.embedding := NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hw
        exact congrArg (fun f => f x) hbase_conj }
  have hgenK : вҲҖ x (hxK : x вҲҲ K),
      let hxS : x вҲҲ S := Or.inl hxK
      let xN : N := вҹЁx, hN.ge (IntermediateField.subset_adjoin F S hxS)вҹ©
      let xK : K := вҹЁx, hxKвҹ©
      ПҲ xN = ПҶ xN := by
    intro x hxK
    let hxS : x вҲҲ S := Or.inl hxK
    let xN : N := вҹЁx, hN.ge (IntermediateField.subset_adjoin F S hxS)вҹ©
    let xK : K := вҹЁx, hxKвҹ©
    have hkemb : vK.embedding = w'.embedding.comp (algebraMap K вҶҘN) :=
      NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap K вҶҘN) (w := w') hvKreal
    have hkemb_conj : NumberField.ComplexEmbedding.conjugate vK.embedding =
        (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap K вҶҘN) := by
      rw [hkemb, NumberField.ComplexEmbedding.conjugate_comp]
    have hkval : vK.embedding xK = w'.embedding xN := by
      simpa [xK, xN] using congrArg (fun f => f xK) hkemb
    have hkval_conj : (NumberField.ComplexEmbedding.conjugate vK.embedding) xK =
        (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := by
      simpa [xK, xN] using congrArg (fun f => f xK) hkemb_conj
    calc
      ПҲ xN = (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := rfl
      _ = (NumberField.ComplexEmbedding.conjugate vK.embedding) xK := by symm; exact hkval_conj
      _ = vK.embedding xK := by
        exact congrArg (fun f => f xK) (NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hvKreal)
      _ = w'.embedding xN := hkval
      _ = ПҶ xN := rfl
  have hgenM : вҲҖ x (hxM : x вҲҲ M),
      let hxS : x вҲҲ S := Or.inr hxM
      let xN : N := вҹЁx, hN.ge (IntermediateField.subset_adjoin F S hxS)вҹ©
      let xM : M := вҹЁx, hxMвҹ©
      ПҲ xN = ПҶ xN := by
    intro x hxM
    let hxS : x вҲҲ S := Or.inr hxM
    let xN : N := вҹЁx, hN.ge (IntermediateField.subset_adjoin F S hxS)вҹ©
    let xM : M := вҹЁx, hxMвҹ©
    have hmemb : vM.embedding = w'.embedding.comp (algebraMap M вҶҘN) :=
      NumberField.InfinitePlace.comap_embedding_of_isReal (f := algebraMap M вҶҘN) (w := w') hvMreal
    have hmemb_conj : NumberField.ComplexEmbedding.conjugate vM.embedding =
        (NumberField.ComplexEmbedding.conjugate w'.embedding).comp (algebraMap M вҶҘN) := by
      rw [hmemb, NumberField.ComplexEmbedding.conjugate_comp]
    have hmval : vM.embedding xM = w'.embedding xN := by
      simpa [xM, xN] using congrArg (fun f => f xM) hmemb
    have hmval_conj : (NumberField.ComplexEmbedding.conjugate vM.embedding) xM =
        (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := by
      simpa [xM, xN] using congrArg (fun f => f xM) hmemb_conj
    calc
      ПҲ xN = (NumberField.ComplexEmbedding.conjugate w'.embedding) xN := rfl
      _ = (NumberField.ComplexEmbedding.conjugate vM.embedding) xM := by symm; exact hmval_conj
      _ = vM.embedding xM := by
        exact congrArg (fun f => f xM) (NumberField.InfinitePlace.conjugate_embedding_eq_of_isReal hvMreal)
      _ = w'.embedding xN := hmval
      _ = ПҶ xN := rfl
  have hПҲПҶ : ПҲ = ПҶ := by
    refine IntermediateField.algHom_ext_of_eq_adjoin (F := F) (E := AlgebraicClosure F) (S := N)
      (K := в„Ӯ) hN ?_
    intro x hx
    rcases hx with hxK | hxM
    В· simpa [S] using hgenK x hxK
    В· simpa [S] using hgenM x hxM
  have hconj : NumberField.ComplexEmbedding.conjugate w'.embedding = w'.embedding := by
    simpa [ПҲ, ПҶ] using congrArg (fun f : вҶҘN вҶ’вӮҗ[F] в„Ӯ => (f : вҶҘN вҶ’+* в„Ӯ)) hПҲПҶ
  exact NumberField.InfinitePlace.isReal_iff.mpr <|
    NumberField.ComplexEmbedding.isReal_iff.mpr hconj

theorem unramified_inertia_card_one (F : Type) [Field F] [NumberField F] (K : Type) [Field K] [Algebra F K] [NumberField K] [FiniteDimensional F K] [IsGalois F K] (hK : IsEverywhereUnramified F K) (рқ”ӯ : Ideal (рқ“һ F)) (рқ”“ : Ideal (рқ“һ K)) [рқ”“.IsPrime] (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ) (hрқ”“ : рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ K)) : Nat.card (Ideal.inertia (Gal(K/F)) рқ”“) = 1 := by
  letI : рқ”ӯ.IsMaximal := hp.isMaximal hne
  letI : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
  have hP_ne : рқ”“ вү  вҠҘ := Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ”“
  letI : рқ”“.IsMaximal := hрқ”“.1.isMaximal hP_ne
  have hunder : Ideal.under (рқ“һ F) рқ”“ = рқ”ӯ := by
    simpa using (Ideal.over_def (A := рқ“һ F) (P := рқ”“) (p := рқ”ӯ)).symm
  haveI : Algebra.IsUnramifiedAt (рқ“һ F) рқ”“ :=
    (Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := рқ“һ F) (S := рқ“һ K) (p := рқ”“)
      hP_ne).2 <| by
        simpa [hunder] using hK.unramified_at_finite рқ”ӯ рқ”“ hp hne hрқ”“
  calc
    Nat.card (Ideal.inertia (Gal(K/F)) рқ”“)
        = рқ”ӯ.ramificationIdxIn (рқ“һ K) := by
            simpa using Ideal.card_inertia_eq_ramificationIdxIn (G := Gal(K/F)) рқ”ӯ hne рқ”“
    _ = Ideal.ramificationIdx рқ”ӯ рқ”“ := by
            simpa using Ideal.ramificationIdxIn_eq_ramificationIdx (p := рқ”ӯ) (P := рқ”“) (G := Gal(K/F))
    _ = 1 := hK.unramified_at_finite рқ”ӯ рқ”“ hp hne hрқ”“

theorem sup_unramified_at_finite (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField вҶҘ(K вҠ” M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : вҲҖ (рқ”ӯ : Ideal (рқ“һ F)) (рқ”“ : Ideal (рқ“һ вҶҘ(K вҠ” M))), рқ”ӯ.IsPrime вҶ’ рқ”ӯ вү  вҠҘ вҶ’ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘ(K вҠ” M)) вҶ’ Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := by
  intro рқ”ӯ рқ”“ hp hne hрқ”“
  let N : IntermediateField F (AlgebraicClosure F) := K вҠ” M
  let K' : IntermediateField F вҶҘN := IntermediateField.restrict (show K вүӨ N by exact le_sup_left)
  let M' : IntermediateField F вҶҘN := IntermediateField.restrict (show M вүӨ N by exact le_sup_right)
  let eK : K вүғвӮҗ[F] вҶҘK' := IntermediateField.restrict_algEquiv (show K вүӨ N by exact le_sup_left)
  let eM : M вүғвӮҗ[F] вҶҘM' := IntermediateField.restrict_algEquiv (show M вүӨ N by exact le_sup_right)
  haveI : IsGalois F вҶҘN := by infer_instance
  haveI : IsGalois F вҶҘK' := IsGalois.of_algEquiv eK
  haveI : IsGalois F вҶҘM' := IsGalois.of_algEquiv eM
  haveI : FiniteDimensional F вҶҘN := by infer_instance
  haveI : FiniteDimensional F вҶҘK' := by infer_instance
  haveI : FiniteDimensional F вҶҘM' := by infer_instance
  have hK' : IsEverywhereUnramified F вҶҘK' := IsEverywhereUnramified.transport eK hK
  have hM' : IsEverywhereUnramified F вҶҘM' := IsEverywhereUnramified.transport eM hM
  let OK : (рқ“һ вҶҘK') вҶ’вӮҗ[рқ“һ F] (рқ“һ вҶҘN) := NumberField.RingOfIntegers.mapAlgHom K'.val
  let OM : (рқ“һ вҶҘM') вҶ’вӮҗ[рқ“һ F] (рқ“һ вҶҘN) := NumberField.RingOfIntegers.mapAlgHom M'.val
  let PK : Ideal (рқ“һ вҶҘK') := рқ”“.comap OK
  let PM : Ideal (рқ“һ вҶҘM') := рқ”“.comap OM
  letI : рқ”“.IsPrime := hрқ”“.1
  have hPK : PK вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘK') := by
    change (рқ”“.comap OK).IsPrime вҲ§ (рқ”“.comap OK).LiesOver рқ”ӯ
    refine вҹЁIdeal.IsPrime.comap (f := OK), ?_вҹ©
    letI : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
    simpa [PK, OK] using (Ideal.comap_liesOver (Q := рқ”“) (p := рқ”ӯ) OK)
  have hPM : PM вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘM') := by
    change (рқ”“.comap OM).IsPrime вҲ§ (рқ”“.comap OM).LiesOver рқ”ӯ
    refine вҹЁIdeal.IsPrime.comap (f := OM), ?_вҹ©
    letI : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
    simpa [PM, OM] using (Ideal.comap_liesOver (Q := рқ”“) (p := рқ”ӯ) OM)
  letI : PK.IsPrime := hPK.1
  letI : PM.IsPrime := hPM.1
  have hsup' : K' вҠ” M' = (вҠӨ : IntermediateField F вҶҘN) := by
    apply (IntermediateField.lift_injective N)
    rw [IntermediateField.lift_sup]
    rw [show IntermediateField.lift K' = K by
      simp [K']]
    rw [show IntermediateField.lift M' = M by
      simp [M']]
    rw [IntermediateField.lift_top]
  set_option maxHeartbeats 800000 in
  have hInertia_eq_bot : Ideal.inertia (Gal(вҶҘN/F)) рқ”“ = вҠҘ := by
    apply Subgroup.ext
    intro Пғ
    constructor
    В· intro hПғ
      have hПғK : AlgEquiv.restrictNormalHom K' Пғ вҲҲ Ideal.inertia (Gal(вҶҘK'/F)) PK := by
        exact restrict_mem_inertia (F := F) (N := вҶҘN) (K := K') (рқ”“ := рқ”“) (Пғ := Пғ) hПғ
      have hПғM : AlgEquiv.restrictNormalHom M' Пғ вҲҲ Ideal.inertia (Gal(вҶҘM'/F)) PM := by
        exact restrict_mem_inertia (F := F) (N := вҶҘN) (K := M') (рқ”“ := рқ”“) (Пғ := Пғ) hПғ
      have hcardK : Nat.card (Ideal.inertia (Gal(вҶҘK'/F)) PK) = 1 :=
        unramified_inertia_card_one (F := F) (K := вҶҘK') hK' рқ”ӯ PK hp hne hPK
      have hcardM : Nat.card (Ideal.inertia (Gal(вҶҘM'/F)) PM) = 1 :=
        unramified_inertia_card_one (F := F) (K := вҶҘM') hM' рқ”ӯ PM hp hne hPM
      have hbotK : Ideal.inertia (Gal(вҶҘK'/F)) PK = вҠҘ :=
        (Subgroup.card_eq_one).1 hcardK
      have hbotM : Ideal.inertia (Gal(вҶҘM'/F)) PM = вҠҘ :=
        (Subgroup.card_eq_one).1 hcardM
      have hresK : AlgEquiv.restrictNormalHom K' Пғ = 1 := by
        have : AlgEquiv.restrictNormalHom K' Пғ вҲҲ (вҠҘ : Subgroup Gal(вҶҘK'/F)) := by
          simpa [hbotK] using hПғK
        simpa using this
      have hresM : AlgEquiv.restrictNormalHom M' Пғ = 1 := by
        have : AlgEquiv.restrictNormalHom M' Пғ вҲҲ (вҠҘ : Subgroup Gal(вҶҘM'/F)) := by
          simpa [hbotM] using hПғM
        simpa using this
      have hfixK : Пғ вҲҲ K'.fixingSubgroup := by
        rw [IntermediateField.mem_fixingSubgroup_iff]
        intro x hx
        simpa [hresK] using (AlgEquiv.restrictNormalHom_apply K' Пғ вҹЁx, hxвҹ©).symm
      have hfixM : Пғ вҲҲ M'.fixingSubgroup := by
        rw [IntermediateField.mem_fixingSubgroup_iff]
        intro x hx
        simpa [hresM] using (AlgEquiv.restrictNormalHom_apply M' Пғ вҹЁx, hxвҹ©).symm
      have hfixSup : Пғ вҲҲ (K' вҠ” M').fixingSubgroup := by
        rw [IntermediateField.fixingSubgroup_sup]
        exact вҹЁhfixK, hfixMвҹ©
      have hПғ1 : Пғ = 1 := by
        have : Пғ вҲҲ (вҠӨ : IntermediateField F вҶҘN).fixingSubgroup := by
          simpa [hsup'] using hfixSup
        simpa [IntermediateField.fixingSubgroup_top, Subgroup.mem_bot] using this
      simp [Subgroup.mem_bot, hПғ1]
    В· intro hПғ
      rw [Subgroup.mem_bot] at hПғ
      simp [hПғ]
  letI : рқ”ӯ.IsMaximal := hp.isMaximal hne
  letI : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
  have hP_ne : рқ”“ вү  вҠҘ := Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ”“
  letI : рқ”“.IsMaximal := hрқ”“.1.isMaximal hP_ne
  letI : Field (рқ“һ F в§ё рқ”ӯ) := Ideal.Quotient.field рқ”ӯ
  letI : Field (рқ“һ вҶҘN в§ё рқ”“) := Ideal.Quotient.field рқ”“
  haveI : Module.Finite (рқ“һ F в§ё рқ”ӯ) (рқ“һ вҶҘN в§ё рқ”“) :=
    module_finite_of_liesOver (A := рқ“һ F) (B := рқ“һ вҶҘN) (p := рқ”ӯ) (P := рқ”“)
  haveI : Algebra.IsAlgebraic (рқ“һ F в§ё рқ”ӯ) (рқ“һ вҶҘN в§ё рқ”“) :=
    Algebra.IsAlgebraic.of_finite (R := рқ“һ F в§ё рқ”ӯ) (A := рқ“һ вҶҘN в§ё рқ”“)
  haveI : Finite (рқ“һ F в§ё рқ”ӯ) := by infer_instance
  letI : PerfectField (рқ“һ F в§ё рқ”ӯ) := PerfectField.ofFinite (K := рқ“һ F в§ё рқ”ӯ)
  haveI : Algebra.IsSeparable (рқ“һ F в§ё рқ”ӯ) (рқ“һ вҶҘN в§ё рқ”“) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hCardN : Nat.card (Ideal.inertia (Gal(вҶҘN/F)) рқ”“) = 1 := by
    rw [hInertia_eq_bot]
    exact (Subgroup.card_eq_one).2 rfl
  calc
    Ideal.ramificationIdx рқ”ӯ рқ”“ = рқ”ӯ.ramificationIdxIn (рқ“һ вҶҘN) := by
      symm
      simpa using Ideal.ramificationIdxIn_eq_ramificationIdx (p := рқ”ӯ) (P := рқ”“) (G := Gal(вҶҘN/F))
    _ = Nat.card (Ideal.inertia (Gal(вҶҘN/F)) рқ”“) := by
      symm
      simpa using Ideal.card_inertia_eq_ramificationIdxIn (G := Gal(вҶҘN/F)) рқ”ӯ hne рқ”“
    _ = 1 := hCardN

theorem sup_isUnramified (F : Type) [Field F] [NumberField F] (K M : IntermediateField F (AlgebraicClosure F)) [NumberField K] [NumberField M] [NumberField вҶҘ(K вҠ” M)] [IsGalois F K] [IsGalois F M] (hK : IsEverywhereUnramified F K) (hM : IsEverywhereUnramified F M) : IsEverywhereUnramified F вҶҘ(K вҠ” M) := by
  let N : IntermediateField F (AlgebraicClosure F) := K вҠ” M
  refine IsEverywhereUnramified.of_local F вҶҘN ?_ ?_
  В· intro рқ”ӯ рқ”“ hp hne hрқ”“
    simpa [N] using sup_unramified_at_finite F K M hK hM рқ”ӯ рқ”“ hp hne hрқ”“
  В· intro w hw w' hw'
    simpa [N] using sup_real_lifts_real F K M hK hM w hw w' hw'

theorem finsetSup_isUnramified (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)] (s : Finset (maximalUnramifiedProPFIndex F p)) [NumberField вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F))] : IsEverywhereUnramified F вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F)) := by
  classical
  let P : Finset (maximalUnramifiedProPFIndex F p) вҶ’ Prop :=
    fun s =>
      вҲҖ [_inst : NumberField вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F))],
        IsEverywhereUnramified F вҶҘ(вЁҶ i вҲҲ s, i.M : IntermediateField F (AlgebraicClosure F))
  have hP : вҲҖ s : Finset (maximalUnramifiedProPFIndex F p), P s := by
    intro s
    induction s using Finset.induction_on with
    | empty =>
        intro _inst
        haveI : NumberField вҶҘ(вҠҘ : IntermediateField F (AlgebraicClosure F)) := by
          simpa using (NumberField.of_ringEquiv (K := F)
            (L := вҶҘ(вҠҘ : IntermediateField F (AlgebraicClosure F)))
            ((IntermediateField.botEquiv F (AlgebraicClosure F)).symm.toRingEquiv))
        have hFF : IsEverywhereUnramified F F := by
          refine IsEverywhereUnramified.of_local F F ?_ ?_
          В· intro рқ”ӯ рқ”“ hp hne hрқ”“
            have hPeq : рқ”“ = рқ”ӯ := by
              haveI : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
              simpa using (Ideal.over_def рқ”“ рқ”ӯ).symm
            rw [hPeq]
            have hram : Ideal.ramificationIdx рқ”ӯ (Ideal.map (algebraMap (рқ“һ F) (рқ“һ F)) рқ”ӯ) = 1 := by
              exact Ideal.ramificationIdx_map_self_eq_one (R := рқ“һ F) (S := рқ“һ F) (p := рқ”ӯ)
                (by simpa using hp.ne_top) (by simpa using hne)
            simpa using hram
          В· intro w hw w' hw'
            have hw'' : w'.comap (RingHom.id F) = w := by
              simpa using hw'
            cases hw''
            simpa using hw
        have hbot : IsEverywhereUnramified F вҶҘ(вҠҘ : IntermediateField F (AlgebraicClosure F)) :=
          IsEverywhereUnramified.transport
            ((IntermediateField.botEquiv F (AlgebraicClosure F)).symm) hFF
        have hEmpty : (вҠҘ : IntermediateField F (AlgebraicClosure F)) =
            вЁҶ i вҲҲ (вҲ… : Finset (maximalUnramifiedProPFIndex F p)),
              i.M := by
          simp
        exact IsEverywhereUnramified.transport (IntermediateField.equivOfEq hEmpty) hbot
    | @insert i s his ih =>
        intro _inst
        let Ks : IntermediateField F (AlgebraicClosure F) :=
          вЁҶ j вҲҲ s, j.M
        letI : FiniteDimensional F i.M := i.hfd
        letI : NumberField i.M := i.hnf
        haveI : FiniteDimensional F вҶҘKs :=
          IntermediateField.finiteDimensional_iSup_of_finset' (t := fun j : maximalUnramifiedProPFIndex F p => j.M)
            (s := s) (by intro j hj; exact j.hfd)
        haveI : FiniteDimensional F вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) :=
          IntermediateField.finiteDimensional_sup (E1 := i.M) (E2 := Ks)
        letI : Module.Finite F вҶҘKs := show Module.Finite F вҶҘKs from inferInstance
        letI : NumberField вҶҘKs := NumberField.of_module_finite F вҶҘKs
        letI : Module.Finite F вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) :=
          show Module.Finite F вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) from inferInstance
        letI : NumberField вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) :=
          NumberField.of_module_finite F вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F))
        haveI : IsGalois F i.M := i.hg
        haveI : IsGalois F вҶҘKs := finsetSup_isGalois (F := F) (p := p) (s := s)
        have hKs : IsEverywhereUnramified F вҶҘKs := by
          simpa [Ks] using (ih : IsEverywhereUnramified F вҶҘ(вЁҶ j вҲҲ s, j.M : IntermediateField F (AlgebraicClosure F)))
        have hi : IsEverywhereUnramified F i.M := i.hunr
        have hSup : IsEverywhereUnramified F вҶҘ(i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) :=
          sup_isUnramified (F := F) (K := i.M) (M := Ks) hi hKs
        have hInsert : (i.M вҠ” Ks : IntermediateField F (AlgebraicClosure F)) =
            вЁҶ j вҲҲ insert i s, j.M := by
          simpa [Ks] using (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M)).symm
        exact IsEverywhereUnramified.transport (IntermediateField.equivOfEq hInsert) hSup
  exact hP s

theorem finiteIntermediate_isUnramified (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)] (L : IntermediateField F (maximalUnramifiedProPF F p)) [FiniteDimensional F L] [NumberField L] [IsGalois F L] : IsEverywhereUnramified F L := by
  classical
  let L0 : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift L
  let e : L вүғвӮҗ[F] L0 := IntermediateField.liftAlgEquiv L
  letI : FiniteDimensional F L0 := e.toLinearEquiv.finiteDimensional
  letI : Module.Finite F L0 := show Module.Finite F L0 from inferInstance
  haveI : NumberField L0 := NumberField.of_module_finite F L0
  letI : IsGalois F L0 := IsGalois.of_algEquiv (IntermediateField.liftAlgEquiv L)
  obtain вҹЁs, hsвҹ© := finiteIntermediate_lift_le_finsetSup (F := F) (p := p) (L := L)
  let Ms : IntermediateField F (AlgebraicClosure F) := вЁҶ i вҲҲ s, i.M
  have hs' : L0 вүӨ Ms := by
    simpa [L0, Ms] using hs
  haveI : FiniteDimensional F Ms := by
    simpa [Ms] using
      (IntermediateField.finiteDimensional_iSup_of_finset'
        (K := F)
        (t := fun i : maximalUnramifiedProPFIndex F p => i.M)
        (s := s)
        (h := fun i _ => i.hfd))
  letI : Module.Finite F Ms := show Module.Finite F Ms from inferInstance
  haveI : NumberField Ms := NumberField.of_module_finite F Ms
  have hMs : IsEverywhereUnramified F Ms :=
    finsetSup_isUnramified (F := F) (p := p) (s := s)
  have hL0 : IsEverywhereUnramified F L0 :=
    subfield_isUnramified_of_le (F := F) (L := L0) (M := Ms) hs' hMs
  exact IsEverywhereUnramified.transport (IntermediateField.liftAlgEquiv L).symm hL0

theorem cft_D2_infiniteQuotientTower (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (Q : ProPQuotient p (MaxUnramifiedProPGaloisGroup F p))

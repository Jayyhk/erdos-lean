  have hcenter_top : Subgroup.center (Q в§ё M) = вҠӨ := (hquot_bot_or_top _).resolve_left hcenter_ne_bot
  letI : CommGroup (Q в§ё M) := Group.commGroupOfCenterEqTop hcenter_top
  have hsimple : IsSimpleGroup (Q в§ё M) := by

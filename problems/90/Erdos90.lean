theorem inflation_transgression_apply_eq (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N))
    (hω : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G
      (inflatedSchreier2Cocycle p G N hN χ)) :
    (inflation p G N 2).hom.toLinearMap (transgression p G N hN χ) =
      (_root_.Erdos90.InhomogHomogIso.cohomologyIso p G 2)
        (_root_.Erdos90.InhomogClassAPI.classMap p G 2
          (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G
            (inflatedSchreier2Cocycle p G N hN χ) hω)) := by
  let ω :=
    _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
      (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
      (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
      (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1)
  have hq : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω := by
    simpa [ω] using
      (_root_.Erdos90.TransgressionContinuousInternal.schreier_isCocycle p G N
        (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
        (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
        (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1)
        (_root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit_conjugation_invariant
          p G N hN χ))
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  change
    (inflation p G N 2).hom.toLinearMap
      ((_root_.Erdos90.InhomogHomogIso.cohomologyIso p (G ⧸ N) 2)
        (_root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2
          (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ω hq))) =
      (_root_.Erdos90.InhomogHomogIso.cohomologyIso p G 2)
        (_root_.Erdos90.InhomogClassAPI.classMap p G 2
          (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p G
            (inflatedSchreier2Cocycle p G N hN χ) hω))
  simpa [inflation, inflatedSchreier2Cocycle, ω] using
    (cohomologyIso_natural_map_ofIsCocycle2 p G (G ⧸ N) (QuotientGroup.mk' N)
      QuotientGroup.continuous_mk ω hq hω)

theorem exists_continuousConjInvariantHom_and_sectionCochain_of_normalized_inflated_coboundary
    (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (ω : {ω : C((G ⧸ N) × (G ⧸ N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω})
    (h1 : ∀ q : G ⧸ N, ω.1 (1, q) = 0)
    (h2 : ∀ q : G ⧸ N, ω.1 (q, 1) = 0)
    (hinfl : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p G (QPull p G N ω)) :
    ∃ χh : Additive ↥N →ₜ+ ZMod p, ∃ u : C(G ⧸ N, ZMod p),
      (∀ g : G, ∀ n : ↥N,
        χh (Additive.ofMul (MulAut.conjNormal (H := N) g n)) = χh (Additive.ofMul n)) ∧
      (∀ x y : G ⧸ N,
        ω.1 (x, y) =
          u y - u (x * y) + u x +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N
              (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN)
              (_root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN)
              χh.toAddMonoidHom) (x, y)) := by
  classical
  rcases hinfl with ⟨b, hb⟩
  have hb_one : b 1 = 0 := by
    have h := hb 1 1
    simpa [QPull, h2 (1 : G ⧸ N)] using h.symm
  have hb_rightN : ∀ g : G, ∀ n : ↥N, b (g * n) = b n + b g := by
    intro g n
    have hqn : (n : G ⧸ N) = 1 := by
      simp
    have hq0 : ω.1 ((g : G ⧸ N), 1) = b n - b (g * n) + b g := by
      simpa [QPull, hqn] using hb g n
    have h0 : 0 = b n - b (g * n) + b g := by
      rw [h2 (g : G ⧸ N)] at hq0
      exact hq0
    have h' := congrArg (fun a => a + b (g * n)) h0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h'
  have hb_leftN : ∀ n : ↥N, ∀ g : G, b ((n : G) * g) = b g + b n := by
    intro n g
    have hqn : (n : G ⧸ N) = 1 := by
      simp
    have hq0 : ω.1 (1, (g : G ⧸ N)) = b g - b ((n : G) * g) + b n := by
      simpa [QPull, hqn] using hb n g
    have h0 : 0 = b g - b ((n : G) * g) + b n := by
      rw [h1 (g : G ⧸ N)] at hq0
      exact hq0
    have h' := congrArg (fun a => a + b ((n : G) * g)) h0
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h'
  let χh : Additive ↥N →ₜ+ ZMod p :=
    { toAddMonoidHom :=
        { toFun := fun n => -b (((@Additive.toMul ↥N) n : ↥N) : G)
          map_zero' := by
            simp [hb_one]
          map_add' := by
            intro n₁ n₂
            have hmul :
                b (((((@Additive.toMul ↥N) n₁ : ↥N) : G) * (((@Additive.toMul ↥N) n₂ : ↥N) : G))) =
                  b (((@Additive.toMul ↥N) n₂ : ↥N) : G) + b (((@Additive.toMul ↥N) n₁ : ↥N) : G) := by
              simpa using
                (hb_leftN (n := ((@Additive.toMul ↥N) n₁ : ↥N))
                  (g := (((@Additive.toMul ↥N) n₂ : ↥N) : G)))
            have hneg := congrArg (fun a : ZMod p => -a) hmul
            simpa [toMul_add, add_assoc, add_left_comm, add_comm] using hneg }
      continuous_toFun := by
        simpa using (b.continuous.comp continuous_subtype_val).neg }
  let s := _root_.Erdos90.TransgressionContinuous.chosenSection G N hN
  let hs := _root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN
  let u : C(G ⧸ N, ZMod p) := b.comp s
  refine ⟨χh, u, ?_, ?_⟩
  · intro g n
    have hgn : b (g * n) = b n + b g := hb_rightN g n
    have hconj : b (g * n) = b g + b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) := by
      simpa [MulAut.conjNormal_apply, mul_assoc] using
        (hb_leftN (n := (MulAut.conjNormal (H := N) g n)) (g := g))
    have hEq : b (n : G) + b g = b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) + b g := by
      calc
        b (n : G) + b g = b (g * n) := by simp [hgn.symm]
        _ = b g + b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) := hconj
        _ = b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) + b g := by abel
    have hbn : b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) = b (n : G) := by
      exact (add_right_cancel hEq).symm
    change -b (((MulAut.conjNormal (H := N) g n : ↥N) : G)) = -b (n : G)
    exact congrArg (fun a : ZMod p => -a) hbn
  · intro x y
    change
      ω.1 (x, y) =
        u y - u (x * y) + u x +
          (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
            χh.toAddMonoidHom) (x, y)
    let d := _root_.Erdos90.TransgressionContinuousInternal.schreierDefect G N s hs x y
    have hx : QuotientGroup.mk' N (s x) = x := hs x
    have hy : QuotientGroup.mk' N (s y) = y := hs y
    have hxy := hb (s x) (s y)
    have hxy0 :
        ω.1 ((QuotientGroup.mk' N) (s x), (QuotientGroup.mk' N) (s y)) =
          b (s y) - b (s x * s y) + b (s x) := by
      simpa [QPull] using hxy
    have hxy' : ω.1 (x, y) = b (s y) - b (s x * s y) + b (s x) := by
      simpa [hx, hy] using hxy0
    have hd : (d : G) * s (x * y) = s x * s y := by
      change (s x * s y * (s (x * y))⁻¹) * s (x * y) = s x * s y
      group
    have hmul : b (s x * s y) = b (s (x * y)) + b d := by
      simpa [d, hd] using hb_leftN (n := d) (g := s (x * y))
    have hcont : Continuous (χh.toAddMonoidHom : Additive ↥N → ZMod p) := χh.continuous_toFun
    have hcont' : Continuous (fun n : Additive ↥N => -b (((@Additive.toMul ↥N) n : ↥N) : G)) := by
      simpa [χh] using hcont
    have hsch :
        (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
          χh.toAddMonoidHom) (x, y) = -b d := by
      simp [_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle, d, χh, hcont']
    calc
      ω.1 (x, y) = b (s y) - b (s x * s y) + b (s x) := hxy'
      _ = b (s y) - (b (s (x * y)) + b d) + b (s x) := by rw [hmul]
      _ = b (s y) - b (s (x * y)) + b (s x) - b d := by abel
      _ = b (s y) - b (s (x * y)) + b (s x) +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
              χh.toAddMonoidHom) (x, y) := by
            rw [hsch]
            abel
      _ = u y - u (x * y) + u x +
            (_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs
              χh.toAddMonoidHom) (x, y) := by
            rfl

theorem exists_h1NormalInvariantClass_of_continuousConjInvariantHom (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (χh : Additive ↥N →ₜ+ ZMod p)
    (hχinv : ∀ g : G, ∀ n : ↥N,
      χh (Additive.ofMul (MulAut.conjNormal (H := N) g n)) = χh (Additive.ofMul n)) :
    ∃ χ : ↥(_root_.Erdos90.h1NormalInvariantSubmodule p G N),
      _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN χ.1 =
        χh.toAddMonoidHom := by
  haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
  let eN :=
    _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog
      (p := p) (K := ↥N)
  let x : _root_.Erdos90.H1ContsTrivial p G N := eN.symm χh
  have hx : eN x = χh := by
    simp [x]
  have hxhom :
      _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN x =
        χh.toAddMonoidHom := by
    change (eN x).toAddMonoidHom = χh.toAddMonoidHom
    exact congrArg (fun f : Additive ↥N →ₜ+ ZMod p => f.toAddMonoidHom) hx
  have hxinv : ∀ g : G,
      (_root_.Erdos90.h1ConjMap p G N g).hom x = x := by
    intro g
    have hcont :
        Continuous ((MulAut.conjNormal (H := N) g⁻¹ : ↥N ≃* ↥N) : ↥N → ↥N) := by
      refine continuous_induced_rng.2 ?_
      have hval : ∀ n : ↥N,

    _ = ((4 : ℝ) ^ (AdmissibleDatum.f 𝒟)) ^ ((n : ℝ)⁻¹) *
          ((((NumberField.discr 𝒟.L).natAbs : ℝ) ^ 2) ^ ((n : ℝ)⁻¹)) := by
          rw [Real.mul_rpow (by positivity) (by positivity)]

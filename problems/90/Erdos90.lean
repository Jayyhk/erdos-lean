          (fun Оҫ : в„қ => (FourierTransform.fourier ПҲ Оҫ) *
            G ((Пғ : в„Ӯ) + ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)))) X := rfl

theorem compactFreqKernel_physical_tendsto {f : в„• вҶ’ в„қ} {b : в„қ} {ПҲ : в„қ вҶ’ в„Ӯ} :
    (hF : HasBoundaryLaplaceExtension f b) вҶ’
    (hПҲ : CompactFreqKernel ПҲ) вҶ’
    (hconv : вҲҖ X : в„қ,
      MeasureTheory.IntegrableOn
        (fun u : в„қ => ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))
        (Set.Ioi (-X))) вҶ’
    вҲҖ X : в„қ,
      Filter.Tendsto
        (fun Пғ : в„қ =>
          вҲ« u in Set.Ioi (-X),
            ПҲ u * ((((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) *
              Complex.exp (-((Пғ : в„Ӯ) * (X + u)))))
        (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)))
        (nhds
          (вҲ« u in Set.Ioi (-X),
            ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))) := by
  intro hF hПҲ hconv X
  let g : в„қ вҶ’ в„Ӯ := fun u => ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ))
  let F : в„қ вҶ’ в„қ вҶ’ в„Ӯ := fun Пғ u => g u * Complex.exp (-((Пғ : в„Ӯ) * (X + u)))
  let Ој : MeasureTheory.Measure в„қ := MeasureTheory.volume.restrict (Set.Ioi (-X))
  have hg_int_on : MeasureTheory.IntegrableOn g (Set.Ioi (-X)) := by
    simpa [g] using hconv X
  have hg_int : MeasureTheory.Integrable g Ој := by
    simpa [Ој] using hg_int_on
  have hF_meas :
      вҲҖб¶  Пғ : в„қ in nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)),
        MeasureTheory.AEStronglyMeasurable (F Пғ) Ој := by
    refine Filter.Eventually.of_forall ?_
    intro Пғ
    have hExp_cont : Continuous fun u : в„қ => Complex.exp (-((Пғ : в„Ӯ) * (X + u))) := by
      continuity
    simpa [F] using hg_int.aestronglyMeasurable.mul hExp_cont.aestronglyMeasurable
  have h_bound :
      вҲҖб¶  Пғ : в„қ in nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)),
        вҲҖбөҗ u вҲӮОј, вҖ–F Пғ uвҖ– вүӨ вҖ–g uвҖ– := by
    have hПғmem : вҲҖб¶  Пғ : в„қ in nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)), Пғ вҲҲ Set.Ioi (0 : в„қ) := by
      show Set.Ioi (0 : в„қ) вҲҲ nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ))
      exact self_mem_nhdsWithin
    filter_upwards [hПғmem] with Пғ hПғmem
    refine MeasureTheory.ae_restrict_of_forall_mem (Ој := MeasureTheory.volume) (s := Set.Ioi (-X)) measurableSet_Ioi ?_
    intro u hu
    have hu' : -X < u := by simpa using hu
    have hXu : 0 < X + u := by
      linarith
    have hПғ : 0 < Пғ := hПғmem
    have hExp_le : вҖ–Complex.exp (-((Пғ : в„Ӯ) * (X + u)))вҖ– вүӨ 1 := by
      rw [Complex.norm_exp]
      have hle : Complex.re (-((Пғ : в„Ӯ) * (X + u))) вүӨ 0 := by
        simp
        nlinarith [hПғ, hXu]
      have hle' := Real.exp_le_exp.mpr hle
      simpa using hle'
    calc
      вҖ–F Пғ uвҖ– = вҖ–g uвҖ– * вҖ–Complex.exp (-((Пғ : в„Ӯ) * (X + u)))вҖ– := by
        simp [F, norm_mul]
      _ вүӨ вҖ–g uвҖ– * 1 := by
        exact mul_le_mul_of_nonneg_left hExp_le (norm_nonneg _)
      _ = вҖ–g uвҖ– := by simp
  have h_lim :
      вҲҖбөҗ u вҲӮОј,
        Filter.Tendsto (fun Пғ : в„қ => F Пғ u)
          (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)))
          (nhds (g u)) := by
    refine Filter.Eventually.of_forall ?_
    intro u
    have hcont : ContinuousAt (fun Пғ : в„қ => F Пғ u) 0 := by
      have hcont' : Continuous fun Пғ : в„қ => F Пғ u := by
        continuity
      exact hcont'.continuousAt
    simpa [F] using hcont.continuousWithinAt.tendsto
  simpa [Ој, F, g, mul_assoc] using
    MeasureTheory.tendsto_integral_filter_of_dominated_convergence
      (Ој := Ој) (bound := fun u => вҖ–g uвҖ–) hF_meas h_bound (hg_int.norm) h_lim

theorem compactFreqKernel_convolution_eq_fourier {f : в„• вҶ’ в„қ} {b : в„қ} {ПҲ : в„қ вҶ’ в„Ӯ} :
    (hF : HasBoundaryLaplaceExtension f b) вҶ’
    (hПҲ : CompactFreqKernel ПҲ) вҶ’
    (hconv : вҲҖ X : в„қ,
      MeasureTheory.IntegrableOn
        (fun u : в„қ => ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))
        (Set.Ioi (-X))) вҶ’
    вҲғ F : в„қ вҶ’ в„Ӯ, Continuous F вҲ§ HasCompactSupport F вҲ§
      вҲҖ X : в„қ,
        вҲ« u in Set.Ioi (-X), ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) =
          FourierTransform.fourier F X := by
  intro hF hПҲ hconv
  classical
  rcases hF with вҹЁG, hGcont, hGint, hGeqвҹ©
  have hF' : HasBoundaryLaplaceExtension f b := вҹЁG, hGcont, hGint, hGeqвҹ©
  let F : в„қ вҶ’ в„Ӯ := fun Оҫ =>
    (FourierTransform.fourier ПҲ Оҫ) * G ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I))
  refine вҹЁF, ?_, ?_, ?_вҹ©
  В· have hGaxis : Continuous fun Оҫ : в„қ => G ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)) := by
      refine hGcont.comp_continuous ?_ ?_
      В· continuity
      В· intro Оҫ
        simp
    simpa [F] using hПҲ.fourier_continuous.mul hGaxis
  В· simpa [F] using hПҲ.fourier_compact.mul_right
  В· intro X
    let phys : в„қ вҶ’ в„Ӯ := fun Пғ =>
      вҲ« u in Set.Ioi (-X),
        ПҲ u * ((((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)) *
          Complex.exp (-((Пғ : в„Ӯ) * (X + u))))
    let freq : в„қ вҶ’ в„Ӯ := fun Пғ =>
      FourierTransform.fourier
        (fun Оҫ : в„қ => (FourierTransform.fourier ПҲ Оҫ) *
          G ((Пғ : в„Ӯ) + ((((-2 * Real.pi * Оҫ : в„қ) : в„Ӯ) * Complex.I)))) X
    have hphys : Filter.Tendsto phys
        (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)))
        (nhds (вҲ« u in Set.Ioi (-X),
          ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))) := by
      simpa [phys] using compactFreqKernel_physical_tendsto hF' hПҲ hconv X
    have hfreq : Filter.Tendsto freq
        (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)))
        (nhds (FourierTransform.fourier F X)) := by
      simpa [freq, F] using compactFreqKernel_frequency_tendsto hПҲ hGcont X
    have heq : phys =б¶ [nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ))] freq := by
      have hIoi : Set.Ioi (0 : в„қ) вҲҲ nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ)) := by
        rw [Metric.mem_nhdsWithin_iff]
        refine вҹЁ1, by norm_num, ?_вҹ©
        intro y hy
        exact hy.2
      filter_upwards [hIoi] with Пғ hПғ
      simpa [phys, freq] using compactFreqKernel_damped_eq_fourier hGint hGeq hПҲ X Пғ hПғ
    haveI : Filter.NeBot (nhdsWithin (0 : в„қ) (Set.Ioi (0 : в„қ))) := nhdsWithin_Ioi_neBot le_rfl
    exact tendsto_nhds_unique_of_eventuallyEq hphys hfreq heq

theorem compactFreqKernel_tendsto_zero {f : в„• вҶ’ в„қ} {b : в„қ} {ПҲ : в„қ вҶ’ в„Ӯ} :
    (hF : HasBoundaryLaplaceExtension f b) вҶ’
    (hПҲ : CompactFreqKernel ПҲ) вҶ’
    (hconv : вҲҖ X : в„қ,
      MeasureTheory.IntegrableOn
        (fun u : в„қ => ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))
        (Set.Ioi (-X))) вҶ’
    Filter.Tendsto
      (fun X : в„қ =>
        вҲ« u : в„қ, ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ)))
      Filter.atTop (nhds 0) := by
  intro hF hПҲ hconv
  rcases compactFreqKernel_convolution_eq_fourier hF hПҲ hconv with вҹЁF, hFcont, hFcomp, hEqвҹ©
  have hzero : Filter.Tendsto (fun X : в„қ => FourierTransform.fourier F X) (Filter.cocompact в„қ) (nhds 0) := by
    simpa using Real.zero_at_infty_fourier F
  have hzero' : Filter.Tendsto (fun X : в„қ => FourierTransform.fourier F X) Filter.atTop (nhds 0) := by
    exact hzero.mono_left (by simp)
  have htail : Filter.Tendsto
      (fun X : в„қ => вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ)))
      Filter.atTop (nhds 0) := by
    simpa using compactFreqKernel_negativeTail_tendsto_zero (hПҲ := hПҲ) (c := (((-b : в„қ) : в„Ӯ)))
  have hdecomp :
      (fun X : в„қ =>
        вҲ« u : в„қ, ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ))) =
      (fun X : в„қ =>
        FourierTransform.fourier F X +
          вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ))) := by
    funext X
    let g : в„қ вҶ’ в„Ӯ := fun u => ПҲ u * (((logRescalePartialSum f (X + u) - b : в„қ) : в„Ӯ))
    have hpos_int_ioi : MeasureTheory.IntegrableOn g (Set.Ioi (-X)) := by
      simpa [g] using hconv X
    have hpos_int_ici : MeasureTheory.IntegrableOn g (Set.Ici (-X)) := by
      exact hpos_int_ioi.congr_set_ae ((MeasureTheory.Ioi_ae_eq_Ici (Ој := MeasureTheory.volume) (a := -X)).symm)
    have hconst_int : MeasureTheory.Integrable (fun u : в„қ => ПҲ u * (((-b : в„қ) : в„Ӯ))) := by
      simpa using hПҲ.integrable.mul_const (((-b : в„қ) : в„Ӯ))
    have hneg_int_iio : MeasureTheory.IntegrableOn g (Set.Iio (-X)) := by
      refine (hconst_int.integrableOn).congr_fun ?_ measurableSet_Iio
      intro u hu
      have hu' : u < -X := hu
      have hxu : X + u < 0 := by
        have hsum : X + u < X + -X := add_lt_add_right hu' X
        simpa using hsum
      have hnot : В¬ 0 вүӨ X + u := not_le.mpr hxu
      simp [g, logRescalePartialSum, hnot]
    have hsplit' :
        (вҲ« u in Set.Iio (-X), g u) +
          (вҲ« u in Set.Ici (-X), g u) =
        вҲ« u : в„қ, g u := by
      exact intervalIntegral.integral_Iio_add_Ici (b := -X) (f := g) hneg_int_iio hpos_int_ici
    have htail_eq :
        вҲ« u in Set.Iio (-X), g u =
          вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ)) := by
      calc
        вҲ« u in Set.Iio (-X), g u =
            вҲ« u in Set.Iio (-X), ПҲ u * (((-b : в„қ) : в„Ӯ)) := by
          refine MeasureTheory.setIntegral_congr_fun measurableSet_Iio ?_
          intro u hu
          have hu' : u < -X := hu
          have hxu : X + u < 0 := by
            have hsum : X + u < X + -X := add_lt_add_right hu' X
            simpa using hsum
          have hnot : В¬ 0 вүӨ X + u := not_le.mpr hxu
          simp [g, logRescalePartialSum, hnot]
        _ = вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ)) := by
          simpa using
            (MeasureTheory.integral_Iic_eq_integral_Iio
              (Ој := MeasureTheory.volume)
              (x := -X)
              (f := fun u : в„қ => ПҲ u * (((-b : в„қ) : в„Ӯ)))).symm
    have hEqg :
        вҲ« u in Set.Ioi (-X), g u = FourierTransform.fourier F X := by
      simpa [g] using hEq X
    calc
      вҲ« u : в„қ, g u =
          (вҲ« u in Set.Iio (-X), g u) +
            (вҲ« u in Set.Ici (-X), g u) := by
        simpa using hsplit'.symm
      _ =
          (вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ))) +
            (вҲ« u in Set.Ioi (-X), g u) := by
        rw [htail_eq, MeasureTheory.integral_Ici_eq_integral_Ioi (Ој := MeasureTheory.volume) (x := -X) (f := g)]
      _ =
          (вҲ« u in Set.Ioi (-X), g u) +
            (вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ))) := by
        rw [add_comm]
      _ = FourierTransform.fourier F X +
            (вҲ« u in Set.Iic (-X), ПҲ u * (((-b : в„қ) : в„Ӯ))) := by
        rw [hEqg]
  rw [hdecomp]
  simpa using hzero'.add htail

theorem eventual_pos_of_quasi_monotone_and_unitIntervalAverage {f : в„• вҶ’ в„қ} {b : в„қ} :
    (hb : 0 < b) вҶ’
    (hnonneg : вҲҖ n, 0 вүӨ f n) вҶ’
    (hqm : вҲҖ {x y : в„қ}, 0 вүӨ x вҶ’ 0 вүӨ y вҶ’
      logRescalePartialSum f x вүӨ Real.exp y * logRescalePartialSum f (x + y)) вҶ’
    (havg : Filter.Tendsto (fun X : в„қ => вҲ« t in X - 1..X, logRescalePartialSum f t)
      Filter.atTop (nhds b)) вҶ’
    вҲғ c : в„қ, 0 < c вҲ§ вҲғ xвӮҖ : в„қ, вҲҖ x : в„қ, xвӮҖ вүӨ x вҶ’ c вүӨ logRescalePartialSum f x := by
  intro hb hnonneg hqm havg
  let U : в„қ вҶ’ в„қ := logRescalePartialSum f
  have hU_nonneg : вҲҖ x : в„қ, 0 вүӨ U x := by
    intro x
    dsimp [U, logRescalePartialSum]
    split_ifs with hx
    В· refine mul_nonneg ?_ ?_
      В· positivity
      В· exact Finset.sum_nonneg (by
          intro k hk
          exact hnonneg k)
    В· positivity
  have hEventuallyAvg : вҲҖб¶  X in Filter.atTop, b / 2 < вҲ« t in X - 1..X, U t := by
    have hmem : Set.Ioi (b / 2) вҲҲ nhds b := by
      exact Ioi_mem_nhds (by linarith [hb])
    simpa [U] using havg hmem
  rcases Filter.eventually_atTop.mp hEventuallyAvg with вҹЁx1, hx1вҹ©
  refine вҹЁb / 2 / Real.exp 1, ?_, max x1 1, ?_вҹ©
  В· positivity
  В· intro x hx
    have hx1_le : x1 вүӨ x := le_trans (le_max_left _ _) hx
    have hx_ge_one : 1 вүӨ x := le_trans (le_max_right _ _) hx
    have hAvgLower : b / 2 < вҲ« t in x - 1..x, U t := hx1 x hx1_le
    have hpoint : вҲҖ t вҲҲ Set.uIoc (x - 1) x, вҖ–U tвҖ– вүӨ Real.exp 1 * U x := by
      intro t ht
      have hxx : x - 1 вүӨ x := by linarith
      have ht' : t вҲҲ Set.Ioc (x - 1) x := by
        simpa [Set.uIoc_of_le hxx] using ht
      have hlt : x - 1 < t := ht'.1
      have hle : t вүӨ x := ht'.2
      have htnonneg : 0 вүӨ t := by linarith
      have hyt : 0 вүӨ x - t := by linarith
      have hsum : t + (x - t) = x := by ring
      have hq : U t вүӨ Real.exp (x - t) * U x := by
        simpa [U, hsum] using hqm (x := t) (y := x - t) htnonneg hyt
      have hxt_le_one : x - t вүӨ 1 := by linarith
      have hexp_le : Real.exp (x - t) вүӨ Real.exp 1 := by
        gcongr
      have hmul : Real.exp (x - t) * U x вүӨ Real.exp 1 * U x := by
        exact mul_le_mul_of_nonneg_right hexp_le (hU_nonneg x)
      have hq' : U t вүӨ Real.exp 1 * U x := le_trans hq hmul
      simpa [Real.norm_eq_abs, abs_of_nonneg (hU_nonneg t)] using hq'
    have hnorm : вҖ–вҲ« t in x - 1..x, U tвҖ– вүӨ Real.exp 1 * U x := by
      have htmp := intervalIntegral.norm_integral_le_of_norm_le_const (a := x - 1) (b := x) (f := U)
        (C := Real.exp 1 * U x) hpoint
      have hxlen : |x - (x - 1)| = 1 := by
        have : x - (x - 1) = 1 := by ring
        rw [this, abs_of_nonneg (by norm_num : (0 : в„қ) вүӨ 1)]
      simpa [hxlen] using htmp
    have hIntNonneg : 0 вүӨ вҲ« t in x - 1..x, U t := by
      refine intervalIntegral.integral_nonneg ?_ ?_
      В· linarith
      В· intro t ht
        exact hU_nonneg t
    have hIntUpper : вҲ« t in x - 1..x, U t вүӨ Real.exp 1 * U x := by
      simpa [Real.norm_eq_abs, abs_of_nonneg hIntNonneg] using hnorm
    have hbound : b / 2 < Real.exp 1 * U x := lt_of_lt_of_le hAvgLower hIntUpper
    have hxlower : b / 2 / Real.exp 1 < U x := by
      have hpos : 0 < Real.exp 1 := Real.exp_pos 1
      rw [div_lt_iffвӮҖ' hpos]
      simpa [mul_comm, mul_left_comm, mul_assoc] using hbound
    exact le_of_lt hxlower

theorem intervalIntegral_compare_leftTent_compactKernel {f : в„• вҶ’ в„қ} {b C Оҙ X : в„қ} {ПҲ : в„қ вҶ’ в„Ӯ} :
  CompactFreqKernel ПҲ вҶ’
  (вҲҖ t вҲҲ Set.Icc (0 : в„қ) 1, |logRescalePartialSum f (X + t) - b| вүӨ C) вҶ’
  (вҲ« u : в„қ, вҖ–leftTentKernel u - ПҲ uвҖ– вүӨ Оҙ) вҶ’
  0 вүӨ C вҶ’
  0 вүӨ Оҙ вҶ’
  |(вҲ« t in (0 : в„қ)..1,
      (leftTentKernel (t - (1 / 2 : в„қ)) + leftTentKernel ((1 / 2 : в„қ) - t)).re *
        (logRescalePartialSum f (X + t) - b)) -
    (вҲ« t in (0 : в„қ)..1,
      ((ПҲ (t - (1 / 2 : в„қ))).re + (ПҲ ((1 / 2 : в„қ) - t)).re) *
        (logRescalePartialSum f (X + t) - b))| вүӨ
    2 * C * Оҙ := by
  intro hПҲ hbound hОҙ hC0 hОҙ0
  let g : в„қ вҶ’ в„қ := fun t => logRescalePartialSum f (X + t) - b
  let K : в„қ вҶ’ в„қ := fun u => вҖ–leftTentKernel u - ПҲ uвҖ–
  have h01 : (0 : в„қ) вүӨ 1 := by norm_num
  have hKint : MeasureTheory.Integrable K := by
    simp [K]
    simpa using (leftTentKernel_integrable.sub hПҲ.integrable).norm
  have hsum_meas : Measurable (fun x : в„қ => вҲ‘ k вҲҲ Finset.Icc 1 вҢҠReal.exp xвҢӢвӮҠ, f k) := by
    let s : в„• вҶ’ в„қ := fun n => вҲ‘ k вҲҲ Finset.Icc 1 n, f k
    have hs : Measurable s := measurable_from_nat
    simpa [s] using hs.comp ((Real.continuous_exp.measurable).nat_floor)
  have hlog_meas : Measurable (logRescalePartialSum f) := by
    unfold logRescalePartialSum
    refine Measurable.ite measurableSet_Ici ?_ measurable_const
    exact ((Real.continuous_exp.comp continuous_neg).measurable.mul hsum_meas)
  have hg_meas : Measurable g := by
    simpa [g] using ((hlog_meas.comp (measurable_const.add measurable_id)).sub measurable_const)
  have hg_ae : MeasureTheory.AEStronglyMeasurable g ((MeasureTheory.volume).restrict (Set.uIoc (0 : в„қ) 1)) := by
    simpa using (hg_meas.aestronglyMeasurable.restrict (s := Set.uIoc (0 : в„қ) 1))
  have hg_bound_ae : вҲҖбөҗ t вҲӮ((MeasureTheory.volume).restrict (Set.uIoc (0 : в„қ) 1)), вҖ–g tвҖ– вүӨ C := by
    rw [MeasureTheory.ae_restrict_iff' measurableSet_uIoc]
    refine Filter.Eventually.of_forall ?_
    intro t ht
    have htIoc : t вҲҲ Set.Ioc (0 : в„қ) 1 := by
      simpa [Set.uIoc_of_le h01] using ht
    have ht' : t вҲҲ Set.Icc (0 : в„қ) 1 := вҹЁle_of_lt htIoc.1, htIoc.2вҹ©
    simpa [g, Real.norm_eq_abs] using hbound t ht'
  have hkL1 : MeasureTheory.Integrable (fun t : в„қ => (leftTentKernel (t - (1 / 2 : в„қ))).re) := by
    simpa [sub_eq_add_neg] using (leftTentKernel_integrable.comp_add_right (-(1 / 2 : в„қ))).re
  have hkP1 : MeasureTheory.Integrable (fun t : в„қ => (ПҲ (t - (1 / 2 : в„қ))).re) := by

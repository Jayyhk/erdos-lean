            hL_unr (рқ””' : Ideal (рқ“һ L)) hрқ””_over_p)
  have hPunr : Algebra.IsUnramifiedAt (рқ“һ F) рқ”“ := by
    letI : Algebra.IsUnramifiedAt (рқ“һ F) (рқ””' : Ideal (рқ“һ L)) := hQunr
    exact Algebra.IsUnramifiedAt.of_liesOver (R := рқ“һ F) (p := рқ”“) (P := (рқ””' : Ideal (рқ“һ L)))
  have hPne : рқ”“ вү  вҠҘ := Ideal.ne_bot_of_mem_primesOver hne hрқ”“
  exact
    by
      simpa [Ideal.over_def (A := рқ“һ F) (P := рқ”“) (p := рқ”ӯ)] using
        (Algebra.isUnramifiedAt_iff_of_isDedekindDomain
            (R := рқ“һ F) (S := рқ“һ K) (p := рқ”“) hPne).1 hPunr

noncomputable def maximalUnramifiedFiniteStage
    (F : Type) [Field F] [NumberField F]
    (p : в„•) [Fact (Nat.Prime p)]
    (s : Finset (maximalUnramifiedProPFIndex F p)) :
    IntermediateField F (AlgebraicClosure F) :=
  вЁҶ i вҲҲ s, i.M

theorem maximalUnramified_restrictNormalHom_surjective (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (M : IntermediateField F (maximalUnramifiedProPF F p)) [Normal F M] :
    Function.Surjective ((AlgEquiv.restrictNormalHom (F := F)
      (KвӮҒ := maximalUnramifiedProPF F p) M) :
      MaxUnramifiedProPGaloisGroup F p вҶ’* (M вүғвӮҗ[F] M)) := by
  haveI : Normal F (maximalUnramifiedProPF F p) :=
    MaxUnramifiedProPGaloisGroup.normal_maximalUnramifiedProPF F p
  simpa [MaxUnramifiedProPGaloisGroup] using
    (AlgEquiv.restrictNormalHom_surjective (F := F)
      (KвӮҒ := M) (E := maximalUnramifiedProPF F p))

theorem normal_numberField_intermediate_fg {F K : Type*} [Field F] [Field K] [Algebra F K]
    (M : IntermediateField F K) [FiniteDimensional F M] [Normal F M] [NumberField M] :
    M.FG := by
  letI : Algebra.FiniteType F M := Module.Finite.finiteType M
  letI : Algebra.EssFiniteType F M := Algebra.EssFiniteType.of_finiteType F M
  exact (IntermediateField.essFiniteType_iff (F := F) (E := K) (K := M)).1 inferInstance

theorem restrictNormal_mem_inertia_comap (F : Type) [Field F] [NumberField F]
    (E K : IntermediateField F (AlgebraicClosure F))
    [NumberField вҶҘE] [NumberField вҶҘK]
    [Algebra вҶҘK вҶҘE] [IsScalarTower F вҶҘK вҶҘE]
    [Normal F вҶҘK]
    (рқ”– : Ideal (рқ“һ вҶҘE))
    {Пғ : вҶҘE вүғвӮҗ[F] вҶҘE} :
    Пғ вҲҲ рқ”–.inertia (вҶҘE вүғвӮҗ[F] вҶҘE) вҶ’
      (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) вҲҲ
        (Ideal.comap
          (NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F вҶҘK вҶҘE))
          рқ”–).inertia (вҶҘK вүғвӮҗ[F] вҶҘK) := by
  intro hПғ
  rw [AddSubgroup.mem_inertia] at hПғ вҠў
  intro x
  let f : рқ“һ вҶҘK вҶ’вӮҗ[рқ“һ F] рқ“һ вҶҘE :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F вҶҘK вҶҘE)
  change ((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) вҖў x - x : рқ“һ вҶҘK) вҲҲ Ideal.comap f рқ”–
  rw [Ideal.mem_comap]
  rw [show f (((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) вҖў x - x : рқ“һ вҶҘK)) =
      f ((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) вҖў x) - f x by
    simp]
  have hcomm :
      f ((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) вҖў x) = Пғ вҖў f x := by
    apply NumberField.RingOfIntegers.ext
    change algebraMap вҶҘK вҶҘE (((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘE) вҶҘK Пғ) x : вҶҘK)) =
      Пғ (algebraMap вҶҘK вҶҘE (x : вҶҘK))
    simpa only [f] using
      (AlgEquiv.restrictNormal_commutes (ПҮ := Пғ) (E := вҶҘK) (x := (x : вҶҘK)))
  have hПғx := hПғ (f x)
  simpa [hcomm] using hПғx

theorem restrict_eq_one_of_eq_one_on_sup_left_right (F : Type) [Field F] [NumberField F]
    (K L : IntermediateField F (AlgebraicClosure F))
    [Normal F вҶҘK] [Normal F вҶҘL] [Normal F вҶҘ(K вҠ” L)]
    [Algebra вҶҘK вҶҘ(K вҠ” L)] [Algebra вҶҘL вҶҘ(K вҠ” L)]
    [IsScalarTower F вҶҘK вҶҘ(K вҠ” L)] [IsScalarTower F вҶҘL вҶҘ(K вҠ” L)]
    (Пғ : вҶҘ(K вҠ” L) вүғвӮҗ[F] вҶҘ(K вҠ” L))
    (hAlgK : вҲҖ x : вҶҘK,
      algebraMap вҶҘK вҶҘ(K вҠ” L) x = IntermediateField.inclusion le_sup_left x)
    (hAlgL : вҲҖ x : вҶҘL,
      algebraMap вҶҘL вҶҘ(K вҠ” L) x = IntermediateField.inclusion le_sup_right x)
    (hK : (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘK Пғ) = 1)
    (hL : (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘL Пғ) = 1) :
    Пғ = 1 := by
  have hKx : вҲҖ x : вҶҘK, (Пғ.restrictNormal вҶҘK) x = x := by
    intro x
    have hx := congrArg (fun e : вҶҘK вүғвӮҗ[F] вҶҘK => e x) hK
    simpa using hx
  have hLx : вҲҖ x : вҶҘL, (Пғ.restrictNormal вҶҘL) x = x := by
    intro x
    have hx := congrArg (fun e : вҶҘL вүғвӮҗ[F] вҶҘL => e x) hL
    simpa using hx
  have hfixK : вҲҖ x : вҶҘK, Пғ (algebraMap вҶҘK вҶҘ(K вҠ” L) x) = algebraMap вҶҘK вҶҘ(K вҠ” L) x := by
    intro x
    have hcomm := AlgEquiv.restrictNormal_commutes (ПҮ := Пғ) (E := вҶҘK) (x := x)
    rw [hKx x] at hcomm
    simpa using hcomm.symm
  have hfixL : вҲҖ x : вҶҘL, Пғ (algebraMap вҶҘL вҶҘ(K вҠ” L) x) = algebraMap вҶҘL вҶҘ(K вҠ” L) x := by
    intro x
    have hcomm := AlgEquiv.restrictNormal_commutes (ПҮ := Пғ) (E := вҶҘL) (x := x)
    rw [hLx x] at hcomm
    simpa using hcomm.symm
  have hS :
      (K вҠ” L : IntermediateField F (AlgebraicClosure F)) =
        IntermediateField.adjoin F ((K : Set (AlgebraicClosure F)) вҲӘ L) := by
    simpa using (IntermediateField.sup_def K L)
  have hПғ_alg : (Пғ : вҶҘ(K вҠ” L) вҶ’вӮҗ[F] вҶҘ(K вҠ” L)) = 1 := by
    refine IntermediateField.algHom_ext_of_eq_adjoin (F := F) (S := K вҠ” L) hS ?_
    intro x hx
    rcases hx with hx | hx
    В· let xE : вҶҘ(K вҠ” L) :=
        вҹЁx,
          hS.ge
            (IntermediateField.subset_adjoin F ((K : Set (AlgebraicClosure F)) вҲӘ L)
              (Or.inl hx))вҹ©
      let e : вҶҘK := вҹЁx, hxвҹ©
      have hxE : xE = algebraMap вҶҘK вҶҘ(K вҠ” L) e := by
        ext
        rw [hAlgK e]
        simp [xE, e]
      calc
        Пғ xE = Пғ (algebraMap вҶҘK вҶҘ(K вҠ” L) e) := by rw [hxE]
        _ = algebraMap вҶҘK вҶҘ(K вҠ” L) e := hfixK _
        _ = (1 : вҶҘ(K вҠ” L) вҶ’вӮҗ[F] вҶҘ(K вҠ” L)) xE := by rw [hxE]; rfl
    В· let xE : вҶҘ(K вҠ” L) :=
        вҹЁx,
          hS.ge
            (IntermediateField.subset_adjoin F ((K : Set (AlgebraicClosure F)) вҲӘ L)
              (Or.inr hx))вҹ©
      let e : вҶҘL := вҹЁx, hxвҹ©
      have hxE : xE = algebraMap вҶҘL вҶҘ(K вҠ” L) e := by
        ext
        rw [hAlgL e]
        simp [xE, e]
      calc
        Пғ xE = Пғ (algebraMap вҶҘL вҶҘ(K вҠ” L) e) := by rw [hxE]
        _ = algebraMap вҶҘL вҶҘ(K вҠ” L) e := hfixL _
        _ = (1 : вҶҘ(K вҠ” L) вҶ’вӮҗ[F] вҶҘ(K вҠ” L)) xE := by rw [hxE]; rfl
  ext x
  simpa using congrArg (fun f : вҶҘ(K вҠ” L) вҶ’вӮҗ[F] вҶҘ(K вҠ” L) => f x) hПғ_alg

theorem two_field_sup_locally_unramified (F : Type) [Field F] [NumberField F]
    (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ)
    (K L : IntermediateField F (AlgebraicClosure F))
    [FiniteDimensional F вҶҘK] [FiniteDimensional F вҶҘL] [FiniteDimensional F вҶҘ(K вҠ” L)]
    [IsGalois F вҶҘK] [IsGalois F вҶҘL] [IsGalois F вҶҘ(K вҠ” L)]
    [NumberField вҶҘK] [NumberField вҶҘL] [NumberField вҶҘ(K вҠ” L)]
    (hK : вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘK), Ideal.ramificationIdx рқ”ӯ рқ”“ = 1)
    (hL : вҲҖ рқ”” вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘL), Ideal.ramificationIdx рқ”ӯ рқ”” = 1) :
    вҲҖ рқ”– вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘ(K вҠ” L)), Ideal.ramificationIdx рқ”ӯ рқ”– = 1 := by
  intro рқ”– hрқ”–
  letI : Algebra вҶҘK вҶҘ(K вҠ” L) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_left).toRingHom)
  letI : IsScalarTower F вҶҘK вҶҘ(K вҠ” L) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_left)
  letI : Algebra вҶҘL вҶҘ(K вҠ” L) :=
    RingHom.toAlgebra ((IntermediateField.inclusion le_sup_right).toRingHom)
  letI : IsScalarTower F вҶҘL вҶҘ(K вҠ” L) :=
    IsScalarTower.of_algHom (IntermediateField.inclusion le_sup_right)
  letI : Normal F вҶҘK :=
    (isGalois_iff.mp (show IsGalois F вҶҘK from inferInstance)).2
  letI : Normal F вҶҘL :=
    (isGalois_iff.mp (show IsGalois F вҶҘL from inferInstance)).2
  letI : Normal F вҶҘ(K вҠ” L) :=
    (isGalois_iff.mp (show IsGalois F вҶҘ(K вҠ” L) from inferInstance)).2
  let fK : (рқ“һ вҶҘK) вҶ’вӮҗ[рқ“һ F] (рқ“һ вҶҘ(K вҠ” L)) :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F вҶҘK вҶҘ(K вҠ” L))
  let fL : (рқ“һ вҶҘL) вҶ’вӮҗ[рқ“һ F] (рқ“һ вҶҘ(K вҠ” L)) :=
    NumberField.RingOfIntegers.mapAlgHom (IsScalarTower.toAlgHom F вҶҘL вҶҘ(K вҠ” L))
  let рқ”“ : Ideal (рқ“һ вҶҘK) := Ideal.comap fK рқ”–
  let рқ”” : Ideal (рқ“һ вҶҘL) := Ideal.comap fL рқ”–
  have hSprime : рқ”–.IsPrime := hрқ”–.1
  have hSlies : рқ”–.LiesOver рқ”ӯ := hрқ”–.2
  have hPprime : рқ”“.IsPrime := by
    dsimp [рқ”“]
    letI : рқ”–.IsPrime := hSprime
    simpa using (Ideal.comap_isPrime fK.toRingHom рқ”–)
  have hQprime : рқ””.IsPrime := by
    dsimp [рқ””]
    letI : рқ”–.IsPrime := hSprime
    simpa using (Ideal.comap_isPrime fL.toRingHom рқ”–)
  have hPlies : рқ”“.LiesOver рқ”ӯ := by
    dsimp [рқ”“]
    letI : рқ”–.LiesOver рқ”ӯ := hSlies
    simpa using (Ideal.comap_liesOver рқ”– рқ”ӯ fK)
  have hQlies : рқ””.LiesOver рқ”ӯ := by
    dsimp [рқ””]
    letI : рқ”–.LiesOver рқ”ӯ := hSlies
    simpa using (Ideal.comap_liesOver рқ”– рқ”ӯ fL)
  have hPmem : рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘK) := вҹЁhPprime, hPliesвҹ©
  have hQmem : рқ”” вҲҲ рқ”ӯ.primesOver (рқ“һ вҶҘL) := вҹЁhQprime, hQliesвҹ©
  letI : рқ”ӯ.IsMaximal := hp.isMaximal hne
  letI : рқ”“.IsMaximal := hPprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ”“)
  letI : рқ””.IsMaximal := hQprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ””)
  letI : рқ”–.IsMaximal := hSprime.isMaximal (Ideal.ne_bot_of_liesOver_of_ne_bot hne рқ”–)
  letI : Field ((рқ“һ F) в§ё рқ”ӯ) := Ideal.Quotient.field рқ”ӯ
  letI : Field ((рқ“һ вҶҘK) в§ё рқ”“) := Ideal.Quotient.field рқ”“
  letI : Field ((рқ“һ вҶҘL) в§ё рқ””) := Ideal.Quotient.field рқ””
  letI : Field ((рқ“һ вҶҘ(K вҠ” L)) в§ё рқ”–) := Ideal.Quotient.field рқ”–
  let p0 : Ideal в„Ө := Ideal.under в„Ө рқ”ӯ
  have habsNorm_p_ne_zero : Ideal.absNorm рқ”ӯ вү  0 := by
    intro h0
    exact hne ((Ideal.absNorm_eq_zero_iff (I := рқ”ӯ)).mp h0)
  have hp0ne : p0 вү  вҠҘ := by
    letI : рқ”ӯ.LiesOver p0 := by
      dsimp [p0]
      simpa using (Ideal.over_under (A := в„Ө) рқ”ӯ)
    intro hp0bot
    have hmem0 : (((Ideal.absNorm рқ”ӯ : в„•) : в„Ө)) вҲҲ p0 := by
      exact (Ideal.mem_of_liesOver (P := рқ”ӯ) (p := p0) (((Ideal.absNorm рқ”ӯ : в„•) : в„Ө))).2
        (by simpa using (Ideal.absNorm_mem рқ”ӯ))
    have hz0 : (((Ideal.absNorm рқ”ӯ : в„•) : в„Ө)) = 0 := by
      simpa [hp0bot] using hmem0
    exact habsNorm_p_ne_zero (by exact_mod_cast hz0)
  have hp0abs_ne_zero : Ideal.absNorm p0 вү  0 := by
    intro h0
    exact hp0ne ((Ideal.absNorm_eq_zero_iff (I := p0)).mp h0)
  have hp0eq : Ideal.span ({(Ideal.absNorm p0 : в„Ө)} : Set в„Ө) = p0 := by
    simp [p0]
  let e : в„Ө в§ё p0 вүғ+* ZMod (Ideal.absNorm p0) :=
    (Ideal.quotEquivOfEq hp0eq.symm).trans (Int.quotientSpanNatEquivZMod (Ideal.absNorm p0))
  letI : NeZero (Ideal.absNorm p0) := вҹЁhp0abs_ne_zeroвҹ©
  letI : Fintype (ZMod (Ideal.absNorm p0)) := ZMod.fintype (Ideal.absNorm p0)
  have hfinZ : Finite (в„Ө в§ё p0) := Finite.of_equiv _ e.symm.toEquiv
  letI : Finite (в„Ө в§ё p0) := hfinZ
  have hmf : Module.Finite (в„Ө в§ё p0) ((рқ“һ F) в§ё рқ”ӯ) := by
    letI : рқ”ӯ.LiesOver p0 := by
      dsimp [p0]
      simpa using (Ideal.over_under (A := в„Ө) рқ”ӯ)
    exact module_finite_of_liesOver (P := рқ”ӯ) (p := p0)
  letI : Module.Finite (в„Ө в§ё p0) ((рқ“һ F) в§ё рқ”ӯ) := hmf
  letI : Finite ((рқ“һ F) в§ё рқ”ӯ) := Module.finite_of_finite (R := в„Ө в§ё p0)
  letI : PerfectField ((рқ“һ F) в§ё рқ”ӯ) := PerfectField.ofFinite
  letI : Algebra.IsAlgebraic ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘK) в§ё рқ”“) := by infer_instance
  letI : Algebra.IsSeparable ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘK) в§ё рқ”“) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Algebra.IsAlgebraic ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘL) в§ё рқ””) := by infer_instance
  letI : Algebra.IsSeparable ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘL) в§ё рқ””) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  letI : Algebra.IsAlgebraic ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘ(K вҠ” L)) в§ё рқ”–) := by infer_instance
  letI : Algebra.IsSeparable ((рқ“һ F) в§ё рқ”ӯ) ((рқ“һ вҶҘ(K вҠ” L)) в§ё рқ”–) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  have hramK : Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := hK рқ”“ hPmem
  have hramL : Ideal.ramificationIdx рқ”ӯ рқ”” = 1 := hL рқ”” hQmem
  have hcardK : Nat.card (рқ”“.inertia (вҶҘK вүғвӮҗ[F] вҶҘK)) = 1 := by
    letI : рқ”“.LiesOver рқ”ӯ := hPlies
    letI : рқ”“.IsPrime := hPprime
    rw [Ideal.card_inertia_eq_ramificationIdxIn (G := вҶҘK вүғвӮҗ[F] вҶҘK) рқ”ӯ hne рқ”“,
      Ideal.ramificationIdxIn_eq_ramificationIdx (G := вҶҘK вүғвӮҗ[F] вҶҘK) (p := рқ”ӯ) (P := рқ”“)]
    exact hramK
  have hcardL : Nat.card (рқ””.inertia (вҶҘL вүғвӮҗ[F] вҶҘL)) = 1 := by
    letI : рқ””.LiesOver рқ”ӯ := hQlies
    letI : рқ””.IsPrime := hQprime
    rw [Ideal.card_inertia_eq_ramificationIdxIn (G := вҶҘL вүғвӮҗ[F] вҶҘL) рқ”ӯ hne рқ””,
      Ideal.ramificationIdxIn_eq_ramificationIdx (G := вҶҘL вүғвӮҗ[F] вҶҘL) (p := рқ”ӯ) (P := рқ””)]
    exact hramL
  have hInertiaK_bot : рқ”“.inertia (вҶҘK вүғвӮҗ[F] вҶҘK) = вҠҘ :=
    (Subgroup.card_eq_one).mp hcardK
  have hInertiaL_bot : рқ””.inertia (вҶҘL вүғвӮҗ[F] вҶҘL) = вҠҘ :=
    (Subgroup.card_eq_one).mp hcardL
  have hSinertia_bot : рқ”–.inertia (вҶҘ(K вҠ” L) вүғвӮҗ[F] вҶҘ(K вҠ” L)) = вҠҘ := by
    refine Subgroup.ext ?_
    intro Пғ
    constructor
    В· intro hПғ
      have hresK_mem :
          (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘK Пғ) вҲҲ
            рқ”“.inertia (вҶҘK вүғвӮҗ[F] вҶҘK) := by
        simpa [fK, рқ”“] using
          (restrictNormal_mem_inertia_comap F (K вҠ” L) K рқ”– (Пғ := Пғ) hПғ)
      have hresL_mem :
          (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘL Пғ) вҲҲ
            рқ””.inertia (вҶҘL вүғвӮҗ[F] вҶҘL) := by
        simpa [fL, рқ””] using
          (restrictNormal_mem_inertia_comap F (K вҠ” L) L рқ”– (Пғ := Пғ) hПғ)
      have hresK : (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘK Пғ) = 1 := by
        rw [hInertiaK_bot] at hresK_mem
        simpa [Subgroup.mem_bot] using hresK_mem
      have hresL : (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := вҶҘ(K вҠ” L)) вҶҘL Пғ) = 1 := by
        rw [hInertiaL_bot] at hresL_mem
        simpa [Subgroup.mem_bot] using hresL_mem
      have hAlgK : вҲҖ x : вҶҘK,
          algebraMap вҶҘK вҶҘ(K вҠ” L) x = IntermediateField.inclusion le_sup_left x := by
        intro x
        rfl
      have hAlgL : вҲҖ x : вҶҘL,
          algebraMap вҶҘL вҶҘ(K вҠ” L) x = IntermediateField.inclusion le_sup_right x := by
        intro x
        rfl
      have hПғ1 : Пғ = 1 :=
        restrict_eq_one_of_eq_one_on_sup_left_right F K L Пғ hAlgK hAlgL hresK hresL
      simpa [Subgroup.mem_bot] using hПғ1
    В· intro hПғ
      have hПғ1 : Пғ = 1 := by
        simpa [Subgroup.mem_bot] using hПғ
      rw [hПғ1]
      exact (рқ”–.inertia (вҶҘ(K вҠ” L) вүғвӮҗ[F] вҶҘ(K вҠ” L))).one_mem
  have hramIn : Ideal.ramificationIdxIn рқ”ӯ (рқ“һ вҶҘ(K вҠ” L)) = 1 := by
    letI : рқ”–.LiesOver рқ”ӯ := hSlies
    rw [вҶҗ Ideal.card_inertia_eq_ramificationIdxIn
      (G := вҶҘ(K вҠ” L) вүғвӮҗ[F] вҶҘ(K вҠ” L)) рқ”ӯ hne рқ”–, hSinertia_bot, Subgroup.card_bot]
  letI : рқ”–.LiesOver рқ”ӯ := hSlies
  letI : рқ”–.IsPrime := hSprime
  rw [вҶҗ Ideal.ramificationIdxIn_eq_ramificationIdx
    (G := вҶҘ(K вҠ” L) вүғвӮҗ[F] вҶҘ(K вҠ” L)) (p := рқ”ӯ) (P := рқ”–)]
  exact hramIn

theorem maximalUnramifiedFiniteStage_locally_unramified (F : Type) [Field F] [NumberField F]
    (p : в„•) [Fact (Nat.Prime p)]
    (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ)
    (s : Finset (maximalUnramifiedProPFIndex F p))
    [NumberField (maximalUnramifiedFiniteStage F p s)] :
    вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ (maximalUnramifiedFiniteStage F p s)),
      Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      intro рқ”“ hрқ”“
      simp [maximalUnramifiedFiniteStage, iSup_false] at hрқ”“ вҠў
      have hPrime : рқ”“.IsPrime := hрқ”“.1
      have hOver : рқ”“.LiesOver рқ”ӯ := hрқ”“.2
      have hempty : maximalUnramifiedFiniteStage F p (вҲ… : Finset (maximalUnramifiedProPFIndex F p)) =
          (вҠҘ : IntermediateField F (AlgebraicClosure F)) := by
        simp [maximalUnramifiedFiniteStage, iSup_false]
      let eStage : вҶҘ(maximalUnramifiedFiniteStage F p (вҲ… : Finset (maximalUnramifiedProPFIndex F p))) вүғвӮҗ[F] F :=
        (IntermediateField.equivOfEq (F := F) (E := AlgebraicClosure F) hempty).trans
          (IntermediateField.botEquiv F (AlgebraicClosure F))
      let e : (рқ“һ вҶҘ(maximalUnramifiedFiniteStage F p (вҲ… : Finset (maximalUnramifiedProPFIndex F p)))) вүғвӮҗ[рқ“һ F] (рқ“һ F) :=
        NumberField.RingOfIntegers.mapAlgEquiv eStage
      let Q : Ideal (рқ“һ F) := Ideal.map e рқ”“
      have hQOver : Q.LiesOver рқ”ӯ := by
        dsimp [Q]
        infer_instance
      have hQeq : Q = рқ”ӯ := by
        simpa [Q] using (Ideal.over_def (P := Q) (p := рқ”ӯ)).symm
      have hramQ : Ideal.ramificationIdx рқ”ӯ Q = 1 := by
        simpa [hQeq] using
          (Ideal.ramificationIdx_map_self_eq_one (R := рқ“һ F) (S := рқ“һ F)
            (hвӮҒ := by simpa using hp.ne_top)
            (hвӮӮ := by simpa using hne))
      have hmap : Ideal.ramificationIdx рқ”ӯ Q = Ideal.ramificationIdx рқ”ӯ рқ”“ := by
        simpa [Q] using
          (Ideal.ramificationIdx_map_eq (R := рқ“һ F) (S := рқ“һ вҶҘ(maximalUnramifiedFiniteStage F p вҲ…))
            (SвӮҒ := рқ“һ F) (p := рқ”ӯ) (P := рқ”“) e)
      exact hmap.symm.trans hramQ
  | @insert i s hi ih =>
      let S := maximalUnramifiedFiniteStage F p s
      letI : FiniteDimensional F вҶҘi.M := i.hfd
      letI : IsGalois F вҶҘi.M := i.hg
      letI : NumberField вҶҘi.M := i.hnf
      letI : вҲҖ j : maximalUnramifiedProPFIndex F p, FiniteDimensional F вҶҘ(j.M) := fun j => j.hfd
      letI : FiniteDimensional F вҶҘS := by
        simpa [S, maximalUnramifiedFiniteStage] using
          (IntermediateField.finiteDimensional_iSup_of_finset
            (K := F) (L := AlgebraicClosure F)
            (t := fun j : maximalUnramifiedProPFIndex F p => j.M) (s := s))
      letI : NumberField вҶҘS := NumberField.of_module_finite F S
      have hS_eq : S = вЁҶ j : {j // j вҲҲ s}, j.1.M := by
        dsimp [S, maximalUnramifiedFiniteStage]
        rw [вҶҗ Finset.iSup_coe (s := s) (f := fun j : maximalUnramifiedProPFIndex F p => j.M)]
        symm
        exact iSup_subtype
      have hS_normal' : Normal F вҶҘ(вЁҶ j : {j // j вҲҲ s}, j.1.M) := by
        letI : вҲҖ j : {j // j вҲҲ s}, Normal F вҶҘ(j.1.M) := fun j => j.1.hg.to_normal
        exact IntermediateField.normal_iSup (F := F) (t := fun j : {j // j вҲҲ s} => j.1.M)
      have hS_normal : Normal F вҶҘS := by
        rw [hS_eq]
        exact hS_normal'
      letI : IsGalois F вҶҘS := by
        rw [isGalois_iff]
        exact вҹЁinferInstance, hS_normalвҹ©
      have hstage : maximalUnramifiedFiniteStage F p (insert i s) = i.M вҠ” S := by
        simpa [S, maximalUnramifiedFiniteStage] using
          (Finset.iSup_insert i s (fun j : maximalUnramifiedProPFIndex F p => j.M))
      letI : FiniteDimensional F вҶҘ(i.M вҠ” S) := IntermediateField.finiteDimensional_sup (K := F) (E1 := i.M) (E2 := S)
      have hsup_normal : Normal F вҶҘ(i.M вҠ” S) := IntermediateField.normal_sup (E := i.M) (E' := S)
      letI : IsGalois F вҶҘ(i.M вҠ” S) := by
        rw [isGalois_iff]
        exact вҹЁinferInstance, hsup_normalвҹ©
      letI : NumberField вҶҘ(i.M вҠ” S) := NumberField.of_module_finite F вҶҘ(i.M вҠ” S)
      rw [hstage]
      simpa [S] using
        two_field_sup_locally_unramified F рқ”ӯ hp hne i.M S
          (fun рқ”” hрқ”” => i.hunr.unramified_at_finite рқ”ӯ рқ”” hp hne hрқ””)
          (fun рқ”” hрқ”” => ih рқ”” hрқ””)

theorem finite_galois_subextension_of_maximalUnramified_locally_unramified (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (рқ”ӯ : Ideal (рқ“һ F)) (hp : рқ”ӯ.IsPrime) (hne : рқ”ӯ вү  вҠҘ)
    (M : IntermediateField F (maximalUnramifiedProPF F p))
    [FiniteDimensional F M] [Normal F M] [NumberField M] :
    вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ M), Ideal.ramificationIdx рқ”ӯ рқ”“ = 1 := by
  classical
  intro рқ”“ hрқ”“
  let E : IntermediateField F (AlgebraicClosure F) := maximalUnramifiedProPF F p
  let M' : IntermediateField F (AlgebraicClosure F) := IntermediateField.lift M
  have hM_fg0 : M.FG := normal_numberField_intermediate_fg M
  have hM_fg : M'.FG := by
    rcases hM_fg0 with вҹЁs0, hs0вҹ©
    refine вҹЁs0.image (fun x : maximalUnramifiedProPF F p => (x : AlgebraicClosure F)), ?_вҹ©
    have hs0' : IntermediateField.lift (IntermediateField.adjoin F (вҶ‘s0 : Set (maximalUnramifiedProPF F p))) = M' := by
      simpa [M'] using congrArg (fun S : IntermediateField F (maximalUnramifiedProPF F p) => IntermediateField.lift S) hs0
    simpa [IntermediateField.lift, IntermediateField.adjoin_map, Finset.coe_image] using hs0'
  let t : maximalUnramifiedProPFIndex F p вҶ’ IntermediateField F (AlgebraicClosure F) := fun i => i.M
  have hEq : maximalUnramifiedProPF F p = вЁҶ i : maximalUnramifiedProPFIndex F p, t i := by
    simpa [t] using MaxUnramifiedProPGaloisGroup.maximalUnramifiedProPF_eq_iSup_index (F := F) (p := p)
  have hMle0 : M' вүӨ maximalUnramifiedProPF F p := by
    simpa [M', E] using (show IntermediateField.lift M вүӨ maximalUnramifiedProPF F p from IntermediateField.lift_le M)
  have hMle1 : M' вүӨ вЁҶ i : maximalUnramifiedProPFIndex F p, t i := by
    simpa [hEq] using hMle0
  obtain вҹЁs, hsвҹ© := fg_intermediateField_le_iSup_finset (M := M') hM_fg (t := t) hMle1
  let S : IntermediateField F (AlgebraicClosure F) := maximalUnramifiedFiniteStage F p s
  have hMleS : M' вүӨ S := by
    simpa [S, maximalUnramifiedFiniteStage, t] using hs
  letI : вҲҖ i : maximalUnramifiedProPFIndex F p, FiniteDimensional F (t i) := fun i => i.hfd
  letI : FiniteDimensional F S := by
    simpa [S, maximalUnramifiedFiniteStage, t] using
      (IntermediateField.finiteDimensional_iSup_of_finset (K := F) (L := AlgebraicClosure F) (t := t) (s := s))
  letI : NumberField S := NumberField.of_module_finite F S
  have hS_unr : вҲҖ рқ”” вҲҲ рқ”ӯ.primesOver (рқ“һ S), Ideal.ramificationIdx рқ”ӯ рқ”” = 1 :=
    maximalUnramifiedFiniteStage_locally_unramified F p рқ”ӯ hp hne s
  let f : M вҶ’вӮҗ[F] S :=
    (IntermediateField.inclusion hMleS).comp (IntermediateField.liftAlgEquiv M).toAlgHom
  let instMS : Algebra M S := f.toRingHom.toAlgebra
  let instTower : @IsScalarTower F M S _ instMS.toSMul _ := IsScalarTower.of_algHom f
  exact @local_unramified_descends_in_tower F M S _ _ _ _ _ _ _ _ instMS instTower _ _ рқ”ӯ hp hne hS_unr рқ”“ hрқ”“

theorem exists_splittingDetectorAt (F : Type) [Field F] [NumberField F] (p : в„•) [Fact (Nat.Prime p)]
    (рқ”ӯ : Ideal (рқ“һ F)) (_hp : рқ”ӯ.IsPrime) (_hne : рқ”ӯ вү  вҠҘ) :
    вҲғ Пғ : MaxUnramifiedProPGaloisGroup F p, IsSplittingDetectorAt F p рқ”ӯ Пғ := by
  classical
  letI : рқ”ӯ.IsPrime := _hp
  let K := maximalUnramifiedProPF F p
  let A : SplittingDetectorTestField F p вҶ’ Set (MaxUnramifiedProPGaloisGroup F p) := fun i => by
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M вүғвӮҗ[F] i.M) := i.hpG
    exact {Пғ | ((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := K) i.M) Пғ : i.M вүғвӮҗ[F] i.M) = 1 вҶ”
      вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ i.M), Ideal.inertiaDeg рқ”ӯ рқ”“ = 1}
  have hclosed : вҲҖ i, IsClosed (A i) := by
    intro i
    dsimp [A]
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M вүғвӮҗ[F] i.M) := i.hpG
    let res : MaxUnramifiedProPGaloisGroup F p вҶ’ (i.M вүғвӮҗ[F] i.M) :=
      AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := K) i.M
    have hres : Continuous res := by
      simpa [res, K] using
        (InfiniteGalois.restrictNormalHom_continuous (k := F) (K := K) i.M)
    letI : DiscreteTopology (i.M вүғвӮҗ[F] i.M) :=
      krullTopology_discreteTopology_of_finiteDimensional F i.M
    by_cases hsplit : вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ i.M), Ideal.inertiaDeg рқ”ӯ рқ”“ = 1
    В· let S : Set (i.M вүғвӮҗ[F] i.M) := {(1 : i.M вүғвӮҗ[F] i.M)}
      have hS : IsClosed S := isClosed_discrete S
      have hA : {Пғ : MaxUnramifiedProPGaloisGroup F p |
          (res Пғ = 1 вҶ” вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ i.M), Ideal.inertiaDeg рқ”ӯ рқ”“ = 1)} = res вҒ»В№' S := by
        ext Пғ
        constructor
        В· intro h
          exact h.mpr hsplit
        В· intro hПғ
          constructor
          В· intro _
            exact hsplit
          В· intro _
            exact hПғ
      rw [hA]
      exact IsClosed.preimage hres hS
    В· let S : Set (i.M вүғвӮҗ[F] i.M) := ({(1 : i.M вүғвӮҗ[F] i.M)} : Set (i.M вүғвӮҗ[F] i.M))б¶ң
      have hS : IsClosed S := isClosed_discrete S
      have hA : {Пғ : MaxUnramifiedProPGaloisGroup F p |
          (res Пғ = 1 вҶ” вҲҖ рқ”“ вҲҲ рқ”ӯ.primesOver (рқ“һ i.M), Ideal.inertiaDeg рқ”ӯ рқ”“ = 1)} = res вҒ»В№' S := by
        ext Пғ
        constructor
        В· intro h hПғ
          exact hsplit (h.mp hПғ)
        В· intro hПғ
          constructor
          В· intro hEq
            exact False.elim (hПғ hEq)
          В· intro hsplit'
            exact False.elim (hsplit hsplit')
      rw [hA]
      exact IsClosed.preimage hres hS
  have hFIP : вҲҖ s : Finset (SplittingDetectorTestField F p), (вӢӮ i вҲҲ s, A i).Nonempty := by
    intro s
    let О№s : Type := {i : SplittingDetectorTestField F p // i вҲҲ (вҶ‘s : Set (SplittingDetectorTestField F p))}
    let N : IntermediateField F K := вЁҶ i : О№s, i.1.M
    have hle : вҲҖ {i : SplittingDetectorTestField F p}, i вҲҲ s вҶ’ i.M вүӨ N := by
      intro i hi
      exact le_iSup (fun j : О№s => j.1.M) вҹЁi, by simpa using hiвҹ©
    letI : Finite О№s := by infer_instance
    letI : вҲҖ i : О№s, FiniteDimensional F i.1.M := fun i => i.1.hfd
    letI : FiniteDimensional F N := by
      simpa [N] using
        (IntermediateField.finiteDimensional_iSup_of_finite
          (K := F) (L := K) (t := fun i : О№s => i.1.M))
    letI : вҲҖ i : О№s, Normal F i.1.M := fun i => i.1.hnorm
    letI : Normal F N := by
      simpa [N] using
        (IntermediateField.normal_iSup (F := F) (K := K) (t := fun i : О№s => i.1.M))
    letI : IsGalois F N := by
      rw [isGalois_iff]
      exact вҹЁinferInstance, inferInstanceвҹ©
    letI : NumberField N := NumberField.of_module_finite F N
    letI : рқ”ӯ.IsMaximal := Ideal.IsPrime.isMaximal _hp _hne
    have hQnonempty : Nonempty (рқ”ӯ.primesOver (рқ“һ N)) := by
      simpa using (Ideal.nonempty_primesOver (R := рқ“һ F) (S := рқ“һ N) рқ”ӯ)
    let Qs : рқ”ӯ.primesOver (рқ“һ N) := Classical.choice hQnonempty
    let рқ”” : Ideal (рқ“һ N) := Qs.1
    have hрқ”” : рқ”” вҲҲ рқ”ӯ.primesOver (рқ“һ N) := Qs.2
    letI : рқ””.IsPrime := Qs.2.1
    letI : рқ””.LiesOver рқ”ӯ := Qs.2.2
    letI : рқ””.IsMaximal := by
      change Qs.1.IsMaximal
      exact Ideal.primesOver.isMaximal Qs
    have hQne : рқ”” вү  вҠҘ := by
      exact Ring.ne_bot_of_isMaximal_of_not_isField inferInstance (NumberField.RingOfIntegers.not_isField N)
    haveI : Module.Finite в„Ө (рқ“һ N) := by infer_instance
    letI : Finite (рқ“һ N в§ё рқ””) := Ideal.finiteQuotientOfFreeOfNeBot рқ”” hQne
    have hramN :=
      finite_galois_subextension_of_maximalUnramified_locally_unramified
        F p рқ”ӯ _hp _hne N
    have hramQ : Ideal.ramificationIdx рқ”ӯ рқ”” = 1 := hramN рқ”” hрқ””
    let П„ : N вүғвӮҗ[F] N := arithFrobAt (R := рқ“һ F) (G := N вүғвӮҗ[F] N) рқ””
    have hП„ : AlgHom.IsArithFrobAt (R := рқ“һ F)
        ((NumberField.RingOfIntegers.mapAlgEquiv П„).toAlgHom) рқ”” := by
      change IsArithFrobAt (R := рқ“һ F) П„ рқ””
      simpa [П„] using (IsArithFrobAt.arithFrobAt (R := рқ“һ F) (G := N вүғвӮҗ[F] N) (Q := рқ””))
    have hsurj := maximalUnramified_restrictNormalHom_surjective (F := F) (p := p) N
    obtain вҹЁПғ, hПғNвҹ© := hsurj П„
    refine вҹЁПғ, ?_вҹ©
    simp only [Set.mem_iInter]
    intro i hi
    letI : FiniteDimensional F i.M := i.hfd
    letI : Normal F i.M := i.hnorm
    letI : NumberField i.M := i.hnf
    letI : IsPGroup p (i.M вүғвӮҗ[F] i.M) := i.hpG
    letI : IsGalois F i.M := by
      rw [isGalois_iff]
      exact вҹЁinferInstance, inferInstanceвҹ©
    let f_incl : i.M вҶ’вӮҗ[F] N := IntermediateField.inclusion (hle hi)
    let instMN : Algebra i.M N := f_incl.toRingHom.toAlgebra
    letI : Algebra i.M N := instMN
    letI : SMul i.M N := instMN.toSMul
    letI : IsScalarTower F i.M N := IsScalarTower.of_algHom f_incl
    let f : (рқ“һ i.M) вҶ’вӮҗ[рқ“һ F] (рқ“һ N) := NumberField.RingOfIntegers.mapAlgHom f_incl
    let рқ”“0 : Ideal (рқ“һ i.M) := Ideal.comap f рқ””
    have hрқ”“0 : рқ”“0 вҲҲ рқ”ӯ.primesOver (рқ“һ i.M) := by
      letI : рқ”“0.IsPrime := Ideal.comap_isPrime f.toRingHom рқ””
      letI : рқ”“0.LiesOver рқ”ӯ := Ideal.comap_liesOver (Q := рқ””) (p := рқ”ӯ) f
      exact (Ideal.primesOver.mk (p := рқ”ӯ) рқ”“0).2
    have hrami :=
      finite_galois_subextension_of_maximalUnramified_locally_unramified
        F p рқ”ӯ _hp _hne i.M
    have hramрқ”“0 : Ideal.ramificationIdx рқ”ӯ рқ”“0 = 1 := hrami рқ”“0 hрқ”“0
    have hП„i : AlgHom.IsArithFrobAt (R := рқ“һ F)
        ((NumberField.RingOfIntegers.mapAlgEquiv
          (((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := N) i.M) П„))).toAlgHom) рқ”“0 := by
      simpa [рқ”“0, f] using (isArithFrobAt_restrictNormal F i.M N рқ”ӯ рқ”” hрқ”” П„ hП„)
    let valN : N вҶ’вӮҗ[i.M] K :=
      { toRingHom := (IntermediateField.val N).toRingHom
        commutes' := by
          intro x
          rfl }
    letI : IsScalarTower i.M N K := IsScalarTower.of_algHom valN
    have hresПғ :
        (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := K) i.M) Пғ =
          (AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := N) i.M) П„ := by
      rw [IsScalarTower.AlgEquiv.restrictNormalHom_comp_apply (F := F) (KвӮҒ := i.M) (KвӮӮ := N) (f := Пғ)]
      rw [hПғN]
    have hiff0 :
        ((AlgEquiv.restrictNormalHom (F := F) (KвӮҒ := N) i.M) П„ : i.M вүғвӮҗ[F] i.M) = 1 вҶ”
          Ideal.inertiaDeg рқ”ӯ рқ”“0 = 1 := by

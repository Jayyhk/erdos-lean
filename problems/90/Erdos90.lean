  have habs := fun_zmod3_equiv_pow_three_and_comm (k + 1) (M вүғвӮҗ[в„ҡ] M) e
  rcases habs with вҹЁhpow_abs, hcomm_absвҹ©
  have hpow_rel : вҲҖ Пғ : M вүғвӮҗ[F] M, Пғ ^ 3 = 1 := by
    intro Пғ

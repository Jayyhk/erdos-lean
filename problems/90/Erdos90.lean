  let ПҒ1 : (M0 вүғвӮҗ[в„ҡ] M0) вҶ’* (J1 вүғвӮҗ[в„ҡ] J1) :=
    @AlgEquiv.restrictNormalHom в„ҡ _ M0 _ _ J1 _ _ _ _ hNJ1
  let ПҒ2 : (M0 вүғвӮҗ[в„ҡ] M0) вҶ’* (J2 вүғвӮҗ[в„ҡ] J2) :=
    @AlgEquiv.restrictNormalHom в„ҡ _ M0 _ _ J2 _ _ _ _ hNJ2
  have hpair_injective :
      Function.Injective (fun П„ : M0 вүғвӮҗ[в„ҡ] M0 => (ПҒ1 П„, ПҒ2 П„)) := by
    simpa [ПҒ1, ПҒ2] using
      (@restrictNormalHom_pair_injective_of_sup_eq_top в„ҡ M0 _ _ _ J1 J2 hNJ1 hNJ2 hJsup)
  obtain вҹЁgalJ1вҹ© :=

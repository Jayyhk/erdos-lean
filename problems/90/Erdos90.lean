  omega

theorem rel_discr_eq_of_nonvanishing_on_inertia (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]
    [IsTotallyReal M] [IsGalois в„ҡ M]
    (e : (M вүғвӮҗ[в„ҡ] M) вүғ* Multiplicative (Fin в„“ вҶ’ ZMod 3))
    (Пғ : Fin в„“ вҶ’ (M вүғвӮҗ[в„ҡ] M))
    (_hПғ_mem : вҲҖ i, вҲғ P : Ideal (рқ“һ M),
      P вҲҲ (Ideal.span {(r i : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M) вҲ§
      Nat.card (P.inertia (M вүғвӮҗ[в„ҡ] M)) = 3 вҲ§
      Пғ i вҲҲ P.inertia (M вүғвӮҗ[в„ҡ] M) вҲ§
      Пғ i вү  1)
    (lin : (Fin в„“ вҶ’ ZMod 3) вҶ’вӮ—[ZMod 3] ZMod 3)
    (_hlinv : вҲҖ i, lin (Multiplicative.toAdd (e (Пғ i))) вү  0)
    (_hdisc : (NumberField.discr M).natAbs = (вҲҸ i, r i) ^ (2 * 3 ^ (в„“ - 1))) :
    let ПҲ := linearMapToCharacter в„“ lin
    let ПҶ : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (ZMod 3) := ПҲ.comp e
    let H : Subgroup (M вүғвӮҗ[в„ҡ] M) := ПҶ.ker
    let F : IntermediateField в„ҡ M := IntermediateField.fixedField H
    (NumberField.discr M).natAbs =
      (NumberField.discr F).natAbs ^ Module.finrank F M := by
  classical
  let ПҲ := linearMapToCharacter в„“ lin
  let ПҶ : (M вүғвӮҗ[в„ҡ] M) вҶ’* Multiplicative (ZMod 3) := ПҲ.comp e
  let H : Subgroup (M вүғвӮҗ[в„ҡ] M) := ПҶ.ker
  let F : IntermediateField в„ҡ M := IntermediateField.fixedField H
  letI : NumberField F := NumberField.of_intermediateField F
  have hlocal : вҲҖ i (P : Ideal (рқ“һ M)),
      P вҲҲ (Ideal.span {(r i : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M) вҶ’
      В¬ P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M) := by
    simpa [ПҲ, ПҶ, H, F] using
      (all_primes_over_ri_not_dvd_differentIdeal_of_nonvanishing в„“ r M e Пғ _hПғ_mem lin _hlinv)
  have hnotdvd_all : вҲҖ P : Ideal (рқ“һ M), P.IsPrime вҶ’ В¬ P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M) := by
    intro P hPprime
    by_cases hPbot : P = вҠҘ
    В· subst hPbot
      rw [Ideal.dvd_iff_le, le_bot_iff]
      exact differentIdeal_ne_bot (A := рқ“һ F) (B := рқ“һ M)
    В· letI : P.IsPrime := hPprime
      letI : NeZero P := вҹЁhPbotвҹ©
      let q : в„• := Ideal.absNorm (Ideal.under в„Ө P)
      have hqprime : q.Prime := by
        dsimp [q]
        simpa using (Nat.absNorm_under_prime P)
      by_cases hq_mem : вҲғ i : Fin в„“, r i = q
      В· rcases hq_mem with вҹЁi, hriqвҹ©
        have hPover : P вҲҲ (Ideal.span {(r i : в„Ө)} : Ideal в„Ө).primesOver (рқ“һ M) := by
          refine вҹЁhPprime, ?_вҹ©
          simpa [q, hriq] using (show P.LiesOver (Ideal.span {(q : в„Ө)}) from Int.liesOver_span_absNorm P)
        exact hlocal i P hPover
      В· have hq_not_dvd_prod : В¬ q вҲЈ вҲҸ i, r i := by
          intro hqdvd
          have hqprime' : Prime q := (Nat.prime_iff).1 hqprime
          rcases Prime.exists_mem_finset_dvd hqprime' (s := Finset.univ) (f := r) hqdvd with вҹЁi, _, hqiвҹ©
          have hEq : q = r i := (Nat.prime_dvd_prime_iff_eq hqprime (_hr_prime i)).1 hqi
          exact hq_mem вҹЁi, hEq.symmвҹ©
        have hq_not_dvd_disc : В¬ q вҲЈ (NumberField.discr M).natAbs := by
          rw [_hdisc]
          intro hqdvd
          exact hq_not_dvd_prod (hqprime.dvd_of_dvd_pow hqdvd)
        have hP_not_dvd_diffZ : В¬ P вҲЈ differentIdeal в„Ө (рқ“һ M) := by
          intro hPdvdZ
          have hle : differentIdeal в„Ө (рқ“һ M) вүӨ P := (Ideal.dvd_iff_le).1 hPdvdZ
          have hPnorm_dvd :
              Ideal.absNorm P вҲЈ Ideal.absNorm (differentIdeal в„Ө (рқ“һ M)) :=
            Ideal.absNorm_dvd_absNorm_of_le hle
          have hq_dvd_Pnorm : q вҲЈ Ideal.absNorm P := by
            dsimp [q]
            exact Int.absNorm_under_dvd_absNorm P
          have hq_dvd_diffnorm : q вҲЈ Ideal.absNorm (differentIdeal в„Ө (рқ“һ M)) :=
            dvd_trans hq_dvd_Pnorm hPnorm_dvd
          exact hq_not_dvd_disc (by
            simpa [NumberField.absNorm_differentIdeal (K := M) (рқ’Ә := рқ“һ M)] using hq_dvd_diffnorm)
        have h_unram_Z : Algebra.IsUnramifiedAt в„Ө P :=
          (not_dvd_differentIdeal_iff).1 hP_not_dvd_diffZ
        have h_unram_F : Algebra.IsUnramifiedAt (рқ“һ F) P := by
          letI : Algebra.IsUnramifiedAt в„Ө P := h_unram_Z
          exact Algebra.IsUnramifiedAt.of_restrictScalars (R := в„Ө) (A := рқ“һ F) (B := рқ“һ M) P
        exact (not_dvd_differentIdeal_iff).2 h_unram_F
  have hdisc_eq :
      (NumberField.discr M).natAbs =
        (NumberField.discr F).natAbs ^ Module.finrank F M :=
    discr_eq_of_not_dvd_differentIdeal_at_all_primes F M hnotdvd_all
  simpa [ПҲ, ПҶ, H, F] using hdisc_eq

theorem exists_good_linear_map_rel_discr (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (M : Type) [Field M] [CharZero M] [NumberField M]

    вҹЁL, _instF, _instCZ, _instNF, _instTR, _instGal, _instAlg, hdeg, hdiscвҹ©
  refine вҹЁL, inferInstance, inferInstance, inferInstance, inferInstance,
    inferInstance, inferInstance, hdeg, hdisc, ?_вҹ©
  letI : Fact (Nat.Prime 3) := вҹЁby decideвҹ©
  have hcardL : Nat.card (L вүғвӮҗ[в„ҡ] L) = 3 := by
    simpa [hdeg] using (IsGalois.card_aut_eq_finrank в„ҡ L)
  have hcardZ : Nat.card (Multiplicative (ZMod 3)) = 3 := by
    rw [Nat.card_eq_fintype_card, Fintype.card_multiplicative, ZMod.card]
  exact вҹЁmulEquivOfPrimeCardEq hcardL hcardZвҹ©

theorem discr_eq_of_not_dvd_differentIdeal_at_all_primes (F M : Type) [Field F] [Field M] [NumberField F] [NumberField M]
    [Algebra F M] [FiniteDimensional F M] [IsScalarTower в„ҡ F M]
    (_hnotdvd : вҲҖ P : Ideal (рқ“һ M), P.IsPrime вҶ’ В¬ P вҲЈ differentIdeal (рқ“һ F) (рқ“һ M)) :
    (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M := by
  let D : Ideal (рқ“һ M) := differentIdeal (рқ“һ F) (рқ“һ M)

      hnear'.filter_mono nhdsWithin_le_nhds
    have hmem : вҲҖб¶  w : в„Ӯ in nhdsWithin z S, w вҲҲ S := by
      change S вҲҲ nhds z вҠ“ Filter.principal S
      simpa using Filter.inter_mem_inf (Filter.univ_mem : Set.univ вҲҲ nhds z)
        (by simp [Filter.mem_principal])
    have hnear_mem : вҲҖб¶  w : в„Ӯ in nhdsWithin z S, w.re < z.re + 1 вҲ§ w вҲҲ S := by
      filter_upwards [hnear, hmem] with w hwre hwS
      exact вҹЁhwre, hwSвҹ©

          вҖ–вҲ« t in (0 : в„қ)..1,
            ((leftTentKernel ((1 / 2 : в„қ) - t)).re * g t - (ПҲ ((1 / 2 : в„қ) - t)).re * g t)вҖ– := by
            rw [вҶҗ intervalIntegral.integral_sub hL2 hP2, Real.norm_eq_abs]
      _ вүӨ вҲ« t in (0 : в„қ)..1, C * K ((1 / 2 : в„қ) - t) := by
        exact intervalIntegral.norm_integral_le_of_norm_le (Ој := MeasureTheory.volume) h01
          (Filter.Eventually.of_forall (fun t ht => by
            have ht' : t вҲҲ Set.Icc (0 : в„қ) 1 := вҹЁle_of_lt ht.1, ht.2вҹ©
            have hgt : |g t| вүӨ C := hbound t ht'

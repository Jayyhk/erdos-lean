    intro n
    rw [вҶҗ QuotientGroup.isOpenQuotientMap_mk.continuous_comp_iff]
    simpa [Function.comp, QuotientGroup.map_mk'] using
      (QuotientGroup.continuous_mk (N := R n))
  let q : вҲҖ n, C(G в§ё N, G в§ё R n) := fun n =>
    вҹЁQuotientGroup.map N (R n) (MonoidHom.id G)
      (show N вүӨ R n from le_sup_left), hqcont nвҹ©
  let aSeq : вҲҖ n, C(G в§ё N, G в§ё (W n).toSubgroup) := fun n => (t n).1.comp (q n)
  have hstepA : вҲҖ n (x : G в§ё N),
      QuotientGroup.map (W (n + 1)).toSubgroup (W n).toSubgroup (MonoidHom.id G)
        (show (W (n + 1)).toSubgroup вүӨ (W n).toSubgroup from hWdesc n)

theorem proposition_2_2_prime_family_L (рқ’ҹ : AdmissibleDatum) (b : Fin рқ’ҹ.t) :
    вҲғ p : Fin рқ’ҹ.f вҶ’ Ideal (рқ“һ рқ’ҹ.L),
      (вҲҖ i, p i вү  вҠҘ) вҲ§
      (вҲҖ i, (p i).IsPrime) вҲ§
      (вҲҖ {i j}, i вү  j вҶ’ p i вү  p j) вҲ§
      (вҲҖ i,
        (p i).LiesOver (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) вҲ§
        Ideal.ramificationIdx (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) (p i) = 1 вҲ§
        Ideal.inertiaDeg (Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)) (p i) = 1) вҲ§
      ((вҲҸ i : Fin рқ’ҹ.f, p i) = Ideal.span ({(рқ’ҹ.q b : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L))) := by
  classical
  let qid : Ideal в„Ө := Ideal.span ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө)
  let s : Finset (Ideal (рқ“һ рқ’ҹ.L)) := primesOverFinset qid (рқ“һ рқ’ҹ.L)
  have hqid0 : qid вү  вҠҘ := by
    dsimp [qid]
    simp [Nat.Prime.ne_zero (рқ’ҹ.q_prime b)]
  have hqid_prime : qid.IsPrime := by
    dsimp [qid]
    rw [Ideal.span_singleton_prime]
    В· exact (Nat.prime_iff_prime_int).mp (рқ’ҹ.q_prime b)
    В· exact_mod_cast (Nat.Prime.ne_zero (рқ’ҹ.q_prime b))
  letI : qid.IsMaximal := Ideal.IsPrime.isMaximal hqid_prime hqid0
  have hs_card : s.card = рқ’ҹ.f := by
    have hs_ncard : (s : Set (Ideal (рқ“һ рқ’ҹ.L))).ncard = рқ’ҹ.f := by
      calc
        (s : Set (Ideal (рқ“һ рқ’ҹ.L))).ncard = (qid.primesOver (рқ“һ рқ’ҹ.L)).ncard := by
          simpa [s] using congrArg Set.ncard (coe_primesOverFinset (p := qid) (B := рқ“һ рқ’ҹ.L) hqid0)
        _ = Module.finrank в„ҡ рқ’ҹ.L := (рқ’ҹ.q_splits_in_L b).2
        _ = рқ’ҹ.f := by rfl
    simpa using hs_ncard
  let e : Fin рқ’ҹ.f вүғ s := (Finset.equivFinOfCardEq (s := s) hs_card).symm
  refine вҹЁfun i => ((e i : s) : Ideal (рқ“һ рқ’ҹ.L)), ?_вҹ©
  constructor
  В· intro i
    simpa [s] using (Ideal.Factors.ne_bot qid (e i))
  constructor
  В· intro i
    simpa [s] using (Ideal.Factors.isPrime qid (e i))
  constructor
  В· intro i j hij hpij
    apply hij
    apply e.injective
    exact Subtype.ext hpij
  constructor
  В· intro i
    have hmem_s : (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))) вҲҲ s := (e i).property
    have hmem : (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))) вҲҲ qid.primesOver (рқ“һ рқ’ҹ.L) := by
      exact (mem_primesOverFinset_iff (p := qid) (B := рқ“һ рқ’ҹ.L) hqid0).mp (by simp [s])
    have hsplit : Ideal.ramificationIdx qid (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))) = 1 вҲ§
        Ideal.inertiaDeg qid (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))) = 1 := by
      simpa [qid] using (рқ’ҹ.q_splits_in_L b).1 (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))) hmem
    exact вҹЁhmem.2, hsplit.1, hsplit.2вҹ©
  В· let I : Ideal (рқ“һ рқ’ҹ.L) := Ideal.map (algebraMap в„Ө (рқ“һ рқ’ҹ.L)) qid
    have hI0 : I вү  вҠҘ := by
      dsimp [I]
      exact Ideal.map_ne_bot_of_ne_bot hqid0
    have hcount1 : вҲҖ P вҲҲ s, Multiset.count P (UniqueFactorizationMonoid.factors I) = 1 := by
      intro P hP
      have hmem : P вҲҲ qid.primesOver (рқ“һ рқ’ҹ.L) := by
        exact (mem_primesOverFinset_iff (p := qid) (B := рқ“һ рқ’ҹ.L) hqid0).mp (by simpa [s] using hP)
      have hP0 : P вү  вҠҘ := Ideal.ne_bot_of_mem_primesOver hqid0 hmem
      have hPprime : P.IsPrime := hmem.1
      have hram : Ideal.ramificationIdx qid P = 1 := by
        simpa [qid] using ((рқ’ҹ.q_splits_in_L b).1 P hmem).1
      rw [Ideal.IsDedekindDomain.ramificationIdx_eq_factors_count (by simpa [I] using hI0) hPprime hP0] at hram
      simpa [I] using hram
    have hprod_enum :
        (вҲҸ i : Fin рқ’ҹ.f, (((e i : s) : Ideal (рқ“һ рқ’ҹ.L)))) = вҲҸ x : s, ((x : Ideal (рқ“һ рқ’ҹ.L))) := by
      exact Fintype.prod_equiv e (fun i => (((e i : s) : Ideal (рқ“һ рқ’ҹ.L))))
        (fun x => ((x : Ideal (рқ“һ рқ’ҹ.L)))) (fun _ => rfl)
    have hprod_subtype : (вҲҸ x : s, ((x : Ideal (рқ“һ рқ’ҹ.L)))) = вҲҸ P вҲҲ s, P := by
      simpa [Finset.univ_eq_attach] using
        (Finset.prod_attach s (fun P : Ideal (рқ“һ рқ’ҹ.L) => P))
    have hprod_s : вҲҸ P вҲҲ s, P = I := by
      calc
        вҲҸ P вҲҲ s, P = вҲҸ P вҲҲ s, P ^ Multiset.count P (UniqueFactorizationMonoid.factors I) := by
          apply Finset.prod_congr rfl
          intro P hP
          rw [hcount1 P hP, pow_one]
        _ = (UniqueFactorizationMonoid.factors I).prod := by
          symm
          simpa [s, I, primesOverFinset] using
            (Finset.prod_multiset_count (s := UniqueFactorizationMonoid.factors I))
        _ = I := by
          rw [UniqueFactorizationMonoid.factors_eq_normalizedFactors, prod_normalizedFactors_eq_self hI0]
    calc
      (вҲҸ i : Fin рқ’ҹ.f, (((e i : s) : Ideal (рқ“һ рқ’ҹ.L)))) = вҲҸ x : s, ((x : Ideal (рқ“һ рқ’ҹ.L))) := hprod_enum
      _ = вҲҸ P вҲҲ s, P := hprod_subtype
      _ = I := hprod_s
      _ = Ideal.span ({(рқ’ҹ.q b : рқ“һ рқ’ҹ.L)} : Set (рқ“һ рқ’ҹ.L)) := by
        dsimp [I, qid]
        simpa using (Ideal.map_span (algebraMap в„Ө (рқ“һ рқ’ҹ.L)) ({(рқ’ҹ.q b : в„Ө)} : Set в„Ө))


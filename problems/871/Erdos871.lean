    simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hk)] at hQ
    simp only [Finset.mem_image, Finset.mem_Icc] at hQ
    obtain ⟨u, ⟨hu_lo, hu_hi⟩, rfl⟩ := hQ
    simp only [N]
    have hgrow := seq.exponential_growth k hk
    have hbound := seq.growth_bound k hk
    have h3ku : 3 * k * u ≤ 3 * k * (k + 1) := Nat.mul_le_mul_left (3*k) hu_hi
    have h5n : 5 * seq.n (k-1) ≥ 3 * k * (k + 1) + 1 := by nlinarith [hbound]
    omega
  · have hR_lo := (seq.R_subset k hk x hR).1
    have hgrow := seq.exponential_growth k hk
    have hnpos := seq.n_pos (k-1)
    simp only [N]
    omega
/-- For j > k, B_j elements are all > N_k -/
lemma B_j_gt_N_k (seq : NathansonSeq) (j k : ℕ) (hjk : j > k) (hj : 1 ≤ j) :
    ∀ x ∈ seq.B_k j, x > seq.N k := by
  intro x hx
  have hlb := seq.B_k_lower_bound j hj x hx
  have hle : k ≤ j - 1 := by omega
  have hN_mono := seq.N_mono_le hle
  omega
/-- For j < k with j ≥ 1, B_j elements are all ≤ n_{k-1} + N_{k-2} -/
lemma B_j_le_bound (seq : NathansonSeq) (j k : ℕ) (hjk : j < k) (hj : 1 ≤ j) :
    ∀ x ∈ seq.B_k j, x ≤ seq.n (k-1) + seq.N (k-2) := by
  intro x hx
  have hub := seq.B_k_upper_bound j hj x hx
  have hle_n : j ≤ k - 1 := by omega
  have hle_N : j - 1 ≤ k - 2 := by omega
  have hn_mono := seq.n_mono_le hle_n
  have hN_mono := seq.N_mono_le hle_N
  omega
/-!
# Lemma 3
-/
/-- Lemma 3(i): N_k is not representable as a sum of two elements of B -/
theorem lemma3_part1 (seq : NathansonSeq) (k : ℕ) :
    ¬∃ (a b : ℕ), seq.inB a ∧ seq.inB b ∧ a + b = seq.N k := by
  intro ⟨c, d, hc, hd, hcd⟩
  wlog hle : c ≤ d generalizing c d
  · push_neg at hle
    exact this d c hd hc (by omega) (le_of_lt hle)
  have hc_le : c ≤ seq.n k := by simp only [N] at hcd; omega
  have hd_ge : seq.n k + 1 ≤ d := by simp only [N] at hcd; omega
  obtain hk0 | hkpos := Nat.eq_zero_or_pos k
  · subst hk0
    obtain ⟨kc, hkc, hcmem⟩ := hc
    obtain ⟨kd, hkd, hdmem⟩ := hd
    have hc_bound : 2 * seq.n 0 + 2 ≤ c := by
      simp only [B_k] at hcmem
      rw [Finset.mem_union, Finset.mem_union] at hcmem
      rcases hcmem with (hP | hQ) | hR
      · -- c ∈ P_kc: elements are ≥ N_{kc-1} + 1 ≥ N_0 + 1 = 2n_0 + 2
        have hP_lo := (seq.P_subset kc hkc c hP).1
        have hN_mono := seq.N_mono_from_zero (kc - 1)
        simp only [N] at hP_lo hN_mono
        omega
      · -- c ∈ Q_kc: Use the helper lemma
        simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hkc)] at hQ
        simp only [Finset.mem_image, Finset.mem_Icc] at hQ
        obtain ⟨u, ⟨hu_lo, hu_hi⟩, rfl⟩ := hQ
        exact seq.Q_element_lower_bound kc hkc u hu_lo hu_hi
      · -- c ∈ R_kc: elements are ≥ n_kc + 1 ≥ n_0 + 1
        have hR_lo := (seq.R_subset kc hkc c hR).1
        have hmono := seq.n_mono_from_zero kc
        omega
    simp only [N] at hcd
    omega
  obtain ⟨kc, hkc, hcmem⟩ := hc
  obtain ⟨kd, hkd, hdmem⟩ := hd
  have hkd_le_k : kd ≤ k := by
    by_contra hkd_gt
    push_neg at hkd_gt
    have hd_gt := seq.B_j_gt_N_k kd k hkd_gt hkd d hdmem
    simp only [N] at hcd hd_gt
    omega
  have hkd_eq_k : kd = k := by
    rcases hkd_le_k.lt_or_eq with hkd_lt | hkd_eq
    · -- kd < k: B_{kd} elements are ≤ n_{k-1} + N_{k-2}, which is << n_k + 1
      exfalso
      have hd_small := seq.B_j_le_bound kd k hkd_lt hkd d hdmem
      have hgrowk := seq.exponential_growth k hkpos
      by_cases hk1 : k = 1
      · -- k = 1: kd < 1 means kd = 0, but kd ≥ 1 from hkd
        omega
      · -- k ≥ 2: use exponential growth for k-1
        have hk2 : k - 1 ≥ 1 := by omega
        have hgrowkm1 := seq.exponential_growth (k-1) hk2
        have h7n : 7 * seq.n (k-1) > 2 * seq.n (k-2) := by
          calc 7 * seq.n (k-1) ≥ 7 * (8 * seq.n (k-2)) := Nat.mul_le_mul_left 7 hgrowkm1
            _ = 56 * seq.n (k-2) := by ring
            _ > 2 * seq.n (k-2) := by have := seq.n_pos (k-2); omega
        simp only [N] at hd_small
        omega
    · exact hkd_eq
  rw [hkd_eq_k] at hdmem
  simp only [B_k] at hdmem
  rw [Finset.mem_union, Finset.mem_union] at hdmem
  rcases hdmem with (hP | hQ) | hR
  · -- d ∈ P_k: d ≤ n_k - N_{k-1} < n_k < n_k + 1, contradiction
    have hP_hi := (seq.P_subset k hkpos d hP).2
    have hgrow := seq.exponential_growth k hkpos
    simp only [N] at hcd
    omega
  · -- d ∈ Q_k: d < n_k < n_k + 1, contradiction
    have hQ_small := seq.Q_lt_n k hkpos d hQ
    omega
  · -- d ∈ R_k: Now show c ∉ B
    simp only [R, if_neg (Nat.one_le_iff_ne_zero.mp hkpos)] at hR
    simp only [Finset.mem_sdiff, Finset.mem_Icc, Finset.mem_image, Finset.mem_Icc,
               not_exists, not_and] at hR
    obtain ⟨⟨hd_lo, hd_hi⟩, hd_not_excl⟩ := hR
    have hc_lo' : c ≥ seq.n k - 2 * seq.n (k-1) := by
      simp only [N] at hcd hd_hi
      omega
    have hkc_le_k : kc ≤ k := by
      by_contra hkc_gt
      push_neg at hkc_gt
      have hc_gt := seq.B_j_gt_N_k kc k hkc_gt hkc c hcmem
      simp only [N] at hcd hc_gt
      omega
    have hkc_eq_k : kc = k := by
      rcases hkc_le_k.lt_or_eq with hkc_lt | hkc_eq
      · exfalso
        have hc_small := seq.B_j_le_bound kc k hkc_lt hkc c hcmem
        have hgrowk := seq.exponential_growth k hkpos
        by_cases hk1 : k = 1
        · -- k = 1: kc < 1 means kc = 0, but kc ≥ 1
          omega
        · -- k ≥ 2
          have hk2 : k - 1 ≥ 1 := by omega
          have hgrowkm1 := seq.exponential_growth (k-1) hk2
          have hn_pos := seq.n_pos (k-1)
          have h5n : 5 * seq.n (k-1) > 2 * seq.n (k-2) + 1 := by
            calc 5 * seq.n (k-1) ≥ 5 * (8 * seq.n (k-2)) := Nat.mul_le_mul_left 5 hgrowkm1
              _ = 40 * seq.n (k-2) := by ring
              _ > 2 * seq.n (k-2) + 1 := by have := seq.n_pos (k-2); omega
          simp only [N] at hc_small
          omega
      · exact hkc_eq
    rw [hkc_eq_k] at hcmem
    simp only [B_k] at hcmem
    rw [Finset.mem_union, Finset.mem_union] at hcmem
    rcases hcmem with (hcP | hcQ) | hcR
    · -- c ∈ P_k: c ≤ n_k - N_{k-1} = n_k - 2n_{k-1} - 1, but c ≥ n_k - 2n_{k-1}
      have hP_hi := (seq.P_subset k hkpos c hcP).2
      have hgrow := seq.exponential_growth k hkpos
      simp only [N] at hcd
      simp only [P, if_neg (Nat.one_le_iff_ne_zero.mp hkpos), Finset.mem_Icc] at hcP
      simp only [N] at hcP
      omega
    · -- c ∈ Q_k: c = n_k - n_{k-1} - 3ku + 1 for some u ∈ [1, k+1]
      simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hkpos)] at hcQ
      simp only [Finset.mem_image, Finset.mem_Icc] at hcQ
      obtain ⟨u, ⟨hu_lo, hu_hi⟩, hc_eq⟩ := hcQ
      have hgrow := seq.exponential_growth k hkpos
      have hbound := seq.growth_bound k hkpos
      have h3ku : 3 * k * u ≤ 3 * k * (k + 1) := Nat.mul_le_mul_left (3*k) hu_hi
      have hsub_valid : seq.n k ≥ seq.n (k-1) + 3 * k * u := by
        have h5n : 5 * seq.n (k-1) ≥ 3 * k * (k + 1) + 1 := by nlinarith [hbound]
        omega
      have hd_eq : d = seq.n k + seq.n (k-1) + 3 * k * u := by
        simp only [N] at hcd
        omega
      have hcontra := hd_not_excl u ⟨hu_lo, hu_hi⟩
      exact hcontra hd_eq.symm
    · -- c ∈ R_k: c ≥ n_k + 1, but c ≤ n_k
      have hR_lo := (seq.R_subset k hkpos c hcR).1
      omega
/-- Key polynomial inequality for Case 6: 7 * (3(k-1)² + 6(k-1) + 1) ≥ 3(k-1)k for k ≥ 1 -/
lemma case6_poly_bound (k : ℕ) (hk : k ≥ 1) :
    7 * (3 * (k-1)^2 + 6 * (k-1) + 1) ≥ 3 * (k-1) * k := by
  cases k with
  | zero => omega
  | succ k' =>
    simp only [Nat.succ_sub_one]
    nlinarith [Nat.zero_le k', sq_nonneg k']
/-- Upper bound for Case 6: n_{k-2} + k + 3 ≥ 3k² for k ≥ 3 using growth_bound
    (Written additively to avoid Nat subtraction issues) -/
lemma case6_nkm2_bound (seq : NathansonSeq) (k : ℕ) (hk : k ≥ 3) :
    seq.n (k-2) + k + 3 ≥ 3 * k^2 := by
  have hkm1 : k - 1 ≥ 1 := by omega
  have hbound := seq.growth_bound (k-1) hkm1
  simp only [Nat.sub_sub] at hbound
  have hpoly : 3 * (k-1)^2 + 6 * (k-1) + 1 + k + 3 ≥ 3 * k^2 := by
    cases k with
    | zero => omega
    | succ k' =>
      simp only [Nat.succ_sub_one]
      ring_nf
      nlinarith [sq_nonneg k']
  calc seq.n (k-2) + k + 3
      ≥ (3 * (k-1)^2 + 6 * (k-1) + 1) + k + 3 := by linarith
    _ ≥ 3 * k^2 := hpoly
set_option maxHeartbeats 2000000
/-- Lemma 3(ii): Representation count
From Nathanson's paper (Lemma 3, part ii), for n ∈ [N_{k-1}+1, N_k-1], we need to exhibit
k distinct pairs (a_i, b_i) with a_i ≤ b_i, a_i + b_i = n, and a_i, b_i ∈ B_k ∪ B_{k-1} ∪ B_{k-2}.
The proof splits into 6 cases based on which subinterval n falls into:
1. n ∈ [2N_{k-1} + 2k, N_k - 2N_{k-1} - 2k + 1]: Use P_k × P_k (Lemma 2 on single interval)
2. n ∈ [N_k - 2N_{k-1} - 2k + 2, N_k - k]: Use P_k × T_k where T_k ⊆ R_k
3. n ∈ [N_{k-1} + 2k - 1, N_{k-1} + N_{k-2}]: Use S_{k-1} × S_{k-1} where S_{k-1} ⊆ R_{k-1}
4. n ∈ [N_{k-1} + N_{k-2} + 1, 2N_{k-1} + 2k - 1]: Use P_k × P_{k-2}
5. n ∈ [N_k - k + 1, N_k - 1]: Use Q_k + R_k construction
6. n ∈ [N_{k-1} + 1, N_{k-1} + 2k - 2]: Use Q_{k-1} + R_{k-1} construction
-/
theorem lemma3_part2 (seq : NathansonSeq) (k : ℕ) (hk : k ≥ 3) (n : ℕ)
    (hn_lo : seq.N (k - 1) + 1 ≤ n) (hn_hi : n ≤ seq.N k - 1) :
    k ≤ countReps (seq.B_k k ∪ seq.B_k (k - 1) ∪ seq.B_k (k - 2)) n := by
  have hkm1 : k - 1 ≥ 1 := by omega
  have hkm2 : k - 2 ≥ 1 := by omega
  have hk1 : k ≥ 1 := by omega
  have hgrowk := seq.exponential_growth k hk1
  have hgrowkm1 := seq.exponential_growth (k-1) hkm1
  have hgrowkm2 := seq.exponential_growth (k-2) hkm2
  have hboundk := seq.growth_bound k hk1
  have hboundkm1 := seq.growth_bound (k-1) hkm1
  have hboundkm2 : seq.n (k - 2 - 1) ≥ 3 * (k-2)^2 + 6 * (k-2) + 1 := seq.growth_bound (k-2) hkm2
  by_cases h_case6 : n ≤ seq.N (k-1) + 2*k - 2
  · -- This case uses cross-pairs from Q_{k-1} × R_{k-1}
    have hn_case6_lo : n ≥ seq.N (k-1) + 1 := hn_lo
    simp only [N] at hn_case6_lo h_case6
    have hnkm2_poly : seq.n (k-2) ≥ 3 * (k-1)^2 + 6 * (k-1) + 1 := by
      have h := seq.growth_bound (k-1) hkm1
      simp only [Nat.sub_sub] at h
      exact h
    have hQ_nonneg : seq.n (k-1) ≥ seq.n (k-2) + 3 * (k-1) * k := by
      have hpoly := case6_poly_bound k hk1
      have h7 : 7 * seq.n (k-2) ≥ 7 * (3 * (k-1)^2 + 6 * (k-1) + 1) := by
        have := hnkm2_poly; linarith
      calc seq.n (k-1) ≥ 8 * seq.n (k-2) := hgrowkm1
        _ = seq.n (k-2) + 7 * seq.n (k-2) := by ring
        _ ≥ seq.n (k-2) + 7 * (3 * (k-1)^2 + 6 * (k-1) + 1) := by linarith
        _ ≥ seq.n (k-2) + 3 * (k-1) * k := by linarith
    have hnkm2_upper := case6_nkm2_bound seq k hk
    have hQkm1_in_Bkm1 : seq.Q (k-1) ⊆ seq.B_k (k-1) := fun x hx =>
      Finset.mem_union_left _ (Finset.mem_union_right _ hx)
    have hRkm1_in_Bkm1 : seq.R (k-1) ⊆ seq.B_k (k-1) := fun x hx =>
      Finset.mem_union_right _ hx
    have hBkm1_in_union : seq.B_k (k-1) ⊆ seq.B_k k ∪ seq.B_k (k-1) ∪ seq.B_k (k-2) := fun x hx =>
      Finset.mem_union_left _ (Finset.mem_union_right _ hx)
    let qfun : ℕ → ℕ := fun u => seq.n (k-1) - seq.n (k-2) - 3 * (k-1) * u + 1
    let rfun : ℕ → ℕ := fun u => n - qfun u
    have hq_sub_valid : ∀ u ≤ k, seq.n (k-1) ≥ seq.n (k-2) + 3 * (k-1) * u := fun u hu =>
      calc seq.n (k-1) ≥ seq.n (k-2) + 3 * (k-1) * k := hQ_nonneg
        _ ≥ seq.n (k-2) + 3 * (k-1) * u := by nlinarith
    have hq_in_Qkm1 : ∀ u ∈ Finset.Icc 1 k, qfun u ∈ seq.Q (k-1) := by
      intro u hu
      simp only [Q, if_neg (Nat.one_le_iff_ne_zero.mp hkm1), Finset.mem_image]
      use u
      simp only [Finset.mem_Icc] at hu ⊢
      constructor
      · omega
      · -- Need to show qfun u = n_{k-1} - n_{k-2} - 3(k-1)u + 1
        rfl
    have hr_lo : ∀ u ∈ Finset.Icc 1 k, rfun u ≥ seq.n (k-1) + 1 := by
      intro u hu
      simp only [rfun, qfun, Finset.mem_Icc] at *
      have hsub := hq_sub_valid u hu.2
      omega
    have hr_hi : ∀ u ∈ Finset.Icc 1 k, rfun u ≤ seq.n (k-1) + seq.N (k-2) := by
      intro u hu
      simp only [Finset.mem_Icc] at hu
      simp only [rfun, qfun, N]
      have hsub := hq_sub_valid u hu.2
      have hbound := hnkm2_upper
      have hq_bound : seq.n (k-1) - seq.n (k-2) - 3 * (k-1) * u + 1 ≤ seq.n (k-1) := by omega
      have hn_ge_q : n ≥ seq.n (k-1) - seq.n (k-2) - 3 * (k-1) * u + 1 := by
        calc n ≥ 2 * seq.n (k-1) + 2 := by omega
          _ ≥ seq.n (k-1) := by omega
          _ ≥ seq.n (k-1) - seq.n (k-2) - 3 * (k-1) * u + 1 := hq_bound
      have hsum_bound : n + 3 * (k-1) * u ≤ 2 * seq.n (k-1) + seq.n (k-2) + 2 := by
        have h1 : n ≤ 2 * seq.n (k-1) + 2 * k - 1 := by omega
        have h2 : 3 * (k-1) * u ≤ 3 * (k-1) * k := by nlinarith
        have h4 : seq.n (k-2) + k + 3 ≥ 3 * k^2 := hbound
        have hkey_add : 2 * k + 3 * (k-1) * k + k = 3 * k^2 := by
          cases k with
          | zero => simp
          | succ k' => simp only [Nat.succ_sub_one]; ring
        have h_2k_add : 2 * k + 3 * (k-1) * k + k ≤ seq.n (k-2) + k + 3 := by linarith
        have h_2k_sub : 2 * k + 3 * (k-1) * k ≤ seq.n (k-2) + 3 := by linarith
        have h5 : 2 * k - 1 + 3 * (k-1) * k ≤ seq.n (k-2) + 2 := by omega
        omega
      omega
    have hr_not_excl : ∀ u ∈ Finset.Icc 1 k,
        rfun u ∉ Finset.image (fun w => seq.n (k-1) + seq.n (k-2) + 3 * (k-1) * w)
                              (Finset.Icc 1 k) := by
      intro u hu
      simp only [Finset.mem_image, not_exists, not_and, Finset.mem_Icc]
      intro w ⟨hw_lo, hw_hi⟩
      simp only [rfun, qfun]
      simp only [Finset.mem_Icc] at hu
      intro heq
      have hsub := hq_sub_valid u hu.2
      have hgap : 3 * (k - 1) > 2 * k - 2 := by omega
      have hn_eq : n = 2 * seq.n (k-1) + 1 + 3 * (k-1) * w - 3 * (k-1) * u := by omega
      by_cases hwu : w = u
      · -- w = u: n = 2n_{k-1} + 1, but n ≥ 2n_{k-1} + 2
        subst hwu
        omega
      · -- w ≠ u: |w-u| ≥ 1, so 3(k-1)|w-u| ≥ 3(k-1) > 2k-2, contradicting n bounds
        have hdiff_lo : 3 * (k-1) * w + 1 ≥ 3 * (k-1) * u + 2 := by omega
        have hdiff_hi : 3 * (k-1) * w + 1 ≤ 3 * (k-1) * u + 2 * k - 1 := by omega
        rcases Nat.lt_trichotomy w u with hwlt | hwequiv | hwgt
        · -- w < u: Then 3(k-1)w ≤ 3(k-1)(u-1) < 3(k-1)u, contradicting hdiff_lo
          have hw_lt : w + 1 ≤ u := by omega
          have hmono : 3 * (k-1) * (w + 1) ≤ 3 * (k-1) * u := Nat.mul_le_mul_left _ hw_lt
          have hexp : 3 * (k - 1) * (w + 1) = 3 * (k - 1) * w + 3 * (k - 1) := by ring
          linarith
        · -- w = u: contradicts hwu
          exact absurd hwequiv hwu
        · -- w > u: w ≥ u + 1, so 3(k-1)w ≥ 3(k-1)(u+1) = 3(k-1)u + 3(k-1)
          have hw_ge : u + 1 ≤ w := by omega
          have hmono : 3 * (k-1) * (u + 1) ≤ 3 * (k-1) * w := Nat.mul_le_mul_left _ hw_ge
          have hexp : 3 * (k - 1) * (u + 1) = 3 * (k - 1) * u + 3 * (k - 1) := by ring
          have hcomb : 3 * (k - 1) * u + 3 * (k - 1) ≤ 3 * (k - 1) * w := by linarith
          have hdiff_hi' : 3 * (k - 1) * w ≤ 3 * (k - 1) * u + 2 * k - 2 := by omega
          have hchain : 3 * (k - 1) * u + 3 * (k - 1) ≤ 3 * (k - 1) * u + 2 * k - 2 := by linarith
          have hcontra : 3 * (k - 1) ≤ 2 * k - 2 := by omega
          omega
    have hr_in_Rkm1 : ∀ u ∈ Finset.Icc 1 k, rfun u ∈ seq.R (k-1) := by
      intro u hu
      simp only [R, if_neg (Nat.one_le_iff_ne_zero.mp hkm1), Finset.mem_sdiff, Finset.mem_Icc]
      constructor
      · exact ⟨hr_lo u hu, hr_hi u hu⟩
      · -- Need to show rfun u is not in the excluded set
        have hkm1_eq : k - 1 - 1 = k - 2 := by omega
        have hk_eq : k - 1 + 1 = k := by omega
        simp only [hkm1_eq, hk_eq]
        exact hr_not_excl u hu
    have hq_le_r : ∀ u ∈ Finset.Icc 1 k, qfun u ≤ rfun u := by
      intro u hu
      have hlo := hr_lo u hu
      simp only [qfun, rfun, Finset.mem_Icc] at *
      have hsub := hq_sub_valid u hu.2
      omega
    have hsum : ∀ u ∈ Finset.Icc 1 k, qfun u + rfun u = n := by
      intro u hu
      simp only [qfun, rfun, Finset.mem_Icc] at *
      have hsub := hq_sub_valid u hu.2
      omega
    let pairs : Finset (ℕ × ℕ) := Finset.image (fun u => (qfun u, rfun u)) (Finset.Icc 1 k)
    have sub_eq_lemma : ∀ A B u v : ℕ, A ≥ B * u → A ≥ B * v →
        A - B * u + 1 = A - B * v + 1 → B * u = B * v := by
      intro A B u v hau hav heq
      omega
    have hcard : pairs.card = k := by
      simp only [pairs]
      have hinj : Set.InjOn (fun u => (qfun u, rfun u)) (Finset.Icc 1 k : Set ℕ) := by
        intro u hu v hv huv
        simp only [Finset.coe_Icc, Set.mem_Icc] at hu hv
        simp only [Prod.mk.injEq] at huv
        have hqeq := huv.1
        simp only [qfun] at hqeq
        have hsubu := hq_sub_valid u hu.2
        have hsubv := hq_sub_valid v hv.2
        have hAu : seq.n (k-1) - seq.n (k-2) ≥ 3 * (k-1) * u := by omega
        have hAv : seq.n (k-1) - seq.n (k-2) ≥ 3 * (k-1) * v := by omega
        have hmul := sub_eq_lemma (seq.n (k-1) - seq.n (k-2)) (3 * (k-1)) u v hAu hAv hqeq
        have hpos : 3 * (k - 1) > 0 := by omega
        exact Nat.eq_of_mul_eq_mul_left hpos hmul
      rw [Finset.card_image_of_injOn hinj, Nat.card_Icc]

theorem proposition_3_8_base_fields (hFG : Hyp_FiniteTopologicalRank) : ∃ C_rd : ℝ, 0 < C_rd ∧
    ∀ ℓ : ℕ, 0 < ℓ →
      ∃ (F : Type) (_ : Field F) (_ : CharZero F) (_ : NumberField F)
        (_ : IsTotallyReal F) (_ : IsGalois ℚ F),
        Module.finrank ℚ F = 3 ∧
        Nonempty ((F ≃ₐ[ℚ] F) ≃* Multiplicative (ZMod 3)) ∧
        ℓ - 1 ≤ generatorRank (MaxUnramifiedProPGaloisGroup F 3) ∧
        Real.log (NumberField.rootDiscr F) ≤ C_rd * (ℓ : ℝ) * Real.log (max 2 ℓ) := by
  classical
  letI : Fact (Nat.Prime 3) := ⟨by decide⟩
  obtain ⟨C_rd, hC_rd_pos, hC_rd⟩ := primesCongOneMod3_log_sum_bound
  refine ⟨C_rd, hC_rd_pos, ?_⟩
  intro ℓ hℓ
  let r : Fin ℓ → ℕ := fun i => primesCongOneMod3 i
  have hr_prime : ∀ i : Fin ℓ, (r i).Prime := by
    intro i
    simpa [r] using primesCongOneMod3_prime i
  have hr_mod3 : ∀ i : Fin ℓ, r i % 3 = 1 := by
    intro i
    simpa [r] using primesCongOneMod3_mod i
  have hr_inj : Function.Injective r := by
    intro i j hij
    exact Fin.ext (primesCongOneMod3_strictMono.injective hij)
  obtain ⟨F, M, _, _, _, _, _, _, _, _, _, _, _, _, hcubic, hFMdeg, hdiscrF, hdiscrM,
      hFexp, hQexp, hFabel, hQabel, hcard, hmul, hpgroup, hunr⟩ :=
    proposition_3_2 ℓ hℓ r hr_prime hr_inj hr_mod3
  refine ⟨F, inferInstance, inferInstance, inferInstance, inferInstance, inferInstance,
    hcubic, ?_, ?_, ?_⟩
  · have hFcard : Nat.card (F ≃ₐ[ℚ] F) = 3 := by
      simpa [hcubic] using (IsGalois.card_aut_eq_finrank (F := ℚ) (E := F))
    have hZ3card : Nat.card (Multiplicative (ZMod 3)) = 3 := by
      simp
    exact ⟨mulEquivOfPrimeCardEq (G := F ≃ₐ[ℚ] F) (G' := Multiplicative (ZMod 3)) (p := 3) hFcard hZ3card⟩
  · let G := MaxUnramifiedProPGaloisGroup F 3
    let Q := Fin (ℓ - 1) → ZMod 3
    have hGfg : IsFinitelyGeneratedProPGroup 3 G := by
      simpa [G] using (MaxUnramifiedProPGaloisGroup.isFinitelyGeneratedProPGroup hFG (F := F) (p := 3))
    have hQrank : Module.finrank (ZMod 3) Q = ℓ - 1 := by
      simp [Q]
    obtain ⟨e⟩ := hmul
    obtain ⟨ψ, hψ_surj, hψ_cont⟩ :=
      prop38_universal_property (F := F) (p := 3) (M := M) hunr hpgroup
    letI : DiscreteTopology (M ≃ₐ[F] M) := inferInstance
    let φ : G →* Multiplicative Q := e.toMonoidHom.comp ψ
    have hφ_surj : Function.Surjective φ := by
      intro q
      rcases e.surjective q with ⟨g, rfl⟩
      rcases hψ_surj g with ⟨x, rfl⟩
      exact ⟨x, rfl⟩
    have hφ_cont : Continuous φ := by
      change Continuous fun x => e (ψ x)
      exact (continuous_of_discreteTopology : Continuous e).comp hψ_cont
    exact prop38_burnside_basis (G := G) (p := 3) hGfg (k := ℓ - 1) (Q := Q)
      hQrank φ hφ_surj hφ_cont
  · have hprod_nonzero : ∀ i ∈ Finset.range ℓ, (primesCongOneMod3 i : ℝ) ≠ 0 := by
      intro i hi
      exact_mod_cast (Nat.Prime.ne_zero (primesCongOneMod3_prime i))
    have hsum_nonneg : 0 ≤ ∑ i ∈ Finset.range ℓ, Real.log (primesCongOneMod3 i : ℝ) := by
      refine Finset.sum_nonneg ?_
      intro i hi
      have htwo : (2 : ℝ) ≤ (primesCongOneMod3 i : ℝ) := by
        exact_mod_cast (Nat.Prime.two_le (primesCongOneMod3_prime i))
      have hone : (1 : ℝ) ≤ (primesCongOneMod3 i : ℝ) := by linarith
      exact Real.log_nonneg hone
    calc
      Real.log (NumberField.rootDiscr F)
          = Real.log ((∏ i ∈ Finset.range ℓ, (primesCongOneMod3 i : ℝ)) ^ (2 : ℕ)) / 3 := by
              rw [rootDiscr_log_eq, hdiscrF, hcubic, Nat.cast_pow]
              simp [r, Fin.prod_univ_eq_prod_range, Nat.cast_prod]
      _ = (2 / 3 : ℝ) * Real.log (∏ i ∈ Finset.range ℓ, (primesCongOneMod3 i : ℝ)) := by
            rw [Real.log_pow]
            ring_nf
      _ = (2 / 3 : ℝ) * ∑ i ∈ Finset.range ℓ, Real.log (primesCongOneMod3 i : ℝ) := by
            rw [Real.log_prod hprod_nonzero]
      _ ≤ ∑ i ∈ Finset.range ℓ, Real.log (primesCongOneMod3 i : ℝ) := by
            nlinarith
      _ ≤ C_rd * (ℓ : ℝ) * Real.log (max 2 ℓ) := by
            simpa using hC_rd ℓ

theorem proposition_3_8_numeric_constants (C_rd : ℝ) (hC_rd : 0 < C_rd) :
    ∃ (ℓ₁ : ℕ) (C_H : ℝ), 0 < C_H ∧
      ∀ ℓ ≥ ℓ₁, ∀ x : ℝ, 0 < x →
        Real.log x ≤ C_rd * (ℓ : ℝ) * Real.log (max 2 ℓ) →
        let H : ℝ := 2 * (max 1 (2 * x)) ^ (2 * classNumberConstant)
        Real.log H ≤ C_H * (ℓ : ℝ) * Real.log (max 2 ℓ) ∧
        0 < ((((ℓ - 1) ^ 2 / 100 : ℕ) : ℝ) * Real.log 2 - Real.log H) := by
  set_option maxHeartbeats 1000000 in
  let c : ℝ := classNumberConstant
  let C_H : ℝ := 1 + 2 * c + 2 * c * C_rd
  let eps : ℝ := Real.log 2 / (2000 * C_H)
  have hc_pos : 0 < c := by
    dsimp [c]
    exact classNumberConstant_pos
  have hC_H : 0 < C_H := by
    dsimp [C_H, c]
    nlinarith [classNumberConstant_pos, hC_rd]
  have hlog2_pos : 0 < Real.log 2 := by
    have htwo : (1 : ℝ) < 2 := by norm_num
    exact Real.log_pos htwo
  have heps_pos : 0 < eps := by
    dsimp [eps]
    have hden_pos : 0 < 2000 * C_H := by positivity
    exact div_pos hlog2_pos hden_pos
  have hsmall_nat : (fun n : ℕ => Real.log (n : ℝ)) =o[Filter.atTop] fun n => (n : ℝ) := by
    simpa using (Asymptotics.IsLittleO.natCast_atTop (R := ℝ) Real.isLittleO_log_id_atTop)
  have hsmall_eps : ∀ᶠ n : ℕ in Filter.atTop, Real.log (n : ℝ) ≤ eps * (n : ℝ) := by
    filter_upwards [Asymptotics.IsLittleO.def hsmall_nat heps_pos] with n hn
    have hn_nonneg : 0 ≤ (n : ℝ) := by positivity
    have habs : |Real.log (n : ℝ)| ≤ eps * (n : ℝ) := by

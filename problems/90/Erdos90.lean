    have hriPrime : Prime (r i) := Nat.prime_iff.mp (_hr_prime i)
    obtain вҹЁPdiv, hPdiv_mem, hri_dvd_absNormPdivвҹ© := Prime.exists_mem_multiset_map_dvd hriPrime hri_dvd_normFactors
    have hPdiv_prime : Pdiv.IsPrime := (Ideal.mem_normalizedFactors_iff (I := differentIdeal в„Ө (рқ“һ M)) hdiff_ne_bot).mp hPdiv_mem |>.1
    have hPdiv_le : differentIdeal в„Ө (рқ“һ M) вүӨ Pdiv := (Ideal.mem_normalizedFactors_iff (I := differentIdeal в„Ө (рқ“һ M)) hdiff_ne_bot).mp hPdiv_mem |>.2

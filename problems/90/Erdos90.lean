theorem proposition_3_2_compositum_and_F_bridge_step (k : в„•) (r : Fin (k + 1) вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)
    (d : Proposition32BridgeData (k + 1)
      ((вҲҸ i, r i) ^ 2)
      ((вҲҸ i, r i) ^ (2 * 3 ^ k)))
    (s : в„•) (hs_prime : s.Prime) (hs_ne : вҲҖ i, r i вү  s) (hs_mod3 : s % 3 = 1) :
    Nonempty (Proposition32BridgeData (k + 2)
      (((вҲҸ i, r i) * s) ^ 2)
      (((вҲҸ i, r i) * s) ^ (2 * 3 ^ (k + 1)))) := by
  classical
  letI : Field d.M := d.field_M
  letI : CharZero d.M := d.charZero_M
  letI : NumberField d.M := d.numberField_M
  letI : IsTotallyReal d.M := d.totallyReal_M
  letI : IsGalois в„ҡ d.M := d.galoisQM

      ∫ x in ((1 : ℝ) / 2)..R, Real.sqrt (R ^ 2 - x ^ 2) =
        R * ∫ u in ((1 : ℝ) / (2 * R))..1, Real.sqrt (R ^ 2 - (u * R) ^ 2) := by
    simpa [hR0.ne', div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hscale0.symm
  have hscale2 :
      ∫ x in ((1 : ℝ) / 2)..R, Real.sqrt (R ^ 2 - x ^ 2) =
        R ^ 2 * ∫ u in ((1 : ℝ) / (2 * R))..1, Real.sqrt (1 - u ^ 2) := by
    rw [hscale1]
    have hfun :
        (fun u : ℝ => Real.sqrt (R ^ 2 - (u * R) ^ 2)) =
          fun u : ℝ => R * Real.sqrt (1 - u ^ 2) := by
      funext u
      have hRnonneg : 0 ≤ R := le_of_lt hR0
      have hEq : R ^ 2 - (u * R) ^ 2 = R ^ 2 * (1 - u ^ 2) := by
        ring
      rw [hEq, Real.sqrt_mul (sq_nonneg R)]
      have : Real.sqrt (R ^ 2) = R := by
        simp [Real.sqrt_sq_eq_abs, abs_of_nonneg hRnonneg]
      rw [this]
    rw [hfun, intervalIntegral.integral_const_mul]
    ring
  set a : ℝ := (1 : ℝ) / (2 * R)
  let F : ℝ → ℝ := fun u => (u * Real.sqrt (1 - u ^ 2) + Real.arcsin u) / 2
  have ha_le_one : a ≤ 1 := by
    dsimp [a]
    have h2R_pos : 0 < 2 * R := by positivity
    exact (div_le_iff₀ h2R_pos).2 (by nlinarith)
  have ha_pos : 0 < a := by
    dsimp [a]
    positivity
  have hF_cont : Continuous F := by
    unfold F
    continuity
  have hInt : ∫ u in a..1, Real.sqrt (1 - u ^ 2) = F 1 - F a := by
    apply intervalIntegral.integral_eq_sub_of_hasDeriv_right_of_le ha_le_one
    · exact hF_cont.continuousOn
    · intro x hx
      have hx0 : 0 < x := lt_trans ha_pos hx.1
      have hne : 1 - x ^ 2 ≠ 0 := by
        nlinarith [hx0, hx.2]
      have hsqrt_pos : 0 < Real.sqrt (1 - x ^ 2) := by
        apply Real.sqrt_pos.2
        nlinarith [hx0, hx.2]
      have hsqrt_ne : Real.sqrt (1 - x ^ 2) ≠ 0 := hsqrt_pos.ne'
      have hinner : HasDerivAt (fun y : ℝ => 1 - y ^ 2) (-(2 * x)) x := by
        convert ((hasDerivAt_const x (1 : ℝ)).sub ((hasDerivAt_id x).pow 2)) using 1
        simp [pow_two]
      have hsqrt :
          HasDerivAt (fun y : ℝ => Real.sqrt (1 - y ^ 2)) (-(2 * x) / (2 * Real.sqrt (1 - x ^ 2))) x := by
        exact hinner.sqrt hne
      have harcsin : HasDerivAt Real.arcsin (1 / Real.sqrt (1 - x ^ 2)) x := by
        apply Real.hasDerivAt_arcsin
        · linarith
        · exact ne_of_lt hx.2
      have hprod :

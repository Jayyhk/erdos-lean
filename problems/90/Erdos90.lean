  have htor : Monoid.IsTorsion (G ⧸ N) := ExponentExists.isTorsion hExp
  haveI : Group.FG H := by
    simpa [H] using (Group.closure_finset_fg T)
  haveI : Finite H := CommGroup.finite_of_fg_torsion H (IsTorsion.subgroup htor H)
  haveI : IsClosed (N : Set G) := by
    simp [N, _root_.Erdos90.closedFrattini]

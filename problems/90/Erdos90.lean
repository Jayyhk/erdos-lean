    simpa [Оі, D, C] using hОҙ
  have hlarge' : A вүӨ Real.exp ((Оі / 2) * (рқ’ҹ j).f) := by
    simpa [Оі] using hlarge
  have hExpLe' : Real.exp ((Оі / 2) * (рқ’ҹ j).f) вүӨ (n : в„қ) := by
    simpa [Оі] using hExpLe
  have hn_upper' : (n : в„қ) вүӨ C ^ (2 * (рқ’ҹ j).f) := by
    simpa [C, D] using hn_upper

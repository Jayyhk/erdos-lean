          · -- q ≤ future_upper_floor (Nat).
            -- (q : ℝ) ≤ exp(y_target^{A-1}). Since q is Nat, q ≤ ⌊exp(...)⌋₊ via Nat.le_floor.
            rw [hfuf_def]
            exact Nat.le_floor hq_data.2.2

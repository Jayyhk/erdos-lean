        (DenseRange.topologicalClosure_map_subgroup (f := π)
          continuous_quotient_mk' (QuotientGroup.mk'_surjective N).denseRange hS_top :
          ((Subgroup.closure (S : Set G)).map π).topologicalClosure =
            (⊤ : Subgroup (G ⧸ N)))

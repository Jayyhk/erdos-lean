    haveI : Q.1.IsMaximal := Ideal.primesOver.isMaximal (p := p) Q
    haveI : Q.1.LiesOver p := Ideal.primesOver.liesOver (p := p) Q
    letI : Field (в„Ө в§ё p) := Ideal.Quotient.field p
    letI : Field ((рқ“һ M) в§ё Q.1) := Ideal.Quotient.field Q.1
    have hQne : Q.1 вү  вҠҘ := Ideal.ne_bot_of_mem_primesOver (S := рқ“һ M) hpne Q.2
    have hsepQ : Algebra.IsSeparable (в„Ө в§ё p) ((рқ“һ M) в§ё Q.1) := by

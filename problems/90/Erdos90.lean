            ring
  simpa [D, E, P, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, mul_comm, mul_left_comm,
    mul_assoc] using hfinal

theorem boundary_extension_translate_difference_damped_eq {f : в„• вҶ’ в„қ} {b Оҙ : в„қ} :
  HasBoundaryLaplaceExtension f b вҶ’ 0 < Оҙ вҶ’
  вҲғ F : в„Ӯ вҶ’ в„Ӯ,
    ContinuousOn F {z : в„Ӯ | 0 вүӨ z.re} вҲ§
    Set.EqOn F
      (fun z : в„Ӯ =>
        вҲ« x in Set.Ioi (0 : в„қ),
          ((((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b) : в„қ) : в„Ӯ) *
            Complex.exp (-z * x)))
      {z : в„Ӯ | 0 < z.re} вҲ§
    F 0 = -вҲ« y in (0 : в„қ)..Оҙ, (((logRescalePartialSum f y - b : в„қ) : в„Ӯ)) := by
  intro hExt hОҙ
  rcases hExt with вҹЁG, hGcont, hGint, hGeqвҹ©
  let U : в„қ вҶ’ в„Ӯ := fun y => ((logRescalePartialSum f y - b : в„қ) : в„Ӯ)
  let J : в„Ӯ вҶ’ в„Ӯ := fun z => вҲ« y in (0 : в„қ)..Оҙ, U y * Complex.exp (-z * y)
  let F : в„Ӯ вҶ’ в„Ӯ := fun z => (Complex.exp (z * Оҙ) - 1) * G z - Complex.exp (z * Оҙ) * J z
  refine вҹЁF, ?_, ?_, ?_вҹ©
  В· have hJcont : ContinuousOn J {z : в„Ӯ | 0 вүӨ z.re} := by
      simpa [J, U] using
        (boundary_extension_local_interval_laplace_continuous (f := f) (b := b) (Оҙ := Оҙ))
    have hExp : Continuous fun z : в„Ӯ => Complex.exp (z * Оҙ) := by
      continuity
    have hExpSubOne : Continuous fun z : в„Ӯ => Complex.exp (z * Оҙ) - 1 := by
      continuity
    exact (hExpSubOne.continuousOn.mul hGcont).sub (hExp.continuousOn.mul hJcont)
  В· intro z hz
    have hOrig : MeasureTheory.IntegrableOn
        (fun x : в„қ => U x * Complex.exp (-z * x)) (Set.Ioi (0 : в„қ)) := by
      simpa [U] using hGint z hz
    have hTail : MeasureTheory.IntegrableOn
        (fun x : в„қ => U x * Complex.exp (-z * x)) (Set.Ioi Оҙ) := by
      refine hOrig.mono_set ?_
      intro x hx
      exact lt_trans hОҙ hx
    have hTailInd : MeasureTheory.Integrable
        ((Set.Ioi Оҙ).indicator (fun x : в„қ => U x * Complex.exp (-z * x))) := by
      exact hTail.integrable_indicator measurableSet_Ioi
    have hShiftCoreInd : MeasureTheory.Integrable
        (fun x : в„қ => (Set.Ioi Оҙ).indicator (fun x : в„қ => U x * Complex.exp (-z * x)) (x + Оҙ)) := by
      simpa using hTailInd.comp_add_right Оҙ
    have hShiftCore : MeasureTheory.IntegrableOn
        (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * (x + Оҙ))) (Set.Ioi (0 : в„қ)) := by
      rw [вҶҗ MeasureTheory.integrable_indicator_iff measurableSet_Ioi]
      convert hShiftCoreInd using 1
      ext x
      by_cases hx : x вҲҲ Set.Ioi (0 : в„қ)
      В· have hxd : x + Оҙ вҲҲ Set.Ioi Оҙ := by
          simp only [Set.mem_Ioi] at hx вҠў
          linarith
        simp [hx, hxd, U]
      В· have hxd : x + Оҙ вҲү Set.Ioi Оҙ := by
          simp only [Set.mem_Ioi, not_lt] at hx вҠў
          linarith
        simp [hx, hxd, U]
    have hShiftInd : MeasureTheory.Integrable
        ((Set.Ioi (0 : в„қ)).indicator (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * x))) := by
      have hShiftCoreInd0 : MeasureTheory.Integrable
          ((Set.Ioi (0 : в„қ)).indicator
            (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * (x + Оҙ)))) := by
        exact hShiftCore.integrable_indicator measurableSet_Ioi
      have hScaled : MeasureTheory.Integrable
          (fun x : в„қ => Complex.exp (z * Оҙ) *
            ((Set.Ioi (0 : в„қ)).indicator
              (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * (x + Оҙ))) x)) := by
        exact hShiftCoreInd0.const_mul (Complex.exp (z * Оҙ))
      convert hScaled using 1
      ext x
      by_cases hx : x вҲҲ Set.Ioi (0 : в„қ)
      В· simp [hx]
        calc
          U (x + Оҙ) * Complex.exp (-(z * x))
              = U (x + Оҙ) *
                  (Complex.exp (z * Оҙ) * Complex.exp (-(z * (x + Оҙ)))) := by
                  congr 1
                  rw [вҶҗ Complex.exp_add]
                  congr 1
                  ring
          _ = Complex.exp (z * Оҙ) * (U (x + Оҙ) * Complex.exp (-(z * (x + Оҙ)))) := by
                ring
      В· simp [hx]
    have hShift : MeasureTheory.IntegrableOn
        (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * x)) (Set.Ioi (0 : в„қ)) := by
      rw [вҶҗ MeasureTheory.integrable_indicator_iff measurableSet_Ioi]
      exact hShiftInd
    have hShiftEq :
        вҲ« x in Set.Ioi (0 : в„қ), U (x + Оҙ) * Complex.exp (-z * x)
          = Complex.exp (z * Оҙ) *
              ((вҲ« x in Set.Ioi (0 : в„қ), U x * Complex.exp (-z * x)) - J z) := by
      simpa [J, U] using
        boundary_extension_shifted_laplace_eq
          (f := f) (b := b) (Оҙ := Оҙ) вҹЁG, hGcont, hGint, hGeqвҹ© hОҙ z hz
    have hOrigEq : G z = вҲ« x in Set.Ioi (0 : в„қ), U x * Complex.exp (-z * x) := by
      exact hGeq hz
    calc
      F z = (вҲ« x in Set.Ioi (0 : в„қ), U (x + Оҙ) * Complex.exp (-z * x))
            - вҲ« x in Set.Ioi (0 : в„қ), U x * Complex.exp (-z * x) := by
        rw [hShiftEq, вҶҗ hOrigEq]
        simp only [F]
        ring
      _ = вҲ« x in Set.Ioi (0 : в„қ),
            (U (x + Оҙ) * Complex.exp (-z * x)) - (U x * Complex.exp (-z * x)) := by
        symm
        simpa using
          (MeasureTheory.integral_sub (Ој := MeasureTheory.volume.restrict (Set.Ioi (0 : в„қ)))
            hShift hOrig)
      _ = вҲ« x in Set.Ioi (0 : в„қ),
            ((((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b) : в„қ) : в„Ӯ) *
              Complex.exp (-z * x)) := by
        congr with x
        simp [U, sub_mul]
  В· simp [F, J, U]

theorem boundary_extension_translate_difference_real_bounded_near_zero {f : в„• вҶ’ в„қ} {b Оҙ : в„қ} :
  HasBoundaryLaplaceExtension f b вҶ’ 0 < Оҙ вҶ’
  вҲғ Оө M : в„қ, 0 < Оө вҲ§
    вҲҖ Пғ : в„қ, 0 < Пғ вҶ’ Пғ < Оө вҶ’
      Complex.re (вҲ« x in Set.Ioi (0 : в„қ),
        ((((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b) : в„қ) : в„Ӯ) *
          Complex.exp (-(Пғ : в„Ӯ) * x))) вүӨ M := by
  intro hExt hОҙ
  rcases boundary_extension_translate_difference_damped_eq hExt hОҙ with вҹЁF, hFcont, hFeq, hF0вҹ©
  have h0mem : (0 : в„Ӯ) вҲҲ {z : в„Ӯ | 0 вүӨ z.re} := by
    simp
  have hcont0 : ContinuousWithinAt F {z : в„Ӯ | 0 вүӨ z.re} 0 := hFcont 0 h0mem
  rcases Metric.continuousWithinAt_iff.mp hcont0 1 zero_lt_one with вҹЁОө, hОөpos, hОөвҹ©
  refine вҹЁОө, вҖ–F 0вҖ– + 1, hОөpos, ?_вҹ©
  intro Пғ hПғpos hПғlt
  have hПғmem : ((Пғ : в„Ӯ) вҲҲ {z : в„Ӯ | 0 вүӨ z.re}) := by
    simp [le_of_lt hПғpos]
  have hdist : dist ((Пғ : в„Ӯ)) 0 < Оө := by
    simpa [dist_eq_norm, Complex.norm_real, Real.norm_eq_abs, abs_of_pos hПғpos] using hПғlt
  have hFclose : dist (F (Пғ : в„Ӯ)) (F 0) < 1 := by
    exact hОө hПғmem hdist
  have hFnorm : вҖ–F (Пғ : в„Ӯ)вҖ– < вҖ–F 0вҖ– + 1 := by
    have hdist' : вҖ–F (Пғ : в„Ӯ) - F 0вҖ– < 1 := by
      simpa [dist_eq_norm] using hFclose
    have htriangle : вҖ–F (Пғ : в„Ӯ)вҖ– вүӨ вҖ–F (Пғ : в„Ӯ) - F 0вҖ– + вҖ–F 0вҖ– := by
      have := norm_add_le (F (Пғ : в„Ӯ) - F 0) (F 0)
      simpa [sub_add_cancel] using this
    linarith
  have hEq : F (Пғ : в„Ӯ) = вҲ« x in Set.Ioi (0 : в„қ),
      ((((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b) : в„қ) : в„Ӯ) *
        Complex.exp (-(Пғ : в„Ӯ) * x)) := by
    have hПғre : 0 < ((Пғ : в„Ӯ)).re := by simpa using hПғpos
    exact hFeq hПғre
  rw [вҶҗ hEq]
  have hre : Complex.re (F (Пғ : в„Ӯ)) вүӨ вҖ–F (Пғ : в„Ӯ)вҖ– := by
    simpa using (RCLike.re_le_norm (F (Пғ : в„Ӯ)))
  linarith

theorem interval_average_eq_sub_translate_difference {f : в„• вҶ’ в„қ} {b Оҙ x y : в„қ} :
  вҲ« t in x..y,
      ((logRescalePartialSum f (t + Оҙ) - b) - (logRescalePartialSum f t - b))
    =
      (вҲ« t in y..(y + Оҙ), (logRescalePartialSum f t - b)) -
        вҲ« t in x..(x + Оҙ), (logRescalePartialSum f t - b) := by
  let U : в„қ вҶ’ в„қ := fun t => logRescalePartialSum f t - b
  have hxy : IntervalIntegrable U MeasureTheory.volume x y := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b x y
  have hx : IntervalIntegrable U MeasureTheory.volume x (x + Оҙ) := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b x (x + Оҙ)
  have hshift : IntervalIntegrable U MeasureTheory.volume (x + Оҙ) (y + Оҙ) := by
    simpa [U] using logRescalePartialSum_intervalIntegrable f b (x + Оҙ) (y + Оҙ)
  have hxy_shift : IntervalIntegrable (fun t : в„қ => U (t + Оҙ)) MeasureTheory.volume x y := by
    simpa using
      (IntervalIntegrable.comp_add_right_iff (f := U) (a := x) (b := y) (c := Оҙ)).2 hshift
  calc
    вҲ« t in x..y,
        ((logRescalePartialSum f (t + Оҙ) - b) - (logRescalePartialSum f t - b))
        = вҲ« t in x..y, (U (t + Оҙ) - U t) := by
            simp [U]
    _ = (вҲ« t in x..y, U (t + Оҙ)) - вҲ« t in x..y, U t := by
          rw [intervalIntegral.integral_sub hxy_shift hxy]
    _ = (вҲ« t in (x + Оҙ)..(y + Оҙ), U t) - вҲ« t in x..y, U t := by
          congr 1
          rw [intervalIntegral.integral_comp_add_right (f := U) (a := x) (b := y) (d := Оҙ)]
    _ = (вҲ« t in y..(y + Оҙ), U t) - вҲ« t in x..(x + Оҙ), U t := by
          rw [intervalIntegral.integral_interval_sub_interval_comm' hshift hxy hx.symm]
    _ = (вҲ« t in y..(y + Оҙ), (logRescalePartialSum f t - b)) -
          вҲ« t in x..(x + Оҙ), (logRescalePartialSum f t - b) := by
          simp [U]

theorem interval_average_lower_bound_of_quasi_monotone {f : в„• вҶ’ в„қ} {b X Оҙ О· : в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’
  0 вүӨ X вҶ’
  0 вүӨ Оҙ вҶ’
  0 вүӨ О· вҶ’
  (вҲ« y in (X + О·)..(X + О· + Оҙ), (logRescalePartialSum f y - b))
    вүҘ Real.exp (-О·) * (вҲ« y in X..(X + Оҙ), (logRescalePartialSum f y - b))
      - (1 - Real.exp (-О·)) * b * Оҙ := by
  intro hnonneg hX hОҙ hО·
  let L : в„қ вҶ’ в„қ := logRescalePartialSum f
  have hXОҙ : X вүӨ X + Оҙ := by linarith
  have hbaseInt : IntervalIntegrable (fun y : в„қ => L y - b) MeasureTheory.volume X (X + Оҙ) :=
    logRescalePartialSum_intervalIntegrable f b X (X + Оҙ)
  have hshiftInt : IntervalIntegrable (fun t : в„қ => L (t + О·) - b) MeasureTheory.volume X (X + Оҙ) := by
    convert (logRescalePartialSum_intervalIntegrable f b (X + О·) (X + О· + Оҙ)).comp_add_right О· using 1 <;> ring_nf
  have hpoint : вҲҖ t вҲҲ Set.Icc X (X + Оҙ),
      Real.exp (-О·) * (L t - b) - (1 - Real.exp (-О·)) * b вүӨ L (t + О·) - b := by
    intro t ht
    have ht0 : 0 вүӨ t := le_trans hX ht.1
    have hmono : L t вүӨ Real.exp О· * L (t + О·) := by
      simpa [L] using (logRescalePartialSum_quasi_monotone hnonneg (x := t) (y := О·) ht0 hО·)
    have hexp : Real.exp (-О·) * Real.exp О· = 1 := by
      rw [вҶҗ Real.exp_add]
      ring_nf
      simp
    have hscaled : Real.exp (-О·) * L t вүӨ L (t + О·) := by
      calc
        Real.exp (-О·) * L t вүӨ Real.exp (-О·) * (Real.exp О· * L (t + О·)) := by
          exact mul_le_mul_of_nonneg_left hmono (by positivity)
        _ = (Real.exp (-О·) * Real.exp О·) * L (t + О·) := by ring
        _ = L (t + О·) := by rw [hexp, one_mul]
    have hrew : Real.exp (-О·) * (L t - b) - (1 - Real.exp (-О·)) * b = Real.exp (-О·) * L t - b := by
      ring
    rw [hrew]
    linarith
  have hshift :
      (вҲ« y in (X + О·)..(X + О· + Оҙ), (L y - b)) = вҲ« t in X..(X + Оҙ), (L (t + О·) - b) := by
    symm
    convert (intervalIntegral.integral_comp_add_right (f := fun y : в„қ => L y - b) (a := X) (b := X + Оҙ) (d := О·)) using 1
    ring_nf
  have hconst : IntervalIntegrable (fun _ : в„қ => (1 - Real.exp (-О·)) * b) MeasureTheory.volume X (X + Оҙ) := by
    simp
  have hlowerInt :
      IntervalIntegrable (fun t : в„қ => Real.exp (-О·) * (L t - b) - (1 - Real.exp (-О·)) * b) MeasureTheory.volume X (X + Оҙ) := by
    exact (hbaseInt.const_mul (Real.exp (-О·))).sub hconst
  have hmono_int :
      вҲ« t in X..(X + Оҙ), (Real.exp (-О·) * (L t - b) - (1 - Real.exp (-О·)) * b)
        вүӨ вҲ« t in X..(X + Оҙ), (L (t + О·) - b) := by
    exact intervalIntegral.integral_mono_on hXОҙ hlowerInt hshiftInt hpoint
  have hsmul : Оҙ вҖў ((1 - Real.exp (-О·)) * b) = (1 - Real.exp (-О·)) * b * Оҙ := by
    change Оҙ * ((1 - Real.exp (-О·)) * b) = (1 - Real.exp (-О·)) * b * Оҙ
    ring
  have hcalc :
      вҲ« t in X..(X + Оҙ), (Real.exp (-О·) * (L t - b) - (1 - Real.exp (-О·)) * b)
        = Real.exp (-О·) * (вҲ« t in X..(X + Оҙ), (L t - b)) - (1 - Real.exp (-О·)) * b * Оҙ := by
    rw [intervalIntegral.integral_sub (hbaseInt.const_mul (Real.exp (-О·))) hconst]
    rw [intervalIntegral.integral_const_mul (Real.exp (-О·))]
    rw [intervalIntegral.integral_const]
    have hlen : X + Оҙ - X = Оҙ := by ring
    rw [hlen, hsmul]
  rw [hshift]
  linarith

theorem overshoot_intervals {f : в„• вҶ’ в„қ} {b A : в„қ} :
  (вҲҖ n, 0 вүӨ f n) вҶ’
  0 < A вҶ’
  вҲғ Оҙ c : в„қ, 0 < Оҙ вҲ§ 0 < c вҲ§
    вҲҖ {x : в„қ}, 0 вүӨ x вҶ’ A < logRescalePartialSum f x - b вҶ’
      вҲҖ y вҲҲ Set.Icc x (x + Оҙ), c вүӨ logRescalePartialSum f y - b := by
  intro hnonneg hA
  by_cases hb : 0 вүӨ b
  В· refine вҹЁReal.log ((A + b) / (A / 2 + b)), A / 2, ?_, ?_, ?_вҹ©
    В· have hden : 0 < A / 2 + b := by linarith
      have hr_one : 1 < (A + b) / (A / 2 + b) := by
        have hlt : A / 2 + b < A + b := by linarith
        have hEq : (1 : в„қ) = (A / 2 + b) / (A / 2 + b) := by
          field_simp [hden.ne']
        rw [hEq]
        exact div_lt_div_of_pos_right hlt hden
      exact Real.log_pos hr_one
    В· linarith
    В· intro x hx hovers y hy
      have hxy : x вүӨ y := hy.1
      have hy_upper : y вүӨ x + Real.log ((A + b) / (A / 2 + b)) := hy.2
      have hyx_nonneg : 0 вүӨ y - x := by linarith
      have hy_eq : x + (y - x) = y := by ring
      have hUxy := logRescalePartialSum_quasi_monotone (f := f) hnonneg (x := x) (y := y - x) hx hyx_nonneg
      rw [hy_eq] at hUxy
      have hAxb : A + b < logRescalePartialSum f x := by linarith
      have hden : 0 < A / 2 + b := by linarith
      have hyx_le : y - x вүӨ Real.log ((A + b) / (A / 2 + b)) := by
        linarith
      have hr_pos : 0 < (A + b) / (A / 2 + b) := by
        have hnum : 0 < A + b := by linarith
        positivity
      have hr : Real.exp (y - x) вүӨ (A + b) / (A / 2 + b) := by
        have htmp := Real.exp_le_exp.mpr hyx_le
        simpa [Real.exp_log hr_pos] using htmp
      have hy_nonneg : 0 вүӨ logRescalePartialSum f y := logRescalePartialSum_nonneg hnonneg y
      have hmul : logRescalePartialSum f x вүӨ ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
        calc
          logRescalePartialSum f x вүӨ Real.exp (y - x) * logRescalePartialSum f y := hUxy
          _ вүӨ ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
            gcongr
      have hlt : A + b < ((A + b) / (A / 2 + b)) * logRescalePartialSum f y := by
        exact lt_of_lt_of_le hAxb hmul
      have hAy : A / 2 + b < logRescalePartialSum f y := by
        by_contra hcontra
        have hy_le : logRescalePartialSum f y вүӨ A / 2 + b := by linarith
        have hmul_le : ((A + b) / (A / 2 + b)) * logRescalePartialSum f y вүӨ ((A + b) / (A / 2 + b)) * (A / 2 + b) := by
          gcongr
        have hEq : ((A + b) / (A / 2 + b)) * (A / 2 + b) = A + b := by
          field_simp [hden.ne']
        linarith
      linarith
  В· have hbneg : b < 0 := by linarith
    refine вҹЁ1, min (A / 2) (-b / 2), by norm_num, ?_, ?_вҹ©
    В· have h1 : 0 < A / 2 := by linarith
      have h2 : 0 < -b / 2 := by linarith
      exact lt_min h1 h2
    В· intro x hx hovers y hy
      have hy_nonneg : 0 вүӨ logRescalePartialSum f y := logRescalePartialSum_nonneg hnonneg y
      have hmain : -b вүӨ logRescalePartialSum f y - b := by linarith
      have hmin : min (A / 2) (-b / 2) вүӨ -b := by
        have h2 : -b / 2 вүӨ -b := by linarith
        exact le_trans (min_le_right _ _) h2
      exact le_trans hmin hmain

noncomputable def partialSumIccDiv (f : в„• вҶ’ в„қ) (Y : в„•) : в„қ :=
  Finset.sum (Finset.Icc 1 Y) f / (Y : в„қ)

def partialSumIccEReal (f : в„• вҶ’ в„қ) (X : в„•) : EReal :=
  ((вҲ‘ n вҲҲ Finset.Icc 1 X, f n : в„қ) : EReal)

theorem frequently_small_partialSumIcc_of_linearGrowthInf_nonpos {f : в„• вҶ’ в„қ} :
    LinearGrowth.linearGrowthInf (partialSumIccEReal f) вүӨ 0 вҶ’
    вҲҖ Оө : в„қ, 0 < Оө вҶ’
      вҲғб¶  N : в„• in Filter.atTop,
        вҲ‘ k вҲҲ Finset.Icc 1 N, f k вүӨ Оө * (N : в„қ) := by
  intro h Оө hОө
  have hОөE : (0 : EReal) < (Оө : EReal) := by
    exact_mod_cast hОө
  have hlt : LinearGrowth.linearGrowthInf (partialSumIccEReal f) < (Оө : EReal) := by
    exact lt_of_le_of_lt h hОөE
  have hfreq : вҲғб¶  N : в„• in Filter.atTop, partialSumIccEReal f N вүӨ (Оө : EReal) * N := by
    exact LinearGrowth.frequently_le_mul hlt
  refine hfreq.mono ?_
  intro N hN
  have hN' : ((вҲ‘ n вҲҲ Finset.Icc 1 N, f n : в„қ) : EReal) вүӨ (((Оө * (N : в„қ) : в„қ) : EReal)) := by
    simpa [partialSumIccEReal] using hN
  exact_mod_cast hN'

def partialSumRangeEReal (f : в„• вҶ’ в„қ) (X : в„•) : EReal :=

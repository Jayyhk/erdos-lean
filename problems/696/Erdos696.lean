        Nat.Coprime.coprime_dvd_left hd_dvd_a hab_coprime
      have hdb_dvd_M : d * b ∣ M :=
        Nat.Coprime.mul_dvd_of_dvd_of_dvd hd_cop_b hd_dvd_M hb_dvd_M

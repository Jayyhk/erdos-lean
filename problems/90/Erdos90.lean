theorem boundary_extension_translate_difference_damped_integrable {f : в„• вҶ’ в„қ} {b Оҙ : в„қ} :
  HasBoundaryLaplaceExtension f b вҶ’ 0 < Оҙ вҶ’
  вҲҖ z : в„Ӯ, 0 < z.re вҶ’
    MeasureTheory.IntegrableOn
      (fun x : в„қ =>
        ((((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b) : в„қ) : в„Ӯ) *
          Complex.exp (-z * x)))
      (Set.Ioi (0 : в„қ)) := by
  intro hExt hОҙ z hz
  rcases hExt with вҹЁG, hGcont, hGint, hGeqвҹ©
  let U : в„қ вҶ’ в„Ӯ := fun x => (((logRescalePartialSum f x - b : в„қ) : в„Ӯ))
  let g : в„қ вҶ’ в„Ӯ := fun x => U x * Complex.exp (-z * x)
  have h_orig : MeasureTheory.IntegrableOn g (Set.Ioi (0 : в„қ)) := by
    simpa only [g, U] using hGint z hz
  have h_tail : MeasureTheory.IntegrableOn g (Set.Ioi Оҙ) := by
    exact h_orig.mono_set (by intro x hx; exact lt_trans hОҙ hx)
  have h_tail_ind : MeasureTheory.Integrable (Set.indicator (Set.Ioi Оҙ) g) := by
    exact h_tail.integrable_indicator measurableSet_Ioi
  have h_shift_ind : MeasureTheory.Integrable (fun x : в„қ => Set.indicator (Set.Ioi Оҙ) g (x + Оҙ)) := by
    simpa only [g] using h_tail_ind.comp_add_right Оҙ
  have h_shift0 : MeasureTheory.IntegrableOn
      (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * (((x + Оҙ : в„қ) : в„Ӯ))))
      (Set.Ioi (0 : в„қ)) := by
    refine (h_shift_ind.integrableOn).congr_fun ?_ measurableSet_Ioi
    intro x hx
    have hxОҙ : x + Оҙ вҲҲ Set.Ioi Оҙ := by
      dsimp [Set.Ioi] at hx вҠў
      linarith
    simp only [Set.indicator_of_mem, hxОҙ, g]
  have h_const : MeasureTheory.IntegrableOn
      (fun x : в„қ => Complex.exp (z * Оҙ) * (U (x + Оҙ) * Complex.exp (-z * (((x + Оҙ : в„қ) : в„Ӯ)))))
      (Set.Ioi (0 : в„қ)) :=
    h_shift0.const_mul _
  have h_shift : MeasureTheory.IntegrableOn (fun x : в„қ => U (x + Оҙ) * Complex.exp (-z * x)) (Set.Ioi (0 : в„қ)) := by
    refine h_const.congr_fun ?_ measurableSet_Ioi
    intro x hx
    calc
      Complex.exp (z * Оҙ) * (U (x + Оҙ) * Complex.exp (-z * (((x + Оҙ : в„қ) : в„Ӯ))))
          = U (x + Оҙ) * (Complex.exp (z * Оҙ) * Complex.exp (-z * (((x + Оҙ : в„қ) : в„Ӯ)))) := by ring
      _ = U (x + Оҙ) * Complex.exp (z * Оҙ + -z * (((x + Оҙ : в„қ) : в„Ӯ))) := by rw [вҶҗ Complex.exp_add]
      _ = U (x + Оҙ) * Complex.exp (-z * x) := by
          congr 2
          push_cast
          ring
  have h_sub : MeasureTheory.IntegrableOn
      (fun x : в„қ => (U (x + Оҙ) * Complex.exp (-z * x)) - (U x * Complex.exp (-z * x)))
      (Set.Ioi (0 : в„қ)) :=
    h_shift.sub h_orig
  refine h_sub.congr_fun ?_ measurableSet_Ioi
  intro x hx
  change
    вҶ‘(logRescalePartialSum f (x + Оҙ) - b) * Complex.exp (-z * x) -
      вҶ‘(logRescalePartialSum f x - b) * Complex.exp (-z * x) =
    вҶ‘((logRescalePartialSum f (x + Оҙ) - b) - (logRescalePartialSum f x - b)) * Complex.exp (-z * x)
  rw [вҶҗ sub_mul]
  push_cast
  rfl

theorem centeredTentWeight_intervalIntegral_eq_leftTent_shift_add_reflect {f : в„• вҶ’ в„қ} {b X : в„қ} :
  вҲ« t in (0 : в„қ)..1,
      centeredTentWeight t * (logRescalePartialSum f (X + t) - b)
    =
      вҲ« t in (0 : в„қ)..1,
        (leftTentKernel (t - (1 / 2 : в„қ)) + leftTentKernel ((1 / 2 : в„қ) - t)).re *
          (logRescalePartialSum f (X + t) - b) := by
  refine intervalIntegral.integral_congr_ae ?_
  have hne : вҲҖбөҗ t вҲӮ(MeasureTheory.volume), t вү  (1 / 2 : в„қ) := by
    rw [MeasureTheory.ae_iff]
    simp
  filter_upwards [hne] with t htne htI
  have ht0 : (0 : в„қ) < t := by simpa using htI.1
  have ht1 : t вүӨ (1 : в„қ) := by simpa using htI.2
  have hcoeff :
      centeredTentWeight t =
        (leftTentKernel (t - (1 / 2 : в„қ)) + leftTentKernel ((1 / 2 : в„қ) - t)).re := by
    by_cases hlt : t < (1 / 2 : в„қ)
    В· have hle1 : t - (1 / 2 : в„қ) вүӨ 0 := by linarith
      have hleft :
          leftTentKernel (t - (1 / 2 : в„қ)) =
            (((2 * ((t - (1 / 2 : в„қ)) + 1) : в„қ)) : в„Ӯ) := by
        unfold leftTentKernel
        have hcond : -1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0 := by
          constructor <;> linarith
        rw [if_pos hcond]
      have hright : leftTentKernel ((1 / 2 : в„қ) - t) = 0 := by
        unfold leftTentKernel
        have hnot : В¬ (-1 вүӨ (1 / 2 : в„қ) - t вҲ§ (1 / 2 : в„қ) - t вүӨ 0) := by
          intro h
          linarith [h.2]
        rw [if_neg hnot]
      unfold centeredTentWeight
      rw [abs_of_nonpos hle1, max_eq_right]
      В· rw [hleft, hright]
        simp
        ring
      В· linarith [ht0]
    В· have hhalf_le : (1 / 2 : в„қ) вүӨ t := by linarith
      have hgt : (1 / 2 : в„қ) < t := lt_of_le_of_ne hhalf_le htne.symm
      have hleft : leftTentKernel (t - (1 / 2 : в„қ)) = 0 := by
        unfold leftTentKernel
        have hnot : В¬ (-1 вүӨ t - (1 / 2 : в„қ) вҲ§ t - (1 / 2 : в„қ) вүӨ 0) := by
          intro h
          linarith [h.2]
        rw [if_neg hnot]
      have hright :
          leftTentKernel ((1 / 2 : в„қ) - t) =
            (((2 * (((1 / 2 : в„қ) - t) + 1) : в„қ)) : в„Ӯ) := by
        unfold leftTentKernel
        have hcond : -1 вүӨ (1 / 2 : в„қ) - t вҲ§ (1 / 2 : в„қ) - t вүӨ 0 := by
          constructor <;> linarith
        rw [if_pos hcond]
      unfold centeredTentWeight
      rw [abs_of_nonneg (by linarith), max_eq_right]
      В· rw [hleft, hright]
        simp
        ring
      В· linarith [ht1]
  rw [hcoeff]

theorem centered_tent_intervalIntegral_eq_additive {f : в„• вҶ’ в„қ} {b X : в„қ} :
  вҲ« t in X..(X + 1),

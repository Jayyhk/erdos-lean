theorem continuousH2_exists_normalized_cocycle (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (x : H p 2 (G ⧸ N)) :
    ∃ ω : {ω : C((G ⧸ N) × (G ⧸ N), ZMod p) //
        _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω},
      QClass p G N hN ω = x ∧
      (∀ q : G ⧸ N, ω.1 (1, q) = 0) ∧
      (∀ q : G ⧸ N, ω.1 (q, 1) = 0) := by
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  let e := _root_.Erdos90.InhomogHomogIso.cohomologyIso p (G ⧸ N) 2
  let y : _root_.Erdos90.InhomogClassAPI.Cohomology p (G ⧸ N) 2 := e.symm x
  have hx : e y = x := by
    simp [y, e]
  rw [← hx]
  unfold _root_.Erdos90.InhomogClassAPI.Cohomology at y ⊢
  refine Submodule.Quotient.induction_on
    (p := _root_.Erdos90.InhomogClassAPI.coboundariesInCocycles p (G ⧸ N) 2)
    (x := y) ?_
  intro z
  have hz : (_root_.Erdos90.InhomogContsCochains.d p (G ⧸ N) 2) z.1 = 0 := by
    simp [_root_.Erdos90.InhomogClassAPI.Cocycles, z.2]
  have hcontract0 (g h k : G ⧸ N) :
      Fin.contractNth 0 (fun x y : G ⧸ N => x * y) ![g, h, k] = ![g * h, k] := by
    ext i
    fin_cases i
    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hcontract1 (g h k : G ⧸ N) :
      Fin.contractNth 1 (fun x y : G ⧸ N => x * y) ![g, h, k] = ![g, h * k] := by
    ext i
    fin_cases i
    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hcontract2 (g h k : G ⧸ N) :
      Fin.contractNth 2 (fun x y : G ⧸ N => x * y) ![g, h, k] = ![g, h] := by
    ext i
    fin_cases i
    all_goals simp [Fin.contractNth_apply_of_eq, Fin.contractNth_apply_of_gt,
      Fin.contractNth_apply_of_lt]
  have hpow : ((-1 : ZMod p) ^ 3) = -1 := by
    norm_num
  have hz' (g h k : G ⧸ N) :
      z.1 ![h, k] - z.1 ![g * h, k] + z.1 ![g, h * k] - z.1 ![g, h] = 0 := by
    have hz'' := congrArg (fun F => F ![g, h, k]) hz
    change _root_.Erdos90.InhomogContsCochains.dAux.toFun 2 z.1 ![g, h, k] = 0 at hz''
    simp [_root_.Erdos90.InhomogContsCochains.dAux.toFun, Fin.sum_univ_three,
      hcontract0, hcontract1, hcontract2] at hz''
    have hpair : (fun i : Fin 2 => ![h, k] i) = ![h, k] := by
      ext i
      fin_cases i <;> rfl
    rw [hpair] at hz''
    simpa [hpow, sub_eq_add_neg, add_assoc] using hz''
  let f : C((G ⧸ N) × (G ⧸ N), ZMod p) :=
    z.1.comp ⟨fun gh => ![gh.1, gh.2], by
      exact continuous_pi (fun i => by
        fin_cases i
        · simpa using (continuous_fst : Continuous fun gh : (G ⧸ N) × (G ⧸ N) => gh.1)
        · simpa using (continuous_snd : Continuous fun gh : (G ⧸ N) × (G ⧸ N) => gh.2))⟩
  have hf : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) f := by
    intro g h k
    simpa [f] using hz' g h k
  let c : ZMod p := f (1, 1)
  let b : C(G ⧸ N, ZMod p) :=
    ⟨fun _ => -c, continuous_const⟩
  let corr : C((G ⧸ N) × (G ⧸ N), ZMod p) :=
    ⟨fun _ => -c, continuous_const⟩
  have hcorr : _root_.Erdos90.InhomogClassAPI.IsCoboundary2 p (G ⧸ N) corr := by
    refine ⟨b, ?_⟩
    intro g h
    simp [corr, b, c]
  let ωfun : C((G ⧸ N) × (G ⧸ N), ZMod p) :=
    ⟨fun gh => f gh - c, by
      exact f.continuous.sub continuous_const⟩
  have hω : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ωfun := by
    intro g h k
    have hf' := hf g h k
    change (f (h, k) - c) - (f (g * h, k) - c) + (f (g, h * k) - c) - (f (g, h) - c) = 0
    rw [sub_eq_add_neg, sub_eq_add_neg, sub_eq_add_neg]
    rw [sub_eq_add_neg] at hf'
    abel_nf at hf' ⊢
    exact hf'
  have hof : _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) f hf = z := by
    apply Subtype.ext
    ext g
    change z.1 ![g 0, g 1] = z.1 g
    congr 1
    ext i
    fin_cases i <;> rfl
  have hzero :
      _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωfun hω -
          _root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) f hf) = 0 := by
    rw [_root_.Erdos90.InhomogClassAPI.classMap_eq_zero_iff]
    change
      (((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωfun hω :
            _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
          _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2) -
        ((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) f hf :
            _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
          _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2)) ∈
      _root_.Erdos90.InhomogClassAPI.Coboundaries p (G ⧸ N) 2
    have hdiff :
        (((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωfun hω :
              _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
            _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2) -
          ((_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) f hf :
              _root_.Erdos90.InhomogClassAPI.Cocycles p (G ⧸ N) 2) :
            _root_.Erdos90.InhomogContsCochains.Cochain p (G ⧸ N) 2)) =
          _root_.Erdos90.InhomogClassAPI.ofProd p (G ⧸ N) corr := by
      ext g
      change (ωfun (g 0, g 1) - f (g 0, g 1)) = corr (g 0, g 1)
      simp [ωfun, corr, c]
    rw [hdiff]
    exact _root_.Erdos90.InhomogClassAPI.ofProd_mem_coboundaries_of_isCoboundary2 p (G ⧸ N) corr hcorr
  have hclass :
      _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) ωfun hω) =
      _root_.Erdos90.InhomogClassAPI.classMap p (G ⧸ N) 2
        (_root_.Erdos90.InhomogClassAPI.ofIsCocycle2 p (G ⧸ N) f hf) := by
    rw [← sub_eq_zero]
    rw [← LinearMap.map_sub]
    exact hzero
  let ω : {ω : C((G ⧸ N) × (G ⧸ N), ZMod p) //
      _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G ⧸ N) ω} := ⟨ωfun, hω⟩
  refine ⟨ω, ?_, ?_, ?_⟩
  · dsimp [QClass, ω]
    rw [hclass, hof]
    rfl
  · intro q
    change ωfun (1, q) = 0
    change f (1, q) - c = 0
    have hf1 : f (1, q) = c := by
      simpa [c] using isCocycle2_map_one_fst p (G ⧸ N) f hf q
    rw [hf1]
    simp
  · intro q
    change ωfun (q, 1) = 0
    change f (q, 1) - c = 0
    have hf1 : f (q, 1) = c := by
      simpa [c] using isCocycle2_map_one_snd p (G ⧸ N) f hf q
    rw [hf1]
    simp

open CategoryTheory in

  have hQ0 : Q 0 = 0 := by
    simp [Q]
  have hP0 : P 0 = 0 := by
    simp [P]
  have hpartsПғ :
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) =
        (1 - E X) * P X - Пғ * (вҲ« t in (0 : в„қ)..X, P t * E t) := by
    calc
      Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) =
          Пғ * (Q X * P X - Q 0 * P 0 - (вҲ« t in (0 : в„қ)..X, P t * E t)) := by
            simpa using congrArg (fun z => Пғ * z) hparts'
      _ = (1 - E X) * P X - Пғ * (вҲ« t in (0 : в„қ)..X, P t * E t) := by
            rw [hQ0, hP0, hQ_formula X (by simp [hX])]
            field_simp [hПғ.ne']
            ring
  have hDQ_split' :
      (вҲ« t in (0 : в„қ)..X, D t) =
        Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) + (вҲ« t in (0 : в„қ)..X, D t * E t) := by
    exact (sub_eq_iff_eq_add).mp hDQ_split.symm
  have hfinal :
      (вҲ« t in (0 : в„қ)..X, D t * E t) =
        E X * P X + Пғ * (вҲ« t in (0 : в„қ)..X, P t * E t) := by
    calc
      (вҲ« t in (0 : в„қ)..X, D t * E t) =
          (вҲ« t in (0 : в„қ)..X, D t) - Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) := by
            linarith [hDQ_split']
      _ = P X - Пғ * (вҲ« t in (0 : в„қ)..X, D t * Q t) := by
            simp [P]
      _ = P X - ((1 - E X) * P X - Пғ * (вҲ« t in (0 : в„қ)..X, P t * E t)) := by
            rw [hpartsПғ]

  let L : в„• вҶ’ IntermediateField F K := fun j => IntermediateField.fixedField (((H j : ClosedSubgroup (Gal(K/F))) : Subgroup (Gal(K/F))))
  have hLfix : вҲҖ j, ((L j).fixingSubgroup : Subgroup (Gal(K/F))) = N j := by
    intro j
    simpa [L, H] using (InfiniteGalois.fixingSubgroup_fixedField (k := F) (K := K) (H j))
  have hLfin_gal : вҲҖ j, FiniteDimensional F (L j) вҲ§ IsGalois F (L j) := by
    intro j
    have hopen : IsOpen (((L j).fixingSubgroup : Subgroup (Gal(K/F))) : Set (Gal(K/F))) := by
      rw [hLfix j]
      exact hNopen j
    have hnormal : ((L j).fixingSubgroup : Subgroup (Gal(K/F))).Normal := by
      rw [hLfix j]
      exact hNnormal j
    exact (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := F) (K := K) (L := L j)).1 вҹЁhopen, hnormalвҹ©
  have hLfd : вҲҖ j, FiniteDimensional F (L j) := fun j => (hLfin_gal j).1
  have hLgalois : вҲҖ j, IsGalois F (L j) := fun j => (hLfin_gal j).2
  have hLnum : вҲҖ j, NumberField (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j
    letI : Module.Finite F (L j) := hLfd j
    exact NumberField.of_module_finite F (L j)
  have hphi_surj : вҲҖ j, Function.Surjective (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map) : Gal(K/F) вҶ’* (Q.Q в§ё (U j : Subgroup Q.Q))) := by
    intro j q
    rcases (QuotientGroup.mk'_surjective (N := (U j : Subgroup Q.Q))) q with вҹЁx, rflвҹ©
    rcases Q.surjective x with вҹЁg, rflвҹ©
    exact вҹЁg, rflвҹ©
  have hNker : вҲҖ j, N j = (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map) : Gal(K/F) вҶ’* (Q.Q в§ё (U j : Subgroup Q.Q))).ker := by
    intro j
    change ((U j : Subgroup Q.Q).comap Q.map) = (((QuotientGroup.mk' (U j : Subgroup Q.Q)).comp Q.map)).ker
    rw [вҶҗ MonoidHom.comap_ker (QuotientGroup.mk' (U j : Subgroup Q.Q)) Q.map, QuotientGroup.ker_mk']
  let hquot_equiv : вҲҖ j, (Q.Q в§ё (U j : Subgroup Q.Q)) вүғ* (Gal(K/F) в§ё N j) := by
    intro j

    Continuous ((MulAut.conjNormal g : ↥N ≃* ↥N).symm : ↥N → ↥N) := by
  refine continuous_induced_rng.2 ?_
  simp only [Function.comp_def, MulAut.conjNormal_symm_apply]
  exact (continuous_const.mul continuous_subtype_val).mul continuous_const

private noncomputable def actAux (e : ↥N ≃* ↥N) (he : Continuous (e : ↥N → ↥N))
    (hesymm : Continuous (e.symm : ↥N → ↥N)) :
    (H1ContsTrivial p G N : TopModuleCat (ZMod p)) ≅ H1ContsTrivial p G N where
  hom := ContinuousCohomology.cohomologyMapTrivial (ZMod p)
    e.symm.toMonoidHom hesymm (TopModuleCat.of (ZMod p) (ZMod p)) 1
  inv := ContinuousCohomology.cohomologyMapTrivial (ZMod p)
    e.toMonoidHom he (TopModuleCat.of (ZMod p) (ZMod p)) 1
  hom_inv_id := by

    have heq : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id _ := by ext x; simp
    have hcomp := ContinuousCohomology.cohomologyMapTrivial_comp (ZMod p)
      e.toMonoidHom e.symm.toMonoidHom he hesymm
      (TopModuleCat.of (ZMod p) (ZMod p)) 1

    have hid := ContinuousCohomology.cohomologyMapTrivial_id (ZMod p)
      (TopModuleCat.of (ZMod p) (ZMod p)) (G := ↥N) 1
    calc ContinuousCohomology.cohomologyMapTrivial (ZMod p) e.symm.toMonoidHom
            hesymm (TopModuleCat.of (ZMod p) (ZMod p)) 1 ≫
          ContinuousCohomology.cohomologyMapTrivial (ZMod p) e.toMonoidHom
            he (TopModuleCat.of (ZMod p) (ZMod p)) 1
        = ContinuousCohomology.cohomologyMapTrivial (ZMod p)
            (e.symm.toMonoidHom.comp e.toMonoidHom) (hesymm.comp he)
            (TopModuleCat.of (ZMod p) (ZMod p)) 1 := hcomp.symm
      _ = ContinuousCohomology.cohomologyMapTrivial (ZMod p) (MonoidHom.id _) continuous_id
            (TopModuleCat.of (ZMod p) (ZMod p)) 1 := by
              congr 1
      _ = 𝟙 _ := hid
  inv_hom_id := by

    have heq : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id _ := by ext x; simp
    have hcomp := ContinuousCohomology.cohomologyMapTrivial_comp (ZMod p)
      e.symm.toMonoidHom e.toMonoidHom hesymm he
      (TopModuleCat.of (ZMod p) (ZMod p)) 1
    have hid := ContinuousCohomology.cohomologyMapTrivial_id (ZMod p)
      (TopModuleCat.of (ZMod p) (ZMod p)) (G := ↥N) 1
    calc ContinuousCohomology.cohomologyMapTrivial (ZMod p) e.toMonoidHom
            he (TopModuleCat.of (ZMod p) (ZMod p)) 1 ≫
          ContinuousCohomology.cohomologyMapTrivial (ZMod p) e.symm.toMonoidHom
            hesymm (TopModuleCat.of (ZMod p) (ZMod p)) 1
        = ContinuousCohomology.cohomologyMapTrivial (ZMod p)
            (e.toMonoidHom.comp e.symm.toMonoidHom) (he.comp hesymm)
            (TopModuleCat.of (ZMod p) (ZMod p)) 1 := hcomp.symm
      _ = ContinuousCohomology.cohomologyMapTrivial (ZMod p) (MonoidHom.id _) continuous_id
            (TopModuleCat.of (ZMod p) (ZMod p)) 1 := by
              congr 1
      _ = 𝟙 _ := hid

noncomputable def h1ConjAction :
    G →* (H1ContsTrivial p G N ≃ₗ[ZMod p] H1ContsTrivial p G N) :=
  H1ConjugationInternal.h1ConjAction p G N

theorem h1ConjAction_apply (g : G) (x : H1ContsTrivial p G N) :
    h1ConjAction p G N g x = (h1ConjMap p G N g).hom x :=
  H1ConjugationInternal.h1ConjAction_apply p G N g x

theorem N_acts_trivially (n : G) (hn : n ∈ N) :
    h1ConjAction p G N n = LinearEquiv.refl (ZMod p) (H1ContsTrivial p G N) :=
  H1ConjugationInternal.N_acts_trivially p G N n hn

noncomputable def h1InvariantSubmodule :
    Submodule (ZMod p) (H1ContsTrivial p G N) where
  carrier := { x | ∀ g : G, h1ConjAction p G N g x = x }
  zero_mem' := by intro g; simp
  add_mem' := by
    intro x y hx hy g
    simp [map_add, hx g, hy g]
  smul_mem' := by
    intro c x hx g
    simp [map_smul, hx g]

theorem h1InvariantSubmodule_eq_opaque :
    h1InvariantSubmodule p G N = h1NormalInvariantSubmodule p G N := by

  apply Submodule.ext
  intro x
  rfl


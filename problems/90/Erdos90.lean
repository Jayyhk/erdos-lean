    exact (Module.surjective_piEquiv_apply_iff
      (О№ := Fin в„“) (R := ZMod 3) (M := Fin в„“ вҶ’ ZMod 3) v).2 _hspan
  have hTinj : Function.Injective T := by
    simpa using
      ((LinearMap.injective_iff_surjective : Function.Injective T вҶ” Function.Surjective T).2
        hTsurj)
  let eT : (Fin в„“ вҶ’ ZMod 3) вүғвӮ—[ZMod 3] (Fin в„“ вҶ’ ZMod 3) :=
    T.linearEquivOfInjective hTinj rfl
  let lin : (Fin в„“ вҶ’ ZMod 3) вҶ’вӮ—[ZMod 3] ZMod 3 :=
    (Pi.basisFun (ZMod 3) (Fin в„“)).sumCoords.comp eT.symm.toLinearMap
  refine вҹЁlin, ?_, ?_вҹ©
  В· intro hlin
    let i0 : Fin в„“ := вҹЁ0, _hв„“вҹ©
    have hbasis : eT.symm (v i0) = Pi.basisFun (ZMod 3) (Fin в„“) i0 := by
      apply eT.injective
      rw [eT.apply_symm_apply]
      simp [eT, T, Module.piEquiv]
    have h1 : lin (v i0) = 1 := by
      change (Pi.basisFun (ZMod 3) (Fin в„“)).sumCoords (eT.symm (v i0)) = 1
      rw [hbasis]
      simp
    have h0 : lin (v i0) = 0 := by
      simp [hlin]
    have h10 : (1 : ZMod 3) = 0 := by
      simp [h1] at h0
    exact (by decide : (1 : ZMod 3) вү  0) h10
  В· intro i
    have hbasis : eT.symm (v i) = Pi.basisFun (ZMod 3) (Fin в„“) i := by
      apply eT.injective
      rw [eT.apply_symm_apply]
      simp [eT, T, Module.piEquiv]
    change (Pi.basisFun (ZMod 3) (Fin в„“)).sumCoords (eT.symm (v i)) = 1
    rw [hbasis]
    simp

theorem fun_zmod3_equiv_pow_three_and_comm (n : в„•) (G : Type) [Group G]
    (e : G вүғ* Multiplicative (Fin n вҶ’ ZMod 3)) :
    (вҲҖ g : G, g ^ 3 = 1) вҲ§
    (вҲҖ g h : G, g * h = h * g) := by
  constructor
  В· intro g

  haveI : TotallyDisconnectedSpace (G в§ё N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  let s : C(G в§ё N, G) :=
    _root_.Erdos90.TransgressionContinuous.chosenSection G N hN
  let hs : вҲҖ x : G в§ё N, QuotientGroup.mk' N (s x) = x :=
    _root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN
  let ПҮh : Additive вҶҘN вҶ’+ ZMod p :=
    _root_.Erdos90.TransgressionContinuousInternal.h1ToHom_explicit p G N hN ПҮ.1
  let ПүПҮ : C((G в§ё N) Г— (G в§ё N), ZMod p) :=
    _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs ПҮh

    exact eq_sub_iff_add_eq.mpr (by simpa [add_comm] using h_split)
  have h_exp_rewrite :
      вҲҖ x : в„қ,
        ((((logRescalePartialSum f (x + Оҙ) - b : в„қ) : в„Ӯ) * Complex.exp (-z * x))) =
          Complex.exp (z * Оҙ) * U (x + Оҙ) := by
    intro x
    have hexp : Complex.exp (-z * x) = Complex.exp (z * Оҙ) * Complex.exp (-z * (x + Оҙ)) := by

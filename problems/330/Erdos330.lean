    ((crtProductPstarFinset M (m a) (fun i : NonselectedIndex P a => m (i : ℕ))
          φ (a : ZMod M) β e h).card : ℝ) / (M : ℝ) =
        (1 : ℝ) / (m a : ℝ) *
          ∏ i : NonselectedIndex P a, (1 - (1 : ℝ) / (m (i : ℕ) : ℝ)) := by
      exact crtProductPstarFinset_card_real_formula M (m a)

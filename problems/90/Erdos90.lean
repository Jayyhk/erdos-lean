  have hs : ∀ q : G ⧸ N, QuotientGroup.mk' N (s q) = q :=
    _root_.Erdos90.TransgressionContinuous.chosenSection_spec G N hN
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  let b : C(G ⧸ N, ZMod p) := by
    refine ⟨fun q => ψ (s q), ?_⟩
    simpa using hψcont.comp s.continuous
  let χN :=
    _root_.Erdos90.TransgressionContinuous.h1ToHom p G N hN ((restriction p G N 1).hom y)
  have hχNcont : Continuous (χN : Additive ↥N → ZMod p) := by
    simpa [χN] using
      _root_.Erdos90.TransgressionContinuous.h1ToHom_continuous p G N hN
        ((restriction p G N 1).hom y)
  let ω := _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs χN
  have hb : ∀ g h : G ⧸ N, ω (g, h) = b h - b (g * h) + b g := by
    intro g h
    show _root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle p G N s hs χN
        (g, h) = b h - b (g * h) + b g
    simp only [_root_.Erdos90.TransgressionContinuousInternal.schreier2Cocycle,
      hχNcont, dif_pos]
    have hχN_eval : ∀ n : Additive ↥N,
        χN n = (ψ.comp (MonoidHom.toAdditive N.subtype)) n := by
      intro n; exact congrArg (fun f : Additive ↥N →+ ZMod p => f n) hψ
    show χN (Additive.ofMul
        (_root_.Erdos90.TransgressionContinuousInternal.schreierDefect G N s hs g h)) =
      b h - b (g * h) + b g
    rw [hχN_eval]
    show ψ (Additive.ofMul (s g) + Additive.ofMul (s h) + -Additive.ofMul (s (g * h))) =
      ψ (Additive.ofMul (s h)) - ψ (Additive.ofMul (s (g * h))) + ψ (Additive.ofMul (s g))
    rw [map_add, map_add, map_neg]

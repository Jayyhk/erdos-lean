theorem lemma_2_4_shift_count_eq_lattice_encard (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) (u : рқ’ҹ.K) (hОӣu : рқ’ҹ.ОҰ u вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V)) : ({l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + (l : рқ’ҹ.V) + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R}.encard) = ((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card := by
  classical
  let lu : рқ’ҹ.Оӣ := вҹЁрқ’ҹ.ОҰ u, hОӣuвҹ©
  let S : Set рқ’ҹ.Оӣ :=
    {l | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R вҲ§
        a + (l : рқ’ҹ.V) + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R}
  let T : Set рқ’ҹ.V :=
    {x | x вҲҲ рқ’ҹ.X a R вҲ§ x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X a R}
  let F : Finset рқ’ҹ.V :=
    (рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)
  let f : рқ’ҹ.Оӣ вҶ’ рқ’ҹ.V := fun l => a + (l : рқ’ҹ.V)
  have hbij : Set.BijOn f S T := by
    refine вҹЁ?_, ?_, ?_вҹ©
    В· intro l hl
      refine вҹЁ?_, ?_вҹ©
      В· exact вҹЁвҹЁl, rflвҹ©, hl.1вҹ©
      В· refine вҹЁ?_, hl.2вҹ©
        refine вҹЁl + lu, ?_вҹ©
        simp [f, lu, add_assoc]
    В· intro lвӮҒ hlвӮҒ lвӮӮ hlвӮӮ hEq
      apply Subtype.ext
      exact add_left_cancel hEq
    В· intro x hx
      rcases hx.1 with вҹЁвҹЁl, rflвҹ©, hlBвҹ©
      refine вҹЁl, ?_, rflвҹ©
      exact вҹЁhlB, hx.2.2вҹ©
  have hencard : S.encard = T.encard := by
    exact Set.encard_congr (Set.BijOn.equiv f hbij)
  have hT : T = (F : Set рқ’ҹ.V) := by
    ext x
    simp [T, F, AdmissibleDatum.X_finset]
  calc
    ({l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + (l : рқ’ҹ.V) + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R}.encard)
        = S.encard := by rfl
    _ = T.encard := hencard
    _ = (F : Set рқ’ҹ.V).encard := by rw [hT]
    _ = F.card := Set.encard_coe_eq_coe_finsetCard F
    _ = ((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card := by rfl

theorem lemma_2_4_vaddInvariantVolume (рқ’ҹ : AdmissibleDatum) : MeasureTheory.VAddInvariantMeasure (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V MeasureTheory.volume := by

theorem primesCongOneMod3_count_power_lower_bound: вҲғ Оҙ : в„қ, 0 < Оҙ вҲ§ вҲғ XвӮҖ : в„•, вҲҖ X : в„•, XвӮҖ вүӨ X вҶ’

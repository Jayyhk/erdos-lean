      simpa using (integrableOn_exp_mul_complex_Ioi (a := -z) (c := 0) hneg)
    simpa using hexp.const_mul (((a.re : ℝ) : ℂ))
  calc
    (fun z : ℂ => (g (1 + z) - ((a.re : ℝ) : ℂ)) / (1 + z)) z
        = (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
            ((a.re : ℝ) : ℂ) / z := by
          simpa using hmain
    _ = (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
          ∫ x in Set.Ioi (0 : ℝ), (((a.re : ℝ) : ℂ) * Complex.exp (-z * x)) := by
          rw [integral_const_mul_cexp_neg_Ioi (b := a.re) hz]

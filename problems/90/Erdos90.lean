      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) := by
  exact proposition_3_2_compositum_and_F_bridge ℓ _hℓ r _hr_prime _hr_inj _hr_mod3

theorem proposition_3_2 (ℓ : ℕ) (_hℓ : 0 < ℓ) (r : Fin ℓ → ℕ)
    (_hr_prime : ∀ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : ∀ i, r i % 3 = 1) :
    ∃ (F M : Type)
      (_ : Field F) (_ : Field M)
      (_ : CharZero F) (_ : CharZero M)
      (_ : NumberField F) (_ : NumberField M)
      (_ : IsTotallyReal F) (_ : IsTotallyReal M)
      (_ : IsGalois ℚ F) (_ : IsGalois ℚ M)
      (_ : Algebra F M) (_ : IsGalois F M),
      Module.finrank ℚ F = 3 ∧
      Module.finrank F M = 3 ^ (ℓ - 1) ∧
      (NumberField.discr F).natAbs = (∏ i, r i) ^ 2 ∧
      (NumberField.discr M).natAbs = (∏ i, r i) ^ (2 * 3 ^ (ℓ - 1)) ∧
      (∀ σ : M ≃ₐ[F] M, σ ^ 3 = 1) ∧
      (∀ σ : M ≃ₐ[ℚ] M, σ ^ 3 = 1) ∧
      (∀ σ τ : M ≃ₐ[F] M, σ * τ = τ * σ) ∧
      (∀ σ τ : M ≃ₐ[ℚ] M, σ * τ = τ * σ) ∧
      Nat.card (M ≃ₐ[F] M) = 3 ^ (ℓ - 1) ∧
      Nonempty ((M ≃ₐ[F] M) ≃*
        Multiplicative (Fin (ℓ - 1) → ZMod 3)) ∧
      IsPGroup 3 (M ≃ₐ[F] M) ∧
      IsEverywhereUnramified F M := by
  rcases proposition_3_2_compositum_and_F_local ℓ _hℓ r _hr_prime _hr_inj _hr_mod3 with
    ⟨M, _instFieldM, _instCharZeroM, _instNumberFieldM, _instTotallyRealM, _instGaloisQM,
      F, _instFieldF, _instCharZeroF, _instNumberFieldF, _instTotallyRealF, _instGaloisQF,
      _instAlgFM, _instTower, _instFiniteDimensional, _instGaloisFM,
      hfinQM, habs, hdiscM, hfinQF, hFabs, hfinFM, hodd, hdiscF, hpowRel, hcommRel⟩
  let hpowAbs := (fun_zmod3_equiv_pow_three_and_comm ℓ (M ≃ₐ[ℚ] M) (Classical.choice habs)).1
  let hcommAbs := (fun_zmod3_equiv_pow_three_and_comm ℓ (M ≃ₐ[ℚ] M) (Classical.choice habs)).2
  have hcard : Nat.card (M ≃ₐ[F] M) = 3 ^ (ℓ - 1) := by
    rw [IsGalois.card_aut_eq_finrank F M, hfinFM]
  have hmulEquiv : Nonempty ((M ≃ₐ[F] M) ≃* Multiplicative (Fin (ℓ - 1) → ZMod 3)) := by
    exact elementary_abelian_three_mulEquiv (ℓ - 1) (M ≃ₐ[F] M) hpowRel hcommRel hcard
  have hPGroup : IsPGroup 3 (M ≃ₐ[F] M) := by
    rw [IsPGroup.iff_card]
    exact ⟨ℓ - 1, hcard⟩
  have hdiscTower : (NumberField.discr M).natAbs = (NumberField.discr F).natAbs ^ Module.finrank F M := by
    rw [hdiscM, hdiscF, hfinFM]
    rw [pow_mul]
  have hunram : IsEverywhereUnramified F M :=
    IsEverywhereUnramified_of_discr_eq_and_totally_real_local F M hodd hdiscTower
  refine ⟨F, M, _instFieldF, _instFieldM, _instCharZeroF, _instCharZeroM, _instNumberFieldF, _instNumberFieldM,
    _instTotallyRealF, _instTotallyRealM, _instGaloisQF, _instGaloisQM, _instAlgFM, _instGaloisFM, ?_⟩
  exact ⟨hfinQF, hfinFM, hdiscF, hdiscM, hpowRel, hpowAbs, hcommRel, hcommAbs, hcard, hmulEquiv, hPGroup, hunram⟩


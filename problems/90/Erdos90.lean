  have hdiv : p вҲЈ Nat.card (Q в§ё M) := (hQ.to_quotient M).card_eq_or_dvd.resolve_left hcard_ne_one
  have hcard_eq_p : Nat.card (Q в§ё M) = p := ((Nat.prime_dvd_prime_iff_eq hp hprimecard).1 hdiv).symm
  have hcomm : commutator Q вүӨ M := by
    have hmulComm : Std.Commutative (fun a b : Q в§ё M => a * b) := by

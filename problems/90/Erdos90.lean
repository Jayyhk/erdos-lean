noncomputable def BKContsHomSubmodule (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) :
    Submodule (ZMod p) (↥N → ZMod p) where
  carrier :=
    { f |
      (∀ x y : ↥N, f (x * y) = f x + f y) ∧
        f 1 = 0 ∧
        Continuous f }
  zero_mem' :=
    ⟨by intros; simp, rfl, continuous_const⟩
  add_mem' := by
    rintro f g ⟨hf_hom, hf_one, hf_c⟩ ⟨hg_hom, hg_one, hg_c⟩
    refine ⟨?_, ?_, hf_c.add hg_c⟩
    · intro x y
      simp [hf_hom, hg_hom, Pi.add_apply]
      ring
    · simp [hf_one, hg_one, Pi.add_apply]
  smul_mem' := by
    rintro c f ⟨hf_hom, hf_one, hf_c⟩
    refine ⟨?_, ?_, ?_⟩
    · intro x y
      simp [Pi.smul_apply, hf_hom, mul_add]
    · simp [Pi.smul_apply, hf_one]
    · change Continuous (fun x => c • f x)
      exact hf_c.const_smul c

noncomputable def BKGInvariantContsHomSubmodule (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    Submodule (ZMod p) (↥N → ZMod p) where
  carrier :=
    { f |
      (∀ x y : ↥N, f (x * y) = f x + f y) ∧
        f 1 = 0 ∧
        Continuous f ∧
        ∀ (h : G) (x : ↥N),
          f ⟨h * (x : G) * h⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 h⟩ = f x }
  zero_mem' :=
    ⟨by intros; simp, rfl, continuous_const, by intros; simp⟩
  add_mem' := by
    rintro f g ⟨hf_hom, hf_one, hf_c, hf_g⟩ ⟨hg_hom, hg_one, hg_c, hg_g⟩
    refine ⟨?_, ?_, hf_c.add hg_c, ?_⟩
    · intro x y
      simp [hf_hom, hg_hom, Pi.add_apply]
      ring
    · simp [hf_one, hg_one, Pi.add_apply]
    · intro h x
      simp [Pi.add_apply, hf_g h x, hg_g h x]
  smul_mem' := by
    rintro c f ⟨hf_hom, hf_one, hf_c, hf_g⟩
    refine ⟨?_, ?_, ?_, ?_⟩
    · intro x y
      simp [Pi.smul_apply, hf_hom, mul_add]
    · simp [Pi.smul_apply, hf_one]
    · change Continuous (fun x => c • f x)
      exact hf_c.const_smul c
    · intro h x
      simp [Pi.smul_apply, hf_g h x]

structure BKGInvariantHom (p : ℕ) (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] where
  hom : ↥N →* Multiplicative (ZMod p)
  continuous : Continuous hom
  ginv : ∀ (g : G) (x : ↥N),
    hom ⟨g * (x : G) * g⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 g⟩ = hom x

noncomputable def BKHomogeneousComplex (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) : CochainComplex (TopModuleCat (ZMod p)) ℕ :=
  ((ContinuousCohomology.homogeneousCochains (ZMod p) ↥N).obj
    (Action.trivial ↥N (TopModuleCat.of (ZMod p) (ZMod p))))

theorem bk_BKContsHom_cycle_source (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (f : BKContsHomSubmodule p G N) :
    ∃ c : (BKHomogeneousComplex p G N).X 1,
      ((BKHomogeneousComplex p G N).d 1 2).hom c = 0 ∧
      (let c' : C(↥N, C(↥N, ZMod p)) := c.1
       ∀ x y : ↥N,
         c' x y =
           (f.1) ⟨(x : G)⁻¹ * y, by
             simpa using N.mul_mem (N.inv_mem x.2) y.2⟩) := by
  classical
  let rep := Action.trivial ↥N (TopModuleCat.of (ZMod p) (ZMod p))
  let φ : C(↥N, ZMod p) := ⟨f.1, f.2.2.2⟩
  let c0 : C(↥N, C(↥N, ZMod p)) :=
    (((ContinuousCohomology.MultiInd.d (ZMod p) ↥N 1).app rep).hom φ)
  let d2c0 : C(↥N, C(↥N, C(↥N, ZMod p))) :=
    (((ContinuousCohomology.MultiInd.d (ZMod p) ↥N 2).app rep).hom c0)
  have hc0_eval : ∀ x y : ↥N, c0 x y = f.1 y - f.1 x := by
    intro x y
    dsimp [c0, φ, ContinuousCohomology.MultiInd.d, ContinuousCohomology.MultiInd.functor,
      ContinuousCohomology.const, ContinuousCohomology.I, ContinuousCohomology.Iobj,
      CategoryTheory.Functor.whiskerLeft, CategoryTheory.Functor.whiskerRight]
    rfl
  have hpt (a b d : ↥N) : d2c0 a b d = 0 := by
    have h := CategoryTheory.NatTrans.congr_app
      (ContinuousCohomology.MultiInd.d_comp_d (R := ZMod p) (G := ↥N) 1) rep
    have h' := congrArg (fun m => ((((m.hom φ : C(↥N, C(↥N, C(↥N, ZMod p)))) a) b) d)) h
    exact h'
  refine ⟨⟨c0, ?_⟩, ?_, ?_⟩
  · intro g
    change ((ContinuousCohomology.Iobj (ContinuousCohomology.Iobj rep)).ρ g).hom c0 = c0
    apply ContinuousMap.ext
    intro x
    apply ContinuousMap.ext
    intro y
    rw [ContinuousCohomology.Iobj_ρ_apply, ContinuousCohomology.Iobj_ρ_apply]
    change (c0 (g⁻¹ * x)) (g⁻¹ * y) = (c0 x) y
    rw [hc0_eval, hc0_eval]
    have hgy : f.1 (g⁻¹ * y) = f.1 (g⁻¹) + f.1 y := by
      simpa [rep] using f.2.1 g⁻¹ y
    have hgx : f.1 (g⁻¹ * x) = f.1 (g⁻¹) + f.1 x := by
      simpa [rep] using f.2.1 g⁻¹ x
    rw [hgy, hgx]
    ring
  · apply Subtype.ext
    apply ContinuousMap.ext
    intro a
    apply ContinuousMap.ext
    intro b
    apply ContinuousMap.ext
    intro d
    change d2c0 a b d = 0
    exact hpt a b d
  · change ∀ x y : ↥N, c0 x y =
        f.1 ⟨(x : G)⁻¹ * y, by simpa using N.mul_mem (N.inv_mem x.2) y.2⟩
    intro x y
    rw [hc0_eval]
    have hxy : f.1 y = f.1 x + f.1 ⟨(x : G)⁻¹ * y, by simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := by
      have hm : x * ⟨(x : G)⁻¹ * y, by simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ = y := by
        apply Subtype.ext
        simp [mul_assoc]
      simpa [hm] using f.2.1 x ⟨(x : G)⁻¹ * y, by simpa using N.mul_mem (N.inv_mem x.2) y.2⟩
    have hxy' := congrArg (fun z => z - f.1 x) hxy
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hxy'

theorem bk_conjNormal_continuous (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] (g : G) :
    Continuous ((MulAut.conjNormal g : ↥N ≃* ↥N) : ↥N → ↥N) := by
  refine continuous_induced_rng.2 ?_
  simpa [MulAut.conjNormal_apply, mul_assoc] using
    ((continuous_const.mul continuous_subtype_val).mul continuous_const)

noncomputable def bk_cycles1_cochain (p : ℕ) [Fact p.Prime] (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z : (BKHomogeneousComplex p G N).cycles 1) : C(↥N, C(↥N, ZMod p)) :=
  (((BKHomogeneousComplex p G N).iCycles 1).hom z).1

theorem bk_cycles1_cochain_injective (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    Function.Injective (bk_cycles1_cochain p G N) := by
  intro z z' h
  let K := BKHomogeneousComplex p G N
  let fM : (CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p))).obj (K.cycles 1) ⟶
      (CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p))).obj (K.X 1) :=
    (CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p))).map (K.iCycles 1)
  have hf : Function.Injective fM := by
    exact (ModuleCat.mono_iff_injective fM).1 inferInstance
  apply hf
  apply Subtype.ext
  simpa [fM, K, bk_cycles1_cochain] using h

theorem bk_BKContsHom_to_cycles1 (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    ∃ invFun : BKContsHomSubmodule p G N →ₗ[ZMod p] (BKHomogeneousComplex p G N).cycles 1,
      ∀ (f : BKContsHomSubmodule p G N) (x y : ↥N),
        bk_cycles1_cochain p G N (invFun f) x y =
          (f.1) ⟨(x : G)⁻¹ * y, by
            simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := by
  classical
  let K := BKHomogeneousComplex p G N
  let chooseC : BKContsHomSubmodule p G N → K.X 1 :=
    fun f => Classical.choose (bk_BKContsHom_cycle_source p G N f)
  let chooseHzero : ∀ f : BKContsHomSubmodule p G N, ((K.d 1 2).hom (chooseC f)) = 0 :=
    fun f => (Classical.choose_spec (bk_BKContsHom_cycle_source p G N f)).1
  let S := K.sc' 0 1 2
  have hi : (ComplexShape.up ℕ).prev 1 = 0 := by
    simp
  have hk : (ComplexShape.up ℕ).next 1 = 2 := by
    simp
  let kf : CategoryTheory.Limits.KernelFork S.g :=
    CategoryTheory.Limits.KernelFork.ofι (TopModuleCat.kerι (K.d 1 2))
      (TopModuleCat.kerι_comp (K.d 1 2))
  let iso1 : kf.pt ≅ S.cycles :=
    S.isoCyclesOfIsLimit (kf := kf) (TopModuleCat.isLimitKer (K.d 1 2))
  let iso2 : K.cycles 1 ≅ S.cycles :=
    K.cyclesIsoSc' 0 1 2 hi hk
  let φ := CategoryTheory.CategoryStruct.comp iso1.hom iso2.inv
  have hassoc :
      CategoryTheory.CategoryStruct.comp (CategoryTheory.CategoryStruct.comp iso1.hom iso2.inv)
        (K.iCycles 1) =
      CategoryTheory.CategoryStruct.comp iso1.hom
        (CategoryTheory.CategoryStruct.comp iso2.inv (K.iCycles 1)) := by
    simp
  have hφi : CategoryTheory.CategoryStruct.comp φ (K.iCycles 1) = TopModuleCat.kerι (K.d 1 2) := by
    dsimp [φ]
    rw [hassoc]
    rw [HomologicalComplex.cyclesIsoSc'_inv_iCycles]
    simpa [kf, iso1, S] using
      (CategoryTheory.ShortComplex.isoCyclesOfIsLimit_hom_iCycles
        (S := S) (kf := kf) (hkf := TopModuleCat.isLimitKer (K.d 1 2)))
  let invFunToFun : BKContsHomSubmodule p G N → K.cycles 1 :=
    fun f => φ.hom ⟨chooseC f, chooseHzero f⟩
  have hιelem : ∀ f : BKContsHomSubmodule p G N,
      ((K.iCycles 1).hom (invFunToFun f)) = chooseC f := by
    intro f
    let zker : kf.pt := ⟨chooseC f, chooseHzero f⟩
    have h := congrArg (fun η => η.hom zker) hφi
    simpa [invFunToFun, zker, TopModuleCat.kerι] using h
  have h_invFun :
      ∀ (f : BKContsHomSubmodule p G N) (x y : ↥N),
        bk_cycles1_cochain p G N (invFunToFun f) x y =
          (f.1) ⟨(x : G)⁻¹ * y, by
            simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := by
    intro f x y
    have hchoose := (Classical.choose_spec (bk_BKContsHom_cycle_source p G N f)).2
    dsimp [chooseC] at hchoose
    rw [bk_cycles1_cochain, hιelem f]
    exact hchoose x y
  let invFun : BKContsHomSubmodule p G N →ₗ[ZMod p] K.cycles 1 :=
    { toFun := invFunToFun
      map_add' := by
        intro f g
        apply bk_cycles1_cochain_injective p G N
        ext x y
        calc
          bk_cycles1_cochain p G N (invFunToFun (f + g)) x y
              = ((f + g).1) ⟨(x : G)⁻¹ * y, by
                  simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ :=
                h_invFun (f + g) x y
          _ = (f.1) ⟨(x : G)⁻¹ * y, by
                simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ +
              (g.1) ⟨(x : G)⁻¹ * y, by
                simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := rfl
          _ = bk_cycles1_cochain p G N (invFunToFun f) x y +
              bk_cycles1_cochain p G N (invFunToFun g) x y := by
                rw [h_invFun f x y, h_invFun g x y]
          _ = bk_cycles1_cochain p G N (invFunToFun f + invFunToFun g) x y := by
                unfold bk_cycles1_cochain
                rw [map_add]
                rfl
      map_smul' := by
        intro c f
        apply bk_cycles1_cochain_injective p G N
        ext x y
        calc
          bk_cycles1_cochain p G N (invFunToFun (c • f)) x y
              = ((c • f).1) ⟨(x : G)⁻¹ * y, by
                  simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ :=
                h_invFun (c • f) x y
          _ = c • (f.1) ⟨(x : G)⁻¹ * y, by
                simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := rfl
          _ = c • bk_cycles1_cochain p G N (invFunToFun f) x y := by
                rw [h_invFun f x y]
          _ = bk_cycles1_cochain p G N (c • invFunToFun f) x y := by
                unfold bk_cycles1_cochain
                rw [map_smul]
                rfl }
  refine ⟨invFun, ?_⟩
  intro f x y
  exact h_invFun f x y

noncomputable def bk_cycles1_eval (p : ℕ) [Fact p.Prime] (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z : (BKHomogeneousComplex p G N).cycles 1) : ↥N → ZMod p :=
  fun y => bk_cycles1_cochain p G N z 1 y

theorem bk_cycles1_eval_add (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z w : (BKHomogeneousComplex p G N).cycles 1) (y : ↥N) :
    bk_cycles1_eval p G N (z + w) y =
      bk_cycles1_eval p G N z y + bk_cycles1_eval p G N w y := by
  unfold bk_cycles1_eval bk_cycles1_cochain
  rw [ContinuousLinearMap.map_add]
  rfl

theorem bk_cycles1_eval_smul (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (c : ZMod p) (z : (BKHomogeneousComplex p G N).cycles 1) (y : ↥N) :
    bk_cycles1_eval p G N (c • z) y = c * bk_cycles1_eval p G N z y := by
  unfold bk_cycles1_eval bk_cycles1_cochain
  let f := ((BKHomogeneousComplex p G N).iCycles 1).hom
  rw [ContinuousLinearMap.map_smul]
  rfl

theorem bk_cycles1_reconstruct (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z : (BKHomogeneousComplex p G N).cycles 1) (x y : ↥N) :
    bk_cycles1_cochain p G N z x y =
      bk_cycles1_cochain p G N z 1
        ⟨(x : G)⁻¹ * y, by
          simpa using N.mul_mem (N.inv_mem x.2) y.2⟩ := by
  let c := bk_cycles1_cochain p G N z
  have hz := (((BKHomogeneousComplex p G N).iCycles 1).hom z).2 x
  have hz' := congrArg (fun f : C(↥N, C(↥N, ZMod p)) => f x y) hz
  change
    ((((ContinuousCohomology.Iobj
        (ContinuousCohomology.Iobj
          (Action.trivial ↥N (TopModuleCat.of (ZMod p) (ZMod p))))).ρ x).hom c) x) y = c x y at hz'
  rw [ContinuousCohomology.Iobj_ρ_apply, ContinuousCohomology.Iobj_ρ_apply] at hz'
  simpa [Action.trivial] using hz'.symm

theorem bk_cycles1_eval_mem_BKContsHom (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (z : (BKHomogeneousComplex p G N).cycles 1) :
    bk_cycles1_eval p G N z ∈ BKContsHomSubmodule p G N := by
  let K := BKHomogeneousComplex p G N
  let rep := Action.trivial ↥N (TopModuleCat.of (ZMod p) (ZMod p))
  let cz : C(↥N, C(↥N, ZMod p)) := bk_cycles1_cochain p G N z
  have hhom : ∀ x y : ↥N, bk_cycles1_eval p G N z (x * y) = bk_cycles1_eval p G N z x + bk_cycles1_eval p G N z y := by
    intro x y
    let w : C(↥N, C(↥N, C(↥N, ZMod p))) := ((K.d 1 2).hom ((K.iCycles 1).hom z)).1
    have hz := congrArg (fun f => f.hom z) (K.iCycles_d 1 2)
    change (K.d 1 2).hom ((K.iCycles 1).hom z) = 0 at hz
    have hw : w = 0 := by
      simpa [w] using congrArg (fun t => (t.1 : C(↥N, C(↥N, C(↥N, ZMod p))))) hz
    have hw1 : w 1 = 0 := by
      exact congrArg (fun f : C(↥N, C(↥N, C(↥N, ZMod p))) => f 1) hw
    have hw2 : w 1 x = 0 := by
      exact congrArg (fun f : C(↥N, C(↥N, ZMod p)) => f x) hw1
    have hw3 : w 1 x (x * y) = 0 := by
      exact congrArg (fun f : C(↥N, ZMod p) => f (x * y)) hw2
    let t1 : C(↥N, C(↥N, C(↥N, ZMod p))) :=
      (((ContinuousCohomology.MultiInd.functor (ZMod p) ↥N 2).whiskerLeft
        (ContinuousCohomology.const (ZMod p) ↥N)).app rep).hom cz
    let t2 : C(↥N, C(↥N, C(↥N, ZMod p))) :=
      ((CategoryTheory.Functor.whiskerRight (ContinuousCohomology.MultiInd.d (ZMod p) ↥N 1)
        (ContinuousCohomology.I (ZMod p) ↥N)).app rep).hom cz
    have hw_split : w 1 x (x * y) = t1 1 x (x * y) - t2 1 x (x * y) := by
      dsimp [w, t1, t2, K, rep, cz, BKHomogeneousComplex, bk_cycles1_cochain,
        ContinuousCohomology.homogeneousCochains, ContinuousCohomology.MultiInd.complex,
        CochainComplex.of, ContinuousCohomology.MultiInd.d_succ]
      rfl
    have h1 : t1 1 x (x * y) = bk_cycles1_cochain p G N z x (x * y) := by
      rfl
    have h2 : t2 1 x (x * y) =
        bk_cycles1_cochain p G N z 1 (x * y) - bk_cycles1_cochain p G N z 1 x := by
      dsimp [t2, cz, rep, bk_cycles1_cochain, ContinuousCohomology.MultiInd.d_succ,
        ContinuousCohomology.MultiInd.d_zero]
      rfl
    have hzero :
        bk_cycles1_cochain p G N z x (x * y) -
          (bk_cycles1_cochain p G N z 1 (x * y) - bk_cycles1_cochain p G N z 1 x) = 0 := by
      rw [hw_split, h1, h2] at hw3
      exact hw3
    have hrec : bk_cycles1_cochain p G N z x (x * y) = bk_cycles1_cochain p G N z 1 y := by
      simpa [mul_assoc] using bk_cycles1_reconstruct p G N z x (x * y)
    have hsum :
        bk_cycles1_cochain p G N z 1 x + bk_cycles1_cochain p G N z 1 y -
          bk_cycles1_cochain p G N z 1 (x * y) = 0 := by
      simpa [hrec, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hzero
    rw [sub_eq_zero] at hsum
    simpa [bk_cycles1_eval, add_comm] using hsum.symm
  refine ⟨hhom, ?_, ?_⟩
  · have h11 := hhom 1 1
    have h11' : bk_cycles1_eval p G N z 1 + bk_cycles1_eval p G N z 1 = bk_cycles1_eval p G N z 1 + 0 := by
      simpa using h11.symm
    exact add_left_cancel h11'
  · change Continuous (fun y => bk_cycles1_cochain p G N z 1 y)
    exact (bk_cycles1_cochain p G N z 1).continuous

theorem bk_eval_zero_of_normal_generators (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : ℕ} (g : Fin k → G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure)
    (χ : BKGInvariantHom p G N)
    (hχ_zero : ∀ i : Fin k,
      ∃ (hmem : (g i : G) ∈ N),
        χ.hom ⟨g i, hmem⟩ = 1) :
    ∀ x : ↥N, χ.hom x = 1 := by
  set K : Subgroup ↥N := χ.hom.ker with hK_def
  set K' : Subgroup G := K.map N.subtype with hK'_def
  have hK'_iff : ∀ x : G, x ∈ K' ↔
      ∃ (hmem : x ∈ N), χ.hom ⟨x, hmem⟩ = 1 := by
    intro x
    simp only [hK'_def, hK_def, Subgroup.mem_map, MonoidHom.mem_ker, Subgroup.coe_subtype]
    constructor
    · rintro ⟨y, hy, rfl⟩
      exact ⟨y.2, hy⟩
    · rintro ⟨hmem, hχ⟩
      exact ⟨⟨x, hmem⟩, hχ, rfl⟩
  have hK'_normal : K'.Normal := by
    refine ⟨fun n hn h => ?_⟩
    rcases (hK'_iff n).mp hn with ⟨hn_mem, hχn⟩
    refine (hK'_iff _).mpr ?_
    refine ⟨‹N.Normal›.conj_mem n hn_mem h, ?_⟩
    rw [χ.ginv h ⟨n, hn_mem⟩]
    exact hχn
  have h_gen_le : Set.range g ⊆ (K' : Set G) := by
    rintro _ ⟨i, rfl⟩
    rcases hχ_zero i with ⟨hmem, hχ⟩
    exact (hK'_iff (g i)).mpr ⟨hmem, hχ⟩
  have h_normalClosure_le : Subgroup.normalClosure (Set.range g) ≤ K' :=
    Subgroup.normalClosure_le_normal h_gen_le
  have hN_closed : IsClosed (N : Set G) := by
    rw [_hN]
    exact Subgroup.isClosed_topologicalClosure _
  have hK_closed : IsClosed (K : Set ↥N) := by
    have : (K : Set ↥N) = χ.hom ⁻¹' {1} := rfl
    rw [this]
    exact (isClosed_singleton).preimage χ.continuous
  have hN_closedMap : IsClosedMap ((↑) : ↥N → G) :=
    hN_closed.isClosedMap_subtype_val
  have hK'_closed : IsClosed (K' : Set G) := by
    have h_eq : (K' : Set G) = ((↑) : ↥N → G) '' (K : Set ↥N) := by
      simp [hK'_def, Subgroup.coe_map]
    rw [h_eq]
    exact hN_closedMap _ hK_closed
  have h_topClosure_le : (Subgroup.normalClosure (Set.range g)).topologicalClosure ≤ K' :=
    Subgroup.topologicalClosure_minimal _ h_normalClosure_le hK'_closed
  have hN_le_K' : N ≤ K' := by
    rw [_hN]
    exact h_topClosure_le
  intro x
  have hxG : (x : G) ∈ K' := hN_le_K' x.2
  rcases (hK'_iff (x : G)).mp hxG with ⟨_, hχ⟩
  exact hχ

theorem bk_evalLinearMap_injective_of_normal_generators (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : ℕ} (g : Fin k → G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure) :
    ∃ eval : BKGInvariantContsHomSubmodule p G N →ₗ[ZMod p] (Fin k → ZMod p),
      Function.Injective eval := by
  have hg_mem : ∀ i : Fin k, (g i : G) ∈ N := by
    intro i
    rw [_hN]
    have hmem_nc : (g i : G) ∈ Subgroup.normalClosure (Set.range g) :=
      Subgroup.subset_normalClosure (show (g i : G) ∈ Set.range g from ⟨i, rfl⟩)
    exact (Subgroup.le_topologicalClosure (Subgroup.normalClosure (Set.range g))) hmem_nc
  let eval : BKGInvariantContsHomSubmodule p G N →ₗ[ZMod p] (Fin k → ZMod p) :=
    { toFun := fun f i => (f : ↥N → ZMod p) ⟨g i, hg_mem i⟩
      map_add' := by
        intro f f'
        ext i
        rfl
      map_smul' := by
        intro c f
        ext i
        rfl }
  refine ⟨eval, ?_⟩
  intro f f' hff'
  rcases f.2 with ⟨hf_hom, hf_one, hf_c, hf_g⟩
  rcases f'.2 with ⟨hf'_hom, hf'_one, hf'_c, hf'_g⟩
  let d : ↥N → ZMod p := fun x => (f : ↥N → ZMod p) x - (f' : ↥N → ZMod p) x
  have hd_hom : ∀ x y : ↥N, d (x * y) = d x + d y := by
    intro x y
    dsimp [d]
    rw [hf_hom x y, hf'_hom x y]
    ring
  have hd_one : d 1 = 0 := by
    dsimp [d]
    simp [hf_one, hf'_one]
  have hd_c : Continuous d := by
    simpa [d] using hf_c.sub hf'_c
  have hd_g : ∀ (h : G) (x : ↥N),
      d ⟨h * (x : G) * h⁻¹, ‹N.Normal›.conj_mem (x : G) x.2 h⟩ = d x := by
    intro h x
    simp [d, hf_g h x, hf'_g h x]
  let χ : BKGInvariantHom p G N :=
    { hom :=
        { toFun := fun x => Multiplicative.ofAdd (d x)
          map_one' := by
            simpa using congrArg Multiplicative.ofAdd hd_one
          map_mul' := by
            intro x y
            simpa using congrArg Multiplicative.ofAdd (hd_hom x y) }
      continuous := by
        change Continuous d
        exact hd_c
      ginv := by
        intro h x
        simp [hd_g h x] }
  have hχ_zero : ∀ i : Fin k,
      ∃ hmem : (g i : G) ∈ N,
        χ.hom ⟨g i, hmem⟩ = 1 := by
    intro i
    refine ⟨hg_mem i, ?_⟩
    have hi : d ⟨g i, hg_mem i⟩ = 0 := by
      dsimp [d]
      exact sub_eq_zero.mpr (by
        have hi := congrFun hff' i
        simpa [eval] using hi)
    dsimp [χ]
    change Multiplicative.ofAdd (d ⟨g i, hg_mem i⟩) = Multiplicative.ofAdd 0
    rw [hi]
  have hχ_all : ∀ x : ↥N, χ.hom x = 1 :=
    bk_eval_zero_of_normal_generators p G g N _hN χ hχ_zero
  apply Subtype.ext
  funext x
  have hx := hχ_all x
  dsimp [χ, d] at hx
  change (f : ↥N → ZMod p) x - (f' : ↥N → ZMod p) x = 0 at hx
  exact sub_eq_zero.mp hx

theorem bk_GInvariantContsHom_finite_and_rank_le (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    {k : ℕ} (g : Fin k → G)
    (N : Subgroup G) [N.Normal]
    (_hN : N = (Subgroup.normalClosure (Set.range g)).topologicalClosure) :
    FiniteDimensional (ZMod p) (BKGInvariantContsHomSubmodule p G N) ∧
      Module.finrank (ZMod p) (BKGInvariantContsHomSubmodule p G N) ≤ k := by
  rcases bk_evalLinearMap_injective_of_normal_generators p G g N _hN with ⟨eval, heval⟩
  constructor
  · exact FiniteDimensional.of_injective eval heval
  · letI := FiniteDimensional.of_injective eval heval
    simpa using (LinearMap.finrank_le_finrank_of_injective (f := eval) heval)

theorem bk_homogeneousComplex_d01_zero (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) :
    (BKHomogeneousComplex p G N).d 0 1 = 0 := by
  apply CategoryTheory.ConcreteCategory.ext
  ext x
  obtain ⟨x : C(N, ZMod p), hx⟩ := x
  change ∀ g : N,
      (((ContinuousCohomology.Iobj (Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p)))).ρ g).hom x = x) at hx
  apply Subtype.ext
  apply ContinuousMap.ext
  intro a
  apply ContinuousMap.ext
  intro b
  have hxa_aux : ((Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))).ρ a).hom (x 1) = x a := by
    have h0 := congr(DFunLike.coe (F := C(N, _)) $(hx a) a)
    have hI := ContinuousCohomology.Iobj_ρ_apply (R := ZMod p) (G := N)
      (rep := Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))) a x a
    simpa using hI.symm.trans h0
  have hxa_id : ((Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))).ρ a).hom (x 1) = x 1 := by
    rfl
  have hxa : x a = x 1 := by
    exact hxa_aux.symm.trans hxa_id
  have hxb_aux : ((Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))).ρ b).hom (x 1) = x b := by
    have h0 := congr(DFunLike.coe (F := C(N, _)) $(hx b) b)
    have hI := ContinuousCohomology.Iobj_ρ_apply (R := ZMod p) (G := N)
      (rep := Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))) b x b
    simpa using hI.symm.trans h0
  have hxb_id : ((Action.trivial N (TopModuleCat.of (ZMod p) (ZMod p))).ρ b).hom (x 1) = x 1 := by
    rfl
  have hxb : x b = x 1 := by
    exact hxb_aux.symm.trans hxb_id
  unfold BKHomogeneousComplex
  simp only [ContinuousCohomology.homogeneousCochains, ContinuousCohomology.MultiInd.d_succ,
    ContinuousCohomology.MultiInd.d_zero, ContinuousCohomology.Iobj_ρ_apply,
    CategoryTheory.Functor.comp_obj, CategoryTheory.Functor.mapHomologicalComplex_obj_d,
    CategoryTheory.Functor.mapHomologicalComplex_obj_X, TopModuleCat.ofHom, TopModuleCat.Hom.hom]
  change x b - x a = 0
  rw [hxb, hxa]
  simp

theorem bk_h1Conts_linearEquiv_cycles1 (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    ∃ e : _root_.Erdos90.H1ContsTrivial p G N ≃ₗ[ZMod p] (BKHomogeneousComplex p G N).cycles 1,
      ∀ (g : G) (x : _root_.Erdos90.H1ContsTrivial p G N),
        e ((_root_.Erdos90.h1ConjMap p G N g).hom x) =
          (HomologicalComplex.cyclesMap
            (ContinuousCohomology.cochainsMapTrivial (ZMod p)
              ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
              (bk_conjNormal_continuous G N g⁻¹)
              (TopModuleCat.of (ZMod p) (ZMod p))) 1).hom (e x) := by
  classical
  let K := BKHomogeneousComplex p G N
  have hd : K.d 0 1 = 0 := by
    simpa [K] using bk_homogeneousComplex_d01_zero p G N
  have hprev : (ComplexShape.up ℕ).prev 1 = 0 := by
    simp
  let e0 : K.cycles 1 ≅ K.homology 1 :=
    HomologicalComplex.isoHomologyπ K 0 1 hprev hd
  refine ⟨?_, ?_⟩
  · simpa [K, _root_.Erdos90.H1ContsTrivial, e0] using
      (e0.symm.toContinuousLinearEquiv.toLinearEquiv)
  · intro g x
    let φg : K ⟶ K :=
      ContinuousCohomology.cochainsMapTrivial (ZMod p)
        ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
        (bk_conjNormal_continuous G N g⁻¹)
        (TopModuleCat.of (ZMod p) (ZMod p))
    let ψg : K.homology 1 ⟶ K.homology 1 :=
      ContinuousCohomology.cohomologyMapTrivial (ZMod p)
        ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
        (bk_conjNormal_continuous G N g⁻¹)
        (TopModuleCat.of (ZMod p) (ZMod p)) 1
    have hnat0 :
        CategoryTheory.CategoryStruct.comp (K.homologyπ 1) ψg =
          CategoryTheory.CategoryStruct.comp (HomologicalComplex.cyclesMap φg 1) (K.homologyπ 1) := by
      exact HomologicalComplex.homologyπ_naturality (φ := φg) (i := 1)
    have hnat :
        CategoryTheory.CategoryStruct.comp ψg e0.symm.hom =
          CategoryTheory.CategoryStruct.comp e0.symm.hom (HomologicalComplex.cyclesMap φg 1) := by
      apply (CategoryTheory.cancel_epi (K.homologyπ 1)).1
      have hcomp := congrArg (fun t => CategoryTheory.CategoryStruct.comp t e0.symm.hom) hnat0
      simpa [e0, CategoryTheory.Category.assoc] using hcomp
    have hnatx := congrArg (fun f => f x) hnat
    exact hnatx

theorem bk_iobjMap_trivial_conj_apply (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] (g : G)
    (M : Type) [AddCommGroup M] [Module (ZMod p) M] [TopologicalSpace M]
    [ContinuousAdd M] [ContinuousSMul (ZMod p) M]
    (d : C(↥N, M)) (x : ↥N) :
    ((ContinuousCohomology.iobjMap (ZMod p)
        ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
        (bk_conjNormal_continuous G N g⁻¹)
        (Action.trivial ↥N (TopModuleCat.of (ZMod p) M))).hom.hom d) x =
      d ⟨g⁻¹ * (x : G) * g, by
        simpa using (‹N.Normal›.conj_mem (x : G) x.2 g⁻¹)⟩ := by
  rw [ContinuousCohomology.iobjMap_hom_hom_apply (R := ZMod p) (G := ↥N) (H := ↥N)
    (f := ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom))
    (hf := bk_conjNormal_continuous G N g⁻¹)
    (X := Action.trivial ↥N (TopModuleCat.of (ZMod p) M))
    (c := d) (x := x)]
  congr 1
  apply Subtype.ext
  simp

theorem bk_cycles1_eval_conj (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal]
    (g : G) (z : (BKHomogeneousComplex p G N).cycles 1) (y : ↥N) :
    bk_cycles1_eval p G N
      ((HomologicalComplex.cyclesMap
        (ContinuousCohomology.cochainsMapTrivial (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
          (bk_conjNormal_continuous G N g⁻¹)
          (TopModuleCat.of (ZMod p) (ZMod p))) 1).hom z) y =
      bk_cycles1_eval p G N z ⟨g⁻¹ * (y : G) * g, by
        simpa using (‹N.Normal›.conj_mem (y : G) y.2 g⁻¹)⟩ := by
  let X0 := Action.trivial ↥N (TopModuleCat.of (ZMod p) (ZMod p))
  have h1val (d : C(↥N, ZMod p)) :
      ((ContinuousCohomology.multiIndMap (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
          (bk_conjNormal_continuous G N g⁻¹)
          1 X0).hom.hom d : C(↥N, ZMod p)) =
        (ContinuousCohomology.iobjMap (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
          (bk_conjNormal_continuous G N g⁻¹)
          X0).hom.hom d := by
    rfl
  have h1 (d : C(↥N, ZMod p)) (x : ↥N) :
      (show C(↥N, ZMod p) from
        (ContinuousCohomology.multiIndMap (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
          (bk_conjNormal_continuous G N g⁻¹)
          1 X0).hom.hom d) x =
      d ⟨g⁻¹ * (x : G) * g, by
        simpa using (‹N.Normal›.conj_mem (x : G) x.2 g⁻¹)⟩ := by
    rw [h1val]
    exact bk_iobjMap_trivial_conj_apply p G N g (ZMod p) d x
  have hI (d : C(↥N, C(↥N, ZMod p))) (x : ↥N) :
      let e : C(↥N, C(↥N, ZMod p)) :=
        ((ContinuousCohomology.I (ZMod p) ↥N).map
          (ContinuousCohomology.iobjMap (ZMod p)
            ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
            (bk_conjNormal_continuous G N g⁻¹)
            X0)).hom.hom d
      e x =
        (ContinuousCohomology.iobjMap (ZMod p)
            ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
            (bk_conjNormal_continuous G N g⁻¹)
            X0).hom.hom (d x) := by
    rfl
  have h2val (c : C(↥N, C(↥N, ZMod p))) :
      ((ContinuousCohomology.multiIndMap (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
          (bk_conjNormal_continuous G N g⁻¹)
          2 X0).hom.hom c : C(↥N, C(↥N, ZMod p))) =
        ((ContinuousCohomology.I (ZMod p) ↥N).map
          (ContinuousCohomology.iobjMap (ZMod p)
            ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
            (bk_conjNormal_continuous G N g⁻¹)
            X0)).hom.hom
          ((ContinuousCohomology.iobjMap (ZMod p)
            ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
            (bk_conjNormal_continuous G N g⁻¹)
            (ContinuousCohomology.Iobj X0)).hom.hom c) := by
    rfl
  have h2 (c : C(↥N, C(↥N, ZMod p))) (x y : ↥N) :
      (show C(↥N, C(↥N, ZMod p)) from
        (ContinuousCohomology.multiIndMap (ZMod p)
          ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)

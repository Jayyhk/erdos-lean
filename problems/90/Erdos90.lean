  let eL : L вүғвӮҗ[в„ҡ] K2 :=
    IntermediateField.topEquiv.symm.trans
      ((IntermediateField.equivMap (вҠӨ : IntermediateField в„ҡ L) iL).trans
        (IntermediateField.equivOfEq (by simpa [K2] using (AlgHom.fieldRange_eq_map iL).symm)))

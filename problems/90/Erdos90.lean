    have hle3 : p.ramificationIdxIn (рқ“һ M) вүӨ 3 := by
      simpa [p] using ramificationIdxIn_le_three_of_rel_discr в„“ r _hr_prime _hr_inj _hr_mod3 M e _hfin _hdisc i
    have hne0 : p.ramificationIdxIn (рқ“һ M) вү  0 := by
      exact Ideal.ramificationIdxIn_ne_zero (G := M вүғвӮҗ[в„ҡ] M) (B := рқ“һ M) (p := p) hpne
    have hodd : Odd (3 ^ в„“) := by
      exact Odd.pow (by decide : Odd 3)
    have hnot2 : В¬ 2 вҲЈ 3 ^ в„“ := Odd.not_two_dvd_nat hodd
    have hnot2' : p.ramificationIdxIn (рқ“һ M) вү  2 := by
      intro h2

    letI : NumberField (L j) := hLnum j
    letI : IsGalois F (L j) := hLgalois j
    exact finiteIntermediate_isUnramified F p (L j)
  have hbase_iso : Nonempty ((L 0) вүғвӮҗ[в„ҡ] F) := by
    refine вҹЁ((hL0.symm в–ё (IntermediateField.botEquiv F K)) : (L 0) вүғвӮҗ[F] F).restrictScalars в„ҡвҹ©
  have hstep_compat : вҲҖ j,
      (((IntermediateField.inclusion (hLmono j)).toRingHom).comp (algebraMap F (L j)) = algebraMap F (L (j + 1))) := by
    intro j
    ext x
    rfl
  have hcard_eq_finrankF : вҲҖ j, Nat.card (Q.Q в§ё (U j : Subgroup Q.Q)) = Module.finrank F (L j) := by
    intro j
    letI : FiniteDimensional F (L j) := hLfd j

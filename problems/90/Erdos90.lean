theorem proposition_2_2_fiber_principal_generator_normOne (рқ’ҹ : AdmissibleDatum)
    (I : proposition_2_2_choice_type рқ’ҹ вҶ’ Ideal (рқ“һ рқ’ҹ.K))
    (hI_nonzero : вҲҖ Оө, I Оө вү  вҠҘ)
    (hI_mul_conj : вҲҖ Оө, I Оө * proposition_2_2_conjIdeal рқ’ҹ (I Оө) = proposition_2_2_qIdeal рқ’ҹ)
    (C : ClassGroup (рқ“һ рқ’ҹ.K))
    (ОөвӮҖ : proposition_2_2_choice_type рқ’ҹ)
    (Оө : {Оө : proposition_2_2_choice_type рқ’ҹ //
          ClassGroup.mk0 вҹЁI Оө, mem_nonZeroDivisors_iff_ne_zero.mpr (hI_nonzero Оө)вҹ© = C})
    (x : рқ“һ рқ’ҹ.K) (hx0 : x вү  0)
    (hx : I Оө.1 * proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ) =
      Ideal.span ({x} : Set (рқ“һ рқ’ҹ.K))) :
    рқ’ҹ.IsNormOneIntegral ((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)) := by
  classical
  let u : рқ’ҹ.K := (x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)
  have hxK0 : (x : рқ’ҹ.K) вү  0 := by
    exact_mod_cast hx0
  have hcx0 : рқ’ҹ.c (x : рқ’ҹ.K) вү  0 := by
    intro h
    apply hxK0
    rw [вҶҗ рқ’ҹ.c_sq_eq_id (x : рқ’ҹ.K), h, map_zero]
  refine вҹЁ?_, ?_, ?_вҹ©
  В· calc
      рқ’ҹ.relNorm u
          = (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)) *
              (рқ’ҹ.c (x : рқ’ҹ.K) / рқ’ҹ.c (рқ’ҹ.c (x : рқ’ҹ.K)))) := by
                simp [u, AdmissibleDatum.relNorm, map_divвӮҖ]
      _ = (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)) * ((рқ’ҹ.c (x : рқ’ҹ.K)) / (x : рқ’ҹ.K))) := by
            rw [рқ’ҹ.c_sq_eq_id]
      _ = 1 := by
            field_simp [hxK0, hcx0]
  В· intro Пғ
    have hПғx0 : Пғ (x : рқ’ҹ.K) вү  0 := by
      intro h
      apply hxK0
      apply Пғ.injective
      simpa using h
    change вҖ–Пғ (((x : рқ’ҹ.K) / рқ’ҹ.c (x : рқ’ҹ.K)))вҖ– = 1
    rw [map_divвӮҖ, complex_embedding_conjugation_compat]
    rw [norm_div, norm_star, div_self (norm_ne_zero_iff.mpr hПғx0)]
  В· let e : (рқ“һ рқ’ҹ.K) вүғвӮҗ[рқ“һ рқ’ҹ.L] (рқ“һ рқ’ҹ.K) :=
        NumberField.RingOfIntegers.mapAlgEquiv (рқ’ҹ.c : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K)
    have he2вӮҖ : Ideal.map e (Ideal.map e (I ОөвӮҖ)) = I ОөвӮҖ := by
      simpa [proposition_2_2_conjIdeal, e] using
        (proposition_2_2_conjIdeal_involutive рқ’ҹ (I ОөвӮҖ))
    have hx_map' : Ideal.map e (I Оө.1) * Ideal.map e (proposition_2_2_conjIdeal рқ’ҹ (I ОөвӮҖ)) = Ideal.span ({e x} : Set (рқ“һ рқ’ҹ.K)) := by
      have hx_map := congrArg (fun J : Ideal (рқ“һ рқ’ҹ.K) => Ideal.map e J) hx
      simpa [Ideal.map_mul, Ideal.map_span, Set.image_singleton] using hx_map
    have hx_conj : proposition_2_2_conjIdeal рқ’ҹ (I Оө.1) * I ОөвӮҖ = Ideal.span ({e x} : Set (рқ“һ рқ’ҹ.K)) := by
      rw [proposition_2_2_conjIdeal, he2вӮҖ] at hx_map'

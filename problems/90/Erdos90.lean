      (B ⧸ LinearMap.range (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatToCycles)) ≃ₗ[ZMod p]
        (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).homology : Type) :=
    (((_root_.Erdos90.InhomogContsCochains.complex p G).sc n).moduleCatHomologyIso.symm.toLinearEquiv)
  exact eQ.symm.trans eH

theorem inhomogCohomology_complexHomology_exists (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] (n : ℕ) :
    Nonempty (_root_.Erdos90.InhomogClassAPI.Cohomology p G n ≃ₗ[ZMod p] (((_root_.Erdos90.InhomogContsCochains.complex p G).homology n) : Type)) :=

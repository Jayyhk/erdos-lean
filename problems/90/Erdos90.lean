abbrev ConjInvariantHom (A : Type*) (G : Type*) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :=
  {χ : N →* A // ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ}

theorem conjInvariantHom_eval_injective_normalClosure (A : Type*) (G : Type*) [CommGroup A] [Group G] (n : ℕ) (gens : Fin n → G) :
    let N : Subgroup G := Subgroup.normalClosure (Set.range gens)
    let eval : {φ : N →* A // ∀ g : G, φ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = φ} → Fin n → A := fun φ i => φ.1 ⟨gens i, Subgroup.subset_normalClosure ⟨i, rfl⟩⟩
    Function.Injective eval := by
  classical
  dsimp
  intro φ ψ h
  rcases φ with ⟨φ, hφ⟩
  rcases ψ with ⟨ψ, hψ⟩
  have hgen_eq (i : Fin n) :
      φ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ =
        ψ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ := by
    exact congrFun h i
  apply Subtype.ext
  ext x
  have hx : x.1 ∈ Subgroup.closure (Group.conjugatesOfSet (Set.range gens)) := by
    simp [Subgroup.normalClosure, x.2]
  have hEq :
      ∀ g (hg : g ∈ Subgroup.closure (Group.conjugatesOfSet (Set.range gens))),
        ∀ hgN : g ∈ Subgroup.normalClosure (Set.range gens),
          φ ⟨g, hgN⟩ = ψ ⟨g, hgN⟩ := by
    intro g hg
    refine Subgroup.closure_induction
      (k := Group.conjugatesOfSet (Set.range gens))
      (p := fun g _ =>
        ∀ hgN : g ∈ Subgroup.normalClosure (Set.range gens),
          φ ⟨g, hgN⟩ = ψ ⟨g, hgN⟩) ?_ ?_ ?_ ?_ hg
    · intro y hy hyN
      rcases (Group.mem_conjugatesOfSet_iff.mp hy) with ⟨a, ha, hconj⟩
      rcases ha with ⟨i, rfl⟩
      rcases (isConj_iff.mp hconj) with ⟨c, rfl⟩
      have hconjElt :
          ((MulAut.conjNormal (H := Subgroup.normalClosure (Set.range gens)) c)
            ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩) =
            ⟨c * gens i * c⁻¹, hyN⟩ := by
        apply Subtype.ext
        simp [MulAut.conjNormal_apply]
      have hφc :=
        congrArg
          (fun f =>
            f ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩)
          (hφ c)
      have hψc :=
        congrArg
          (fun f =>
            f ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩)
          (hψ c)
      have hφc' :
          φ ⟨c * gens i * c⁻¹, hyN⟩ =
            φ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ := by
        simpa [MonoidHom.comp_apply, hconjElt] using hφc
      have hψc' :
          ψ ⟨c * gens i * c⁻¹, hyN⟩ =
            ψ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ := by
        simpa [MonoidHom.comp_apply, hconjElt] using hψc
      calc
        φ ⟨c * gens i * c⁻¹, hyN⟩ = φ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ := hφc'
        _ = ψ ⟨gens i, Subgroup.subset_normalClosure (s := Set.range gens) ⟨i, rfl⟩⟩ := hgen_eq i
        _ = ψ ⟨c * gens i * c⁻¹, hyN⟩ := hψc'.symm
    · intro h1N
      have hone : (⟨1, h1N⟩ : Subgroup.normalClosure (Set.range gens)) = 1 := by
        apply Subtype.ext
        rfl
      calc
        φ ⟨1, h1N⟩ = φ 1 := by rw [hone]
        _ = 1 := φ.map_one
        _ = ψ 1 := by symm; exact ψ.map_one
        _ = ψ ⟨1, h1N⟩ := by rw [hone]
    · intro a b ha hb hPa hPb habN
      have haN : a ∈ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using ha
      have hbN : b ∈ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using hb
      have hmul :
          (⟨a * b, habN⟩ : Subgroup.normalClosure (Set.range gens)) =
            ⟨a, haN⟩ * ⟨b, hbN⟩ := by
        apply Subtype.ext
        rfl
      calc
        φ ⟨a * b, habN⟩ = φ (⟨a, haN⟩ * ⟨b, hbN⟩) := by rw [hmul]
        _ = φ ⟨a, haN⟩ * φ ⟨b, hbN⟩ := by
          simpa using MonoidHom.map_mul φ ⟨a, haN⟩ ⟨b, hbN⟩
        _ = ψ ⟨a, haN⟩ * ψ ⟨b, hbN⟩ := by rw [hPa haN, hPb hbN]
        _ = ψ (⟨a, haN⟩ * ⟨b, hbN⟩) := by
          symm
          simpa using MonoidHom.map_mul ψ ⟨a, haN⟩ ⟨b, hbN⟩
        _ = ψ ⟨a * b, habN⟩ := by rw [hmul]
    · intro a ha hPa haInvN
      have haN : a ∈ Subgroup.normalClosure (Set.range gens) := by
        simpa [Subgroup.normalClosure] using ha
      have hinv :
          (⟨a⁻¹, haInvN⟩ : Subgroup.normalClosure (Set.range gens)) =
            (⟨a, haN⟩)⁻¹ := by
        apply Subtype.ext
        rfl
      calc
        φ ⟨a⁻¹, haInvN⟩ = φ ((⟨a, haN⟩ : Subgroup.normalClosure (Set.range gens))⁻¹) := by
          rw [hinv]
        _ = (φ ⟨a, haN⟩)⁻¹ := by
          simp
        _ = (ψ ⟨a, haN⟩)⁻¹ := by rw [hPa haN]
        _ = ψ ((⟨a, haN⟩ : Subgroup.normalClosure (Set.range gens))⁻¹) := by
          symm
          simp
        _ = ψ ⟨a⁻¹, haInvN⟩ := by rw [hinv]
  exact hEq x.1 hx x.2

theorem finrank_middle_le_left_add_right_of_exact (k : Type*) [Field k] {V₁ V₂ V₃ : Type*} [AddCommGroup V₁] [Module k V₁] [FiniteDimensional k V₁] [AddCommGroup V₂] [Module k V₂] [FiniteDimensional k V₂] [AddCommGroup V₃] [Module k V₃] [FiniteDimensional k V₃] (f : V₁ →ₗ[k] V₂) (g : V₂ →ₗ[k] V₃) (hfg : Function.Exact f g) : Module.finrank k V₂ ≤ Module.finrank k V₁ + Module.finrank k V₃ := by
  classical
  rw [← LinearMap.finrank_range_add_finrank_ker g]
  rw [Function.Exact.linearMap_ker_eq hfg]
  have hf : Module.finrank k ↥(LinearMap.range f) ≤ Module.finrank k V₁ := LinearMap.finrank_range_le f
  have hg : Module.finrank k ↥(LinearMap.range g) ≤ Module.finrank k V₃ := Submodule.finrank_le _
  omega

noncomputable def quotientGroupExtension (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    GroupExtension N G (G ⧸ N) where
  inl := N.subtype
  rightHom := QuotientGroup.mk' N
  inl_injective := by
    intro a b h
    exact Subtype.ext h
  range_inl_eq_ker_rightHom := by
    rw [Subgroup.range_subtype, QuotientGroup.ker_mk']
  rightHom_surjective := QuotientGroup.mk'_surjective N

theorem quotientGroupExtension_conjAct_eq_conjNormal (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (g : G) : (quotientGroupExtension G N).conjAct g = MulAut.conjNormal (H := N) g := by
  ext n
  simpa [quotientGroupExtension, MulAut.conjNormal_apply] using
    ((quotientGroupExtension G N).inl_conjAct_comm (e := g) (n := n))

noncomputable abbrev quotientGroupSection (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    (quotientGroupExtension G N).Section :=
  GroupExtension.surjInvRightHom (quotientGroupExtension G N)

noncomputable def quotientSectionDefect (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    (G ⧸ N) × (G ⧸ N) → N := fun xy =>
  let S := quotientGroupExtension G N
  let σ := quotientGroupSection G N
  Classical.choose <|
    (show ∃ n : N, S.inl n = σ xy.1 * σ xy.2 * (σ (xy.1 * xy.2))⁻¹ from by
      simpa [MonoidHom.mem_range] using
        (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
          (S := S) (σ := σ) (g₁ := xy.1) (g₂ := xy.2)))

theorem quotientSectionDefect_spec (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (x y : G ⧸ N) : ↑(quotientSectionDefect G N (x, y)) = quotientGroupSection G N x * quotientGroupSection G N y * (quotientGroupSection G N (x * y))⁻¹ := by
  classical
  unfold quotientSectionDefect
  simpa [quotientGroupSection, quotientGroupExtension] using
    (Classical.choose_spec
      (show ∃ n : N,
          (quotientGroupExtension G N).inl n =
            quotientGroupSection G N x * quotientGroupSection G N y *
              (quotientGroupSection G N (x * y))⁻¹ from by
        simpa [MonoidHom.mem_range, quotientGroupSection, quotientGroupExtension] using
          (GroupExtension.Section.mul_mul_mul_inv_mem_range_inl
            (S := quotientGroupExtension G N)
            (σ := quotientGroupSection G N) (g₁ := x) (g₂ := y))))

noncomputable def quotientSectionRemainder (G : Type*) [Group G] (N : Subgroup G) [N.Normal] :
    G → N := fun g =>
  ⟨g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹, by
    apply (QuotientGroup.eq_one_iff (N := N)
      (x := g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹)).mp
    change (QuotientGroup.mk' N) (g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹) = 1
    have hσ :
        (QuotientGroup.mk' N : G →* G ⧸ N) (quotientGroupSection G N ((QuotientGroup.mk' N) g)) =
          (QuotientGroup.mk' N) g := by
      simpa [quotientGroupSection, quotientGroupExtension] using
        (GroupExtension.Section.rightHom_section (S := quotientGroupExtension G N)
          (σ := quotientGroupSection G N) ((QuotientGroup.mk' N) g))
    rw [map_mul, map_inv, hσ]
    simp⟩

theorem quotientSectionRemainder_mul (G : Type*) [Group G] (N : Subgroup G) [N.Normal] (g h : G) : quotientSectionRemainder G N (g * h) = quotientSectionRemainder G N g * (MulAut.conjNormal (H := N) (quotientGroupSection G N ((QuotientGroup.mk' N) g)) (quotientSectionRemainder G N h)) * quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h)) := by
  classical
  apply Subtype.ext
  change
    ((g * h) * (quotientGroupSection G N ((QuotientGroup.mk' N) (g * h)))⁻¹ : G) =
      ((g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹) *
          ↑(MulAut.conjNormal (H := N) (quotientGroupSection G N ((QuotientGroup.mk' N) g))
            (quotientSectionRemainder G N h)) *
          ↑(quotientSectionDefect G N
            ((QuotientGroup.mk' N) g, (QuotientGroup.mk' N) h)) : G)
  rw [MulAut.conjNormal_apply]
  rw [quotientSectionDefect_spec]
  change
    (g * h) * (quotientGroupSection G N ((QuotientGroup.mk' N) (g * h)))⁻¹ =
      (g * (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹) *
        (quotientGroupSection G N ((QuotientGroup.mk' N) g) *
          (h * (quotientGroupSection G N ((QuotientGroup.mk' N) h))⁻¹) *
          (quotientGroupSection G N ((QuotientGroup.mk' N) g))⁻¹) *
        (quotientGroupSection G N ((QuotientGroup.mk' N) g) *
          quotientGroupSection G N ((QuotientGroup.mk' N) h) *
          (quotientGroupSection G N ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h))⁻¹)
  rw [map_mul]
  group

noncomputable def quotientTransgressionFactor (A : Type*) (G : Type*) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (χ : N →* A) : (G ⧸ N) × (G ⧸ N) → A :=
  fun xy => χ (quotientSectionDefect G N xy)

noncomputable def inflatedQuotientTransgressionFactor (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] (χ : N →* A) : G × G → A :=
  fun gh =>
    quotientTransgressionFactor A G N χ
      (((QuotientGroup.mk' N) gh.1), ((QuotientGroup.mk' N) gh.2))

noncomputable abbrev restrictHomKerEquivQuotientHom (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] : (MonoidHom.restrictHom N A).ker ≃* (G ⧸ N →* A) := MonoidHom.restrictHomKerEquiv A N

def restrictToConjInvariantHom (A : Type*) (G : Type*) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] :
    (G →* A) → ConjInvariantHom A G N := fun ψ =>
  ⟨ψ.comp N.subtype, by
    intro g
    ext n
    change ψ (g * n.1 * g⁻¹) = ψ n.1
    simp [MulAut.conjNormal_apply, map_mul, map_inv, mul_assoc, mul_left_comm, mul_comm]⟩

noncomputable abbrev trivialCoeffRep (k G : Type) [CommRing k] [Group G] : Rep k G := Rep.trivial k G k

noncomputable abbrev H1TrivialIso (k G : Type) [CommRing k] [Group G] : groupCohomology.H1 (trivialCoeffRep k G) ≅ ModuleCat.of k (Additive G →+ k) := groupCohomology.H1IsoOfIsTrivial (trivialCoeffRep k G)

theorem inflation_restriction_H1_exact (k G : Type) [CommRing k] [Group G] (N : Subgroup G) [N.Normal] : (groupCohomology.H1InfRes (trivialCoeffRep k G) N).Exact := by
  simpa [trivialCoeffRep] using groupCohomology.H1InfRes_exact (A := trivialCoeffRep k G) (S := N)

theorem inflation_restriction_H1_exact_zmod (p : ℕ) (G : Type) [Group G] (N : Subgroup G) [N.Normal] : (groupCohomology.H1InfRes (trivialCoeffRep (ZMod p) G) N).Exact := by

theorem finiteGalois_splitCompletely_primes_infinite (L : Type) [Field L] [NumberField L] [Algebra ℚ L]
    [FiniteDimensional ℚ L] [IsGalois ℚ L] :
    {q : ℕ | q.Prime ∧
      (∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
          Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) ∧
      ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L)).ncard =
        Module.finrank ℚ L}.Infinite := by
  classical
  let S0 : Set ℕ :=
    {q : ℕ | q.Prime ∧
      (∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
          Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
          Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1)}
  have hS0inf : S0.Infinite := splitCompletely_primes_infinite_via_kummerDedekind L
  refine Set.Infinite.mono ?_ hS0inf
  intro q hq
  rcases hq with ⟨hqprime, hsplit⟩
  refine ⟨hqprime, hsplit, ?_⟩
  let p : Ideal ℤ := Ideal.span {(q : ℤ)}
  have hp0 : p ≠ ⊥ := by
    dsimp [p]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast hqprime.ne_zero
  letI : Fact q.Prime := ⟨hqprime⟩
  haveI : p.IsMaximal := by
    dsimp [p]
    simpa using (Int.ideal_span_isMaximal_of_prime q)
  rw [← coe_primesOverFinset hp0 (𝓞 L), Set.ncard_coe_finset]
  calc
    (primesOverFinset p (𝓞 L)).card = ∑ P ∈ primesOverFinset p (𝓞 L), 1 := by
      rw [Finset.card_eq_sum_ones]
    _ = ∑ P ∈ primesOverFinset p (𝓞 L), Ideal.ramificationIdx p P * Ideal.inertiaDeg p P := by
      refine Finset.sum_congr rfl ?_
      intro P hP
      have hmem : P ∈ p.primesOver (𝓞 L) := (mem_primesOverFinset_iff hp0 (𝓞 L)).mp hP
      rcases hsplit P hmem with ⟨he, hf⟩
      rw [he, hf]
    _ = Module.finrank ℚ L := by
      exact Ideal.sum_ramification_inertia (S := 𝓞 L) (K := ℚ) (L := L) hp0


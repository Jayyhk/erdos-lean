        Polynomial.X ^ 2 + Polynomial.C (1 : 𝒟.L) := by
    simpa [x] using admissibleDatum_iO_field_minpoly_eq 𝒟
  have hfrac :=
    minpoly.isIntegrallyClosed_eq_field_fractions
      (R := NumberField.RingOfIntegers 𝒟.L)
      (S := NumberField.RingOfIntegers 𝒟.K)
      (K := 𝒟.L)
      (L := 𝒟.K)
      (s := x)
      (hs := by
        exact (Algebra.isIntegral_def.mp

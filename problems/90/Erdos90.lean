theorem lSeriesSummable_of_Icc_growth_family {f : в„• вҶ’ в„қ} :
    (вҲҖ n, 0 вүӨ f n) вҶ’
    (вҲҖ r : в„қ, 1 < r вҶ’ вҲғ C : в„қ, 0 вүӨ C вҲ§ вҲҖ N : в„•,
      вҲ‘ k вҲҲ Finset.Icc 1 N, f k вүӨ C * (N : в„қ) ^ r) вҶ’
    вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s := by
  intro hnonneg hgrowth s hs
  let r : в„қ := (1 + s.re) / 2
  have hr1 : 1 < r := by
    dsimp [r]
    linarith
  have hrs : r < s.re := by
    dsimp [r]
    linarith
  have hr0 : 0 вүӨ r := by
    dsimp [r]
    linarith
  rcases hgrowth r hr1 with вҹЁC, hC0, hCвҹ©
  have hO : (fun n : в„• => вҲ‘ k вҲҲ Finset.Icc 1 n, f k) =O[Filter.atTop] fun n : в„• => (n : в„қ) ^ r := by
    refine Asymptotics.IsBigO.of_bound C ?_
    filter_upwards [Filter.Eventually.of_forall hC] with n hn
    have hsum_nonneg : 0 вүӨ вҲ‘ k вҲҲ Finset.Icc 1 n, f k := by
      exact Finset.sum_nonneg (by
        intro k hk
        exact hnonneg k)
    have hrpow_nonneg : 0 вүӨ (n : в„қ) ^ r := by
      exact Real.rpow_nonneg (by positivity) r
    simpa [Real.norm_eq_abs, abs_of_nonneg hsum_nonneg, abs_of_nonneg hrpow_nonneg] using hn
  exact LSeriesSummable_of_sum_norm_bigO_and_nonneg hO hnonneg hr0 hrs

theorem lSeries_real_eq_re_add_pole_of_eqOn {f : в„• вҶ’ в„қ} {a : в„Ӯ} {g : в„Ӯ вҶ’ в„Ӯ} :
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’

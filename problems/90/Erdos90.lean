open NumberField.InfinitePlace in
theorem proposition_3_6_aux_extension_exists
    (hFG : Hyp_FiniteTopologicalRank)
    (F : Type) [Field F] [NumberField F] [IsTotallyReal F]
    (_hcubic : Module.finrank ℚ F = 3) :
    ∃ (L : FiniteGaloisIntermediateField ℚ (AlgebraicClosure ℚ)) (_ : NumberField L),
      ∀ q : ℕ,
        (q.Prime ∧
          (∀ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
              Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
              Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1) ∧
          ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L)).ncard =
            Module.finrank ℚ L) →
        proposition_3_6_goodPrime F q := by
  classical
  letI : IsAlgClosure ℚ (AlgebraicClosure ℚ) := AlgebraicClosure.instIsAlgClosure ℚ
  letI : IsGalois ℚ (AlgebraicClosure ℚ) := IsAlgClosure.isGalois ℚ (AlgebraicClosure ℚ)
  rcases proposition_3_6_frattini_fixedField_exists hFG F with ⟨M, hfdM, hnumM, hgalM, hMunr, hMfix⟩
  let Kmax := maximalUnramifiedProPF F 3
  haveI : IsGalois F Kmax := MaxUnramifiedProPGaloisGroup.isGalois_maximalUnramifiedProPF F 3
  have hopen_hnormal : IsOpen (M.fixingSubgroup : Set (Gal(Kmax/F))) ∧ M.fixingSubgroup.Normal := by
    exact (InfiniteGalois.isOpen_and_normal_iff_finite_and_isGalois (k := F) (K := Kmax) M).2 ⟨hfdM, hgalM⟩
  have hnormal : M.fixingSubgroup.Normal := hopen_hnormal.2
  have hG : IsFinitelyGeneratedProPGroup 3 (MaxUnramifiedProPGaloisGroup F 3) :=
    MaxUnramifiedProPGaloisGroup.isFinitelyGeneratedProPGroup hFG F 3
  have hpquot : IsPGroup 3 (Gal(Kmax/F) ⧸ M.fixingSubgroup) := by
    exact @IsFinitelyGeneratedProPGroup.isPGroup_quotient 3 (MaxUnramifiedProPGaloisGroup F 3) _ _ _ hG M.fixingSubgroup hnormal hopen_hnormal.1
  let H : ClosedSubgroup (Gal(Kmax/F)) :=
    { toSubgroup := M.fixingSubgroup
      isClosed' := Subgroup.isClosed_of_isOpen _ hopen_hnormal.1 }
  have hfixM : IntermediateField.fixedField (H : Subgroup Gal(Kmax/F)) = M := by
    simpa [H] using (InfiniteGalois.fixedField_fixingSubgroup (k := F) (K := Kmax) M)
  let eFix : IntermediateField.fixedField (H : Subgroup Gal(Kmax/F)) ≃ₐ[F] M :=
    IntermediateField.equivOfEq hfixM
  haveI : (H : Subgroup Gal(Kmax/F)).Normal := by
    change M.fixingSubgroup.Normal
    exact hopen_hnormal.2
  let hquotM : Gal(Kmax/F) ⧸ M.fixingSubgroup ≃* (M ≃ₐ[F] M) := by
    simpa [H] using (InfiniteGalois.normalAutEquivQuotient (k := F) (K := Kmax) H).trans (AlgEquiv.autCongr eFix)
  have hpM : IsPGroup 3 (M ≃ₐ[F] M) := IsPGroup.of_equiv hpquot hquotM
  let eM : M →ₐ[ℚ] AlgebraicClosure ℚ := IsAlgClosed.lift
  let M0 : IntermediateField ℚ (AlgebraicClosure ℚ) := eM.fieldRange
  let eMfield : M ≃ₐ[ℚ] M0 := AlgEquiv.ofInjectiveField eM
  letI : FiniteDimensional ℚ M0 := eMfield.toLinearEquiv.finiteDimensional
  letI : NumberField M0 := NumberField.of_module_finite ℚ M0
  let eC : CyclotomicField 4 ℚ →ₐ[ℚ] AlgebraicClosure ℚ := IsAlgClosed.lift
  let C0 : IntermediateField ℚ (AlgebraicClosure ℚ) := eC.fieldRange
  let eCfield : CyclotomicField 4 ℚ ≃ₐ[ℚ] C0 := AlgEquiv.ofInjectiveField eC
  letI : FiniteDimensional ℚ C0 := eCfield.toLinearEquiv.finiteDimensional
  letI : NumberField C0 := NumberField.of_module_finite ℚ C0
  obtain ⟨L, hM0L, hC0L⟩ := finiteGaloisIntermediateField_contains_two_subfields M0 C0
  letI : NumberField L := NumberField.of_module_finite ℚ L
  refine ⟨L, inferInstance, ?_⟩
  intro q hq
  rcases hq with ⟨hqprime, hsplitL, hcardL⟩
  let LM0 : IntermediateField M0 (AlgebraicClosure ℚ) := IntermediateField.extendScalars hM0L
  let LC0 : IntermediateField C0 (AlgebraicClosure ℚ) := IntermediateField.extendScalars hC0L
  letI : NumberField ↥LM0 := by
    simpa [LM0] using (inferInstance : NumberField ↥L)
  letI : NumberField ↥LC0 := by
    simpa [LC0] using (inferInstance : NumberField ↥L)
  have hsplitM0 :
      ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 ↥M0),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower ↥M0 ↥LM0 q hqprime hsplitL
  have hsplitC0 :
      ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 ↥C0),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower ↥C0 ↥LC0 q hqprime hsplitL
  have hsplitM :
      ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 M),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
    exact primewise_split_transport_of_algEquiv M ↥M0 eMfield q hqprime hsplitM0
  have hsplitC :
      ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 (CyclotomicField 4 ℚ)),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
    exact primewise_split_transport_of_algEquiv (CyclotomicField 4 ℚ) ↥C0 eCfield q hqprime hsplitC0
  have hsplitF :
      ∀ 𝔭 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔭 = 1 := by
    set_option maxHeartbeats 400000 in
      exact primewise_split_descends_of_tower F M q hqprime hsplitM
  have hcountF :
      ((Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 F)).ncard =
        Module.finrank ℚ F :=
    splitCount_of_primewiseSplit (K := F) q hqprime hsplitF
  haveI : IsCyclotomicExtension {4} ℚ (CyclotomicField 4 ℚ) :=
    CyclotomicField.instIsCyclotomicExtensionSingletonNatSetOfCharZero 4 ℚ
  have hmod4 : q % 4 = 1 :=
    primewise_split_in_cyclotomic4_implies_mod4 (CyclotomicField 4 ℚ) q hqprime hsplitC
  refine ⟨hqprime, hmod4, ⟨hsplitF, hcountF⟩, ?_⟩
  intro 𝔭 hp hne hmem
  let p0 : Ideal ℤ := Ideal.span {(q : ℤ)}
  let σ : MaxUnramifiedProPGaloisGroup F 3 := splittingDetectorAt F 3 𝔭 hp hne
  have hsplitP : ∀ 𝔓 ∈ 𝔭.primesOver (𝓞 M), Ideal.inertiaDeg 𝔭 𝔓 = 1 := by
    intro 𝔓 hP
    have hPmem : 𝔓 ∈ p0.primesOver (𝓞 M) := by
      refine ⟨hP.1, ?_⟩
      letI : 𝔓.LiesOver 𝔭 := hP.2
      letI : 𝔭.LiesOver p0 := by simpa [p0] using hmem.2
      exact Ideal.LiesOver.trans 𝔓 𝔭 p0
    have hP0 : Ideal.inertiaDeg p0 𝔓 = 1 := by
      exact (hsplitM 𝔓 (by simpa [p0] using hPmem)).2
    have h𝔭0 : Ideal.inertiaDeg p0 𝔭 = 1 := by
      exact (hsplitF 𝔭 (by simpa [p0] using hmem)).2
    letI : Fact q.Prime := ⟨hqprime⟩
    letI : p0.IsMaximal := Int.ideal_span_isMaximal_of_prime q
    letI : 𝔭.LiesOver p0 := by simpa [p0] using hmem.2
    letI : 𝔓.LiesOver 𝔭 := hP.2
    letI : 𝔭.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p0] using hmem)
    letI : 𝔓.IsMaximal := Ideal.isMaximal_of_mem_primesOver (by simpa [p0] using hPmem)
    rw [Ideal.inertiaDeg_algebra_tower p0 𝔭 𝔓] at hP0
    rw [h𝔭0, one_mul] at hP0
    exact hP0
  have hres : (AlgEquiv.restrictNormalHom M σ : M ≃ₐ[F] M) = 1 := by
    exact (splittingDetectorAt_spec F 3 𝔭 hp hne M hpM).2 hsplitP
  have hker : σ ∈ (AlgEquiv.restrictNormalHom M).ker := by
    change (AlgEquiv.restrictNormalHom M) σ = 1
    exact hres
  have hfix : σ ∈ M.fixingSubgroup := by
    rwa [IntermediateField.restrictNormalHom_ker M] at hker
  simpa [σ, hMfix] using hfix

theorem ringOfIntegers_exponent_ne_zero_of_primitive_element (K : Type) [Field K] [NumberField K] {θ : NumberField.RingOfIntegers K}
    (hθ : IntermediateField.adjoin ℚ ({(θ : K)} : Set K) = ⊤) :
    RingOfIntegers.exponent θ ≠ 0 := by
  have hθ' : Algebra.adjoin ℚ ({(θ : K)} : Set K) = ⊤ := by
    simpa only [IntermediateField.adjoin_eq_top_iff] using hθ
  have hmul :=
    conductor_mul_differentIdeal (A := ℤ) (K := ℚ) (L := K)
      (B := NumberField.RingOfIntegers K) θ hθ'
  have hderiv_ne_zero_K : (Polynomial.aeval (θ : K)) (Polynomial.derivative (minpoly ℤ θ)) ≠ 0 := by
    letI : Algebra.IsIntegral ℚ K := Algebra.IsAlgebraic.isIntegral (K := ℚ) (A := K)
    have hsepQ : (minpoly ℚ (θ : K)).Separable := by
      simpa [IsSeparable] using (IsSeparable.of_integral ℚ (θ : K))
    have hderivQ : (Polynomial.aeval (θ : K)) (Polynomial.derivative (minpoly ℚ (θ : K))) ≠ 0 := by
      exact hsepQ.aeval_derivative_ne_zero (minpoly.aeval ℚ (θ : K))
    have hmap : minpoly ℚ (θ : K) = (minpoly ℤ θ).map (algebraMap ℤ ℚ) := by
      simpa only [NumberField.RingOfIntegers.minpoly_coe] using
        (minpoly.isIntegrallyClosed_eq_field_fractions' (R := ℤ) (K := ℚ)
          (S := K) (s := (θ : K)) (NumberField.RingOfIntegers.isIntegral_coe θ))
    rw [hmap, Polynomial.derivative_map] at hderivQ
    simpa only [Polynomial.aeval_map_algebraMap] using hderivQ
  have hderiv_ne_zero : (Polynomial.aeval θ) (Polynomial.derivative (minpoly ℤ θ)) ≠ 0 := by
    rw [← NumberField.RingOfIntegers.coe_ne_zero_iff]
    simpa using hderiv_ne_zero_K
  have hspan_ne_bot :
      Ideal.span ({(Polynomial.aeval θ) (Polynomial.derivative (minpoly ℤ θ))} :
        Set (NumberField.RingOfIntegers K)) ≠ ⊥ := by
    intro hbot
    have hx0 : (Polynomial.aeval θ) (Polynomial.derivative (minpoly ℤ θ)) = 0 :=
      (Ideal.span_singleton_eq_bot).mp hbot
    exact hderiv_ne_zero hx0
  have hconductor_ne_bot : conductor ℤ θ ≠ ⊥ := by
    intro hbot
    have hprod_bot : conductor ℤ θ * differentIdeal ℤ (NumberField.RingOfIntegers K) = ⊥ := by
      rw [hbot, Ideal.bot_mul]
    rw [hmul] at hprod_bot
    exact hspan_ne_bot hprod_bot
  have hunder_ne_bot : Ideal.under ℤ (conductor ℤ θ) ≠ ⊥ := by
    exact Ideal.under_ne_bot ℤ hconductor_ne_bot
  rw [RingOfIntegers.exponent]
  exact (Ideal.absNorm_ne_zero_iff (Ideal.under ℤ (conductor ℤ θ))).2
    (Ideal.finiteQuotientOfFreeOfNeBot _ hunder_ne_bot)

open NumberField in
theorem splitCompletely_primes_infinite_via_kummerDedekind_aux (L : Type) [Field L] [NumberField L] [Algebra ℚ L]
    [FiniteDimensional ℚ L] [IsGalois ℚ L] :
    {q : ℕ | q.Prime ∧
      ∃ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1}.Infinite := by
  classical
  let P : ℕ → Prop := fun q =>
    q.Prime ∧
      ∃ 𝔓 ∈ (Ideal.span {(q : ℤ)} : Ideal ℤ).primesOver (𝓞 L),
        Ideal.ramificationIdx (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1 ∧
        Ideal.inertiaDeg (Ideal.span {(q : ℤ)} : Ideal ℤ) 𝔓 = 1
  have hP : ∀ badPrimes : Finset ℕ, ∃ q : ℕ, P q ∧ q ∉ badPrimes := by
    intro badPrimes
    obtain ⟨θ, hθ⟩ := numberField_exists_integral_primitive_element L
    let f : Polynomial ℤ := minpoly ℤ θ
    have hf_natDegree_ne_zero : f.natDegree ≠ 0 := by
      exact ne_of_gt (minpoly.natDegree_pos θ.isIntegral)
    have hθexp : RingOfIntegers.exponent θ ≠ 0 :=
      ringOfIntegers_exponent_ne_zero_of_primitive_element L hθ
    have hdisc_ne_zero : Polynomial.discr f ≠ 0 := by
      simpa [f] using (minpoly_discr_ne_zero (K := L) (θ := θ))
    let bad : Finset ℕ :=
      badPrimes ∪ (RingOfIntegers.exponent θ).primeFactors ∪ (Polynomial.discr f).natAbs.primeFactors
    obtain ⟨q, hqprime, hqbad, n, hqeval⟩ :=
      intPolynomial_exists_prime_dvd_eval_outside f hf_natDegree_ne_zero bad
    have hqnot_badPrimes : q ∉ badPrimes := by
      intro hqmem
      exact hqbad (by simp [bad, hqmem])
    have hqexp : ¬ q ∣ RingOfIntegers.exponent θ := by
      intro hqdiv
      have hqmem : q ∈ (RingOfIntegers.exponent θ).primeFactors :=
        Nat.Prime.mem_primeFactors hqprime hqdiv hθexp
      exact hqbad (by simp [bad, hqmem])
    have hqdisc : ¬ q ∣ (Polynomial.discr f).natAbs := by
      intro hqdiv
      have hqmem : q ∈ (Polynomial.discr f).natAbs.primeFactors :=
        Nat.Prime.mem_primeFactors hqprime hqdiv (by
          exact Int.natAbs_ne_zero.mpr hdisc_ne_zero)
      exact hqbad (by simp [bad, hqmem])
    haveI : Fact q.Prime := ⟨hqprime⟩
    rcases prime_above_ef_one_of_not_dvd_exponent_discr_and_eval (K := L) (θ := θ)
      q hqexp hqdisc hqeval with ⟨𝔓, h𝔓, he, hf⟩
    refine ⟨q, ?_, hqnot_badPrimes⟩
    dsimp [P]
    exact ⟨hqprime, 𝔓, h𝔓, he, hf⟩
  simpa [P] using infinite_of_exists_outside_finset P hP


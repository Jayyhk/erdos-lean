open NumberField

theorem disc_eq_of_unramified
    (F M : Type) [Field F] [Field M] [NumberField F] [NumberField M]
    [Algebra F M] [FiniteDimensional F M]
    (_h_finite : ∀ (𝔭 : Ideal (𝓞 F)) (𝔓 : Ideal (𝓞 M)),
        𝔭.IsPrime → 𝔭 ≠ ⊥ →
        𝔓 ∈ 𝔭.primesOver (𝓞 M) →
        Ideal.ramificationIdx 𝔭 𝔓 = 1) :
    (NumberField.discr M).natAbs =
      (NumberField.discr F).natAbs ^ Module.finrank F M := by

  have h_main :=
    NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
      F (𝓞 F) M (𝓞 M)

  have h_diff_top : differentIdeal (𝓞 F) (𝓞 M) = ⊤ := by
    by_contra h_ne_top

    obtain ⟨P, hPmax, hPle⟩ :=
      Ideal.exists_le_maximal (differentIdeal (𝓞 F) (𝓞 M)) h_ne_top
    have hPdvd : P ∣ differentIdeal (𝓞 F) (𝓞 M) := Ideal.dvd_iff_le.mpr hPle

    have hPprime : P.IsPrime := hPmax.isPrime
    have hPne_bot : P ≠ ⊥ :=
      Ring.ne_bot_of_isMaximal_of_not_isField hPmax (RingOfIntegers.not_isField M)

    have hUne_bot : P.under (𝓞 F) ≠ ⊥ := Ideal.under_ne_bot (𝓞 F) hPne_bot
    have hUprime : (P.under (𝓞 F)).IsPrime := Ideal.IsPrime.under (𝓞 F) P

    have hLies : P.LiesOver (P.under (𝓞 F)) := Ideal.over_under _

    have hPmem : P ∈ (P.under (𝓞 F)).primesOver (𝓞 M) := ⟨hPprime, hLies⟩

    have h_ram_one :
        Ideal.ramificationIdx (P.under (𝓞 F)) P = 1 :=
      _h_finite (P.under (𝓞 F)) P hUprime hUne_bot hPmem

    have h_unram : Algebra.IsUnramifiedAt (𝓞 F) P := by
      rw [Algebra.isUnramifiedAt_iff_of_isDedekindDomain (R := 𝓞 F) hPne_bot]
      exact h_ram_one

    have h_not_dvd : ¬ P ∣ differentIdeal (𝓞 F) (𝓞 M) := by
      rw [not_dvd_differentIdeal_iff]
      exact h_unram
    exact h_not_dvd hPdvd

  rw [h_diff_top, Ideal.absNorm_top, one_mul] at h_main
  exact h_main

theorem IsEverywhereUnramified.discr_eq
    {F M : Type} [Field F] [Field M] [NumberField F] [NumberField M]
    [Algebra F M] [FiniteDimensional F M] (h : IsEverywhereUnramified F M) :
    (NumberField.discr M).natAbs =
      (NumberField.discr F).natAbs ^ Module.finrank F M :=
  disc_eq_of_unramified F M h.1


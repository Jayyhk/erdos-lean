  have hmcv : MeasurableConstVAdd (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V := inferInstance
  have hvinv : MeasureTheory.VAddInvariantMeasure (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V MeasureTheory.volume := inferInstance
  have hcount (a : рқ’ҹ.V) :
      (вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a)) =
        (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) := by
    let T : Set рқ’ҹ.Оӣ := {l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + (l : рқ’ҹ.V) + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R}
    calc
      (вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a))
          = вҲ‘' l : рқ’ҹ.Оӣ, T.indicator (fun _ => (1 : ENNReal)) l := by
            refine tsum_congr ?_
            intro l
            change S.indicator (fun _ => (1 : ENNReal)) ((l : рқ’ҹ.V) + a) = _
            by_cases hl : l вҲҲ T
            В· have hs : (l : рқ’ҹ.V) + a вҲҲ S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
            В· have hs : (l : рқ’ҹ.V) + a вҲү S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
      _ = вҲ‘' l : T, (1 : ENNReal) := by
            symm
            exact tsum_subtype T (fun _ => (1 : ENNReal))
      _ = T.encard := ENNReal.tsum_set_one T
      _ = (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) := by
            exact_mod_cast (lemma_2_4_shift_count_eq_lattice_encard рқ’ҹ a R u hОӣu)
  have hlin0 :
      вҲ«вҒ» x, S.indicator (fun _ => (1 : ENNReal)) x вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» x in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ x) вҲӮMeasureTheory.volume := by
    simpa [F] using
      (@MeasureTheory.IsAddFundamentalDomain.lintegral_eq_tsum'' (вҶҘрқ’ҹ.Оӣ) (рқ’ҹ.V)
        inferInstance inferInstance inferInstance (lemma_2_4_FD рқ’ҹ) MeasureTheory.volume
        hmcv hvinv inferInstance (lemma_2_4_isAddFundamentalDomain рқ’ҹ)
        (S.indicator (fun _ => (1 : ENNReal))))
  have hmeas_indicator : Measurable (S.indicator (fun _ => (1 : ENNReal))) := by
    exact Measurable.indicator measurable_const hS
  have hmeas_l (l : рқ’ҹ.Оӣ) :
      Measurable (fun a : рқ’ҹ.V => S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a)) := by
    exact hmeas_indicator.comp (measurable_const_vadd l)
  have hlin :
      вҲ«вҒ» a in F, вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» a in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := by
    exact MeasureTheory.lintegral_tsum (fun l => (hmeas_l l).aemeasurable)
  have hlin_count :
      вҲ«вҒ» a in F, (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» a in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := by
    calc
      вҲ«вҒ» a in F, (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) вҲӮMeasureTheory.volume
          = вҲ«вҒ» a in F, вҲ‘' l : рқ’ҹ.Оӣ, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := by
              refine MeasureTheory.lintegral_congr_ae ?_
              exact Filter.Eventually.of_forall (fun a => (hcount a).symm)
      _ = вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» a in F, S.indicator (fun _ => (1 : ENNReal)) (l +бөҘ a) вҲӮMeasureTheory.volume := hlin
  have hmeas_count :
      AEMeasurable
        (fun a : рқ’ҹ.V => (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal))
        (MeasureTheory.volume.restrict F) := by
    simpa [hcount] using (Measurable.ennreal_tsum (fun l : рқ’ҹ.Оӣ => hmeas_l l)).aemeasurable
  have hfinite_count :
      вҲҖбөҗ a вҲӮ(MeasureTheory.volume.restrict F),
        (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) < вҠӨ := by
    exact Filter.Eventually.of_forall (fun a => by simp)
  have hfinite_indicator :
      вҲҖбөҗ a вҲӮMeasureTheory.volume,
        S.indicator (fun _ => (1 : ENNReal)) a < вҠӨ := by
    exact Filter.Eventually.of_forall (fun a => by
      by_cases ha : a вҲҲ S <;> simp [ha])
  have hreal :
      (вҲ«вҒ» a, S.indicator (fun _ => (1 : ENNReal)) a вҲӮMeasureTheory.volume).toReal =
        MeasureTheory.volume.real S := by
    calc
      (вҲ«вҒ» a, S.indicator (fun _ => (1 : ENNReal)) a вҲӮMeasureTheory.volume).toReal
          = вҲ« a, (S.indicator (fun _ => (1 : ENNReal)) a).toReal вҲӮMeasureTheory.volume := by
              symm
              exact MeasureTheory.integral_toReal hmeas_indicator.aemeasurable hfinite_indicator
      _ = вҲ« a, S.indicator (fun _ => (1 : в„қ)) a вҲӮMeasureTheory.volume := by
            refine MeasureTheory.integral_congr_ae ?_
            exact Filter.Eventually.of_forall (fun a => by
              by_cases ha : a вҲҲ S <;> simp [ha])
      _ = MeasureTheory.volume.real S := by
            simpa using (MeasureTheory.integral_indicator_one (Ој := MeasureTheory.volume) (s := S) hS)
  calc
    вҲ« a in F, (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ) вҲӮMeasureTheory.volume
        = (вҲ«вҒ» a in F, (((рқ’ҹ.X_finset a R).filter (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : ENNReal) вҲӮMeasureTheory.volume).toReal := by
            simpa using
              (MeasureTheory.integral_toReal (Ој := MeasureTheory.volume.restrict F) hmeas_count hfinite_count)
    _ = (вҲ«вҒ» a, S.indicator (fun _ => (1 : ENNReal)) a вҲӮMeasureTheory.volume).toReal := by
          rw [hlin_count, hlin0.symm]
    _ = MeasureTheory.volume.real S := hreal
    _ = MeasureTheory.volume.real { a : рқ’ҹ.V | a вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R } := by
          rfl

theorem lemma_2_4_volume_closedPolydisc (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) : MeasureTheory.volume.real (рқ’ҹ.closedPolydisc R) = (рқ’ҹ.b R) ^ рқ’ҹ.f := by
  have hEq : рқ’ҹ.closedPolydisc R = Metric.closedBall (0 : рқ’ҹ.V) R := by
    ext z
    simp [AdmissibleDatum.closedPolydisc, Metric.mem_closedBall, dist_eq_norm, supNorm_eq_norm]
  rw [hEq, MeasureTheory.measureReal_def]
  rw [MeasureTheory.volume_pi_closedBall (x := (0 : рқ’ҹ.V)) hR]
  simp [Complex.volume_closedBall, AdmissibleDatum.b, hR, Fin.prod_const, mul_comm, mul_left_comm, mul_assoc]

open scoped BigOperators in
theorem lemma_2_4_integral_N_count (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) : вҲ« a in lemma_2_4_FD рқ’ҹ, (рқ’ҹ.N_count a R : в„қ) вҲӮMeasureTheory.volume = MeasureTheory.volume.real (рқ’ҹ.closedPolydisc R) := by
  let F := lemma_2_4_FD рқ’ҹ
  let B := рқ’ҹ.closedPolydisc R
  let hmcv : MeasurableConstVAdd (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V :=
    вҹЁfun l => by
      change Measurable ((l : рқ’ҹ.V) + В· : рқ’ҹ.V вҶ’ рқ’ҹ.V)
      simpa [vadd_eq_add] using (measurable_const_add (l : рқ’ҹ.V))вҹ©
  let hvim : MeasureTheory.VAddInvariantMeasure (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V MeasureTheory.volume :=
    вҹЁfun c s hs => by
      change MeasureTheory.volume (((fun x : рқ’ҹ.V => (c : рқ’ҹ.V) + x) вҒ»В№' s)) = MeasureTheory.volume s
      simp [vadd_eq_add]вҹ©
  have hF := lemma_2_4_isAddFundamentalDomain рқ’ҹ
  have hB_eq : B = Metric.closedBall (0 : рқ’ҹ.V) R := by
    ext z
    simp [B, AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm, hR]
  have hB_meas : MeasurableSet B := by
    rw [hB_eq]
    exact measurableSet_closedBall
  have hcount (a : рқ’ҹ.V) :
      (вҲ‘' l : рқ’ҹ.Оӣ, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ a)) = (рқ’ҹ.N_count a R : ENNReal) := by
    let s : Set рқ’ҹ.Оӣ := {l | (l : рқ’ҹ.V) + a вҲҲ B}
    have hs : s = {l : рқ’ҹ.Оӣ | a + (l : рқ’ҹ.V) вҲҲ B} := by
      ext l
      change (((l : рқ’ҹ.V) + a вҲҲ B) вҶ” a + (l : рқ’ҹ.V) вҲҲ B)
      rw [add_comm]
    calc
      вҲ‘' l : рқ’ҹ.Оӣ, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ a)
          = вҲ‘' l : рқ’ҹ.Оӣ, s.indicator (fun _ : рқ’ҹ.Оӣ => (1 : ENNReal)) l := by
              refine tsum_congr ?_
              intro l
              by_cases hl : (l : рқ’ҹ.V) + a вҲҲ B
              В· have hl' : l +бөҘ a вҲҲ B := by
                  simpa [vadd_eq_add] using hl
                simp [s, hl, hl']
              В· have hl' : l +бөҘ a вҲү B := by
                  simpa [vadd_eq_add] using hl
                simp [s, hl, hl']
      _ = вҲ‘' l : s, (1 : ENNReal) := by
            symm
            exact tsum_subtype (s := s) (f := fun _ : рқ’ҹ.Оӣ => (1 : ENNReal))
      _ = (s.encard : ENNReal) := by
            simp
      _ = (((рқ’ҹ.N_count a R : в„•вҲһ)) : ENNReal) := by
            rw [hs, lemma_2_4_N_count_eq_lattice_encard]
      _ = (рқ’ҹ.N_count a R : ENNReal) := by
            rfl
  have hlin :
      вҲ«вҒ» x, Set.indicator B (fun _ => (1 : ENNReal)) x вҲӮMeasureTheory.volume =
        вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» x in F, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x) вҲӮMeasureTheory.volume := by
    simpa [F, B] using
      (@MeasureTheory.IsAddFundamentalDomain.lintegral_eq_tsum''
        (вҶҘрқ’ҹ.Оӣ) рқ’ҹ.V _ _ _ F MeasureTheory.volume hmcv hvim inferInstance hF
        (Set.indicator B (fun _ => (1 : ENNReal))))
  have hmeas_indicator : Measurable (Set.indicator B (fun _ : рқ’ҹ.V => (1 : ENNReal))) := by
    exact Measurable.indicator measurable_const hB_meas
  have hmeas_l (l : рқ’ҹ.Оӣ) : AEMeasurable (fun x : рқ’ҹ.V => Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x)) (MeasureTheory.volume.restrict F) := by
    exact (hmeas_indicator.comp (measurable_const_vadd l)).aemeasurable
  have hlin_count : вҲ«вҒ» x in F, (рқ’ҹ.N_count x R : ENNReal) вҲӮMeasureTheory.volume = MeasureTheory.volume B := by
    calc
      вҲ«вҒ» x in F, (рқ’ҹ.N_count x R : ENNReal) вҲӮMeasureTheory.volume
          = вҲ«вҒ» x in F, вҲ‘' l : рқ’ҹ.Оӣ, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x) вҲӮMeasureTheory.volume := by
              refine MeasureTheory.lintegral_congr_ae ?_
              exact Filter.Eventually.of_forall (fun x => (hcount x).symm)
      _ = вҲ‘' l : рқ’ҹ.Оӣ, вҲ«вҒ» x in F, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x) вҲӮMeasureTheory.volume := by
            simpa using (MeasureTheory.lintegral_tsum (Ој := MeasureTheory.volume.restrict F)
              (f := fun l : рқ’ҹ.Оӣ => fun x : рқ’ҹ.V => Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x)) hmeas_l)
      _ = вҲ«вҒ» x, Set.indicator B (fun _ => (1 : ENNReal)) x вҲӮMeasureTheory.volume := hlin.symm
      _ = MeasureTheory.volume B := by
            simp [hB_meas]
  have hmeas_tsum : AEMeasurable
      (fun x : рқ’ҹ.V => вҲ‘' l : рқ’ҹ.Оӣ, Set.indicator B (fun _ => (1 : ENNReal)) (l +бөҘ x))
      (MeasureTheory.volume.restrict F) := by
    exact AEMeasurable.ennreal_tsum (fun l => hmeas_l l)
  have hmeas_count : AEMeasurable (fun x : рқ’ҹ.V => (рқ’ҹ.N_count x R : ENNReal)) (MeasureTheory.volume.restrict F) := by
    exact hmeas_tsum.congr (Filter.Eventually.of_forall hcount)
  have hfinite_count : вҲҖбөҗ x вҲӮMeasureTheory.volume.restrict F, (рқ’ҹ.N_count x R : ENNReal) < вҠӨ := by
    exact Filter.Eventually.of_forall (fun x => by simp)
  have hreal :
      вҲ« x in F, (рқ’ҹ.N_count x R : в„қ) вҲӮMeasureTheory.volume =
        (вҲ«вҒ» x in F, (рқ’ҹ.N_count x R : ENNReal) вҲӮMeasureTheory.volume).toReal := by
    simpa using (MeasureTheory.integral_toReal (Ој := MeasureTheory.volume.restrict F)
      (f := fun x : рқ’ҹ.V => (рқ’ҹ.N_count x R : ENNReal)) hmeas_count hfinite_count)
  rw [hreal, hlin_count]
  rfl

theorem lemma_2_4_average_N_count (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) : вЁҚ a in lemma_2_4_FD рқ’ҹ, (рқ’ҹ.N_count a R : в„қ) вҲӮMeasureTheory.volume = (рқ’ҹ.b R) ^ рқ’ҹ.f / ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) := by
  rw [MeasureTheory.setAverage_eq]
  rw [lemma_2_4_integral_N_count рқ’ҹ R hR]
  rw [lemma_2_4_volume_closedPolydisc рқ’ҹ R hR]
  have hcov :
      ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) =
        MeasureTheory.volume.real (lemma_2_4_FD рқ’ҹ) := by
    simpa using
      (ZLattice.covolume_eq_measure_fundamentalDomain
        (L := рқ’ҹ.Оӣ) (F := lemma_2_4_FD рқ’ҹ) (Ој := MeasureTheory.volume)
        (h := lemma_2_4_isAddFundamentalDomain рқ’ҹ))
  rw [вҶҗ hcov]
  simp only [smul_eq_mul, div_eq_mul_inv]
  ring

theorem lemma_2_4_volume_overlap_set (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) (u : рқ’ҹ.K) (hu : вҲҖ Пғ : рқ’ҹ.K вҶ’+* в„Ӯ, вҖ–Пғ uвҖ– = 1) : MeasureTheory.volume.real { a : рқ’ҹ.V | a вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R } = overlapArea R ^ рқ’ҹ.f := by
  classical
  let s : Fin рқ’ҹ.f вҶ’ Set в„Ӯ :=
    fun i => Metric.closedBall (0 : в„Ӯ) R вҲ© Metric.closedBall (-(adm_Пғ рқ’ҹ i u)) R
  have hset :
      { a : рқ’ҹ.V | a вҲҲ рқ’ҹ.closedPolydisc R вҲ§ a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R }
        = Set.univ.pi s := by
    ext a
    constructor
    В· intro ha
      rw [Set.mem_univ_pi]
      intro i
      rcases ha with вҹЁha1, ha2вҹ©
      have ha1' : a вҲҲ Metric.closedBall (0 : рқ’ҹ.V) R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha1
      have ha2' : a + рқ’ҹ.ОҰ u вҲҲ Metric.closedBall (0 : рқ’ҹ.V) R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha2
      have ha1pi : a вҲҲ Set.univ.pi (fun j : Fin рқ’ҹ.f => Metric.closedBall (0 : в„Ӯ) R) := by
        simpa [closedBall_pi (x := (0 : рқ’ҹ.V)) hR] using ha1'
      have ha2pi : a + рқ’ҹ.ОҰ u вҲҲ Set.univ.pi (fun j : Fin рқ’ҹ.f => Metric.closedBall (0 : в„Ӯ) R) := by
        simpa [closedBall_pi (x := (0 : рқ’ҹ.V)) hR] using ha2'
      refine вҹЁ(Set.mem_univ_pi.mp ha1pi i), ?_вҹ©
      have hi : a i + рқ’ҹ.ОҰ u i вҲҲ Metric.closedBall (0 : в„Ӯ) R :=
        Set.mem_univ_pi.mp ha2pi i
      simpa [s, AdmissibleDatum.ОҰ, Metric.mem_closedBall, dist_eq_norm, sub_eq_add_neg,
        add_assoc, add_left_comm, add_comm] using hi
    В· intro ha
      rw [Set.mem_univ_pi] at ha
      have ha1pi : a вҲҲ Set.univ.pi (fun i : Fin рқ’ҹ.f => Metric.closedBall (0 : в„Ӯ) R) := by
        rw [Set.mem_univ_pi]
        intro i
        exact (ha i).1
      have ha1' : a вҲҲ Metric.closedBall (0 : рқ’ҹ.V) R := by
        simpa [closedBall_pi (x := (0 : рқ’ҹ.V)) hR] using ha1pi
      have ha1poly : a вҲҲ рқ’ҹ.closedPolydisc R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha1'
      have ha2pi : a + рқ’ҹ.ОҰ u вҲҲ Set.univ.pi (fun i : Fin рқ’ҹ.f => Metric.closedBall (0 : в„Ӯ) R) := by
        rw [Set.mem_univ_pi]
        intro i
        have hi : a i вҲҲ Metric.closedBall (-(adm_Пғ рқ’ҹ i u)) R := (ha i).2
        simpa [AdmissibleDatum.ОҰ, Metric.mem_closedBall, dist_eq_norm, sub_eq_add_neg,
          add_assoc, add_left_comm, add_comm] using hi
      have ha2' : a + рқ’ҹ.ОҰ u вҲҲ Metric.closedBall (0 : рқ’ҹ.V) R := by
        simpa [closedBall_pi (x := (0 : рқ’ҹ.V)) hR] using ha2pi
      have ha2poly : a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R := by
        simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm, Metric.mem_closedBall, dist_eq_norm]
          using ha2'
      exact вҹЁha1poly, ha2polyвҹ©
  rw [hset, MeasureTheory.measureReal_def, MeasureTheory.volume_pi_pi]
  rw [ENNReal.toReal_prod]
  have hfac : вҲҖ i : Fin рқ’ҹ.f, (MeasureTheory.volume (s i)).toReal = overlapArea R := by
    intro i
    have hПғ : вҖ–adm_Пғ рқ’ҹ i uвҖ– = 1 := hu (adm_Пғ рқ’ҹ i)
    simpa [s] using lemma_2_4_closedBall_overlap_volume R (adm_Пғ рқ’ҹ i u) hПғ
  simp_rw [hfac]
  simp

open scoped Pointwise in
theorem lemma_2_4_average_E_count (рқ’ҹ : AdmissibleDatum) (R : в„қ) (hR : 0 вүӨ R) (U : Finset рқ’ҹ.K) (hU_norm : вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u) : вЁҚ a in lemma_2_4_FD рқ’ҹ, (рқ’ҹ.E_count a R U : в„қ) вҲӮMeasureTheory.volume = ((U.card : в„қ) * overlapArea R ^ рқ’ҹ.f) / ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) := by
  classical
  rw [MeasureTheory.setAverage_eq]
  simp_rw [AdmissibleDatum.E_count, Nat.cast_sum]
  have hsum :
      вҲ« a in lemma_2_4_FD рқ’ҹ,
          вҲ‘ u вҲҲ U,
            (((рқ’ҹ.X_finset a R).filter
              (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ)
            вҲӮMeasureTheory.volume
        =
      вҲ‘ u вҲҲ U,
        вҲ« a in lemma_2_4_FD рқ’ҹ,
          (((рқ’ҹ.X_finset a R).filter
            (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ)
            вҲӮMeasureTheory.volume := by
    simpa using
      (MeasureTheory.integral_finset_sum
        (Ој := MeasureTheory.volume.restrict (lemma_2_4_FD рқ’ҹ)) U
        (fun u hu =>
          lemma_2_4_integrable_shift_count рқ’ҹ R u
            (by exact вҹЁu, (hU_norm u hu).2.2, rflвҹ©)))
  rw [hsum]
  have hsum2 :
      вҲ‘ u вҲҲ U,
        вҲ« a in lemma_2_4_FD рқ’ҹ,
          (((рқ’ҹ.X_finset a R).filter
            (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card : в„қ)
            вҲӮMeasureTheory.volume
      = вҲ‘ u вҲҲ U, overlapArea R ^ рқ’ҹ.f := by
    refine Finset.sum_congr rfl ?_
    intro u hu
    have hОӣu : рқ’ҹ.ОҰ u вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
      exact вҹЁu, (hU_norm u hu).2.2, rflвҹ©
    rw [lemma_2_4_integral_shift_count рқ’ҹ R hR u hОӣu]
    rw [lemma_2_4_volume_overlap_set рқ’ҹ R hR u ((hU_norm u hu).2.1)]
  rw [hsum2]
  rw [вҶҗ ZLattice.covolume_eq_measure_fundamentalDomain
    (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) (h := lemma_2_4_isAddFundamentalDomain рқ’ҹ)]
  simp [Finset.sum_const_nat, smul_eq_mul, div_eq_mul_inv]
  ring

theorem lemma_2_4_gap_average_pos (рқ’ҹ : AdmissibleDatum) (H : в„қ) (hH : 0 < H) (R : в„қ) (hR : 1 / 2 < R) (U : Finset рқ’ҹ.K) (hU_norm : вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u) (hU_size : (U.card : в„қ) вүҘ Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f)) (_hПҒ_pos : 0 < рқ’ҹ.ПҒ R) (_hПҒ : -((рқ’ҹ.t * Real.log 2 - Real.log H) / 2) < Real.log (рқ’ҹ.ПҒ R)) : 0 < вЁҚ a in lemma_2_4_FD рқ’ҹ, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume := by
  set Оі : в„қ := (рқ’ҹ.t : в„қ) * Real.log 2 - Real.log H
  let s : Set рқ’ҹ.V := lemma_2_4_FD рқ’ҹ
  let ОҪ : MeasureTheory.Measure рқ’ҹ.V := (MeasureTheory.volume s)вҒ»В№ вҖў MeasureTheory.volume.restrict s
  have hcov_pos : 0 < ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) := by
    simpa using ZLattice.covolume_pos (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume)
  have hR_pos : 0 < R := by linarith
  have hb_pos : 0 < рқ’ҹ.b R := by
    unfold AdmissibleDatum.b
    positivity
  have hoverlap_eq : overlapArea R = рқ’ҹ.ПҒ R * рқ’ҹ.b R := by
    calc
      overlapArea R = (overlapArea R / рқ’ҹ.b R) * рқ’ҹ.b R := by
        field_simp [hb_pos.ne']
      _ = рқ’ҹ.ПҒ R * рқ’ҹ.b R := by rw [AdmissibleDatum.ПҒ]
  have hoverlap_pos : 0 < overlapArea R := by
    rw [hoverlap_eq]
    exact mul_pos _hПҒ_pos hb_pos
  have hU_card_pos : 0 < (U.card : в„қ) := by
    exact lt_of_lt_of_le (Real.exp_pos (Оі * рқ’ҹ.f)) hU_size
  have havgE := lemma_2_4_average_E_count рқ’ҹ R hR_pos.le U hU_norm
  have havgN := lemma_2_4_average_N_count рқ’ҹ R hR_pos.le
  rw [MeasureTheory.setAverage_eq'] at havgE havgN
  have hE_rhs_pos :
      0 < ((U.card : в„қ) * overlapArea R ^ рқ’ҹ.f) /
        ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) := by
    exact div_pos (mul_pos hU_card_pos (pow_pos hoverlap_pos _)) hcov_pos
  have hN_rhs_pos :
      0 < (рқ’ҹ.b R) ^ рқ’ҹ.f /
        ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) := by
    exact div_pos (pow_pos hb_pos _) hcov_pos
  have hE_int_ne_zero :
      вҲ« a, (рқ’ҹ.E_count a R U : в„қ) вҲӮОҪ вү  0 := by
    rw [havgE]
    exact hE_rhs_pos.ne'
  have hN_int_ne_zero :
      вҲ« a, (рқ’ҹ.N_count a R : в„қ) вҲӮОҪ вү  0 := by
    rw [havgN]
    exact hN_rhs_pos.ne'
  have hE_int : MeasureTheory.Integrable (fun a => (рқ’ҹ.E_count a R U : в„қ)) ОҪ := by
    by_contra hnot
    rw [MeasureTheory.integral_undef hnot] at hE_int_ne_zero
    exact hE_int_ne_zero rfl
  have hN_int : MeasureTheory.Integrable (fun a => (рқ’ҹ.N_count a R : в„қ)) ОҪ := by
    by_contra hnot
    rw [MeasureTheory.integral_undef hnot] at hN_int_ne_zero
    exact hN_int_ne_zero rfl
  have hf_pos : (0 : в„қ) < рқ’ҹ.f := by
    exact_mod_cast рқ’ҹ.f_pos
  have hrho_pow_pos : 0 < (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
    exact pow_pos _hПҒ_pos _
  have hlogstep : Оі / 2 < Оі + Real.log (рқ’ҹ.ПҒ R) := by
    linarith [_hПҒ]
  have hmulstep : (Оі / 2) * (рқ’ҹ.f : в„қ) < (Оі + Real.log (рқ’ҹ.ПҒ R)) * (рқ’ҹ.f : в„қ) := by
    exact mul_lt_mul_of_pos_right hlogstep hf_pos
  have hlt_exp : Real.exp (Оі * рқ’ҹ.f / 2) < Real.exp (Оі * рқ’ҹ.f) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
    have htemp : Real.exp ((Оі / 2) * (рқ’ҹ.f : в„қ)) < Real.exp ((Оі + Real.log (рқ’ҹ.ПҒ R)) * (рқ’ҹ.f : в„қ)) := by
      exact Real.exp_lt_exp.mpr hmulstep
    have hright :
        Real.exp ((Оі + Real.log (рқ’ҹ.ПҒ R)) * (рқ’ҹ.f : в„қ)) =
          Real.exp (Оі * (рқ’ҹ.f : в„қ)) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
      calc
        Real.exp ((Оі + Real.log (рқ’ҹ.ПҒ R)) * (рқ’ҹ.f : в„қ))
            = Real.exp (Оі * (рқ’ҹ.f : в„қ) + Real.log (рқ’ҹ.ПҒ R) * (рқ’ҹ.f : в„қ)) := by
                congr 1
                ring
        _ = Real.exp (Оі * (рқ’ҹ.f : в„қ)) * Real.exp (Real.log (рқ’ҹ.ПҒ R) * (рқ’ҹ.f : в„қ)) := by
              rw [Real.exp_add]
        _ = Real.exp (Оі * (рқ’ҹ.f : в„қ)) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
              congr 1
              calc
                Real.exp (Real.log (рқ’ҹ.ПҒ R) * (рқ’ҹ.f : в„қ))
                    = Real.exp (Real.log (рқ’ҹ.ПҒ R)) ^ (рқ’ҹ.f : в„қ) := by
                        rw [Real.exp_mul]
                _ = (рқ’ҹ.ПҒ R) ^ (рқ’ҹ.f : в„қ) := by rw [Real.exp_log _hПҒ_pos]
                _ = (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by rw [Real.rpow_natCast]
    have hleft : Real.exp ((Оі / 2) * (рқ’ҹ.f : в„қ)) = Real.exp (Оі * рқ’ҹ.f / 2) := by
      congr 1
      ring
    rw [hleft, hright] at htemp
    exact htemp
  have hmul_u : Real.exp (Оі * рқ’ҹ.f) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f вүӨ (U.card : в„қ) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
    exact mul_le_mul_of_nonneg_right hU_size hrho_pow_pos.le
  have hC_lt : Real.exp (Оі * рқ’ҹ.f / 2) < (U.card : в„қ) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f := by
    exact lt_of_lt_of_le hlt_exp hmul_u
  rw [MeasureTheory.setAverage_eq']
  change 0 < вҲ« a, lemma_2_4_gap рқ’ҹ H R U a вҲӮОҪ
  dsimp [lemma_2_4_gap]
  rw [MeasureTheory.integral_sub hE_int (hN_int.const_mul _)]
  rw [MeasureTheory.integral_const_mul]
  rw [havgE, havgN]
  have hfinal_eq :
      ((U.card : в„қ) * overlapArea R ^ рқ’ҹ.f) /
            ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume) -
          Real.exp (Оі * рқ’ҹ.f / 2) *
            ((рқ’ҹ.b R) ^ рқ’ҹ.f /
              ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume)) =
        (((U.card : в„қ) * (рқ’ҹ.ПҒ R) ^ рқ’ҹ.f) - Real.exp (Оі * рқ’ҹ.f / 2)) *
          ((рқ’ҹ.b R) ^ рқ’ҹ.f /
            ZLattice.covolume (L := рқ’ҹ.Оӣ) (Ој := MeasureTheory.volume)) := by
    rw [hoverlap_eq, mul_pow]
    ring
  rw [hfinal_eq]
  exact mul_pos (sub_pos.mpr hC_lt) hN_rhs_pos

theorem lemma_2_4 (рқ’ҹ : AdmissibleDatum) (H : в„қ) (hH : 0 < H)
    (R : в„қ) (hR : 1 / 2 < R)
    (U : Finset рқ’ҹ.K)
    (hU_norm : вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u)
    (hU_size : (U.card : в„қ) вүҘ
      Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f))

    (_hПҒ_pos : 0 < рқ’ҹ.ПҒ R)
    (_hПҒ : -((рқ’ҹ.t * Real.log 2 - Real.log H) / 2) < Real.log (рқ’ҹ.ПҒ R)) :
    вҲғ a : рқ’ҹ.V,
      0 < рқ’ҹ.N_count a R вҲ§
      (рқ’ҹ.E_count a R U : в„қ) вүҘ
        Real.exp ((рқ’ҹ.t * Real.log 2 - Real.log H) * рқ’ҹ.f / 2) *
          рқ’ҹ.N_count a R := by
  have havg :
      0 < вЁҚ a in lemma_2_4_FD рқ’ҹ, lemma_2_4_gap рқ’ҹ H R U a вҲӮMeasureTheory.volume :=
    lemma_2_4_gap_average_pos рқ’ҹ H hH R hR U hU_norm hU_size _hПҒ_pos _hПҒ
  rcases lemma_2_4_exists_gap_positive рқ’ҹ H R U havg with вҹЁa, _haFD, hgapвҹ©
  have hNpos : 0 < рқ’ҹ.N_count a R := by
    by_contra hNnonpos
    have hNzero : рқ’ҹ.N_count a R = 0 := by
      linarith
    have hEzero : рқ’ҹ.E_count a R U = 0 :=
      lemma_2_4_E_count_eq_zero_of_N_count_eq_zero рқ’ҹ a R U hNzero
    unfold lemma_2_4_gap at hgap
    rw [hNzero, hEzero] at hgap
    norm_num at hgap
  refine вҹЁa, hNpos, ?_вҹ©
  have hgap' := hgap
  unfold lemma_2_4_gap at hgap'
  linarith

noncomputable def complexPoint (z : в„Ӯ) : Point :=
  (EuclideanSpace.equiv (Fin 2) в„қ).symm ![z.re, z.im]

theorem complexPoint_dist (z w : в„Ӯ) : dist (complexPoint z) (complexPoint w) = вҖ–z - wвҖ– := by
  have hsq : dist (complexPoint z) (complexPoint w) ^ 2 = вҖ–z - wвҖ– ^ 2 := by
    calc
      dist (complexPoint z) (complexPoint w) ^ 2
          = вҲ‘ i : Fin 2, dist ((complexPoint z) i) ((complexPoint w) i) ^ 2 := by
            rw [EuclideanSpace.dist_sq_eq]
      _ = (z.re - w.re) ^ 2 + (z.im - w.im) ^ 2 := by
        simp [complexPoint, Real.dist_eq, sq_abs]
      _ = вҖ–z - wвҖ– ^ 2 := by
        rw [RCLike.norm_sq_eq_def]
        simp
        ring
  have hnonneg1 : 0 вүӨ dist (complexPoint z) (complexPoint w) := dist_nonneg
  have hnonneg2 : 0 вүӨ вҖ–z - wвҖ– := norm_nonneg _
  nlinarith

theorem complexPoint_injective: Function.Injective complexPoint := by
  intro z w h
  have h' := congrArg (EuclideanSpace.equiv (Fin 2) в„қ) h
  apply Complex.ext
  В· simpa [complexPoint] using congrFun h' 0
  В· simpa [complexPoint] using congrFun h' 1

theorem lemma_2_5_pi1_injOn (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) : Set.InjOn рқ’ҹ.ПҖ1 (рқ’ҹ.X a R) := by
  intro x hx y hy hxy
  rcases hx with вҹЁhx, _вҹ©
  rcases hy with вҹЁhy, _вҹ©
  rcases hx with вҹЁlx, rflвҹ©
  rcases hy with вҹЁly, rflвҹ©
  have hlx : ((lx : рқ’ҹ.V) вҲҲ рқ’ҹ.Оӣ) := lx.2
  change вҲғ u : рқ’ҹ.K,
      (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) x) вҲ§
        рқ’ҹ.ОҰ u = (lx : рқ’ҹ.V) at hlx
  have hly : ((ly : рқ’ҹ.V) вҲҲ рқ’ҹ.Оӣ) := ly.2
  change вҲғ u : рқ’ҹ.K,
      (вҲғ x : рқ“һ рқ’ҹ.K, ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = (algebraMap (рқ“һ рқ’ҹ.K) рқ’ҹ.K) x) вҲ§
        рқ’ҹ.ОҰ u = (ly : рқ’ҹ.V) at hly
  rcases hlx with вҹЁuвӮҒ, _, huвӮҒвҹ©
  rcases hly with вҹЁuвӮӮ, _, huвӮӮвҹ©
  have hxy' :
      a вҹЁ0, рқ’ҹ.f_posвҹ© + (lx : рқ’ҹ.V) вҹЁ0, рқ’ҹ.f_posвҹ© =
        a вҹЁ0, рқ’ҹ.f_posвҹ© + (ly : рқ’ҹ.V) вҹЁ0, рқ’ҹ.f_posвҹ© := by
    simpa [AdmissibleDatum.ПҖ1] using hxy
  have hxy0 : (lx : рқ’ҹ.V) вҹЁ0, рқ’ҹ.f_posвҹ© = (ly : рқ’ҹ.V) вҹЁ0, рқ’ҹ.f_posвҹ© :=
    add_left_cancel hxy'
  have hu : uвӮҒ = uвӮӮ := by
    apply (adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ©).injective
    rw [вҶҗ huвӮҒ, вҶҗ huвӮӮ] at hxy0
    simpa [AdmissibleDatum.ОҰ] using hxy0
  have hl : (lx : рқ’ҹ.V) = (ly : рқ’ҹ.V) := by
    rw [вҶҗ huвӮҒ, вҶҗ huвӮӮ, hu]
  simp [hl]

noncomputable def orderedUnitPairs (P : Finset Point) : Finset (Point Г— Point) :=
  (P.offDiag).filter (fun xy => dist xy.1 xy.2 = 1)

theorem lemma_2_5_E_count_le_orderedUnitPairs (рқ’ҹ : AdmissibleDatum) (U : Finset рқ’ҹ.K)
    (hU_norm : вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u)
    (a : рқ’ҹ.V) (R : в„қ)
    (hinj : Set.InjOn рқ’ҹ.ПҖ1 (рқ’ҹ.X a R)) :
    рқ’ҹ.E_count a R U вүӨ (orderedUnitPairs (рқ’ҹ.P_set a R)).card := by
  classical
  unfold AdmissibleDatum.E_count
  rw [show вҲ‘ u вҲҲ U, ((рқ’ҹ.X_finset a R).filter
        (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card
      = (U.sigma (fun u => (рқ’ҹ.X_finset a R).filter
          (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R))).card from
      (Finset.card_sigma _ _).symm]
  set src := U.sigma (fun u => (рқ’ҹ.X_finset a R).filter
    (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R))
  let g : (ОЈ _ : рқ’ҹ.K, рқ’ҹ.V) вҶ’ Point Г— Point := fun p =>
    (complexPoint (рқ’ҹ.ПҖ1 (p.2 + рқ’ҹ.ОҰ p.1)), complexPoint (рқ’ҹ.ПҖ1 p.2))
  have hmap : вҲҖ p вҲҲ src, g p вҲҲ orderedUnitPairs (рқ’ҹ.P_set a R) := by
    intro вҹЁu, xвҹ© hp
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp
    rcases hp with вҹЁhu, hx, hx'вҹ©
    have hxP : complexPoint (рқ’ҹ.ПҖ1 x) вҲҲ рқ’ҹ.P_set a R := by
      unfold AdmissibleDatum.P_set
      exact Finset.mem_image.mpr вҹЁx, hx, by simp [complexPoint]вҹ©
    have hyP : complexPoint (рқ’ҹ.ПҖ1 (x + рқ’ҹ.ОҰ u)) вҲҲ рқ’ҹ.P_set a R := by
      unfold AdmissibleDatum.P_set
      exact Finset.mem_image.mpr вҹЁx + рқ’ҹ.ОҰ u, hx', by simp [complexPoint]вҹ©
    have hdist : dist (complexPoint (рқ’ҹ.ПҖ1 (x + рқ’ҹ.ОҰ u))) (complexPoint (рқ’ҹ.ПҖ1 x)) = 1 := by
      rw [complexPoint_dist]
      have hnorm : вҖ–adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ© uвҖ– = 1 :=
        (hU_norm u hu).2.1 (adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ©)
      simpa [AdmissibleDatum.ПҖ1, AdmissibleDatum.ОҰ] using hnorm
    refine Finset.mem_filter.mpr ?_
    refine вҹЁ?_, hdistвҹ©
    rw [Finset.mem_offDiag]
    refine вҹЁhyP, hxP, ?_вҹ©
    intro hEq
    have hEq' : complexPoint (рқ’ҹ.ПҖ1 (x + рқ’ҹ.ОҰ u)) = complexPoint (рқ’ҹ.ПҖ1 x) := by
      simpa [g] using hEq
    have hzero : dist (complexPoint (рқ’ҹ.ПҖ1 (x + рқ’ҹ.ОҰ u))) (complexPoint (рқ’ҹ.ПҖ1 x)) = 0 := by
      rw [hEq']
      exact dist_self _
    rw [hzero] at hdist
    norm_num at hdist
  have hinjg : Set.InjOn g src := by
    intro вҹЁu, xвҹ© hp вҹЁv, yвҹ© hq heq
    change Sigma.mk u x вҲҲ src at hp
    change Sigma.mk v y вҲҲ src at hq
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp hq
    rcases hp with вҹЁhu, hx, hx'вҹ©
    rcases hq with вҹЁhv, hy, hy'вҹ©
    simp only [g, Prod.mk.injEq] at heq
    rcases heq with вҹЁh1, h2вҹ©
    have hПҖ1 : рқ’ҹ.ПҖ1 x = рқ’ҹ.ПҖ1 y := complexPoint_injective h2
    have hxy : x = y := hinj
      (by simpa [AdmissibleDatum.X_finset] using hx)
      (by simpa [AdmissibleDatum.X_finset] using hy)
      hПҖ1
    have hПҖ2 : рқ’ҹ.ПҖ1 (x + рқ’ҹ.ОҰ u) = рқ’ҹ.ПҖ1 (y + рқ’ҹ.ОҰ v) := complexPoint_injective h1
    have hxy' : x + рқ’ҹ.ОҰ u = y + рқ’ҹ.ОҰ v := hinj
      (by simpa [AdmissibleDatum.X_finset] using hx')
      (by simpa [AdmissibleDatum.X_finset] using hy')
      hПҖ2
    have hОҰ : рқ’ҹ.ОҰ u = рқ’ҹ.ОҰ v := by
      rw [hxy] at hxy'
      exact add_left_cancel hxy'
    have huv : u = v := AdmissibleDatum.ОҰ_injective рқ’ҹ hОҰ
    cases huv
    cases hxy
    rfl
  exact Finset.card_le_card_of_injOn g hmap hinjg

theorem orderedUnitPairs_card_le_two_mul_nu (P : Finset Point) : (orderedUnitPairs P).card вүӨ 2 * ОҪ P := by
  classical
  let T : Finset (Point Г— Point) := orderedUnitPairs P
  let f : Point Г— Point вҶ’ Sym2 Point := fun xy => Sym2.mk xy.1 xy.2
  let unitDistSymm : {g : Point вҶ’ Point вҶ’ Prop // вҲҖ a b, g a b = g b a} :=
    вҹЁfun a b => dist a b = 1, by
      intro a b
      simp [dist_comm]вҹ©
  change T.card вүӨ 2 * ОҪ P
  have hfiber_le_two : вҲҖ z вҲҲ T.image f, ({a вҲҲ T | f a = z}).card вүӨ 2 := by
    intro z hz
    have hnotdiag : В¬ z.IsDiag := by
      rcases Finset.mem_image.mp hz with вҹЁxy, hxyT, rflвҹ©
      have hxyT' : xy вҲҲ P.offDiag вҲ§ dist xy.1 xy.2 = 1 := by
        simpa [T, orderedUnitPairs] using hxyT
      simpa [f] using Finset.not_isDiag_mk_of_mem_offDiag hxyT'.1
    have hcard_le : ({a вҲҲ T | f a = z}).card вүӨ (z.toFinset.offDiag).card := by
      let g : {a // a вҲҲ {a вҲҲ T | f a = z}} вҶ’ {a // a вҲҲ z.toFinset.offDiag} := by
        intro p
        refine вҹЁp.1, ?_вҹ©
        rcases Finset.mem_filter.mp p.2 with вҹЁhpT, hpzвҹ©
        have hpT' : p.1 вҲҲ P.offDiag вҲ§ dist p.1.1 p.1.2 = 1 := by
          simpa [T, orderedUnitPairs] using hpT
        rcases Finset.mem_offDiag.mp hpT'.1 with вҹЁ_, _, hneвҹ©
        refine Finset.mem_offDiag.mpr ?_
        refine вҹЁ?_, ?_, hneвҹ©
        В· have hx : p.1.1 вҲҲ f p.1 := by
            simp [f]
          exact (Sym2.mem_toFinset).2 (by
            simpa [hpz] using hx)
        В· have hy : p.1.2 вҲҲ f p.1 := by
            simp [f]
          exact (Sym2.mem_toFinset).2 (by
            simpa [hpz] using hy)
      have hg_inj : Function.Injective g := by
        intro a b h
        cases a
        cases b
        cases h
        rfl
      exact Finset.card_le_card_of_injective (f := g) hg_inj
    have hz_card : z.toFinset.card = 2 := Sym2.card_toFinset_of_not_isDiag z hnotdiag
    calc
      ({a вҲҲ T | f a = z}).card вүӨ (z.toFinset.offDiag).card := hcard_le
      _ = z.toFinset.card * z.toFinset.card - z.toFinset.card := by
        simp
      _ = 2 := by
        rw [hz_card]
  have hT_le : T.card вүӨ 2 * (T.image f).card := by
    calc
      T.card = вҲ‘ z вҲҲ T.image f, ({a вҲҲ T | f a = z}).card :=
        Finset.card_eq_sum_card_image f T
      _ вүӨ вҲ‘ z вҲҲ T.image f, 2 := by
        refine Finset.sum_le_sum ?_
        intro z hz
        exact hfiber_le_two z hz
      _ = 2 * (T.image f).card := by
        simp [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]
  have himage_subset :
      T.image f вҠҶ P.sym2.filter (fun z : Sym2 Point => В¬ z.IsDiag вҲ§ Sym2.lift unitDistSymm z) := by
    intro z hz
    rcases Finset.mem_image.mp hz with вҹЁxy, hxyT, rflвҹ©
    have hxyT' : xy вҲҲ P.offDiag вҲ§ dist xy.1 xy.2 = 1 := by
      simpa [T, orderedUnitPairs] using hxyT
    rcases Finset.mem_offDiag.mp hxyT'.1 with вҹЁhxP, hyP, _вҹ©
    refine Finset.mem_filter.mpr ?_
    refine вҹЁ?_, ?_вҹ©
    В· simpa [f] using (Finset.mk_mem_sym2_iff).2 вҹЁhxP, hyPвҹ©
    В· refine вҹЁ?_, ?_вҹ©
      В· simpa [f] using Finset.not_isDiag_mk_of_mem_offDiag hxyT'.1
      В· simpa [f, unitDistSymm] using hxyT'.2
  have himage_le : (T.image f).card вүӨ ОҪ P := by
    simpa [ОҪ, unitDistSymm] using Finset.card_le_card himage_subset
  exact le_trans hT_le (Nat.mul_le_mul_left 2 himage_le)

theorem lemma_2_5 (рқ’ҹ : AdmissibleDatum) (U : Finset рқ’ҹ.K)
    (_hU_norm : вҲҖ u вҲҲ U, рқ’ҹ.IsNormOneIntegral u)
    (a : рқ’ҹ.V) (R : в„қ) :
    Set.InjOn рқ’ҹ.ПҖ1 (рқ’ҹ.X a R) вҲ§
      2 * ОҪ (рқ’ҹ.P_set a R) вүҘ рқ’ҹ.E_count a R U := by
  constructor
  В· exact lemma_2_5_pi1_injOn рқ’ҹ a R
  В· let hinj : Set.InjOn рқ’ҹ.ПҖ1 (рқ’ҹ.X a R) := lemma_2_5_pi1_injOn рқ’ҹ a R
    have hE : рқ’ҹ.E_count a R U вүӨ (orderedUnitPairs (рқ’ҹ.P_set a R)).card :=
      lemma_2_5_E_count_le_orderedUnitPairs рқ’ҹ U _hU_norm a R hinj
    have hord : (orderedUnitPairs (рқ’ҹ.P_set a R)).card вүӨ 2 * ОҪ (рқ’ҹ.P_set a R) :=
      orderedUnitPairs_card_le_two_mul_nu (рқ’ҹ.P_set a R)
    exact le_trans hE hord

theorem P_set_card_eq_N_count (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ)
    (_hinj : Set.InjOn рқ’ҹ.ПҖ1 (рқ’ҹ.X a R)) :
    (рқ’ҹ.P_set a R).card = рқ’ҹ.N_count a R := by
  classical

  have hinj_comp : Set.InjOn
      (fun z : рқ’ҹ.V =>
        (EuclideanSpace.equiv (Fin 2) в„қ).symm ![(рқ’ҹ.ПҖ1 z).re, (рқ’ҹ.ПҖ1 z).im])
      (рқ’ҹ.X a R) := by
    intro x hx y hy hxy
    have hzw' : (![(рқ’ҹ.ПҖ1 x).re, (рқ’ҹ.ПҖ1 x).im] : Fin 2 вҶ’ в„қ) =
        ![(рқ’ҹ.ПҖ1 y).re, (рқ’ҹ.ПҖ1 y).im] :=
      (EuclideanSpace.equiv (Fin 2) в„қ).symm.injective hxy
    have h0 : (рқ’ҹ.ПҖ1 x).re = (рқ’ҹ.ПҖ1 y).re :=
      congrArg (fun v : Fin 2 вҶ’ в„қ => v 0) hzw'
    have h1 : (рқ’ҹ.ПҖ1 x).im = (рқ’ҹ.ПҖ1 y).im :=
      congrArg (fun v : Fin 2 вҶ’ в„қ => v 1) hzw'
    exact _hinj hx hy (Complex.ext h0 h1)

  have hcoe : (рқ’ҹ.X_finset a R : Set рқ’ҹ.V) = рқ’ҹ.X a R := by
    simp [AdmissibleDatum.X_finset]

  unfold AdmissibleDatum.P_set AdmissibleDatum.N_count
  apply Finset.card_image_of_injOn
  intro x hx y hy hxy
  exact hinj_comp (by simp [AdmissibleDatum.X_finset] at hx; exact hx)
                  (by simp [AdmissibleDatum.X_finset] at hy; exact hy)
                  hxy

theorem complex_ball_packing (n : в„•) (s : Finset (Fin n вҶ’ в„Ӯ)) (R Оҙ : в„қ) : 0 вүӨ R вҶ’ 0 < Оҙ вҶ’ (вҲҖ z вҲҲ s, вҖ–zвҖ– вүӨ R) вҶ’ (вҲҖ x вҲҲ s, вҲҖ y вҲҲ s, x вү  y вҶ’ Оҙ вүӨ dist x y) вҶ’ (s.card : в„қ) вүӨ (2 * R / Оҙ + 1) ^ (2 * n) := by
  intro hR hОҙ hs hsep
  let r : в„қ := Оҙ / 2
  let Ој : MeasureTheory.Measure (Fin n вҶ’ в„Ӯ) := by
    volume_tac
  have hr : 0 < r := by
    dsimp [r]
    linarith
  have hbigr : 0 < R + r := by linarith
  have hpair : Set.PairwiseDisjoint (s : Set (Fin n вҶ’ в„Ӯ)) (fun x => Metric.ball x r) := by
    intro x hx y hy hxy
    apply Metric.ball_disjoint_ball
    dsimp [r]
    have h := hsep x hx y hy hxy
    linarith
  have hsubset : (вӢғ x вҲҲ s, Metric.ball x r) вҠҶ Metric.ball (0 : Fin n вҶ’ в„Ӯ) (R + r) := by
    intro y hy
    simp only [Set.mem_iUnion] at hy вҠў
    rcases hy with вҹЁx, hx, hyвҹ©
    have hxR := hs x hx
    have hyx : dist y x < r := hy
    have hy_norm : вҖ–y - xвҖ– < r := by
      simpa [dist_eq_norm] using hyx
    have hy_lt : вҖ–yвҖ– < R + r := by
      calc
        вҖ–yвҖ– = вҖ–(y - x) + xвҖ– := by
          congr 1
          abel_nf
        _ вүӨ вҖ–y - xвҖ– + вҖ–xвҖ– := norm_add_le _ _
        _ < r + R := add_lt_add_of_lt_of_le hy_norm hxR
        _ = R + r := by ring
    simpa [dist_eq_norm] using hy_lt
  have hsum : вҲ‘ x вҲҲ s, Ој (Metric.ball x r) вүӨ Ој (Metric.ball (0 : Fin n вҶ’ в„Ӯ) (R + r)) := by
    have hmono : Ој (вӢғ x вҲҲ s, Metric.ball x r) вүӨ Ој (Metric.ball (0 : Fin n вҶ’ в„Ӯ) (R + r)) := by
      exact MeasureTheory.measure_mono hsubset
    rw [MeasureTheory.measure_biUnion_finset hpair] at hmono
    В· exact hmono
    В· intro x hx
      exact Metric.isOpen_ball.measurableSet
  have hvol_small : вҲҖ x : Fin n вҶ’ в„Ӯ, Ој (Metric.ball x r) = (ENNReal.ofReal r ^ 2 * NNReal.pi) ^ n := by
    intro x
    simpa [Ој] using (MeasureTheory.volume_pi_ball x hr)
  have hvol_big : Ој (Metric.ball (0 : Fin n вҶ’ в„Ӯ) (R + r)) = (ENNReal.ofReal (R + r) ^ 2 * NNReal.pi) ^ n := by
    simpa [Ој] using (MeasureTheory.volume_pi_ball (0 : Fin n вҶ’ в„Ӯ) hbigr)
  rw [hvol_big] at hsum
  simp [hvol_small] at hsum
  have hcsmall0 : ENNReal.ofReal r ^ 2 * (NNReal.pi : ENNReal) = ENNReal.ofReal (r ^ 2 * Real.pi) := by
    rw [вҶҗ ENNReal.ofReal_pow hr.le, ENNReal.coe_nnreal_eq, NNReal.coe_real_pi, вҶҗ ENNReal.ofReal_mul]
    positivity
  have hcbig0 : ENNReal.ofReal (R + r) ^ 2 * (NNReal.pi : ENNReal) = ENNReal.ofReal ((R + r) ^ 2 * Real.pi) := by
    rw [вҶҗ ENNReal.ofReal_pow (show 0 вүӨ R + r by linarith), ENNReal.coe_nnreal_eq, NNReal.coe_real_pi, вҶҗ ENNReal.ofReal_mul]
    positivity
  have hcsmall : (ENNReal.ofReal r ^ 2 * (NNReal.pi : ENNReal)) ^ n = ENNReal.ofReal ((r ^ 2 * Real.pi) ^ n) := by
    rw [hcsmall0, вҶҗ ENNReal.ofReal_pow]
    positivity
  have hcbig : (ENNReal.ofReal (R + r) ^ 2 * (NNReal.pi : ENNReal)) ^ n = ENNReal.ofReal (((R + r) ^ 2 * Real.pi) ^ n) := by
    rw [hcbig0, вҶҗ ENNReal.ofReal_pow]
    positivity
  rw [hcsmall, hcbig] at hsum
  rw [вҶҗ ENNReal.ofReal_natCast s.card, вҶҗ ENNReal.ofReal_mul (show 0 вүӨ (s.card : в„қ) by positivity)] at hsum
  have hsum' : (s.card : в„қ) * ((r ^ 2 * Real.pi) ^ n) вүӨ (((R + r) ^ 2 * Real.pi) ^ n) := by
    exact (ENNReal.ofReal_le_ofReal_iff (by positivity)).mp hsum
  have hratio : (s.card : в„қ) вүӨ ((((R + r) ^ 2 * Real.pi) / (r ^ 2 * Real.pi)) ^ n) := by
    have hApos : 0 < (r ^ 2 * Real.pi) ^ n := by positivity
    have := (le_div_iffвӮҖ hApos).2 hsum'
    simpa [div_pow] using this
  have hratio' : (s.card : в„қ) вүӨ (((R + r) / r) ^ (2 * n)) := by
    have hdiv : (((R + r) ^ 2 * Real.pi) / (r ^ 2 * Real.pi) : в„қ) = ((R + r) / r) ^ 2 := by
      field_simp [Real.pi_pos.ne', hr.ne']
    rw [hdiv] at hratio
    simpa [pow_mul] using hratio
  have hrw : (R + r) / r = 2 * R / Оҙ + 1 := by
    dsimp [r]
    field_simp [hОҙ.ne']
  simpa [hrw] using hratio'

theorem lattice_nonzero_norm_ge_inv_denom (рқ’ҹ : AdmissibleDatum) {z : рқ’ҹ.V} : z вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) вҶ’ z вү  0 вҶ’ (1 / рқ’ҹ.denom : в„қ) вүӨ вҖ–zвҖ– := by
  intro hz hne
  rcases hz with вҹЁu, вҹЁx, hxвҹ©, rflвҹ©
  have hu : u вү  0 := by
    intro hu0
    apply hne
    ext i
    simp [AdmissibleDatum.ОҰ, hu0]
  have hxK_ne : (x : рқ’ҹ.K) вү  0 := by
    intro hxzero
    have hmul0 : ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) * u = 0 := by
      simpa [hxzero] using hx
    have hQ0 : ((рқ’ҹ.Q : рқ’ҹ.K) ^ 2) вү  0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr (Nat.ne_of_gt рқ’ҹ.Q_pos))
    exact hu ((mul_eq_zero.mp hmul0).resolve_left hQ0)
  have hx_ne : x вү  0 := by
    intro hxzero
    exact hxK_ne (by simpa using hxzero)
  by_contra hlt
  have hlt' : вҖ–рқ’ҹ.ОҰ uвҖ– < (1 / рқ’ҹ.denom : в„қ) := by
    simpa using not_le.mp hlt
  have hsupu : рқ’ҹ.supNorm (рқ’ҹ.ОҰ u) < (1 / рқ’ҹ.denom : в„қ) := by
    simpa [supNorm_eq_norm] using hlt'
  have hcoord_le : вҲҖ i : Fin рқ’ҹ.f, вҖ–adm_Пғ рқ’ҹ i uвҖ– вүӨ рқ’ҹ.supNorm (рқ’ҹ.ОҰ u) := by
    intro i
    unfold AdmissibleDatum.supNorm
    simpa [AdmissibleDatum.ОҰ] using
      (Finset.le_sup' (s := Finset.univ) (f := fun r : Fin рқ’ҹ.f => вҖ–рқ’ҹ.ОҰ u rвҖ–)
        (b := i) (by simp))
  have hcoord : вҲҖ i : Fin рқ’ҹ.f, вҖ–adm_Пғ рқ’ҹ i uвҖ– < (1 / рқ’ҹ.denom : в„қ) := by
    intro i
    exact lt_of_le_of_lt (hcoord_le i) hsupu
  have hmap : вҲҖ i : Fin рқ’ҹ.f, (рқ’ҹ.denom : в„Ӯ) * adm_Пғ рқ’ҹ i u = adm_Пғ рқ’ҹ i (x : рқ’ҹ.K) := by
    intro i
    simpa [AdmissibleDatum.denom, map_mul, map_pow, AdmissibleDatum.Q, mul_assoc, mul_left_comm, mul_comm] using congrArg (adm_Пғ рқ’ҹ i) hx
  have hnorm : вҲҖ i : Fin рқ’ҹ.f, вҖ–adm_Пғ рқ’ҹ i (x : рқ’ҹ.K)вҖ– = (рқ’ҹ.denom : в„қ) * вҖ–adm_Пғ рқ’ҹ i uвҖ– := by
    intro i
    rw [вҶҗ hmap i, norm_mul]
    simp
  have hxcoord : вҲҖ i : Fin рқ’ҹ.f, вҖ–adm_Пғ рқ’ҹ i (x : рқ’ҹ.K)вҖ– < 1 := by
    intro i
    have hdpos : (0 : в„қ) < рқ’ҹ.denom := by exact_mod_cast рқ’ҹ.denom_pos
    have hmul : (рқ’ҹ.denom : в„қ) * вҖ–adm_Пғ рқ’ҹ i uвҖ– < (рқ’ҹ.denom : в„қ) * (1 / рқ’ҹ.denom : в„қ) :=
      mul_lt_mul_of_pos_left (hcoord i) hdpos
    rw [hnorm i]
    have hdenom0 : (рқ’ҹ.denom : в„қ) вү  0 := by exact_mod_cast (Nat.ne_of_gt рқ’ҹ.denom_pos)
    simpa [hdenom0] using hmul
  have hc_sq : вҲҖ x : рқ’ҹ.K, рқ’ҹ.c (рқ’ҹ.c x) = x := by
    have hext : (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K).comp (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K)
        = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
      refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
      intro y hy
      have hy_eq : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
      subst hy_eq
      simp [рқ’ҹ.c_i_K, map_neg]
    intro x
    have hx := AlgHom.congr_fun hext x
    simpa using hx
  have hc_symm : (рқ’ҹ.c).symm = рқ’ҹ.c := by
    ext x
    have := hc_sq ((рқ’ҹ.c).symm x)
    simpa using this.symm
  have haut : вҲҖ Пғ : рқ’ҹ.K вүғвӮҗ[рқ’ҹ.L] рқ’ҹ.K, Пғ = 1 вҲЁ Пғ = рқ’ҹ.c := by
    intro Пғ
    have hПғ_sq : Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K = -1 := by
      have h1 : Пғ (рқ’ҹ.i_K * рқ’ҹ.i_K) = Пғ (-1) := by rw [рқ’ҹ.i_K_sq]
      rw [map_mul, map_neg, map_one] at h1
      exact h1
    have hprod : (Пғ рқ’ҹ.i_K - рқ’ҹ.i_K) * (Пғ рқ’ҹ.i_K + рқ’ҹ.i_K) = 0 := by
      have : (Пғ рқ’ҹ.i_K - рқ’ҹ.i_K) * (Пғ рқ’ҹ.i_K + рқ’ҹ.i_K)
          = Пғ рқ’ҹ.i_K * Пғ рқ’ҹ.i_K - рқ’ҹ.i_K * рқ’ҹ.i_K := by ring
      rw [this, hПғ_sq, рқ’ҹ.i_K_sq, sub_self]
    have hПғ_cases : Пғ рқ’ҹ.i_K = рқ’ҹ.i_K вҲЁ Пғ рқ’ҹ.i_K = -рқ’ҹ.i_K := by
      rcases mul_eq_zero.mp hprod with h | h
      В· exact Or.inl (sub_eq_zero.mp h)
      В· exact Or.inr (eq_neg_of_add_eq_zero_left h)
    rcases hПғ_cases with hid | hc
    В· left
      have hext : (Пғ : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) = AlgHom.id рқ’ҹ.L рқ’ҹ.K := by
        refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
        intro y hy
        have : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
        subst this
        simpa using hid
      ext x
      have := AlgHom.congr_fun hext x
      simpa using this
    В· right
      have hext : (Пғ : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) = (рқ’ҹ.c : рқ’ҹ.K вҶ’вӮҗ[рқ’ҹ.L] рқ’ҹ.K) := by
        refine AlgHom.ext_of_adjoin_eq_top (рқ’ҹ.adjoin_i_K_eq_top) ?_
        intro y hy
        have hy_eq : y = рқ’ҹ.i_K := Set.mem_singleton_iff.mp hy
        subst hy_eq
        change Пғ рқ’ҹ.i_K = рқ’ҹ.c рқ’ҹ.i_K
        rw [hc, рқ’ҹ.c_i_K]
      ext x
      have := AlgHom.congr_fun hext x
      simpa using this
  let restr : Fin рқ’ҹ.f вҶ’ (рқ’ҹ.L вҶ’+* в„Ӯ) := fun i => (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K)
  have hrestr_inj : Function.Injective restr := by
    intro i j hij
    by_contra hneij
    exact рқ’ҹ.adm_Пғ_restrict_distinct i j hneij hij
  have hrestr_bij : Function.Bijective restr := by
    refine (Fintype.bijective_iff_injective_and_card restr).2 ?_
    constructor
    В· exact hrestr_inj
    В· rw [Fintype.card_fin, NumberField.Embeddings.card (K := рқ’ҹ.L) (A := в„Ӯ)]
      rfl
  have hrestr_surj : Function.Surjective restr := hrestr_bij.surjective
  have hall : вҲҖ Пғ : рқ’ҹ.K вҶ’+* в„Ӯ, вҖ–Пғ (x : рқ’ҹ.K)вҖ– < 1 := by
    intro Пғ
    let ПҲ : рқ’ҹ.L вҶ’+* в„Ӯ := Пғ.comp (algebraMap рқ’ҹ.L рқ’ҹ.K)
    obtain вҹЁi, hiвҹ© := hrestr_surj ПҲ
    have hcomp : (adm_Пғ рқ’ҹ i).comp (algebraMap рқ’ҹ.L рқ’ҹ.K) = ПҲ := hi
    obtain вҹЁП„, hП„вҹ© := NumberField.ComplexEmbedding.exists_comp_symm_eq_of_comp_eq
      (adm_Пғ рқ’ҹ i) Пғ (by simpa [ПҲ] using hcomp)
    rcases haut П„ with hП„1 | hП„c
    В· rw [hП„1] at hП„
      have hEq : adm_Пғ рқ’ҹ i = Пғ := by simpa using hП„
      simpa [hEq] using hxcoord i
    В· rw [hП„c] at hП„
      have hEq : (adm_Пғ рқ’ҹ i).comp рқ’ҹ.c = Пғ := by simpa [hc_symm] using hП„
      have hEval : Пғ (x : рқ’ҹ.K) = star ((adm_Пғ рқ’ҹ i) (x : рқ’ҹ.K)) := by
        have hEval' := congrArg (fun ПҶ : рқ’ҹ.K вҶ’+* в„Ӯ => ПҶ (x : рқ’ҹ.K)) hEq
        change (adm_Пғ рқ’ҹ i) (рқ’ҹ.c (x : рқ’ҹ.K)) = Пғ (x : рқ’ҹ.K) at hEval'
        rw [complex_embedding_conjugation_compat рқ’ҹ (adm_Пғ рқ’ҹ i) (x : рқ’ҹ.K)] at hEval'
        simpa using hEval'.symm
      simpa [hEval] using hxcoord i
  have hint : IsIntegral в„Ө (x : рқ’ҹ.K) := NumberField.RingOfIntegers.isIntegral_coe x
  have hle : вҲҖ Пғ : рқ’ҹ.K вҶ’+* в„Ӯ, вҖ–Пғ (x : рқ’ҹ.K)вҖ– вүӨ 1 := by
    intro Пғ
    exact le_of_lt (hall Пғ)
  rcases NumberField.Embeddings.pow_eq_one_of_norm_le_one (K := рқ’ҹ.K) (A := в„Ӯ) hxK_ne hint hle with вҹЁn, hnpos, hpowвҹ©
  have hpow0 := congrArg (adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ©) hpow
  have hx0lt := hxcoord вҹЁ0, рқ’ҹ.f_posвҹ©
  have hpow_eq_one : вҖ–adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ© (x : рқ’ҹ.K)вҖ– ^ n = 1 := by
    have := congrArg (fun z : в„Ӯ => вҖ–zвҖ–) hpow0
    simpa [map_pow, norm_pow] using this
  have hpowlt : вҖ–adm_Пғ рқ’ҹ вҹЁ0, рқ’ҹ.f_posвҹ© (x : рқ’ҹ.K)вҖ– ^ n < 1 := by
    exact pow_lt_oneвӮҖ (norm_nonneg _) hx0lt (Nat.ne_of_gt hnpos)
  rw [hpow_eq_one] at hpowlt
  linarith

theorem X_separated (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ) {x y : рқ’ҹ.V} : x вҲҲ рқ’ҹ.X a R вҶ’ y вҲҲ рқ’ҹ.X a R вҶ’ x вү  y вҶ’ (1 / рқ’ҹ.denom : в„қ) вүӨ dist x y := by
  intro hx hy hxy
  rcases hx with вҹЁhx, _вҹ©
  rcases hy with вҹЁhy, _вҹ©
  rcases hx with вҹЁlвӮҒ, rflвҹ©
  rcases hy with вҹЁlвӮӮ, rflвҹ©
  have hmem : ((lвӮҒ - lвӮӮ : рқ’ҹ.Оӣ) : рқ’ҹ.V) вҲҲ (рқ’ҹ.Оӣ : Set рқ’ҹ.V) := by
    exact (lвӮҒ - lвӮӮ).property
  have hne : ((lвӮҒ - lвӮӮ : рқ’ҹ.Оӣ) : рқ’ҹ.V) вү  0 := by
    intro h
    apply hxy
    have h' : ((lвӮҒ : рқ’ҹ.V) - (lвӮӮ : рқ’ҹ.V)) = 0 := by
      simpa using h
    have heq : (lвӮҒ : рқ’ҹ.V) = (lвӮӮ : рқ’ҹ.V) := sub_eq_zero.mp h'
    simp [heq]
  have hsep := lattice_nonzero_norm_ge_inv_denom рқ’ҹ hmem hne
  simpa [dist_eq_norm] using hsep

theorem lemma_2_6 (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ)
    (hR : 1 / 2 < R) :
    (рқ’ҹ.N_count a R : в„қ) вүӨ (4 * R * рқ’ҹ.denom) ^ (2 * рқ’ҹ.f) := by
  classical
  unfold AdmissibleDatum.N_count
  have hR_nonneg : 0 вүӨ R := by
    linarith
  have hdenom_posR : (0 : в„қ) < рқ’ҹ.denom := by
    exact_mod_cast рқ’ҹ.denom_pos
  have hdelta : 0 < (1 / рқ’ҹ.denom : в„қ) := by
    exact one_div_pos.mpr hdenom_posR
  have hnorm : вҲҖ z вҲҲ рқ’ҹ.X_finset a R, вҖ–zвҖ– вүӨ R := by
    intro z hz
    have hzX : z вҲҲ рқ’ҹ.X a R := by
      simpa [AdmissibleDatum.X_finset] using hz
    have hzB : z вҲҲ рқ’ҹ.closedPolydisc R := hzX.2
    simpa [AdmissibleDatum.closedPolydisc, supNorm_eq_norm] using hzB
  have hsep : вҲҖ x вҲҲ рқ’ҹ.X_finset a R, вҲҖ y вҲҲ рқ’ҹ.X_finset a R, x вү  y вҶ’ (1 / рқ’ҹ.denom : в„қ) вүӨ dist x y := by
    intro x hx y hy hxy
    have hxX : x вҲҲ рқ’ҹ.X a R := by
      simpa [AdmissibleDatum.X_finset] using hx
    have hyX : y вҲҲ рқ’ҹ.X a R := by
      simpa [AdmissibleDatum.X_finset] using hy
    exact X_separated рқ’ҹ a R hxX hyX hxy
  have hpack : ((рқ’ҹ.X_finset a R).card : в„қ) вүӨ (2 * R / (1 / рқ’ҹ.denom : в„қ) + 1) ^ (2 * рқ’ҹ.f) := by
    exact complex_ball_packing рқ’ҹ.f (рқ’ҹ.X_finset a R) R (1 / рқ’ҹ.denom) hR_nonneg hdelta hnorm hsep
  refine le_trans hpack ?_
  have hdenom_ne : (рқ’ҹ.denom : в„қ) вү  0 := ne_of_gt hdenom_posR
  have hbase_eq : 2 * R / (1 / рқ’ҹ.denom : в„қ) + 1 = 2 * R * рқ’ҹ.denom + 1 := by
    field_simp [hdenom_ne]
  rw [hbase_eq]
  have hdenom_ge : (1 : в„қ) вүӨ рқ’ҹ.denom := by
    exact_mod_cast рқ’ҹ.one_le_denom
  have hbase_ge_one : 1 вүӨ 2 * R * рқ’ҹ.denom := by
    nlinarith
  have hbase_nonneg : 0 вүӨ 2 * R * рқ’ҹ.denom + 1 := by
    linarith
  have hbase_le : 2 * R * рқ’ҹ.denom + 1 вүӨ 4 * R * рқ’ҹ.denom := by
    linarith
  exact pow_le_pow_leftвӮҖ hbase_nonneg hbase_le (2 * рқ’ҹ.f)

theorem E_count_le_N_count_sq (рқ’ҹ : AdmissibleDatum) (a : рқ’ҹ.V) (R : в„қ)
    (U : Finset рқ’ҹ.K) :
    рқ’ҹ.E_count a R U вүӨ рқ’ҹ.N_count a R ^ 2 := by
  classical
  unfold AdmissibleDatum.E_count AdmissibleDatum.N_count

  rw [show вҲ‘ u вҲҲ U, ((рқ’ҹ.X_finset a R).filter
        (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R)).card
      = (U.sigma (fun u => (рқ’ҹ.X_finset a R).filter
          (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R))).card from
      (Finset.card_sigma _ _).symm]
  set src := U.sigma (fun u => (рқ’ҹ.X_finset a R).filter
    (fun x => x + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.X_finset a R))
  set tgt := (рқ’ҹ.X_finset a R) Г—Лў (рқ’ҹ.X_finset a R)

  let g : (ОЈ _ : рқ’ҹ.K, рқ’ҹ.V) вҶ’ рқ’ҹ.V Г— рқ’ҹ.V := fun p => (p.2, p.2 + рқ’ҹ.ОҰ p.1)
  have hmap : вҲҖ p вҲҲ src, g p вҲҲ tgt := by
    intro вҹЁu, xвҹ© hp
    simp only [Finset.mem_sigma, Finset.mem_filter, src] at hp
    exact Finset.mem_product.mpr вҹЁhp.2.1, hp.2.2вҹ©
  have hinj : Set.InjOn g src := by
    intro вҹЁu, xвҹ© _ вҹЁv, yвҹ© _ heq
    simp only [g, Prod.mk.injEq] at heq
    obtain вҹЁhxy, hОҰвҹ© := heq
    have huv : рқ’ҹ.ОҰ u = рқ’ҹ.ОҰ v := by
      have : x + рқ’ҹ.ОҰ u = y + рқ’ҹ.ОҰ v := hОҰ
      rw [hxy] at this
      exact add_left_cancel this
    have huv' : u = v := AdmissibleDatum.ОҰ_injective рқ’ҹ huv
    subst hxy; subst huv'; rfl
  calc src.card
      вүӨ tgt.card := Finset.card_le_card_of_injOn g hmap hinj
    _ = (рқ’ҹ.X_finset a R).card * (рқ’ҹ.X_finset a R).card := by
        simp [tgt, Finset.card_product]
    _ = (рқ’ҹ.X_finset a R).card ^ 2 := by ring

theorem ПҒ_tends_to_one (рқ’ҹ : AdmissibleDatum) :
    Filter.Tendsto рқ’ҹ.ПҒ Filter.atTop (nhds 1) := by

  have hA : Filter.Tendsto
      (fun R : в„қ => (2 / Real.pi) * Real.arccos (1 / (2 * R)))
      Filter.atTop (nhds 1) := by
    have h_inv : Filter.Tendsto (fun R : в„қ => 1 / (2 * R)) Filter.atTop (nhds 0) := by
      have h2 : Filter.Tendsto (fun R : в„қ => 2 * R) Filter.atTop Filter.atTop :=
        Filter.Tendsto.const_mul_atTop (by norm_num : (0 : в„қ) < 2) Filter.tendsto_id
      have hinv := h2.inv_tendsto_atTop
      convert hinv using 1
      ext R; rw [one_div, Pi.inv_apply]
    have h_arccos : Filter.Tendsto (fun R : в„қ => Real.arccos (1 / (2 * R)))
        Filter.atTop (nhds (Real.arccos 0)) :=
      Filter.Tendsto.arccos h_inv
    have h_arccos' : Filter.Tendsto (fun R : в„қ => Real.arccos (1 / (2 * R)))
        Filter.atTop (nhds (Real.pi / 2)) := by
      rw [вҶҗ Real.arccos_zero]; exact h_arccos
    have h := h_arccos'.const_mul (2 / Real.pi)
    have hpi : Real.pi вү  0 := Real.pi_pos.ne'
    convert h using 1
    field_simp

  have hB : Filter.Tendsto
      (fun R : в„қ => Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2))
      Filter.atTop (nhds 0) := by

    have h_upper : Filter.Tendsto (fun R : в„қ => 1 / (Real.pi * R)) Filter.atTop (nhds 0) := by
      have hR : Filter.Tendsto (fun R : в„қ => Real.pi * R) Filter.atTop Filter.atTop :=
        Filter.Tendsto.const_mul_atTop Real.pi_pos Filter.tendsto_id
      have hinv := hR.inv_tendsto_atTop
      convert hinv using 1
      ext R; rw [one_div, Pi.inv_apply]
    refine squeeze_zero' (g := fun R => 1 / (Real.pi * R)) ?_ ?_ h_upper
    В· filter_upwards [Filter.eventually_ge_atTop (1/2 : в„қ)] with R hR
      have hRpos : 0 < R := by linarith
      have h4R2 : 0 вүӨ 4 * R ^ 2 - 1 := by nlinarith
      positivity
    В· filter_upwards [Filter.eventually_ge_atTop (1 : в„қ)] with R hR
      have hRpos : 0 < R := by linarith
      have h4R2 : 0 вүӨ 4 * R ^ 2 - 1 := by nlinarith

      have h_sqrt_le : Real.sqrt (4 * R ^ 2 - 1) вүӨ 2 * R := by
        have h_eq : Real.sqrt (4 * R ^ 2) = 2 * R := by
          rw [show (4 * R ^ 2 : в„қ) = (2 * R) ^ 2 by ring,
              Real.sqrt_sq (by linarith)]
        calc Real.sqrt (4 * R ^ 2 - 1) вүӨ Real.sqrt (4 * R ^ 2) :=
              Real.sqrt_le_sqrt (by linarith)
          _ = 2 * R := h_eq
      have hПҖR : 0 < Real.pi * R := mul_pos Real.pi_pos hRpos
      have h2ПҖR2 : 0 < 2 * Real.pi * R ^ 2 := by positivity
      rw [div_le_div_iffвӮҖ h2ПҖR2 hПҖR]
      nlinarith [Real.pi_pos, Real.sqrt_nonneg (4 * R ^ 2 - 1)]

  have h_eq : вҲҖб¶  R in Filter.atTop, рқ’ҹ.ПҒ R =
      (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2) := by
    filter_upwards [Filter.eventually_gt_atTop (1/2 : в„қ)] with R hR
    have hRpos : 0 < R := by linarith
    have hПҖR2 : Real.pi * R ^ 2 вү  0 := by positivity
    have h_overlap : overlapArea R =
        2 * R ^ 2 * Real.arccos (1 / (2 * R)) -
          (1 / 2) * Real.sqrt (4 * R ^ 2 - 1) := by
      unfold overlapArea
      rw [if_neg (not_lt.mpr (le_of_lt hR))]
    unfold AdmissibleDatum.ПҒ AdmissibleDatum.b
    rw [h_overlap]
    field_simp
  have h_sum : Filter.Tendsto
      (fun R : в„қ => (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2))
      Filter.atTop (nhds (1 - 0)) := hA.sub hB
  rw [sub_zero] at h_sum

  have h_eq_sym : (fun R : в„қ =>
      (2 / Real.pi) * Real.arccos (1 / (2 * R)) -
        Real.sqrt (4 * R ^ 2 - 1) / (2 * Real.pi * R ^ 2)) =б¶ [Filter.atTop] рқ’ҹ.ПҒ := by
    filter_upwards [h_eq] with R hR using hR.symm
  exact h_sum.congr' h_eq_sym

theorem theorem_2_3_absorb_factor_two (n A Оҙ : в„қ) (hn : 0 < n) (hОҙpos : 0 < Оҙ)
    (hA : (2 : в„қ) ^ (1 / Оҙ) вүӨ A) (hAn : A вүӨ n) :
    (2 : в„қ) * n ^ (1 + Оҙ) вүӨ n ^ (1 + 2 * Оҙ) := by
  have hОҙnonneg : 0 вүӨ Оҙ := le_of_lt hОҙpos
  have htwo_nonneg : 0 вүӨ (2 : в„қ) ^ (1 / Оҙ) := by
    positivity
  have htwo_le_nОҙ : (2 : в„қ) вүӨ n ^ Оҙ := by
    have h := Real.rpow_le_rpow htwo_nonneg (le_trans hA hAn) hОҙnonneg
    have htwo : ((2 : в„қ) ^ (1 / Оҙ)) ^ Оҙ = (2 : в„қ) := by
      rw [вҶҗ Real.rpow_mul (by positivity : 0 вүӨ (2 : в„қ))]
      have hОҙmul : (1 / Оҙ) * Оҙ = 1 := by
        field_simp [hОҙpos.ne']
      rw [hОҙmul, Real.rpow_one]
    rw [htwo] at h
    exact h
  have hn_pow_nonneg : 0 вүӨ n ^ (1 + Оҙ) := by
    positivity
  have hmul : (2 : в„қ) * n ^ (1 + Оҙ) вүӨ n ^ Оҙ * n ^ (1 + Оҙ) :=
    mul_le_mul_of_nonneg_right htwo_le_nОҙ hn_pow_nonneg
  have hrewrite : n ^ Оҙ * n ^ (1 + Оҙ) = n ^ (1 + 2 * Оҙ) := by
    rw [вҶҗ Real.rpow_add hn Оҙ (1 + Оҙ)]
    have hexp : Оҙ + (1 + Оҙ) = 1 + 2 * Оҙ := by ring
    rw [hexp]
  calc
    (2 : в„қ) * n ^ (1 + Оҙ) вүӨ n ^ Оҙ * n ^ (1 + Оҙ) := hmul
    _ = n ^ (1 + 2 * Оҙ) := hrewrite

theorem theorem_2_3_choose_radius (рқ’ҹ : AdmissibleDatum) (Оі : в„қ) (hОі : 0 < Оі) :
    вҲғ R : в„қ, 1 / 2 < R вҲ§ 0 < рқ’ҹ.ПҒ R вҲ§ -(Оі / 2) < Real.log (рқ’ҹ.ПҒ R) := by
  let hПҒ : Filter.Tendsto рқ’ҹ.ПҒ Filter.atTop (nhds 1) := ПҒ_tends_to_one рқ’ҹ
  have hpos : вҲҖб¶  R : в„қ in Filter.atTop, 0 < рқ’ҹ.ПҒ R := by
    exact hПҒ.eventually (Ioi_mem_nhds (show (0 : в„қ) < 1 by norm_num))
  have hlog : Filter.Tendsto (fun R : в„қ => Real.log (рқ’ҹ.ПҒ R)) Filter.atTop (nhds 0) := by
    simpa using Filter.Tendsto.log hПҒ one_ne_zero
  have hloglb : вҲҖб¶  R : в„қ in Filter.atTop, -(Оі / 2) < Real.log (рқ’ҹ.ПҒ R) := by
    exact hlog.eventually (Ioi_mem_nhds (by nlinarith : -(Оі / 2) < (0 : в„қ)))
  have hgt : вҲҖб¶  R : в„қ in Filter.atTop, 1 / 2 < R := by
    exact Filter.eventually_gt_atTop (1 / 2 : в„қ)
  have hall : вҲҖб¶  R : в„қ in Filter.atTop, 1 / 2 < R вҲ§ 0 < рқ’ҹ.ПҒ R вҲ§ -(Оі / 2) < Real.log (рқ’ҹ.ПҒ R) := by
    filter_upwards [hgt, hpos, hloglb] with R hgtR hposR hlogR
    exact вҹЁhgtR, hposR, hlogRвҹ©
  rw [Filter.eventually_atTop] at hall
  rcases hall with вҹЁR0, hR0вҹ©
  exact вҹЁR0, hR0 R0 le_rflвҹ©

noncomputable def theorem_2_3_denConst (t : в„•) (q : Fin t вҶ’ в„•) : в„қ := ((((вҲҸ b : Fin t, q b) ^ 2 : в„•) : в„қ))

theorem theorem_2_3_denom_eq (t : в„•) (q : Fin t вҶ’ в„•) (рқ’ҹ : в„• вҶ’ AdmissibleDatum)
    (sameT : вҲҖ j, (рқ’ҹ j).t = t)
    (sameQ : вҲҖ j (b : Fin t),
      (рқ’ҹ j).q (Fin.cast (sameT j).symm b) = q b)
    (j : в„•) :
    ((рқ’ҹ j).denom : в„қ) = theorem_2_3_denConst t q := by
  unfold AdmissibleDatum.denom AdmissibleDatum.Q theorem_2_3_denConst
  have hprod : вҲҸ b : Fin ((рқ’ҹ j).t), (рқ’ҹ j).q b = вҲҸ b : Fin t, q b := by
    simpa [sameQ] using
      (Fin.prod_congr' (h := (sameT j).symm) (f := (рқ’ҹ j).q)).symm
  rw [hprod]

theorem theorem_2_3_denConst_one_le (t : в„•) (q : Fin t вҶ’ в„•) (рқ’ҹ : в„• вҶ’ AdmissibleDatum)
    (sameT : вҲҖ j, (рқ’ҹ j).t = t)
    (sameQ : вҲҖ j (b : Fin t),
      (рқ’ҹ j).q (Fin.cast (sameT j).symm b) = q b) :
    1 вүӨ theorem_2_3_denConst t q := by
  have h0 : (1 : в„қ) вүӨ ((рқ’ҹ 0).denom : в„қ) := by
    exact_mod_cast (рқ’ҹ 0).one_le_denom
  rw [theorem_2_3_denom_eq t q рқ’ҹ sameT sameQ 0] at h0
  exact h0

noncomputable def theorem_2_3_gamma (t : в„•) (H : в„қ) : в„қ := (t : в„қ) * Real.log 2 - Real.log H

theorem theorem_2_3_example_bounds (t : в„•) (q : Fin t вҶ’ в„•)
    (рқ’ҹ : в„• вҶ’ AdmissibleDatum)
    (sameT : вҲҖ j, (рқ’ҹ j).t = t)
    (sameQ : вҲҖ j (b : Fin t),
      (рқ’ҹ j).q (Fin.cast (sameT j).symm b) = q b)
    (H : в„қ) (hH : 0 < H)
    (hClass : вҲҖ j, (NumberField.classNumber (рқ’ҹ j).K : в„қ) вүӨ H ^ (рқ’ҹ j).f)
    (R : в„қ) (hR : 1 / 2 < R)
    (hПҒ0_pos : 0 < (рқ’ҹ 0).ПҒ R)
    (hПҒ0 : -(theorem_2_3_gamma t H / 2) < Real.log ((рқ’ҹ 0).ПҒ R))
    (j : в„•) :
    вҲғ n : в„•, 0 < n вҲ§
      Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) вүӨ (n : в„қ) вҲ§
      (n : в„қ) вүӨ (4 * R * theorem_2_3_denConst t q) ^ (2 * (рқ’ҹ j).f) вҲ§
      (2 : в„қ) * (ОҪn n : в„қ) вүҘ
        Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) * n := by
  classical
  have hПҒj_pos : 0 < (рқ’ҹ j).ПҒ R := by
    simpa [AdmissibleDatum.ПҒ, AdmissibleDatum.b] using hПҒ0_pos
  have hПҒj :
      -(((рқ’ҹ j).t * Real.log 2 - Real.log H) / 2) < Real.log ((рқ’ҹ j).ПҒ R) := by
    simpa [theorem_2_3_gamma, sameT j, AdmissibleDatum.ПҒ, AdmissibleDatum.b] using hПҒ0
  rcases proposition_2_2 (рқ’ҹ j) H hH (hClass j) with вҹЁU, hUcard, hUnormвҹ©
  rcases lemma_2_4 (рқ’ҹ j) H hH R hR U hUnorm hUcard hПҒj_pos hПҒj with вҹЁa, hNpos, hEвҹ©
  refine вҹЁ(рқ’ҹ j).N_count a R, hNpos, ?_, ?_, ?_вҹ©
  В· have hnR : 0 < ((рқ’ҹ j).N_count a R : в„қ) := by
      exact_mod_cast hNpos
    have hE' :
        ((рқ’ҹ j).E_count a R U : в„қ) вүҘ
          Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) *
            ((рқ’ҹ j).N_count a R : в„қ) := by
      simpa [theorem_2_3_gamma, sameT j, mul_assoc, mul_left_comm, mul_comm,
        div_eq_mul_inv] using hE
    have hEsqR : ((рқ’ҹ j).E_count a R U : в„қ) вүӨ ((рқ’ҹ j).N_count a R : в„қ) ^ 2 := by
      exact_mod_cast E_count_le_N_count_sq (рқ’ҹ j) a R U
    have hEN :
        Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) *
            ((рқ’ҹ j).N_count a R : в„қ) вүӨ
          ((рқ’ҹ j).N_count a R : в„қ) ^ 2 := by
      linarith
    by_contra hlt
    have hlt' :
        ((рқ’ҹ j).N_count a R : в„қ) < Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) := by
      linarith
    have hsq_lt :
        ((рқ’ҹ j).N_count a R : в„қ) ^ 2 <
          Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) *
            ((рқ’ҹ j).N_count a R : в„қ) := by
      have hmul :
          ((рқ’ҹ j).N_count a R : в„қ) * ((рқ’ҹ j).N_count a R : в„қ) <
            Real.exp ((theorem_2_3_gamma t H / 2) * (рқ’ҹ j).f) *
              ((рқ’ҹ j).N_count a R : в„қ) := by
        exact mul_lt_mul_of_pos_right hlt' hnR
      simpa [pow_two, mul_assoc, mul_left_comm, mul_comm] using hmul
    linarith
  В· have hNle := lemma_2_6 (рқ’ҹ j) a R hR
    rw [theorem_2_3_denom_eq t q рқ’ҹ sameT sameQ j] at hNle
    simpa using hNle
  В· have hОҪ := lemma_2_5 (рқ’ҹ j) U hUnorm a R
    have hcard : ((рқ’ҹ j).P_set a R).card = (рқ’ҹ j).N_count a R :=
      P_set_card_eq_N_count (рқ’ҹ j) a R hОҪ.1
    have hОҪn_nat0 : ОҪ ((рқ’ҹ j).P_set a R) вүӨ ОҪn ((рқ’ҹ j).N_count a R) := by

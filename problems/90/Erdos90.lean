    cochainsMapTrivial_f1_mono_of_surjective (p := p)
      (A := G) (B := G ⧸ N)
      (f := QuotientGroup.mk' N) (hf := QuotientGroup.continuous_mk)
      (hsurj := QuotientGroup.mk'_surjective N)
  haveI : CategoryTheory.Mono (HomologicalComplex.cyclesMap φ 1) := inferInstance
  have hmono_comp : CategoryTheory.Mono
      (CategoryTheory.CategoryStruct.comp (CQ.homologyπ 1) (HomologicalComplex.homologyMap φ 1)) := by
    rw [HomologicalComplex.homologyπ_naturality (φ := φ) (i := 1)]
    infer_instance
  have hmono_homologyMap : CategoryTheory.Mono (HomologicalComplex.homologyMap φ 1) :=
    (CategoryTheory.mono_comp_iff_of_isIso (CQ.homologyπ 1)
      (HomologicalComplex.homologyMap φ 1)).1 hmono_comp
  have hmono_infl : CategoryTheory.Mono (inflation p G N 1) := by
    simpa [inflation, H, φ] using hmono_homologyMap
  letI : CategoryTheory.Mono (inflation p G N 1) := hmono_infl
  have hmono_module : CategoryTheory.Mono
      (((CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p))).map
        (inflation p G N 1))) :=
    CategoryTheory.preserves_mono_of_preservesLimit
      (CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p)))
      (inflation p G N 1)
  simpa using
    (ModuleCat.mono_iff_injective
      (((CategoryTheory.forget₂ (TopModuleCat (ZMod p)) (ModuleCat (ZMod p))).map
        (inflation p G N 1)))).1 hmono_module

theorem isCocycle2_map_one_fst (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (ω : C(G × G, ZMod p))
    (hω : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p G ω)

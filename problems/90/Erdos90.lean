section CochainsMap

variable {G H : Type} [Group G] [Group H]
  [TopologicalSpace G] [TopologicalSpace H]
  [IsTopologicalGroup G] [IsTopologicalGroup H]
  (f : G вҶ’* H) (hf : Continuous f)


      calc
        вҲҸ P : s, (((p : в„қ) ^ (2 : в„•)) ^ encode x P) = вҲҸ P вҲҲ s.attach, (((p : в„қ) ^ (2 : в„•)) ^ m.count P.1) := h1
        _ = вҲҸ P вҲҲ s.attach, (((p : в„қ) ^ m.count P.1) ^ (2 : в„•)) := hmid
        _ = (вҲҸ P вҲҲ s.attach, ((p : в„қ) ^ m.count P.1)) ^ (2 : в„•) := by
          simpa using (Finset.prod_pow s.attach (2 : в„•) (fun P => (p : в„қ) ^ m.count P.1))
        _ = (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) := h2
    have hg_eq : g (encode x) = 1 / (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) := by
      simpa [g, one_div] using congrArg Inv.inv hg_den
    have hsq : (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) вүӨ ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•)) := by
      exact pow_le_pow_leftвӮҖ (by positivity) hprod_le _
    have hprod_pos : 0 < вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P := by
      refine Finset.prod_pos ?_
      intro P hP
      exact pow_pos (by exact_mod_cast hp.pos) _
    have hpos : 0 < (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) := by
      exact pow_pos hprod_pos _
    calc
      weight x = 1 / ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•)) := by rfl
      _ вүӨ 1 / (вҲҸ P вҲҲ s, (p : в„қ) ^ m.count P) ^ (2 : в„•) := by
        exact one_div_le_one_div_of_le hpos hsq
      _ = g (encode x) := by rw [hg_eq]
  have hweight : Summable weight := by
    exact Summable.of_nonneg_of_le hweight_nonneg hpoint hcomp
  have htsum_le_comp : вҲ‘' x : Sigma ОІ, weight x вүӨ вҲ‘' x : Sigma ОІ, g (encode x) := by
    refine Real.tsum_le_of_sum_le hweight_nonneg ?_
    intro u

    (K : Type) [Field K] [NumberField K] : в„қ :=
  (4 / Real.pi) ^ NumberField.InfinitePlace.nrComplexPlaces K *
    (((Module.finrank в„ҡ K).factorial : в„қ) /
      (Module.finrank в„ҡ K : в„қ) ^ Module.finrank в„ҡ K *
      Real.sqrt |(NumberField.discr K : в„қ)|)

noncomputable def dedekindZetaTwoReal
    (K : Type) [Field K] [NumberField K] : в„қ :=
  вҲ‘' n : в„•, (Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = n} : в„қ) /
    (n : в„қ) ^ (2 : в„•)

noncomputable def idealsUpToNormCount
    (K : Type) [Field K] [NumberField K] (x : в„қ) : в„• :=
  Nat.card {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) // Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ x}

theorem classNumber_le_idealsUpToNormCount_minkowskiAuxBound (K : Type) [Field K] [NumberField K] :
    NumberField.classNumber K вүӨ idealsUpToNormCount K (minkowskiAuxBound K) := by
  classical
  letI :
      Finite {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) //
        Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ вҢҲminkowskiAuxBound KвҢүвӮҠ} :=
    (Ideal.finite_setOf_absNorm_leвӮҖ (S := рқ“һ K) вҢҲminkowskiAuxBound KвҢүвӮҠ).to_subtype
  let g :
      {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) //
        Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ minkowskiAuxBound K} вҶ’
      {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) //
        Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ вҢҲminkowskiAuxBound KвҢүвӮҠ} :=
    fun I => вҹЁI.1, by
      have h' : ((Ideal.absNorm (I.1 : Ideal (рқ“һ K))) : в„қ) вүӨ (вҢҲminkowskiAuxBound KвҢүвӮҠ : в„қ) := by
        exact le_trans I.2 (Nat.le_ceil _)
      exact_mod_cast h'вҹ©
  letI :
      Finite {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) //
        Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ minkowskiAuxBound K} :=
    Finite.of_injective g (by
      intro I J h
      exact Subtype.ext (congrArg (fun x => x.1) h))
  let f :
      {I : вҶҘ(nonZeroDivisors (Ideal (рқ“һ K))) //
        Ideal.absNorm (I : Ideal (рқ“һ K)) вүӨ minkowskiAuxBound K} вҶ’
      ClassGroup (рқ“һ K) := fun I => ClassGroup.mk0 I.1
  have hf : Function.Surjective f := by
    intro C
    rcases NumberField.exists_ideal_in_class_of_norm_le (K := K) C with вҹЁI, hIC, hInormвҹ©
    refine вҹЁвҹЁI, ?_вҹ©, ?_вҹ©
    В· simpa [minkowskiAuxBound] using hInorm
    В· simpa [f] using hIC
  simpa [NumberField.classNumber, idealsUpToNormCount] using Nat.card_le_card_of_surjective f hf

theorem idealsUpToNormCount_eq_floor (K : Type) [Field K] [NumberField K] (x : в„қ) (hx : 0 вүӨ x) :
    idealsUpToNormCount K x = idealsUpToNormCount K (вҢҠxвҢӢвӮҠ : в„қ) := by
  unfold idealsUpToNormCount
  refine Nat.card_congr ?_
  refine Equiv.subtypeEquivRight ?_
  intro I
  constructor
  В· intro hI
    exact_mod_cast (Nat.le_floor hI)
  В· intro hI
    exact le_trans hI (Nat.floor_le hx)

theorem idealsUpToNormCount_nat_eq_sum_normFibers (K : Type) [Field K] [NumberField K] (n : в„•) :
    idealsUpToNormCount K (n : в„қ) =
      вҲ‘ k вҲҲ Finset.Icc 1 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k} := by
  classical
  have h_zero : Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = 0} = 1 := by
    simp [Ideal.absNorm_eq_zero_iff]
  rw [вҶҗ add_left_inj 1]
  calc
    idealsUpToNormCount K (n : в„қ) + 1
        = Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I вүӨ n} := by
            simpa [idealsUpToNormCount] using
              (Ideal.card_norm_le_eq_card_norm_le_add_one (S := рқ“һ K) n).symm
    _ = Nat.card вҶ‘((fun I : Ideal (рқ“һ K) => Ideal.absNorm I) вҒ»В№' (вҶ‘(Finset.Icc 0 n) : Set в„•)) := by
            simp [Set.coe_eq_subtype, Finset.mem_Icc]
    _ = вҲ‘ k вҲҲ Finset.Icc 0 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k} := by
            rw [Finset.card_preimage_eq_sum_card_image_eq
              (f := fun I : Ideal (рқ“һ K) => Ideal.absNorm I)
              (s := Finset.Icc 0 n)
              (fun k _ => Ideal.finite_setOf_absNorm_eq (S := рқ“һ K) k)]
    _ = Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = 0} +
          вҲ‘ k вҲҲ Finset.Ioc 0 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k} := by
            rw [вҶҗ Finset.sum_Ioc_add_eq_sum_Icc (a := 0) (b := n)
              (f := fun k => Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k}) n.zero_le,
              Nat.add_comm]
    _ = 1 + вҲ‘ k вҲҲ Finset.Ioc 0 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k} := by
            rw [h_zero]
    _ = 1 + вҲ‘ k вҲҲ Finset.Icc 1 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k} := by
            rw [вҶҗ Finset.Icc_succ_left_eq_Ioc (a := 0) (b := n)]
            simp
    _ = (вҲ‘ k вҲҲ Finset.Icc 1 n, Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = k}) + 1 := by
            rw [Nat.add_comm]

theorem idealsUpToNormCount_le_dedekindZetaTwoReal_mul_sq (K : Type) [Field K] [NumberField K] (x : в„қ) (hx : 0 вүӨ x) :
    (idealsUpToNormCount K x : в„қ) вүӨ dedekindZetaTwoReal K * x ^ (2 : в„•) := by
  classical
  let a : в„• вҶ’ в„қ := fun n вҶҰ Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = n}
  let N : в„• := вҢҠxвҢӢвӮҠ
  have hcount_sum :
      (idealsUpToNormCount K x : в„қ) = вҲ‘ k вҲҲ Finset.Icc 1 N, a k := by
    rw [show idealsUpToNormCount K x = idealsUpToNormCount K (N : в„қ) by
      simpa [N] using idealsUpToNormCount_eq_floor K x hx]
    rw [idealsUpToNormCount_nat_eq_sum_normFibers]
    simp [a]
  have hBigO :
      (fun n вҶҰ вҲ‘ k вҲҲ Finset.Icc 1 n, a k) =O[Filter.atTop] fun n вҶҰ (n : в„қ) ^ (1 : в„қ) := by
    apply Asymptotics.isBigO_atTop_natCast_rpow_of_tendsto_div_rpow
    refine ((NumberField.Ideal.tendsto_norm_le_div_atTopвӮҖ K).comp tendsto_natCast_atTop_atTop).congr
      (fun n вҶҰ ?_)
    change (idealsUpToNormCount K (n : в„қ) : в„қ) / (n : в„қ) =
      (вҲ‘ k вҲҲ Finset.Icc 1 n, a k) / ((n : в„қ) ^ (1 : в„қ))
    rw [idealsUpToNormCount_nat_eq_sum_normFibers]
    simp [a, Real.rpow_natCast]
  have hL : LSeriesSummable (fun n вҶҰ a n) (((3 : в„қ) / 2 : в„қ) : в„Ӯ) := by
    refine LSeriesSummable_of_sum_norm_bigO_and_nonneg hBigO (fun n вҶҰ ?_) ?_ ?_
    В· exact Nat.cast_nonneg _
    В· norm_num
    В· norm_num
  have habs : LSeries.abscissaOfAbsConv (fun n вҶҰ (a n : в„Ӯ)) вүӨ (3 : в„қ) / 2 :=
    hL.abscissaOfAbsConv_le
  have hsumm : Summable (fun n : в„• вҶҰ a n / (n : в„қ) ^ (2 : в„•)) := by
    have hsumm' : Summable (fun n : в„• вҶҰ a n / (n : в„қ) ^ (2 : в„қ)) := by
      refine LSeries.summable_real_of_abscissaOfAbsConv_lt ?_
      exact lt_of_le_of_lt habs (by
        norm_num : (((3 : в„қ) / 2 : в„қ) : EReal) < ((2 : в„қ) : EReal))
    simpa [Real.rpow_natCast] using hsumm'
  let g : в„• вҶ’ в„қ := fun n вҶҰ a n / (n : в„қ) ^ (2 : в„•)
  have hg_nonneg : вҲҖ n, 0 вүӨ g n := by
    intro n
    exact div_nonneg (Nat.cast_nonneg _) (by positivity)
  have hsum_tsum :
      вҲ‘ k вҲҲ Finset.Icc 1 N, g k вүӨ вҲ‘' n : в„•, g n := by
    have htsum_nonneg : 0 вүӨ вҲ‘' n : в„•, g n := by
      exact tsum_nonneg hg_nonneg
    refine (ENNReal.ofReal_le_ofReal_iff htsum_nonneg).mp ?_
    rw [ENNReal.ofReal_sum_of_nonneg (fun k hk вҶҰ hg_nonneg k)]
    rw [ENNReal.ofReal_tsum_of_nonneg hg_nonneg (by simpa [g] using hsumm)]
    simpa using ENNReal.sum_le_tsum (s := Finset.Icc 1 N) (f := fun n вҶҰ ENNReal.ofReal (g n))
  have hterm :
      вҲҖ k вҲҲ Finset.Icc 1 N, a k вүӨ x ^ (2 : в„•) * g k := by
    intro k hk
    rcases Finset.mem_Icc.mp hk with вҹЁhk1, hkNвҹ©
    have hkpos : 0 < (k : в„қ) := by
      exact_mod_cast hk1
    have hkx : (k : в„қ) вүӨ x := by
      have hkN' : (k : в„қ) вүӨ N := by
        exact_mod_cast hkN
      exact hkN'.trans (by simpa [N] using (Nat.floor_le hx))
    have hsq : (k : в„қ) ^ (2 : в„•) вүӨ x ^ (2 : в„•) := by
      nlinarith
    have hratio : (1 : в„қ) вүӨ x ^ (2 : в„•) / (k : в„қ) ^ (2 : в„•) := by
      have hk_sq_pos : 0 < (k : в„қ) ^ (2 : в„•) := by
        positivity
      exact (le_div_iffвӮҖ hk_sq_pos).2 (by simpa using hsq)
    calc
      a k = a k * 1 := by ring
      _ вүӨ a k * (x ^ (2 : в„•) / (k : в„қ) ^ (2 : в„•)) := by
        gcongr
      _ = x ^ (2 : в„•) * g k := by
        simp [g]
        ring
  have hx2_nonneg : 0 вүӨ x ^ (2 : в„•) := by
    positivity
  calc
    (idealsUpToNormCount K x : в„қ) = вҲ‘ k вҲҲ Finset.Icc 1 N, a k := hcount_sum
    _ вүӨ вҲ‘ k вҲҲ Finset.Icc 1 N, x ^ (2 : в„•) * g k := by
      exact Finset.sum_le_sum fun k hk вҶҰ hterm k hk
    _ = x ^ (2 : в„•) * вҲ‘ k вҲҲ Finset.Icc 1 N, g k := by
      rw [Finset.mul_sum]
    _ вүӨ x ^ (2 : в„•) * вҲ‘' n : в„•, g n := by
      exact mul_le_mul_of_nonneg_left hsum_tsum hx2_nonneg
    _ = dedekindZetaTwoReal K * x ^ (2 : в„•) := by
      rw [dedekindZetaTwoReal, mul_comm]

noncomputable def dedekindZetaTwoAF
    (K : Type) [Field K] [NumberField K] : ArithmeticFunction в„қ :=
  вҹЁfun n вҶҰ (Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = n} : в„қ) /
      (n : в„қ) ^ (2 : в„•), by
    simp [Ideal.absNorm_eq_zero_iff]вҹ©

theorem dedekindZetaTwoAF_summable (K : Type) [Field K] [NumberField K] :
    Summable (fun n : в„• => dedekindZetaTwoAF K n) := by
  let a : в„• вҶ’ в„қ := fun n вҶҰ Nat.card {I : Ideal (рқ“һ K) // Ideal.absNorm I = n}
  let c : в„қ :=
    (2 ^ nrRealPlaces K * (2 * Real.pi) ^ nrComplexPlaces K * NumberField.Units.regulator K *
        NumberField.classNumber K) /
      (NumberField.Units.torsionOrder K * Real.sqrt |NumberField.discr K|)
  have hlimвӮҒ :
      Filter.Tendsto ((fun s : в„қ вҶҰ (idealsUpToNormCount K s : в„қ) / s) вҲҳ Nat.cast)
        Filter.atTop (nhds c) := by
    simpa [c, idealsUpToNormCount] using
      (NumberField.Ideal.tendsto_norm_le_div_atTopвӮҖ K).comp tendsto_natCast_atTop_atTop
  have hlimвӮҒ' :
      Filter.Tendsto (fun n : в„• вҶҰ (idealsUpToNormCount K (n : в„қ) : в„қ) / (n : в„қ))
        Filter.atTop (nhds c) := by
    simpa [Function.comp] using hlimвӮҒ
  have hEq :
      (fun n : в„• вҶҰ (idealsUpToNormCount K (n : в„қ) : в„қ) / (n : в„қ)) =
        fun n : в„• вҶҰ (вҲ‘ k вҲҲ Finset.Icc 1 n, a k) / (n : в„қ) := by
    funext n
    rw [idealsUpToNormCount_nat_eq_sum_normFibers]
    simp [a]
  have hlimвӮӮ :
      Filter.Tendsto (fun n : в„• вҶҰ (вҲ‘ k вҲҲ Finset.Icc 1 n, a k) / (n : в„қ))
        Filter.atTop (nhds c) := by
    rw [вҶҗ hEq]
    exact hlimвӮҒ'
  have hBigO :
      (fun n : в„• вҶҰ вҲ‘ k вҲҲ Finset.Icc 1 n, a k) =O[Filter.atTop] fun n вҶҰ (n : в„қ) ^ (1 : в„қ) := by
    exact Asymptotics.isBigO_atTop_natCast_rpow_of_tendsto_div_rpow <| by
      simpa [Real.rpow_natCast] using hlimвӮӮ
  have hnonneg : вҲҖ n : в„•, 0 вүӨ a n := fun n вҶҰ Nat.cast_nonneg _
  have hL : LSeriesSummable (fun n вҶҰ a n) ((((3 : в„қ) / 2 : в„қ) : в„Ӯ)) := by
    refine LSeriesSummable_of_sum_norm_bigO_and_nonneg hBigO hnonneg ?_ ?_
    В· norm_num
    В· norm_num
  have hsumm' : Summable (fun n : в„• вҶҰ a n / (n : в„қ) ^ (2 : в„қ)) := by
    refine LSeries.summable_real_of_abscissaOfAbsConv_lt ?_
    exact lt_of_le_of_lt hL.abscissaOfAbsConv_le (by norm_num)
  have hsumm : Summable (fun n : в„• вҶҰ a n / (n : в„қ) ^ (2 : в„•)) := by
    simpa [Real.rpow_natCast] using hsumm'
  simpa [dedekindZetaTwoAF, a] using hsumm

theorem ideal_normFiber_mul_equiv (K : Type) [Field K] [NumberField K] (m n : в„•) (hcop : m.Coprime n) :
    Nonempty ({I : Ideal (рқ“һ K) // Ideal.absNorm I = m * n} вүғ
      ({J : Ideal (рқ“һ K) // Ideal.absNorm J = m} Г—
        {L : Ideal (рқ“һ K) // Ideal.absNorm L = n})) := by
  classical
  by_cases hm0 : m = 0
  В· have hn1 : n = 1 := by
      simpa [hm0] using hcop
    subst hm0
    subst hn1
    let F : {I : Ideal (рқ“һ K) // Ideal.absNorm I = 0 * 1} вҶ’
        ({J : Ideal (рқ“һ K) // Ideal.absNorm J = 0} Г— {L : Ideal (рқ“һ K) // Ideal.absNorm L = 1}) :=
      fun I => вҹЁвҹЁI.1, by simpa using I.2вҹ©, вҹЁвҠӨ, by simpвҹ©вҹ©
    let G : ({J : Ideal (рқ“һ K) // Ideal.absNorm J = 0} Г— {L : Ideal (рқ“һ K) // Ideal.absNorm L = 1}) вҶ’
        {I : Ideal (рқ“һ K) // Ideal.absNorm I = 0 * 1} :=
      fun JL => вҹЁJL.1.1, by simpa using JL.1.2вҹ©
    have hFG : Function.LeftInverse G F := by
      intro I
      apply Subtype.ext
      rfl
    have hGF : Function.RightInverse G F := by
      rintro вҹЁJ, Lвҹ©
      apply Prod.ext
      В· apply Subtype.ext
        rfl
      В· apply Subtype.ext
        exact (Ideal.absNorm_eq_one_iff.mp L.2).symm
    exact вҹЁвҹЁF, G, hFG, hGFвҹ©вҹ©
  В· by_cases hn0 : n = 0
    В· have hm1 : m = 1 := by
        simpa [hn0] using hcop
      subst hn0
      subst hm1
      let F : {I : Ideal (рқ“һ K) // Ideal.absNorm I = 1 * 0} вҶ’
          ({J : Ideal (рқ“һ K) // Ideal.absNorm J = 1} Г— {L : Ideal (рқ“һ K) // Ideal.absNorm L = 0}) :=
        fun I => вҹЁвҹЁвҠӨ, by simpвҹ©, вҹЁI.1, by simpa using I.2вҹ©вҹ©
      let G : ({J : Ideal (рқ“һ K) // Ideal.absNorm J = 1} Г— {L : Ideal (рқ“һ K) // Ideal.absNorm L = 0}) вҶ’
          {I : Ideal (рқ“һ K) // Ideal.absNorm I = 1 * 0} :=
        fun JL => вҹЁJL.2.1, by simpa using JL.2.2вҹ©
      have hFG : Function.LeftInverse G F := by
        intro I
        apply Subtype.ext
        rfl
      have hGF : Function.RightInverse G F := by
        rintro вҹЁJ, Lвҹ©
        apply Prod.ext
        В· apply Subtype.ext
          exact (Ideal.absNorm_eq_one_iff.mp J.2).symm
        В· apply Subtype.ext
          rfl
      exact вҹЁвҹЁF, G, hFG, hGFвҹ©вҹ©
    В· have helper {A : Ideal (рқ“һ K)} (hA0 : Ideal.absNorm A вү  0) {t u : в„•}
          (ht : (t : рқ“һ K) вҲҲ A) (hcop_tu : t.Coprime u) : (Ideal.absNorm A).Coprime u := by
          have hAfinite : Finite ((рқ“һ K) в§ё A) := (Ideal.absNorm_ne_zero_iff A).mp hA0
          let _ : Fintype ((рқ“һ K) в§ё A) := Fintype.ofFinite ((рқ“һ K) в§ё A)
          refine Nat.coprime_of_dvd fun p hp hpA hpU => ?_
          obtain вҹЁx, hxordвҹ© := by
            let _ : Fact p.Prime := вҹЁhpвҹ©
            simpa [Nat.card_eq_fintype_card, Ideal.absNorm_apply] using
              (exists_prime_addOrderOf_dvd_card' (G := (рқ“һ K) в§ё A) p hpA)
          rcases (Nat.Coprime.cast (R := рқ“һ K) hcop_tu) with вҹЁa, b, habвҹ©
          have ht0 : Ideal.Quotient.mk A (t : рқ“һ K) = 0 := Ideal.Quotient.eq_zero_iff_mem.mpr ht
          have hu_inv : Ideal.Quotient.mk A b * (u : (рқ“һ K в§ё A)) = 1 := by
            have hbez := congrArg (Ideal.Quotient.mk A) hab
            simpa [map_add, map_mul, ht0, mul_assoc, mul_comm, mul_left_comm] using hbez
          have hu_zero : u вҖў x = 0 := by
            rw [вҶҗ addOrderOf_dvd_iff_nsmul_eq_zero, hxord]
            exact hpU
          have hx_zero : x = 0 := by
            have hux : (u : (рқ“һ K в§ё A)) * x = 0 := by
              simpa [nsmul_eq_mul] using hu_zero
            have h1 := congrArg (fun z => Ideal.Quotient.mk A b * z) hux
            have h2 : ((Ideal.Quotient.mk A b * (u : (рқ“һ K в§ё A))) * x) = 0 := by
              simpa [mul_assoc] using h1
            have h3 : (1 : (рқ“һ K в§ё A)) * x = 0 := by simpa [hu_inv] using h2
            simpa using h3
          have : p = 1 := by
            simpa [hx_zero] using hxord.symm
          exact hp.ne_one this
      let M : Ideal (рқ“һ K) := Ideal.span ({(m : рқ“һ K)} : Set (рқ“һ K))
      let N : Ideal (рқ“һ K) := Ideal.span ({(n : рқ“һ K)} : Set (рқ“һ K))
      have hMNcop : IsCoprime M N := by
        rw [Ideal.isCoprime_iff_exists]
        rcases (Nat.Coprime.cast (R := рқ“һ K) hcop) with вҹЁa, b, habвҹ©
        refine вҹЁa * m, ?_, b * n, ?_, ?_вҹ©
        В· exact Ideal.mul_mem_left _ _ (Ideal.subset_span (by simp))
        В· exact Ideal.mul_mem_left _ _ (Ideal.subset_span (by simp))
        В· simpa [mul_assoc, mul_comm, mul_left_comm] using hab
      let F : {I : Ideal (рқ“һ K) // Ideal.absNorm I = m * n} вҶ’
          ({J : Ideal (рқ“һ K) // Ideal.absNorm J = m} Г—
            {L : Ideal (рқ“һ K) // Ideal.absNorm L = n}) := fun I => by
        let I0 : Ideal (рқ“һ K) := I.1
        let J : Ideal (рқ“һ K) := I0 вҠ” M
        let L : Ideal (рқ“һ K) := I0 вҠ” N
        have hMNtop : M вҠ” N = вҠӨ := hMNcop.sup_eq
        have hsup : J вҠ” L = вҠӨ := by
          calc
            J вҠ” L = I0 вҠ” (M вҠ” N) := by

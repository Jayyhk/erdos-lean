      Module.finrank в„ҡ рқ’ҹ.K = Module.finrank в„ҡ рқ’ҹ.L * Module.finrank рқ’ҹ.L рқ’ҹ.K := by
        symm
        exact Module.finrank_mul_finrank в„ҡ рқ’ҹ.L рқ’ҹ.K
      _ = AdmissibleDatum.f рқ’ҹ * 2 := by
        rw [AdmissibleDatum.f, Algebra.IsQuadraticExtension.finrank_eq_two рқ’ҹ.L рқ’ҹ.K]
      _ = 2 * AdmissibleDatum.f рқ’ҹ := by ring
  have hrank : Module.finrank в„Ө A = 2 * AdmissibleDatum.f рқ’ҹ := by
    rw [hrank0, hfinrankK]
  have hnorm2Q : ((Algebra.norm в„Ө (2 : A) : в„Ө) : в„ҡ) = ((2 : в„ҡ) ^ (2 * AdmissibleDatum.f рқ’ҹ)) := by
    calc
      ((Algebra.norm в„Ө (2 : A) : в„Ө) : в„ҡ) = algebraMap в„Ө в„ҡ (Algebra.intNorm в„Ө A (2 : A)) := by
        rw [Algebra.intNorm_eq_norm]
        rfl
      _ = Algebra.norm в„ҡ (((2 : A) : рқ’ҹ.K)) := by
        simpa [A] using (Algebra.algebraMap_intNorm (A := в„Ө) (K := в„ҡ) (L := рқ’ҹ.K) (B := A) (x := (2 : A)))
      _ = Algebra.norm в„ҡ (2 : рқ’ҹ.K) := by rfl
      _ = (2 : в„ҡ) ^ Module.finrank в„ҡ рқ’ҹ.K := by
        simpa using (Algebra.norm_algebraMap (K := в„ҡ) (L := рқ’ҹ.K) (x := (2 : в„ҡ)))
      _ = ((2 : в„ҡ) ^ (2 * AdmissibleDatum.f рқ’ҹ)) := by rw [hfinrankK]
  have hnorm2 : Algebra.norm в„Ө (2 : A) = (2 : в„Ө) ^ (2 * AdmissibleDatum.f рқ’ҹ) := by
    apply Int.cast_injective (Оұ := в„ҡ)
    calc
      ((Algebra.norm в„Ө (2 : A) : в„Ө) : в„ҡ) = (2 : в„ҡ) ^ (2 * AdmissibleDatum.f рқ’ҹ) := hnorm2Q
      _ = (((2 : в„Ө) ^ (2 * AdmissibleDatum.f рқ’ҹ) : в„Ө) : в„ҡ) := by norm_num
  have hspan_norm : Ideal.absNorm (Ideal.span ({(2 : A)} : Set A)) = 4 ^ AdmissibleDatum.f рқ’ҹ := by
    rw [Ideal.absNorm_span_singleton, hnorm2]
    norm_num [pow_mul]
  have hdiv' : Ideal.absNorm I вҲЈ 4 ^ AdmissibleDatum.f рқ’ҹ := by
    rw [hspan_eq, hspan_norm] at hdiv
    exact hdiv
  exact Nat.le_of_dvd (by positivity) hdiv'

theorem admissibleDatum_natAbs_discr_K_le_four_pow_f_mul_natAbs_discr_L_sq (рқ’ҹ : AdmissibleDatum) :
  (NumberField.discr рқ’ҹ.K).natAbs вүӨ
    4 ^ (AdmissibleDatum.f рқ’ҹ) * (NumberField.discr рқ’ҹ.L).natAbs ^ 2 := by
  let D := Ideal.absNorm
    (differentIdeal (NumberField.RingOfIntegers рқ’ҹ.L) (NumberField.RingOfIntegers рқ’ҹ.K))
  have hD : D вүӨ 4 ^ (AdmissibleDatum.f рқ’ҹ) := by
    simpa [D] using admissibleDatum_differentIdeal_absNorm_le_four_pow_f рқ’ҹ
  have hdisc_nat : (NumberField.discr рқ’ҹ.K).natAbs =
      D * (NumberField.discr рқ’ҹ.L).natAbs ^ 2 := by
    simpa [D, Algebra.IsQuadraticExtension.finrank_eq_two рқ’ҹ.L рқ’ҹ.K] using
      (NumberField.natAbs_discr_eq_absNorm_differentIdeal_mul_natAbs_discr_pow
        рқ’ҹ.L (NumberField.RingOfIntegers рқ’ҹ.L) рқ’ҹ.K (NumberField.RingOfIntegers рқ’ҹ.K))
  calc
    (NumberField.discr рқ’ҹ.K).natAbs = D * (NumberField.discr рқ’ҹ.L).natAbs ^ 2 := hdisc_nat
    _ вүӨ 4 ^ (AdmissibleDatum.f рқ’ҹ) * (NumberField.discr рқ’ҹ.L).natAbs ^ 2 :=
      Nat.mul_le_mul_right ((NumberField.discr рқ’ҹ.L).natAbs ^ 2) hD

theorem rootDiscr_adjoin_i_bound (рқ’ҹ : AdmissibleDatum) :
  NumberField.rootDiscr рқ’ҹ.K вүӨ 2 * NumberField.rootDiscr рқ’ҹ.L := by
  have hdisc : ((NumberField.discr рқ’ҹ.K).natAbs : в„қ) вүӨ (4 : в„қ) ^ (AdmissibleDatum.f рқ’ҹ) *
      ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ 2 := by
    exact_mod_cast admissibleDatum_natAbs_discr_K_le_four_pow_f_mul_natAbs_discr_L_sq рқ’ҹ
  let n : в„• := 2 * AdmissibleDatum.f рқ’ҹ
  have hfinrankK' := by
    letI : Algebra в„ҡ рқ’ҹ.K := DivisionRing.toRatAlgebra
    show ((Module.finrank в„ҡ рқ’ҹ.K : в„•) : в„қ) = (n : в„қ)
    exact_mod_cast admissibleDatum_finrankK_eq_two_mul_f_anyAlg (рқ’ҹ := рқ’ҹ)
  have hfinrankK_inv := by
    letI : Algebra в„ҡ рқ’ҹ.K := DivisionRing.toRatAlgebra
    show (((Module.finrank в„ҡ рқ’ҹ.K : в„•) : в„қ)вҒ»В№) = ((n : в„қ)вҒ»В№)
    simpa using congrArg Inv.inv hfinrankK'
  have hrootK : NumberField.rootDiscr рқ’ҹ.K = ((NumberField.discr рқ’ҹ.K).natAbs : в„қ) ^ ((n : в„қ)вҒ»В№) := by
    rw [NumberField.rootDiscr_def, вҶҗ Nat.cast_natAbs]
    exact congrArg (fun t : в„қ => ((NumberField.discr рқ’ҹ.K).natAbs : в„қ) ^ t) hfinrankK_inv
  have hrootL : NumberField.rootDiscr рқ’ҹ.L =
      ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ ((AdmissibleDatum.f рқ’ҹ : в„қ)вҒ»В№) := by
    rw [NumberField.rootDiscr_def, AdmissibleDatum.f, вҶҗ Nat.cast_natAbs]
  have hn : n вү  0 := by
    dsimp [n]
    exact Nat.mul_ne_zero (by decide) (Nat.ne_of_gt рқ’ҹ.f_pos)
  have hexp_nonneg : 0 вүӨ ((n : в„қ)вҒ»В№) := by
    positivity
  have hpow := Real.rpow_le_rpow (by positivity) hdisc hexp_nonneg
  have hpow4 : (4 : в„қ) ^ (AdmissibleDatum.f рқ’ҹ) = (2 : в„қ) ^ n := by
    dsimp [n]
    rw [pow_mul]
    norm_num
  have hfour : ((4 : в„қ) ^ (AdmissibleDatum.f рқ’ҹ)) ^ ((n : в„қ)вҒ»В№) = 2 := by
    rw [hpow4]
    exact Real.pow_rpow_inv_natCast (by positivity) hn
  have hf_ne : (AdmissibleDatum.f рқ’ҹ : в„қ) вү  0 := by
    exact_mod_cast (Nat.ne_of_gt рқ’ҹ.f_pos)
  have hn_cast : (n : в„қ) = 2 * (AdmissibleDatum.f рқ’ҹ : в„қ) := by
    dsimp [n]
    norm_num [Nat.cast_mul]
  have hLfactor : ((((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ 2) ^ ((n : в„қ)вҒ»В№)) =
      ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ ((AdmissibleDatum.f рқ’ҹ : в„қ)вҒ»В№) := by
    rw [вҶҗ Real.rpow_natCast_mul
      (show 0 вүӨ ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) by positivity) 2 ((n : в„қ)вҒ»В№)]
    have hmul : (2 : в„қ) * ((n : в„қ)вҒ»В№) = (AdmissibleDatum.f рқ’ҹ : в„қ)вҒ»В№ := by
      rw [hn_cast]
      field_simp [hf_ne]
    simpa using congrArg (fun t : в„қ => ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ t) hmul
  calc
    NumberField.rootDiscr рқ’ҹ.K = ((NumberField.discr рқ’ҹ.K).natAbs : в„қ) ^ ((n : в„қ)вҒ»В№) := hrootK
    _ вүӨ ((4 : в„қ) ^ (AdmissibleDatum.f рқ’ҹ) * ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ 2) ^ ((n : в„қ)вҒ»В№) := hpow
    _ = ((4 : в„қ) ^ (AdmissibleDatum.f рқ’ҹ)) ^ ((n : в„қ)вҒ»В№) *
          ((((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ 2) ^ ((n : в„қ)вҒ»В№)) := by
          rw [Real.mul_rpow (by positivity) (by positivity)]
    _ = 2 * ((NumberField.discr рқ’ҹ.L).natAbs : в„қ) ^ ((AdmissibleDatum.f рқ’ҹ : в„қ)вҒ»В№) := by
          rw [hfour, hLfactor]
    _ = 2 * NumberField.rootDiscr рқ’ҹ.L := by rw [hrootL]


          exact Ideal.absNorm_eq_one_iff.mp (Nat.dvd_one.mp hdiv1)
        have hJM : (J0 * L0) вҠ” M = J0 := by
          calc
            (J0 * L0) вҠ” M = M вҠ” J0 * L0 := by rw [sup_comm]
            _ = M вҠ” J0 := by
              simpa [Ideal.mul_comm] using (Ideal.sup_mul_eq_of_coprime_right (I := M) (J := J0) (K := L0) (by simpa [sup_comm] using hLMtop))
            _ = J0 := sup_eq_right.mpr hMleJ0
        have hLN : (J0 * L0) вҠ” N = L0 := by
          calc
            (J0 * L0) вҠ” N = N вҠ” J0 * L0 := by rw [sup_comm]
            _ = N вҠ” L0 := by
              simpa [Ideal.mul_comm] using (Ideal.sup_mul_eq_of_coprime_left (I := N) (J := J0) (K := L0) (by simpa [sup_comm] using hJNtop))
            _ = L0 := sup_eq_right.mpr hNleL0
        apply Prod.ext
        В· apply Subtype.ext
          simpa [F, G, M, N] using hJM
        В· apply Subtype.ext
          simpa [F, G, M, N] using hLN
      exact вҹЁвҹЁF, G, hFG, hGFвҹ©вҹ©

theorem dedekindZetaTwoAF_isMultiplicative (K : Type) [Field K] [NumberField K] :
    (dedekindZetaTwoAF K).IsMultiplicative := by
  classical
  refine ArithmeticFunction.IsMultiplicative.iff_ne_zero.2 ?_
  constructor
  В· simp [dedekindZetaTwoAF, Ideal.absNorm_eq_one_iff]
  В· intro m n hm hn hcop
    obtain вҹЁeвҹ© := ideal_normFiber_mul_equiv K m n hcop
    have hcard := Nat.card_congr e
    rw [Nat.card_prod] at hcard
    dsimp [dedekindZetaTwoAF]
    rw [hcard, Nat.cast_mul, Nat.cast_mul]
    have hpow : ((m : в„қ) * (n : в„қ)) ^ (2 : в„•) = (m : в„қ) ^ (2 : в„•) * (n : в„қ) ^ (2 : в„•) := by
      simpa using (mul_pow (m : в„қ) (n : в„қ) (2 : в„•))
    rw [hpow]
    have hmR : (m : в„қ) ^ (2 : в„•) вү  0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr hm)
    have hnR : (n : в„қ) ^ (2 : в„•) вү  0 := by
      exact pow_ne_zero 2 (Nat.cast_ne_zero.mpr hn)
    rw [div_eq_mul_inv, div_eq_mul_inv, div_eq_mul_inv]
    field_simp [hmR, hnR]

theorem normalizedFactor_mem_primesOverFinset_of_absNorm_eq_primePow (K : Type) [Field K] [NumberField K] (p : в„•) (hp : p.Prime)
    {I P : Ideal (рқ“һ K)} {e : в„•}
    (hI : Ideal.absNorm I = p ^ e) (hP : P вҲҲ normalizedFactors I) :
    P вҲҲ primesOverFinset (Ideal.span ({(p : в„Ө)} : Set в„Ө)) (рқ“һ K) := by
  classical
  let pp : Ideal в„Ө := Ideal.span ({(p : в„Ө)} : Set в„Ө)
  have hIabs0 : Ideal.absNorm I вү  0 := by
    rw [hI]
    exact pow_ne_zero _ hp.ne_zero
  have hI0 : I вү  вҠҘ := by
    intro hbot
    apply hIabs0
    simp [hbot]
  rcases (Ideal.mem_normalizedFactors_iff hI0).1 hP with вҹЁhPprime, hIPвҹ©
  have hP0 : P вү  (0 : Ideal (рқ“һ K)) := UniqueFactorizationMonoid.ne_zero_of_mem_normalizedFactors hP
  let q : в„• := Ideal.absNorm (Ideal.under в„Ө P)
  have hqprime : q.Prime := by
    letI : P.IsPrime := hPprime
    letI : NeZero P := вҹЁhP0вҹ©
    dsimp [q]
    simpa using Nat.absNorm_under_prime P
  have hqdvdIunder : q вҲЈ Ideal.absNorm (Ideal.under в„Ө I) := by
    dsimp [q]
    exact Ideal.absNorm_dvd_absNorm_of_le (Ideal.comap_mono hIP)
  have hIunderdvd : Ideal.absNorm (Ideal.under в„Ө I) вҲЈ Ideal.absNorm I :=
    Int.absNorm_under_dvd_absNorm I
  have hqdpowe : q вҲЈ p ^ e := by
    have hqdnormI : q вҲЈ Ideal.absNorm I := dvd_trans hqdvdIunder hIunderdvd
    simpa [hI] using hqdnormI
  have hqp : q = p := Nat.prime_eq_prime_of_dvd_pow hqprime hp hqdpowe
  have hL : P.LiesOver pp := by
    letI : P.LiesOver (Ideal.span ({(q : в„Ө)} : Set в„Ө)) := by
      simpa [q] using (Int.liesOver_span_absNorm (I := P))
    have hUnder : Ideal.span ({(q : в„Ө)} : Set в„Ө) = Ideal.under в„Ө P :=
      Ideal.over_def (A := в„Ө) (P := P) (p := Ideal.span ({(q : в„Ө)} : Set в„Ө))
    refine вҹЁ?_вҹ©
    simpa [pp, hqp] using hUnder
  have hpp_ne_bot : pp вү  вҠҘ := by
    dsimp [pp]
    rw [Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  letI : Fact p.Prime := вҹЁhpвҹ©
  haveI : pp.IsMaximal := by
    simpa [pp] using (Int.ideal_span_isMaximal_of_prime p)
  rw [mem_primesOverFinset_iff (B := рқ“һ K) hpp_ne_bot]
  change P.IsPrime вҲ§ P.LiesOver pp
  exact вҹЁhPprime, hLвҹ©

theorem summable_pi_inverse_square_prime {Оұ : Type*} (s : Finset Оұ) (p : в„•) (hp : p.Prime) :
    Summable (fun ОҪ : (s вҶ’ в„•) => (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№) := by
  classical
  let a : в„қ := ((p : в„қ) ^ (2 : в„•))вҒ»В№
  have ha0 : 0 вүӨ a := by
    dsimp [a]
    positivity
  have hp1 : (1 : в„қ) < p := by
    exact_mod_cast hp.one_lt
  have hpow : 1 < (p : в„қ) ^ (2 : в„•) := by
    nlinarith
  have ha1 : a < 1 := by
    dsimp [a]
    simpa using (inv_lt_one_of_one_ltвӮҖ hpow)
  let f : (s вҶ’ в„•) вҶ’ в„қ := fun ОҪ => вҲҸ i, a ^ ОҪ i
  have hf_eq : (fun ОҪ : (s вҶ’ в„•) => (вҲҸ i, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ i)))вҒ»В№) = f := by
    funext ОҪ
    simp [f, a, inv_pow]
  rw [hf_eq]
  have hf_nonneg : вҲҖ ОҪ : s вҶ’ в„•, 0 вүӨ f ОҪ := by
    intro ОҪ
    exact Finset.prod_nonneg fun i hi => pow_nonneg ha0 _
  refine summable_of_sum_le (c := вҲҸ i : s, (1 - a)вҒ»В№) hf_nonneg ?_
  intro u
  let t : s вҶ’ Finset в„• := fun i => u.image fun ОҪ : s вҶ’ в„• => ОҪ i
  have hsubset : u вҠҶ Fintype.piFinset t := by
    intro ОҪ hОҪ
    rw [Fintype.mem_piFinset]
    intro i
    exact Finset.mem_image_of_mem (fun ОҪ : s вҶ’ в„• => ОҪ i) hОҪ
  have hsum_le : вҲҖ i : s, вҲ‘ k вҲҲ t i, a ^ k вүӨ (1 - a)вҒ»В№ := by
    intro i
    exact sum_le_hasSum (t i) (fun k hk => pow_nonneg ha0 k) (hasSum_geometric_of_lt_one ha0 ha1)
  calc
    вҲ‘ ОҪ вҲҲ u, f ОҪ вүӨ вҲ‘ ОҪ вҲҲ Fintype.piFinset t, f ОҪ := by
      exact Finset.sum_le_sum_of_subset_of_nonneg hsubset (fun ОҪ hОҪ1 hОҪ2 => hf_nonneg ОҪ)
    _ = вҲҸ i, вҲ‘ k вҲҲ t i, a ^ k := by
      simp [f]
      symm
      exact Finset.prod_univ_sum t (fun i k => a ^ k)
    _ вүӨ вҲҸ i : s, (1 - a)вҒ»В№ := by
      refine Finset.prod_le_prod ?_ ?_
      В· intro i hi
        exact Finset.sum_nonneg fun k hk => pow_nonneg ha0 _
      В· intro i hi
        exact hsum_le i

theorem sigma_weight_summable_le_tuple (K : Type) [Field K] [NumberField K] (p : в„•) (hp : p.Prime) :
    let pp : Ideal в„Ө := Ideal.span ({(p : в„Ө)} : Set в„Ө)
    let ОІ : в„• вҶ’ Type := fun e => { I : Ideal (рқ“һ K) // Ideal.absNorm I = p ^ e }
    let s : Finset (Ideal (рқ“һ K)) := primesOverFinset pp (рқ“һ K)
    Summable (fun x : Sigma ОІ => 1 / ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•))) вҲ§
      вҲ‘' x : Sigma ОІ, 1 / ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•)) вүӨ
        вҲ‘' ОҪ : (s вҶ’ в„•), (вҲҸ P, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ P)))вҒ»В№ := by
  classical
  dsimp
  let pp : Ideal в„Ө := Ideal.span ({(p : в„Ө)} : Set в„Ө)
  let ОІ : в„• вҶ’ Type := fun e => { I : Ideal (рқ“һ K) // Ideal.absNorm I = p ^ e }
  let s : Finset (Ideal (рқ“һ K)) := primesOverFinset pp (рқ“һ K)
  let weight : Sigma ОІ вҶ’ в„қ := fun x => 1 / ((Ideal.absNorm x.2.1 : в„қ) ^ (2 : в„•))
  let g : (s вҶ’ в„•) вҶ’ в„қ := fun ОҪ => (вҲҸ P, ((((p : в„қ) ^ (2 : в„•)) ^ ОҪ P)))вҒ»В№
  let encode : Sigma ОІ вҶ’ (s вҶ’ в„•) := fun x P => Multiset.count P.1 (normalizedFactors x.2.1)
  have hsigma_of_ideal_eq : вҲҖ {x y : Sigma ОІ}, x.2.1 = y.2.1 вҶ’ x = y := by
    intro x y hI
    refine Sigma.subtype_ext ?_ ?_
    В· exact (Nat.pow_right_injective hp.two_le) (by simpa [x.2.2, y.2.2] using congrArg Ideal.absNorm hI)
    В· exact hI
  have hweight_nonneg : вҲҖ x : Sigma ОІ, 0 вүӨ weight x := by
    intro x
    positivity
  have hg_nonneg : вҲҖ ОҪ : (s вҶ’ в„•), 0 вүӨ g ОҪ := by
    intro ОҪ
    positivity
  have hg : Summable g := by
    simpa [g] using summable_pi_inverse_square_prime s p hp
  have hencode_support : вҲҖ (x : Sigma ОІ) {P : Ideal (рқ“һ K)}, P вҲҲ normalizedFactors x.2.1 вҶ’ P вҲҲ s := by
    intro x P hP
    exact normalizedFactor_mem_primesOverFinset_of_absNorm_eq_primePow K p hp x.2.2 hP
  have hnot_bot : вҲҖ x : Sigma ОІ, x.2.1 вү  вҠҘ := by
    intro x
    have hpos : 0 < Ideal.absNorm x.2.1 := by simpa [x.2.2] using pow_pos hp.pos x.1
    intro hxbot

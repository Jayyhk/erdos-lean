            _ ≤ c ^ m * c := hstep
            _ = c ^ (m + 1) := by rw [pow_succ]
    have hpow_ge_one : (1 : ℝ) ≤ c ^ n := hpow_ge_one_all n
    have hfloor_one : 1 ≤ ⌊c ^ n⌋₊ := by
      exact (Nat.one_le_floor_iff (c ^ n)).2 hpow_ge_one
    have hfloor_one' : (1 : ℝ) ≤ (⌊c ^ n⌋₊ : ℝ) := by

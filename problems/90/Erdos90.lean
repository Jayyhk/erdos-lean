    simpa [_root_.Erdos90.InhomogContsCochains.d_apply,
      _root_.Erdos90.InhomogContsCochains.dAux.toFun,
      _root_.Erdos90.InhomogClassAPI.ofProd, Fin.sum_univ_two,

          ContinuousCohomology.MultiInd.functor (ZMod p) G 1 вҹ¶
            ContinuousCohomology.MultiInd.functor (ZMod p) G 2 :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G 1).whiskerLeft
          (ContinuousCohomology.const (ZMod p) G)
      let B :
          ContinuousCohomology.MultiInd.functor (ZMod p) G 1 вҹ¶
            ContinuousCohomology.MultiInd.functor (ZMod p) G 2 :=
        CategoryTheory.Functor.whiskerRight (ContinuousCohomology.const (ZMod p) G)
          (ContinuousCohomology.I (ZMod p) G)
      change towerEval p G 2 (((A - B).app X).hom y) t =
        towerEval p G 1 y (Fin.tail t) +
          ((Finset.univ : Finset (Fin 1)).sum (fun j : Fin 1 =>
            (-1 : ZMod p) ^ ((j : в„•) + 1) вҖў towerEval p G 1 y (j.succ.removeNth t)))
      have hy : ((A - B).app X).hom y = (A.app X).hom y - (B.app X).hom y := by
        simp [Action.sub_hom, TopModuleCat.hom_sub, ContinuousLinearMap.sub_apply]
      have hsub : towerEval p G 2 (((A - B).app X).hom y) t =
          towerEval p G 2 ((A.app X).hom y) t - towerEval p G 2 ((B.app X).hom y) t := by
        rw [hy, towerEval_sub]
      have hA : towerEval p G 2 ((A.app X).hom y) t = y (Fin.tail t 0) := by
        rfl
      have hB : towerEval p G 2 ((B.app X).hom y) t = y (Fin.removeNth 1 t 0) := by
        rfl
      rw [hsub, hA, hB, Fin.sum_univ_one]
      simp [Fin.removeNth_zero, sub_eq_add_neg, towerEval, towerAsC]
      rfl
  | succ n ih =>
      let X : Action (TopModuleCat (ZMod p)) G :=
        Action.trivial G (TopModuleCat.of (ZMod p) (ZMod p))
      rw [ContinuousCohomology.MultiInd.d_succ]
      let A :
          ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2) вҹ¶
            ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 3) :=
        (ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2)).whiskerLeft
          (ContinuousCohomology.const (ZMod p) G)
      let B :
          ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 2) вҹ¶
            ContinuousCohomology.MultiInd.functor (ZMod p) G (n + 3) :=
        CategoryTheory.Functor.whiskerRight
          (ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1))
          (ContinuousCohomology.I (ZMod p) G)
      let y0 : HomogTower p G (n + 1) := (towerAsC p G (n + 1) y) (t 0)
      change towerEval p G (n + 3) (((A - B).app X).hom y) t =
        towerEval p G (n + 2) y (Fin.tail t) +
          ((Finset.univ : Finset (Fin (n + 2))).sum (fun j : Fin (n + 2) =>
            (-1 : ZMod p) ^ ((j : в„•) + 1) вҖў towerEval p G (n + 2) y (j.succ.removeNth t)))
      have hy : ((A - B).app X).hom y = (A.app X).hom y - (B.app X).hom y := by
        simp [Action.sub_hom, TopModuleCat.hom_sub, ContinuousLinearMap.sub_apply]
      have hsub : towerEval p G (n + 3) (((A - B).app X).hom y) t =
          towerEval p G (n + 3) ((A.app X).hom y) t - towerEval p G (n + 3) ((B.app X).hom y) t := by
        rw [hy, towerEval_sub]
      have hA : towerEval p G (n + 3) ((A.app X).hom y) t = towerEval p G (n + 2) y (Fin.tail t) := by
        rfl
      have hB0 : towerEval p G (n + 3) ((B.app X).hom y) t =
          towerEval p G (n + 2)
            (((ContinuousCohomology.MultiInd.d (ZMod p) G (n + 1)).app X).hom y0)
            (Fin.tail t) := by
        rfl
      have hih := ih y0 (Fin.tail t)
      have hremove1 : towerEval p G (n + 2) y ((0 : Fin (n + 2)).succ.removeNth t) =
          towerEval p G (n + 1) y0 (Fin.tail (Fin.tail t)) := by
        rfl
      have hshift (j : Fin (n + 1)) :
          towerEval p G (n + 2) y (j.succ.succ.removeNth t) =
            towerEval p G (n + 1) y0 (j.succ.removeNth (Fin.tail t)) := by
        rw [succSucc_removeNth_eq_cons_removeNth_tail]
        rfl
      let f : Fin (n + 1) вҶ’ ZMod p := fun j =>
        towerEval p G (n + 1) y0 (j.succ.removeNth (Fin.tail t))
      have hs :
          -((Finset.univ : Finset (Fin (n + 1))).sum
              (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : в„•) + 1) вҖў f j)) =
            (Finset.univ : Finset (Fin (n + 1))).sum
              (fun j : Fin (n + 1) => (-1 : ZMod p) ^ ((j : в„•) + 1 + 1) вҖў f j) := by
        simpa [f, smul_eq_mul] using neg_alternating_sum_shift p (n + 1) f
      rw [hsub, hA, hB0, hih, sub_eq_add_neg, neg_add]
      conv_rhs => rw [Fin.sum_univ_succ]
      rw [hs]
      congr 1
      rw [hremove1]
      simp [pow_one]
      apply Finset.sum_congr rfl
      intro i hi
      rw [hshift]


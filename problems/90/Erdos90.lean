theorem neg_alternating_sum_shift (p : в„•) [Fact p.Prime] (n : в„•) (f : Fin n вҶ’ ZMod p) : -((Finset.univ : Finset (Fin n)).sum (fun j : Fin n => (-1 : ZMod p) ^ ((j : в„•) + 1) * f j)) = (Finset.univ : Finset (Fin n)).sum (fun j : Fin n => (-1 : ZMod p) ^ ((j : в„•) + 1 + 1) * f j) := by

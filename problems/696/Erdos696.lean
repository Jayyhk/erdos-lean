        have h_step_b : y_target^2 * (b : ℝ) / Real.exp (y_target ^ A) ≤
            Real.exp (-c * Real.log y_target) / 2 * (b : ℝ) := by
          rw [show y_target^2 * (b : ℝ) / Real.exp (y_target ^ A) =

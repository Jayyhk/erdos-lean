          (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN ((QuotientGroup.mk' N) g))⁻¹) *
        (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN ((QuotientGroup.mk' N) g) *
          _root_.Erdos90.TransgressionContinuous.chosenSection G N hN ((QuotientGroup.mk' N) h) *
          (_root_.Erdos90.TransgressionContinuous.chosenSection G N hN
            ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h))⁻¹)
  rw [map_mul]
  group

theorem h1ToHom_continuous (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    [SecondCountableTopology G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (x : _root_.Erdos90.H1ContsTrivial p G N) :
    Continuous fun n : Additive ↥N =>
      (_root_.Erdos90.TransgressionContinuous.h1ToHom p G N hN x) n := by

  exact _root_.Erdos90.TransgressionContinuous.h1ToHom_continuous p G N hN x

noncomputable abbrev homogeneous1TrivialCycles
    (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K] : Type :=
  ((((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj
      (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p)))).cycles 1 :
      TopModuleCat (ZMod p)) : Type)

noncomputable def homogeneous1TrivialCyclesValue
    (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g h : K) : ZMod p := by
  let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj
    (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))))
  let z := (Cx.iCycles 1) x
  exact DFunLike.coe (F := C(K, ZMod p))
    (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 g) h

theorem exists_homogeneous1_cycle_of_continuousAddHom (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (χ : Additive K →ₜ+ ZMod p) :
    ∃ x : homogeneous1TrivialCycles p K,
      ∀ g h : K,
        homogeneous1TrivialCyclesValue p K x g h =
          χ (Additive.ofMul (g⁻¹ * h)) := by
  classical
  let rep : Action (TopModuleCat (ZMod p)) K :=
    Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))
  let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj rep)
  let φ : C(K × K, ZMod p) :=
    { toFun := fun gh => χ (Additive.ofMul (gh.1⁻¹ * gh.2))
      continuous_toFun := by
        have h1 : Continuous fun gh : K × K => χ (Additive.ofMul gh.1) :=
          χ.continuous.comp (continuous_ofMul.comp continuous_fst)
        have h2 : Continuous fun gh : K × K => χ (Additive.ofMul gh.2) :=
          χ.continuous.comp (continuous_ofMul.comp continuous_snd)
        simpa [ofMul_inv, ofMul_mul, map_add] using h1.neg.add h2 }
  let zχ0 : C(K, C(K, ZMod p)) := ContinuousMap.curry φ
  have hzχ0 : ∀ g h : K, zχ0 g h = χ (Additive.ofMul (g⁻¹ * h)) := by
    intro g h
    simp [zχ0, φ, ContinuousMap.curry_apply]
  let zχ : { z : C(K, C(K, ZMod p)) //
      ∀ a : K, (((ContinuousCohomology.Iobj (ContinuousCohomology.Iobj rep)).ρ a).hom z = z) } := by
    refine ⟨zχ0, ?_⟩
    intro a
    ext g h
    change zχ0 (a⁻¹ * g) (a⁻¹ * h) = zχ0 g h
    have hmul : (a⁻¹ * g)⁻¹ * (a⁻¹ * h) = g⁻¹ * h := by
      group
    simp [hzχ0, hmul]
  let zχX : Cx.X 1 := zχ
  let left2Map (u : C(K, ZMod p)) : C(K, C(K, ZMod p)) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).obj rep).V
    exact (((ContinuousCohomology.MultiInd.functor (ZMod p) K 1).whiskerLeft
      (ContinuousCohomology.const (ZMod p) K)).app rep).hom u
  let right2Map (u : C(K, ZMod p)) : C(K, C(K, ZMod p)) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).obj rep).V
    exact ((CategoryTheory.Functor.whiskerRight (ContinuousCohomology.const (ZMod p) K)
      (ContinuousCohomology.I (ZMod p) K)).app rep).hom u
  let d1u (u : C(K, ZMod p)) : C(K, C(K, ZMod p)) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).obj rep).V
    exact ((ContinuousCohomology.MultiInd.d (ZMod p) K 1).app rep).hom u
  have hd1_apply (u : C(K, ZMod p)) (h k : K) :
      d1u u h k = u k - u h := by
    change left2Map u h k - right2Map u h k = u k - u h
    rfl
  let left3Map (f : C(K, C(K, ZMod p))) : C(K, C(K, C(K, ZMod p))) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 3).obj rep).V
    exact (((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).whiskerLeft
      (ContinuousCohomology.const (ZMod p) K)).app rep).hom f
  let right3Map (f : C(K, C(K, ZMod p))) : C(K, C(K, C(K, ZMod p))) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 3).obj rep).V
    exact ((CategoryTheory.Functor.whiskerRight (ContinuousCohomology.MultiInd.d (ZMod p) K 1)
      (ContinuousCohomology.I (ZMod p) K)).app rep).hom f
  let d2f (f : C(K, C(K, ZMod p))) : C(K, C(K, C(K, ZMod p))) := by
    change ((ContinuousCohomology.MultiInd.functor (ZMod p) K 3).obj rep).V
    exact ((ContinuousCohomology.MultiInd.d (ZMod p) K 2).app rep).hom f
  have hd2_apply (f : C(K, C(K, ZMod p))) (g h k : K) :
      d2f f g h k = f h k - f g k + f g h := by
    change left3Map f g h k - right3Map f g h k = f h k - f g k + f g h
    rw [show right3Map f g h k = d1u (f g) h k by rfl]
    rw [show left3Map f g h k = f h k by rfl]
    rw [hd1_apply]
    abel
  let z3 : { z : C(K, C(K, C(K, ZMod p))) //
    ∀ a : K, (((ContinuousCohomology.Iobj (ContinuousCohomology.Iobj (ContinuousCohomology.Iobj rep))).ρ a).hom z = z) } := by
    change Cx.X 2
    exact (Cx.d 1 2).hom zχX
  have hz3_zero : z3.1 = 0 := by
    ext g h k
    change d2f zχ0 g h k = 0
    rw [hd2_apply]
    change χ (Additive.ofMul (h⁻¹ * k)) - χ (Additive.ofMul (g⁻¹ * k)) + χ (Additive.ofMul (g⁻¹ * h)) = 0
    have hmul : g⁻¹ * k = (g⁻¹ * h) * (h⁻¹ * k) := by
      group
    have hmap : χ (Additive.ofMul (g⁻¹ * k)) =
        χ (Additive.ofMul (g⁻¹ * h)) + χ (Additive.ofMul (h⁻¹ * k)) := by
      rw [hmul, ofMul_mul]
      simp
    rw [hmap]
    abel
  have hzcycle : (Cx.d 1 2).hom zχX = 0 := by
    change z3 = (0 : Cx.X 2)
    exact Subtype.ext hz3_zero
  let kz : TopModuleCat.of (ZMod p) (ZMod p) ⟶ Cx.X 1 :=
    TopModuleCat.ofHom ((1 : ZMod p →L[ZMod p] ZMod p).smulRight zχX)
  have hkz_hom : (CategoryTheory.CategoryStruct.comp kz (Cx.d 1 2)).hom = 0 := by
    apply ContinuousLinearMap.ext_ring
    rw [TopModuleCat.hom_comp, ContinuousLinearMap.comp_apply]
    have hkz_eval : (TopModuleCat.Hom.hom kz) 1 = zχX := by
      change ((1 : ZMod p →L[ZMod p] ZMod p).smulRight zχX) 1 = zχX
      rw [ContinuousLinearMap.smulRight_apply, ContinuousLinearMap.one_apply, one_smul]
    rw [hkz_eval, hzcycle]
    rfl
  have hkz : CategoryTheory.CategoryStruct.comp kz (Cx.d 1 2) = 0 := by
    apply CategoryTheory.ConcreteCategory.ext
    exact hkz_hom
  let mx : TopModuleCat.of (ZMod p) (ZMod p) ⟶ Cx.cycles 1 :=
    Cx.liftCycles kz 2 (by simp) hkz
  let x : homogeneous1TrivialCycles p K := mx 1
  have hmx : CategoryTheory.CategoryStruct.comp mx (Cx.iCycles 1) = kz := by
    change CategoryTheory.CategoryStruct.comp (Cx.liftCycles kz 2 (by simp) hkz) (Cx.iCycles 1) = kz
    simp [Cx.liftCycles_i kz 2 (by simp) hkz]
  have hxeval : (Cx.iCycles 1) x = zχX := by
    change (CategoryTheory.CategoryStruct.comp mx (Cx.iCycles 1)) 1 = zχX
    rw [hmx]
    change ((1 : ZMod p →L[ZMod p] ZMod p).smulRight zχX) 1 = zχX
    rw [ContinuousLinearMap.smulRight_apply, ContinuousLinearMap.one_apply, one_smul]
  refine ⟨x, ?_⟩
  intro g h
  unfold homogeneous1TrivialCyclesValue
  dsimp [x]
  rw [hxeval]
  simp [zχX, zχ, hzχ0 g h]

noncomputable def homogeneous1TrivialCyclesEval
    (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g : K) : ZMod p :=
  homogeneous1TrivialCyclesValue p K x 1 g

theorem homogeneous1_cycle_relation (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g h : K) :
    homogeneous1TrivialCyclesValue p K x g (g * h) -
      homogeneous1TrivialCyclesEval p K x (g * h) +
      homogeneous1TrivialCyclesEval p K x g = 0 := by
  let X := Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))
  let Cx := (ContinuousCohomology.homogeneousCochains (ZMod p) K).obj X
  let x' : Cx.cycles 1 := x
  let z := (Cx.iCycles 1) x'
  let w : C(K, C(K, ZMod p)) := z.1
  let d1 := ContinuousCohomology.MultiInd.d (ZMod p) K 1
  let a : ((ContinuousCohomology.MultiInd.functor (ZMod p) K 1).comp
      (ContinuousCohomology.I (ZMod p) K)).obj X ⟶
      ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).comp
        (ContinuousCohomology.I (ZMod p) K)).obj X :=
    ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).whiskerLeft
      (ContinuousCohomology.const (ZMod p) K)).app X
  let b : ((ContinuousCohomology.MultiInd.functor (ZMod p) K 1).comp
      (ContinuousCohomology.I (ZMod p) K)).obj X ⟶
      ((ContinuousCohomology.MultiInd.functor (ZMod p) K 2).comp
        (ContinuousCohomology.I (ZMod p) K)).obj X :=
    (CategoryTheory.Functor.whiskerRight d1 (ContinuousCohomology.I (ZMod p) K)).app X
  have hab : DFunLike.coe (F := C(K, C(K, C(K, ZMod p))))
      ((a - b).hom.hom w) 1 g (g * h)
      = w g (g * h) - (w 1 (g * h) - w 1 g) := by
    dsimp [a, b, d1, CategoryTheory.Functor.whiskerLeft, CategoryTheory.Functor.whiskerRight,
      ContinuousCohomology.MultiInd.functor,
      ContinuousCohomology.MultiInd.d,
      ContinuousCohomology.const, ContinuousCohomology.I]
    rfl
  have h0 : CategoryTheory.CategoryStruct.comp (Cx.iCycles 1) (Cx.d 1 2) = 0 :=
    HomologicalComplex.iCycles_d (K := Cx) (i := 1) (j := 2)
  have hz : (Cx.d 1 2) z = 0 := by
    change (CategoryTheory.CategoryStruct.comp (Cx.iCycles 1) (Cx.d 1 2)) x' = 0
    rw [h0]
    rfl
  have hz_eval := congrArg
    (fun t => DFunLike.coe (F := C(K, C(K, C(K, ZMod p)))) t.1 1 g (g * h)) hz
  dsimp [Cx, X, ContinuousCohomology.homogeneousCochains,
    ContinuousCohomology.MultiInd.complex,
    ContinuousCohomology.invariants] at hz_eval
  change DFunLike.coe (F := C(K, C(K, C(K, ZMod p))))
      (((ContinuousCohomology.MultiInd.d (ZMod p) K 2).app X).hom.hom z.1) 1 g
      (g * h) = 0 at hz_eval
  rw [ContinuousCohomology.MultiInd.d_succ (R := ZMod p) (G := K) 1] at hz_eval
  change DFunLike.coe (F := C(K, C(K, C(K, ZMod p))))
      ((a - b).hom.hom w) 1 g (g * h) = 0 at hz_eval
  rw [hab] at hz_eval
  have hz_formula' : w g (g * h) - (w 1 (g * h) - w 1 g) = 0 := hz_eval
  have hz_formula : w g (g * h) - w 1 (g * h) + w 1 g = 0 := by
    convert hz_formula' using 1
    ring
  simpa [homogeneous1TrivialCyclesValue, homogeneous1TrivialCyclesEval, w, z] using hz_formula

theorem homogeneous1_cyclesMap_eval (p : ℕ) [Fact p.Prime]
    {G1 G2 : Type} [Group G1] [TopologicalSpace G1] [IsTopologicalGroup G1]
    [Group G2] [TopologicalSpace G2] [IsTopologicalGroup G2]
    (f : G1 →* G2) (hf : Continuous f)
    (x : homogeneous1TrivialCycles p G2) (g : G1) :
    homogeneous1TrivialCyclesEval p G1
      (HomologicalComplex.cyclesMap
        (ContinuousCohomology.cochainsMapTrivial (ZMod p) f hf
          (TopModuleCat.of (ZMod p) (ZMod p))) 1 x) g =
      homogeneous1TrivialCyclesEval p G2 x (f g) := by
  let φ := ContinuousCohomology.cochainsMapTrivial (ZMod p) f hf
    (TopModuleCat.of (ZMod p) (ZMod p))
  let X : Action (TopModuleCat (ZMod p)) G2 :=
    Action.trivial G2 (TopModuleCat.of (ZMod p) (ZMod p))
  have hm_eval (c : C(G2, C(G2, ZMod p))) :
      DFunLike.coe (F := C(G1, ZMod p))
        (DFunLike.coe (F := C(G1, C(G1, ZMod p)))
          ((ContinuousCohomology.multiIndMap (ZMod p) f hf 2 X).hom.hom c) 1) g =
      DFunLike.coe (F := C(G2, ZMod p))
        (DFunLike.coe (F := C(G2, C(G2, ZMod p))) c (f 1)) (f g) := by
    rw [ContinuousCohomology.multiIndMap_succ, ContinuousCohomology.multiIndMap_succ,
      ContinuousCohomology.multiIndMap_zero]
    rfl
  unfold homogeneous1TrivialCyclesEval homogeneous1TrivialCyclesValue
  have h := congrArg
    (fun k =>
      DFunLike.coe (F := C(G1, ZMod p))
        (DFunLike.coe (F := C(G1, C(G1, ZMod p))) ((k x).1) 1) g)
    (HomologicalComplex.cyclesMap_i (φ := φ) (i := 1))
  convert h using 1
  · let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) G2).obj X)
    let z := (CategoryTheory.ConcreteCategory.hom (HomologicalComplex.iCycles Cx 1)) x
    change DFunLike.coe (F := C(G2, ZMod p))
      (DFunLike.coe (F := C(G2, C(G2, ZMod p))) z.1 1) (f g) =
      DFunLike.coe (F := C(G1, ZMod p))
        (DFunLike.coe (F := C(G1, C(G1, ZMod p)))
          ((ContinuousCohomology.multiIndMap (ZMod p) f hf 2 X).hom.hom z.1) 1) g
    simpa [X, map_one] using (hm_eval z.1).symm

theorem homogeneous1_eval_continuous (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) :
    Continuous fun g : K => homogeneous1TrivialCyclesEval p K x g := by
  classical
  let X := Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))
  let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj X)
  let z := (Cx.iCycles 1) x
  change Continuous fun g : K =>
    DFunLike.coe (F := C(K, ZMod p))
      (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 1) g
  exact (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 1).continuous

theorem homogeneous1_invariant_eval (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g h : K) :
    homogeneous1TrivialCyclesValue p K x 1 h =
      homogeneous1TrivialCyclesValue p K x g (g * h) := by
  let X := Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))
  let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj X)
  let z := (Cx.iCycles 1) x
  change
      DFunLike.coe (F := C(K, ZMod p))
        (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 1) h =
      DFunLike.coe (F := C(K, ZMod p))
        (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 g) (g * h)
  have hz : (((ContinuousCohomology.Iobj (ContinuousCohomology.Iobj X)).ρ g).hom z.1 = z.1) := z.2 g
  have hz' := congrArg
    (fun f => DFunLike.coe (F := C(K, ZMod p))
      (DFunLike.coe (F := C(K, C(K, ZMod p))) f g) (g * h)) hz
  dsimp [ContinuousCohomology.Iobj, X, Action.trivial] at hz'
  change
      DFunLike.coe (F := C(K, ZMod p))
        (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 (g⁻¹ * g))
        (g⁻¹ * (g * h)) =
      DFunLike.coe (F := C(K, ZMod p))
        (DFunLike.coe (F := C(K, C(K, ZMod p))) z.1 g) (g * h) at hz'
  simpa [mul_assoc] using hz'

theorem homogeneous1_cycle_eval_mul (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g h : K) :
    homogeneous1TrivialCyclesEval p K x (g * h) =
      homogeneous1TrivialCyclesEval p K x g + homogeneous1TrivialCyclesEval p K x h := by
  have hrel := homogeneous1_cycle_relation p K x g h
  rw [← homogeneous1_invariant_eval p K x g h] at hrel
  dsimp [homogeneous1TrivialCyclesEval] at hrel
  have h1 := congrArg (fun t => t + homogeneous1TrivialCyclesValue p K x 1 (g * h)) hrel
  abel_nf at h1
  simpa [homogeneous1TrivialCyclesEval, add_comm, add_left_comm, add_assoc] using h1.symm

theorem homogeneous1_recover_from_eval (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    (x : homogeneous1TrivialCycles p K) (g h : K) :
    homogeneous1TrivialCyclesValue p K x g h =
      homogeneous1TrivialCyclesEval p K x (g⁻¹ * h) := by
  rw [homogeneous1TrivialCyclesEval]
  symm
  calc
    homogeneous1TrivialCyclesValue p K x 1 (g⁻¹ * h) =
        homogeneous1TrivialCyclesValue p K x g (g * (g⁻¹ * h)) :=
      homogeneous1_invariant_eval p K x g (g⁻¹ * h)
    _ = homogeneous1TrivialCyclesValue p K x g h := by
      simp [mul_assoc]

theorem homogeneous1TrivialCycles_ext_eval (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    {x y : homogeneous1TrivialCycles p K}
    (hxy : ∀ g : K,
      homogeneous1TrivialCyclesEval p K x g = homogeneous1TrivialCyclesEval p K y g) :
    x = y := by
  classical
  let X := Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))
  let Cx := (ContinuousCohomology.homogeneousCochains (ZMod p) K).obj X
  have hix : Function.Injective (((CategoryTheory.forget₂ (TopModuleCat (ZMod p)) TopCat).map
      (Cx.iCycles 1)).hom) :=
    (TopCat.mono_iff_injective _).1 inferInstance
  apply hix
  apply Subtype.ext
  apply ContinuousMap.ext
  intro g
  apply ContinuousMap.ext
  intro h
  change homogeneous1TrivialCyclesValue p K x g h = homogeneous1TrivialCyclesValue p K y g h
  rw [homogeneous1_recover_from_eval, homogeneous1_recover_from_eval]
  exact hxy (g⁻¹ * h)

theorem continuousH1TrivialCyclesAddEquiv_package (p : ℕ) [Fact p.Prime] :
    ∃ e : ∀ (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K],
        ((((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj
            (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p)))).cycles 1 :
            TopModuleCat (ZMod p)) : Type) ≃+
          (Additive K →ₜ+ ZMod p),
      ∀ {G1 G2 : Type} [Group G1] [TopologicalSpace G1] [IsTopologicalGroup G1]
        [Group G2] [TopologicalSpace G2] [IsTopologicalGroup G2]
        (f : G1 →* G2) (hf : Continuous f)
        (x : ((((ContinuousCohomology.homogeneousCochains (ZMod p) G2).obj
            (Action.trivial G2 (TopModuleCat.of (ZMod p) (ZMod p)))).cycles 1 :
            TopModuleCat (ZMod p)) : Type)),
        e G1 (HomologicalComplex.cyclesMap
          (ContinuousCohomology.cochainsMapTrivial (ZMod p) f hf
            (TopModuleCat.of (ZMod p) (ZMod p))) 1 x) =
          (e G2 x).comp
            ({ toFun := fun g => Additive.ofMul (f g.toMul)
               map_zero' := by simp
               map_add' := by intro a b; simp
               continuous_toFun := by simpa using hf } : Additive G1 →ₜ+ Additive G2) := by
  classical
  refine ⟨?_, ?_⟩
  · intro K _ _ _
    let Cx := ((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj
      (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p))))
    have h_eval_add (x y : homogeneous1TrivialCycles p K) (g : K) :
        homogeneous1TrivialCyclesEval p K (x + y) g =
          homogeneous1TrivialCyclesEval p K x g + homogeneous1TrivialCyclesEval p K y g := by
      simp [homogeneous1TrivialCyclesEval, homogeneous1TrivialCyclesValue, Cx]
      rfl
    let forward : homogeneous1TrivialCycles p K → (Additive K →ₜ+ ZMod p) :=
      fun x =>
        { toFun := fun g => homogeneous1TrivialCyclesEval p K x g.toMul
          map_zero' := by
            have h : homogeneous1TrivialCyclesEval p K x 1 =
                homogeneous1TrivialCyclesEval p K x 1 + homogeneous1TrivialCyclesEval p K x 1 := by
              simpa using homogeneous1_cycle_eval_mul p K x (1 : K) 1
            have h' := congrArg (fun t => t - homogeneous1TrivialCyclesEval p K x 1) h
            simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h'.symm
          map_add' := by
            intro a b
            exact homogeneous1_cycle_eval_mul p K x a.toMul b.toMul
          continuous_toFun := by
            simpa using homogeneous1_eval_continuous p K x }
    let inverse : (Additive K →ₜ+ ZMod p) → homogeneous1TrivialCycles p K :=
      fun χ => Classical.choose (exists_homogeneous1_cycle_of_continuousAddHom p K χ)
    have hleft : ∀ x : homogeneous1TrivialCycles p K, inverse (forward x) = x := by
      intro x
      apply homogeneous1TrivialCycles_ext_eval p K
      intro g
      have hspec := Classical.choose_spec (exists_homogeneous1_cycle_of_continuousAddHom p K (forward x))
      simpa [forward, inverse, homogeneous1TrivialCyclesEval, inv_one, one_mul] using hspec 1 g
    have hright : ∀ χ : Additive K →ₜ+ ZMod p, forward (inverse χ) = χ := by
      intro χ
      ext g
      have hspec := Classical.choose_spec (exists_homogeneous1_cycle_of_continuousAddHom p K χ)
      simpa [forward, inverse, inv_one, one_mul] using hspec 1 g.toMul
    refine
      { toFun := forward
        invFun := inverse
        left_inv := hleft
        right_inv := hright
        map_add' := ?_ }
    intro x y
    ext g
    simpa [forward] using h_eval_add x y g.toMul
  · intro G1 G2 _ _ _ _ _ _ f hf x
    ext g
    exact homogeneous1_cyclesMap_eval p f hf x g.toMul

theorem homogeneousCochains_d01_trivial_zero (p : ℕ) [Fact p.Prime]
    (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K] :
    (((ContinuousCohomology.homogeneousCochains (ZMod p) K).obj
      (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p)))).d 0 1) = 0 := by
  ext f
  obtain ⟨f, hf⟩ := f
  have hf' : ∀ g : K,
      (((ContinuousCohomology.Iobj
        (Action.trivial K (TopModuleCat.of (ZMod p) (ZMod p)))).ρ g).hom f) = f := by
    simpa [ContinuousCohomology.MultiInd.complex, ContinuousCohomology.MultiInd.functor] using hf
  apply Subtype.ext
  apply ContinuousMap.ext
  intro a
  apply ContinuousMap.ext
  intro b
  change (show C(K, ZMod p) from f) b - (show C(K, ZMod p) from f) a = 0
  rw [sub_eq_zero]
  have h := congr(DFunLike.coe (F := C(K, ZMod p)) $(hf' (a * b⁻¹)) a)
  change (show C(K, ZMod p) from f) ((a * b⁻¹)⁻¹ * a) = (show C(K, ZMod p) from f) a at h
  simpa [mul_assoc] using h


    simpa [FourierTransform.fourier, sub_eq_add_neg] using
      (VectorFourier.fourierIntegral_comp_add_right Real.fourierChar MeasureTheory.volume (innerₗ ℝ) ψ (-a))
  refine ⟨?_, ?_, ?_, ?_, ?_⟩
  · simpa using hψ.continuous.comp (continuous_id.sub continuous_const)
  · simpa using hψ.integrable.comp_sub_right a
  · rw [hfourier]
    exact (Real.continuous_fourierChar.comp ((continuous_const.inner continuous_id).neg)).smul
      hψ.fourier_continuous
  · rw [hfourier]
    simpa using
      (HasCompactSupport.smul_left
        (f := fun ξ : ℝ => Real.fourierChar (-inner ℝ a ξ)) hψ.fourier_compact)
  ·
    simpa using
      (MeasureTheory.integral_sub_right_eq_self (f := ψ) a).trans hψ.mass_one

theorem continuousOn_shift_sub_const_div_one_add {g : ℂ → ℂ} {c : ℂ} :
    ContinuousOn g {s : ℂ | 1 ≤ s.re} →
    ContinuousOn (fun z : ℂ => (g (1 + z) - c) / (1 + z)) {z : ℂ | 0 ≤ z.re} := by
  intro hg
  have hden : ContinuousOn (fun z : ℂ => 1 + z) {z : ℂ | 0 ≤ z.re} :=
    (continuous_const.add continuous_id).continuousOn

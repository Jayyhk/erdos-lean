@[reducible] def trivialMulDistribMulAction (G A : Type*) [Monoid G] [CommGroup A] :
    MulDistribMulAction G A where
  smul := fun _ a => a
  one_smul := by
    intro a
    rfl
  mul_smul := by
    intro g h a
    rfl
  smul_mul := by
    intro g a b
    rfl
  smul_one := by
    intro g
    rfl

theorem exists_lift_of_transgressionFactor_isMulCoboundary (A : Type*) (G : Type*) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : N →* A) (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) : (letI := trivialMulDistribMulAction (G ⧸ N) A; groupCohomology.IsMulCoboundary₂ (quotientTransgressionFactor A G N χ)) → ∃ ψ : G →* A, ψ.comp N.subtype = χ := by
  intro hcb
  classical
  letI := trivialMulDistribMulAction (G ⧸ N) A
  rcases hcb with ⟨b, hb⟩
  have hb1 : b 1 = χ (quotientSectionDefect G N (1, 1)) := by
    simpa [quotientTransgressionFactor, div_eq_mul_inv] using hb 1 1
  have hb_mul : ∀ x y : G ⧸ N,
      χ (quotientSectionDefect G N (x, y)) * b (x * y) = b x * b y := by
    intro x y
    have hxy := congrArg (fun a : A => a * b (x * y)) (hb x y)
    simpa [quotientTransgressionFactor, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hxy.symm
  have hdef11 : ↑(quotientSectionDefect G N (1, 1)) = quotientGroupSection G N 1 := by
    simpa using quotientSectionDefect_spec G N (1 : G ⧸ N) 1
  have h_ext_aux : ∀ n : N, χ (quotientSectionRemainder G N (n : G)) * b 1 = χ n := by
    intro n
    have hqn : (QuotientGroup.mk' N) (n : G) = 1 := by
      exact (QuotientGroup.eq_one_iff (N := N) (x := (n : G))).mpr n.property
    have hmul : quotientSectionRemainder G N (n : G) * quotientSectionDefect G N (1, 1) = n := by
      apply Subtype.ext
      change (((n : G) * (quotientGroupSection G N ((QuotientGroup.mk' N) (n : G)))⁻¹) *
          quotientSectionDefect G N (1, 1) : G) = (n : G)
      rw [hqn, hdef11]
      simp [mul_assoc]
    calc
      χ (quotientSectionRemainder G N (n : G)) * b 1
          = χ (quotientSectionRemainder G N (n : G)) * χ (quotientSectionDefect G N (1, 1)) := by
              rw [hb1]
      _ = χ (quotientSectionRemainder G N (n : G) * quotientSectionDefect G N (1, 1)) := by
            rw [← χ.map_mul]
      _ = χ n := by rw [hmul]
  let ψ : G →* A :=
    { toFun := fun g => χ (quotientSectionRemainder G N g) * b ((QuotientGroup.mk' N) g)
      map_one' := by
        simpa using h_ext_aux (1 : N)
      map_mul' := by
        intro g h
        have hconj :
            χ
                (MulAut.conjNormal (H := N)
                  (quotientGroupSection G N ((QuotientGroup.mk' N) g))
                  (quotientSectionRemainder G N h)) =
              χ (quotientSectionRemainder G N h) := by
          have hcomp := congrArg (fun f : N →* A => f (quotientSectionRemainder G N h))
            (hχ (quotientGroupSection G N ((QuotientGroup.mk' N) g)))
          simpa using hcomp
        have hrχ :
            χ (quotientSectionRemainder G N (g * h)) =
              χ (quotientSectionRemainder G N g) * χ (quotientSectionRemainder G N h) *
                χ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) := by
          rw [quotientSectionRemainder_mul, χ.map_mul, χ.map_mul, hconj]
        have hbxy :
            χ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) *
                b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h) =
              b ((QuotientGroup.mk' N) g) * b ((QuotientGroup.mk' N) h) :=
          hb_mul ((QuotientGroup.mk' N) g) ((QuotientGroup.mk' N) h)
        rw [map_mul]
        calc
          χ (quotientSectionRemainder G N (g * h)) * b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h)
              = (χ (quotientSectionRemainder G N g) * χ (quotientSectionRemainder G N h) *
                  χ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h)))) *
                  b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h) := by
                  rw [hrχ]
          _ = χ (quotientSectionRemainder G N g) * χ (quotientSectionRemainder G N h) *
                (χ (quotientSectionDefect G N (((QuotientGroup.mk' N) g), ((QuotientGroup.mk' N) h))) *
                  b ((QuotientGroup.mk' N) g * (QuotientGroup.mk' N) h)) := by
                simp [mul_assoc, mul_left_comm, mul_comm]
          _ = χ (quotientSectionRemainder G N g) * χ (quotientSectionRemainder G N h) *
                (b ((QuotientGroup.mk' N) g) * b ((QuotientGroup.mk' N) h)) := by
                rw [hbxy]
          _ = (χ (quotientSectionRemainder G N g) * b ((QuotientGroup.mk' N) g)) *
                (χ (quotientSectionRemainder G N h) * b ((QuotientGroup.mk' N) h)) := by
                simp [mul_assoc, mul_left_comm, mul_comm] }
  refine ⟨ψ, ?_⟩
  ext n
  change χ (quotientSectionRemainder G N ↑n) * b ((QuotientGroup.mk' N) ↑n) = χ n
  have hqn : (QuotientGroup.mk' N) (↑n) = 1 := by
    exact (QuotientGroup.eq_one_iff (N := N) (x := (n : G))).mpr n.property
  rw [hqn]
  exact h_ext_aux n

theorem inflatedQuotientTransgressionFactor_isMulCoboundary (A G : Type) [CommGroup A] [Group G] (N : Subgroup G) [N.Normal] (χ : N →* A) (hχ : ∀ g : G, χ.comp ((MulAut.conjNormal (H := N) g).toMonoidHom) = χ) : letI := trivialMulDistribMulAction G A; groupCohomology.IsMulCoboundary₂ (inflatedQuotientTransgressionFactor A G N χ) := by
  letI := trivialMulDistribMulAction G A
  refine ⟨fun g => (χ (quotientSectionRemainder G N g))⁻¹, ?_⟩
  intro g h
  dsimp [inflatedQuotientTransgressionFactor, quotientTransgressionFactor]
  change (χ (quotientSectionRemainder G N h))⁻¹ / (χ (quotientSectionRemainder G N (g * h)))⁻¹ * (χ (quotientSectionRemainder G N g))⁻¹ = _
  have hmul := quotientSectionRemainder_mul G N g h
  have hmulχ := by
    simpa [map_mul, mul_assoc] using congrArg χ hmul
  have hχconj :
      χ (MulAut.conjNormal (H := N)
          (quotientGroupSection G N ((g : G ⧸ N)))
          (quotientSectionRemainder G N h)) =
        χ (quotientSectionRemainder G N h) := by
    simpa using congrArg
      (fun f : N →* A => f (quotientSectionRemainder G N h))
      (hχ (quotientGroupSection G N ((g : G ⧸ N))))
  rw [hmulχ, hχconj]
  simp [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm]

noncomputable abbrev quotientTrivialMulRep (A G : Type) [CommGroup A] [Group G]
    (N : Subgroup G) [N.Normal] : Rep ℤ (G ⧸ N) := by
  letI := trivialMulDistribMulAction (G ⧸ N) A

  have hle : ds.length ≤ HChain n := by
    show ds.length ≤ HChain n
    rw [HChain, if_neg hn1]
    exact le_csSup hbound hmem
  exact hRle.trans hle

/-- Pointwise lower-bound witness for the greedy divisor-chain construction. -/

private theorem continuous_conjNormal
    {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] (g : G) :
    Continuous ((MulAut.conjNormal g : ↥N ≃* ↥N) : ↥N → ↥N) := by
  refine continuous_induced_rng.2 ?_
  have hval : ∀ x : ↥N,
      ((MulAut.conjNormal g (x : ↥N) : ↥N) : G) = g * (x : G) * g⁻¹ :=
    fun x => MulAut.conjNormal_apply g x
  simp only [Function.comp_def, hval]
  exact (continuous_const.mul continuous_subtype_val).mul continuous_const

noncomputable def h1ConjMap
    (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] (g : G) :
    H1ContsTrivial p G N ⟶ H1ContsTrivial p G N :=
  ContinuousCohomology.cohomologyMapTrivial (ZMod p)
    (MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom
    (continuous_conjNormal N g⁻¹)
    (TopModuleCat.of (ZMod p) (ZMod p)) 1

noncomputable def h1NormalInvariantSubmodule
    (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    Submodule (ZMod p) (H1ContsTrivial p G N) where
  carrier := { x : H1ContsTrivial p G N | ∀ g : G, (h1ConjMap p G N g).hom x = x }
  zero_mem' := by
    intro g
    exact map_zero (h1ConjMap p G N g).hom
  add_mem' := by
    intro x y hx hy g
    rw [map_add, hx g, hy g]
  smul_mem' := by
    intro c x hx g
    rw [map_smul, hx g]

noncomputable def h1NormalInvariantRank
    (p : ℕ) [Fact p.Prime] (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] : ℕ :=
  Module.finrank (ZMod p) ↥(h1NormalInvariantSubmodule p G N)

def H1NormalInvariantFinite
    (p : ℕ) [Fact p.Prime] (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] : Prop :=
  FiniteDimensional (ZMod p) ↥(h1NormalInvariantSubmodule p G N)


noncomputable def closedFrattini
    (p : ℕ) (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] :
    Subgroup G :=
  (Subgroup.closure
    ((Set.range (fun g : G => g ^ p)) ∪ (commutator G : Set G))).topologicalClosure

def IsFinitelyGeneratedProPGroup (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G] : Prop :=
  (∃ S : Finset G, (Subgroup.closure (S : Set G)).topologicalClosure = ⊤) ∧
  (∀ (H : Subgroup G) [H.Normal], IsOpen (H : Set G) → IsPGroup p (G ⧸ H)) ∧
  CompactSpace G ∧ T2Space G ∧ TotallyDisconnectedSpace G

theorem IsFinitelyGeneratedProPGroup.compactSpace
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G) : CompactSpace G :=
  hG.2.2.1

theorem IsFinitelyGeneratedProPGroup.t2Space
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G) : T2Space G :=
  hG.2.2.2.1

theorem IsFinitelyGeneratedProPGroup.totallyDisconnectedSpace
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G) : TotallyDisconnectedSpace G :=
  hG.2.2.2.2

theorem IsFinitelyGeneratedProPGroup.isPGroup_quotient
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G)
    (H : Subgroup G) [H.Normal] (hH : IsOpen (H : Set G)) :
    IsPGroup p (G ⧸ H) :=
  hG.2.1 H hH

theorem IsFinitelyGeneratedProPGroup.secondCountableTopology
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G) :
    SecondCountableTopology G := by

  obtain ⟨⟨S, hS⟩, _hP, hCompact, hT2, hTotDisc⟩ := hG
  haveI : CompactSpace G := hCompact
  haveI : T2Space G := hT2
  haveI : TotallyDisconnectedSpace G := hTotDisc
  exact _root_.Erdos90.ProPGroupsInternal.secondCountableTopology_of_fg_profinite hS

theorem generatorRank_spec
    {p : ℕ} {G : Type} [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (hG : IsFinitelyGeneratedProPGroup p G) :
    ∃ S : Finset G, S.card = generatorRank G ∧
      (Subgroup.closure (S : Set G)).topologicalClosure = ⊤ := by
  obtain ⟨S₀, hS₀⟩ := hG.1
  have hne :
      ({k : ℕ | ∃ S : Finset G, S.card = k ∧
        (Subgroup.closure (S : Set G)).topologicalClosure = ⊤}).Nonempty :=
    ⟨S₀.card, S₀, rfl, hS₀⟩
  exact Nat.sInf_mem hne

structure ProPQuotient (p : ℕ) (G : Type)
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G] where

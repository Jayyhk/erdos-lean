theorem primesCongOneMod3_nth_poly_bound: вҲғ A : в„қ, 0 < A вҲ§ вҲҖ i : в„•, (primesCongOneMod3 i : в„қ) вүӨ (max 2 i : в„қ) ^ A := by
  obtain вҹЁB, hBpos, KвӮҖ, hcountвҹ© := primesCongOneMod3_dyadic_count_lower_bound
  let A : в„• := B * (KвӮҖ + 2)
  refine вҹЁ(A : в„қ), ?_, ?_вҹ©
  В· dsimp [A]
    positivity
  В· intro i
    let m : в„• := max 2 i
    let l : в„• := Nat.log 2 m
    let k : в„• := max KвӮҖ l.succ
    have hm_ge_two : 2 вүӨ m := by
      dsimp [m]
      exact le_max_left 2 i
    have hi_le_m : i вүӨ m := by
      dsimp [m]
      exact le_max_right 2 i
    have hm_ne_zero : m вү  0 := by
      omega
    have hk_ge_KвӮҖ : KвӮҖ вүӨ k := by
      dsimp [k]
      exact le_max_left KвӮҖ l.succ
    have hk_ge_lsucc : l.succ вүӨ k := by
      dsimp [k]
      exact le_max_right KвӮҖ l.succ
    have hi_lt_two_pow_lsucc : i < 2 ^ l.succ := by
      exact lt_of_le_of_lt hi_le_m (Nat.lt_pow_succ_log_self (by decide) m)
    have hi_lt_two_pow_k : i < 2 ^ k := by
      have hmono := pow_right_monotone (show (1 : в„•) вүӨ 2 by decide)
      exact lt_of_lt_of_le hi_lt_two_pow_lsucc (hmono hk_ge_lsucc)
    have hi_lt_count : i < Nat.count (fun n => n.Prime вҲ§ n % 3 = 1) (2 ^ (B * k)) := by
      exact lt_of_lt_of_le hi_lt_two_pow_k (hcount k hk_ge_KвӮҖ)
    have hnth_lt : primesCongOneMod3 i < 2 ^ (B * k) := by
      simpa [primesCongOneMod3] using
        (Nat.nth_lt_of_lt_count (p := fun n => n.Prime вҲ§ n % 3 = 1) hi_lt_count)
    have hk_le : k вүӨ KвӮҖ + l.succ := by
      have h1 : KвӮҖ вүӨ KвӮҖ + l.succ := by omega
      have h2 : l.succ вүӨ KвӮҖ + l.succ := by omega
      exact max_le h1 h2
    have hpow_log_le : 2 ^ l вүӨ m := by
      exact Nat.pow_le_of_le_log hm_ne_zero le_rfl
    have hsucc_le : 2 ^ l.succ вүӨ m ^ 2 := by
      calc
        2 ^ l.succ = 2 ^ l * 2 := by rw [pow_succ]
        _ вүӨ m * 2 := Nat.mul_le_mul_right 2 hpow_log_le
        _ вүӨ m * m := Nat.mul_le_mul_left m hm_ge_two
        _ = m ^ 2 := by rw [pow_two]
    have hbase : 2 ^ (KвӮҖ + l.succ) вүӨ m ^ (KвӮҖ + 2) := by
      calc
        2 ^ (KвӮҖ + l.succ) = 2 ^ KвӮҖ * 2 ^ l.succ := by rw [pow_add]
        _ вүӨ m ^ KвӮҖ * m ^ 2 := by
          gcongr
        _ = m ^ (KвӮҖ + 2) := by rw [вҶҗ pow_add]
    have hpow_bound_nat : 2 ^ (B * k) вүӨ m ^ A := by
      have hmono := pow_right_monotone (show (1 : в„•) вүӨ 2 by decide)
      calc
        2 ^ (B * k) вүӨ 2 ^ (B * (KвӮҖ + l.succ)) := by
          exact hmono (Nat.mul_le_mul_left B hk_le)
        _ = (2 ^ (KвӮҖ + l.succ)) ^ B := by rw [Nat.mul_comm, pow_mul]
        _ вүӨ (m ^ (KвӮҖ + 2)) ^ B := by
          exact pow_le_pow_left' hbase B
        _ = m ^ ((KвӮҖ + 2) * B) := by rw [вҶҗ pow_mul]
        _ = m ^ A := by
          dsimp [A]

    intro n
    dsimp [m]
    exact Nat.floor_pos.2 (by
      simpa using (one_le_powвӮҖ (show 1 вүӨ c by linarith) : 1 вүӨ c ^ n))
  have hx_mem : вҲҖ n, x n вҲҲ Set.Ioc 1 2 := by
    intro n
    constructor
    В· have hm_real_pos : 0 < (m n : в„қ) := by
        exact_mod_cast hm_pos n
      have hinv_pos : 0 < ((m n : в„қ)вҒ»В№) := by
        exact inv_pos.2 hm_real_pos
      dsimp [x]
      linarith
    В· dsimp [x]
      have hm_ge_one : (1 : в„қ) вүӨ m n := by
        exact_mod_cast (Nat.succ_le_of_lt (hm_pos n))
      have hinv_le_one : ((m n : в„қ)вҒ»В№) вүӨ 1 := inv_le_one_of_one_leвӮҖ hm_ge_one
      linarith
  have hbound : вҲҖ n, abs (seq n - a) вүӨ C / (m n : в„қ) := by
    intro n
    have h0 : abs (F (x n) - a * (m n : в„қ)) вүӨ C := by
      have h0' := hC (hx_mem n)
      dsimp [F, x] at h0'
      rw [show (1 + (m n : в„қ)вҒ»В№) - 1 = (m n : в„қ)вҒ»В№ by ring] at h0'
      simpa [div_inv_eq_mul] using h0'
    have hm_real_pos : 0 < (m n : в„қ) := by
      exact_mod_cast hm_pos n
    have hm_real_ne : (m n : в„қ) вү  0 := ne_of_gt hm_real_pos
    have hdiv : abs (F (x n) - a * (m n : в„қ)) / (m n : в„қ) вүӨ C / (m n : в„қ) := by
      exact div_le_div_of_nonneg_right h0 (le_of_lt hm_real_pos)
    have hEq : seq n - a = (F (x n) - a * (m n : в„қ)) / (m n : в„қ) := by
      dsimp [seq]
      field_simp [hm_real_ne]
    calc
      abs (seq n - a)
          = abs ((F (x n) - a * (m n : в„қ)) / (m n : в„қ)) := by rw [hEq]
      _ = abs (F (x n) - a * (m n : в„қ)) / (m n : в„қ) := by
            rw [abs_div, abs_of_pos hm_real_pos]
      _ вүӨ C / (m n : в„қ) := hdiv
  have hm_atTop : Filter.Tendsto m Filter.atTop Filter.atTop := by
    simpa [m] using (tendsto_nat_floor_atTop.comp (tendsto_pow_atTop_atTop_of_one_lt hc))
  have hm_real_atTop : Filter.Tendsto (fun n => (m n : в„қ)) Filter.atTop Filter.atTop := by
    exact (tendsto_natCast_atTop_iff.2 hm_atTop)
  have hCdiv : Filter.Tendsto (fun n => C / (m n : в„қ)) Filter.atTop (nhds 0) := by
    exact Filter.Tendsto.const_div_atTop hm_real_atTop C
  have habs : Filter.Tendsto (fun n => abs (seq n - a)) Filter.atTop (nhds 0) := by
    exact squeeze_zero (fun n => abs_nonneg _) hbound hCdiv
  have hdist : Filter.Tendsto (fun n => dist (seq n) a) Filter.atTop (nhds 0) := by
    simpa [Real.dist_eq] using habs
  have hseq : Filter.Tendsto seq Filter.atTop (nhds a) :=
    (tendsto_iff_dist_tendsto_zero.2 hdist)
  simpa [seq, F, x, m] using hseq

theorem tendsto_sum_range_div_of_tendsto_sum_Icc_div {f : в„• вҶ’ в„қ} {l : в„қ} :
    Filter.Tendsto
      (fun m : в„• => (вҲ‘ k вҲҲ Finset.Icc 1 m, f k) / (m : в„қ))
      Filter.atTop (nhds l) вҶ’
    Filter.Tendsto
      (fun m : в„• => (вҲ‘ k вҲҲ Finset.range m, f k) / (m : в„қ))
      Filter.atTop (nhds l) := by
  intro h
  let g : в„• вҶ’ в„қ := fun m => (вҲ‘ k вҲҲ Finset.Icc 1 m, f k) / (m : в„қ)
  have hg : Filter.Tendsto g Filter.atTop (nhds l) := h
  have hcomp : Filter.Tendsto (fun m : в„• => g (m - 1)) Filter.atTop (nhds l) := by
    simpa using hg.comp (Filter.tendsto_sub_atTop_nat 1)
  have hzero : Filter.Tendsto (fun m : в„• => f 0 / (m : в„қ)) Filter.atTop (nhds 0) := by
    simpa using tendsto_const_div_atTop_nhds_zero_nat (f 0)
  have hratio_aux : Filter.Tendsto (fun n : в„• => (n : в„қ) / ((n : в„қ) + 1)) Filter.atTop (nhds 1) := by
    simpa using (tendsto_natCast_div_add_atTop (1 : в„қ))
  have hu : Filter.Tendsto (fun m : в„• => (((m - 1 : в„•) : в„қ) / ((((m - 1 : в„•) : в„қ)) + 1))) Filter.atTop (nhds 1) := by
    simpa using hratio_aux.comp (Filter.tendsto_sub_atTop_nat 1)
  have hratio : Filter.Tendsto (fun m : в„• => (((m - 1 : в„•) : в„қ) / (m : в„қ))) Filter.atTop (nhds 1) := by
    refine Filter.Tendsto.congr' (Filter.Eventually.of_forall ?_) hu
    intro m
    cases m with
    | zero => norm_num
    | succ n =>
        simp [Nat.cast_sub (Nat.succ_le_succ (Nat.zero_le n))]
  have hmul : Filter.Tendsto (fun m : в„• => (((m - 1 : в„•) : в„қ) / (m : в„қ)) * g (m - 1)) Filter.atTop (nhds (1 * l)) := by
    exact hratio.mul hcomp
  have hadd : Filter.Tendsto (fun m : в„• => f 0 / (m : в„қ) + (((m - 1 : в„•) : в„қ) / (m : в„қ)) * g (m - 1)) Filter.atTop (nhds (0 + 1 * l)) := by
    exact hzero.add hmul
  have hadd' : Filter.Tendsto (fun m : в„• => f 0 / (m : в„қ) + (((m - 1 : в„•) : в„қ) / (m : в„қ)) * g (m - 1)) Filter.atTop (nhds l) := by
    simpa using hadd
  have hEq :
      (fun m : в„• => f 0 / (m : в„қ) + (((m - 1 : в„•) : в„қ) / (m : в„қ)) * g (m - 1)) =б¶ [Filter.atTop]
        (fun m : в„• => (вҲ‘ k вҲҲ Finset.range m, f k) / (m : в„қ)) := by
    filter_upwards [Filter.eventually_gt_atTop 0] with m hm
    rcases Nat.exists_eq_succ_of_ne_zero (Nat.ne_of_gt hm) with вҹЁn, rflвҹ©
    have hsum : (вҲ‘ k вҲҲ Finset.range (n + 1), f k) = f 0 + вҲ‘ k вҲҲ Finset.Icc 1 n, f k := by
      rw [Nat.range_succ_eq_Icc_zero]
      rw [вҶҗ Finset.insert_Icc_succ_left_eq_Icc (a := 0) (b := n) (Nat.zero_le n)]
      rw [Finset.sum_insert]
      В· simp
      В· simp
    rw [hsum, add_div]
    congr 1
    by_cases hn : n = 0
    В· simp [hn, g]
    В· have hn0 : (n : в„қ) вү  0 := by
        exact_mod_cast hn
      simpa [g] using (div_mul_div_cancelвӮҖ' hn0 (вҶ‘n + 1) (вҲ‘ k вҲҲ Finset.Icc 1 n, f k))
  exact Filter.Tendsto.congr' hEq hadd'

theorem tendsto_weighted_average_floor_pow_of_LSeries_pole {f : в„• вҶ’ в„қ} {a : в„Ӯ} {g : в„Ӯ вҶ’ в„Ӯ} :
    (вҲҖ s : в„Ӯ, 1 < s.re вҶ’ LSeriesSummable (fun n => (f n : в„Ӯ)) s) вҶ’

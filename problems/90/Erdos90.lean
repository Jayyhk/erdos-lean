  rw [hG, ← hcenterz']
  have hz0 : (z : ℂ) ≠ 0 := by
    exact_mod_cast hz.ne'
  have hz1 : (1 + (z : ℂ)) ≠ 0 := by
    have hz1r : (1 + z : ℝ) ≠ 0 := by
      linarith
    exact_mod_cast hz1r
  field_simp [hz0, hz1]
  ring

theorem continuousOn_centered_logRescalePartialSum_laplace_of_eqOn {f : ℕ → ℝ} {a : ℂ} {g : ℂ → ℂ} :

  continuous : Continuous map
  isProP : ∀ (H : Subgroup Q) [hN : H.Normal], IsOpen (H : Set Q) →
    IsPGroup p (Q ⧸ H)

attribute [instance] ProPQuotient.group ProPQuotient.topSpace

  letI : MulSemiringAction (M вүғвӮҗ[в„ҡ] M) (Ideal (рқ“һ M)) := Ideal.pointwiseMulSemiringAction
  obtain вҹЁП„, hП„вҹ© := Ideal.exists_smul_eq_of_isGaloisGroup p PвӮҖ P (M вүғвӮҗ[в„ҡ] M)
  let ПҒ : M вүғвӮҗ[в„ҡ] M := П„ * Пғ i * П„вҒ»В№

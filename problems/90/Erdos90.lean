            Algebra.adjoin в„Ө ({B.gen} : Set (CyclotomicField r в„ҡ)) := by
          simpa [Algebra.smul_def] using hz0
        simpa using (Subalgebra.neg_mem _ hzneg)
    have hz1z : ((r : в„Ө) ^ (r - 2)) вҖў (NumberField.integralBasis (CyclotomicField r в„ҡ) j) вҲҲ
        Algebra.adjoin в„Ө ({B.gen} : Set (CyclotomicField r в„ҡ)) := by
      simpa [Algebra.smul_def] using hz1q
    have hxadjoin : (NumberField.integralBasis (CyclotomicField r в„ҡ) j) вҲҲ
        Algebra.adjoin в„Ө ({B.gen} : Set (CyclotomicField r в„ҡ)) := by
      exact @mem_adjoin_of_smul_prime_pow_smul_of_minpoly_isEisensteinAt
        в„Ө в„ҡ (CyclotomicField r в„ҡ) (r : в„Ө) _ _ _ _ _ _
        (instIsScalarTowerCyclotomicField r в„ҡ) _ _ _ (B := B)
        (Nat.prime_iff_prime_int.1 hr) hBint (n := r - 2)
        (z := NumberField.integralBasis (CyclotomicField r в„ҡ) j) hxint hz1z hei
    rw [Algebra.adjoin_singleton_eq_range_aeval] at hxadjoin
    rcases hxadjoin with вҹЁQ, hQвҹ©
    rw [вҶҗ hQ]
    change IsIntegral в„Ө (B.basis.repr (Polynomial.aeval B.gen Q) i)
    rw [Polynomial.aeval_eq_sum_range, map_sum, Finset.sum_apply']
    refine IsIntegral.sum (R := в„Ө) (A := в„ҡ) (s := Finset.range (Q.natDegree + 1))
      (f := fun n => ((B.basis.repr (Q.coeff n вҖў B.gen ^ n)) i)) ?_
    intro n hn
    have hterm' : IsIntegral в„Ө ((Q.coeff n : в„ҡ) * B.basis.repr (B.gen ^ n) i) :=
      (isIntegral_algebraMap : IsIntegral в„Ө (Q.coeff n : в„ҡ)).mul (hpowint n i)
    simpa [Algebra.smul_def, hreprmul Q n i] using hterm'
  have hIB : вҲҖ i j, IsIntegral в„Ө ((NumberField.integralBasis (CyclotomicField r в„ҡ)).toMatrix B.basis i j) := by
    intro i j
    rw [Module.Basis.toMatrix_apply]
    have hx : B.basis j вҲҲ (algebraMap (рқ“һ (CyclotomicField r в„ҡ)) (CyclotomicField r в„ҡ)).range := by
      refine вҹЁвҹЁB.basis j, ?_вҹ©, rflвҹ©
      simpa [B.basis_eq_pow] using hBint.pow j.1
    have hx' : B.basis j вҲҲ Submodule.span в„Ө (Set.range (NumberField.integralBasis (CyclotomicField r в„ҡ))) := by
      exact (NumberField.mem_span_integralBasis (K := CyclotomicField r в„ҡ)).2 hx
    have hrepr := (Module.Basis.mem_span_iff_repr_mem (R := в„Ө) (S := в„ҡ)
      (b := NumberField.integralBasis (CyclotomicField r в„ҡ)) (m := B.basis j)).1 hx'
    rcases hrepr i with вҹЁn, hnвҹ©
    rw [вҶҗ hn]
    exact isIntegral_algebraMap
  have hcomp : Algebra.discr в„ҡ B.basis = Algebra.discr в„ҡ (NumberField.integralBasis (CyclotomicField r в„ҡ)) := by
    exact Algebra.discr_eq_discr_of_toMatrix_coeff_isIntegral (K := CyclotomicField r в„ҡ) hBI hIB
  have hcoe : (((NumberField.discr (CyclotomicField r в„ҡ)) : в„Ө) : в„ҡ) = Algebra.discr в„ҡ B.basis := by
    calc
      (((NumberField.discr (CyclotomicField r в„ҡ)) : в„Ө) : в„ҡ) =
          Algebra.discr в„ҡ (NumberField.integralBasis (CyclotomicField r в„ҡ)) := NumberField.coe_discr (K := CyclotomicField r в„ҡ)
      _ = Algebra.discr в„ҡ B.basis := hcomp.symm
  have hdiscr_int : NumberField.discr (CyclotomicField r в„ҡ) =
      (-1 : в„Ө) ^ ((r - 1) / 2) * (r : в„Ө) ^ (r - 2) := by
    apply Int.cast_injective (Оұ := в„ҡ)
    calc
      (((NumberField.discr (CyclotomicField r в„ҡ)) : в„Ө) : в„ҡ) = Algebra.discr в„ҡ B.basis := hcoe
      _ = (-1) ^ ((r - 1) / 2) * r ^ (r - 2) := hBdiscr
      _ = ((((-1 : в„Ө) ^ ((r - 1) / 2) * (r : в„Ө) ^ (r - 2)) : в„Ө) : в„ҡ) := by
        simp
  rw [hdiscr_int]
  by_cases hEven : Even ((r - 1) / 2)
  В· rw [hEven.neg_one_pow]

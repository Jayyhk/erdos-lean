theorem lemma_2_4_integrable_shift_count (𝒟 : AdmissibleDatum) (R : ℝ) (u : 𝒟.K) (hΛu : 𝒟.Φ u ∈ (𝒟.Λ : Set 𝒟.V)) : MeasureTheory.Integrable (fun a : 𝒟.V => (((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ℝ)) (MeasureTheory.volume.restrict (lemma_2_4_FD 𝒟)) := by
  classical
  letI : MeasurableConstVAdd (↥𝒟.Λ) 𝒟.V := lemma_2_4_measurableConstVAdd 𝒟
  letI : MeasureTheory.VAddInvariantMeasure (↥𝒟.Λ) 𝒟.V MeasureTheory.volume :=
    lemma_2_4_vaddInvariantVolume 𝒟
  let F : Set 𝒟.V := lemma_2_4_FD 𝒟
  let S : Set 𝒟.V := { a : 𝒟.V | a ∈ 𝒟.closedPolydisc R ∧ a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R }
  let g_u : 𝒟.V → ENNReal := fun a =>
    (((𝒟.X_finset a R).filter (fun x => x + 𝒟.Φ u ∈ 𝒟.X_finset a R)).card : ENNReal)
  have hclosed_eq : 𝒟.closedPolydisc R = Metric.closedBall (0 : 𝒟.V) R := by
    ext z
    simp [AdmissibleDatum.closedPolydisc, Metric.mem_closedBall, supNorm_eq_norm]
  have hB : MeasurableSet (𝒟.closedPolydisc R) := by
    rw [hclosed_eq]
    exact measurableSet_closedBall
  have hS : MeasurableSet S := by
    change MeasurableSet (𝒟.closedPolydisc R ∩ {a : 𝒟.V | a + 𝒟.Φ u ∈ 𝒟.closedPolydisc R})
    refine hB.inter ?_
    exact hB.preimage (measurable_id.add measurable_const)
  have hmcv : MeasurableConstVAdd (↥𝒟.Λ) 𝒟.V := inferInstance
  have hvinv : MeasureTheory.VAddInvariantMeasure (↥𝒟.Λ) 𝒟.V MeasureTheory.volume := inferInstance
  have hcount (a : 𝒟.V) :
      (∑' l : 𝒟.Λ, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a)) = g_u a := by
    let T : Set 𝒟.Λ :=
      {l : 𝒟.Λ | a + (l : 𝒟.V) ∈ 𝒟.closedPolydisc R ∧
          a + (l : 𝒟.V) + 𝒟.Φ u ∈ 𝒟.closedPolydisc R}
    calc
      (∑' l : 𝒟.Λ, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a))
          = ∑' l : 𝒟.Λ, T.indicator (fun _ => (1 : ENNReal)) l := by
            refine tsum_congr ?_
            intro l
            change S.indicator (fun _ => (1 : ENNReal)) ((l : 𝒟.V) + a) = _
            by_cases hl : l ∈ T
            · have hs : (l : 𝒟.V) + a ∈ S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
            · have hs : (l : 𝒟.V) + a ∉ S := by
                simpa [T, S, add_assoc, add_left_comm, add_comm] using hl
              simp [hl, hs]
      _ = ∑' l : T, (1 : ENNReal) := by
            symm
            exact tsum_subtype T (fun _ => (1 : ENNReal))
      _ = T.encard := ENNReal.tsum_set_one T
      _ = g_u a := by
            dsimp [g_u, T]
            exact_mod_cast (lemma_2_4_shift_count_eq_lattice_encard 𝒟 a R u hΛu)
  have hlin0 :
      ∫⁻ x, S.indicator (fun _ => (1 : ENNReal)) x ∂MeasureTheory.volume =
        ∑' l : 𝒟.Λ, ∫⁻ x in F, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ x) ∂MeasureTheory.volume := by
    simpa [F] using
      (@MeasureTheory.IsAddFundamentalDomain.lintegral_eq_tsum'' (↥𝒟.Λ) (𝒟.V)
        inferInstance inferInstance inferInstance (lemma_2_4_FD 𝒟) MeasureTheory.volume
        hmcv hvinv inferInstance (lemma_2_4_isAddFundamentalDomain 𝒟)
        (S.indicator (fun _ => (1 : ENNReal))))
  have hmeas_indicator : Measurable (S.indicator (fun _ : 𝒟.V => (1 : ENNReal))) := by
    exact Measurable.indicator measurable_const hS
  have hmeas_l : ∀ l : 𝒟.Λ,
      Measurable fun a : 𝒟.V => S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a) := by
    intro l
    exact hmeas_indicator.comp (measurable_const_vadd l)
  have hlin :
      ∫⁻ a in F, ∑' l : 𝒟.Λ, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a) ∂MeasureTheory.volume =
        ∑' l : 𝒟.Λ, ∫⁻ a in F, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a) ∂MeasureTheory.volume := by
    simpa using
      (MeasureTheory.lintegral_tsum
        (μ := MeasureTheory.volume.restrict F)
        (f := fun l : 𝒟.Λ => fun a : 𝒟.V => S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a))
        (fun l => (hmeas_l l).aemeasurable))
  have hglobal :
      ∫⁻ a, S.indicator (fun _ => (1 : ENNReal)) a ∂MeasureTheory.volume = MeasureTheory.volume S := by
    simp [hS]
  have hlintegral_eq : ∫⁻ a in F, g_u a ∂MeasureTheory.volume = MeasureTheory.volume S := by
    calc
      ∫⁻ a in F, g_u a ∂MeasureTheory.volume
          = ∫⁻ a in F, ∑' l : 𝒟.Λ, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a) ∂MeasureTheory.volume := by
              refine MeasureTheory.lintegral_congr_ae ?_
              exact Filter.Eventually.of_forall (fun a => (hcount a).symm)
      _ = ∑' l : 𝒟.Λ, ∫⁻ a in F, S.indicator (fun _ => (1 : ENNReal)) (l +ᵥ a) ∂MeasureTheory.volume := hlin
      _ = ∫⁻ a, S.indicator (fun _ => (1 : ENNReal)) a ∂MeasureTheory.volume := hlin0.symm
      _ = MeasureTheory.volume S := hglobal
  have hg_meas : AEMeasurable g_u (MeasureTheory.volume.restrict F) := by
    simpa [hcount] using (Measurable.ennreal_tsum (fun l : 𝒟.Λ => hmeas_l l)).aemeasurable
  have hS_subset : S ⊆ 𝒟.closedPolydisc R := fun _ ha => ha.1
  have hB_lt_top : MeasureTheory.volume (𝒟.closedPolydisc R) < ⊤ := by
    rw [hclosed_eq]
    exact MeasureTheory.measure_closedBall_lt_top (μ := MeasureTheory.volume) (x := (0 : 𝒟.V)) (r := R)
  have hS_ne_top : MeasureTheory.volume S ≠ ⊤ :=
    (lt_of_le_of_lt (MeasureTheory.measure_mono hS_subset) hB_lt_top).ne
  simpa [g_u, ENNReal.toReal_natCast] using
    (MeasureTheory.integrable_toReal_of_lintegral_ne_top hg_meas (by
      rw [hlintegral_eq]
      exact hS_ne_top))


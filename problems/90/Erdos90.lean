theorem exists_continuous_h1ToHom_lift_of_restriction (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
    (y : (H p 1 G : Type)) :
    ∃ ψ : Additive G →+ ZMod p,
      Continuous ψ ∧
      _root_.Erdos90.TransgressionContinuous.h1ToHom p G N hN
        ((restriction p G N 1).hom y) =
        ψ.comp (MonoidHom.toAdditive N.subtype) := by
  classical
  haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
  let e := continuousH1TrivialAddEquivContinuousAddHom (p := p)
  refine ⟨(e G y).toAddMonoidHom, (e G y).continuous_toFun, ?_⟩
  have hx :
      _root_.Erdos90.TransgressionContinuous.h1ToHom p G N hN
        ((restriction p G N 1).hom y) =
      ((e ↥N ((restriction p G N 1).hom y)).toAddMonoidHom) := by
    simpa [e] using h1ToHom_eq_package (p := p) (G := G) (N := N) (hN := hN)
      ((restriction p G N 1).hom y)
  rw [hx]
  have hnat :=
    _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog_naturality
      p ↥N G N.subtype continuous_subtype_val y
  have hnat' := congrArg ContinuousAddMonoidHom.toAddMonoidHom hnat
  simpa [e, restriction,
    continuousH1TrivialAddEquivContinuousAddHom] using hnat'

theorem h1ClassOfContinuousHom_package (p : ℕ) [Fact p.Prime] :
    ∃ c : ∀ (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
        [T2Space K] [CompactSpace K] [TotallyDisconnectedSpace K],
        (Additive K →ₜ+ ZMod p) → (H p 1 K : Type),
      (∀ (K : Type) [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
          [T2Space K] [CompactSpace K] [TotallyDisconnectedSpace K]
          (x : (H p 1 K : Type)),
          c K ((continuousH1TrivialAddEquivContinuousAddHom (p := p) (K := K) x)) = x) ∧
      (∀ (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
          [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
          (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G))
          (ψ : Additive G →ₜ+ ZMod p),
          haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
          (restriction p G N 1).hom (c G ψ) =
            c ↥N (ψ.comp (additiveSubtypeContinuousHom G N))) := by
  classical
  let e := continuousH1TrivialAddEquivContinuousAddHom (p := p)
  refine ⟨fun K _ _ _ _ _ _ => (e K).symm, ?_, ?_⟩
  · intro K _ _ _ _ _ _ x
    exact (e K).symm_apply_apply x
  · intro G _ _ _ _ _ _ N _ hN ψ
    haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
    have hnat :=
      _root_.Erdos90.TransgressionContinuousInternal.continuousH1TrivialAddEquivContinuousAddHom_inhomog_naturality
        p ↥N G N.subtype continuous_subtype_val ((e G).symm ψ)
    refine (e ↥N).injective ?_
    simpa [restriction, additiveSubtypeContinuousHom, e,
      continuousH1TrivialAddEquivContinuousAddHom] using hnat

theorem inflation_range_le_restriction_ker_H1 (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] :
    LinearMap.range (inflation p G N 1).hom.toLinearMap ≤
      LinearMap.ker (restriction p G N 1).hom.toLinearMap := by
  rw [LinearMap.range_le_ker_iff]
  have hcomp := by
    simpa [inflation, restriction] using
      (ContinuousCohomology.cohomologyMapTrivial_comp (R := ZMod p)
        (f := N.subtype) (g := QuotientGroup.mk' N)
        (hf := continuous_subtype_val) (hg := QuotientGroup.continuous_mk)
        (X := TopModuleCat.of (ZMod p) (ZMod p)) (n := 1))
  have hzero :=
    cohomologyMapTrivial_eq_zero_of_eq_one (p := p)
      (A := N) (B := G ⧸ N)
      (1 : N →* G ⧸ N) continuous_one rfl
  have hcat := hcomp.symm.trans hzero
  ext x
  have hx := congrArg (fun f => f.hom x) hcat
  simpa using hx

theorem restriction_ker_le_inflation_range_H1 (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    LinearMap.ker (restriction p G N 1).hom.toLinearMap ≤
      LinearMap.range (inflation p G N 1).hom.toLinearMap := by
  intro x hx
  simp only [LinearMap.mem_ker] at hx
  haveI : CompactSpace ↥N := isCompact_iff_compactSpace.mp hN.isCompact
  haveI : TotallyDisconnectedSpace (G ⧸ N) :=
    _root_.Erdos90.QuotientGroup.totallyDisconnectedSpace N hN
  haveI hClosed : IsClosed ((N : Set G)) := hN
  haveI : T2Space (G ⧸ N) :=
    have : T1Space (G ⧸ N) := QuotientGroup.instT1Space
    inferInstance
  rcases continuousH1TrivialAddEquivContinuousAddHom_package (p := p) with ⟨e, he_nat⟩
  let ψcts : Additive G →ₜ+ ZMod p := e G x
  have hxr : (restriction p G N 1).hom x = 0 := by simpa using hx
  have hvanish : ∀ n : N, ψcts (Additive.ofMul (n : G)) = 0 := by
    intro n
    have hnatRes := he_nat (G1 := N) (G2 := G) N.subtype continuous_subtype_val x
    have hnatRes_n := congrArg (fun f : Additive N →ₜ+ ZMod p => f (Additive.ofMul n)) hnatRes
    have hxr' :
        (TopModuleCat.Hom.hom
          (ContinuousCohomology.cohomologyMapTrivial (ZMod p) N.subtype continuous_subtype_val
            (TopModuleCat.of (ZMod p) (ZMod p)) 1)) x = 0 := by
      simpa [restriction] using hxr
    dsimp [ψcts] at hnatRes_n ⊢
    rw [hxr'] at hnatRes_n
    simpa using hnatRes_n.symm
  let φcts : G →ₜ* Multiplicative (ZMod p) :=
    { toFun := fun g => Multiplicative.ofAdd (ψcts (Additive.ofMul g))
      map_one' := by simp [ψcts]
      map_mul' := by
        intro a b
        simp [ψcts.map_add]
      continuous_toFun := by
        simpa [ψcts] using ψcts.continuous_toFun }
  have hNker : N ≤ φcts.toMonoidHom.ker := by
    intro n hn
    change Multiplicative.ofAdd (ψcts (Additive.ofMul n)) = 1
    simp [hvanish ⟨n, hn⟩]
  let φq : G ⧸ N →* Multiplicative (ZMod p) := QuotientGroup.lift N φcts.toMonoidHom hNker
  have hcont_comp : Continuous (φq ∘ QuotientGroup.mk) := by
    simpa [φq, Function.comp] using φcts.continuous_toFun
  have hcont_q : Continuous φq := by
    exact (QuotientGroup.isOpenQuotientMap_mk (N := N)).continuous_comp_iff.mp hcont_comp
  let ψbar : Additive (G ⧸ N) →ₜ+ ZMod p :=
    { toFun := fun q => (φq q.toMul).toAdd
      map_zero' := by simp [φq]
      map_add' := by
        intro a b
        simp [φq.map_mul]
      continuous_toFun := by
        exact hcont_q }
  let y : (H p 1 (G ⧸ N) : Type) := (e (G ⧸ N)).symm ψbar
  let qAdd : Additive G →ₜ+ Additive (G ⧸ N) :=
    { toFun := fun g => Additive.ofMul ((QuotientGroup.mk' N) g.toMul)
      map_zero' := by simp
      map_add' := by intro a b; simp
      continuous_toFun := by
        change Continuous (fun g : G => Additive.ofMul ((QuotientGroup.mk' N) g))
        simpa using QuotientGroup.continuous_mk }
  have hcompq : ψbar.comp qAdd = ψcts := by
    ext g
    change (φq ((QuotientGroup.mk' N) g.toMul)).toAdd = ψcts g
    simp [φq, QuotientGroup.lift_mk, φcts]
  have hE : e G ((inflation p G N 1).hom y) = ψcts := by
    have hnatInf :=
      he_nat (G1 := G) (G2 := G ⧸ N) (QuotientGroup.mk' N) QuotientGroup.continuous_mk y
    rw [show e (G ⧸ N) y = ψbar by simp [y]] at hnatInf
    simpa [inflation, qAdd] using hnatInf.trans hcompq
  have hy : (inflation p G N 1).hom y = x := by
    exact (e G).injective (by simpa [ψcts] using hE)
  simp only [LinearMap.mem_range]
  exact ⟨y, hy⟩

theorem exact_at_H1G (p : ℕ) [Fact p.Prime]
    (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G]
    (N : Subgroup G) [N.Normal] (hN : IsClosed (N : Set G)) :
    LinearMap.range (inflation p G N 1).hom.toLinearMap =
      LinearMap.ker (restriction p G N 1).hom.toLinearMap := by
  exact le_antisymm
    (inflation_range_le_restriction_ker_H1 (p := p) (G := G) (N := N))
    (restriction_ker_le_inflation_range_H1 (p := p) (G := G) (N := N) hN)


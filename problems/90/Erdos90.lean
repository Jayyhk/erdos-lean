    apply Complex.ext <;> simp [haim]
  have hEq : g (1 + z) = LSeries (fun n => (f n : ℂ)) (1 + z) - a / z := by
    have hEq0 := heq (show (1 + z) ∈ {s : ℂ | 1 < s.re} by
      simpa [Complex.add_re] using add_lt_add_left hz 1)
    simpa using hEq0
  have hL := lseries_eq_logRescalePartialSum_laplace hnonneg hsumm z hz
  have hmain :
      (g (1 + z) - ((a.re : ℝ) : ℂ)) / (1 + z) =
        (∫ x in Set.Ioi (0 : ℝ), (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x))) -
          ((a.re : ℝ) : ℂ) / z := by
    rw [hEq, hL, ha_re]
    field_simp [hz0, h1z0]
    ring_nf
    simp
  have hlog_int :
      MeasureTheory.IntegrableOn
        (fun x : ℝ => (((logRescalePartialSum f x : ℝ) : ℂ) * Complex.exp (-z * x)))
        (Set.Ioi (0 : ℝ)) :=
    integrableOn_logRescalePartialSum_kernel hnonneg hsumm z hz

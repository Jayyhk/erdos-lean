    calc
      Nat.card (F вүғвӮҗ[в„ҡ] F) = Nat.card ((M вүғвӮҗ[в„ҡ] M) в§ё H) := by
        exact Nat.card_congr ((IsGalois.normalAutEquivQuotient H).symm.toEquiv)
      _ = 3 := hcardQ
  have hfinrankF : Module.finrank в„ҡ F = 3 := by
    exact (IsGalois.card_aut_eq_finrank в„ҡ F).symm.trans hcardF
  have hfinrankFM : Module.finrank F M = 3 ^ k := by

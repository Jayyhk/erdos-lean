        have hJNtop : J0 вҠ” N = вҠӨ := by
          have hdiv : Ideal.absNorm (J0 вҠ” N) вҲЈ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 вүӨ J0 вҠ” N by exact le_sup_left)
          have hdiv1 : Ideal.absNorm (J0 вҠ” N) вҲЈ 1 := by
            rw [вҶҗ hJNcop.gcd_eq_one]

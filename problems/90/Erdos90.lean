    exact measurableSet_closedBall
  have hS : MeasurableSet S := by
    change MeasurableSet (рқ’ҹ.closedPolydisc R вҲ© {a : рқ’ҹ.V | a + рқ’ҹ.ОҰ u вҲҲ рқ’ҹ.closedPolydisc R})
    refine hB.inter ?_

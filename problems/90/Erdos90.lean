        Ideal.ramificationIdx p 𝔓 =
            Ideal.ramificationIdx p 𝔮 * Ideal.ramificationIdx 𝔮 𝔓 := by
          exact Ideal.ramificationIdx_algebra_tower
            (R := ℤ) (S := 𝓞 𝒟.L) (T := 𝓞 𝒟.K)
            (p := p) (P := 𝔮) (Q := 𝔓) hmap𝔮_ne hpmap_ne hmap_le
        _ = 1 := by rw [h𝔮e, hrel_e]
    have habs_f : Ideal.inertiaDeg p 𝔓 = 1 := by
      letI : 𝔓.LiesOver 𝔮 := h𝔓over𝔮
      calc
        Ideal.inertiaDeg p 𝔓 = Ideal.inertiaDeg p 𝔮 * Ideal.inertiaDeg 𝔮 𝔓 := by
          exact Ideal.inertiaDeg_algebra_tower
            (R := ℤ) (S := 𝓞 𝒟.L) (T := 𝓞 𝒟.K) p 𝔮 𝔓

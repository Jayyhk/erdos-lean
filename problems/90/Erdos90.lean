      simp only [hc0, hc1, b0, sub_eq_add_neg]
      have hs : (fun i : Fin 1 => ![g, h] i.succ) = ![h] := by
        ext i
        fin_cases i
        rfl
      rw [hs]
      norm_num
      rw [← add_assoc]
      rfl
    calc
      (QPull p G N ω) (g, h) = ((_root_.Erdos90.InhomogContsCochains.d p G 1) b) ![g, h] := by
        symm
        exact hbh'
      _ = b0 h - b0 (g * h) + b0 g := hd_eval
  rcases normalized_quotientCocycle_class_eq_transgression_of_inflated_coboundary p G N hN ω h1 h2 hinfl with ⟨χ, hχ⟩
  rw [LinearMap.mem_range]
  refine ⟨χ, ?_⟩
  rw [← hωx]
  symm
  exact hχ

theorem restriction_range_comap_le_ker_transgression (p : ℕ) [Fact p.Prime]

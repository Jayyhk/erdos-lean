        have hJLcop : IsCoprime J0 L0 := Ideal.isCoprime_iff_sup_eq.mpr (Ideal.absNorm_eq_one_iff.mp hsupnorm)
        have hMleJ0 : M вүӨ J0 := (Ideal.span_singleton_le_iff_mem J0).2 hm_mem_J0
        have hNleL0 : N вүӨ L0 := (Ideal.span_singleton_le_iff_mem L0).2 hn_mem_L0
        have hLM0 : Ideal.absNorm (L0 вҠ” M) вү  0 := by
          intro h0
          have hdiv : Ideal.absNorm (L0 вҠ” M) вҲЈ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 вүӨ L0 вҠ” M by exact le_sup_left)
          rw [h0] at hdiv
          exact hn0 (Nat.zero_dvd.mp hdiv)
        have hJN0 : Ideal.absNorm (J0 вҠ” N) вү  0 := by
          intro h0
          have hdiv : Ideal.absNorm (J0 вҠ” N) вҲЈ m := by
            simpa [hJ0n] using Ideal.absNorm_dvd_absNorm_of_le (show J0 вүӨ J0 вҠ” N by exact le_sup_left)
          rw [h0] at hdiv
          exact hm0 (Nat.zero_dvd.mp hdiv)
        have hLMcop : (Ideal.absNorm (L0 вҠ” M)).Coprime n := by
          have hm_mem : (m : рқ“һ K) вҲҲ L0 вҠ” M := (show M вүӨ L0 вҠ” M from le_sup_right) (Ideal.subset_span (by simp))
          exact helper hLM0 hm_mem hcop
        have hJNcop : (Ideal.absNorm (J0 вҠ” N)).Coprime m := by
          have hn_mem : (n : рқ“һ K) вҲҲ J0 вҠ” N := (show N вүӨ J0 вҠ” N from le_sup_right) (Ideal.subset_span (by simp))
          exact helper hJN0 hn_mem hcop.symm
        have hLMtop : L0 вҠ” M = вҠӨ := by
          have hdiv : Ideal.absNorm (L0 вҠ” M) вҲЈ n := by
            simpa [hL0n] using Ideal.absNorm_dvd_absNorm_of_le (show L0 вүӨ L0 вҠ” M by exact le_sup_left)
          have hdiv1 : Ideal.absNorm (L0 вҠ” M) вҲЈ 1 := by
            rw [вҶҗ hLMcop.gcd_eq_one]

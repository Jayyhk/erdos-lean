    have hpc_lt_q : past_cutoff < q := by
      by_cases hk_zero : k = 0
      · rw [hpc_def]
        simp [hk_zero]
        exact Nat.lt_of_le_of_lt (Nat.zero_le _) (Nat.lt_of_le_of_lt (Nat.zero_le _) hq_prime.one_lt)
      · -- k ≥ 1: past_cutoff ≤ ⌊exp(y_k^{A-1})⌋₊.

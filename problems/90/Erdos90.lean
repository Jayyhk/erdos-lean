            (show R (n + 1) вүӨ R n from hRle n) ((q (n + 1)) x)) := hstep n ((q (n + 1)) x)
      _ = (t n).1 ((q n) x) := by
        congr 1
        dsimp [q]
        simpa using congrArg (fun h => h x)
          (QuotientGroup.map_comp_map
            (N := N) (M := R (n + 1)) (O := R n)
            (f := MonoidHom.id G) (g := MonoidHom.id G)
            (hf := show N вүӨ (R (n + 1)).comap (MonoidHom.id G) by
              simpa using (show N вүӨ R (n + 1) from le_sup_left))

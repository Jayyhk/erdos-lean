    rcases (Subgroup.ne_bot_iff_exists_ne_one).mp hQinertia_ne_bot with вҹЁПғi, hПғi_neвҹ©
    refine вҹЁПғi.1, Q.1, Q.2, hcardQ3, Пғi.2, ?_вҹ©
    simpa using hПғi_ne
  choose Пғ hПғ using hExistsFor
  refine вҹЁПғ, ?_вҹ©
  intro i
  rcases hПғ i with вҹЁP, hPmem, hPcard, hПғmem, hПғneвҹ©
  exact вҹЁP, hPmem, hPcard, hПғmem, hПғneвҹ©

theorem ramification_vectors_span_top_rel_discr (в„“ : в„•) (_hв„“ : 0 < в„“) (r : Fin в„“ вҶ’ в„•)
    (_hr_prime : вҲҖ i, (r i).Prime)
    (_hr_inj : Function.Injective r)
    (_hr_mod3 : вҲҖ i, r i % 3 = 1)

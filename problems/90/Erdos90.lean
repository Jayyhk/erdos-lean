    φ (consecutiveDifferencesTuple H n fun i => f (g i))
  congr 1
  funext i
  simp [consecutiveDifferencesTuple, map_mul]

noncomputable def inhomogCochainPullback (p : ℕ) [Fact p.Prime]
    (G H : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H]

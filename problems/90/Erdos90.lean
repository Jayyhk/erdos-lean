noncomputable def conjEquiv (g : G) : (↥N) ≃* (↥N) := MulAut.conjNormal g

theorem conjEquiv_continuous (g : G) : Continuous (conjEquiv (G := G) N g) := by

  refine continuous_induced_rng.2 ?_
  have hval : ∀ x : ↥N,
      ((conjEquiv (G := G) N g x : ↥N) : G) = g * (x : G) * g⁻¹ :=
    fun x => MulAut.conjNormal_apply g x
  simp only [Function.comp_def, hval]
  exact (continuous_const.mul continuous_subtype_val).mul continuous_const

noncomputable def conjContEquiv (g : G) : (↥N) ≃ₜ* (↥N) where
  toMulEquiv := conjEquiv (G := G) N g
  continuous_toFun := conjEquiv_continuous (G := G) N g
  continuous_invFun := by

    refine continuous_induced_rng.2 ?_
    simp only [Function.comp_def]

    exact (continuous_const.mul continuous_subtype_val).mul continuous_const

private theorem conjInvContinuous (g : G) :
    Continuous ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N) : ↥N → ↥N) :=
  conjEquiv_continuous (G := G) N g⁻¹


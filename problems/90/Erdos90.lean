    _ = AdmissibleDatum.f 𝒟 * 2 := by
      rw [AdmissibleDatum.f, Algebra.IsQuadraticExtension.finrank_eq_two 𝒟.L 𝒟.K]
    _ = 2 * AdmissibleDatum.f 𝒟 := by
      ring

theorem admissibleDatum_finrankK_eq_two_mul_f_anyAlg (𝒟 : AdmissibleDatum) [hAlg : Algebra ℚ 𝒟.K] :

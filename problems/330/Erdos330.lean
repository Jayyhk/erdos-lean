theorem exists_crtProduct_CRTGadget_of_card_formula {ι : Type*}
    [Fintype ι] [DecidableEq ι]
    (P : Finset ℕ) (m : ℕ → ℕ) (M a : ℕ)
    (p0 : ℕ) [NeZero M] [Fact p0.Prime] [NeZero p0]
    (hp0_eq : p0 = m a)
    (p : ι → ℕ) [∀ i, Fact (Nat.Prime (p i))]

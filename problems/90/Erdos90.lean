theorem bk_cycles1_linearEquiv_BKContsHom (p : ℕ) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    (N : Subgroup G) [N.Normal] :
    ∃ e : (BKHomogeneousComplex p G N).cycles 1 ≃ₗ[ZMod p] BKContsHomSubmodule p G N,
      ∀ (g : G) (z : (BKHomogeneousComplex p G N).cycles 1) (y : ↥N),
        (e ((HomologicalComplex.cyclesMap
          (ContinuousCohomology.cochainsMapTrivial (ZMod p)
            ((MulAut.conjNormal g⁻¹ : ↥N ≃* ↥N).toMonoidHom)
            (bk_conjNormal_continuous G N g⁻¹)
            (TopModuleCat.of (ZMod p) (ZMod p))) 1).hom z)).1 y =
          (e z).1 ⟨g⁻¹ * (y : G) * g, by
            simpa using (‹N.Normal›.conj_mem (y : G) y.2 g⁻¹)⟩ := by
  let toFun : (BKHomogeneousComplex p G N).cycles 1 →ₗ[ZMod p] BKContsHomSubmodule p G N :=
    { toFun := fun z => ⟨bk_cycles1_eval p G N z, bk_cycles1_eval_mem_BKContsHom p G N z⟩
      map_add' := by
        intro z w
        apply Subtype.ext
        ext y

        В· simpa using (continuous_snd : Continuous fun gh : (G в§ё N) Г— (G в§ё N) => gh.2))вҹ©
  have hf : _root_.Erdos90.InhomogClassAPI.IsCocycle2 p (G в§ё N) f := by

        fun i : Fin (n + 1) => (g 0)вҒ»В№ * g i := by
    simpa [prefixProdTuple, consecutiveDifferencesTuple] using
      (partialProd_consecutiveDifferences G n g)
  rw [hprefix]
  simpa using homogObj_towerEval_leftMul p G n x (g 0)вҒ»В№ g

theorem inhomogToHomog_homogToInhomog (p : в„•) [Fact p.Prime] (G : Type) [Group G] [TopologicalSpace G] [IsTopologicalGroup G] [T2Space G] [CompactSpace G] [TotallyDisconnectedSpace G] (n : в„•) : (inhomogToHomog p G n).comp (homogToInhomog p G n) = (LinearMap.id : HomogObjType p G n вҶ’вӮ—[ZMod p] HomogObjType p G n) := by
